# comments allowed
browse_single: 	true
max_search: 	4000000
code_font_size: 20

projects:
	orbiter: Project
		name: 	orbiter
		root: 	'foundry/orbiter'
		build:	silver orbiter
		cwd:	'.'
		run:	orbiter
		files:	orbiter.ag Editor.ag

consoles:
	shell: ConsoleInstance
		name:	shell
		kind:	shell

	jean: ConsoleInstance
		name:	claude
		kind:	claude
		run:	claude --dangerously-skip-permissions