# comments allowed
show_right: false

projects:
	silver: Project
		name: 	silver
		root: 	'/src/silver'
		build:	make debug

	hyperspace: Project
		name: 	hyperspace
		root: 	'/src/silver/foundry/hyperspace'
		build:	silver hyperspace
	
	test4: Project
		name: 	test4
		deps: 	silver
		root: 	'/src/silver/foundry/test4'
		build:	silver test4
		cwd:	'/src/silver'
		run:	test4
