# comments allowed
projects:
	orbiter: Project
		name: 	orbiter
		root: 	'foundry/orbiter'
		build:	silver orbiter
		cwd:	'.'
		run:	orbiter
		files:	orbiter.ag Editor.ag

consoles:
	shell: ConsoleInstance
		name:	shell
		kind:	shell
	claude: ConsoleInstance
		name:	claude
		kind:	claude
		run:	claude
	gemini: ConsoleInstance
		name:	gemini
		kind:	gemini
		run:	gemini -y
