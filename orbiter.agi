# comments allowed
projects:
	silver: Project
		name: 	silver
		root: 	'.'
		build:	make debug
		files:	src/silver.c src/aether.c foundry/trinity/Canvas.ag

	hyperspace: Project
		name: 	hyperspace
		root: 	'foundry/hyperspace'
		build:	silver hyperspace --clean
		cwd:	'.'
		run:	hyperspace

	test4: Project
		name: 	test4
		deps: 	silver
		root: 	'foundry/test4'
		build:	silver test4 --clean
		cwd:	'.'
		run:	test4

consoles:
	shell: ConsoleInstance
		name:	shell
		kind:	shell
	claude: ConsoleInstance
		name:	claude
		kind:	claude
		run:	claude
	gemini: ConsoleInstance
		name:	gemini
		kind:	gemini
		run:	gemini -y
