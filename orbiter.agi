# comments allowed
projects:
	silver: Project
		name: 	silver
		root: 	'/src/silver'
		build:	make debug

	hyperspace: Project
		name: 	hyperspace
		root: 	'/src/silver/foundry/hyperspace'
		build:	silver hyperspace --clean
		cwd:	'/src/silver'
		run:	hyperspace
	
	test4: Project
		name: 	test4
		deps: 	silver
		root: 	'/src/silver/foundry/test4'
		build:	silver test4 --clean
		cwd:	'/src/silver'
		run:	test4

consoles:
	shell: ConsoleInstance
		name:	shell
		kind:	shell
	claude: ConsoleInstance
		name:	claude
		kind:	claude
	gemini: ConsoleInstance
		name:	gemini
		kind:	gemini
