            vmodel    = Model [ vk: cv.vk, w: w, s: vshader, rigid_s: cshader, transparent_s: cshader, samplers: sm, subdiv: subdiv_levels ]
            vmodel.id = gm
            # auto-frame: union of POSITION bounds in WORLD space — each mesh
            # node's composed scene-graph transform applied to its box corners
            mnx : f32 [  1e9 ]
            mny : f32 [  1e9 ]
            mnz : f32 [  1e9 ]
            mxx : f32 [ -1e9 ]
            mxy : f32 [ -1e9 ]
            mxz : f32 [ -1e9 ]
            for [ nd: Node ] in gm.nodes
