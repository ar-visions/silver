                acfg : picker[]
                agen : hyperspace2 [ (rig) ? rig : acfg ]
                # only the offscreen capture view pays for synthesis —
                # interactive panes never sample the atlas cells
                wants : bool [ agen && ((agen.gen > 0 && rig) || agen.dump_iris) ]
                is_atlas : bool [ false ]
                if [ wants && kk == 'iris' ]
                    eim = build_iris_atlas[ eim, 3, 777 ]
                    eml = 3
                    is_atlas = true
                if [ wants && kk == 'iris_melanin' ]
                    eim = build_iris_atlas[ eim, 0, 31337 ]
                    eml = 3
                    is_atlas = true
                if [ wants && kk == 'iris_disp_a' ]
                    eim = build_iris_atlas[ eim, 0, 52711 ]
                    eml = 3
                    is_atlas = true
                if [ wants && kk == 'iris_disp_b' ]
                    eim = build_iris_atlas[ eim, 0, 104729 ]
                    eml = 3
                    is_atlas = true
                if [ wants && kk == 'iris_disp_c' ]
