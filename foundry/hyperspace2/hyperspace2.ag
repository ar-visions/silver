                                una : f32 [ f32[ (cap_pseed % 1000 + 1000) % 1000 ] / 1000.0 ]
                                nam : f32 [ una * globe_rad * 0.25 ]
                                if [ cap_clean ] nam = 0.0
                                for [ q8: i32 0, q8 < hc9.nv, q8 += 1 ]
                                    wn8 : f32 [ nose_w[ q8 ] ]
                                    if [ wn8 <= 0.0 ] continue
                                    q83 : i32 [ q8 * 3 ]
                                    for [ x8: i32 0, x8 < 3, x8 += 1 ]
                                        cap_pseed = cap_pseed * 6364136223846793005 + 1442695040888963407
                                        nd8 : f32 [ (f32[ (cap_pseed % 1000 + 1000) % 1000 ] / 1000.0 - 0.5) * 2.0 * nam * wn8 ]
                                        bp9[ q83 + x8 ] += nd8 - cap_nd[ q83 + x8 ]
                                        cap_nd[ q83 + x8 ] = nd8
                            # general perlin over the WHOLE mesh, fresh per
                            # LOOK — zero near the four corner anchors
                            # (oc + ic): those are truth and never move
                            if [ !cap_maw ]
                                cap_maw = new f32 [ hc9.nv ]
                                cap_mp = new f32 [ hc9.nv * 3 ]
                                ilx : f32 [ eyec_lx + (eyec_lx - anch_lx) ]
                                irx : f32 [ eyec_rx + (eyec_rx - anch_rx) ]
                                for [ q7: i32 0, q7 < hc9.nv, q7 += 1 ]
                                    q73 : i32 [ q7 * 3 ]
                                    bx7 : f32 [ hc9.base[ q73 ] ]
                                    by7 : f32 [ hc9.base[ q73 + 1 ] ]
                                    bz7 : f32 [ hc9.base[ q73 + 2 ] ]
                                    dm7 : f32 [ 1e30 ]
                                    for [ p7: i32 0, p7 < 4, p7 += 1 ]
                                        px7 : f32 [ anch_lx ]
                                        py7 : f32 [ anch_ly ]
                                        pz7 : f32 [ anch_lz ]
                                        if [ p7 == 1 ]
                                            px7 = anch_rx
                                            py7 = anch_ry
                                            pz7 = anch_rz
                                        if [ p7 == 2 ]
                                            px7 = ilx
                                            py7 = eyec_ly
                                            pz7 = eyec_lz
                                        if [ p7 == 3 ]
                                            px7 = irx
                                            py7 = eyec_ry
                                            pz7 = eyec_rz
                                        dx7 : f32 [ bx7 - px7 ]
                                        dy7 : f32 [ by7 - py7 ]
                                        dz7 : f32 [ bz7 - pz7 ]
                                        dd7 : f32 [ sqrt[ dx7*dx7 + dy7*dy7 + dz7*dz7 ] ]
                                        if [ dd7 < dm7 ] dm7 = dd7
                                    wa7 : f32 [ (dm7 / globe_rad - 0.5) / 0.9 ]
                                    if [ wa7 < 0.0 ] wa7 = 0.0
                                    if [ wa7 > 1.0 ] wa7 = 1.0
                                    if [ hc9.pin ] wa7 = wa7 * (1.0 - hc9.pin[ q7 ])
                                    cap_maw[ q7 ] = wa7
                            cap_pseed = cap_pseed * 6364136223846793005 + 1442695040888963407
                            umm : f32 [ f32[ (cap_pseed % 1000 + 1000) % 1000 ] / 1000.0 ]
                            mam : f32 [ umm * umm * umm * globe_rad * 0.12 ]
                            # PARKED: sectors only for now
                            mam = 0.0
                            ms3 : local i64 [ 3 ]
                            for [ x7: i32 0, x7 < 3, x7 += 1 ]
                                cap_pseed = cap_pseed * 6364136223846793005 + 1442695040888963407
                                ms3[ x7 ] = cap_pseed
                            kw7 : f32 [ 1.0 / (globe_rad * 2.2) ]
                            for [ q7: i32 0, q7 < hc9.nv, q7 += 1 ]
                                wa7 : f32 [ cap_maw[ q7 ] ]
                                q73 : i32 [ q7 * 3 ]
                                bx7 : f32 [ hc9.base[ q73 ] * kw7 ]
                                by7 : f32 [ hc9.base[ q73 + 1 ] * kw7 ]
                                for [ x7: i32 0, x7 < 3, x7 += 1 ]
                                    mn7 : f32 [ (vnoise2[ ms3[ x7 ], bx7, by7 ] - 0.5) * 2.0 * mam * wa7 ]
                                    bp9[ q73 + x7 ] += mn7 - cap_mp[ q73 + x7 ]
                                    cap_mp[ q73 + x7 ] = mn7
                            # FACE: every other vert scrambled like the
                            # nose at 1/3 the amount, fresh per LOOK —
                            # the head net memorizes static geometry
                            # within one epoch otherwise. still point =
                            # midpoint between each eye's ic and oc; the
                            # globe center is not observable at inference
                            if [ !cap_faw ]
                                cap_faw = new f32 [ hc9.nv ]
                                mly : f32 [ (anch_ly + eyec_ly) * 0.5 ]
                                mlz : f32 [ (anch_lz + eyec_lz) * 0.5 ]
                                mry : f32 [ (anch_ry + eyec_ry) * 0.5 ]
                                mrz : f32 [ (anch_rz + eyec_rz) * 0.5 ]
                                for [ q5: i32 0, q5 < hc9.nv, q5 += 1 ]
                                    q53 : i32 [ q5 * 3 ]
                                    lx5 : f32 [ hc9.base[ q53 ] - eyec_lx ]
                                    ly5 : f32 [ hc9.base[ q53 + 1 ] - mly ]
                                    lz5 : f32 [ hc9.base[ q53 + 2 ] - mlz ]
                                    rx5 : f32 [ hc9.base[ q53 ] - eyec_rx ]
                                    ry5 : f32 [ hc9.base[ q53 + 1 ] - mry ]
                                    rz5 : f32 [ hc9.base[ q53 + 2 ] - mrz ]
                                    dl5 : f32 [ sqrt[ lx5*lx5 + ly5*ly5 + lz5*lz5 ] ]
                                    dr5 : f32 [ sqrt[ rx5*rx5 + ry5*ry5 + rz5*rz5 ] ]
                                    dm5 : f32 [ (dl5 < dr5) ? dl5 : dr5 ]
                                    wf5 : f32 [ dm5 / (globe_rad * 0.6) ]
                                    if [ wf5 > 1.0 ] wf5 = 1.0
                                    if [ hc9.pin ] wf5 = wf5 * (1.0 - hc9.pin[ q5 ])
                                    cap_faw[ q5 ] = wf5
                            if [ !cap_fd ]
                                cap_fd = new f32 [ hc9.nv * 3 ]
                            cap_pseed = cap_pseed * 6364136223846793005 + 1442695040888963407
                            unf : f32 [ f32[ (cap_pseed % 1000 + 1000) % 1000 ] / 1000.0 ]
                            fam : f32 [ unf * globe_rad * 0.0833 ]
                            if [ cap_clean ] fam = 0.0
                            for [ q6: i32 0, q6 < hc9.nv, q6 += 1 ]
                                wf6 : f32 [ cap_faw[ q6 ] ]
                                if [ nose_w ] wf6 = wf6 * (1.0 - nose_w[ q6 ])
                                q63 : i32 [ q6 * 3 ]
                                for [ x6: i32 0, x6 < 3, x6 += 1 ]
                                    cap_pseed = cap_pseed * 6364136223846793005 + 1442695040888963407
                                    fd6 : f32 [ (f32[ (cap_pseed % 1000 + 1000) % 1000 ] / 1000.0 - 0.5) * 2.0 * fam * wf6 ]
                                    bp9[ q63 + x6 ] += fd6 - cap_fd[ q63 + x6 ]
                                    cap_fd[ q63 + x6 ] = fd6
                            # ORBITAL: whole painted eye region scales per
                            # LOOK about the outer corners — mostly BIGGER
                            # (square-biased to +14%), small only ~15%:
                            # shrunken openings read weird
                            if [ eye_w ]
                                if [ !cap_ed ]
                                    cap_ed = new f32 [ hc9.nv * 3 ]
                                cap_pseed = cap_pseed * 6364136223846793005 + 1442695040888963407
                                ue4 : f32 [ f32[ (cap_pseed % 1000 + 1000) % 1000 ] / 1000.0 ]
                                ed4 : f32 [ ue4 * ue4 * 0.14 ]
                                cap_pseed = cap_pseed * 6364136223846793005 + 1442695040888963407
                                if [ (cap_pseed % 1000 + 1000) % 1000 < 150 ] ed4 = 0.0 - ue4 * 0.03
                                if [ cap_clean ] ed4 = 0.0
                                mpx4 : f32 [ 0.0 - anch_lx ]
                                for [ q4: i32 0, q4 < hc9.nv, q4 += 1 ]
                                    q43 : i32 [ q4 * 3 ]
                                    w4 : f32 [ eye_w[ q4 ] ]
                                    if [ hc9.pin ] w4 = w4 * (1.0 - hc9.pin[ q4 ])
                                    dx4 : f32 [ hc9.base[ q43 ] - anch_lx ]
                                    mx4 : f32 [ hc9.base[ q43 ] - mpx4 ]
                                    ox4 : f32 [ (dx4*dx4 < mx4*mx4) ? dx4 : mx4 ]
                                    dy4 : f32 [ hc9.base[ q43 + 1 ] - anch_ly ]
                                    dz4 : f32 [ hc9.base[ q43 + 2 ] - anch_lz ]
                                    s4  : f32 [ ed4 * w4 ]
                                    tx4 : f32 [ ox4 * s4 ]
                                    ty4 : f32 [ dy4 * s4 ]
                                    tz4 : f32 [ dz4 * s4 ]
                                    bp9[ q43 ]     += tx4 - cap_ed[ q43 ]
                                    bp9[ q43 + 1 ] += ty4 - cap_ed[ q43 + 1 ]
                                    bp9[ q43 + 2 ] += tz4 - cap_ed[ q43 + 2 ]
                                    cap_ed[ q43 ]     = tx4
                                    cap_ed[ q43 + 1 ] = ty4
                                    cap_ed[ q43 + 2 ] = tz4
                    hq : quatf [ head_q[ cap_hy, cap_hp, cap_hr ] ]
                    ncx : f32 [ 0.0 - mxc ]
                    ncy : f32 [ 0.0 - myc ]
                    ncz : f32 [ 0.0 - mzc ]
                    cap_rot = mat4f.identity[]
                    cap_rot = cap_rot.translate[ vec3f [ mxc, myc, mzc ] ]
                    cap_rot = cap_rot.rotate[ hq ]
                    cap_rot = cap_rot.translate[ vec3f [ ncx, ncy, ncz ] ]
                    # up to 16 plot candidates for this seat + pose: the eyes
                    # must actually fixate the point — a clamped gaze would be
                    # a lying label. no fit -> the whole sample re-rolls
                    aimed : bool [ false ]
                    for [ t2: i32 0, t2 < 16, t2 += 1 ]
                        cap_pseed = cap_pseed * 6364136223846793005 + 1442695040888963407
                        plot_u = f32[ cap_pseed % 1000 ] / 1000.0 * pex0
                        cap_pseed = cap_pseed * 6364136223846793005 + 1442695040888963407
                        plot_v = f32[ cap_pseed % 1000 ] / 1000.0 * pex0
                        if [ fpc.plot_fx > -900.0 ]
                            plot_u = fpc.plot_fx
                            plot_v = fpc.plot_fy
                        if [ aim_at_plot[ fpc, plot_u, plot_v ] ]
                            aimed = true
                            break
                    if [ aimed && bd1 >= fpc.dist_min ]
                        apply_eyes_down[]
                        capture_state = 1
                    el
                        # a pose that can't fixate a fresh plot ends its
                        # group; a new pose rolls next frame
                        cap_look_i = 0
                el [ capture_state == 1 ]
                    if [ !save_plot_sample[ fpc, cap_cam ] ]
                        # an eye region would clip this camera's frame:
                        # discard the pose entirely, re-roll a fresh sample
                        clip_rejects += 1
                        if [ (clip_rejects % 200) == 0 ] puts 'plot capture: {clip_rejects} poses re-rolled for eye clip'
                        cap_cam = 0
                        cap_look_i = 0
                        capture_state = 0
                    el
                        if [ cap_cam == 0 ]
                            # IR lamp for the verify frame = the TOP mount
                            # camera; stash before the view moves
                            cap_camx = look_x + dist * cos[ pitch ] * sin[ yaw ]
                            cap_camy = look_y + dist * sin[ pitch ]
                            cap_camz = look_z + dist * cos[ pitch ] * cos[ yaw ]
                        cap_cam += 1
                        if [ cap_cam < fpc.cameras ]
                            # next camera: the mirror mount BELOW the screen
                            # (same offsets, opposite sign), tilted up
                            tc2 : f32 [ radians[ fpc.cam_tilt_deg ] ]
                            c1x : f32 [ cap_scx - fpc.cam_x ]
                            c1y : f32 [ cap_scy - fpc.cam_y ]
                            c1z : f32 [ cap_scz - fpc.cam_z ]
                            yaw = 0.0
                            pitch = 0.0 - tc2
                            dist = 1.0
                            look_x = c1x
                            look_y = c1y + sin[ tc2 ]
                            look_z = c1z - cos[ tc2 ]
                            fov_x = fpc.cam_fov_deg
                        el
                            cap_cam = 0
                            if [ fpc.verify ]
                                capture_state = 3
                            el
                                # no --verify: skip the proof frame, wrap now
                                capture_state = 0
                                capture_left -= 1
                                cap_look_i += 1
                                if [ cap_look_i >= fpc.looks ] cap_look_i = 0
                                if [ (cap_idx % 100) == 0 ] puts 'plot capture: {cap_idx} done, {capture_left} left'
                                if [ capture_left == 0 ]
                                    puts 'plot capture complete: {cap_idx} samples'
                                    if [ fpc.gen > 0 ] exit[ 0 ]
                    if [ capture_state == 3 ]
                        capture_state = 2
                        # verify pose (--verify): camera AT the gaze target,
                        # looking back at the eye midpoint, zoomed for pupil
                        # reading. the gaze bones hold still; only the
                        # camera moves.
                        mxv : f32 [ (eyec_lx + eyec_rx) * 0.5 ]
                        myv : f32 [ (eyec_ly + eyec_ry) * 0.5 ]
                        mzv : f32 [ (eyec_lz + eyec_rz) * 0.5 ]
                        dxv : f32 [ cap_tx - mxv ]
                        dyv : f32 [ cap_ty - myv ]
                        dzv : f32 [ cap_tz - mzv ]
