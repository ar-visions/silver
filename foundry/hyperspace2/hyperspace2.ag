                me : gm.meshes[ nd.mesh ]
                if [ !me ] continue
                wmat : mat4f [ nd.world ]
                for [ pr: Primitive ] in me.primitives
                    for [ av: @i64, an: string ] in pr.attributes
                        if [ an == 'POSITION' ]
                            ac : gm.accessors[ av[0] ]
                            for [ cn: i32 0, cn < 8, cn += 1 ]
                                cxv : f32 [ ((cn & 1) != 0) ? ac.max.x : ac.min.x ]
                                cyv : f32 [ ((cn & 2) != 0) ? ac.max.y : ac.min.y ]
                                czv : f32 [ ((cn & 4) != 0) ? ac.max.z : ac.min.z ]
                                # column-major transform, scalar math (a C
                                # vec4f-by-value return crosses the aether/clang
                                # struct-return ABI wrong — see mul_v4 note)
                                wcx : f32 [ wmat.m[0] * cxv + wmat.m[4] * cyv + wmat.m[8]  * czv + wmat.m[12] ]
                                wcy : f32 [ wmat.m[1] * cxv + wmat.m[5] * cyv + wmat.m[9]  * czv + wmat.m[13] ]
                                wcz : f32 [ wmat.m[2] * cxv + wmat.m[6] * cyv + wmat.m[10] * czv + wmat.m[14] ]
                                if [ wcx < mnx ] mnx = wcx
                                if [ wcy < mny ] mny = wcy
                                if [ wcz < mnz ] mnz = wcz
                                if [ wcx > mxx ] mxx = wcx
                                if [ wcy > mxy ] mxy = wcy
                                if [ wcz > mxz ] mxz = wcz
            fpf : picker[]
            # brush size from the model's height: radius 8%, max move 4%
            if [ mxx > mnx && paint_radius <= 0.0 ]
                paint_radius = (mxy - mny) * 0.08
                paint_amount = (mxy - mny) * 0.04
            if [ mxx > mnx && fpf && !fpf.cam_ready ]
                sx : f32 [ mxx - mnx ]
                sy : f32 [ mxy - mny ]
                sz : f32 [ mxz - mnz ]
                r  : f32 [ sx ]
                if [ sy > r ] r = sy
                if [ sz > r ] r = sz
                fpf.look_x = (mnx + mxx) * 0.5
                fpf.look_y = mny + (mxy - mny) * 0.5
                fpf.look_z = (mnz + mxz) * 0.5
                fpf.dist   = (mxy - mny) * 1.8
                if [ fpf.dist < 0.2 ] fpf.dist = 0.2
