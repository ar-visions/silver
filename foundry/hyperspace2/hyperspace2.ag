            # root's id to 'app', so id can't identify it here
            cca : f32 [ 1.0 ]
            if [ rig ] cca = 0.0
            vrender   = Render [ vk: cv.vk, w: w, width: gw, height: gh, use_depth: true, clear_color: vec4f [ 0.015, 0.015, 0.015, cca ], models: array Model [ vmodel ] ]
            # register as an element target so trinity draws + fences it at frame
            # top (before compose); draw[] then only updates uniforms and blits.
            # a raw self-submit here corrupts the screen batch for sibling panes.
            w.element_targets[ 'hs2_{id}' ] = vrender
            vrender.wscale = 0.0
            # anchors + pins first, so nothing can ever move the corners
            setup_cage_anchors[]
            # user mask: the main view applies the session's saved cage
            # deltas at startup; --reset writes a zeroed mask instead
            if [ face_idx == 0 ]
                fpm : picker[]
                if [ fpm ]
                    if [ fpm.reset ]
                        fpm.save_mask[ a ]
                    el
                        fpm.load_mask[ a ]
                    # --gen N: batch generation starts itself at launch
                    if [ fpm.gen > 0 && !fpm.cap_started ]
                        fpm.cap_started = true
                        fpm.start_capture[]
                    # --fit: solve the user's metrics from the records
                    if [ fpm.fit && !fpm.cap_started ]
                        fpm.cap_started = true
                        fpm.run_fit[]
            puts 'hyperspace2: bounds={bounds.w}x{bounds.h} window={w.width}x{w.height} scale={w.scale}'
        # orbit camera: spherical eye around the look point (matches the Avatar
        # camera conventions — up is -Y, fov is horizontal)
        tgt : vec3f [ look_x, look_y, look_z ]
        eye : vec3f [
            tgt.x + dist * cos[ pitch ] * sin[ yaw ],
            tgt.y + dist * sin[ pitch ],
            tgt.z + dist * cos[ pitch ] * cos[ yaw ] ]
        up  : vec3f [ 0.0f, -1.0f, 0.0f ]
        asp : f32 [ bounds.w / bounds.h ]
        fy  : f32 [ 2.0f * atan[ tan[ radians[ fov_x ] * 0.5f ] / asp ] ]
        # capture head pose: the whole model (skin + eyeballs) rotates about
        # the eye midpoint; identity outside a capture
        mdlm : mat4f [ mat4f.identity[] ]
        if [ capture_left > 0 ] mdlm = cap_rot
        # IR lamp: coaxial with the render camera EXCEPT the verify
        # frame, where the lamp stays put on the camera mount
        lgx : f32 [ eye.x ]
        lgy : f32 [ eye.y ]
        lgz : f32 [ eye.z ]
        if [ capture_left > 0 && capture_state == 2 ]
            lgx = cap_camx
            lgy = cap_camy
            lgz = cap_camz
        vshader.model = mdlm
        vshader.view  = mat4f.look_at[ eye, tgt, up ]
        vshader.proj  = mat4f.perspective[ fy, asp, 0.05f, 200.0f ]
        vshader.light_x = lgx
        vshader.light_y = lgy
        vshader.light_z = lgz
        vshader.eye_lx = eyec_lx
        vshader.eye_ly = eyec_ly
        vshader.eye_lz = eyec_lz
        vshader.eye_rx = eyec_rx
        vshader.eye_ry = eyec_ry
        vshader.eye_rz = eyec_rz
        # rigid meshes (eyeballs) need the same camera; their model matrix is the
        # per-node world (ubo.model = rshader.model x node_model)
        if [ rshader ]
            rshader.model = mdlm
            rshader.view  = vshader.view
            rshader.proj  = vshader.proj
            rshader.light_x = lgx
            rshader.light_y = lgy
            rshader.light_z = lgz
        if [ cshader ]
            cshader.model = mdlm
            cshader.view  = vshader.view
            cshader.proj  = vshader.proj
            cshader.light_x = lgx
            cshader.light_y = lgy
            cshader.light_z = lgz
            # interactive: sweep pupil dilation on a sine each frame.
            # capture: pupil is PER SAMPLE (set in state 0) — the sine
            # would change dilation between the two cameras' frames
            if [ capture_left == 0 ]
                ph : f32 [ f32[ frame_n ] * 0.02f ]
                cshader.pupil_r = 0.35f + 0.20f * sin[ ph ]
        update_palette[]
        # rigid meshes (eyeballs) follow their bone: re-push node worlds
        if [ vmodel ] vmodel.update_animated[]
        # trinity's element_targets loop draws + fences this render at frame top;
        # here we only upload the fresh uniforms for the next frame's draw
        vrender.update[]
        # HS2_DUMP=1: write the render target to /tmp/hyperspace2_target.png once
        # (~frame 60) — discriminates render corruption from present corruption
        frame_n += 1
        cv.draw_image[ vrender.color, rect [ x: 0.0, y: 0.0, w: bounds.w, h: bounds.h ] ]

element hyperspace2 : trinity
    public model      : path   [ path 'models/uface.gltf' ]
    public width      : i32    [ 1024 ]
    public height     : i32    [ 1024 ]
    public title      : string [ 'hyperspace2' ]
    # solid-color background: the swapchain blit presents the LAST render's
    # color — the background chain's r_view (targeting the screen canvas) is
    # that render, so an app without one has nothing to present
    public background : string [ 'Background' ]
    # A/B face fitter (folded into the app root so it always gets keys as
    # app_object). champion (A = running centre) vs challenger (B = centre +
    # noise); space or a face double-click splits them side by side.
    mutable seeded   : bool
    mutable regen_i  : i32                      # r-key regeneration counter
    public  face_main : ModelView              # auto-binds to e['face_main']
    public  vote_0    : ModelView              # auto-binds to e['vote_0']
    public  vote_1    : ModelView              # auto-binds to e['vote_1']
    mutable cap_os    : offscreen              # headless host for capture
    mutable cap_view  : ModelView              # the element inside it
    mutable cage_ci   : i32 [ -1 ]             # last main-view pick: cage
    mutable cage_v    : i32 [ -1 ]             # last main-view pick: vert
    # user derivation mask: per-vert cage deltas from base, kept per session
    # at /src/hyperspace-sessions/{session}/user.cage. loads at startup,
    # re-saves on every merge; --reset writes it back to all zeros
    public  session   : string [ 'default' ]
    public  reset     : bool
    # --- real-camera recording + outer-corner annotation ---------------
    # record: dual-camera frame pairs into {session}/record, one shot per
    # 600ms (click anywhere to stop). annotate: fullscreen pass over the
    # unplotted pairs — click the LEFT outer corner then the RIGHT, top
    # camera image then bottom; keys {cam}_left_oc / {cam}_right_oc in
    # image-normalized 0..1 coords (hyperspace.ag's convention)
    public  top       : CameraView             # auto-binds to e['top']
    public  bot       : CameraView             # auto-binds to e['bot']
    public  cam_top_dev : string [ '/dev/video2' ]
    public  cam_bot_dev : string [ '/dev/video6' ]
    mutable rec_mode  : string [ '' ]
    mutable rec_i     : i32
    mutable rec_last  : i64
    mutable rec_noise : bool                   # recording negatives (no face)
    mutable ann_files : array string
    mutable ann_i     : i32
    mutable ann_cam   : i32
    mutable ann_sub   : i32
    mutable ann_ext   : bool                   # shift: include inner corners
    mutable ann_tex   : Texture
    mutable ann_img   : Image                  # loaded pair image, pre-GPU
    mutable ann_rect  : rect
    mutable ann_last  : i64
    mutable ann_px    : f32                    # first click (left corner)
    mutable ann_py    : f32
    mutable ann_m0    : vec2f                  # saved plots of the image
    mutable ann_m1    : vec2f                  # on screen: left, right,
    mutable ann_m2    : vec2f                  # nose base (-999 = absent)
    mutable ann_m3    : vec2f                  # left inner corner
    mutable ann_m4    : vec2f                  # right inner corner
    mutable ann_m5    : vec2f                  # hair flag (h key at cursor)
    mutable ann_lf    : string                 # loaded (fid, cam) — avoids
    mutable ann_lc    : i32 [ -1 ]             # reloading per click
    public  redo_oc   : bool                   # re-plot everything, overwrite

    func rec_dir [] -> path
        mkdir[ '/src/hyperspace-sessions', 493 ]
        mkdir[ '/src/hyperspace-sessions/{session}', 493 ]
        rd : path '/src/hyperspace-sessions/{session}/record'
        rd.make_dir[]
        return rd

    func start_record [ noise: bool ]
        # both rig cameras must exist or recording is a lie
        tdev : path '{cam_top_dev}'
        bdev : path '{cam_bot_dev}'
        if [ !tdev.exists[] || !bdev.exists[] ]
            puts 'record ERROR: need both cameras — {cam_top_dev} exists={tdev.exists[]} {cam_bot_dev} exists={bdev.exists[]}'
            return
        rd : rec_dir[]
        # next id = one past the highest existing (deleted pairs leave
        # holes; filling a hole would shadow neighbors' image files)
        rec_i = 0
        k7 : i32 [ 0 ]
        miss7 : i32 [ 0 ]
        while [ miss7 < 500 ]
            fp : path '{rd}/{k7}.agi'
            if [ fp.exists[] ]
                rec_i = k7 + 1
                miss7 = 0
            el
                miss7 += 1
            k7 += 1
        rec_last = 0
        rec_noise = noise
        rec_mode = 'record'
        kind : string [ (noise) ? 'NOISE negatives' : 'face pairs' ]
        puts 'record {kind}: -> {rd} starting at {rec_i} (click to stop)'

    # write or REPLACE `key: value` in a recorded pair's agi
    func agi_put2 [ fid: i32, key: string, val: string ]
        p : path '{rec_dir[]}/{fid}.agi'
        line : string '{key}: {val}\n'
        s : (p.load[ typeid[ string ], null ] to string)
        if [ !s ]
            p.save[ line, null ]
            return
        k2 : string '{key}:'
        ix : num [ s.index_of[ k2 ] ]
        if [ ix < 0 ]
            ns2 : string '{s}{line}'
            p.save[ ns2, null ]
            return
        st : i32 [ i32[ ix ] ]
        hd2 : s.mid[ 0, st ]
        rest : s.mid[ st, s.count - st ]
        nl : num [ rest.index_of[ '\n' ] ]
        tail : string ''
        if [ nl >= 0 ] tail = rest.mid[ i32[ nl ] + 1, rest.count - i32[ nl ] - 1 ]
        ns3 : string '{hd2}{line}{tail}'
        p.save[ ns3, null ]

    func rec_pair_missing [ fid: i32 ] -> bool
        p : path '{rec_dir[]}/{fid}.agi'
        s : (p.load[ typeid[ string ], null ] to string)
        if [ !s ] return true
        # negatives have no face: nothing to plot
        if [ s.index_of[ 'noise: true' ] >= 0 ] return false
        # overwrite pass: every face pair re-enters the queue
        if [ redo_oc ] return true
        if [ s.index_of[ 'top_left_oc:' ] < 0 ] return true
        if [ s.index_of[ 'top_right_oc:' ] < 0 ] return true
        if [ s.index_of[ 'top_nose_base:' ] < 0 ] return true
        if [ s.index_of[ 'bot_left_oc:' ] < 0 ] return true
        if [ s.index_of[ 'bot_right_oc:' ] < 0 ] return true
        if [ s.index_of[ 'bot_nose_base:' ] < 0 ] return true
        # inner corners are the shift-extended pass: their absence keeps
        # the pair queued, the base flow auto-skips past it
        if [ s.index_of[ 'top_left_ic:' ] < 0 ] return true
        if [ s.index_of[ 'top_right_ic:' ] < 0 ] return true
        if [ s.index_of[ 'bot_left_ic:' ] < 0 ] return true
        if [ s.index_of[ 'bot_right_ic:' ] < 0 ] return true
        return false

    # read a saved plot 'key: x y' for one image; absent = (-999,-999)
    func rec_read [ fid: string, cam: i32, sub: i32 ] -> vec2f
        r : vec2f [ x: -999.0, y: -999.0 ]
        cs : string [ (cam == 0) ? 'top' : 'bot' ]
        k6 : string '{cs}_left_oc:'
        if [ sub == 1 ] k6 = string '{cs}_right_oc:'
        if [ sub == 2 ] k6 = string '{cs}_nose_base:'
        if [ sub == 3 ] k6 = string '{cs}_left_ic:'
        if [ sub == 4 ] k6 = string '{cs}_right_ic:'
        if [ sub == 5 ] k6 = string '{cs}_hair:'
        p : path '{rec_dir[]}/{fid}.agi'
        s : (p.load[ typeid[ string ], null ] to string)
        if [ !s ] return r
        ix : num [ s.index_of[ k6 ] ]
        if [ ix < 0 ] return r
        st : i32 [ i32[ ix ] + k6.count ]
        ln : i32 [ s.count - st ]
        if [ ln > 48 ] ln = 48
        rest : s.mid[ st, ln ].trim[]
        parts : rest.split[ ' ' ]
        if [ parts.count < 2 ] return r
        r = vec2f [ x: f32[ atof[ parts[0].chars ] ], y: f32[ atof[ parts[1].chars ] ] ]
        return r

    func ann_refresh_marks []
        fid : ann_files[ ann_i ]
        ann_m0 = rec_read[ fid, ann_cam, 0 ]
        ann_m1 = rec_read[ fid, ann_cam, 1 ]
        ann_m2 = rec_read[ fid, ann_cam, 2 ]
        ann_m3 = rec_read[ fid, ann_cam, 3 ]
        ann_m4 = rec_read[ fid, ann_cam, 4 ]
        ann_m5 = rec_read[ fid, ann_cam, 5 ]

    # a saved plot on screen: colored ring + center dot (reads over any
    # background). left oc orange, right oc blue, nose base yellow
    func ann_mark [ cv: Canvas, mv: vec2f, col: string ]
        if [ mv.x < -100.0 ] return
        mx : f32 [ ann_rect.x + mv.x * ann_rect.w ]
        my : f32 [ ann_rect.y + mv.y * ann_rect.h ]
        cv.arc[ mx, my, 7.0, 0.0, 6.2831853 ]
        cv.fill_color[ '#0000' ]
        cv.stroke_color[ col ]
        cv.stroke_width[ 2.0 ]
        cv.paint[]
        cv.arc[ mx, my, 1.5, 0.0, 6.2831853 ]
        cv.fill_color[ col ]
        cv.stroke_width[ 0.0 ]
        cv.paint[]

    # key built HERE, used HERE: returning a locally-built string from
    # a helper hands the caller a dangling borrow
    func ann_have [ fid: string, cam: i32, sub: i32 ] -> bool
        cs : string [ (cam == 0) ? 'top' : 'bot' ]
        k6 : string '{cs}_left_oc:'
        if [ sub == 1 ] k6 = string '{cs}_right_oc:'
        if [ sub == 2 ] k6 = string '{cs}_nose_base:'
        if [ sub == 3 ] k6 = string '{cs}_left_ic:'
        if [ sub == 4 ] k6 = string '{cs}_right_ic:'
        if [ sub == 5 ] k6 = string '{cs}_hair:'
        p : path '{rec_dir[]}/{fid}.agi'
        s : (p.load[ typeid[ string ], null ] to string)
        if [ !s ] return false
        return s.index_of[ k6 ] >= 0

    # move to the next MISSING plot: already-plotted clicks are skipped
    # (unless redo_oc overwrites); exits annotate when nothing is left
    func ann_seek [ advance: bool ]
        if [ advance ] ann_sub += 1
        # shift extends the pass to the inner corners (subs 3, 4); the
        # base pass never stops on them
        lim7 : i32 [ (ann_ext) ? 5 : 3 ]
        while [ true ]
            if [ ann_sub >= lim7 ]
                ann_sub = 0
                ann_cam += 1
            if [ ann_cam >= 2 ]
                ann_cam = 0
                ann_i += 1
            if [ ann_i >= ann_files.count ]
                rec_mode = ''
                ann_tex = null
                ann_img = null
                ann_lc = -1
                puts 'annotate: all pairs plotted'
                return
            if [ redo_oc ] break
            if [ !ann_have[ ann_files[ ann_i ], ann_cam, ann_sub ] ] break
            ann_sub += 1
        ann_load2[]

    func ann_load2 []
        fid : ann_files[ ann_i ]
        if [ ann_img && ann_lc == ann_cam && ann_lf && ann_lf == fid ] return
        cam : string [ (ann_cam == 0) ? 'top' : 'bot' ]
        ip : path '{rec_dir[]}/{fid}-{cam}.png'
        im : Image [ uri: ip ]
        if [ im.width <= 0 ]
            puts 'annotate ERROR: cannot load {ip}'
            return
        # GPU texture is built lazily in on_canvas with the CANVAS vk —
        # the app element's own vk is not the render context
        im.hold[]
        ann_img = im
        ann_tex = null
        ann_lf = fid
        ann_lf.hold[]
        ann_lc = ann_cam
        ann_refresh_marks[]
        puts 'annotate {fid}-{cam} ({im.width}x{im.height}) ({ann_i + 1}/{ann_files.count})'

    func start_annotate []
        rd : rec_dir[]
        ann_files = array string [ ]
        k : i32 [ 0 ]
        miss7 : i32 [ 0 ]
        while [ miss7 < 500 ]
            fp : path '{rd}/{k}.agi'
            if [ !fp.exists[] ]
                k += 1
                miss7 += 1
                continue
            miss7 = 0
            if [ rec_pair_missing[ k ] ] ann_files += string '{k}'
            k += 1
        if [ ann_files.count == 0 ]
            puts 'annotate: nothing to plot (record first, or all done)'
            return
        # shuffled by PER-PAIR HASH (cameras stay together): uniform
        # coverage on partial passes, and the order is stable regardless
        # of what enters or leaves the queue between sessions. sorted as
        # plain ints — swapping array strings in place dangles borrows
        n5 : i32 [ ann_files.count ]
        fs5 : new i64 [ n5 ]
        for [ i: i32 0, i < n5, i += 1 ]
            fs5[ i ] = i64[ atof[ ann_files[ i ].chars ] ]
        for [ si: i32 1, si < n5, si += 1 ]
            cur : i64 [ fs5[ si ] ]
            kv : i64 [ cur * 2654435761 % 1000003 ]
            sj : i32 [ si ]
            while [ sj > 0 ]
                pv : i64 [ fs5[ sj - 1 ] * 2654435761 % 1000003 ]
                if [ pv <= kv ] break
                fs5[ sj ] = fs5[ sj - 1 ]
                sj -= 1
            fs5[ sj ] = cur
        # finish-what-you-started: pairs with ANY plots lead the queue,
        # untouched pairs follow — hash order within each group
        af5 : array string [ ]
        for [ i: i32 0, i < n5, i += 1 ]
            fi5 : i64 [ fs5[ i ] ]
            fn5 : string '{fi5}'
            if [ ann_have[ fn5, 0, 0 ] ] af5 += fn5
        for [ i: i32 0, i < n5, i += 1 ]
            fi5 : i64 [ fs5[ i ] ]
            fn5 : string '{fi5}'
            if [ !ann_have[ fn5, 0, 0 ] ] af5 += fn5
        ann_files = af5
        ann_i = 0
        ann_cam = 0
        ann_sub = 0
        rec_mode = 'annotate'
        ann_seek[ false ]

    # box-average a square window of the frame into a 32x32 tensor.
    # coords/side are fractions of the image width; out-of-frame is
    # ZERO-padded like the trainer's crop_gray; mir flips horizontally
    # (the stage nets train on left-eye anatomy, right eyes mirror in)
    func crop_tensor2 [ src: Image, cx: f32, cy: f32, side: f32, mir: bool ] -> tensor
        t : tensor [ tensor_shape: 32x32x1 ]
        data : @u8 [ src.vdata[] ]
        bpp : i32 [ (src.format == Pixel.u8) ? 1 : 4 ]
        iw2 : f32 [ f32[ src.width ] ]
        spx : f32 [ side * iw2 ]
        x0 : f32 [ cx * iw2 - spx * 0.5 ]
        y0 : f32 [ cy * iw2 - spx * 0.5 ]
        step : f32 [ spx / 32.0 ]
        for [ oy: i32 0, oy < 32, oy += 1 ]
            ys : i32 [ i32[ y0 + f32[ oy ] * step ] ]
            ye : i32 [ i32[ y0 + (f32[ oy ] + 1.0) * step ] ]
            if [ ye <= ys ] ye = ys + 1
            for [ ox: i32 0, ox < 32, ox += 1 ]
                xs : i32 [ i32[ x0 + f32[ ox ] * step ] ]
                xe : i32 [ i32[ x0 + (f32[ ox ] + 1.0) * step ] ]
                if [ xe <= xs ] xe = xs + 1
                acc : f32 [ 0.0 ]
                cnt : i32 [ 0 ]
                for [ sy: i32 ys, sy < ye, sy += 1 ]
                    for [ sx: i32 xs, sx < xe, sx += 1 ]
                        cnt += 1
                        if [ sy < 0 || sy >= src.height ] continue
                        if [ sx < 0 || sx >= src.width ] continue
                        acc += f32[ data[ (sy * src.width + sx) * bpp ] ]
                dox : i32 [ (mir) ? (31 - ox) : ox ]
                t.floats[ oy * 32 + dox ] = acc / (f32[ cnt ] * 255.0)
        return t

    # a 32x32 gray tensor into a panel texture, for the net-input strip
    func upload_tensor2 [ tex: Texture, t: tensor ]
        img2 : Image [ width: 32, height: 32, format: Pixel.rgba8 ]
        d : @u8 [ img2.vdata[] ]
        for [ i: i32 0, i < 1024, i += 1 ]
            v : f32 [ t.floats[i] * 255.0 ]
            if [ v < 0.0 ]   v = 0.0
            if [ v > 255.0 ] v = 255.0
            b : u8 [ u8[ i32[ v ] ] ]
            d[i * 4]     = b
            d[i * 4 + 1] = b
            d[i * 4 + 2] = b
            d[i * 4 + 3] = u8[ 255 ]
        tex.upload[ img2.vdata[], 4096 ]

    # one camera through the cascade: track each eye (target snaps the
    # window, refine polishes center + outer corner + size), build the
    # look inputs at the training conventions, read head + gaze
    func tb_cam2 [ c: i32, gray: Image ] -> bool
        for [ e2: i32 0, e2 < 2, e2 += 1 ]
            b3 : i32 [ (c * 2 + e2) * 3 ]
            ex : f32 [ tb_ex[ b3 + 0 ] ]
            ey : f32 [ tb_ex[ b3 + 1 ] ]
            es : f32 [ tb_ex[ b3 + 2 ] ]
            mir : bool [ e2 == 1 ]
            # target on a wide window around the last known spot
            tw : f32 [ es * 2.5 ]
            tt : crop_tensor2[ gray, ex, ey, tw, mir ]
            o3 : tensor [ tensor_shape: 1x3 ]
            ts_target.forward1[ tt, o3, 32 ]
            tdx : f32 [ (mir) ? (0.0 - o3.floats[0]) : o3.floats[0] ]
            ex = ex + tdx * tw
            ey = ey + o3.floats[1] * tw
            # exp[] on a subscript feeds the GEP unloaded: local first
            td3 : f32 [ o3.floats[2] ]
            es = exp[ td3 ] * tw
            if [ es < 0.02 ] es = 0.02
            if [ es > 0.35 ] es = 0.35
            # refine at the look crop convention
            c0x : f32 [ ex ]
            c0y : f32 [ ey ]
            rt : crop_tensor2[ gray, c0x, c0y, es, mir ]
            o5 : tensor [ tensor_shape: 1x5 ]
            ts_refine.forward1[ rt, o5, 32 ]
            rdx : f32 [ (mir) ? (0.0 - o5.floats[0]) : o5.floats[0] ]
            rox : f32 [ (mir) ? (0.0 - o5.floats[2]) : o5.floats[2] ]
            ex = c0x + rdx * es
            ey = c0y + o5.floats[1] * es
            b4 : i32 [ (c * 2 + e2) * 2 ]
            tb_oc[ b4 + 0 ] = c0x + rox * es
            tb_oc[ b4 + 1 ] = c0y + o5.floats[3] * es
            rd5 : f32 [ o5.floats[4] ]
            es = exp[ rd5 ] * es
            if [ es < 0.02 ] es = 0.02
            if [ es > 0.35 ] es = 0.35
            # a track that ran off frame resets to its seat prior
            if [ ex < 0.02 || ex > 0.98 || ey < 0.02 || ey > 0.98 ]
                ex = (e2 == 0) ? 0.58 : 0.42
                ey = 0.45
                es = 0.07
            tb_ex[ b3 + 0 ] = ex
            tb_ex[ b3 + 1 ] = ey
            tb_ex[ b3 + 2 ] = es
        # look inputs from the two tracked eyes, training conventions
        bl3 : i32 [ c * 6 ]
        elx : f32 [ tb_ex[ bl3 + 0 ] ]
        ely : f32 [ tb_ex[ bl3 + 1 ] ]
        erx : f32 [ tb_ex[ bl3 + 3 ] ]
        ery : f32 [ tb_ex[ bl3 + 4 ] ]
        sdx5 : f32 [ elx - erx ]
        sdy5 : f32 [ ely - ery ]
        sc5 : f32 [ sqrt[ sdx5*sdx5 + sdy5*sdy5 ] ]
        if [ sc5 < 0.02 ] return false
        side5 : f32 [ sc5 / 2.12 ]
        lc : crop_tensor2[ gray, elx, ely, side5, false ]
        rc : crop_tensor2[ gray, erx, ery, side5, false ]
        fmx : f32 [ (elx + erx) * 0.5 ]
        fmy : f32 [ (ely + ery) * 0.5 ]
        fc5 : crop_tensor2[ gray, fmx, fmy, sc5 * 1.75, false ]
        # face box + the exact 32px net inputs, for the overlay
        tb_fb[ c * 3 + 0 ] = fmx
        tb_fb[ c * 3 + 1 ] = fmy
        tb_fb[ c * 3 + 2 ] = sc5 * 1.75
        if [ tb_pv && tb_pv.count >= 6 ]
            upload_tensor2[ tb_pv[ c * 3 + 0 ], lc ]
            upload_tensor2[ tb_pv[ c * 3 + 1 ], rc ]
            upload_tensor2[ tb_pv[ c * 3 + 2 ], fc5 ]
        ax : tensor [ tensor_shape: 1x18 ]
        bo4 : i32 [ c * 4 ]
        ax.floats[0] = elx - 0.5
        ax.floats[1] = ely - 0.5
        ax.floats[2] = erx - 0.5
        ax.floats[3] = ery - 0.5
        ax.floats[4] = tb_oc[ bo4 + 0 ] - 0.5
        ax.floats[5] = tb_oc[ bo4 + 1 ] - 0.5
        ax.floats[6] = tb_oc[ bo4 + 2 ] - 0.5
        ax.floats[7] = tb_oc[ bo4 + 3 ] - 0.5
        ax.floats[8] = sc5
        ax.floats[9]  = elx - 0.5
        ax.floats[10] = ely - 0.5
        ax.floats[11] = side5
        ax.floats[12] = erx - 0.5
        ax.floats[13] = ery - 0.5
        ax.floats[14] = side5
        ax.floats[15] = fmx - 0.5
        ax.floats[16] = fmy - 0.5
        ax.floats[17] = sc5 * 1.75
        # stash this camera's crops + aux: offset and look both read
        # the PAIR in one forward after the camera loop
        fd9 : tb_f0
        ld9 : tb_l0
        rd9 : tb_r0
        if [ c == 1 ]
            fd9 = tb_f1
            ld9 = tb_l1
            rd9 = tb_r1
        for [ q9: i32 0, q9 < 1024, q9 += 1 ]
            fd9.floats[ q9 ] = fc5.floats[ q9 ]
            ld9.floats[ q9 ] = lc.floats[ q9 ]
            rd9.floats[ q9 ] = rc.floats[ q9 ]
        for [ q8: i32 0, q8 < 18, q8 += 1 ]
            tb_a36[ c * 18 + q8 ] = ax.floats[ q8 ]
        return true

    public func start_test []
        mp : model.parent_dir[]
        ts_target = ts_model [ uri: path '{mp}/target2.ptc' ]
        ts_target.hold[]
        ts_refine = ts_model [ uri: path '{mp}/refine2.ptc' ]
        ts_refine.hold[]
        ts_look = ts_model [ uri: path '{mp}/look2.ptc' ]
        ts_look.hold[]
        ts_off = ts_model [ uri: path '{mp}/offset2.ptc' ]
        ts_off.hold[]
        tb_f0 = tensor [ tensor_shape: 32x32x1 ]
        tb_f0.hold[]
        tb_f1 = tensor [ tensor_shape: 32x32x1 ]
        tb_f1.hold[]
        tb_l0 = tensor [ tensor_shape: 32x32x1 ]
        tb_l0.hold[]
        tb_r0 = tensor [ tensor_shape: 32x32x1 ]
        tb_r0.hold[]
        tb_l1 = tensor [ tensor_shape: 32x32x1 ]
        tb_l1.hold[]
        tb_r1 = tensor [ tensor_shape: 32x32x1 ]
        tb_r1.hold[]
        tb_a36 = new f32 [ 36 ]
        tb_ohave = false
        tb_ex = new f32 [ 12 ]
        tb_oc = new f32 [ 8 ]
        tb_ok = new f32 [ 2 ]
        tb_fb = new f32 [ 6 ]
        for [ c6: i32 0, c6 < 2, c6 += 1 ]
            b6 : i32 [ c6 * 6 ]
            tb_ex[ b6 + 0 ] = 0.58
            tb_ex[ b6 + 1 ] = 0.45
            tb_ex[ b6 + 2 ] = 0.07
            tb_ex[ b6 + 3 ] = 0.42
            tb_ex[ b6 + 4 ] = 0.45
            tb_ex[ b6 + 5 ] = 0.07
        tb_gx = 0.0
        tb_gy = 0.0
        rec_mode = 'test'
        ux.set_fullscreen[ true ]
        puts 'testbed: cascade live (esc to quit)'

    func bench_dir [] -> path
        mkdir[ '/src/hyperspace-sessions', 493 ]
        mkdir[ '/src/hyperspace-sessions/{session}', 493 ]
        bd : path '/src/hyperspace-sessions/{session}/benchmark'
        bd.make_dir[]
        return bd

    # REAL test capture: the mark rides a breathing spiral (no line
    # bias) and every 600ms tick saves a camera pair whose .agi carries
    # the mark position as its gaze label. click anywhere to stop
    public func start_bench []
        tdev : path '{cam_top_dev}'
        bdev : path '{cam_bot_dev}'
        if [ !tdev.exists[] || !bdev.exists[] ]
            puts 'benchmark ERROR: need both cameras — {cam_top_dev} exists={tdev.exists[]} {cam_bot_dev} exists={bdev.exists[]}'
            return
        bd : bench_dir[]
        bench_i = 0
        k7 : i32 [ 0 ]
        miss7 : i32 [ 0 ]
        while [ miss7 < 500 ]
            fp : path '{bd}/{k7}.agi'
            if [ fp.exists[] ]
                bench_i = k7 + 1
                miss7 = 0
            el
                miss7 += 1
            k7 += 1
        bench_t0 = epoch_millis[]
        bench_at = bench_t0 + 3000
        bench_last = 0
        rec_mode = 'bench'
        ux.set_fullscreen[ true ]
        puts 'benchmark: -> {bd} starting at {bench_i} — follow the mark (click to stop)'

    # one record camera's ray through an annotated point. screen center
    # is the origin: +x right, +y up, +z toward the person. cam 0 = top
    # mount (tilted down), cam 1 = the mirror below (tilted up)
    func cam_ray [ c: i32, nx: f32, ny: f32, ox: @f32, dx: @f32 ]
        sgn : f32 [ (c == 0) ? 1.0 : -1.0 ]
        ox[0] = cam_x
        ox[1] = sgn * cam_y
        ox[2] = cam_z
        tl : f32 [ radians[ cam_tilt_deg ] ]
        fx : f32 [ 0.0 ]
        fy : f32 [ 0.0 - sgn * sin[ tl ] ]
        fz : f32 [ cos[ tl ] ]
        # camera basis from forward x world-up
        rx : f32 [ fy * 0.0 - fz * 1.0 ]
        ry : f32 [ 0.0 ]
        rz : f32 [ fx * 1.0 - fy * 0.0 ]
        rl : f32 [ sqrt[ rx*rx + rz*rz ] ]
        if [ rl < 0.0001 ] rl = 0.0001
        rx = rx / rl
        rz = rz / rl
        cux : f32 [ ry*fz - rz*fy ]
        cuy : f32 [ rz*fx - rx*fz ]
        cuz : f32 [ rx*fy - ry*fx ]
        ht : f32 [ tan[ radians[ rec_fov ] * 0.5 ] ]
        px : f32 [ (nx - 0.5) * 2.0 * ht ]
        py : f32 [ (0.5 - ny) * 2.0 * ht ]
        vx : f32 [ fx + rx*px + cux*py ]
        vy : f32 [ fy + ry*px + cuy*py ]
        vz : f32 [ fz + rz*px + cuz*py ]
        vl : f32 [ sqrt[ vx*vx + vy*vy + vz*vz ] ]
        if [ vl < 0.0001 ] vl = 0.0001
        dx[0] = vx / vl
        dx[1] = vy / vl
        dx[2] = vz / vl

    # one fit pass: for every fully annotated non-noise pair, triangulate
    # the three landmarks (closest point of the two mount rays); medians
    # land in fit_span/fit_nose/fit_seat/fit_gap
    func fit_pass []
        rd : rec_dir[]
        cap9 : i32 [ 4096 ]
        spans : new f32 [ cap9 ]
        noses : new f32 [ cap9 ]
        dists : new f32 [ cap9 ]
        gaps  : new f32 [ cap9 ]
        nfit : i32 [ 0 ]
        k : i32 [ 0 ]
        miss7 : i32 [ 0 ]
        while [ miss7 < 500 ]
            fp9 : path '{rd}/{k}.agi'
            if [ !fp9.exists[] ]
                k += 1
                miss7 += 1
                continue
            miss7 = 0
            fid : string '{k}'
            k += 1
            ok9 : bool [ true ]
            for [ c9: i32 0, c9 < 2, c9 += 1 ]
                for [ s9: i32 0, s9 < 3, s9 += 1 ]
                    if [ !ann_have[ fid, c9, s9 ] ] ok9 = false
            if [ !ok9 ] continue
            pw : local f32 [ 9 ]
            gq : f32 [ 0.0 ]
            for [ s9: i32 0, s9 < 3, s9 += 1 ]
                pt : rec_read[ fid, 0, s9 ]
                pb : rec_read[ fid, 1, s9 ]
                o1 : local f32 [ 3 ]
                d1 : local f32 [ 3 ]
                o2 : local f32 [ 3 ]
                d2 : local f32 [ 3 ]
                cam_ray[ 0, pt.x, pt.y, o1, d1 ]
                cam_ray[ 1, pb.x, pb.y, o2, d2 ]
                w0x : f32 [ o1[0] - o2[0] ]
                w0y : f32 [ o1[1] - o2[1] ]
                w0z : f32 [ o1[2] - o2[2] ]
                b9 : f32 [ d1[0]*d2[0] + d1[1]*d2[1] + d1[2]*d2[2] ]
                dd : f32 [ d1[0]*w0x + d1[1]*w0y + d1[2]*w0z ]
                ee : f32 [ d2[0]*w0x + d2[1]*w0y + d2[2]*w0z ]
                den : f32 [ 1.0 - b9 * b9 ]
                if [ den < 0.000001 ] den = 0.000001
                t1 : f32 [ (b9 * ee - dd) / den ]
                t2 : f32 [ (ee - b9 * dd) / den ]
                p1x : f32 [ o1[0] + d1[0]*t1 ]
                p1y : f32 [ o1[1] + d1[1]*t1 ]
                p1z : f32 [ o1[2] + d1[2]*t1 ]
                p2x : f32 [ o2[0] + d2[0]*t2 ]
                p2y : f32 [ o2[1] + d2[1]*t2 ]
                p2z : f32 [ o2[2] + d2[2]*t2 ]
                gxq : f32 [ p1x - p2x ]
                gyq : f32 [ p1y - p2y ]
                gzq : f32 [ p1z - p2z ]
                gq += sqrt[ gxq*gxq + gyq*gyq + gzq*gzq ]
                pw[ s9*3 + 0 ] = (p1x + p2x) * 0.5
                pw[ s9*3 + 1 ] = (p1y + p2y) * 0.5
                pw[ s9*3 + 2 ] = (p1z + p2z) * 0.5
            if [ nfit >= cap9 ] break
            sdx : f32 [ pw[0] - pw[3] ]
            sdy : f32 [ pw[1] - pw[4] ]
            sdz : f32 [ pw[2] - pw[5] ]
            spans[ nfit ] = sqrt[ sdx*sdx + sdy*sdy + sdz*sdz ] * 1000.0
            mx9 : f32 [ (pw[0] + pw[3]) * 0.5 ]
            my9 : f32 [ (pw[1] + pw[4]) * 0.5 ]
            mz9 : f32 [ (pw[2] + pw[5]) * 0.5 ]
            ndx : f32 [ pw[6] - mx9 ]
            ndy : f32 [ pw[7] - my9 ]
            ndz : f32 [ pw[8] - mz9 ]
            noses[ nfit ] = sqrt[ ndx*ndx + ndy*ndy + ndz*ndz ] * 1000.0
            dists[ nfit ] = sqrt[ mx9*mx9 + my9*my9 + mz9*mz9 ]
            gaps[ nfit ] = gq / 3.0 * 1000.0
            nfit += 1
        if [ nfit == 0 ]
            puts 'fit: no fully annotated pairs in {rd}'
            exit[ 1 ]
        # medians via insertion sort (counts are small)
        for [ a9: i32 0, a9 < 4, a9 += 1 ]
            arr : @f32 [ spans ]
            if [ a9 == 1 ] arr = noses
            if [ a9 == 2 ] arr = dists
            if [ a9 == 3 ] arr = gaps
            for [ i9: i32 1, i9 < nfit, i9 += 1 ]
                cv9 : f32 [ arr[ i9 ] ]
                j9 : i32 [ i9 ]
                while [ j9 > 0 ]
                    if [ arr[ j9 - 1 ] <= cv9 ] break
                    arr[ j9 ] = arr[ j9 - 1 ]
                    j9 -= 1
                arr[ j9 ] = cv9
        mid9 : i32 [ nfit / 2 ]
        fit_n = nfit
        fit_span = spans[ mid9 ]
        fit_nose = noses[ mid9 ]
        fit_seat = dists[ mid9 ]
        fit_gap = gaps[ mid9 ]

    # solve ONE record: triangulate its landmark triangle, derive the
    # head yaw/pitch/roll (generator convention) + per-camera 2D triangle
    # mid/span for the composite alignment. out9 layout:
    # [hy, hp, hr, top_mx, top_my, top_span, bot_mx, bot_my, bot_span]
    func rec_solve [ fid: string, out9: @f32 ] -> bool
        for [ c9: i32 0, c9 < 2, c9 += 1 ]
            for [ s9: i32 0, s9 < 3, s9 += 1 ]
                if [ !ann_have[ fid, c9, s9 ] ] return false
        pw : local f32 [ 9 ]
        for [ s9: i32 0, s9 < 3, s9 += 1 ]
            pt : rec_read[ fid, 0, s9 ]
            pb : rec_read[ fid, 1, s9 ]
            o1 : local f32 [ 3 ]
            d1 : local f32 [ 3 ]
            o2 : local f32 [ 3 ]
            d2 : local f32 [ 3 ]
            cam_ray[ 0, pt.x, pt.y, o1, d1 ]
            cam_ray[ 1, pb.x, pb.y, o2, d2 ]
            w0x : f32 [ o1[0] - o2[0] ]
            w0y : f32 [ o1[1] - o2[1] ]
            w0z : f32 [ o1[2] - o2[2] ]
            b9 : f32 [ d1[0]*d2[0] + d1[1]*d2[1] + d1[2]*d2[2] ]
            dd : f32 [ d1[0]*w0x + d1[1]*w0y + d1[2]*w0z ]
            ee : f32 [ d2[0]*w0x + d2[1]*w0y + d2[2]*w0z ]
            den : f32 [ 1.0 - b9 * b9 ]
            if [ den < 0.000001 ] den = 0.000001
            t1 : f32 [ (b9 * ee - dd) / den ]
            t2 : f32 [ (ee - b9 * dd) / den ]
            pw[ s9*3 + 0 ] = (o1[0] + d1[0]*t1 + o2[0] + d2[0]*t2) * 0.5
            pw[ s9*3 + 1 ] = (o1[1] + d1[1]*t1 + o2[1] + d2[1]*t2) * 0.5
            pw[ s9*3 + 2 ] = (o1[2] + d1[2]*t1 + o2[2] + d2[2]*t2) * 0.5
        # triangle axes (record frame: +z toward person). the generator
        # frame is the record frame yawed 180: (x,y,z)g = (-x, y, -z)r
        xax : local f32 [ 3 ]
        xax[0] = 0.0 - (pw[0] - pw[3])
        xax[1] = pw[1] - pw[4]
        xax[2] = 0.0 - (pw[2] - pw[5])
        xl : f32 [ sqrt[ xax[0]*xax[0] + xax[1]*xax[1] + xax[2]*xax[2] ] ]
        if [ xl < 0.0001 ] return false
        xax[0] = xax[0] / xl
        xax[1] = xax[1] / xl
        xax[2] = xax[2] / xl
        # up-ish: eye midpoint minus subnasale, mapped to gen frame
        upx : f32 [ 0.0 - ((pw[0] + pw[3]) * 0.5 - pw[6]) ]
        upy : f32 [ (pw[1] + pw[4]) * 0.5 - pw[7] ]
        upz : f32 [ 0.0 - ((pw[2] + pw[5]) * 0.5 - pw[8]) ]
        # forward = up x left-axis, orthonormal via double cross.
        # rest axes in gen frame: x=(-1,0,0), y=(0,1,0), z=(0,0,1)
        zx : f32 [ upy*xax[2] - upz*xax[1] ]
        zy : f32 [ upz*xax[0] - upx*xax[2] ]
        zz : f32 [ upx*xax[1] - upy*xax[0] ]
        zl : f32 [ sqrt[ zx*zx + zy*zy + zz*zz ] ]
        if [ zl < 0.0001 ] return false
        zx = zx / zl
        zy = zy / zl
        zz = zz / zl
        if [ zz < 0.0 ]
            zx = 0.0 - zx
            zy = 0.0 - zy
            zz = 0.0 - zz
        yx : f32 [ zy*xax[2] - zz*xax[1] ]
        yy : f32 [ zz*xax[0] - zx*xax[2] ]
        yz : f32 [ zx*xax[1] - zy*xax[0] ]
        # yaw/pitch from the forward axis; roll from where the up axis
        # lands after yaw+pitch alone
        hy9 : f32 [ atan2[ zx, zz ] ]
        sp9 : f32 [ 0.0 - zy ]
        if [ sp9 > 1.0 ] sp9 = 1.0
        if [ sp9 < -1.0 ] sp9 = -1.0
        hp9 : f32 [ asin[ sp9 ] ]
        cy9 : f32 [ cos[ hy9 ] ]
        sy9 : f32 [ sin[ hy9 ] ]
        cp9 : f32 [ cos[ hp9 ] ]
        sp10 : f32 [ sin[ hp9 ] ]
        # R_yp x-hat and y-hat columns (Ry*Rx applied to unit axes)
        ax1 : f32 [ cy9 ]
        ay1 : f32 [ 0.0 ]
        az1 : f32 [ 0.0 - sy9 ]
        bx1 : f32 [ sy9 * sp10 ]
        by1 : f32 [ cp9 ]
        bz1 : f32 [ cy9 * sp10 ]
        hr9 : f32 [ atan2[ yx*ax1 + yy*ay1 + yz*az1, yx*bx1 + yy*by1 + yz*bz1 ] ]
        out9[0] = hy9
        out9[1] = hp9
        out9[2] = hr9
        # per-camera 2D mid + span for composite alignment (raw annots)
        for [ c9: i32 0, c9 < 2, c9 += 1 ]
            l2 : rec_read[ fid, c9, 0 ]
            r2 : rec_read[ fid, c9, 1 ]
            sx2 : f32 [ l2.x - r2.x ]
            sy2 : f32 [ l2.y - r2.y ]
            out9[ 3 + c9*3 + 0 ] = (l2.x + r2.x) * 0.5
            out9[ 3 + c9*3 + 1 ] = (l2.y + r2.y) * 0.5
            out9[ 3 + c9*3 + 2 ] = sqrt[ sx2*sx2 + sy2*sy2 ]
        return true

    # load every solvable record for generation
    func load_recs []
        rd : rec_dir[]
        recs_dat = new f32 [ 4096 * 9 ]
        recs_fid = new i32 [ 4096 ]
        tmp_dat : new f32 [ 36864 ]
        tmp_fid : new i32 [ 4096 ]
        recs_noise = new i32 [ 512 ]
        recs_noise_n = 0
        hair_pat = new u8 [ 262144 ]
        hair_n = 0
        tn : i32 [ 0 ]
        k : i32 [ 0 ]
        miss7 : i32 [ 0 ]
        while [ miss7 < 500 ]
            fp9 : path '{rd}/{k}.agi'
            if [ !fp9.exists[] ]
                k += 1
                miss7 += 1
                continue
            miss7 = 0
            fid : string '{k}'
            k += 1
            if [ tn >= 4096 ] break
            # noise pairs (no face) become composite background patches
            ns9 : (fp9.load[ typeid[ string ], null ] to string)
            if [ ns9 && ns9.index_of[ 'noise: true' ] >= 0 ]
                if [ recs_noise_n < 512 ]
                    recs_noise[ recs_noise_n ] = k - 1
                    recs_noise_n += 1
                continue
            # hair samples: a 10%-of-frame patch at each h plot, pooled
            # for generation's hair patching passes (nearest sampling)
            for [ hc9: i32 0, hc9 < 2, hc9 += 1 ]
                if [ hair_n >= 256 ] break
                hv9 : rec_read[ fid, hc9, 5 ]
                if [ hv9.x < -100.0 ] continue
                hnm : string [ (hc9 == 0) ? 'top' : 'bot' ]
                him : Image [ uri: path '{rd}/{k - 1}-{hnm}.png' ]
                if [ him.width <= 0 ] continue
                hp8 : @u8 [ him.pixels ]
                hnc : i32 [ him.channels ]
                hs9 : f32 [ f32[ him.width ] * 0.16 ]
                hx9 : f32 [ hv9.x * f32[ him.width ] ]
                hy9 : f32 [ hv9.y * f32[ him.height ] ]
                for [ py9: i32 0, py9 < 32, py9 += 1 ]
                    sy9 : i32 [ i32[ hy9 + (f32[ py9 ] / 31.0 - 0.5) * hs9 ] ]
                    if [ sy9 < 0 ] sy9 = 0
                    if [ sy9 > him.height - 1 ] sy9 = him.height - 1
                    for [ px9: i32 0, px9 < 32, px9 += 1 ]
                        sx9 : i32 [ i32[ hx9 + (f32[ px9 ] / 31.0 - 0.5) * hs9 ] ]
                        if [ sx9 < 0 ] sx9 = 0
                        if [ sx9 > him.width - 1 ] sx9 = him.width - 1
                        ho9 : i64 [ (i64[ sy9 ] * i64[ him.width ] + i64[ sx9 ]) * i64[ hnc ] ]
                        hd9 : i64 [ i64[ hair_n ] * 1024 + i64[ py9 ] * 32 + i64[ px9 ] ]
                        hair_pat[ hd9 ] = hp8[ ho9 ]
                hair_n += 1
            o9 : local f32 [ 9 ]
            if [ !rec_solve[ fid, o9 ] ] continue
            for [ q9: i32 0, q9 < 9, q9 += 1 ]
                tmp_dat[ tn * 9 + q9 ] = o9[ q9 ]
            tmp_fid[ tn ] = k - 1
            tn += 1
        recs_n = 0
        if [ tn == 0 ]
            puts 'records: 0 fitted poses loaded for generation'
            return
        # the person FACED THE SCREEN on average while recording, so
        # the median solved yaw/pitch is the anatomical solve bias
        # (eye-mid minus subnasale leans backward) — remove it
        sya : new f32 [ tn ]
        spa : new f32 [ tn ]
        for [ i6: i32 0, i6 < tn, i6 += 1 ]
            sya[ i6 ] = tmp_dat[ i6 * 9 + 0 ]
            spa[ i6 ] = tmp_dat[ i6 * 9 + 1 ]
        for [ i6: i32 1, i6 < tn, i6 += 1 ]
            for [ j6: i32 i6, j6 > 0, j6 -= 1 ]
                if [ sya[ j6 ] < sya[ j6 - 1 ] ]
                    ty6 : f32 [ sya[ j6 ] ]
                    sya[ j6 ] = sya[ j6 - 1 ]
                    sya[ j6 - 1 ] = ty6
                if [ spa[ j6 ] < spa[ j6 - 1 ] ]
                    tp6 : f32 [ spa[ j6 ] ]
                    spa[ j6 ] = spa[ j6 - 1 ]
                    spa[ j6 - 1 ] = tp6
        my6 : f32 [ sya[ tn / 2 ] ]
        mp6 : f32 [ spa[ tn / 2 ] ]
        for [ i6: i32 0, i6 < tn, i6 += 1 ]
            dy9 : f32 [ (tmp_dat[ i6 * 9 + 0 ] - my6) * 57.29578 ]
            dp9 : f32 [ (tmp_dat[ i6 * 9 + 1 ] - mp6) * 57.29578 ]
            dr9 : f32 [ tmp_dat[ i6 * 9 + 2 ] * 57.29578 ]
            # sane seated pose only: facing the screen within 60 degrees
            # of yaw, 40 up/down, 40 roll — outside = bad annotation
            bad9 : bool [ false ]
            if [ dy9 > 60.0 || dy9 < -60.0 ] bad9 = true
            if [ dp9 > 40.0 || dp9 < -40.0 ] bad9 = true
            if [ dr9 > 40.0 || dr9 < -40.0 ] bad9 = true
            fid6 : i32 [ tmp_fid[ i6 ] ]
            if [ bad9 ]
                puts 'rec {fid6}: REJECTED yaw={dy9} pitch={dp9} roll={dr9}'
                continue
            recs_dat[ recs_n * 9 + 0 ] = dy9 / 57.29578
            recs_dat[ recs_n * 9 + 1 ] = dp9 / 57.29578
            for [ q9: i32 2, q9 < 9, q9 += 1 ]
                recs_dat[ recs_n * 9 + q9 ] = tmp_dat[ i6 * 9 + q9 ]
            recs_fid[ recs_n ] = fid6
            recs_n += 1
        mydeg : f32 [ my6 * 57.29578 ]
        mpdeg : f32 [ mp6 * 57.29578 ]
        puts 'records: {recs_n} of {tn} poses usable, {recs_noise_n} noise frames, {hair_n} hair patches (bias removed: yaw={mydeg} pitch={mpdeg})'

    # --fit driver: with span_known set, SOLVE the camera fov first —
    # bisect until the stereo span equals the ruler truth (span grows
    # monotonically with fov)
    func run_fit []
        if [ span_known > 0.0 ]
            lo9 : f32 [ 15.0 ]
            hi9 : f32 [ 80.0 ]
            for [ b9: i32 0, b9 < 24, b9 += 1 ]
                rec_fov = (lo9 + hi9) * 0.5
                fit_pass[]
                if [ fit_span < span_known ]
                    lo9 = rec_fov
                el
                    hi9 = rec_fov
        fit_pass[]
        puts 'fit: {fit_n} pairs  fov={rec_fov}  span={fit_span}mm  nose={fit_nose}mm  seat={fit_seat}m  ray-gap={fit_gap}mm'
        fs : string 'fit:\n    count: {fit_n}\n    rec_fov: {rec_fov}\n    span_mm: {fit_span}\n    nose_mm: {fit_nose}\n    seat_m: {fit_seat}\n    ray_gap_mm: {fit_gap}\n'
        fo : path '/src/hyperspace-sessions/{session}/fit.agi'
        fo.save[ fs, null ]
        puts 'fit -> /src/hyperspace-sessions/{session}/fit.agi'
        exit[ 0 ]

    public func on_click [ ev: Event ]
        if [ rec_mode == 'record' ]
            rec_mode = ''
            puts 'record: stopped at {rec_i} pairs'
            ev.stop_propagation[]
            return
        if [ rec_mode == 'bench' ]
            rec_mode = ''
            ux.set_fullscreen[ false ]
            puts 'benchmark: stopped at {bench_i} pairs'
            ev.stop_propagation[]
            return
        if [ rec_mode == 'annotate' ]
            if [ ann_tex && ann_rect.w > 0.0 ]
                now2 : i64 [ epoch_millis[] ]
                if [ now2 - ann_last >= 250 ]
                    ann_last = now2
                    nx : f32 [ (ev.mouse.pos.x - ann_rect.x) / ann_rect.w ]
                    ny : f32 [ (ev.mouse.pos.y - ann_rect.y) / ann_rect.h ]
                    cam : string [ (ann_cam == 0) ? 'top' : 'bot' ]
                    key : string '{cam}_left_oc'
                    if [ ann_sub == 1 ] key = string '{cam}_right_oc'
                    if [ ann_sub == 2 ] key = string '{cam}_nose_base'
                    if [ ann_sub == 3 ] key = string '{cam}_left_ic'
                    if [ ann_sub == 4 ] key = string '{cam}_right_ic'
                    fidn : i32 [ i32[ atof[ ann_files[ ann_i ].chars ] ] ]
                    agi_put2[ fidn, key, string '{nx} {ny}' ]
                    ann_refresh_marks[]
                    ann_ext = ev.key.shift
                    ann_seek[ true ]
            ev.stop_propagation[]
            return
        oe : (ev.origin to element)
        if [ !oe ] return
        # consume ONLY our own buttons: anything else falls through to
        # the ModelViews (face edit clicks, camera orbit)
        if [ oe.id == 'record' ]
            start_record[ false ]
            ev.stop_propagation[]
        el [ oe.id == 'noise' ]
            start_record[ true ]
            ev.stop_propagation[]
        el [ oe.id == 'plot-oc' ]
            start_annotate[]
            ev.stop_propagation[]
        el [ oe.id == 'testbed' ]
            start_test[]
            ev.stop_propagation[]
        el [ oe.id == 'bench' ]
            start_bench[]
            ev.stop_propagation[]

    # the testbed paints OVER the element tree (on_canvas paints under
    # it — feeds would cover the targets)
    public func on_overlay [ cv: Canvas ]
        sw : f32 [ f32[ ux.width ] ]
        sh : f32 [ f32[ ux.height ] ]
        # --test: autostart only after the tree has settled — swapping
        # the tree during init kills in-flight renders (device lost)
        if [ test && rec_mode != 'test' ]
            test_wait += 1
            if [ test_wait > 90 ] start_test[]
        if [ benchmark && rec_mode != 'bench' ]
            test_wait += 1
            if [ test_wait > 90 ] start_bench[]
        if [ rec_mode == 'test' ]
            if [ !ts_look ] return
            # the swap frame binds top/bot to a template that's
            # immediately discarded — let the tree settle first
            test_settle += 1
            if [ test_settle < 5 ] return
            # net-input panels are built here: the app element's own vk
            # is not the render context, the canvas's is
            if [ !tb_pv ]
                tb_pv = array Texture [ ]
                tb_pv.hold[]
                for [ p9: i32 0, p9 < 6, p9 += 1 ]
                    tp9 : Texture [ vk: cv.vk, w: ux, width: 32, height: 32, linear: true ]
                    tb_pv += tp9
            n7 : i32 [ 0 ]
            for [ c7: i32 0, c7 < 2, c7 += 1 ]
                v7 : top
                if [ c7 == 1 ] v7 = bot
                if [ !v7 ] continue
                if [ !v7.camera ] continue
                gr7 : v7.frame_image[]
                if [ !gr7 ] continue
                if [ tb_cam2[ c7, gr7 ] ] n7 += 1
            # two-step pair stage: offset reads both face crops, then
            # look reads both cams' crops + that offset — ONE result,
            # no per-camera averaging (one view can't triangulate)
            if [ n7 == 2 && ts_off && ts_look ]
                ax7 : tensor [ tensor_shape: 1x36 ]
                for [ q7: i32 0, q7 < 36, q7 += 1 ]
                    ax7.floats[ q7 ] = tb_a36[ q7 ]
                o5 : tensor [ tensor_shape: 1x3 ]
                ts_off.forward2i[ tb_f0, tb_f1, ax7, o5, 32, 36 ]
                ox5 : f32 [ o5.floats[0] ]
                oy5 : f32 [ o5.floats[1] ]
                oz5 : f32 [ o5.floats[2] ]
                if [ !tb_ohave ]
                    tb_ox = ox5
                    tb_oy = oy5
                    tb_oz = oz5
                    tb_ohave = true
                el
                    tb_ox = tb_ox * 0.7 + ox5 * 0.3
                    tb_oy = tb_oy * 0.7 + oy5 * 0.3
                    tb_oz = tb_oz * 0.7 + oz5 * 0.3
                ax9 : tensor [ tensor_shape: 1x39 ]
                for [ q6: i32 0, q6 < 36, q6 += 1 ]
                    ax9.floats[ q6 ] = tb_a36[ q6 ]
                ax9.floats[36] = ox5
                ax9.floats[37] = oy5
                ax9.floats[38] = oz5
                o6 : tensor [ tensor_shape: 1x4 ]
                ts_look.forward6i[ tb_l0, tb_r0, tb_f0, tb_l1, tb_r1, tb_f1, ax9, o6, 32, 39 ]
                h7x : f32 [ o6.floats[0] ]
                h7y : f32 [ o6.floats[1] ]
                g7x : f32 [ o6.floats[2] ]
                g7y : f32 [ o6.floats[3] ]
                if [ !tb_have ]
                    tb_gx = g7x
                    tb_gy = g7y
                    tb_hx = h7x
                    tb_hy = h7y
                    tb_have = true
                el
                    tb_gx = tb_gx * 0.7 + g7x * 0.3
                    tb_gy = tb_gy * 0.7 + g7y * 0.3
                    tb_hx = tb_hx * 0.7 + h7x * 0.3
                    tb_hy = tb_hy * 0.7 + h7y * 0.3
            if [ tb_have ]
                # gaze mark (green) and head mark (orange): rings + a
                # small center dot, the annotate idiom that renders true
                gpx : f32 [ (tb_gx + 0.5) * sw ]
                gpy : f32 [ (tb_gy + 0.5) * sh ]
                hpx : f32 [ (tb_hx + 0.5) * sw ]
                hpy : f32 [ (tb_hy + 0.5) * sh ]
                cv.arc[ gpx, gpy, 16.0, 0.0, 6.2831853 ]
                cv.fill_color[ '#0000' ]
                cv.stroke_color[ '#0f8' ]
                cv.stroke_width[ 3.0 ]
                cv.paint[]
                cv.arc[ gpx, gpy, 3.0, 0.0, 6.2831853 ]
                cv.fill_color[ '#0f8' ]
                cv.stroke_width[ 0.0 ]
                cv.paint[]
                cv.arc[ hpx, hpy, 11.0, 0.0, 6.2831853 ]
                cv.fill_color[ '#0000' ]
                cv.stroke_color[ '#f80' ]
                cv.stroke_width[ 2.0 ]
                cv.paint[]
            if [ tb_ohave ]
                od5 : f32 [ sqrt[ tb_ox*tb_ox + tb_oy*tb_oy + tb_oz*tb_oz ] ]
                cv.sync_fence[]
                cv.fill_color[ '#9ab' ]
                cv.draw_text[ 'eyes off screen center ({tb_ox}, {tb_oy}, {tb_oz})m  dist {od5}m',
                    rect [ x: sw * 0.5 - 300.0, y: sh - 40.0, w: 600.0, h: 20.0 ],
                    vec2f [ 0.5, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
                cv.paint[]
            # tracked state over each feed: eye boxes (yellow), outer
            # corners (orange dots) — what the cascade believes, on the
            # pixels it believes it about
            for [ c8: i32 0, c8 < 2, c8 += 1 ]
                # member ternary yields the slot, not the value: assign
                ve : top
                if [ c8 == 1 ] ve = bot
                if [ !ve ] continue
                if [ ve.bounds.w <= 0.0 ] continue
                vbx : f32 [ ve.bounds.x ]
                vby : f32 [ ve.bounds.y ]
                vbw : f32 [ ve.bounds.w ]
                vbh : f32 [ ve.bounds.h ]
                for [ e8: i32 0, e8 < 2, e8 += 1 ]
                    b8 : i32 [ (c8 * 2 + e8) * 3 ]
                    ex8 : f32 [ tb_ex[ b8 + 0 ] ]
                    ey8 : f32 [ tb_ex[ b8 + 1 ] ]
                    es8 : f32 [ tb_ex[ b8 + 2 ] ]
                    cv.rect_to[ vbx + (ex8 - es8 * 0.5) * vbw, vby + (ey8 - es8 * 0.5) * vbh, es8 * vbw, es8 * vbh ]
                    cv.fill_color[ '#0000' ]
                    cv.stroke_color[ '#ff0' ]
                    cv.stroke_width[ 2.0 ]
                    cv.paint[]
                    b9 : i32 [ (c8 * 2 + e8) * 2 ]
                    cv.arc[ vbx + tb_oc[ b9 + 0 ] * vbw, vby + tb_oc[ b9 + 1 ] * vbh, 3.0, 0.0, 6.2831853 ]
                    cv.fill_color[ '#f80' ]
                    cv.stroke_width[ 0.0 ]
                    cv.paint[]
                # face crop box (cyan) — the region look actually reads
                fbx : f32 [ tb_fb[ c8 * 3 + 0 ] ]
                fby : f32 [ tb_fb[ c8 * 3 + 1 ] ]
                fbs : f32 [ tb_fb[ c8 * 3 + 2 ] ]
                if [ fbs > 0.0 ]
                    cv.rect_to[ vbx + (fbx - fbs * 0.5) * vbw, vby + (fby - fbs * 0.5) * vbh, fbs * vbw, fbs * vbh ]
                    cv.fill_color[ '#0000' ]
                    cv.stroke_color[ '#0cf' ]
                    cv.stroke_width[ 2.0 ]
                    cv.paint[]
                # the EXACT 32px inputs look consumed: left, right, face
                if [ tb_pv && tb_pv.count >= 6 ]
                    ps8 : f32 [ vbw * 0.3 ]
                    for [ p8: i32 0, p8 < 3, p8 += 1 ]
                        cv.draw_image[ tb_pv[ c8 * 3 + p8 ],
                            rect [ x: vbx + f32[ p8 ] * (ps8 + 4.0), y: vby - ps8 - 6.0, w: ps8, h: ps8 ] ]
                    cv.paint[]
            if [ tb_have ]
                cv.sync_fence[]
                cv.fill_color[ '#9ab' ]
                cv.draw_text[ 'head ({tb_hx}, {tb_hy})  gaze ({tb_gx}, {tb_gy})',
                    rect [ x: sw * 0.5 - 300.0, y: sh - 64.0, w: 600.0, h: 20.0 ],
                    vec2f [ 0.5, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
                cv.paint[]
            return
        if [ rec_mode == 'bench' ]
            now8 : i64 [ epoch_millis[] ]
            tsec : f32 [ f32[ now8 - bench_t0 ] / 1000.0 ]
            # breathing spiral: angle advances steadily while the radius
            # swells 0 -> full -> 0 over ~45s. pure curves, no line bias
            th8 : f32 [ tsec * 1.1 ]
            rr8 : f32 [ 0.5 - 0.5 * cos[ tsec * 0.1396 ] ]
            bench_u = 0.47 * rr8 * cos[ th8 ]
            bench_v = 0.47 * rr8 * sin[ th8 ]
            mpx : f32 [ (bench_u + 0.5) * sw ]
            mpy : f32 [ (bench_v + 0.5) * sh ]
            # STATIONARY blue ring (128px circle, 2px stroke) at center
            # for the head; the gaze dot travels the spiral. both are
            # rounded rects at full radius — the in-shader circle path
            cv.rounded_rect[ sw * 0.5 - 64.0, sh * 0.5 - 64.0, 128.0, 128.0, 64.0, 64.0, 64.0, 64.0 ]
            cv.fill_color[ '#0000' ]
            cv.stroke_color[ '#08f' ]
            cv.stroke_width[ 2.0 ]
            cv.paint[]
            cv.rounded_rect[ mpx - 6.0, mpy - 6.0, 12.0, 12.0, 6.0, 6.0, 6.0, 6.0 ]
            cv.fill_color[ '#0f8' ]
            cv.stroke_width[ 0.0 ]
            cv.paint[]
            if [ now8 >= bench_at && now8 - bench_last >= 600 ]
                bench_last = now8
                bd : bench_dir[]
                tp : path '{bd}/{bench_i}-top.png'
                bp : path '{bd}/{bench_i}-bot.png'
                okt : bool [ (top) ? top.save_frame[ tp ] : false ]
                okb : bool [ (bot) ? bot.save_frame[ bp ] : false ]
                s : string 'images:\n    top: {bench_i}-top.png\n    bot: {bench_i}-bot.png\ncameras: 2\nlook: {bench_u} {bench_v}\n'
                ag : path '{bd}/{bench_i}.agi'
                ag.save[ s, null ]
                if [ bench_i % 10 == 0 ] puts 'benchmark: {bench_i} pairs (top={okt} bot={okb})'
                bench_i += 1
            return

    public func on_canvas [ cv: Canvas ]
        sw : f32 [ f32[ ux.width ] ]
        sh : f32 [ f32[ ux.height ] ]
        if [ rec_mode == 'record' ]
            if [ rec_i % 50 == 0 && top && top.camera && bot && bot.camera ]
                puts 'rec cams: top dev={top.camera.device} bot dev={bot.camera.device}'
            now3 : i64 [ epoch_millis[] ]
            if [ now3 - rec_last >= 600 ]
                rec_last = now3
                rd : rec_dir[]
                tp : path '{rd}/{rec_i}-top.png'
                bp : path '{rd}/{rec_i}-bot.png'
                okt : bool [ (top) ? top.save_frame[ tp ] : false ]
                okb : bool [ (bot) ? bot.save_frame[ bp ] : false ]
                s : string 'images:\n    top: {rec_i}-top.png\n    bot: {rec_i}-bot.png\ncameras: 2\n'
                # negatives: no face in frame — the loader skips them for
                # gaze and feeds them as face-absent counterexamples
                if [ rec_noise ] s = string '{s}noise: true\n'
                ag : path '{rd}/{rec_i}.agi'
                ag.save[ s, null ]
                if [ rec_i % 10 == 0 ] puts 'record: {rec_i} pairs (top={okt} bot={okb})'
                rec_i += 1
            return
        if [ rec_mode == 'annotate' ]
            if [ ann_img && !ann_tex ]
                ann_tex = Texture [ vk: cv.vk, w: ux, linear: true, mip_levels: 1, sampler: ann_img ]
                ann_tex.hold[]
            if [ !ann_tex ] return
            side : f32 [ (sw < sh) ? sw : sh ]
            ann_rect = rect [ x: (sw - side) * 0.5, y: (sh - side) * 0.5, w: side, h: side ]
            cv.draw_image[ ann_tex, ann_rect ]
            # instruction line: what to plot, which camera, which pair
            fid0 : ann_files[ ann_i ]
            cam0 : string [ (ann_cam == 0) ? 'top' : 'bot' ]
            lbl0 : string 'left oc'
            if [ ann_sub == 1 ] lbl0 = string 'right oc'
            if [ ann_sub == 2 ] lbl0 = string 'nose base'
            if [ ann_sub == 3 ] lbl0 = string 'left ic'
            if [ ann_sub == 4 ] lbl0 = string 'right ic'
            cv.sync_fence[]
            cv.fill_color[ '#9ab' ]
            cv.draw_text[ 'plot {lbl0}  {cam0}  #{fid0}  ({ann_i + 1}/{ann_files.count})  space = skip  n = noise',
                rect [ x: 16.0, y: 12.0, w: sw - 32.0, h: 28.0 ],
                vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            cv.paint[]
            # every SAVED plot of this image stays on screen, straight
            # from disk: left oc ORANGE, right oc BLUE, nose base YELLOW
            ann_mark[ cv, ann_m0, '#f80' ]
            ann_mark[ cv, ann_m1, '#08f' ]
            ann_mark[ cv, ann_m2, '#ff0' ]
            ann_mark[ cv, ann_m3, '#f4a' ]
            ann_mark[ cv, ann_m4, '#0dd' ]
            ann_mark[ cv, ann_m5, '#4c4' ]
    # IR rig: the view is an IR camera mounted ON TOP of the LCD screen.
    # cam_x/y/z place the camera relative to the SCREEN CENTER, in meters,
    # in the person's screen frame: +x right, +y up, +z toward the person.
    # plots are screen positions: (0,0) center, -0.5 left/top, 0.5 right/bottom.
    # defaults = the real rig: 32" 16:9 panel (0.708 x 0.398 m), camera 1.5"
    # above the top edge (half height + 0.038), 1" proud of the screen plane
    # toward the person, tilted ~25 degrees down, ~60 degree IR optics
    public  screen_w  : f32 [ 0.708 ]          # LCD width, meters
    public  screen_h  : f32 [ 0.398 ]          # LCD height, meters
    public  cam_x     : f32 [ 0.0 ]
    public  cam_y     : f32 [ 0.237 ]          # half height + 1.5 inches
    public  cam_z     : f32 [ 0.0254 ]         # 1 inch toward the person
    public  cam_tilt_deg : f32 [ 25.0 ]        # mount tilt down, degrees
    public  cam_fov_deg  : f32 [ 60.0 ]        # IR horizontal FOV, degrees
    public  face_dist : f32 [ 0.55 ]           # camera to face, meters
    # per-sample person movement: the face sits at a different offset from
    # the screen center every sample. 6 inches to 4 feet — the clip gate
    # re-rolls near poses whose eye crops would leave the frame
    public  dist_min  : f32 [ 0.20 ]           # nearest seat distance (8in)
    public  dist_max  : f32 [ 0.61 ]           # farthest seat distance (2ft)
    # capture cameras: 0 = top mount (above screen, tilted down), 1 = the
    # mirror (below screen, tilted up); every sample saves one face image
    # per camera and the .agi indexes the plots per camera
    public  cameras   : i32 [ 2 ]
    public  check_obj : bool                   # write 3D confirm .obj, first 4
    public  dump_iris : bool                   # dump 1024 iris variants as pngs
    public  move_x    : f32 [ 0.08 ]           # max lateral shift, meters
    public  move_y    : f32 [ 0.05 ]           # max vertical shift, meters
    # per-sample head pose variance (radians, max magnitude each axis);
    # the eyes still hit their plot — gaze compensates like a real person
    public  rot_yaw   : f32 [ 0.35 ]           # turn left/right (~20 deg)
    public  rot_pitch : f32 [ 0.2 ]            # nod up/down (~11 deg)
    public  rot_roll  : f32 [ 0.12 ]           # tilt (~7 deg)
    # max |plot| sampled: 0.5 = on screen only; up to 1.0 allows an
    # off-screen band around it; never bigger. every sample's eyes MUST
    # physically reach their plot (16 tries, then the sample re-rolls)
    public  plot_extent : f32 [ 0.5 ]
    # pin every sample to one exact plot (verification): -999 = off
    public  side_verify : bool                 # proof camera beside the face
    public  free_gaze : bool                   # test: no mechanical range gates
    public  eyes_down : f32 [ 1.0 ]            # eyes-down morph percentage
    public  plot_fx : f32 [ -999.0 ]
    public  plot_fy : f32 [ -999.0 ]
    # capture render: the IR camera is SQUARE. frames save at full render
    # resolution — python crops and box-averages, the app never does
    public  cap_w      : i32 [ 2048 ]
    public  cap_h      : i32 [ 2048 ]
    # windowless generation: --hidden --gen N starts an N-sample batch
    # at launch with no visible window and exits when done
    public  hidden     : bool
    public  gen        : i32
    # look multiplier: each pose renders this many gaze positions with
    # the seat, head, identity and lighting held — gaze alone varies
    public  looks      : i32 [ 10 ]
    # --test: the live fullscreen testbed — both cameras through the
    # target -> refine -> look cascade, gaze dot on screen
    public  test       : bool
    mutable ts_target  : ts_model
    mutable ts_refine  : ts_model
    mutable ts_look    : ts_model
    mutable tb_ex      : @f32               # 2 cams x 2 eyes x (x,y,side)
    mutable tb_oc      : @f32               # 2 cams x 2 eyes x (ocx,ocy)
    mutable tb_ok      : @f32               # per-cam cascade success
    mutable tb_gx      : f32
    mutable tb_gy      : f32
    mutable tb_hx      : f32
    mutable tb_hy      : f32
    mutable tb_have    : bool
    mutable test_wait  : i32                   # draws until autostart
    mutable test_settle : i32                  # frames since test began
    mutable tb_fb      : @f32               # 2 cams x (face cx, cy, side)
    mutable tb_pv      : array Texture         # net-input panels: l/r/face per cam
    # two-step pair stage: offset reads both cams' face crops + aux
    # -> eye coordinate relative to the screen center (meters, person
    # frame); look reads BOTH cams' crops + that offset -> head/gaze
    mutable ts_off     : ts_model
    mutable tb_f0      : tensor                # top cam face crop
    mutable tb_f1      : tensor                # bottom cam face crop
    mutable tb_l0      : tensor                # top cam left eye crop
    mutable tb_r0      : tensor                # top cam right eye crop
    mutable tb_l1      : tensor                # bottom cam left eye
    mutable tb_r1      : tensor                # bottom cam right eye
    mutable tb_a36     : @f32               # both cams' 18-aux
    mutable tb_ox      : f32
    mutable tb_oy      : f32
    mutable tb_oz      : f32
    mutable tb_ohave   : bool
    # --verify: also render each sample's proof frame (camera at the
    # gaze target); off by default — it costs a third render per sample
    public  verify     : bool
    # --benchmark: record REAL test pairs while the user's eyes ride a
    # curved spiral mark — each pair carries the mark as its gaze label
    public  benchmark  : bool
    mutable bench_i    : i32
    mutable bench_last : i64
    mutable bench_at   : i64                  # captures start (3s settle)
    mutable bench_t0   : i64                  # spiral clock zero
    mutable bench_u    : f32
    mutable bench_v    : f32
    # --fit: triangulate the annotated record landmarks through the two
    # mount cameras -> the user's true face metrics; writes fit.agi and
    # exits. rec_fov = the record cameras' horizontal fov (degrees)
    public  fit        : bool
    # generation drives head ORIENTATION from the annotated
    # recordings (position stays the generator's uniform draw);
    # each sample picks a random fitted record. 10 minimum.
    mutable recs_n     : i32
    mutable recs_dat   : @f32               # 9 per record, see rec_solve
    mutable recs_fid   : @i32               # record file id per loaded record
    mutable recs_noise : @i32               # noise (no-face) record file ids
    mutable recs_noise_n : i32
    mutable hair_pat : @u8                  # 32x32 hair patches from h plots
    mutable hair_n   : i32
    public  rec_fov    : f32 [ 31.5 ]
    # your true outer-corner span (ruler-measurable). when > 0 the fit
    # SOLVES rec_fov by bisection until the stereo span matches it
    public  span_known : f32 [ 88.0 ]
    mutable fit_n      : i32
    mutable fit_span   : f32
    mutable fit_nose   : f32
    mutable fit_seat   : f32
    mutable fit_gap    : f32
    mutable cap_started : bool
    mutable rng      : i64 [ 88172645463325252 ]
    mutable ab_sigma : f32 [ 1.0 ]            # challenger spread
    mutable c_eye : f32 [ 91.0 ]             # champion (running centre), mm
    mutable c_nos : f32 [ 38.5 ]
    mutable c_mid : f32 [ 33.9 ]
    mutable c_ny  : f32 [ 42.3 ]
    # 4 variants shown in a 2x2 grid: [0] = champion (unperturbed), 1-3 challengers
    mutable veye : array f32
    mutable vnos : array f32
    mutable vmid : array f32
    mutable vny  : array f32
    # one camera shared by both faces so they always show the same angle; a
    # drag on either face writes back here and both faces read it each frame
    mutable yaw    : f32
    mutable pitch  : f32 [ 0.05 ]
    mutable dist   : f32 [ 3.5 ]
    mutable look_x : f32
    mutable look_y : f32 [ 1.0 ]
    mutable look_z : f32
    mutable cam_ready : bool                    # a face has auto-framed once

    # cage A/B loop. click on the MAIN view: unproject to the nearest control
    # vert, then give each vote view the main's cage plus its OWN random
    # scatter around that vert. click on a VOTE view: merge its cage back
    # into the main. corrections from randoms keep accumulating.
    public func cage_click [ mv: ModelView, mx: f32, my: f32 ]
        if [ !face_main || !face_main.vmodel ] return
        if [ mv.face_idx == 0 ]
            if [ !mv.pick_cage[ mx, my ] ] return
            cage_ci = mv.picked_cage
            cage_v  = mv.picked_vert
            cage_scatter[ vote_0 ]
            cage_scatter[ vote_1 ]
            puts 'cage propose: cage={cage_ci} vert={cage_v}'
        el
            if [ !mv.vmodel ] return
            face_main.vmodel.cage_copy_from[ mv.vmodel ]
            save_mask[ face_main ]
            puts 'cage merge: face_idx={mv.face_idx} -> main'

    # write the user mask: per cage, current control positions minus the
    # build-time base — the whole-cage derivation this session has built up
    public func save_mask [ mv: ModelView ]
        if [ !mv || !mv.vmodel || !mv.vmodel.cages ] return
        mkdir[ '/src/hyperspace-sessions', 493 ]
        sdir : '/src/hyperspace-sessions/{session}'
        mkdir[ sdir.chars, 493 ]
        fpn : '{sdir}/user.cage'
        fh : @FILE [ fopen[ fpn.chars, 'wb' ] ]
        if [ !fh ]
            puts 'mask save failed: {fpn}'
            return
        hdr : local i32 [ 2 ]
        hdr[0] = 777001
        hdr[1] = i32[ mv.vmodel.cages.count ]
        fwrite[ hdr, 4, i64[ 2 ], fh ]
        for [ ci: i32 0, ci < mv.vmodel.cages.count, ci += 1 ]
            t : mv.vmodel.cages[ ci ]
            nvh : local i32 [ 1 ]
            nvh[0] = t.nv
            fwrite[ nvh, 4, i64[ 1 ], fh ]
            if [ !t.cage_buf || !t.base ] continue
            cur : @f32 [ t.cage_buf.data ]
            n3 : i32 [ t.nv * 3 ]
            dbuf : new f32 [ n3 ]
            for [ i: i32 0, i < n3, i += 1 ] dbuf[ i ] = cur[ i ] - t.base[ i ]
            fwrite[ dbuf, 4, i64[ n3 ], fh ]
        fclose[ fh ]
        puts 'mask saved: {fpn}'

    # apply the user mask: current = base + saved deltas, whole cage
    public func load_mask [ mv: ModelView ]
        if [ !mv || !mv.vmodel || !mv.vmodel.cages ] return
        fpn : '/src/hyperspace-sessions/{session}/user.cage'
        fh : @FILE [ fopen[ fpn.chars, 'rb' ] ]
        if [ !fh ] return
        hdr : local i32 [ 2 ]
        fread[ hdr, 4, i64[ 2 ], fh ]
        if [ hdr[0] != 777001 || hdr[1] != i32[ mv.vmodel.cages.count ] ]
            puts 'mask mismatch (header): {fpn}'
            fclose[ fh ]
            return
        for [ ci: i32 0, ci < mv.vmodel.cages.count, ci += 1 ]
            t : mv.vmodel.cages[ ci ]
            nvh : local i32 [ 1 ]
            fread[ nvh, 4, i64[ 1 ], fh ]
            if [ nvh[0] != t.nv ]
                puts 'mask mismatch (cage {ci}): {fpn}'
                fclose[ fh ]
                return
            if [ !t.cage_buf || !t.base ] continue
            n3 : i32 [ t.nv * 3 ]
            dbuf : new f32 [ n3 ]
            fread[ dbuf, 4, i64[ n3 ], fh ]
            cur : @f32 [ t.cage_buf.data ]
            for [ i: i32 0, i < n3, i += 1 ] cur[ i ] = t.base[ i ] + dbuf[ i ]
        fclose[ fh ]
        puts 'mask loaded: {fpn}'

    # copy the champion cage into a vote view and shuffle around the picked
    # vert with a fresh random stream
    func cage_scatter [ vv: ModelView ]
        if [ !vv || !vv.vmodel || cage_v < 0 ] return
        vv.vmodel.cage_copy_from[ face_main.vmodel ]
        rng = rng * 6364136223846793005 + 1442695040888963407
        vv.vmodel.cage_shuffle[ cage_ci, cage_v, vv.paint_radius, vv.paint_amount, rng ]

    # uniform 0..1 from a 64-bit LCG; no Math.random in the module
    func rnd [] -> f32
        rng = rng * 6364136223846793005 + 1442695040888963407
        r : i64 [ (rng >> 33) & 2147483647 ]
        return f32[ r ] / 2147483647.0

    # ~zero-mean noise (triangular), range about [-1.5, 1.5]
    func gauss [] -> f32
        return rnd[] + rnd[] + rnd[] - 1.5

    # draw 4 variants around the champion: index 0 unperturbed, 1-3 spread by
    # ab_sigma. per-param base widths are rough human population ranges (mm)
    func resample []
        veye = array f32 [ ]
        vnos = array f32 [ ]
        vmid = array f32 [ ]
        vny  = array f32 [ ]
        for [ i: i32 0, i < 4, i += 1 ]
            s : f32 [ (i == 0) ? 0.0 : ab_sigma ]
            veye += c_eye + gauss[] * 6.0 * s
            vnos += c_nos + gauss[] * 5.0 * s
            vmid += c_mid + gauss[] * 4.0 * s
            vny  += c_ny  + gauss[] * 5.0 * s

    # adopt variant i as the new champion; adapt the spread by how far it sat
    # from the centre (index-0/near picks narrow, far picks keep exploring)
    public func pick [ i: i32 ]
        if [ i < 0 || i >= 4 ] return
        if [ !veye || veye.count < 4 ] return
        ne  : f32 [ veye[i] ]
        nn  : f32 [ vnos[i] ]
        nm  : f32 [ vmid[i] ]
        nyv : f32 [ vny[i] ]
        den : f32 [ ab_sigma ]
        if [ den < 0.001 ] den = 0.001
        de : f32 [ ne  - c_eye ]
        dn : f32 [ nn  - c_nos ]
        dm : f32 [ nm  - c_mid ]
        dy : f32 [ nyv - c_ny ]
        se : f32 [ ((de < 0.0) ? (0.0 - de) : de) / (6.0 * den) ]
        sn : f32 [ ((dn < 0.0) ? (0.0 - dn) : dn) / (5.0 * den) ]
        sm : f32 [ ((dm < 0.0) ? (0.0 - dm) : dm) / (4.0 * den) ]
        sy : f32 [ ((dy < 0.0) ? (0.0 - dy) : dy) / (5.0 * den) ]
        step : f32 [ (se + sn + sm + sy) * 0.25 ]
        c_eye = ne
        c_nos = nn
        c_mid = nm
        c_ny  = nyv
        if [ i == 0 ]
            ab_sigma = ab_sigma * 0.7
        el
            ab_sigma = ab_sigma * (0.55 + step)
        if [ ab_sigma > 1.5 ]  ab_sigma = 1.5
        if [ ab_sigma < 0.15 ] ab_sigma = 0.15
        resample[]
        puts 'hyperspace2: pick {i} sigma={ab_sigma} eye={c_eye} nos={c_nos} mid={c_mid} ny={c_ny}'

    public func on_key [ ev: Event ]
        if [ !ev.key.state ] return
        # space: skip this PAIR entirely (both cameras) during annotation
        if [ rec_mode == 'annotate' && ev.key.unicode == 32 ]
            ann_sub = 5
            ann_cam = 1
            ann_ext = ev.key.shift
            ann_seek[ false ]
            return
        # H: flag HAIR at the cursor (green ring) — one plot per camera,
        # re-press moves it; the sequence stays where it is. generation
        # later patches hair sections from here under perlin masks
        if [ rec_mode == 'annotate' && ev.key.unicode == 72 ]
            if [ ann_rect.w > 0.0 ]
                nx8 : f32 [ (ux.mouse.x - ann_rect.x) / ann_rect.w ]
                ny8 : f32 [ (ux.mouse.y - ann_rect.y) / ann_rect.h ]
                cam8 : string [ (ann_cam == 0) ? 'top' : 'bot' ]
                fidh : i32 [ i32[ atof[ ann_files[ ann_i ].chars ] ] ]
                agi_put2[ fidh, '{cam8}_hair', '{nx8} {ny8}' ]
                puts 'annotate: #{fidh} {cam8} hair at ({nx8}, {ny8})'
                ann_refresh_marks[]
            return
        # F: this pair is the FACE IDENTIFIER — the reference record
        # automatic face fitting reads proportions from. stays on screen
        if [ rec_mode == 'annotate' && ev.key.unicode == 70 ]
            fidn7 : i32 [ i32[ atof[ ann_files[ ann_i ].chars ] ] ]
            agi_put2[ fidn7, 'face_id', 'true' ]
            puts 'annotate: #{fidn7} marked face identifier'
            return
        # N: this pair is NOISE (no usable face) — mark it a negative
        # and skip it; it never re-enters the annotation queue
        if [ rec_mode == 'annotate' && ev.key.unicode == 78 ]
            fidn6 : i32 [ i32[ atof[ ann_files[ ann_i ].chars ] ] ]
            agi_put2[ fidn6, string 'noise', string 'true' ]
            puts 'annotate: #{fidn6} marked noise'
            ann_sub = 5
            ann_cam = 1
            ann_ext = ev.key.shift
            ann_seek[ false ]
            return
        if [ ev.key.unicode == 49 ] pick[ 0 ]     # 1: top-left
        if [ ev.key.unicode == 50 ] pick[ 1 ]     # 2: top-right
        if [ ev.key.unicode == 51 ] pick[ 2 ]     # 3: bottom-left
        if [ ev.key.unicode == 52 ] pick[ 3 ]     # 4: bottom-right
        # R (GLFW keycode 82): regenerate the vote variants (new seeds)
        if [ ev.key.unicode == 82 ] regen_i += 1
        # G (GLFW keycode 71): capture a two-angle perlin-labeled sample
        if [ ev.key.unicode == 71 ]
            if [ face_main ] face_main.begin_export[]
        # X: run the IR plot capture on the OFF-SCREEN capture element
        if [ ev.key.unicode == 88 ] start_capture[]
        # gaze arrows, hinge Q/E, IR toggle I live on the main view — keys
        # only reach focus/app_object, and ModelView is not focusable
        if [ face_main ] face_main.on_key[ ev ]

    # start the plot capture: the SAME ModelView element, hosted headless on
    # a trinity offscreen (backbuffer window, 3:2, no present). the champion
    # cage carries across; the interactive views never move.
    public func start_capture []
        if [ cap_view && cap_view.capture_left != 0 ] return
        if [ recs_n == 0 ]
            load_recs[]
        if [ recs_n < 10 ]
            puts 'generation needs 10 annotated records, have {recs_n} — record + plot oc first'
            if [ gen > 0 ] exit[ 1 ]
            return
        if [ !cap_os ]
            cv2 : ModelView [ model_path: model, face_idx: 0, id: 'cap_root' ]
            cv2.rig = a
            cap_os = offscreen [ vk: vk, width: cap_w, height: cap_h, root: cv2, st: ux.st ]
            cap_os.hold[]
            cap_view = cv2
            ux.offscreens.push[ cap_os ]
            # one headless frame builds the model, cages and anchors
            cap_os.frame[]
        if [ !cap_view.vmodel ]
            puts 'capture view not ready yet'
            return
        if [ face_main && face_main.vmodel ]
            cap_view.vmodel.cage_copy_from[ face_main.vmodel ]
        # regen always deletes what it annotated before: stale higher
        # indices from a longer prior run would poison the training set
        for [ di: i32 0, true, di += 1 ]
            da : path '/src/hyperspace-sessions/{session}/{di}.agi'
            if [ !da.exists[] ] break
            da.remove[]
            df : path '/src/hyperspace-sessions/{session}/{di}-face.png'
            if [ df.exists[] ] df.remove[]
            dv : path '/src/hyperspace-sessions/{session}/{di}-verify.png'
            if [ dv.exists[] ] dv.remove[]
            dp : path '/src/hyperspace-sessions/{session}/{di}-preview.png'
            if [ dp.exists[] ] dp.remove[]
            for [ dc: i32 0, dc < 4, dc += 1 ]
                dfc : path '/src/hyperspace-sessions/{session}/{di}-face{dc}.png'
                if [ dfc.exists[] ] dfc.remove[]
                dpc : path '/src/hyperspace-sessions/{session}/{di}-preview{dc}.png'
                if [ dpc.exists[] ] dpc.remove[]
                dic : path '/src/hyperspace-sessions/{session}/{di}-inputs{dc}.png'
                if [ dic.exists[] ] dic.remove[]
        # --gen counts POSES; each pose renders `looks` gaze positions
        np5 : i32 [ (gen > 0) ? gen : 100 ]
        lk5 : i32 [ (looks > 0) ? looks : 1 ]
        n5 : i32 [ np5 * lk5 ]
        cap_view.begin_capture[ n5 ]
        puts 'plot capture: {np5} poses x {lk5} looks = {n5} samples -> session {session}'

    public func render [] -> Elements
        if [ !seeded ]
            resample[]
            # the stdout overlay sits below our toolbar row
            ux.stdout_y = 32.0
            seeded = true
        e : Elements [ ]
        # record mode: ONLY the two live feeds (stacked like the physical
        # rig, top over bottom) + the toolbar — you see what you record
        # annotate: bare stage — on_canvas draws the image + click cues;
        # any mounted view would paint right over it
        if [ rec_mode == 'annotate' ]
            return e
        if [ rec_mode == 'record' ]
            # own id: a toolbar reused across modes keeps its OLD children
            e['rec-toolbar'] = Toolbar [ elements: Elements [
                'record':  Button [ label: 'stop' ] ] ]
            # animated: live feeds must repaint every frame, never cache
            e['top'] = CameraView [ device: cam_top_dev, animated: true ]
            e['bot'] = CameraView [ device: cam_bot_dev, animated: true ]
            return e
        if [ rec_mode == 'test' ]
            # small live feeds; the cascade + gaze dot draw in on_canvas
            e['top'] = CameraView [ device: cam_top_dev, animated: true ]
            e['bot'] = CameraView [ device: cam_bot_dev, animated: true ]
            return e
        if [ rec_mode == 'bench' ]
            # cameras pump invisibly; ONLY the spiral mark shows
            e['top'] = CameraView [ device: cam_top_dev, animated: true, paint_off: true ]
            e['bot'] = CameraView [ device: cam_bot_dev, animated: true, paint_off: true ]
            return e
        # main champion view on top; two bottom strips of 128x128 vote cells —
        # 'low' (broad, large-map variants) and 'high' (detail, small-map)
        e['face_main'] = ModelView [ model_path: model, face_idx: 0,
            yaw: yaw, pitch: pitch, dist: dist, look_x: look_x, look_y: look_y, look_z: look_z ]
        e['vote_0'] = ModelView [ model_path: model, face_idx: 10 + regen_i * 100,
            yaw: yaw, pitch: pitch, dist: dist, look_x: look_x, look_y: look_y, look_z: look_z ]
        e['vote_1'] = ModelView [ model_path: model, face_idx: 11 + regen_i * 100,
            yaw: yaw, pitch: pitch, dist: dist, look_x: look_x, look_y: look_y, look_z: look_z ]
        if [ rec_mode != 'annotate' ]
            e['toolbar'] = Toolbar [ elements: Elements [
                'record':  Button [ label: 'record' ],
                'noise':   Button [ label: 'noise' ],
                'plot-oc': Button [ label: 'plot oc' ],
                'testbed': Button [ label: 'test' ],
                'bench':   Button [ label: 'bench' ] ] ]
        return e
