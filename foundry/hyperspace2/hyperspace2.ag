import vec
import img
import gltf
import trinity
import <stdio.h>
import <stdlib.h>
import <math.h>

# basic glTF model viewer: `hyperspace2 --model path/to/model.gltf`
# drag orbits the camera, wheel zooms, R resets the view.

ModelViewProject ViewerLit
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib a_pos     : VertexInput    [ type:typeid[ vec3f ] ]
    attrib a_normal  : VertexInput    [ type:typeid[ vec3f ] ]
    attrib a_uv      : VertexInput    [ type:typeid[ vec2f ] ]

    attrib v_normal  : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        view  = mat4f.identity[]
        proj  = mat4f.identity[]

    func vertex [] -> GLSL none {
        v_normal    = mat3(ubo.model) * a_normal;
        v_uv        = a_uv;
        gl_Position = ubo.proj * ubo.view * ubo.model * vec4(a_pos, 1.0);
    }

    # two directional lights + ambient over the material color — enough to read
    # form on any model without needing a full PBR/environment setup
    func fragment [] -> GLSL none {
        vec4  c  = texture(color, v_uv);
        vec3  n  = normalize(v_normal);
        float l  = max(dot(n, normalize(vec3( 0.35, 0.75,  0.55))), 0.0) * 0.75
                 + max(dot(n, normalize(vec3(-0.50, 0.20, -0.60))), 0.0) * 0.25 + 0.22;
        fragColor = vec4(c.rgb * l, 1.0);
    }

# skinned variant: exactly the hinge's attributes (pos/normal/uv + joints/weights)
# plus a joint-matrix palette (SSBO, 4 vec4 per mat4). the vertex is transformed
# by the weighted blend of its joints' matrices, then the model/view/proj.
ModelViewProject SkinnedLit
    mutable ir  : f32         # 1 = near-IR headlamp look, 0 = textured color
    mutable sss : f32 [ 0.4 ] # subsurface wrap: 0 = hard lambert, ~0.5 = waxy skin
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    # declared in CANONICAL packing order — the engine binds vertex inputs to
    # packed attributes by position, so a_tangent/a_uv1 must be present (even if
    # unused) or a_joints/a_weights would bind to TANGENT/TEXCOORD_1 instead
    attrib a_pos     : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_normal  : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_uv      : VertexInput [ type:typeid[ vec2f ] ]
    attrib a_tangent : VertexInput [ type:typeid[ vec4f ] ]     # TANGENT (unused, for layout)
    attrib a_uv1     : VertexInput [ type:typeid[ vec2f ] ]     # TEXCOORD_1 (unused, for layout)
    attrib a_joints  : VertexInput [ type:typeid[ vec4f ] ]     # JOINTS_0 rgba8 UNORM -> *255 = index
    attrib a_weights : VertexInput [ type:typeid[ vec4f ] ]     # WEIGHTS_0

    attrib joints_pal : StorageBuffer [ type:typeid[ Surface ], id:Surface.environment, count:1, format:typeid[ vec4f ] ]

    attrib v_normal  : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib v_vpos    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_vnorm   : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        view  = mat4f.identity[]
        proj  = mat4f.identity[]
        ir    = 1.0

    func vertex [] -> GLSL none {
        int j0 = int(a_joints.x * 255.0 + 0.5);
        int j1 = int(a_joints.y * 255.0 + 0.5);
        int j2 = int(a_joints.z * 255.0 + 0.5);
        int j3 = int(a_joints.w * 255.0 + 0.5);
        mat4 m0 = mat4(joints_pal[j0*4], joints_pal[j0*4+1], joints_pal[j0*4+2], joints_pal[j0*4+3]);
        mat4 m1 = mat4(joints_pal[j1*4], joints_pal[j1*4+1], joints_pal[j1*4+2], joints_pal[j1*4+3]);
        mat4 m2 = mat4(joints_pal[j2*4], joints_pal[j2*4+1], joints_pal[j2*4+2], joints_pal[j2*4+3]);
        mat4 m3 = mat4(joints_pal[j3*4], joints_pal[j3*4+1], joints_pal[j3*4+2], joints_pal[j3*4+3]);
        mat4 sm = a_weights.x*m0 + a_weights.y*m1 + a_weights.z*m2 + a_weights.w*m3;
        vec4 sp     = sm * vec4(a_pos, 1.0);
        vec4 vp     = ubo.view * sp;
        v_normal    = normalize(mat3(sm) * a_normal);
        v_vnorm     = mat3(ubo.view) * (mat3(sm) * a_normal);
        v_vpos      = vp.xyz;
        v_uv        = a_uv;
        gl_Position = ubo.proj * vp;
    }

    # ubo.ir toggles the two looks: near-IR headlamp (light at the camera,
    # N.V falloff, soft broad sheen, distance falloff) vs textured color
    func fragment [] -> GLSL none {
        if (ubo.ir > 0.5) {
            vec3  N   = normalize(v_vnorm);
            vec3  V   = normalize(-v_vpos);
            float ndv = max(dot(N, V), 0.0);
            // subsurface: NIR diffuses under skin, so wrap light past the
            // terminator (soft shadows) and add a broad deep-scatter glow
            float w    = ubo.sss;
            float ndvw = clamp((ndv + w) / (1.0 + w), 0.0, 1.0);
            float diff = pow(ndvw, 1.2);
            float scat = pow(ndvw, 0.5) * w * 0.35;
            float spec = pow(ndv, 16.0) * 0.25;
            float d    = length(v_vpos);
            float fall = clamp(2.0 / (1.0 + 0.04 * d * d), 0.0, 1.0);
            float g    = (0.60 * (diff + scat) + spec) * fall;
            fragColor  = vec4(vec3(g), 1.0);
        } else {
            vec4  c  = texture(color, v_uv);
            vec3  n  = normalize(v_normal);
            float l  = max(dot(n, normalize(vec3( 0.35, 0.75,  0.55))), 0.0) * 0.75
                     + max(dot(n, normalize(vec3(-0.50, 0.20, -0.60))), 0.0) * 0.25 + 0.22;
            fragColor = vec4(c.rgb * l, 1.0);
        }
    }

# non-skinned primitives (eyeballs, teeth, tongue): rigid transform by the
# node's world matrix (ubo.model), driven by whichever bone the mesh parents to
# augmentation params (driven per synthetic sample): pupil aperture radius
# (dilation) and its fuzz, the outer iris/limbus radius and its fuzz, the
# retina glow strength, and the iris fibre brightness
ModelViewProject RigidLit
    mutable ir          : f32     # 1 = near-IR headlamp look, 0 = textured color
    mutable pupil_r     : f32 [ 0.15 ]
    mutable pupil_soft  : f32 [ 0.05 ]
    mutable iris_r      : f32 [ 0.45 ]
    mutable iris_soft   : f32 [ 0.04 ]
    mutable iris_glow   : f32 [ 0.95 ]
    mutable iris_bright : f32 [ 0.40 ]
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib a_pos     : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_normal  : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_uv      : VertexInput [ type:typeid[ vec2f ] ]

    attrib v_normal  : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib v_vpos    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_vnorm   : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        view  = mat4f.identity[]
        proj  = mat4f.identity[]
        ir    = 1.0

    func vertex [] -> GLSL none {
        vec4 wp     = ubo.model * vec4(a_pos, 1.0);
        vec4 vp     = ubo.view * wp;
        v_normal    = normalize(mat3(ubo.model) * a_normal);
        v_vnorm     = mat3(ubo.view) * (mat3(ubo.model) * a_normal);
        v_vpos      = vp.xyz;
        v_uv        = a_uv;
        gl_Position = ubo.proj * vp;
    }

    # ubo.ir toggles: near-IR headlamp (the wet eyeball keeps a sharp glint)
    # vs textured color
    func fragment [] -> GLSL none {
        if (ubo.ir > 0.5) {
            vec3  V    = normalize(-v_vpos);
            float d    = length(v_vpos);
            float fall = clamp(2.0 / (1.0 + 0.04 * d * d), 0.0, 1.0);
            // iris fibres live in the texture ALPHA (0 at the pupil, ~0.3..0.7
            // across the ring); unbound pupil sampler is transparent-black
            vec4  t    = texture(color, v_uv);
            float m    = t.a;
            // aperture axis is the eye's LOCAL +z pushed to view space, so the
            // retro return follows gaze, not the doming surface normals. broad
            // in the axis dot -> stays bright ~60 deg off-axis
            vec3  fwd  = normalize(mat3(ubo.view) * (mat3(ubo.model) * vec3(0.0, 0.0, 1.0)));
            float retro = pow(max(dot(fwd, V), 0.0), 0.45);
            // parameterized shape: pupil opening (inner) and limbus (outer)
            // are soft radial edges; the fibre detail comes from the texture
            float r    = length(v_uv - vec2(0.5));
            float pin  = smoothstep(ubo.pupil_r - ubo.pupil_soft, ubo.pupil_r + ubo.pupil_soft, r);
            float pout = 1.0 - smoothstep(ubo.iris_r - ubo.iris_soft, ubo.iris_r + ubo.iris_soft, r);
            float glow = (0.15 + ubo.iris_glow)      * retro;
            float iris = (0.14 + ubo.iris_bright * m) * retro;
            float g    = mix(glow, iris, pin) * pout * fall;
            fragColor  = vec4(vec3(g), 1.0);
        } else {
            vec4  c  = texture(color, v_uv);
            vec3  n  = normalize(v_normal);
            float l  = max(dot(n, normalize(vec3( 0.35, 0.75,  0.55))), 0.0) * 0.75
                     + max(dot(n, normalize(vec3(-0.50, 0.20, -0.60))), 0.0) * 0.25 + 0.22;
            fragColor = vec4(c.rgb * l, 1.0);
        }
    }

# the wet cornea layer, drawn transparent over the opaque iris: near-clear on the
# forward bulge so the iris reads through, opaque pale sclera at grazing angles,
# and one sharp on-axis Purkinje glint toward the camera
# augmentation params (driven per synthetic sample): sclera brightness facing
# the camera vs at the periphery, its falloff shape, and the glint strength
ModelViewProject CorneaIR
    mutable ir        : f32
    mutable glint     : f32 [ 0.9 ]
    mutable sclera_hi : f32 [ 0.95 ]
    mutable sclera_lo : f32 [ 0.20 ]
    mutable sclera_k  : f32 [ 1.5 ]
    # volume eye: refract the view ray at the cornea and march it through the
    # anterior chamber to the iris plane sitting inside the eyeball sphere.
    # geometry from the model: eyeball radius ~0.0122, iris plane z~0.009,
    # iris radius ~0.0105 (local, metres)
    mutable ior         : f32 [ 1.20 ]
    mutable cornea_c    : f32 [ 0.0025 ]
    mutable cornea_r    : f32 [ 0.0110 ]
    mutable iris_z      : f32 [ 0.009 ]
    mutable iris_radius : f32 [ 0.0046 ]
    mutable iris_tex_scale : f32 [ 1.0 ]
    mutable iris_rot    : f32 [ 0.0 ]
    mutable limbus_soft : f32 [ 0.22 ]
    # iris map mixing: melanin pigment, 3 displacement variants, sclera veins
    mutable mel_amt     : f32 [ 1.0 ]
    mutable disp_wa     : f32 [ 1.0 ]
    mutable disp_wb     : f32 [ 0.0 ]
    mutable disp_wc     : f32 [ 0.0 ]
    mutable disp_amt    : f32 [ 0.35 ]
    mutable sclera_vein : f32 [ 0.15 ]
    mutable pupil_r     : f32 [ 0.40 ]
    mutable pupil_soft  : f32 [ 0.08 ]
    # dilation: pupil_r is the rendered pupil edge; the iris band (pupil_tex..1
    # in the texture) is remapped into (pupil_r..1) with a 2-part warp
    mutable pupil_tex   : f32 [ 0.28 ]
    mutable dilate_warp : f32 [ 1.0 ]
    mutable iris_glow   : f32 [ 0.9 ]
    mutable retro_k     : f32 [ 1.5 ]
    mutable retina_min  : f32 [ 0.25 ]
    mutable iris_bright : f32 [ 0.65 ]
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]
    attrib iris  : LayoutBinding [ type:typeid[ Surface ], id:Surface.iris,  count:1, format: typeid[ rgba8 ] ]
    attrib iris_melanin : LayoutBinding [ type:typeid[ Surface ], id:Surface.iris_melanin, count:1, format: typeid[ rgba8 ] ]
    attrib iris_disp_a  : LayoutBinding [ type:typeid[ Surface ], id:Surface.iris_disp_a,  count:1, format: typeid[ rgba8 ] ]
    attrib iris_disp_b  : LayoutBinding [ type:typeid[ Surface ], id:Surface.iris_disp_b,  count:1, format: typeid[ rgba8 ] ]
    attrib iris_disp_c  : LayoutBinding [ type:typeid[ Surface ], id:Surface.iris_disp_c,  count:1, format: typeid[ rgba8 ] ]
    attrib sclera_disp  : LayoutBinding [ type:typeid[ Surface ], id:Surface.sclera_disp,  count:1, format: typeid[ rgba8 ] ]

    attrib a_pos     : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_normal  : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_uv      : VertexInput [ type:typeid[ vec2f ] ]

    attrib v_normal  : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib v_vpos    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_vnorm   : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        view  = mat4f.identity[]
        proj  = mat4f.identity[]
        ir    = 1.0

    func vertex [] -> GLSL none {
        vec4 wp     = ubo.model * vec4(a_pos, 1.0);
        vec4 vp     = ubo.view * wp;
        v_normal    = normalize(mat3(ubo.model) * a_normal);
        v_vnorm     = mat3(ubo.view) * (mat3(ubo.model) * a_normal);
        v_vpos      = vp.xyz;
        v_uv        = a_uv;
        gl_Position = ubo.proj * vp;
    }

    func fragment [] -> GLSL none {
        // eye local frame (right/up/fwd) and center, all in view space
        mat3  MV    = mat3(ubo.view) * mat3(ubo.model);
        vec3  fwd   = normalize(MV * vec3(0.0, 0.0, 1.0));
        vec3  right = normalize(MV * vec3(1.0, 0.0, 0.0));
        vec3  up    = normalize(MV * vec3(0.0, 1.0, 0.0));
        vec3  Cc    = (ubo.view * ubo.model * vec4(0.0, 0.0, 0.0, 1.0)).xyz;

        vec3  N     = normalize(v_vnorm);
        vec3  Vd    = normalize(-v_vpos);
        float ndv   = max(dot(N, Vd), 0.0);

        // VOLUME: the flat iris disc only rasterizes the eye region; here we
        // trace the real cornea analytically. intersect the camera ray with a
        // cornea sphere sitting in front of the iris, refract at that surface,
        // then march to the iris plane. true depth + parallax, no flat sprite.
        vec3  D     = normalize(v_vpos);
        vec3  Sc    = Cc + fwd * ubo.cornea_c;
        float b     = dot(D, Sc);
        float c     = dot(Sc, Sc) - ubo.cornea_r * ubo.cornea_r;
        float disc  = b * b - c;
        float m     = 0.0;
        float rr    = 2.0;
        float spec  = 0.0;
        if (disc > 0.0) {
            float tt  = b - sqrt(disc);
            vec3  Pin = D * tt;
            vec3  Nin = normalize(Pin - Sc);
            vec3  R   = refract(D, Nin, 1.0 / ubo.ior);
            if (dot(R, R) < 1e-6) { R = D; }
            float Rz  = dot(R, fwd);
            Rz = (Rz < 0.0) ? min(Rz, -1e-3) : max(Rz, 1e-3);
            float s   = (ubo.iris_z - dot(Pin - Cc, fwd)) / Rz;
            vec3  hit = Pin + R * s;
            vec2  hxy = vec2(dot(hit - Cc, right), dot(hit - Cc, up));
            rr        = length(hxy) / ubo.iris_radius;
            // rotate the iris texture, then scale its inner detail
            float ca  = cos(ubo.iris_rot);
            float sa  = sin(ubo.iris_rot);
            vec2  rxy = vec2(hxy.x * ca - hxy.y * sa, hxy.x * sa + hxy.y * ca);
            // pupil dilation: remap the iris band into (pupil_r..1) with a
            // 2-part warp, so tissue near the pupil compresses vs the rim
            float u   = clamp((rr - ubo.pupil_r) / max(1.0 - ubo.pupil_r, 1e-3), 0.0, 1.0);
            float tr  = ubo.pupil_tex + pow(u, ubo.dilate_warp) * (1.0 - ubo.pupil_tex);
            vec2  dir = (rr > 1e-4) ? rxy / (rr * ubo.iris_radius) : vec2(0.0);
            vec2  iuv = vec2(0.5) + 0.5 * dir * (tr / ubo.iris_tex_scale);
            float fib = texture(iris, iuv).a;
            float mel = texture(iris_melanin, iuv).r;
            float da  = texture(iris_disp_a, iuv).r;
            float db  = texture(iris_disp_b, iuv).r;
            float dc  = texture(iris_disp_c, iuv).r;
            float dsp = da * ubo.disp_wa + db * ubo.disp_wb + dc * ubo.disp_wc;
            // melanin sets iris darkness; fibres + displacement crypts add relief
            float base= mix(1.0, mel, ubo.mel_amt);
            m         = clamp(base * (0.6 + 0.4 * fib) + (dsp - 0.5) * ubo.disp_amt, 0.0, 1.0);
            spec      = pow(max(dot(Nin, Vd), 0.0), 120.0) * ubo.glint;
        }

        // pupil, iris fibres, and the retina retroreflection (4x facing the eye)
        float retro = pow(max(dot(fwd, Vd), 0.0), ubo.retro_k);
        float pin   = smoothstep(ubo.pupil_r - ubo.pupil_soft, ubo.pupil_r + ubo.pupil_soft, rr);
        float retina= 1.0 - smoothstep(0.0, ubo.pupil_r, rr) * 0.6;
        float glow  = ubo.iris_glow * mix(ubo.retina_min, 1.0, retro) * retina;
        float irG   = ubo.iris_bright * m;
        float irisV = mix(glow, irG, pin);
        float inIr  = 1.0 - smoothstep(1.0 - ubo.limbus_soft, 1.0, rr);

        // white sclera outside the iris
        float shade = mix(ubo.sclera_lo, ubo.sclera_hi, pow(ndv, ubo.sclera_k));
        float sc    = texture(color, v_uv).r;
        float sdsp  = texture(sclera_disp, v_uv).r;
        float sclera= sc * shade + (sdsp - 0.5) * ubo.sclera_vein;

        float g     = mix(sclera, irisV, inIr) + spec;
        fragColor   = vec4(vec3(g), 1.0);
    }

element ModelView
    # required at construction — the caller must provide it (null is a valid
    # explicit provision; the draw guard then reports the missing file)
    expect  model_path : path
    mutable vshader    : SkinnedLit
    mutable rshader    : RigidLit
    mutable cshader    : CorneaIR
    mutable vmodel     : Model
    mutable vrender    : Render
    mutable gmodel     : GltfModel
    mutable joint_buf  : Buffer
    mutable ibm        : array mat4f          # inverse bind matrices, one per joint
    mutable skin_idx   : i32 [ -1 ]
    mutable hinge_node : i32 [ -1 ]           # the node we rotate (the joint)
    mutable hinge_ang  : f32                  # joint angle, radians
    # eye rig (from the .blend): DAMPED_TRACK aims Eyeball +Y at the target;
    # Eyelids Drag copies 0.8 of eyeball pitch (X) + 0.2 of yaw (Z); Caruncle
    # copies 0.8 X + 0.5 Z. we drive those bones directly at those fractions.
    mutable ebl        : i32 [ -1 ]           # Eyeball.L node index
    mutable ebr        : i32 [ -1 ]           # Eyeball.R
    mutable dgl        : i32 [ -1 ]           # Eyelids Drag.L
    mutable dgr        : i32 [ -1 ]           # Eyelids Drag.R
    mutable crl        : i32 [ -1 ]           # Caruncle.L
    mutable crr        : i32 [ -1 ]           # Caruncle.R
    mutable ebl_rest   : quatf
    mutable ebr_rest   : quatf
    mutable dgl_rest   : quatf
    mutable dgr_rest   : quatf
    mutable crl_rest   : quatf
    mutable crr_rest   : quatf
    # eye spacing (IPD): nudge the eyeball globe bones apart, and let the
    # lid/socket skin follow via a one-time world-space vertex bake (falloff)
    mutable gbl        : i32 [ -1 ]           # Eyeball.L node (globe bone)
    mutable gbr        : i32 [ -1 ]           # Eyeball.R node (globe bone)
    mutable gbl_rest   : vec3f                # Eyeball.L rest translation
    mutable gbr_rest   : vec3f                # Eyeball.R rest translation
    mutable eye_spacing : f32 [ 0.0 ]         # per-eye outward shift, metres (derived)
    mutable span_mm    : f32 [ 91.0 ]         # outer-corner to outer-corner, mm
    mutable ir_on      : bool [ true ]        # near-IR look vs textured color
    mutable gaze_x     : f32                  # eye yaw (left/right), radians
    mutable gaze_y     : f32                  # eye pitch (up/down), radians
    mutable yaw        : f32
    mutable pitch      : f32 [ 0.05 ]
    mutable dist       : f32 [ 3.5 ]
    mutable look_x     : f32
    mutable look_y     : f32 [ 1.0 ]
    mutable look_z     : f32
    mutable dragging   : bool
    mutable lastx      : f32
    mutable lasty      : f32
    mutable frame_n    : i32
    mutable last_press : i32 [ -100 ]         # frame of the last click (dbl-click)
    mutable nose_gain  : f32 [ 0.03 ]         # nose scale from _V_NOSE mask
    # nose landmark fit (mm); defaults equal the model rest -> no-op until set
    mutable nostril_span : f32 [ 38.5 ]       # nostril edge-to-edge, x
    mutable mid_nose     : f32 [ 33.9 ]       # mid-nose width, x
    mutable nostril_y    : f32 [ 42.3 ]       # nostril below eye plane, y
    public  split    : bool                   # CSS :split state -> half width
    # last-baked fit values; when the parent picker feeds new landmarks the
    # mismatch triggers a rebuild so this face re-bakes to them
    mutable baked_span : f32 [ -1.0 ]
    mutable baked_nos  : f32 [ -1.0 ]
    mutable baked_mid  : f32 [ -1.0 ]
    mutable baked_ny   : f32 [ -1.0 ]
    mutable eye_tex : array Texture           # held eye maps, dropped on reload
    mutable morph_w    : map f32 [ string ]   # morph target name -> blend weight
    mutable subdiv_on  : bool [ true ]        # Catmull-Clark subdivide at load
    mutable subdiv_levels : i32 [ 2 ]         # number of Catmull-Clark passes

    func init []
        animated  = true
        focusable = true
        morph_w   = map f32 [ string ] [ ]
        # drive morphs per-sample: morph_w[ 'Body Asian' ] = 1.0, etc.
        # this face is param-driven by the FacePicker parent; not focusable so
        # keys reach the picker (mouse orbit still works by position)
        focusable = false

    # the shared camera + A/B state live on the hyperspace2 app root parent
    func picker [] -> hyperspace2
        if [ !parent ] return null
        return (parent) to hyperspace2

    public func on_press [ ev: Event ]
        # double-click (two presses within ~20 frames) toggles the A|B split
        fp : picker[]
        if [ fp && (frame_n - last_press) < 20 ] fp.split = !fp.split
        last_press = frame_n
        dragging = true
        lastx = ev.mouse.pos.x
        lasty = ev.mouse.pos.y
        set_capture[]

    public func on_release [ ev: Event ]
        dragging = false
        release_capture[]

    public func on_move [ ev: Event ]
        if [ !dragging ] return
        fp : picker[]
        if [ !fp ] return
        dx : f32 [ ev.mouse.pos.x - lastx ]
        dy : f32 [ ev.mouse.pos.y - lasty ]
        lastx = ev.mouse.pos.x
        lasty = ev.mouse.pos.y
        if [ ev.key.shift ]
            # shift-drag PANS: translate the look target along the camera's
            # right and screen-up axes, scaled so the content tracks the cursor
            sc : f32 [ fp.dist * 0.0016 ]
            syw : f32 [ sin[ fp.yaw ] ]
            cyw : f32 [ cos[ fp.yaw ] ]
            spt : f32 [ sin[ fp.pitch ] ]
            cpt : f32 [ cos[ fp.pitch ] ]
            fp.look_x += (cyw * dx + syw * spt * dy) * sc
            fp.look_y += cpt * dy * sc
            fp.look_z += ((0.0 - syw) * dx + cyw * spt * dy) * sc
        el
            fp.yaw   += dx * 0.01
            fp.pitch += dy * 0.01
            if [ fp.pitch >  1.5 ] fp.pitch =  1.5
            if [ fp.pitch < -1.5 ] fp.pitch = -1.5

    public func on_wheel [ ev: Event ]
        fp : picker[]
        if [ !fp ] return
        fp.dist *= 1.0 - f32[ ev.mouse.wheel_delta.y ] * 0.1
        if [ fp.dist < 0.2 ]  fp.dist = 0.2
        if [ fp.dist > 50.0 ] fp.dist = 50.0

    public func on_key [ ev: Event ]
        if [ !ev.key.state ] return
        if [ ev.key.unicode == 82 ]        # R: reset view
            yaw   = 0.0
            pitch = 0.05
        if [ ev.key.unicode == 81 ] hinge_ang -= 0.1   # Q: rotate joint -
        if [ ev.key.unicode == 69 ] hinge_ang += 0.1   # E: rotate joint +
        if [ ev.key.unicode == 73 ]                    # I: toggle IR / color
            ir_on = !ir_on
            irf : f32 [ (ir_on) ? 1.0 : 0.0 ]
            if [ vshader ] vshader.ir = irf
            if [ rshader ] rshader.ir = irf
            if [ cshader ] cshader.ir = irf
        if [ hinge_ang >  3.0 ] hinge_ang =  3.0
        if [ hinge_ang < -3.0 ] hinge_ang = -3.0
        # arrow keys aim the eyes (move the look target left/right/up/down)
        if [ ev.key.unicode == 263 ] gaze_x -= 0.05     # left
        if [ ev.key.unicode == 262 ] gaze_x += 0.05     # right
        if [ ev.key.unicode == 265 ] gaze_y -= 0.05     # up
        if [ ev.key.unicode == 264 ] gaze_y += 0.05     # down
        if [ gaze_x >  0.6 ] gaze_x =  0.6
        if [ gaze_x < -0.6 ] gaze_x = -0.6
        if [ gaze_y >  0.5 ] gaze_y =  0.5
        if [ gaze_y < -0.5 ] gaze_y = -0.5

    # tear down the loaded model so the next draw re-inits with the new fit
    func reload_model []
        if [ eye_tex ]
            for [ tx: Texture ] in eye_tex
                tx.drop[]
            eye_tex = null
        if [ gmodel ] gmodel.drop[]
        if [ joint_buf ] joint_buf.drop[]
        gmodel    = null
        joint_buf = null
        vmodel    = null
        vrender   = null
        skin_idx  = -1
        hinge_node = -1
        gbl = -1
        gbr = -1

    # blend selected shape keys (glTF morph targets) into POSITION at load,
    # weighted by morph_w[name]. runs before skinning and the _V_* detail.
    func apply_morphs []
        if [ !gmodel ] return
        if [ !morph_w ] return
        for [ msh: Mesh ] in gmodel.meshes
            if [ !msh.extras ] continue
            names : msh.extras.targetNames
            if [ !names ] continue
            for [ prim: Primitive ] in msh.primitives
                if [ !prim.targets ] continue
                if [ prim.targets.count == 0 ] continue
                pos_ai : i32 [ -1 ]
                for [ value: ref i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai = i32[ value[0] ]
                if [ pos_ai < 0 ] continue
                pac : gmodel.accessors[ pos_ai ]
                pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
                pbb : gmodel.buffers[ i32[ pbv.buffer ] ]
                pbase : ref i8 [ pbb.data ]
                pstride : i64 [ pac.stride ]
                if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
                poff : i64 [ pbv.byteOffset + pac.byteOffset ]
                vc : i32 [ i32[ pac.count ] ]
                for [ w: f32, nm: string ] in morph_w
                    if [ w < 0.001 ] continue
                    ti : i32 [ -1 ]
                    for [ ni: i32 0, ni < names.count, ni += 1 ]
                        if [ names[ ni ] == nm ] ti = ni
                    if [ ti < 0 ] continue
                    if [ ti >= prim.targets.count ] continue
                    tmap : prim.targets[ ti ]
                    dpos_ai : i32 [ -1 ]
                    for [ value: ref i64, a_name: string ] in tmap
                        if [ a_name == 'POSITION' ] dpos_ai = i32[ value[0] ]
                    if [ dpos_ai < 0 ] continue
                    dac : gmodel.accessors[ dpos_ai ]
                    dbv : gmodel.bufferViews[ i32[ dac.bufferView ] ]
                    dbb : gmodel.buffers[ i32[ dbv.buffer ] ]
                    dbase : ref i8 [ dbb.data ]
                    dstride : i64 [ dac.stride ]
                    if [ dbv.byteStride > 0 ] dstride = dbv.byteStride
                    doff : i64 [ dbv.byteOffset + dac.byteOffset ]
                    for [ i: i32 0, i < vc, i += 1 ]
                        pf : ref f32 [ ((ref pbase[ poff + i64[ i ] * pstride ]) to ref f32) ]
                        df : ref f32 [ ((ref dbase[ doff + i64[ i ] * dstride ]) to ref f32) ]
                        pf[0] = pf[0] + w * df[0]
                        pf[1] = pf[1] + w * df[1]
                        pf[2] = pf[2] + w * df[2]

    # scale the nose region by the painted _V_NOSE blue mask (gray 0.216 =
    # neutral, brighter = push out). baked into POSITION once, before upload.
    func bake_nose []
        if [ !gmodel ] return
        neutral : f32 [ 0.216 ]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                pos_ai  : i32 [ -1 ]
                nose_ai : i32 [ -1 ]
                for [ value: ref i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai  = i32[ value[0] ]
                    if [ a_name == '_V_NOSE'  ] nose_ai = i32[ value[0] ]
                if [ pos_ai  < 0 ] continue
                if [ nose_ai < 0 ] continue
                pac : gmodel.accessors[ pos_ai ]
                nac : gmodel.accessors[ nose_ai ]
                pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
                nbv : gmodel.bufferViews[ i32[ nac.bufferView ] ]
                pbb : gmodel.buffers[ i32[ pbv.buffer ] ]
                nbb : gmodel.buffers[ i32[ nbv.buffer ] ]
                pbase : ref i8 [ pbb.data ]
                nbase : ref i8 [ nbb.data ]
                pstride : i64 [ pac.stride ]
                nstride : i64 [ nac.stride ]
                if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
                if [ nbv.byteStride > 0 ] nstride = nbv.byteStride
                poff : i64 [ pbv.byteOffset + pac.byteOffset ]
                noff : i64 [ nbv.byteOffset + nac.byteOffset ]
                vc : i32 [ i32[ pac.count ] ]
                cx : f32 [ 0.0 ]
                cy : f32 [ 0.0 ]
                cz : f32 [ 0.0 ]
                wsum : f32 [ 0.0 ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : ref u16 [ ((ref nbase[ noff + i64[ i ] * nstride ]) to ref u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    pf : ref f32 [ ((ref pbase[ poff + i64[ i ] * pstride ]) to ref f32) ]
                    cx += pf[0] * m
                    cy += pf[1] * m
                    cz += pf[2] * m
                    wsum += m
                if [ wsum <= 0.0 ] continue
                cx /= wsum
                cy /= wsum
                cz /= wsum
                rad : f32 [ 0.0 ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : ref u16 [ ((ref nbase[ noff + i64[ i ] * nstride ]) to ref u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    pf : ref f32 [ ((ref pbase[ poff + i64[ i ] * pstride ]) to ref f32) ]
                    dx : f32 [ pf[0] - cx ]
                    dy : f32 [ pf[1] - cy ]
                    dz : f32 [ pf[2] - cz ]
                    d  : f32 [ sqrt[ dx * dx + dy * dy + dz * dz ] ]
                    if [ d > rad ] rad = d
                if [ rad <= 0.0 ] continue
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : ref u16 [ ((ref nbase[ noff + i64[ i ] * nstride ]) to ref u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    pf : ref f32 [ ((ref pbase[ poff + i64[ i ] * pstride ]) to ref f32) ]
                    dx : f32 [ pf[0] - cx ]
                    dy : f32 [ pf[1] - cy ]
                    dz : f32 [ pf[2] - cz ]
                    d  : f32 [ sqrt[ dx * dx + dy * dy + dz * dz ] ]
                    if [ d < 0.000001 ] continue
                    s  : f32 [ (m / (1.0 - neutral)) * rad * nose_gain / d ]
                    pf[0] = pf[0] + dx * s
                    pf[1] = pf[1] + dy * s
                    pf[2] = pf[2] + dz * s
                puts 'hyperspace2: baked nose on prim verts={vc} rad={rad}'

    # fit the nose to measured landmarks: lateral width at the nostril and mid
    # bands, a depth profile (top/mid/tip) out from the eye plane, and nostril
    # height. per-vertex bake over the painted _V_NOSE region; each vert's
    # height picks its band. defaults equal the model's rest so no-op until set.
    func bake_nose_landmarks []
        if [ !gmodel ] return
        neutral : f32 [ 0.216 ]
        # eye-plane height (y) datum, from the eye bone
        epy : f32 [ 1.622 ]
        for [ nd: Node ] in gmodel.nodes
            if [ nd.name && nd.name == 'Eye.L' ]
                wl : mat4f [ nd.world ]
                epy = wl.m[13]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                pos_ai  : i32 [ -1 ]
                nose_ai : i32 [ -1 ]
                for [ value: ref i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai  = i32[ value[0] ]
                    if [ a_name == '_V_NOSE'  ] nose_ai = i32[ value[0] ]
                if [ pos_ai  < 0 ] continue
                if [ nose_ai < 0 ] continue
                pac : gmodel.accessors[ pos_ai ]
                nac : gmodel.accessors[ nose_ai ]
                pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
                nbv : gmodel.bufferViews[ i32[ nac.bufferView ] ]
                pbb : gmodel.buffers[ i32[ pbv.buffer ] ]
                nbb : gmodel.buffers[ i32[ nbv.buffer ] ]
                pbase : ref i8 [ pbb.data ]
                nbase : ref i8 [ nbb.data ]
                pstride : i64 [ pac.stride ]
                nstride : i64 [ nac.stride ]
                if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
                if [ nbv.byteStride > 0 ] nstride = nbv.byteStride
                poff : i64 [ pbv.byteOffset + pac.byteOffset ]
                noff : i64 [ nbv.byteOffset + nac.byteOffset ]
                vc : i32 [ i32[ pac.count ] ]
                # pass 1: nose y-range
                ny0 : f32 [  1000000.0 ]
                ny1 : f32 [ -1000000.0 ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : ref u16 [ ((ref nbase[ noff + i64[ i ] * nstride ]) to ref u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    pf : ref f32 [ ((ref pbase[ poff + i64[ i ] * pstride ]) to ref f32) ]
                    if [ pf[1] < ny0 ] ny0 = pf[1]
                    if [ pf[1] > ny1 ] ny1 = pf[1]
                if [ ny1 <= ny0 ] continue
                yspan : f32 [ ny1 - ny0 ]
                # pass 2: rest half-width (max |x|) at the nostril and mid bands
                hw0 : f32 [ 0.0 ]
                hw1 : f32 [ 0.0 ]
                cn0 : i32 [ 0 ]
                cn1 : i32 [ 0 ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : ref u16 [ ((ref nbase[ noff + i64[ i ] * nstride ]) to ref u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    pf : ref f32 [ ((ref pbase[ poff + i64[ i ] * pstride ]) to ref f32) ]
                    t  : f32 [ (pf[1] - ny0) / yspan ]
                    ax : f32 [ (pf[0] < 0.0) ? (0.0 - pf[0]) : pf[0] ]
                    if [ t < 0.333 ]
                        if [ ax > hw0 ] hw0 = ax
                        cn0 += 1
                    el [ t < 0.667 ]
                        if [ ax > hw1 ] hw1 = ax
                        cn1 += 1
                if [ cn0 == 0 || cn1 == 0 ] continue
                # target/rest width ratios at nostril (t=0) and mid (t=0.5)
                ns : f32 [ 1.0 ]
                ms : f32 [ 1.0 ]
                if [ hw0 > 0.0 ] ns = (nostril_span / 1000.0) / (2.0 * hw0)
                if [ hw1 > 0.0 ] ms = (mid_nose / 1000.0) / (2.0 * hw1)
                # nostril target y = the person's eye-to-nostril distance
                nyt : f32 [ epy - nostril_y / 1000.0 ]
                dy_full : f32 [ nyt - ny0 ]
                # pass 3: apply
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : ref u16 [ ((ref nbase[ noff + i64[ i ] * nstride ]) to ref u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    w  : f32 [ m / (1.0 - neutral) ]
                    if [ w > 1.0 ] w = 1.0
                    pf : ref f32 [ ((ref pbase[ poff + i64[ i ] * pstride ]) to ref f32) ]
                    t  : f32 [ (pf[1] - ny0) / yspan ]
                    if [ t < 0.0 ] t = 0.0
                    if [ t > 1.0 ] t = 1.0
                    # lateral width: nostril -> mid -> unchanged at the root
                    ws : f32 [ 1.0 ]
                    if [ t < 0.5 ]
                        ws = ns + (ms - ns) * (t / 0.5)
                    el
                        ws = ms + (1.0 - ms) * ((t - 0.5) / 0.5)
                    pf[0] = pf[0] * (1.0 + w * (ws - 1.0))
                    # nostril height: shift the lower band in y, taper out by mid
                    yw : f32 [ 1.0 - t / 0.5 ]
                    if [ yw < 0.0 ] yw = 0.0
                    pf[1] = pf[1] + w * yw * dy_full
                puts 'hyperspace2: nose fit hw0={hw0} hw1={hw1} nostril dy={dy_full}'

    # 1-to-4 loop split: every triangle -> 4 via edge-midpoint verts, each
    # attribute the average of the two endpoints. runs last (after morph +
    # _V_* bake) so it only carries render/skin streams, not morphs/masks.
    func subdivide []
        if [ !subdiv_on ] return
        if [ !gmodel ] return
        for [ lv: i32 0, lv < subdiv_levels, lv += 1 ]
            for [ msh: Mesh ] in gmodel.meshes
                for [ prim: Primitive ] in msh.primitives
                    midx : i32 [ prim.material ]
                    mnm : string [ '' ]
                    if [ gmodel.materials && gmodel.materials.count > midx ]
                        mnm = gmodel.materials[ midx ].name
                    # only the body needs our subdivision; eyes/teeth/tongue
                    # carry blender modifiers baked in (skip to avoid a freeze)
                    keep : bool [ (mnm == 'Head') || (mnm == 'Body') ]
                    if [ !keep ] continue
                    puts 'subdiv L{lv}: {msh.name} mat={mnm} -> subdividing'
                    subdivide_prim[ prim ]

    func subdivide_prim [ prim: Primitive ]
        pos_i : i32 [ -1 ]
        nrm_i : i32 [ -1 ]
        uv_i  : i32 [ -1 ]
        uv1_i : i32 [ -1 ]
        tan_i : i32 [ -1 ]
        jnt_i : i32 [ -1 ]
        wgt_i : i32 [ -1 ]
        for [ value: ref i64, a_name: string ] in prim.attributes
            if [ a_name == 'POSITION'   ] pos_i = i32[ value[0] ]
            if [ a_name == 'NORMAL'     ] nrm_i = i32[ value[0] ]
            if [ a_name == 'TEXCOORD_0' ] uv_i  = i32[ value[0] ]
            if [ a_name == 'TEXCOORD_1' ] uv1_i = i32[ value[0] ]
            if [ a_name == 'TANGENT'    ] tan_i = i32[ value[0] ]
            if [ a_name == 'JOINTS_0'   ] jnt_i = i32[ value[0] ]
            if [ a_name == 'WEIGHTS_0'  ] wgt_i = i32[ value[0] ]
        puts 'subdiv_prim: pos={pos_i} nrm={nrm_i} uv={uv_i} uv1={uv1_i} tan={tan_i} jnt={jnt_i} wgt={wgt_i}'
        if [ pos_i < 0 ] return
        if [ nrm_i < 0 ] return
        if [ uv_i  < 0 ] return
        if [ tan_i < 0 ] return
        # uv1 and skin are optional (the eye prims have neither); dummy their
        # accessor to POSITION so lookups are valid, and gate all use on the flag
        has_uv1  : bool [ uv1_i >= 0 ]
        has_skin : bool [ (jnt_i >= 0) && (wgt_i >= 0) ]
        u1_use : i32 [ uv1_i ]
        j_use  : i32 [ jnt_i ]
        w_use  : i32 [ wgt_i ]
        if [ !has_uv1 ] u1_use = pos_i
        if [ !has_skin ] j_use = pos_i
        if [ !has_skin ] w_use = pos_i
        pac : gmodel.accessors[ pos_i ]
        nac : gmodel.accessors[ nrm_i ]
        uac : gmodel.accessors[ uv_i  ]
        u1ac: gmodel.accessors[ u1_use ]
        tac : gmodel.accessors[ tan_i ]
        jac : gmodel.accessors[ j_use ]
        wac : gmodel.accessors[ w_use ]
        iac : gmodel.accessors[ i32[ prim.indices ] ]
        pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
        nbv : gmodel.bufferViews[ i32[ nac.bufferView ] ]
        ubv : gmodel.bufferViews[ i32[ uac.bufferView ] ]
        u1bv: gmodel.bufferViews[ i32[ u1ac.bufferView ] ]
        tbv : gmodel.bufferViews[ i32[ tac.bufferView ] ]
        jbv : gmodel.bufferViews[ i32[ jac.bufferView ] ]
        wbv : gmodel.bufferViews[ i32[ wac.bufferView ] ]
        ibv : gmodel.bufferViews[ i32[ iac.bufferView ] ]
        pbase : ref i8 [ gmodel.buffers[ i32[ pbv.buffer ] ].data ]
        nbase : ref i8 [ gmodel.buffers[ i32[ nbv.buffer ] ].data ]
        ubase : ref i8 [ gmodel.buffers[ i32[ ubv.buffer ] ].data ]
        u1base: ref i8 [ gmodel.buffers[ i32[ u1bv.buffer ] ].data ]
        tbase : ref i8 [ gmodel.buffers[ i32[ tbv.buffer ] ].data ]
        jbase : ref i8 [ gmodel.buffers[ i32[ jbv.buffer ] ].data ]
        wbase : ref i8 [ gmodel.buffers[ i32[ wbv.buffer ] ].data ]
        ibase : ref i8 [ gmodel.buffers[ i32[ ibv.buffer ] ].data ]
        poff : i64 [ pbv.byteOffset + pac.byteOffset ]
        noff : i64 [ nbv.byteOffset + nac.byteOffset ]
        uoff : i64 [ ubv.byteOffset + uac.byteOffset ]
        u1off: i64 [ u1bv.byteOffset + u1ac.byteOffset ]
        toff : i64 [ tbv.byteOffset + tac.byteOffset ]
        joff : i64 [ jbv.byteOffset + jac.byteOffset ]
        woff : i64 [ wbv.byteOffset + wac.byteOffset ]
        ioff : i64 [ ibv.byteOffset + iac.byteOffset ]
        pstride : i64 [ pac.stride ]
        nstride : i64 [ nac.stride ]
        ustride : i64 [ uac.stride ]
        u1stride: i64 [ u1ac.stride ]
        tstride : i64 [ tac.stride ]
        jstride : i64 [ jac.stride ]
        wstride : i64 [ wac.stride ]
        istride : i64 [ iac.stride ]
        if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
        if [ nbv.byteStride > 0 ] nstride = nbv.byteStride
        if [ ubv.byteStride > 0 ] ustride = ubv.byteStride
        if [ u1bv.byteStride > 0 ] u1stride = u1bv.byteStride
        if [ tbv.byteStride > 0 ] tstride = tbv.byteStride
        if [ jbv.byteStride > 0 ] jstride = jbv.byteStride
        if [ wbv.byteStride > 0 ] wstride = wbv.byteStride
        if [ ibv.byteStride > 0 ] istride = ibv.byteStride
        nv : i32 [ i32[ pac.count ] ]
        tc : i32 [ i32[ iac.count ] / 3 ]
        ne : i32 [ tc * 3 ]
        ov : i32 [ tc * 7 ]
        ot : i32 [ tc * 6 ]
        puts 'subdiv_prim: in_verts={nv} in_tris={tc} -> out_verts={ov} out_tris={ot}'
        r_nrm : i32 [ ov * 12 ]
        r_uv  : i32 [ ov * 24 ]
        r_uv1 : i32 [ ov * 32 ]
        r_tan : i32 [ ov * 40 ]
        r_jnt : i32 [ ov * 56 ]
        r_wgt : i32 [ ov * 60 ]
        r_idx : i32 [ ov * 76 ]
        total : i32 [ ov * 76 + ot * 12 ]
        nbuf : GltfBuffer [ ]
        nbuf.data = new u8 [ total ]
        nbuf.byteLength = total
        nbuf.hold[]
        bidx : i32 [ i32[ gmodel.buffers.count ] ]
        gmodel.buffers += nbuf
        ndata : ref i8 [ nbuf.data ]
        opos : ref f32 [ ((ref ndata[ 0     ]) to ref f32) ]
        onrm : ref f32 [ ((ref ndata[ r_nrm ]) to ref f32) ]
        ouv  : ref f32 [ ((ref ndata[ r_uv  ]) to ref f32) ]
        ouv1 : ref f32 [ ((ref ndata[ r_uv1 ]) to ref f32) ]
        otan : ref f32 [ ((ref ndata[ r_tan ]) to ref f32) ]
        ojnt : ref u8  [ ((ref ndata[ r_jnt ]) to ref u8 ) ]
        owgt : ref f32 [ ((ref ndata[ r_wgt ]) to ref f32) ]
        oidx : ref u32 [ ((ref ndata[ r_idx ]) to ref u32) ]
        # Catmull-Clark on the recovered quads, welded by position (no seam crease)
        nf    : i32 [ tc / 2 ]
        ne4   : i32 [ nf * 4 ]
        ncpx  : i32 [ nv + ne4 + nf ]
        topo  : new i32 [ nv ]
        tpx   : new f32 [ nv ]
        tpy   : new f32 [ nv ]
        tpz   : new f32 [ nv ]
        accfx : new f32 [ nv ]
        accfy : new f32 [ nv ]
        accfz : new f32 [ nv ]
        accfn : new i32 [ nv ]
        accex : new f32 [ nv ]
        accey : new f32 [ nv ]
        accez : new f32 [ nv ]
        accen : new i32 [ nv ]
        bmx   : new f32 [ nv ]
        bmy   : new f32 [ nv ]
        bmz   : new f32 [ nv ]
        bcn   : new i32 [ nv ]
        npx   : new f32 [ nv ]
        npy   : new f32 [ nv ]
        npz   : new f32 [ nv ]
        fc0   : new i32 [ nf ]
        fc1   : new i32 [ nf ]
        fc2   : new i32 [ nf ]
        fc3   : new i32 [ nf ]
        fi0   : new i32 [ nf ]
        fi1   : new i32 [ nf ]
        fi2   : new i32 [ nf ]
        fi3   : new i32 [ nf ]
        fpx   : new f32 [ nf ]
        fpy   : new f32 [ nf ]
        fpz   : new f32 [ nf ]
        fe_u  : new i32 [ ne4 ]
        fe_v  : new i32 [ ne4 ]
        fe_f0 : new i32 [ ne4 ]
        fe_f1 : new i32 [ ne4 ]
        fe_fn : new i32 [ ne4 ]
        epx   : new f32 [ ne4 ]
        epy   : new f32 [ ne4 ]
        epz   : new f32 [ ne4 ]
        face_e: new i32 [ ne4 ]
        cpx   : new f32 [ ncpx ]
        cpy   : new f32 [ ncpx ]
        cpz   : new f32 [ ncpx ]
        nccx  : new f32 [ ncpx ]
        nccy  : new f32 [ ncpx ]
        nccz  : new f32 [ ncpx ]
        fcv   : new i32 [ 4 ]
        fiv   : new i32 [ 4 ]
        sc    : new i32 [ 4 ]
        mj    : new i32 [ 16 ]
        mw    : new f32 [ 16 ]
        # read the index buffer once, at its real width (u16 base, u32 re-subdiv)
        idxbuf : new i32 [ tc * 3 ]
        iu16 : bool [ iac.componentType == ComponentType.UNSIGNED_SHORT ]
        for [ ii: i32 0, ii < tc * 3, ii += 1 ]
            if [ iu16 ]
                pr16 : ref u16 [ ((ref ibase[ ioff + i64[ ii ] * istride ]) to ref u16) ]
                idxbuf[ ii ] = i32[ pr16[0] ]
            el
                pr32 : ref u32 [ ((ref ibase[ ioff + i64[ ii ] * istride ]) to ref u32) ]
                idxbuf[ ii ] = i32[ pr32[0] ]
        # pass 1: weld input verts to topo ids by quantized position
        wmap : map i32 [ string ] [ ]
        tv : i32 [ 0 ]
        for [ v: i32 0, v < nv, v += 1 ]
            p : ref f32 [ ((ref pbase[ poff + i64[ v ] * pstride ]) to ref f32) ]
            qx : i64 [ i64[ round[ p[0] * 100000.0 ] ] ]
            qy : i64 [ i64[ round[ p[1] * 100000.0 ] ] ]
            qz : i64 [ i64[ round[ p[2] * 100000.0 ] ] ]
            key : '{qx}_{qy}_{qz}'
            if [ wmap.contains[ key ] ]
                topo[ v ] = wmap[ key ]
            el
                topo[ v ] = tv
                tpx[ tv ] = p[0]
                tpy[ tv ] = p[1]
                tpz[ tv ] = p[2]
                accfx[ tv ] = 0.0
                accfy[ tv ] = 0.0
                accfz[ tv ] = 0.0
                accfn[ tv ] = 0
                accex[ tv ] = 0.0
                accey[ tv ] = 0.0
                accez[ tv ] = 0.0
                accen[ tv ] = 0
                bmx[ tv ] = 0.0
                bmy[ tv ] = 0.0
                bmz[ tv ] = 0.0
                bcn[ tv ] = 0
                wmap[ key ] = tv
                tv += 1
        # pass 2: pair consecutive triangles back into quads. every pair shares
        # one edge (the diagonal); the two unshared verts are opposite corners.
        # quad winding [ R, P, S, Q ]: R,P,Q keep triangle A's order, S = apex of B
        for [ pp: i32 0, pp < nf, pp += 1 ]
            ia0 : i32 [ idxbuf[ pp*6 + 0 ] ]
            ia1 : i32 [ idxbuf[ pp*6 + 1 ] ]
            ia2 : i32 [ idxbuf[ pp*6 + 2 ] ]
            ib0 : i32 [ idxbuf[ pp*6 + 3 ] ]
            ib1 : i32 [ idxbuf[ pp*6 + 4 ] ]
            ib2 : i32 [ idxbuf[ pp*6 + 5 ] ]
            a0in : bool [ (ia0 == ib0) || (ia0 == ib1) || (ia0 == ib2) ]
            a1in : bool [ (ia1 == ib0) || (ia1 == ib1) || (ia1 == ib2) ]
            ra : i32 [ ia2 ]
            rp : i32 [ ia0 ]
            rq : i32 [ ia1 ]
            if [ !a0in ]
                ra = ia0
                rp = ia1
                rq = ia2
            if [ !a1in ]
                ra = ia1
                rp = ia2
                rq = ia0
            b1in : bool [ (ib1 == ia0) || (ib1 == ia1) || (ib1 == ia2) ]
            b2in : bool [ (ib2 == ia0) || (ib2 == ia1) || (ib2 == ia2) ]
            sv : i32 [ ib0 ]
            if [ !b1in ] sv = ib1
            if [ !b2in ] sv = ib2
            fi0[ pp ] = ra
            fi1[ pp ] = rp
            fi2[ pp ] = sv
            fi3[ pp ] = rq
            fc0[ pp ] = topo[ ra ]
            fc1[ pp ] = topo[ rp ]
            fc2[ pp ] = topo[ sv ]
            fc3[ pp ] = topo[ rq ]
        # pass 3: face points + per-vertex face-point accumulation
        for [ f: i32 0, f < nf, f += 1 ]
            A : i32 [ fc0[f] ]
            B : i32 [ fc1[f] ]
            C : i32 [ fc2[f] ]
            D : i32 [ fc3[f] ]
            fxx : f32 [ (tpx[A] + tpx[B] + tpx[C] + tpx[D]) * 0.25 ]
            fyy : f32 [ (tpy[A] + tpy[B] + tpy[C] + tpy[D]) * 0.25 ]
            fzz : f32 [ (tpz[A] + tpz[B] + tpz[C] + tpz[D]) * 0.25 ]
            fpx[ f ] = fxx
            fpy[ f ] = fyy
            fpz[ f ] = fzz
            accfx[A] += fxx
            accfy[A] += fyy
            accfz[A] += fzz
            accfn[A] += 1
            accfx[B] += fxx
            accfy[B] += fyy
            accfz[B] += fzz
            accfn[B] += 1
            accfx[C] += fxx
            accfy[C] += fyy
            accfz[C] += fzz
            accfn[C] += 1
            accfx[D] += fxx
            accfy[D] += fyy
            accfz[D] += fzz
            accfn[D] += 1
        # pass 4: unique quad edges with adjacent faces
        femap : map i32 [ string ] [ ]
        nedge2 : i32 [ 0 ]
        for [ f: i32 0, f < nf, f += 1 ]
            fcv[0] = fc0[f]
            fcv[1] = fc1[f]
            fcv[2] = fc2[f]
            fcv[3] = fc3[f]
            for [ e: i32 0, e < 4, e += 1 ]
                en : i32 [ e + 1 ]
                if [ en >= 4 ] en = 0
                u : i32 [ fcv[e] ]
                w : i32 [ fcv[en] ]
                lo : i32 [ u ]
                hi : i32 [ w ]
                if [ u > w ]
                    lo = w
                    hi = u
                key : '{lo}_{hi}'
                eid : i32 [ 0 ]
                if [ femap.contains[ key ] ]
                    eid = femap[ key ]
                    fe_f1[ eid ] = f
                    fe_fn[ eid ] += 1
                el
                    eid = nedge2
                    femap[ key ] = eid
                    fe_u[ eid ] = lo
                    fe_v[ eid ] = hi
                    fe_f0[ eid ] = f
                    fe_f1[ eid ] = f
                    fe_fn[ eid ] = 1
                    nedge2 += 1
                face_e[ f*4 + e ] = eid
        # pass 5: edge points + per-vertex edge-midpoint accumulation
        for [ eid: i32 0, eid < nedge2, eid += 1 ]
            u : i32 [ fe_u[ eid ] ]
            w : i32 [ fe_v[ eid ] ]
            mx : f32 [ (tpx[u] + tpx[w]) * 0.5 ]
            my : f32 [ (tpy[u] + tpy[w]) * 0.5 ]
            mz : f32 [ (tpz[u] + tpz[w]) * 0.5 ]
            accex[u] += mx
            accey[u] += my
            accez[u] += mz
            accen[u] += 1
            accex[w] += mx
            accey[w] += my
            accez[w] += mz
            accen[w] += 1
            if [ fe_fn[ eid ] >= 2 ]
                f0 : i32 [ fe_f0[ eid ] ]
                f1 : i32 [ fe_f1[ eid ] ]
                epx[ eid ] = (tpx[u] + tpx[w] + fpx[f0] + fpx[f1]) * 0.25
                epy[ eid ] = (tpy[u] + tpy[w] + fpy[f0] + fpy[f1]) * 0.25
                epz[ eid ] = (tpz[u] + tpz[w] + fpz[f0] + fpz[f1]) * 0.25
            el
                epx[ eid ] = mx
                epy[ eid ] = my
                epz[ eid ] = mz
                bmx[u] += mx
                bmy[u] += my
                bmz[u] += mz
                bcn[u] += 1
                bmx[w] += mx
                bmy[w] += my
                bmz[w] += mz
                bcn[w] += 1
        # pass 5: updated original-vertex positions
        for [ t: i32 0, t < tv, t += 1 ]
            if [ bcn[t] == 2 ]
                npx[t] = tpx[t] * 0.5 + bmx[t] * 0.25
                npy[t] = tpy[t] * 0.5 + bmy[t] * 0.25
                npz[t] = tpz[t] * 0.5 + bmz[t] * 0.25
            el [ bcn[t] > 0 ]
                npx[t] = tpx[t]
                npy[t] = tpy[t]
                npz[t] = tpz[t]
            el [ accen[t] < 3 ]
                npx[t] = tpx[t]
                npy[t] = tpy[t]
                npz[t] = tpz[t]
            el
                nf : f32 [ f32[ accen[t] ] ]
                fdx : f32 [ accfx[t] / f32[ accfn[t] ] ]
                fdy : f32 [ accfy[t] / f32[ accfn[t] ] ]
                fdz : f32 [ accfz[t] / f32[ accfn[t] ] ]
                rdx : f32 [ accex[t] / nf ]
                rdy : f32 [ accey[t] / nf ]
                rdz : f32 [ accez[t] / nf ]
                npx[t] = (fdx + 2.0 * rdx + (nf - 3.0) * tpx[t]) / nf
                npy[t] = (fdy + 2.0 * rdy + (nf - 3.0) * tpy[t]) / nf
                npz[t] = (fdz + 2.0 * rdz + (nf - 3.0) * tpz[t]) / nf
        # pass 7: unified Catmull-Clark point positions (vertex, edge, face) then
        # smooth normals -- accumulate each output triangle's normal into its points
        for [ t: i32 0, t < tv, t += 1 ]
            cpx[ t ] = npx[ t ]
            cpy[ t ] = npy[ t ]
            cpz[ t ] = npz[ t ]
        for [ eid: i32 0, eid < nedge2, eid += 1 ]
            be : i32 [ tv + eid ]
            cpx[ be ] = epx[ eid ]
            cpy[ be ] = epy[ eid ]
            cpz[ be ] = epz[ eid ]
        for [ f: i32 0, f < nf, f += 1 ]
            bf : i32 [ tv + nedge2 + f ]
            cpx[ bf ] = fpx[ f ]
            cpy[ bf ] = fpy[ f ]
            cpz[ bf ] = fpz[ f ]
        for [ q: i32 0, q < ncpx, q += 1 ]
            nccx[ q ] = 0.0
            nccy[ q ] = 0.0
            nccz[ q ] = 0.0
        for [ f: i32 0, f < nf, f += 1 ]
            fcv[0] = fc0[f]
            fcv[1] = fc1[f]
            fcv[2] = fc2[f]
            fcv[3] = fc3[f]
            gfp : i32 [ tv + nedge2 + f ]
            fx : f32 [ cpx[gfp] ]
            fy : f32 [ cpy[gfp] ]
            fz : f32 [ cpz[gfp] ]
            for [ i: i32 0, i < 4, i += 1 ]
                ip : i32 [ i - 1 ]
                if [ ip < 0 ] ip = 3
                gvp : i32 [ fcv[i] ]
                een : i32 [ face_e[ f*4 + i ] ]
                eep : i32 [ face_e[ f*4 + ip ] ]
                gen : i32 [ tv + een ]
                gep : i32 [ tv + eep ]
                vpx : f32 [ cpx[gvp] ]
                vpy : f32 [ cpy[gvp] ]
                vpz : f32 [ cpz[gvp] ]
                enx : f32 [ cpx[gen] ]
                eny : f32 [ cpy[gen] ]
                enz : f32 [ cpz[gen] ]
                qpx : f32 [ cpx[gep] ]
                qpy : f32 [ cpy[gep] ]
                qpz : f32 [ cpz[gep] ]
                a1x : f32 [ (eny - vpy) * (fz - vpz) - (enz - vpz) * (fy - vpy) ]
                a1y : f32 [ (enz - vpz) * (fx - vpx) - (enx - vpx) * (fz - vpz) ]
                a1z : f32 [ (enx - vpx) * (fy - vpy) - (eny - vpy) * (fx - vpx) ]
                nccx[gvp] += a1x
                nccy[gvp] += a1y
                nccz[gvp] += a1z
                nccx[gen] += a1x
                nccy[gen] += a1y
                nccz[gen] += a1z
                nccx[gfp] += a1x
                nccy[gfp] += a1y
                nccz[gfp] += a1z
                a2x : f32 [ (fy - vpy) * (qpz - vpz) - (fz - vpz) * (qpy - vpy) ]
                a2y : f32 [ (fz - vpz) * (qpx - vpx) - (fx - vpx) * (qpz - vpz) ]
                a2z : f32 [ (fx - vpx) * (qpy - vpy) - (fy - vpy) * (qpx - vpx) ]
                nccx[gvp] += a2x
                nccy[gvp] += a2y
                nccz[gvp] += a2z
                nccx[gfp] += a2x
                nccy[gfp] += a2y
                nccz[gfp] += a2z
                nccx[gep] += a2x
                nccy[gep] += a2y
                nccz[gep] += a2z
        # pass 8: emit 9 verts + 8 tris per quad face (4 corners, 4 edge points,
        # 1 face point). positions/normals from the CC point arrays; uv/tan/skin
        # averaged from the source corners so seams stay per-corner
        for [ f: i32 0, f < nf, f += 1 ]
            fcv[0] = fc0[f]
            fcv[1] = fc1[f]
            fcv[2] = fc2[f]
            fcv[3] = fc3[f]
            fiv[0] = fi0[f]
            fiv[1] = fi1[f]
            fiv[2] = fi2[f]
            fiv[3] = fi3[f]
            ob : i32 [ f * 9 ]
            gfp : i32 [ tv + nedge2 + f ]
            for [ s: i32 0, s < 9, s += 1 ]
                ovi : i32 [ ob + s ]
                o3 : i32 [ ovi * 3 ]
                o2 : i32 [ ovi * 2 ]
                o4 : i32 [ ovi * 4 ]
                nci : i32 [ gfp ]
                scn : i32 [ 1 ]
                sc[0] = fiv[0]
                if [ s < 4 ]
                    nci = fcv[ s ]
                    scn = 1
                    sc[0] = fiv[ s ]
                el [ s < 8 ]
                    ei : i32 [ s - 4 ]
                    en : i32 [ ei + 1 ]
                    if [ en >= 4 ] en = 0
                    nci = tv + face_e[ f*4 + ei ]
                    scn = 2
                    sc[0] = fiv[ ei ]
                    sc[1] = fiv[ en ]
                el
                    nci = gfp
                    scn = 4
                    sc[0] = fiv[0]
                    sc[1] = fiv[1]
                    sc[2] = fiv[2]
                    sc[3] = fiv[3]
                opos[ o3 + 0 ] = cpx[ nci ]
                opos[ o3 + 1 ] = cpy[ nci ]
                opos[ o3 + 2 ] = cpz[ nci ]
                uvx : f32 [ 0.0 ]
                uvy : f32 [ 0.0 ]
                u1x : f32 [ 0.0 ]
                u1y : f32 [ 0.0 ]
                tx : f32 [ 0.0 ]
                ty : f32 [ 0.0 ]
                tz : f32 [ 0.0 ]
                tw : f32 [ 0.0 ]
                mc : i32 [ 0 ]
                for [ ci: i32 0, ci < scn, ci += 1 ]
                    cv : i32 [ sc[ci] ]
                    uu : ref f32 [ ((ref ubase[ uoff + i64[ cv ] * ustride ]) to ref f32) ]
                    u1 : ref f32 [ ((ref u1base[ u1off + i64[ cv ] * u1stride ]) to ref f32) ]
                    tt : ref f32 [ ((ref tbase[ toff + i64[ cv ] * tstride ]) to ref f32) ]
                    jc : ref u8 [ ((ref jbase[ joff + i64[ cv ] * jstride ]) to ref u8) ]
                    wc : ref f32 [ ((ref wbase[ woff + i64[ cv ] * wstride ]) to ref f32) ]
                    uvx += uu[0]
                    uvy += uu[1]
                    u1x += u1[0]
                    u1y += u1[1]
                    tx += tt[0]
                    ty += tt[1]
                    tz += tt[2]
                    tw += tt[3]
                    if [ has_skin ]
                        for [ k: i32 0, k < 4, k += 1 ]
                            jw : f32 [ wc[k] ]
                            if [ jw <= 0.0 ] continue
                            ji : i32 [ i32[ jc[k] ] ]
                            found : bool [ false ]
                            for [ m: i32 0, m < mc, m += 1 ]
                                if [ mj[m] == ji ]
                                    mw[m] += jw
                                    found = true
                            if [ !found ]
                                mj[mc] = ji
                                mw[mc] = jw
                                mc += 1
                invn : f32 [ 1.0 / f32[ scn ] ]
                gx : f32 [ nccx[ nci ] ]
                gy : f32 [ nccy[ nci ] ]
                gz : f32 [ nccz[ nci ] ]
                nl : f32 [ sqrt[ gx*gx + gy*gy + gz*gz ] ]
                if [ nl <= 0.0 ] nl = 1.0
                onrm[ o3 + 0 ] = gx / nl
                onrm[ o3 + 1 ] = gy / nl
                onrm[ o3 + 2 ] = gz / nl
                ouv[ o2 + 0 ] = uvx * invn
                ouv[ o2 + 1 ] = uvy * invn
                ouv1[ o2 + 0 ] = u1x * invn
                ouv1[ o2 + 1 ] = u1y * invn
                otan[ o4 + 0 ] = tx * invn
                otan[ o4 + 1 ] = ty * invn
                otan[ o4 + 2 ] = tz * invn
                otan[ o4 + 3 ] = tw * invn
                for [ o: i32 0, o < 4, o += 1 ]
                    best : i32 [ -1 ]
                    bw : f32 [ 0.0 ]
                    for [ m: i32 0, m < mc, m += 1 ]
                        if [ mw[m] > bw ]
                            bw = mw[m]
                            best = m
                    if [ best < 0 ]
                        ojnt[ o4 + o ] = 0
                        owgt[ o4 + o ] = 0.0
                    el
                        ojnt[ o4 + o ] = u8[ mj[best] ]
                        owgt[ o4 + o ] = mw[best]
                        mw[best] = -1.0
                wsum : f32 [ owgt[ o4 + 0 ] + owgt[ o4 + 1 ] + owgt[ o4 + 2 ] + owgt[ o4 + 3 ] ]
                if [ wsum > 0.0 ]
                    owgt[ o4 + 0 ] = owgt[ o4 + 0 ] / wsum
                    owgt[ o4 + 1 ] = owgt[ o4 + 1 ] / wsum
                    owgt[ o4 + 2 ] = owgt[ o4 + 2 ] / wsum
                    owgt[ o4 + 3 ] = owgt[ o4 + 3 ] / wsum
            # 4 sub-quads per face, each split into 2 triangles
            oi : i32 [ f * 24 ]
            for [ qi: i32 0, qi < 4, qi += 1 ]
                ip : i32 [ qi - 1 ]
                if [ ip < 0 ] ip = 3
                lvp : i32 [ ob + qi ]
                lne : i32 [ ob + 4 + qi ]
                lfp : i32 [ ob + 8 ]
                lpe : i32 [ ob + 4 + ip ]
                oq : i32 [ oi + qi * 6 ]
                oidx[ oq + 0 ] = u32[ lvp ]
                oidx[ oq + 1 ] = u32[ lne ]
                oidx[ oq + 2 ] = u32[ lfp ]
                oidx[ oq + 3 ] = u32[ lvp ]
                oidx[ oq + 4 ] = u32[ lfp ]
                oidx[ oq + 5 ] = u32[ lpe ]
        ovc : i32 [ nf * 9 ]
        otc : i32 [ nf * 8 ]
        pbv.buffer = bidx
        pbv.byteOffset = 0
        pbv.byteLength = ovc * 12
        pbv.byteStride = 0
        pac.byteOffset = 0
        pac.count = ovc
        pac.init[]
        nbv.buffer = bidx
        nbv.byteOffset = r_nrm
        nbv.byteLength = ovc * 12
        nbv.byteStride = 0
        nac.byteOffset = 0
        nac.count = ovc
        nac.init[]
        ubv.buffer = bidx
        ubv.byteOffset = r_uv
        ubv.byteLength = ovc * 8
        ubv.byteStride = 0
        uac.byteOffset = 0
        uac.count = ovc
        uac.init[]
        if [ has_uv1 ]
            u1bv.buffer = bidx
            u1bv.byteOffset = r_uv1
            u1bv.byteLength = ovc * 8
            u1bv.byteStride = 0
            u1ac.byteOffset = 0
            u1ac.count = ovc
            u1ac.init[]
        tbv.buffer = bidx
        tbv.byteOffset = r_tan
        tbv.byteLength = ovc * 16
        tbv.byteStride = 0
        tac.byteOffset = 0
        tac.count = ovc
        tac.init[]
        if [ has_skin ]
            jbv.buffer = bidx
            jbv.byteOffset = r_jnt
            jbv.byteLength = ovc * 4
            jbv.byteStride = 0
            jac.byteOffset = 0
            jac.count = ovc
            jac.init[]
            wbv.buffer = bidx
            wbv.byteOffset = r_wgt
            wbv.byteLength = ovc * 16
            wbv.byteStride = 0
            wac.byteOffset = 0
            wac.count = ovc
            wac.init[]
        # mirrored L/R prims SHARE one index accessor -- mutating it in place
        # corrupts the sibling. build a fresh index accessor + view per prim.
        nibv_i : i32 [ i32[ gmodel.bufferViews.count ] ]
        nibv : BufferView [ buffer: bidx, byteOffset: r_idx, byteLength: otc * 12, byteStride: 0 ]
        gmodel.bufferViews += nibv
        prim.indices = i32[ gmodel.accessors.count ]
        niac : Accessor [ bufferView: nibv_i, componentType: ComponentType.UNSIGNED_INT, type: CompoundType.SCALAR, byteOffset: 0, count: otc * 3 ]
        gmodel.accessors += niac
        puts 'hyperspace2: subdivided quads {nf} -> {otc} tris ({ovc} verts)'

    # read the skin: inverse-bind matrices + which joint node is the hinge, and
    # allocate the joint-matrix palette storage buffer (one mat4 per joint)
    func setup_skin []
        if [ !gmodel.skins || gmodel.skins.count == 0 ] return
        skin_idx = 0
        sk : gmodel.skins[ 0 ]
        nj : i32 [ i32[ sk.joints.count ] ]
        iba : gmodel.accessors[ sk.inverseBindMatrices ]
        ibv : gmodel.bufferViews[ i32[ iba.bufferView ] ]
        ibb : gmodel.buffers[ i32[ ibv.buffer ] ]
        base : ref i8 [ ibb.data ]
        src  : ref f32 [ ((ref base[ ibv.byteOffset + iba.byteOffset ]) to ref f32) ]
        ibm = array mat4f [ ]
        for [ j: i32 0, j < nj, j += 1 ]
            mm : mat4f [ mat4f.identity[] ]
            for [ k: i32 0, k < 16, k += 1 ]
                mm.m[ k ] = src[ j * 16 + k ]
            ibm.push[ mm ]
        for [ j: i32 0, j < nj, j += 1 ]
            jn : gmodel.nodes[ sk.joints[ j ] ]
            if [ jn.name && jn.name == 'Hinge' ] hinge_node = i32[ sk.joints[ j ] ]
        # locate the eye bones and remember their rest local rotation so gaze
        # is applied as a delta on top (node.rotation = gaze x rest)
        # find the eyeball aim bones and the lid-drag / caruncle follow bones
        ni : i32 [ 0 ]
        for [ nd: Node ] in gmodel.nodes
            if [ nd.name && nd.name == 'Eyeball.L' ]
                ebl = ni
                ebl_rest = nd.rotation
                gbl = ni
                gbl_rest = nd.translation
            if [ nd.name && nd.name == 'Eyeball.R' ]
                ebr = ni
                ebr_rest = nd.rotation
                gbr = ni
                gbr_rest = nd.translation
            if [ nd.name && nd.name == 'Eyelids Drag.L' ]
                dgl = ni
                dgl_rest = nd.rotation
            if [ nd.name && nd.name == 'Eyelids Drag.R' ]
                dgr = ni
                dgr_rest = nd.rotation
            if [ nd.name && nd.name == 'Caruncle.L' ]
                crl = ni
                crl_rest = nd.rotation
            if [ nd.name && nd.name == 'Caruncle.R' ]
                crr = ni
                crr_rest = nd.rotation
            ni += 1
        puts 'hyperspace2: ebl={ebl} ebr={ebr} dgl={dgl} dgr={dgr} crl={crl} crr={crr}'
        joint_buf = Buffer [ vk: vshader.vk, size: nj * 64,
            u_storage: true, m_host_visible: true, m_host_coherent: true ]
        joint_buf.hold[]
        puts 'hyperspace2: skin joints={nj} hinge_node={hinge_node}'

    # hamilton product r = a x b (quaternion compose)
    func qmul [ qa: quatf, qb: quatf ] -> quatf
        r : quatf
        r.w = qa.w * qb.w - qa.x * qb.x - qa.y * qb.y - qa.z * qb.z
        r.x = qa.w * qb.x + qa.x * qb.w + qa.y * qb.z - qa.z * qb.y
        r.y = qa.w * qb.y - qa.x * qb.z + qa.y * qb.w + qa.z * qb.x
        r.z = qa.w * qb.z + qa.x * qb.y - qa.y * qb.x + qa.z * qb.w
        return r

    # delta rotation from pitch about local X and yaw about local Z (the eyeball
    # local frame has +Y forward, so pitch=X and yaw=Z, per the DAMPED_TRACK)
    func delta_q [ ax: f32, az: f32 ] -> quatf
        qx : quatf [ x: sin[ ax * 0.5 ], y: 0.0, z: 0.0, w: cos[ ax * 0.5 ] ]
        qz : quatf [ x: 0.0, y: 0.0, z: sin[ az * 0.5 ], w: cos[ az * 0.5 ] ]
        return qmul[ qx, qz ]

    func set_bone [ idx: i32, rest: quatf, d: quatf ]
        if [ idx < 0 ] return
        nb : gmodel.nodes[ idx ]
        nb.rotation = qmul[ d, rest ]

    # aim eyeballs by gaze; drive lids by the rig's copy-rotation fractions
    # (Eyelids Drag: 0.8 pitch + 0.2 yaw, Caruncle: 0.8 pitch + 0.5 yaw)
    func aim_eyes []
        if [ ebl < 0 && ebr < 0 ] return
        eb : quatf [ delta_q[ gaze_y, gaze_x ] ]
        set_bone[ ebl, ebl_rest, eb ]
        set_bone[ ebr, ebr_rest, eb ]
        dg : quatf [ delta_q[ gaze_y * 0.8, gaze_x * 0.2 ] ]
        set_bone[ dgl, dgl_rest, dg ]
        set_bone[ dgr, dgr_rest, dg ]
        cr : quatf [ delta_q[ gaze_y * 0.8, gaze_x * 0.5 ] ]
        set_bone[ crl, crl_rest, cr ]
        set_bone[ crr, crr_rest, cr ]

    # nudge the eyeball globe bones outward so each eyeball follows the socket;
    # local-x maps to world -x on these bones, so subtract to move both apart
    func apply_spacing []
        if [ gbl >= 0 ]
            nl : gmodel.nodes[ gbl ]
            nl.translation = vec3f [ gbl_rest.x - eye_spacing, gbl_rest.y, gbl_rest.z ]
        if [ gbr >= 0 ]
            nr : gmodel.nodes[ gbr ]
            nr.translation = vec3f [ gbr_rest.x + eye_spacing, gbr_rest.y, gbr_rest.z ]

    # move the lid/socket skin to follow the eyeballs: one-time, at load. shift
    # each Head/Body vert along world x toward its nearest eye, by eye_spacing
    # with a smooth falloff to zero at rad. the eyelid verts (skinned to Eye.L/
    # Caruncle/Eyelids Drag) and the surrounding cheek move together -> no squeeze
    func bake_eye_spacing []
        if [ !gmodel ] return
        lcx : f32 [ 0.0 ]
        lcy : f32 [ 0.0 ]
        lcz : f32 [ 0.0 ]
        rcx : f32 [ 0.0 ]
        rcy : f32 [ 0.0 ]
        rcz : f32 [ 0.0 ]
        gotl : bool [ false ]
        gotr : bool [ false ]
        for [ nd: Node ] in gmodel.nodes
            if [ nd.name && nd.name == 'Eye.L' ]
                wl : mat4f [ nd.world ]
                lcx = wl.m[12]
                lcy = wl.m[13]
                lcz = wl.m[14]
                gotl = true
            if [ nd.name && nd.name == 'Eye.R' ]
                wr : mat4f [ nd.world ]
                rcx = wr.m[12]
                rcy = wr.m[13]
                rcz = wr.m[14]
                gotr = true
        if [ !gotl || !gotr ] return
        # the outer eye corner sits about one eyeball radius lateral to the eye
        # centre; measure the globe's x-extent to convert corner span to a shift
        eye_rad : f32 [ 0.0126 ]
        gxmin : f32 [  1000000.0 ]
        gxmax : f32 [ -1000000.0 ]
        gotrad : bool [ false ]
        for [ emsh: Mesh ] in gmodel.meshes
            for [ eprim: Primitive ] in emsh.primitives
                emidx : i32 [ eprim.material ]
                emnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > emidx ]
                    emnm = gmodel.materials[ emidx ].name
                if [ emnm != 'Eyeball' ] continue
                epos_ai : i32 [ -1 ]
                for [ value: ref i64, a_name: string ] in eprim.attributes
                    if [ a_name == 'POSITION' ] epos_ai = i32[ value[0] ]
                if [ epos_ai < 0 ] continue
                eac : gmodel.accessors[ epos_ai ]
                ebv : gmodel.bufferViews[ i32[ eac.bufferView ] ]
                ebb : gmodel.buffers[ i32[ ebv.buffer ] ]
                ebase : ref i8 [ ebb.data ]
                estride : i64 [ eac.stride ]
                if [ ebv.byteStride > 0 ] estride = ebv.byteStride
                eoff : i64 [ ebv.byteOffset + eac.byteOffset ]
                evc : i32 [ i32[ eac.count ] ]
                for [ i: i32 0, i < evc, i += 1 ]
                    ef : ref f32 [ ((ref ebase[ eoff + i64[ i ] * estride ]) to ref f32) ]
                    if [ ef[0] < gxmin ] gxmin = ef[0]
                    if [ ef[0] > gxmax ] gxmax = ef[0]
                    gotrad = true
        if [ gotrad ] eye_rad = (gxmax - gxmin) * 0.5
        # per-eye shift = half the gap between the target and the rest corner span
        dxc : f32 [ lcx - rcx ]
        rest_ipd : f32 [ (dxc < 0.0) ? (0.0 - dxc) : dxc ]
        rest_span : f32 [ rest_ipd + 2.0 * eye_rad ]
        eye_spacing = (span_mm / 1000.0 - rest_span) * 0.5
        puts 'hyperspace2: corner-span target={span_mm}mm rest={rest_span}m rad={eye_rad}m -> shift={eye_spacing}m'
        rad : f32 [ 0.055 ]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                mnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > midx ]
                    mnm = gmodel.materials[ midx ].name
                keep : bool [ (mnm == 'Head') || (mnm == 'Body') ]
                if [ !keep ] continue
                pos_ai : i32 [ -1 ]
                for [ value: ref i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai = i32[ value[0] ]
                if [ pos_ai < 0 ] continue
                pac : gmodel.accessors[ pos_ai ]
                pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
                pbb : gmodel.buffers[ i32[ pbv.buffer ] ]
                pbase : ref i8 [ pbb.data ]
                pstride : i64 [ pac.stride ]
                if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
                poff : i64 [ pbv.byteOffset + pac.byteOffset ]
                vc : i32 [ i32[ pac.count ] ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pf : ref f32 [ ((ref pbase[ poff + i64[ i ] * pstride ]) to ref f32) ]
                    dlx : f32 [ pf[0] - lcx ]
                    dly : f32 [ pf[1] - lcy ]
                    dlz : f32 [ pf[2] - lcz ]
                    drx : f32 [ pf[0] - rcx ]
                    dry : f32 [ pf[1] - rcy ]
                    drz : f32 [ pf[2] - rcz ]
                    dl : f32 [ sqrt[ dlx * dlx + dly * dly + dlz * dlz ] ]
                    dr : f32 [ sqrt[ drx * drx + dry * dry + drz * drz ] ]
                    d   : f32 [ dl ]
                    sgn : f32 [ (lcx >= 0.0) ? 1.0 : -1.0 ]
                    if [ dr < dl ]
                        d = dr
                        sgn = (rcx >= 0.0) ? 1.0 : -1.0
                    if [ d >= rad ] continue
                    t : f32 [ d / rad ]
                    fall : f32 [ 1.0 - (t * t * (3.0 - 2.0 * t)) ]
                    pf[0] = pf[0] + sgn * eye_spacing * fall

    # pose the rig for this frame (hinge + eyes), recompose worlds, and write the
    # skin palette; the caller then pushes rigid node worlds via update_animated
    func update_palette []
        if [ skin_idx < 0 || !joint_buf ] return
        sk : gmodel.skins[ skin_idx ]
        nj : i32 [ i32[ sk.joints.count ] ]
        if [ hinge_node >= 0 ]
            hn : gmodel.nodes[ hinge_node ]
            s2 : f32 [ sin[ hinge_ang * 0.5 ] ]
            hn.rotation = quatf [ x: s2, y: 0.0, z: 0.0, w: cos[ hinge_ang * 0.5 ] ]
        aim_eyes[]
        apply_spacing[]
        gmodel.compute_worlds[]
        dst : ref f32 [ ((joint_buf.data) to ref f32) ]
        for [ j: i32 0, j < nj, j += 1 ]
            jn : gmodel.nodes[ sk.joints[ j ] ]
            jm : mat4f [ jn.world.mul[ ibm[ j ] ] ]
            for [ k: i32 0, k < 16, k += 1 ]
                dst[ j * 16 + k ] = jm.m[ k ]

    # point a named material's baseColorTexture at an albedo map. uri is
    # relative to the model dir (models/), so textures one level up under
    # share/textures use '../'. resolves through Res.res_path at load time
    func set_albedo [ matname: string, uri: string ]
        if [ !gmodel || !gmodel.materials ] return
        if [ !gmodel.images ]   gmodel.images   = array GltfImage [ ]
        if [ !gmodel.textures ] gmodel.textures = array GltfTexture [ ]
        img : GltfImage [ uri: path uri ]
        gmodel.images += img
        iidx : i64 [ gmodel.images.count - 1 ]
        tx : GltfTexture [ source: iidx ]
        gmodel.textures += tx
        tidx : i64 [ gmodel.textures.count - 1 ]
        for [ m: Material ] in gmodel.materials
            if [ m.name == matname ]
                if [ !m.pbrMetallicRoughness ]
                    m.pbrMetallicRoughness = PbrMetallicRoughness [ ]
                m.pbrMetallicRoughness.baseColorTexture = TextureInfo [ index: tidx ]

    # give a material a base-color alpha in (0,1) so the pipeline routes it to
    # the transparent shader (drawn after opaque, depth-test no-write)
    func mark_transparent [ matname: string, av: f32 ]
        if [ !gmodel || !gmodel.materials ] return
        for [ m: Material ] in gmodel.materials
            if [ m.name == matname ]
                if [ !m.pbrMetallicRoughness ]
                    m.pbrMetallicRoughness = PbrMetallicRoughness [ ]
                m.pbrMetallicRoughness.baseColorFactor = vec4f [ 1.0, 1.0, 1.0, av ]

    # wire the purchased skin/eye albedo maps onto the model's materials
    func bind_albedos []
        set_albedo[ 'Head',    '../share/textures/head/skin_albedo.1001.png' ]
        set_albedo[ 'Body',    '../share/textures/head/skin_albedo.1002.png' ]
        set_albedo[ 'Eyeball', '../share/textures/eye/sclera_albedo.png' ]
        set_albedo[ 'Iris',    '../share/textures/eye/iris_fibres.png' ]
        # the eyeball is the translucent cornea layer over the iris

    public func draw [ w: Window ]
        if [ w.draw_stage != CanvasType.screen ] return
        ux.will_animate = true
        if [ bounds.w <= 0.0 || bounds.h <= 0.0 ] return
        # the picker fed new landmarks -> rebuild this face to them
        if [ vrender && (span_mm != baked_span || nostril_span != baked_nos || mid_nose != baked_mid || nostril_y != baked_ny) ]
            reload_model[]
        cv : Canvas [ w.screen ]
        if [ !vrender ]
            expect model_path, 'no model path given'
            vshader   = SkinnedLit [ vk: cv.vk, name: 'skinned' ]
            rshader   = RigidLit   [ vk: cv.vk, name: 'rigid' ]
            cshader   = CorneaIR   [ vk: cv.vk, name: 'cornea' ]
            # load the body and the eyeball spheres (Eye L/R -> CorneaIR volume,
            # the real bump). drop the flat Iris disc meshes (RigidLit planes)
            vshader.groups = array string [ 'Body', 'Eye L', 'Eye R' ]
            # mount the .res sidecar if present, then resolve the model and
            # its buffer uris through the wrapper: loose files win, else the
            # archive cache. base = the asset root, one dir above the model
            root    : path model_path.parent_dir[].parent_dir[]
            resf    : model_path.change_ext[ "res" ]
            reldir  : model_path.parent_dir[].filename[]
            relname : '{reldir}/{model_path.filename[]}'
            gpath   : model_path
            if [ resf.exists[] ]
                Res.mount[ resf, root, path '{root}/cache', '12345' ]
                gpath = Res.res_path[ relname ]
                GltfBuffer.set_base[ path reldir ]
            el
                GltfBuffer.set_base[ model_path.parent_dir[] ]
            expect gpath && gpath.exists[], 'model does not exist: {model_path}'
            # member sets outside init do NOT retain: without the hold the
            # loaded model drops before Render init and Model.finish silently
            # falls back to the default quad
            gm : GltfModel [ gpath.load[ typeid[ GltfModel ], null ] ]
            gm.hold[]
            gmodel = gm
            gm.compute_worlds[]
            # bind the skin/eye albedo maps onto the named materials before
            # the pipelines build (mat_tex reads baseColorTexture)
            bind_albedos[]
            # blend shape keys, then bake the painted nose scale, into POSITION
            apply_morphs[]
            bake_nose[]
            # fit the nose to the person's measured landmarks (mm)
            bake_nose_landmarks[]
            # set eye spacing to the person's IPD (mm); eyeballs follow the bone
            bake_eye_spacing[]
            baked_span = span_mm
            baked_nos  = nostril_span
            baked_mid  = mid_nose
            baked_ny   = nostril_y
            # tessellate the base mesh (1-to-4) after all CPU deformation
            subdivide[]
            # read the skin's inverse-bind matrices, find the joint node, build
            # the joint-matrix palette storage buffer
            setup_skin[]
            update_palette[]
            sm : map Au[string] [ ]
            if [ joint_buf ] sm[ 'joints_pal' ] = joint_buf
            # bind every eye map onto the cornea shader; the single frag samples
            # fibres, melanin, three iris displacements, and the sclera veins
            eye_files : array string [ 'iris_fibres.png', 'iris_melanin.png', 'iris_displacement_a.png', 'iris_displacement_b.png', 'iris_displacement_c.png', 'sclera_displacement.png' ]
            eye_keys  : array string [ 'iris', 'iris_melanin', 'iris_disp_a', 'iris_disp_b', 'iris_disp_c', 'sclera_disp' ]
            eye_tex = array Texture [ ]
            for [ ei: i32 0, ei < eye_files.count, ei += 1 ]
                kf : eye_files[ ei ]
                kk : eye_keys[ ei ]
                ep : path '{model_path.parent_dir[]}/../share/textures/eye/{kf}'
                if [ !ep.exists[] ] continue
                eim : Image [ uri: ep ]
                emx : i32 [ (eim.width > eim.height) ? eim.width : eim.height ]
                eml : i32 [ 1 ]
                for [ q: i32 emx, q > 1, q = q / 2 ]
                    eml += 1
                etx : Texture [ w: w, vk: cv.vk, linear: true, mip_levels: eml, sampler: eim ]
                etx.hold[]
                sm[ kk ] = etx
                eye_tex += etx
            vmodel    = Model [ vk: cv.vk, w: w, s: vshader, rigid_s: cshader, transparent_s: cshader, samplers: sm ]
            vmodel.id = gm
            # auto-frame: union of POSITION bounds in WORLD space — each mesh
            # node's composed scene-graph transform applied to its box corners
            mnx : f32 [  1e9 ]
            mny : f32 [  1e9 ]
            mnz : f32 [  1e9 ]
            mxx : f32 [ -1e9 ]
            mxy : f32 [ -1e9 ]
            mxz : f32 [ -1e9 ]
            for [ nd: Node ] in gm.nodes
                if [ !nd.AF_query_name[ 'mesh' ] ] continue
                me : gm.meshes[ nd.mesh ]
                if [ !me ] continue
                wmat : mat4f [ nd.world ]
                for [ pr: Primitive ] in me.primitives
                    for [ av: ref i64, an: string ] in pr.attributes
                        if [ an == 'POSITION' ]
                            ac : gm.accessors[ av[0] ]
                            for [ cn: i32 0, cn < 8, cn += 1 ]
                                cxv : f32 [ ((cn & 1) != 0) ? ac.max.x : ac.min.x ]
                                cyv : f32 [ ((cn & 2) != 0) ? ac.max.y : ac.min.y ]
                                czv : f32 [ ((cn & 4) != 0) ? ac.max.z : ac.min.z ]
                                # column-major transform, scalar math (a C
                                # vec4f-by-value return crosses the aether/clang
                                # struct-return ABI wrong — see mul_v4 note)
                                wcx : f32 [ wmat.m[0] * cxv + wmat.m[4] * cyv + wmat.m[8]  * czv + wmat.m[12] ]
                                wcy : f32 [ wmat.m[1] * cxv + wmat.m[5] * cyv + wmat.m[9]  * czv + wmat.m[13] ]
                                wcz : f32 [ wmat.m[2] * cxv + wmat.m[6] * cyv + wmat.m[10] * czv + wmat.m[14] ]
                                if [ wcx < mnx ] mnx = wcx
                                if [ wcy < mny ] mny = wcy
                                if [ wcz < mnz ] mnz = wcz
                                if [ wcx > mxx ] mxx = wcx
                                if [ wcy > mxy ] mxy = wcy
                                if [ wcz > mxz ] mxz = wcz
            fpf : picker[]
            if [ mxx > mnx && fpf && !fpf.cam_ready ]
                sx : f32 [ mxx - mnx ]
                sy : f32 [ mxy - mny ]
                sz : f32 [ mxz - mnz ]
                r  : f32 [ sx ]
                if [ sy > r ] r = sy
                if [ sz > r ] r = sz
                fpf.look_x = (mnx + mxx) * 0.5
                fpf.look_y = mny + (mxy - mny) * 0.93
                fpf.look_z = (mnz + mxz) * 0.5
                fpf.dist   = (mxy - mny) * 0.20
                if [ fpf.dist < 0.2 ] fpf.dist = 0.2
                fpf.cam_ready = true
                puts 'hyperspace2: model bounds {sx}x{sy}x{sz} center=({fpf.look_x},{fpf.look_y},{fpf.look_z}) -> dist={fpf.dist}'
            vrender   = Render [ vk: cv.vk, w: w, wscale: 1.0, use_depth: true, clear_color: vec4f [ 0.015, 0.015, 0.015, 1.0 ], models: array Model [ vmodel ] ]
            puts 'hyperspace2: bounds={bounds.w}x{bounds.h} window={w.width}x{w.height} scale={w.scale}'
        # orbit camera: spherical eye around the look point (matches the Avatar
        # camera conventions — up is -Y, fov is horizontal)
        tgt : vec3f [ look_x, look_y, look_z ]
        eye : vec3f [
            tgt.x + dist * cos[ pitch ] * sin[ yaw ],
            tgt.y + dist * sin[ pitch ],
            tgt.z + dist * cos[ pitch ] * cos[ yaw ] ]
        up  : vec3f [ 0.0f, -1.0f, 0.0f ]
        asp : f32 [ bounds.w / bounds.h ]
        fy  : f32 [ 2.0f * atan[ tan[ radians[ 40.0f ] * 0.5f ] / asp ] ]
        vshader.model = mat4f.identity[]
        vshader.view  = mat4f.look_at[ eye, tgt, up ]
        vshader.proj  = mat4f.perspective[ fy, asp, 0.05f, 200.0f ]
        # rigid meshes (eyeballs) need the same camera; their model matrix is the
        # per-node world (ubo.model = rshader.model x node_model), so keep it identity
        if [ rshader ]
            rshader.model = mat4f.identity[]
            rshader.view  = vshader.view
            rshader.proj  = vshader.proj
        if [ cshader ]
            cshader.model = mat4f.identity[]
            cshader.view  = vshader.view
            cshader.proj  = vshader.proj
            # sweep pupil dilation max<->min on a sine each frame
            ph : f32 [ f32[ frame_n ] * 0.02f ]
            cshader.pupil_r = 0.35f + 0.20f * sin[ ph ]
        update_palette[]
        # rigid meshes (eyeballs) follow their bone: re-push node worlds
        if [ vmodel ] vmodel.update_animated[]
        vrender.update[]
        vrender.draw[]
        vrender.flush_submit[]
        vrender.sync_fence[]
        # HS2_DUMP=1: write the render target to /tmp/hyperspace2_target.png once
        # (~frame 60) — discriminates render corruption from present corruption
        frame_n += 1
        if [ frame_n == 60 && getenv[ 'HS2_DUMP' ] ]
            tex : Texture vrender.color
            dsz : i32 [ tex.width * tex.height * 4 ]
            db : Buffer [ vk: tex.vk, size: dsz,
                u_dst: true, m_host_visible: true, m_host_coherent: true ]
            db.transfer[ tex ]
            dshot : Image [ width: tex.width, height: tex.height, format: Pixel.rgba8 ]
            memcpy[ dshot.vdata[], db.mmap[], dsz ]
            db.unmap[]
            dshot.png[ path '/tmp/hyperspace2_target.png' ]
            puts 'hyperspace2: dumped {tex.width}x{tex.height} target'
        cv.draw_image[ vrender.color, rect [ x: 0.0, y: 0.0, w: bounds.w, h: bounds.h ] ]

element hyperspace2 : trinity
    public model      : path
    public width      : i32    [ 1280 ]
    public height     : i32    [ 960 ]
    public title      : string [ 'hyperspace2' ]
    # solid-color background: the swapchain blit presents the LAST render's
    # color — the background chain's r_view (targeting the screen canvas) is
    # that render, so an app without one has nothing to present
    public background : string [ 'Background' ]
    # A/B face fitter (folded into the app root so it always gets keys as
    # app_object). champion (A = running centre) vs challenger (B = centre +
    # noise); space or a face double-click splits them side by side.
    mutable seeded   : bool
    mutable rng      : i64 [ 88172645463325252 ]
    mutable ab_sigma : f32 [ 1.0 ]            # challenger spread
    mutable c_eye : f32 [ 91.0 ]             # champion (running centre), mm
    mutable c_nos : f32 [ 38.5 ]
    mutable c_mid : f32 [ 33.9 ]
    mutable c_ny  : f32 [ 42.3 ]
    mutable b_eye : f32                       # challenger, mm
    mutable b_nos : f32
    mutable b_mid : f32
    mutable b_ny  : f32
    mutable split : bool                       # A and B side by side
    # one camera shared by both faces so they always show the same angle; a
    # drag on either face writes back here and both faces read it each frame
    mutable yaw    : f32
    mutable pitch  : f32 [ 0.05 ]
    mutable dist   : f32 [ 3.5 ]
    mutable look_x : f32
    mutable look_y : f32 [ 1.0 ]
    mutable look_z : f32
    mutable cam_ready : bool                    # a face has auto-framed once

    # uniform 0..1 from a 64-bit LCG; no Math.random in the module
    func rnd [] -> f32
        rng = rng * 6364136223846793005 + 1442695040888963407
        r : i64 [ (rng >> 33) & 2147483647 ]
        return f32[ r ] / 2147483647.0

    # ~zero-mean noise (triangular), range about [-1.5, 1.5]
    func gauss [] -> f32
        return rnd[] + rnd[] + rnd[] - 1.5

    # draw a fresh challenger around the champion, spread by ab_sigma. the
    # per-param base widths are rough human population ranges (mm)
    func resample []
        b_eye = c_eye + gauss[] * 6.0 * ab_sigma
        b_nos = c_nos + gauss[] * 5.0 * ab_sigma
        b_mid = c_mid + gauss[] * 4.0 * ab_sigma
        b_ny  = c_ny  + gauss[] * 5.0 * ab_sigma

    public func on_key [ ev: Event ]
        if [ !ev.key.state ] return
        if [ ev.key.unicode == 32 ] split = !split   # space: split A | B
        if [ ev.key.unicode == 65 ]                  # A: keep champion, narrow
            ab_sigma = ab_sigma * 0.7
            if [ ab_sigma < 0.15 ] ab_sigma = 0.15
            resample[]
        if [ ev.key.unicode == 66 ]                  # B: adopt challenger
            den : f32 [ ab_sigma ]
            if [ den < 0.001 ] den = 0.001
            de : f32 [ b_eye - c_eye ]
            dn : f32 [ b_nos - c_nos ]
            dm : f32 [ b_mid - c_mid ]
            dy : f32 [ b_ny  - c_ny ]
            se : f32 [ ((de < 0.0) ? (0.0 - de) : de) / (6.0 * den) ]
            sn : f32 [ ((dn < 0.0) ? (0.0 - dn) : dn) / (5.0 * den) ]
            sm : f32 [ ((dm < 0.0) ? (0.0 - dm) : dm) / (4.0 * den) ]
            sy : f32 [ ((dy < 0.0) ? (0.0 - dy) : dy) / (5.0 * den) ]
            step : f32 [ (se + sn + sm + sy) * 0.25 ]
            c_eye = b_eye
            c_nos = b_nos
            c_mid = b_mid
            c_ny  = b_ny
            ab_sigma = ab_sigma * (0.55 + step)
            if [ ab_sigma > 1.5 ]  ab_sigma = 1.5
            if [ ab_sigma < 0.15 ] ab_sigma = 0.15
            resample[]
        puts 'hyperspace2: sigma={ab_sigma} eye={c_eye} nos={c_nos} mid={c_mid} ny={c_ny}'

    public func render [] -> Elements
        if [ !seeded ]
            resample[]
            seeded = true
        e : Elements [ ]
        # face_a = champion (full, or left half when split); face_b = challenger
        # (right half), present only while split. both share this camera.
        e['face_a'] = ModelView [ model_path: model, split: split,
            yaw: yaw, pitch: pitch, dist: dist, look_x: look_x, look_y: look_y, look_z: look_z,
            span_mm: c_eye, nostril_span: c_nos, mid_nose: c_mid, nostril_y: c_ny ]
        if [ split ]
            e['face_b'] = ModelView [ model_path: model, split: split,
                yaw: yaw, pitch: pitch, dist: dist, look_x: look_x, look_y: look_y, look_z: look_z,
                span_mm: b_eye, nostril_span: b_nos, mid_nose: b_mid, nostril_y: b_ny ]
        return e
