import vec
import img
import gltf
import trinity
import ai
import ar-visions:torchshim/main <torch_shim.h>
    -ltorch_shim
import <stdio.h>
import <stdlib.h>
import <math.h>
import <sys/stat.h>

# basic glTF model viewer: `hyperspace2 --model path/to/model.gltf`
# drag orbits the camera, wheel zooms, R resets the view.

# TorchScript forward path — the torch trainer's own runtime
class ts_model
    public uri : path
    intern hnd : ARef

    func init []
        us : string '{uri}'
        hnd = ts_load[ us.chars ]
        if [ !hnd ]
            puts 'torchscript: cannot load {uri}'
            exit[ 1 ]

    func forward1 [ img2: tensor, out: tensor, s2: i32 ]
        ts_forward1[ hnd, img2.floats, s2, out.floats, 8 ]

    func forward4 [ l2: tensor, r2: tensor, f2: tensor, a2: tensor, out: tensor, s2: i32, an2: i32 ]
        ts_forward4[ hnd, l2.floats, r2.floats, f2.floats, a2.floats, s2, an2, out.floats, 8 ]

    func forward2i [ a3: tensor, b3: tensor, x3: tensor, out: tensor, s2: i32, an2: i32 ]
        ts_forward2i[ hnd, a3.floats, b3.floats, x3.floats, s2, an2, out.floats, 8 ]

    func forward6i [ a3: tensor, b3: tensor, c3: tensor, d3: tensor, e3: tensor, f3: tensor, x3: tensor, out: tensor, s2: i32, an2: i32 ]
        ts_forward6i[ hnd, a3.floats, b3.floats, c3.floats, d3.floats, e3.floats, f3.floats, x3.floats, s2, an2, out.floats, 8 ]

ModelViewProject ViewerLit
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib a_pos     : VertexInput    [ type:typeid[ vec3f ] ]
    attrib a_normal  : VertexInput    [ type:typeid[ vec3f ] ]
    attrib a_uv      : VertexInput    [ type:typeid[ vec2f ] ]

    attrib v_normal  : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        view  = mat4f.identity[]
        proj  = mat4f.identity[]

    func vertex [] -> GLSL none {
        v_normal    = mat3(ubo.model) * a_normal;
        v_uv        = a_uv;
        gl_Position = ubo.proj * ubo.view * ubo.model * vec4(a_pos, 1.0);
    }

    # two directional lights + ambient over the material color — enough to read
    # form on any model without needing a full PBR/environment setup
    func fragment [] -> GLSL none {
        vec4  c  = texture(color, v_uv);
        vec3  n  = normalize(v_normal);
        float l  = max(dot(n, normalize(vec3( 0.35, 0.75,  0.55))), 0.0) * 0.75
                 + max(dot(n, normalize(vec3(-0.50, 0.20, -0.60))), 0.0) * 0.25 + 0.22;
        fragColor = vec4(c.rgb * l, 1.0);
    }

# skinned variant: exactly the hinge's attributes (pos/normal/uv + joints/weights)
# plus a joint-matrix palette (SSBO, 4 vec4 per mat4). the vertex is transformed
# by the weighted blend of its joints' matrices, then the model/view/proj.
ModelViewProject SkinnedLit
    mutable ir  : f32         # 1 = near-IR headlamp look, 0 = textured color
    mutable sss : f32 [ 0.4 ] # subsurface wrap: 0 = hard lambert, ~0.5 = waxy skin
    mutable light_x : f32     # IR lamp world position (the mount camera)
    mutable light_y : f32
    mutable light_z : f32
    mutable shadow_amt : f32 [ 1.0 ] # _V_SHADOWS darkening: 0.5 half .. 1 black
    # rest-space eye centres: shading contrast collapses around the
    # lids — real orbital skin never shadows as hard as raw N.L
    mutable eye_lx : f32
    mutable eye_ly : f32
    mutable eye_lz : f32
    mutable eye_rx : f32
    mutable eye_ry : f32
    mutable eye_rz : f32
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    # declared in CANONICAL packing order — the engine binds vertex inputs to
    # packed attributes by position, so a_tangent/a_uv1 must be present (even if
    # unused) or a_joints/a_weights would bind to TANGENT/TEXCOORD_1 instead
    attrib a_pos     : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_normal  : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_uv      : VertexInput [ type:typeid[ vec2f ] ]
    attrib a_tangent : VertexInput [ type:typeid[ vec4f ] ]     # TANGENT (unused, for layout)
    attrib a_uv1     : VertexInput [ type:typeid[ vec2f ] ]     # TEXCOORD_1 (unused, for layout)
    attrib a_joints  : VertexInput [ type:typeid[ vec4f ] ]     # JOINTS_0 rgba8 UNORM -> *255 = index
    attrib a_weights : VertexInput [ type:typeid[ vec4f ] ]     # WEIGHTS_0

    attrib joints_pal : StorageBuffer [ type:typeid[ Surface ], id:Surface.environment, count:1, format:typeid[ vec4f ] ]

    attrib v_normal  : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib v_vpos    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_vnorm   : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_edge    : VertexOutput   [ type:typeid[ f32 ] ]
    attrib v_shadow  : VertexOutput   [ type:typeid[ f32 ] ]
    attrib v_rest    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        view  = mat4f.identity[]
        proj  = mat4f.identity[]
        ir    = 1.0

    func vertex [] -> GLSL none {
        int j0 = int(a_joints.x * 255.0 + 0.5);
        int j1 = int(a_joints.y * 255.0 + 0.5);
        int j2 = int(a_joints.z * 255.0 + 0.5);
        int j3 = int(a_joints.w * 255.0 + 0.5);
        mat4 m0 = mat4(joints_pal[j0*4], joints_pal[j0*4+1], joints_pal[j0*4+2], joints_pal[j0*4+3]);
        mat4 m1 = mat4(joints_pal[j1*4], joints_pal[j1*4+1], joints_pal[j1*4+2], joints_pal[j1*4+3]);
        mat4 m2 = mat4(joints_pal[j2*4], joints_pal[j2*4+1], joints_pal[j2*4+2], joints_pal[j2*4+3]);
        mat4 m3 = mat4(joints_pal[j3*4], joints_pal[j3*4+1], joints_pal[j3*4+2], joints_pal[j3*4+3]);
        mat4 sm = a_weights.x*m0 + a_weights.y*m1 + a_weights.z*m2 + a_weights.w*m3;
        vec4 sp     = ubo.model * (sm * vec4(a_pos, 1.0));
        vec4 vp     = ubo.view * sp;
        v_normal    = normalize(mat3(ubo.model) * (mat3(sm) * a_normal));
        v_vnorm     = mat3(ubo.view) * (mat3(ubo.model) * (mat3(sm) * a_normal));
        v_vpos      = vp.xyz;
        v_uv        = a_uv;
        v_edge      = a_uv1.x;
        v_shadow    = a_uv1.y;
        v_rest      = a_pos;
        gl_Position = ubo.proj * vp;
    }

    # ubo.ir toggles the two looks: near-IR lamp at ubo.light_* (world,
    # the camera mount), N.L falloff, soft sheen, lamp-distance falloff
    # — vs textured color
    func fragment [] -> GLSL none {
        // mask edge alpha: _V_EDGE (carried in uv1.x) = 1 at the border, so
        // alpha fades to 0 there; premultiplied output for the "over" blend
        float ea = clamp(1.0 - v_edge, 0.0, 1.0);
        // _V_SHADOWS (uv1.y): darken toward black — nostril interiors
        // etc; ubo.shadow_amt sweeps half to full per sample
        float shd = clamp(1.0 - v_shadow * ubo.shadow_amt, 0.0, 1.0);
        if (ubo.ir > 0.5) {
            vec3  N   = normalize(v_vnorm);
            vec3  V   = normalize(-v_vpos);
            vec3  lv  = (ubo.view * vec4(ubo.light_x, ubo.light_y, ubo.light_z, 1.0)).xyz;
            vec3  L   = normalize(lv - v_vpos);
            float ndl = max(dot(N, L), 0.0);
            // subsurface: NIR diffuses under skin, so wrap light past the
            // terminator (soft shadows) and add a broad deep-scatter glow
            float w    = ubo.sss;
            float ndlw = clamp((ndl + w) / (1.0 + w), 0.0, 1.0);
            // around the lids the shading floor lifts: orbital skin
            // never shadows at raw N.L depth
            float edl  = min(distance(v_rest, vec3(ubo.eye_lx, ubo.eye_ly, ubo.eye_lz)),
                             distance(v_rest, vec3(ubo.eye_rx, ubo.eye_ry, ubo.eye_rz)));
            float ew   = 1.0 - smoothstep(0.018, 0.040, edl);
            ndlw       = mix(ndlw, max(ndlw, 0.72), ew * 0.6);
            float diff = pow(ndlw, 1.2);
            float scat = pow(ndlw, 0.5) * w * 0.35;
            float spec = pow(max(dot(N, normalize(L + V)), 0.0), 16.0) * 0.25;
            float d    = length(lv - v_vpos);
            float fall = clamp(2.0 / (1.0 + 0.04 * d * d), 0.0, 1.0);
            // skin map off for now: fixed defects that never move teach
            // the net nothing. re-enable when we iterate skin maps:
            // float alb = dot(texture(color, v_uv).rgb, vec3(0.333));
            // float g   = (0.60 * (diff + scat) * alb + spec) * fall;
            float g    = (0.60 * (diff + scat) + spec) * fall * shd;
            fragColor  = vec4(vec3(g) * ea, ea);
        } else {
            vec4  c  = texture(color, v_uv);
            vec3  n  = normalize(v_normal);
            float l  = max(dot(n, normalize(vec3( 0.35, 0.75,  0.55))), 0.0) * 0.75
                     + max(dot(n, normalize(vec3(-0.50, 0.20, -0.60))), 0.0) * 0.25 + 0.22;
            fragColor = vec4(c.rgb * l * shd * ea, ea);
        }
    }

# non-skinned primitives (eyeballs, teeth, tongue): rigid transform by the
# node's world matrix (ubo.model), driven by whichever bone the mesh parents to
# augmentation params (driven per synthetic sample): pupil aperture radius
# (dilation) and its fuzz, the outer iris/limbus radius and its fuzz, the
# retina glow strength, and the iris fibre brightness
ModelViewProject RigidLit
    mutable ir          : f32     # 1 = near-IR headlamp look, 0 = textured color
    mutable pupil_r     : f32 [ 0.15 ]
    mutable pupil_soft  : f32 [ 0.05 ]
    mutable iris_r      : f32 [ 0.45 ]
    mutable iris_soft   : f32 [ 0.04 ]
    mutable iris_glow   : f32 [ 0.95 ]
    mutable iris_bright : f32 [ 0.40 ]
    mutable light_x     : f32 # IR lamp world position (the mount camera)
    mutable light_y     : f32
    mutable light_z     : f32
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib a_pos     : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_normal  : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_uv      : VertexInput [ type:typeid[ vec2f ] ]

    attrib v_normal  : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib v_vpos    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_vnorm   : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        view  = mat4f.identity[]
        proj  = mat4f.identity[]
        ir    = 1.0

    func vertex [] -> GLSL none {
        vec4 wp     = ubo.model * vec4(a_pos, 1.0);
        vec4 vp     = ubo.view * wp;
        v_normal    = normalize(mat3(ubo.model) * a_normal);
        v_vnorm     = mat3(ubo.view) * (mat3(ubo.model) * a_normal);
        v_vpos      = vp.xyz;
        v_uv        = a_uv;
        gl_Position = ubo.proj * vp;
    }

    # ubo.ir toggles: near-IR headlamp (the wet eyeball keeps a sharp glint)
    # vs textured color
    func fragment [] -> GLSL none {
        if (ubo.ir > 0.5) {
            vec3  V    = normalize(-v_vpos);
            vec3  lv   = (ubo.view * vec4(ubo.light_x, ubo.light_y, ubo.light_z, 1.0)).xyz;
            vec3  L    = normalize(lv - v_vpos);
            float d    = length(lv - v_vpos);
            float fall = clamp(2.0 / (1.0 + 0.04 * d * d), 0.0, 1.0);
            // iris fibres live in the texture ALPHA (0 at the pupil, ~0.3..0.7
            // across the ring); unbound pupil sampler is transparent-black
            vec4  t    = texture(color, v_uv);
            float m    = t.a;
            // aperture axis is the eye's LOCAL +z pushed to view space, so the
            // retro return follows gaze, not the doming surface normals. broad
            // in the axis dot -> stays bright ~60 deg off-axis
            // retro returns toward the SOURCE: gate by view-lamp align
            vec3  fwd  = normalize(mat3(ubo.view) * (mat3(ubo.model) * vec3(0.0, 0.0, 1.0)));
            float retro = pow(max(dot(fwd, L), 0.0), 0.45) * pow(max(dot(V, L), 0.0), 6.0);
            // parameterized shape: pupil opening (inner) and limbus (outer)
            // are soft radial edges; the fibre detail comes from the texture
            float r    = length(v_uv - vec2(0.5));
            float pin  = smoothstep(ubo.pupil_r - ubo.pupil_soft, ubo.pupil_r + ubo.pupil_soft, r);
            float pout = 1.0 - smoothstep(ubo.iris_r - ubo.iris_soft, ubo.iris_r + ubo.iris_soft, r);
            float glow = (0.15 + ubo.iris_glow)      * retro;
            float iris = (0.14 + ubo.iris_bright * m) * retro;
            float g    = mix(glow, iris, pin) * pout * fall;
            fragColor  = vec4(vec3(g), 1.0);
        } else {
            vec4  c  = texture(color, v_uv);
            vec3  n  = normalize(v_normal);
            float l  = max(dot(n, normalize(vec3( 0.35, 0.75,  0.55))), 0.0) * 0.75
                     + max(dot(n, normalize(vec3(-0.50, 0.20, -0.60))), 0.0) * 0.25 + 0.22;
            fragColor = vec4(c.rgb * l, 1.0);
        }
    }

# the wet cornea layer, drawn transparent over the opaque iris: near-clear on the
# forward bulge so the iris reads through, opaque pale sclera at grazing angles,
# and one sharp on-axis Purkinje glint toward the camera
# augmentation params (driven per synthetic sample): sclera brightness facing
# the camera vs at the periphery, its falloff shape, and the glint strength
ModelViewProject CorneaIR
    mutable ir        : f32
    mutable glint     : f32 [ 0.9 ]
    mutable sclera_hi : f32 [ 0.95 ]
    mutable sclera_lo : f32 [ 0.34 ]
    mutable sclera_k  : f32 [ 1.5 ]
    # volume eye: refract the view ray at the cornea and march it through the
    # anterior chamber to the iris plane sitting inside the eyeball sphere.
    # geometry from the model: eyeball radius ~0.0122, iris plane z~0.009,
    # iris radius ~0.0105 (local, metres)
    mutable ior         : f32 [ 1.20 ]
    mutable cornea_c    : f32 [ 0.0025 ]
    mutable cornea_r    : f32 [ 0.0110 ]
    mutable iris_z      : f32 [ 0.009 ]
    mutable iris_radius : f32 [ 0.0046 ]
    mutable iris_tex_scale : f32 [ 1.0 ]
    mutable iris_rot    : f32 [ 0.0 ]
    mutable iris_dome   : f32 [ 0.0 ]  # -1 caved .. +1 convex iris surface
    mutable iris_cell_x : f32 [ 0.0 ]  # 32x32 iris-atlas cell of this sample
    mutable iris_cell_y : f32 [ 0.0 ]
    mutable iris_cells  : f32 [ 1.0 ]  # atlas grid divisor; 1 = plain maps
    mutable sclera_rot  : f32 [ 0.0 ]  # whites+veins rotate independently
    mutable limbus_soft : f32 [ 0.22 ]
    # iris map mixing: melanin pigment, 3 displacement variants, sclera veins
    mutable mel_amt     : f32 [ 1.0 ]
    mutable disp_wa     : f32 [ 1.0 ]
    mutable disp_wb     : f32 [ 0.0 ]
    mutable disp_wc     : f32 [ 0.0 ]
    mutable disp_amt    : f32 [ 0.35 ]
    mutable sclera_vein : f32 [ 0.15 ]
    # per-sample whites factor 0.7..1.0 — applied at half strength mid
    # (near the iris), full strength out at the sides
    mutable sclera_var  : f32 [ 1.0 ]
    mutable sclera_scale : f32 [ 1.0 ]  # whites texture zoom per sample
    # darken the OUTER EDGE of the whites (toward the opening rim),
    # applied after the texture + vein stage; per-sample amount
    mutable sclera_edge : f32 [ 0.3 ]
    mutable pupil_r     : f32 [ 0.40 ]
    mutable pupil_soft  : f32 [ 0.08 ]
    # dilation: pupil_r is the rendered pupil edge; the iris band (pupil_tex..1
    # in the texture) is remapped into (pupil_r..1) with a 2-part warp
    mutable pupil_tex   : f32 [ 0.28 ]
    mutable dilate_warp : f32 [ 1.0 ]
    mutable iris_glow   : f32 [ 0.9 ]
    mutable retro_k     : f32 [ 1.5 ]
    mutable retina_min  : f32 [ 0.25 ]
    mutable iris_bright : f32 [ 0.65 ]
    # mean-shift the iris band down without crushing fibre contrast
    mutable iris_dark   : f32 [ 0.0 ]
    # per-sample perlin over the iris: deviates the value around the
    # mean (radial probability, strongest mid-band). the one clean
    # iris map otherwise overfits — real irises never hold one depth
    mutable irisn_amt   : f32 [ 0.0 ]  # perlin amplitude around the mean
    mutable irisn_mean  : f32 [ 0.0 ]  # per-sample mean shift
    mutable irisn_freq  : f32 [ 5.0 ]  # lumps per iris diameter
    mutable irisn_seed  : f32 [ 0.0 ]
    # procedural iris: multi-octave perlin replaces the map (98%),
    # feature density set by two radial bands — usually one at the
    # edge and one mid-iris, sometimes rolled anywhere
    mutable iris_proc   : f32 [ 0.98 ]  # perlin vs map mix
    mutable irisd_c1    : f32 [ 1.0 ]   # density band 1 center
    mutable irisd_c2    : f32 [ 0.5 ]   # density band 2 center
    mutable irisd_w     : f32 [ 0.12 ]  # density band width
    mutable irisd_freq  : f32 [ 9.0 ]   # detail lumps per diameter
    mutable irisd_con   : f32 [ 1.0 ]   # feature contrast
    # radial darkening bands: 1D perlin over radius — random ring
    # distributions, usually mild, sometimes strong
    mutable irisb_amt   : f32 [ 0.0 ]   # band darkening strength
    mutable irisb_freq  : f32 [ 6.0 ]   # bands across the radius
    mutable irisb_seed  : f32 [ 0.0 ]
    # whites: large low-freq globs pull the sclera to mid gray
    mutable scln_amt    : f32 [ 0.0 ]   # glob strength
    mutable scln_freq   : f32 [ 2.0 ]   # globs across the eye
    mutable scln_seed   : f32 [ 0.0 ]
    mutable light_x     : f32 # IR lamp world position (the mount camera)
    mutable light_y     : f32
    mutable light_z     : f32
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]
    attrib iris  : LayoutBinding [ type:typeid[ Surface ], id:Surface.iris,  count:1, format: typeid[ rgba8 ] ]
    attrib iris_melanin : LayoutBinding [ type:typeid[ Surface ], id:Surface.iris_melanin, count:1, format: typeid[ rgba8 ] ]
    attrib iris_disp_a  : LayoutBinding [ type:typeid[ Surface ], id:Surface.iris_disp_a,  count:1, format: typeid[ rgba8 ] ]
    attrib iris_disp_b  : LayoutBinding [ type:typeid[ Surface ], id:Surface.iris_disp_b,  count:1, format: typeid[ rgba8 ] ]
    attrib iris_disp_c  : LayoutBinding [ type:typeid[ Surface ], id:Surface.iris_disp_c,  count:1, format: typeid[ rgba8 ] ]
    attrib sclera_disp  : LayoutBinding [ type:typeid[ Surface ], id:Surface.sclera_disp,  count:1, format: typeid[ rgba8 ] ]

    attrib a_pos     : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_normal  : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_uv      : VertexInput [ type:typeid[ vec2f ] ]

    attrib v_normal  : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib v_vpos    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_vnorm   : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        view  = mat4f.identity[]
        proj  = mat4f.identity[]
        ir    = 1.0

    func vertex [] -> GLSL none {
        vec4 wp     = ubo.model * vec4(a_pos, 1.0);
        vec4 vp     = ubo.view * wp;
        v_normal    = normalize(mat3(ubo.model) * a_normal);
        v_vnorm     = mat3(ubo.view) * (mat3(ubo.model) * a_normal);
        v_vpos      = vp.xyz;
        v_uv        = a_uv;
        gl_Position = ubo.proj * vp;
    }

    func fragment [] -> GLSL none {
        // eye local frame (right/up/fwd) and center, all in view space
        mat3  MV    = mat3(ubo.view) * mat3(ubo.model);
        vec3  fwd   = normalize(MV * vec3(0.0, 0.0, 1.0));
        vec3  right = normalize(MV * vec3(1.0, 0.0, 0.0));
        vec3  up    = normalize(MV * vec3(0.0, 1.0, 0.0));
        vec3  Cc    = (ubo.view * ubo.model * vec4(0.0, 0.0, 0.0, 1.0)).xyz;

        vec3  N     = normalize(v_vnorm);
        vec3  Vd    = normalize(-v_vpos);
        // IR lamp in view space (world ubo.light_*: the camera mount)
        vec3  lv    = (ubo.view * vec4(ubo.light_x, ubo.light_y, ubo.light_z, 1.0)).xyz;
        vec3  Lc    = normalize(lv - Cc);
        float ndl   = max(dot(N, normalize(lv - v_vpos)), 0.0);

        // VOLUME: the flat iris disc only rasterizes the eye region; here we
        // trace the real cornea analytically. intersect the camera ray with a
        // cornea sphere sitting in front of the iris, refract at that surface,
        // then march to the iris plane. true depth + parallax, no flat sprite.
        vec3  D     = normalize(v_vpos);
        vec3  Sc    = Cc + fwd * ubo.cornea_c;
        float b     = dot(D, Sc);
        float c     = dot(Sc, Sc) - ubo.cornea_r * ubo.cornea_r;
        float disc  = b * b - c;
        float m     = 0.0;
        float rr    = 2.0;
        float spec  = 0.0;
        float graze = 0.0;
        if (disc > 0.0) {
            float tt  = b - sqrt(disc);
            vec3  Pin = D * tt;
            vec3  Nin = normalize(Pin - Sc);
            // the cornea is CLEAR: grazing transmission at its edge
            // reads neutral, never shaded dark like tissue
            graze     = pow(1.0 - abs(dot(Nin, D)), 1.5);
            vec3  R   = refract(D, Nin, 1.0 / ubo.ior);
            if (dot(R, R) < 1e-6) { R = D; }
            float Rz  = dot(R, fwd);
            Rz = (Rz < 0.0) ? min(Rz, -1e-3) : max(Rz, 1e-3);
            float s   = (ubo.iris_z - dot(Pin - Cc, fwd)) / Rz;
            vec3  hit = Pin + R * s;
            vec2  hxy = vec2(dot(hit - Cc, right), dot(hit - Cc, up));
            rr        = length(hxy) / ubo.iris_radius;
            // iris_dome bows the iris SURFACE out of its flat plane
            // (+1 convex toward the cornea, -1 caved into the eye): the
            // ray re-intersects the bowed depth, so parallax shows it
            float domeH = ubo.iris_dome * 0.35 * ubo.iris_radius;
            for (int di = 0; di < 2; di++) {
                float zs = ubo.iris_z - domeH * (1.0 - min(rr * rr, 1.0));
                s   = (zs - dot(Pin - Cc, fwd)) / Rz;
                hit = Pin + R * s;
                hxy = vec2(dot(hit - Cc, right), dot(hit - Cc, up));
                rr  = length(hxy) / ubo.iris_radius;
            }
            // rotate the iris texture, then scale its inner detail
            float ca  = cos(ubo.iris_rot);
            float sa  = sin(ubo.iris_rot);
            vec2  rxy = vec2(hxy.x * ca - hxy.y * sa, hxy.x * sa + hxy.y * ca);
            // pupil dilation: remap the iris band into (pupil_r..1) with a
            // 2-part warp, so tissue near the pupil compresses vs the rim
            float u   = clamp((rr - ubo.pupil_r) / max(1.0 - ubo.pupil_r, 1e-3), 0.0, 1.0);
            float tr  = ubo.pupil_tex + pow(u, ubo.dilate_warp) * (1.0 - ubo.pupil_tex);
            vec2  dir = (rr > 1e-4) ? rxy / (rr * ubo.iris_radius) : vec2(0.0);
            vec2  iuv = vec2(0.5) + 0.5 * dir * (tr / ubo.iris_tex_scale);
            // iris atlas: fibres/melanin/speckles come from this sample's
            // synthesized cell — every sample wears a different iris.
            // iris_cells 1 = plain maps (interactive, no atlas built)
            vec2  iuvA = (vec2(ubo.iris_cell_x, ubo.iris_cell_y)
                         + clamp(iuv, vec2(0.0), vec2(1.0))) / ubo.iris_cells;
            float fib = texture(iris, iuvA).a;
            float mel = texture(iris_melanin, iuvA).r;
            float da  = texture(iris_disp_a, iuvA).r;
            float db  = texture(iris_disp_b, iuvA).r;
            float dc  = texture(iris_disp_c, iuvA).r;
            float dsp = da * ubo.disp_wa + db * ubo.disp_wb + dc * ubo.disp_wc;
            // melanin sets iris darkness; fibres + displacement crypts add relief
            float base= mix(1.0, mel, ubo.mel_amt);
            m         = clamp(base * (0.6 + 0.4 * fib) + (dsp - 0.5) * ubo.disp_amt, 0.0, 1.0);
            // procedural iris: 4-octave value noise; two radial
            // density bands decide where the fine features live
            float db1 = (u - ubo.irisd_c1) / max(ubo.irisd_w, 1e-3);
            float db2 = (u - ubo.irisd_c2) / max(ubo.irisd_w, 1e-3);
            float dens= clamp(exp(-0.5 * db1 * db1) + exp(-0.5 * db2 * db2), 0.0, 1.0);
            vec2  pp  = hxy / ubo.iris_radius * ubo.irisd_freq
                      + vec2(ubo.irisn_seed * 2.31, ubo.irisn_seed);
            float pm  = 0.0;
            float pw  = 0.5;
            for (int oi = 0; oi < 4; oi++) {
                vec2  pI = floor(pp);
                vec2  pF = fract(pp);
                vec2  pU = pF * pF * (3.0 - 2.0 * pF);
                float pa = fract(sin(dot(pI,                  vec2(127.1, 311.7))) * 43758.5453);
                float pb = fract(sin(dot(pI + vec2(1.0, 0.0), vec2(127.1, 311.7))) * 43758.5453);
                float pc = fract(sin(dot(pI + vec2(0.0, 1.0), vec2(127.1, 311.7))) * 43758.5453);
                float pd = fract(sin(dot(pI + vec2(1.0, 1.0), vec2(127.1, 311.7))) * 43758.5453);
                float pn = mix(mix(pa, pb, pU.x), mix(pc, pd, pU.x), pU.y);
                // octave 0 is the broad base; finer octaves only
                // carry weight inside the density bands, and only
                // ever SUBTRACT — radial features cut darker
                float pc2 = (pn - 0.5) * pw;
                pm += (oi == 0) ? pc2 : -abs(pc2) * 2.0 * mix(0.15, 1.0, dens);
                pp  = pp * 2.17 + vec2(13.7, 9.1);
                pw *= 0.55;
            }
            float procm = clamp(0.5 + pm * ubo.irisd_con * (0.5 + 0.5 * dens), 0.0, 1.0);
            m = mix(m, procm, ubo.iris_proc);
            // radial darkening bands: 1D value noise over radius,
            // squared so most rings are mild, a few go deep
            float bt = u * ubo.irisb_freq + ubo.irisb_seed;
            float bI = floor(bt);
            float bF = fract(bt);
            float bU = bF * bF * (3.0 - 2.0 * bF);
            float b0 = fract(sin(bI * 127.1) * 43758.5453);
            float b1 = fract(sin((bI + 1.0) * 127.1) * 43758.5453);
            float bn = mix(b0, b1, bU);
            m = clamp(m - bn * bn * ubo.irisb_amt, 0.0, 1.0);
            // per-sample perlin around the mean: value noise over the
            // iris plane, radial probability peaking mid-band — the
            // clean source map alone overfits
            vec2  np  = hxy / ubo.iris_radius * ubo.irisn_freq
                      + vec2(ubo.irisn_seed, ubo.irisn_seed * 1.73);
            vec2  nI  = floor(np);
            vec2  nF  = fract(np);
            vec2  nU  = nF * nF * (3.0 - 2.0 * nF);
            float ha  = fract(sin(dot(nI,                  vec2(127.1, 311.7))) * 43758.5453);
            float hb  = fract(sin(dot(nI + vec2(1.0, 0.0), vec2(127.1, 311.7))) * 43758.5453);
            float hcn = fract(sin(dot(nI + vec2(0.0, 1.0), vec2(127.1, 311.7))) * 43758.5453);
            float hd  = fract(sin(dot(nI + vec2(1.0, 1.0), vec2(127.1, 311.7))) * 43758.5453);
            float nz  = mix(mix(ha, hb, nU.x), mix(hcn, hd, nU.x), nU.y);
            float bandR = 0.35 + 0.65 * 4.0 * u * (1.0 - u);
            m = clamp(m + ubo.irisn_mean + (nz - 0.5) * ubo.irisn_amt * bandR, 0.0, 1.0);
            // catchlight = mirror image of the LAMP, not the viewer
            spec      = pow(max(dot(Nin, normalize(normalize(lv - Pin) + Vd)), 0.0), 120.0) * ubo.glint;
        }

        // pupil, iris fibres, and the retina retroreflection: light bounces
        // back toward the SOURCE — bright pupil only near the lamp axis
        float retro = pow(max(dot(fwd, Lc), 0.0), ubo.retro_k) * pow(max(dot(Vd, Lc), 0.0), 6.0);
        float pin   = smoothstep(ubo.pupil_r - ubo.pupil_soft, ubo.pupil_r + ubo.pupil_soft, rr);
        float retina= 1.0 - smoothstep(0.0, ubo.pupil_r, rr) * 0.6;
        float glow  = ubo.iris_glow * mix(ubo.retina_min, 1.0, retro) * retina;
        float irG   = clamp(ubo.iris_bright * m - ubo.iris_dark, 0.0, 1.0);
        float irisV = mix(glow, irG, pin);
        float inIr  = 1.0 - smoothstep(1.0 - ubo.limbus_soft, 1.0, rr);

        // white sclera outside the iris, shaded from the lamp
        float shade = mix(ubo.sclera_lo, ubo.sclera_hi, pow(ndl, ubo.sclera_k));
        // whites + veins rotate independently of the iris texture
        float sca   = cos(ubo.sclera_rot);
        float ssa   = sin(ubo.sclera_rot);
        vec2  suv   = (v_uv - vec2(0.5)) / max(ubo.sclera_scale, 0.5);
        suv         = vec2(suv.x * sca - suv.y * ssa, suv.x * ssa + suv.y * sca) + vec2(0.5);
        float sc    = texture(color, suv).r;
        float sdsp  = texture(sclera_disp, suv).r;
        // whites variance: 0.5 factor at mid, 1.0 at the sides
        float svw   = mix(0.5, 1.0, smoothstep(1.0, 2.2, rr));
        float sclera= (sc * shade + (sdsp - 0.5) * ubo.sclera_vein)
                    * mix(1.0, ubo.sclera_var, svw);
        // large mid-gray globs over the whites: low-freq value
        // noise, squared so globs pool instead of dither
        vec2  gp  = v_uv * ubo.scln_freq + vec2(ubo.scln_seed, ubo.scln_seed * 1.37);
        vec2  gI  = floor(gp);
        vec2  gF  = fract(gp);
        vec2  gU  = gF * gF * (3.0 - 2.0 * gF);
        float ga  = fract(sin(dot(gI,                  vec2(127.1, 311.7))) * 43758.5453);
        float gb  = fract(sin(dot(gI + vec2(1.0, 0.0), vec2(127.1, 311.7))) * 43758.5453);
        float gcn = fract(sin(dot(gI + vec2(0.0, 1.0), vec2(127.1, 311.7))) * 43758.5453);
        float gdn = fract(sin(dot(gI + vec2(1.0, 1.0), vec2(127.1, 311.7))) * 43758.5453);
        float gn  = mix(mix(ga, gb, gU.x), mix(gcn, gdn, gU.x), gU.y);
        float gmid= mix(ubo.sclera_lo, ubo.sclera_hi, 0.5);
        sclera    = mix(sclera, gmid, gn * gn * ubo.scln_amt);
        // the whites' outer edge darkens toward the opening rim —
        // per-sample amount, applied AFTER the glob perlin
        float sedge = smoothstep(1.6, 2.8, rr);
        sclera      = sclera * (1.0 - ubo.sclera_edge * sedge);
        // neutral gray transmission where the cornea edge grazes
        sclera      = mix(sclera, mix(ubo.sclera_lo, ubo.sclera_hi, 0.6), graze);

        float g     = mix(sclera, irisV, inIr) + spec;
        fragColor   = vec4(vec3(g), 1.0);
    }

element ModelView
    # required at construction — the caller must provide it (null is a valid
    # explicit provision; the draw guard then reports the missing file)
    expect  model_path : path
    mutable vshader    : SkinnedLit
    mutable rshader    : RigidLit
    mutable cshader    : CorneaIR
    mutable vmodel     : Model
    mutable vrender    : Render
    mutable gmodel     : GltfModel
    mutable joint_buf  : Buffer
    mutable ibm        : array mat4f          # inverse bind matrices, one per joint
    mutable skin_idx   : i32 [ -1 ]
    mutable hinge_node : i32 [ -1 ]           # the node we rotate (the joint)
    mutable hinge_ang  : f32                  # joint angle, radians
    # eye rig (from the .blend): DAMPED_TRACK aims Eyeball +Y at the target;
    # Eyelids Drag copies 0.8 of eyeball pitch (X) + 0.2 of yaw (Z); Caruncle
    # copies 0.8 X + 0.5 Z. we drive those bones directly at those fractions.
    mutable ebl        : i32 [ -1 ]           # Eyeball.L node index
    mutable ebr        : i32 [ -1 ]           # Eyeball.R
    mutable dgl        : i32 [ -1 ]           # Eyelids Drag.L
    mutable dgr        : i32 [ -1 ]           # Eyelids Drag.R
    mutable crl        : i32 [ -1 ]           # Caruncle.L
    mutable crr        : i32 [ -1 ]           # Caruncle.R
    mutable ebl_rest   : quatf
    mutable ebr_rest   : quatf
    mutable dgl_rest   : quatf
    mutable dgr_rest   : quatf
    mutable crl_rest   : quatf
    mutable crr_rest   : quatf
    # eye spacing (IPD): nudge the eyeball globe bones apart, and let the
    # lid/socket skin follow via a one-time world-space vertex bake (falloff)
    mutable gbl        : i32 [ -1 ]           # Eyeball.L node (globe bone)
    mutable gbr        : i32 [ -1 ]           # Eyeball.R node (globe bone)
    mutable gbl_rest   : vec3f                # Eyeball.L rest translation
    mutable gbr_rest   : vec3f                # Eyeball.R rest translation
    mutable eye_spacing : f32 [ 0.0 ]         # per-eye outward shift, metres (derived)
    mutable span_mm    : f32 [ 91.0 ]         # outer-corner to outer-corner, mm
    mutable ir_on      : bool [ true ]        # near-IR look vs textured color
    mutable gaze_x     : f32                  # cyclopean eye yaw, radians
    mutable gaze_y     : f32                  # cyclopean eye pitch, radians
    mutable gaze_lx    : f32                  # per-eye angles: eyes CONVERGE
    mutable gaze_ly    : f32                  # on near targets, so each eye
    mutable gaze_rx    : f32                  # is solved from its own globe
    mutable gaze_ry    : f32
    mutable gdir_lx    : f32                  # unit gaze dir, head frame
    mutable gdir_ly    : f32
    mutable gdir_lz    : f32 [ 1.0 ]
    mutable gdir_rx    : f32
    mutable gdir_ry    : f32
    mutable gdir_rz    : f32 [ 1.0 ]
    mutable eye_dq_l   : quatf                # exact damped-track deltas
    mutable eye_dq_r   : quatf
    mutable head_rw    : mat4f                # Head Bone rest world rotation
    mutable tgt_x      : f32                  # interactive gaze mark (world;
    mutable tgt_y      : f32                  # z 0 = not placed yet)
    mutable tgt_z      : f32
    mutable yaw        : f32
    mutable pitch      : f32 [ 0.05 ]
    mutable dist       : f32 [ 3.5 ]
    mutable look_x     : f32
    mutable look_y     : f32 [ 1.0 ]
    mutable look_z     : f32
    mutable dragging   : bool
    mutable lastx      : f32
    mutable lasty      : f32
    mutable frame_n    : i32
    mutable last_press : i32 [ -100 ]         # frame of the last click (dbl-click)
    mutable rng2       : i64 [ 88172645463325252 ]  # control-cage deform seed
    # two-octave value-noise face maps (wavelength as fraction of face size)
    mutable n_large_wl  : f32 [ 1.2 ]         # large map wavelength (broad shape)
    mutable n_large_amp : f32 [ 0.03 ]        # large map magnitude
    mutable n_small_wl  : f32 [ 0.4 ]         # small map wavelength (detail)
    mutable n_small_amp : f32 [ 0.012 ]       # small map magnitude, added on top
    mutable n_tan_amp   : f32 [ 0.015 ]       # tangent-plane slide magnitude
    # training label: per control-cage vertex world-space delta the perlin applied
    mutable cage_delta  : @f32
    mutable cage_n      : i32 [ 0 ]           # control-cage vertex count
    # perlin-labeled export: capture two yaw angles + the cage-delta label
    mutable export_step : i32 [ 0 ]           # 0 idle; 3 arm; 1 cap-A; 2 cap-B
    mutable export_idx  : i32 [ 0 ]           # next sample number
    mutable export_yaw0 : f32 [ 0.0 ]         # yaw saved across the two shots
    mutable export_dyaw : f32 [ 0.3 ]         # half-angle between the two views
    mutable cap_a       : Image               # angle-A full frame, held to step 2
    mutable view_a      : mat4f               # angle-A view matrix snapshot
    mutable patch_px    : i32 [ 32 ]          # scan window size (the input patch)
    mutable scan_px     : i32 [ 128 ]         # full face render is scanned at this
    mutable patch_stride: i32 [ 16 ]          # window step (overlap for the blend)
    mutable pj          : @f32             # per-vert projections, 5 f32 each
    mutable pj_cap      : i32 [ 0 ]           # pj capacity in verts
    mutable recbuf      : @f32             # 6-float label record scratch
    mutable nose_gain  : f32 [ 0.03 ]         # nose scale from _V_NOSE mask
    # nose landmark fit (mm); defaults equal the model rest -> no-op until set
    mutable nostril_span : f32 [ 38.5 ]       # nostril edge-to-edge, x
    mutable mid_nose     : f32 [ 33.9 ]       # mid-nose width, x
    mutable nostril_y    : f32 [ 42.3 ]       # nostril below eye plane, y
    public  face_idx : i32                     # 0-3: which grid cell / variant
    mutable moved    : bool                    # drag vs click discriminator
    mutable nose_edited : bool                 # ctrl-drag touched the face
    mutable drag_mode : i32                    # ctrl-drag: 1 eye, 2 nose
    mutable press_x  : f32
    mutable press_y  : f32
    # last-baked fit values; when the parent picker feeds new landmarks the
    # mismatch triggers a rebuild so this face re-bakes to them
    mutable baked_fidx : i32 [ -999 ]         # face_idx last built (r-regen)
    mutable baked_span : f32 [ -1.0 ]
    mutable baked_nos  : f32 [ -1.0 ]
    mutable baked_mid  : f32 [ -1.0 ]
    mutable baked_ny   : f32 [ -1.0 ]
    mutable eye_tex : array Texture           # held eye maps, dropped on reload
    mutable morph_w    : map f32 [ string ]   # morph target name -> blend weight
    mutable subdiv_levels : i32 [ 2 ]         # trinity GPU Catmull-Clark levels (0 = off)
    # cage paint: click unprojects to the nearest control vert (pick_cage)
    mutable paint_radius : f32 [ 0.0 ]        # brush radius, model units
    mutable paint_amount : f32 [ 0.0 ]        # max vert move per scatter
    mutable picked_cage : i32 [ -1 ]          # last pick: cage index
    mutable picked_vert : i32 [ -1 ]          # last pick: control vert
    # outer-eye anchors: the coordinate frame for parametric cage edits.
    # the corners are pinned — no edit or click can ever move them
    mutable anch_set  : bool
    mutable anch_lx : f32
    mutable anch_ly : f32
    mutable anch_lz : f32
    mutable anch_rx : f32
    mutable anch_ry : f32
    mutable anch_rz : f32
    mutable anch_span : f32                   # outer corner to outer corner
    mutable head_ci : i32 [ -1 ]              # largest cage = head/body
    mutable eyec_lx : f32                     # eye globe centres (world)
    mutable eyec_ly : f32
    mutable eyec_lz : f32
    mutable eyec_rx : f32
    mutable eyec_ry : f32
    mutable eyec_rz : f32
    # plot capture: IR rig samples with screen-plot labels
    mutable cap_idx : i32 [ 0 ]               # next sample number
    mutable capture_left : i32 [ 0 ]          # samples remaining (0 = idle)
    mutable capture_state : i32 [ 0 ]         # 0 aim, 1 grab
    mutable clip_rejects : i32 [ 0 ]
    mutable cap_cam  : i32 [ 0 ]              # camera being captured now
    mutable cap_pl   : @f32                # per-camera plot fields, 9 each
    mutable cap_rec  : i32 [ -1 ]             # record whose pose this sample wears          # poses re-rolled for eye clip
    mutable anch_lci : i32 [ -1 ]             # corner CONTROL verts: live
    mutable anch_rci : i32 [ -1 ]             # positions feed the oc labels
    mutable anch_lii : i32 [ -1 ]             # inner corner control verts:
    mutable anch_rii : i32 [ -1 ]             # oc-ic midpoint = eye coord
    mutable cap_gw   : @f32                # lid group weights, 21 x nv
    mutable cap_gd   : @f32                # applied per-vert offsets, 21 x nv x 3
    mutable cap_gc   : @f32                # sector centroids, 21 x 2 sides x 3
    mutable cap_maw  : @f32                # whole-mesh anchor falloff, nv
    mutable cap_mp   : @f32                # applied mesh perlin, nv x 3
    mutable cap_nd   : @f32                # applied nose scramble, nv x 3
    mutable cap_fd   : @f32                # applied face scramble, nv x 3
    mutable cap_faw  : @f32                # face scramble falloff, nv
    mutable cap_ed   : @f32                # applied orbital scale, nv x 3
    mutable cap_gn   : i32                    # 0 unbuilt, -1 missing, 1 live
    # the model's inner tear duct runs big: per pose it scales to
    # 0.3..1.0 of modeled size (the globe covers the exposed slack)
    public  caruncle : f32 [ 1.0 ]
    mutable cap_carm : f32 [ 1.0 ]            # applied caruncle multiplier
    mutable cap_zamt : f32                    # per-pose lid z-follow amount
    mutable cap_lnamt : f32                   # per-pose perlin lid-push amount
    mutable cap_lnrad : f32                   # falloff outer radius, globe radii
    mutable cap_lnsd  : i64                   # perlin lid-push seed
    mutable cap_lnf   : @f32               # applied lid-push, backed out next pose
    # augmentation scale: perlin pushes the lid out along the look
    # direction near the pupil; 0 disables
    public  lid_noise : f32 [ 1.0 ]
    mutable cap_zf   : @f32                # applied z-follow, edn_n*2
    mutable cap_gseed : i64                   # pose-group seed anchor (replay)
    mutable cap_pseed : i64 [ 777 ]           # plot stream: advances across looks
    mutable cap_look_i : i32                  # look index within the pose group
    mutable cap_clean : bool                  # eval group: no augmentation
    mutable cap_camx : f32 [ 0.0 ]            # mount camera (IR lamp) world x
    mutable cap_camy : f32 [ 0.0 ]            # mount camera world y
    mutable cap_camz : f32 [ 0.0 ]            # mount camera world z
    mutable plot_u : f32                      # current plot, -0.5..0.5
    mutable plot_v : f32
    mutable cap_seed : i64 [ 987654321 ]      # plot random stream
    # per-sample head pose: rotation about the eye midpoint (world axes)
    mutable cap_hy : f32                      # head yaw
    mutable cap_hp : f32                      # head pitch
    mutable cap_hr : f32                      # head roll
    mutable cap_rot : mat4f                   # centered rotation matrix
    mutable cap_scx : f32                     # this sample's screen center
    mutable cap_scy : f32
    mutable cap_scz : f32
    mutable cap_tx : f32                      # this sample's gaze target
    mutable cap_ty : f32
    mutable cap_tz : f32
    # the eye bone's forward axis in ITS OWN frame, captured at rest (the
    # rest gaze is world +z). closes the aim loop against the real rig.
    mutable fwd_set : bool
    mutable fwd_lx : f32
    mutable fwd_ly : f32
    mutable fwd_lz : f32
    mutable fwd_rx : f32                      # right eye's own cornea axis
    mutable fwd_ry : f32
    mutable fwd_rz : f32
    mutable globe_rad : f32 [ 0.0126 ]        # eyeball radius, meters
    mutable eye_rest_w : mat4f                # eye bone rest world rotation
    # gaze-driven 'Eyes Down L/R' corrective morphs (Blender drives these
    # from eye pitch; glTF drops drivers, so the engine recreates the ramp)
    mutable edn_set  : bool
    mutable edn_n    : i32 [ 0 ]              # driven head-cage verts
    mutable edn_v    : @i32                # cage vert indices
    mutable edn_dl   : @f32                # Eyes Down L deltas
    mutable edn_dr   : @f32                # Eyes Down R deltas
    mutable edn_wl   : f32 [ 0.0 ]            # currently applied weights —
    mutable edn_wr   : f32 [ 0.0 ]            # morph is RELATIVE to the cage
    mutable eyes_down_full : f32 [ 0.5 ]      # radians down = full morph
    mutable meas_az : f32                     # measured actual gaze angles
    mutable meas_el : f32
    mutable fov_x : f32 [ 40.0 ]              # horizontal FOV, degrees
    # rig config source when hosted headless (no picker parent there)
    mutable rig : hyperspace2
    mutable eye_w   : @f32                 # _V_EYE influence per cage vert
    mutable nose_w  : @f32                 # _V_NOSE influence per cage vert
    mutable lip_w   : @f32                 # _V_LIP_UPPER influence per cage vert

    func init []
        animated  = true
        focusable = true
        morph_w   = map f32 [ string ] [ ]
        # drive morphs per-sample: morph_w[ 'Body Asian' ] = 1.0, etc.
        # this face is param-driven by the FacePicker parent; not focusable so
        # keys reach the picker (mouse orbit still works by position)
        focusable = false

    # the shared camera + A/B state live on the hyperspace2 app root parent.
    # type-checked: hosted headless, the parent is NOT the app root
    func picker [] -> hyperspace2
        if [ !parent ] return null
        return (parent inherits hyperspace2)

    public func on_press [ ev: Event ]
        moved = false
        press_x = ev.mouse.pos.x
        press_y = ev.mouse.pos.y
        dragging = true
        lastx = ev.mouse.pos.x
        lasty = ev.mouse.pos.y
        # shift-press picks the feature by PAINT, not geometry: the
        # nearest cage vertex to the cursor names its region by the
        # deepest painted weight there — eye slants, nose stretches,
        # lip drops. unpainted verts leave shift-drag as the pan
        drag_mode = 0
        if [ ev.key.shift && vmodel && head_ci >= 0 && vshader && eye_w && nose_w ]
            hc : vmodel.cages[ head_ci ]
            if [ hc && hc.cage_buf ]
                bp : @f32 [ hc.cage_buf.data ]
                vm : mat4f [ vshader.view ]
                pm : mat4f [ vshader.proj ]
                mx : f32 [ ev.mouse.pos.x - bounds.x ]
                my : f32 [ ev.mouse.pos.y - bounds.y ]
                best : f32 [ 1e18 ]
                bi : i32 [ -1 ]
                for [ v: i32 0, v < hc.nv, v += 1 ]
                    v3 : i32 [ v * 3 ]
                    vx : f32 [ vm.m[0]*bp[v3] + vm.m[4]*bp[v3+1] + vm.m[8]*bp[v3+2]  + vm.m[12] ]
                    vy : f32 [ vm.m[1]*bp[v3] + vm.m[5]*bp[v3+1] + vm.m[9]*bp[v3+2]  + vm.m[13] ]
                    vz : f32 [ vm.m[2]*bp[v3] + vm.m[6]*bp[v3+1] + vm.m[10]*bp[v3+2] + vm.m[14] ]
                    cxp : f32 [ pm.m[0]*vx + pm.m[4]*vy + pm.m[8]*vz  + pm.m[12] ]
                    cyp : f32 [ pm.m[1]*vx + pm.m[5]*vy + pm.m[9]*vz  + pm.m[13] ]
                    cwp : f32 [ pm.m[3]*vx + pm.m[7]*vy + pm.m[11]*vz + pm.m[15] ]
                    if [ cwp <= 0.0001 ] cwp = 0.0001
                    px5 : f32 [ (cxp / cwp + 1.0) * 0.5 * bounds.w ]
                    py5 : f32 [ (cyp / cwp + 1.0) * 0.5 * bounds.h ]
                    dd2 : f32 [ (px5 - mx)*(px5 - mx) + (py5 - my)*(py5 - my) ]
                    if [ dd2 < best ]
                        best = dd2
                        bi = v
                if [ bi >= 0 ]
                    we5 : f32 [ eye_w[ bi ] ]
                    wn5 : f32 [ nose_w[ bi ] ]
                    wl5 : f32 [ (lip_w) ? lip_w[ bi ] : 0.0 ]
                    if [ wn5 > 0.0 ] drag_mode = 2
                    if [ we5 > wn5 && we5 > wl5 && we5 > 0.0 ] drag_mode = 1
                    if [ wl5 > wn5 && wl5 > we5 && wl5 > 0.0 ] drag_mode = 3
        set_capture[]

    # a click (press+release without dragging) enters the cage A/B loop:
    # main view -> scatter proposals on the vote views; vote view -> merge
    # its cage back into the main. the root routes by face_idx.
    public func on_release [ ev: Event ]
        dragging = false
        release_capture[]
        # a nose gesture persists once, at release — not per move
        if [ nose_edited ]
            nose_edited = false
            fp2 : picker[]
            if [ fp2 ] fp2.save_mask[ a ]
        if [ !moved ]
            fp : picker[]
            if [ fp ] fp.cage_click[ a, ev.mouse.pos.x - bounds.x, ev.mouse.pos.y - bounds.y ]

    # outer eye corners: the eye node centres pushed one globe radius
    # outward. pins them on every cage and picks the head cage (largest)
    func setup_cage_anchors []
        if [ anch_set || !gmodel || !vmodel || !vmodel.cages ] return
        lcx : f32 [ 0.0 ]
        lcy : f32 [ 0.0 ]
        lcz : f32 [ 0.0 ]
        rcx : f32 [ 0.0 ]
        rcy : f32 [ 0.0 ]
        rcz : f32 [ 0.0 ]
        gotl : bool [ false ]
        gotr : bool [ false ]
        for [ nd: Node ] in gmodel.nodes
            if [ nd.name && nd.name == 'Eye.L' ]
                wl : mat4f [ nd.world ]
                lcx = wl.m[12]
                lcy = wl.m[13]
                lcz = wl.m[14]
                gotl = true
            if [ nd.name && nd.name == 'Eye.R' ]
                wr : mat4f [ nd.world ]
                rcx = wr.m[12]
                rcy = wr.m[13]
                rcz = wr.m[14]
                gotr = true
        if [ !gotl || !gotr ] return
        # globe radius from the Eyeball mesh x extent (fallback: human 12.6mm)
        eye_rad : f32 [ 0.0126 ]
        gxmin : f32 [  1000000.0 ]
        gxmax : f32 [ -1000000.0 ]
        gymin : f32 [  1000000.0 ]
        gymax : f32 [ -1000000.0 ]
        gotrad : bool [ false ]
        for [ emsh: Mesh ] in gmodel.meshes
            for [ eprim: Primitive ] in emsh.primitives
                emidx : i32 [ eprim.material ]
                emnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > emidx ]
                    emnm = gmodel.materials[ emidx ].name
                if [ emnm != 'Eyeball' ] continue
                epos_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in eprim.attributes
                    if [ a_name == 'POSITION' ] epos_ai = i32[ value[0] ]
                if [ epos_ai < 0 ] continue
                eac : gmodel.accessors[ epos_ai ]
                ebv : gmodel.bufferViews[ i32[ eac.bufferView ] ]
                ebb : gmodel.buffers[ i32[ ebv.buffer ] ]
                ebase : @i8 [ ebb.data ]
                estride : i64 [ eac.stride ]
                if [ ebv.byteStride > 0 ] estride = ebv.byteStride
                eoff : i64 [ ebv.byteOffset + eac.byteOffset ]
                evc : i32 [ i32[ eac.count ] ]
                for [ i: i32 0, i < evc, i += 1 ]
                    ef : @f32 [ ((@ebase[ eoff + i64[ i ] * estride ]) to @f32) ]
                    if [ ef[0] < gxmin ] gxmin = ef[0]
                    if [ ef[0] > gxmax ] gxmax = ef[0]
                    if [ ef[1] < gymin ] gymin = ef[1]
                    if [ ef[1] > gymax ] gymax = ef[1]
                    gotrad = true
        if [ gotrad ] eye_rad = (gxmax - gxmin) * 0.5
        # globe centre sits below the bone origin: the mesh vertices are
        # per-globe local, so their y midpoint is the bone->centre offset
        ycen : f32 [ 0.0 ]
        if [ gotrad ] ycen = (gymin + gymax) * 0.5
        puts 'hyperspace2: eye globe rad={eye_rad}m bone->centre y offset={ycen}m'
        eyec_lx = lcx
        eyec_ly = lcy + ycen
        eyec_lz = lcz
        eyec_rx = rcx
        eyec_ry = rcy + ycen
        eyec_rz = rcz
        anch_lx = lcx + ((lcx >= rcx) ? eye_rad : (0.0 - eye_rad))
        anch_ly = lcy + ycen
        anch_lz = lcz
        anch_rx = rcx + ((rcx > lcx) ? eye_rad : (0.0 - eye_rad))
        anch_ry = rcy + ycen
        anch_rz = rcz
        # painted TRUE outer corners: _V_EYE red > 0.75 marks exactly one
        # skin vert per side (the lateral canthus). the radius-push above
        # floats beside the eye — not on skin, not inferrable — and stays
        # only as the fallback for unpainted models
        bl4 : f32 [ 0.75 ]
        br4 : f32 [ 0.75 ]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                mnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > midx ]
                    mnm = gmodel.materials[ midx ].name
                if [ mnm != 'Head' ] continue
                r_ai : i32 [ -1 ]
                p_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == '_V_EYE' ] r_ai = i32[ value[0] ]
                    if [ a_name == 'POSITION' ] p_ai = i32[ value[0] ]
                if [ r_ai < 0 || p_ai < 0 ] continue
                rac : gmodel.accessors[ r_ai ]
                rbv : gmodel.bufferViews[ i32[ rac.bufferView ] ]
                rbb : gmodel.buffers[ i32[ rbv.buffer ] ]
                rbase : @i8 [ rbb.data ]
                rstride : i64 [ rac.stride ]
                if [ rbv.byteStride > 0 ] rstride = rbv.byteStride
                roff : i64 [ rbv.byteOffset + rac.byteOffset ]
                pac2 : gmodel.accessors[ p_ai ]
                pbv2 : gmodel.bufferViews[ i32[ pac2.bufferView ] ]
                pbb2 : gmodel.buffers[ i32[ pbv2.buffer ] ]
                pbs2 : @i8 [ pbb2.data ]
                pst2 : i64 [ pac2.stride ]
                if [ pbv2.byteStride > 0 ] pst2 = pbv2.byteStride
                pof2 : i64 [ pbv2.byteOffset + pac2.byteOffset ]
                vc4 : i32 [ i32[ pac2.count ] ]
                for [ i: i32 0, i < vc4, i += 1 ]
                    cu : @u16 [ ((@rbase[ roff + i64[ i ] * rstride ]) to @u16) ]
                    red : f32 [ f32[ cu[0] ] / 65535.0 ]
                    if [ red <= 0.75 ] continue
                    pv4 : @f32 [ ((@pbs2[ pof2 + i64[ i ] * pst2 ]) to @f32) ]
                    dl4 : f32 [ (pv4[0]-lcx)*(pv4[0]-lcx) + (pv4[1]-lcy)*(pv4[1]-lcy) + (pv4[2]-lcz)*(pv4[2]-lcz) ]
                    dr4 : f32 [ (pv4[0]-rcx)*(pv4[0]-rcx) + (pv4[1]-rcy)*(pv4[1]-rcy) + (pv4[2]-rcz)*(pv4[2]-rcz) ]
                    if [ dl4 < dr4 ]
                        if [ red > bl4 ]
                            bl4 = red
                            anch_lx = pv4[0]
                            anch_ly = pv4[1]
                            anch_lz = pv4[2]
                    el
                        if [ red > br4 ]
                            br4 = red
                            anch_rx = pv4[0]
                            anch_ry = pv4[1]
                            anch_rz = pv4[2]
        if [ bl4 > 0.75 && br4 > 0.75 ]
            puts 'anchors: painted canthus corners L=({anch_lx},{anch_ly},{anch_lz}) R=({anch_rx},{anch_ry},{anch_rz})'
        el
            puts 'anchors: no painted corners (_V_EYE red) — radius-push fallback'
        sdx : f32 [ anch_lx - anch_rx ]
        sdy : f32 [ anch_ly - anch_ry ]
        sdz : f32 [ anch_lz - anch_rz ]
        anch_span = sqrt[ sdx*sdx + sdy*sdy + sdz*sdz ]
        # pin both corners on every cage; pick the largest cage as the head
        best_ext : f32 [ 0.0 ]
        for [ ci: i32 0, ci < vmodel.cages.count, ci += 1 ]
            vmodel.cage_pin[ ci, anch_lx, anch_ly, anch_lz, anch_span * 0.04, anch_span * 0.10 ]
            vmodel.cage_pin[ ci, anch_rx, anch_ry, anch_rz, anch_span * 0.04, anch_span * 0.10 ]
            t : vmodel.cages[ ci ]
            if [ !t.base ] continue
            bmn : f32 [  1e30 ]
            bmx : f32 [ -1e30 ]
            n3 : i32 [ t.nv * 3 ]
            for [ i: i32 0, i < n3, i += 1 ]
                if [ t.base[ i ] < bmn ] bmn = t.base[ i ]
                if [ t.base[ i ] > bmx ] bmx = t.base[ i ]
            if [ bmx - bmn > best_ext ]
                best_ext = bmx - bmn
                head_ci = ci
        anch_set = true
        # track each corner's CONTROL VERT so labels project the LIVE
        # deformed position — the plot must match the rendered pixel
        # even after cage edits, morphs and face variance
        if [ head_ci >= 0 ]
            hc0 : vmodel.cages[ head_ci ]
            if [ hc0 && hc0.cage_buf ]
                cb0 : @f32 [ hc0.cage_buf.data ]
                # inner corners: the oc reflected through the globe centre
                # (the lid_weights ic estimate) snapped to its nearest vert
                iex : f32 [ eyec_lx + (eyec_lx - anch_lx) ]
                iey : f32 [ eyec_ly ]
                iez : f32 [ eyec_lz ]
                jex : f32 [ eyec_rx + (eyec_rx - anch_rx) ]
                jey : f32 [ eyec_ry ]
                jez : f32 [ eyec_rz ]
                bdl0 : f32 [ 1e30 ]
                bdr0 : f32 [ 1e30 ]
                bdl1 : f32 [ 1e30 ]
                bdr1 : f32 [ 1e30 ]
                for [ v0: i32 0, v0 < hc0.nv, v0 += 1 ]
                    v30 : i32 [ v0 * 3 ]
                    dl0 : f32 [ (cb0[v30]-anch_lx)*(cb0[v30]-anch_lx) + (cb0[v30+1]-anch_ly)*(cb0[v30+1]-anch_ly) + (cb0[v30+2]-anch_lz)*(cb0[v30+2]-anch_lz) ]
                    dr0 : f32 [ (cb0[v30]-anch_rx)*(cb0[v30]-anch_rx) + (cb0[v30+1]-anch_ry)*(cb0[v30+1]-anch_ry) + (cb0[v30+2]-anch_rz)*(cb0[v30+2]-anch_rz) ]
                    dl1 : f32 [ (cb0[v30]-iex)*(cb0[v30]-iex) + (cb0[v30+1]-iey)*(cb0[v30+1]-iey) + (cb0[v30+2]-iez)*(cb0[v30+2]-iez) ]
                    dr1 : f32 [ (cb0[v30]-jex)*(cb0[v30]-jex) + (cb0[v30+1]-jey)*(cb0[v30+1]-jey) + (cb0[v30+2]-jez)*(cb0[v30+2]-jez) ]
                    if [ dl0 < bdl0 ]
                        bdl0 = dl0
                        anch_lci = v0
                    if [ dr0 < bdr0 ]
                        bdr0 = dr0
                        anch_rci = v0
                    if [ dl1 < bdl1 ]
                        bdl1 = dl1
                        anch_lii = v0
                    if [ dr1 < bdr1 ]
                        bdr1 = dr1
                        anch_rii = v0
        # eye-bone forward in bone frame: at rest the gaze is world +z, so
        # forward_local = R_rest^T * z (rows of the rest world rotation)
        ei : i32 [ (ebl >= 0) ? ebl : ebr ]
        if [ ei >= 0 ]
            nbf : gmodel.nodes[ ei ]
            wf : mat4f [ nbf.world ]
            # per-eye TRUE forward from each eyeball's own corneal apex
            fit_eye_axis[ true ]
            fit_eye_axis[ false ]
            fwd_set = true
            globe_rad = eye_rad
            eye_rest_w = wf
            # Head Bone rest rotation: peel the eye's local rest off its
            # world — the damped-track arc is computed in this frame
            rrq : quatf [ ebl_rest ]
            if [ ebl < 0 ] rrq = ebr_rest
            qcr : quatf [ qconj[ rrq ] ]
            head_rw = wf.rotate[ qcr ]
            eye_dq_l = delta_q[ 0.0, 0.0 ]
            eye_dq_r = delta_q[ 0.0, 0.0 ]
        puts 'anchors: span={anch_span} head_cage={head_ci} L=({anch_lx},{anch_ly},{anch_lz})'
        eye_w  = region_weights[ '_V_EYE' ]
        nose_w = region_weights[ '_V_NOSE' ]
        lip_w  = region_weights[ '_V_LIP_UPPER' ]
        setup_eyes_down[]

    # influence of a painted _V_* vertex color, per welded head-cage vert.
    # mid gray (0.216 linear = 0.5 paint) is the zero point; the blue channel
    # carries influence up to 1.0. sampled at each cage vert's source vert.
    func region_weights [ rname: string ] -> @f32
        if [ head_ci < 0 || !vmodel || !gmodel ] return null
        hc : vmodel.cages[ head_ci ]
        if [ !hc.rep ] return null
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                mnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > midx ]
                    mnm = gmodel.materials[ midx ].name
                if [ mnm != 'Head' ] continue
                r_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == rname ] r_ai = i32[ value[0] ]
                if [ r_ai < 0 ] continue
                rac : gmodel.accessors[ r_ai ]
                rbv : gmodel.bufferViews[ i32[ rac.bufferView ] ]
                rbb : gmodel.buffers[ i32[ rbv.buffer ] ]
                rbase : @i8 [ rbb.data ]
                rstride : i64 [ rac.stride ]
                if [ rbv.byteStride > 0 ] rstride = rbv.byteStride
                roff : i64 [ rbv.byteOffset + rac.byteOffset ]
                nvw : i32 [ hc.nv ]
                wout : new f32 [ nvw ]
                non0 : i32 [ 0 ]
                for [ v: i32 0, v < hc.nv, v += 1 ]
                    sv2 : i32 [ hc.rep[ v ] ]
                    pu : @u16 [ ((@rbase[ roff + i64[ sv2 ] * rstride ]) to @u16) ]
                    wv : f32 [ ((f32[ pu[2] ] / 65535.0) - 0.216) / 0.784 ]
                    # _V_NOSE selection convention: blue 0.5..1.0 -> 0..1,
                    # anything at or below 0.5 is unselected
                    if [ rname == '_V_NOSE' ]
                        wv = ((f32[ pu[2] ] / 65535.0) - 0.5) / 0.5
                    if [ wv < 0.03 ] wv = 0.0
                    if [ wv > 1.0 ] wv = 1.0
                    wout[ v ] = wv
                    if [ wv > 0.0 ] non0 += 1
                puts 'region {rname}: {non0}/{hc.nv} cage verts weighted'
                return wout
        puts 'region {rname}: not found on the Head primitive'
        return null

    # nose length: stretch the painted _V_NOSE region along the nose's own
    # slant axis — bridge (between the anchors) toward the base landmark
    # (blender 0,-0.119,1.57 -> gltf 0,1.57,0.119), down and forward. the
    # tip carries the length, the bridge end stays.
    public func nose_length [ d: f32 ]
        if [ !anch_set || !vmodel || !nose_w ] return
        pxm : f32 [ (anch_lx + anch_rx) * 0.5 ]
        pym : f32 [ (anch_ly + anch_ry) * 0.5 ]
        pzm : f32 [ (anch_lz + anch_rz) * 0.5 ]
        # noses grow DOWN at a standard angle off the face plane (~30
        # degrees forward of straight down), from the bridge pivot
        nang : f32 [ radians[ 30.0 ] ]
        axx : f32 [ 0.0 ]
        axy : f32 [ 0.0 - cos[ nang ] ]
        axz : f32 [ sin[ nang ] ]
        hc : vmodel.cages[ head_ci ]
        hc.wmap = nose_w
        vmodel.cage_stretch_axis[ head_ci, pxm, pym, pzm, axx, axy, axz, d ]

    # painted lid group weights: blue joins the group at > 0.5, and
    # LESS blue = MORE offset (deep blue anchors, 0.5 travels fully)
    func lid_weights [ rname: string ] -> @f32
        if [ head_ci < 0 || !vmodel || !gmodel ] return null
        hc : vmodel.cages[ head_ci ]
        if [ !hc.rep ] return null
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                mnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > midx ]
                    mnm = gmodel.materials[ midx ].name
                if [ mnm != 'Head' ] continue
                r_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == rname ] r_ai = i32[ value[0] ]
                if [ r_ai < 0 ] continue
                rac : gmodel.accessors[ r_ai ]
                rbv : gmodel.bufferViews[ i32[ rac.bufferView ] ]
                rbb : gmodel.buffers[ i32[ rbv.buffer ] ]
                rbase : @i8 [ rbb.data ]
                rstride : i64 [ rac.stride ]
                if [ rbv.byteStride > 0 ] rstride = rbv.byteStride
                roff : i64 [ rbv.byteOffset + rac.byteOffset ]
                nvw : i32 [ hc.nv ]
                wout : new f32 [ nvw ]
                non0 : i32 [ 0 ]
                for [ v: i32 0, v < hc.nv, v += 1 ]
                    sv2 : i32 [ hc.rep[ v ] ]
                    pu : @u16 [ ((@rbase[ roff + i64[ sv2 ] * rstride ]) to @u16) ]
                    bb : f32 [ f32[ pu[2] ] / 65535.0 ]
                    # deeper blue = MORE travel (the _V_NOSE convention),
                    # joining at blue > 0.5. corner pins always win:
                    # the oc anchors are truth and never ride the groups
                    wv : f32 [ (bb - 0.5) / 0.5 ]
                    if [ wv < 0.0 ] wv = 0.0
                    if [ wv > 1.0 ] wv = 1.0
                    if [ hc.pin ] wv = wv * (1.0 - hc.pin[ v ])
                    # hard zero near all four corner anchors (oc + ic)
                    if [ wv > 0.0 && hc.base && anch_set ]
                        vb3 : i32 [ v * 3 ]
                        vbx : f32 [ hc.base[ vb3 ] ]
                        vby : f32 [ hc.base[ vb3 + 1 ] ]
                        vbz : f32 [ hc.base[ vb3 + 2 ] ]
                        dm5 : f32 [ 1e30 ]
                        for [ p5: i32 0, p5 < 4, p5 += 1 ]
                            ax5 : f32 [ anch_lx ]
                            ay5 : f32 [ anch_ly ]
                            az5 : f32 [ anch_lz ]
                            if [ p5 == 1 ]
                                ax5 = anch_rx
                                ay5 = anch_ry
                                az5 = anch_rz
                            if [ p5 == 2 ]
                                ax5 = eyec_lx + (eyec_lx - anch_lx)
                                ay5 = eyec_ly
                                az5 = eyec_lz
                            if [ p5 == 3 ]
                                ax5 = eyec_rx + (eyec_rx - anch_rx)
                                ay5 = eyec_ry
                                az5 = eyec_rz
                            dx5 : f32 [ vbx - ax5 ]
                            dy5 : f32 [ vby - ay5 ]
                            dz5 : f32 [ vbz - az5 ]
                            dd5 : f32 [ sqrt[ dx5*dx5 + dy5*dy5 + dz5*dz5 ] ]
                            if [ dd5 < dm5 ] dm5 = dd5
                        wf5 : f32 [ (dm5 / globe_rad - 0.5) / 0.9 ]
                        if [ wf5 < 0.0 ] wf5 = 0.0
                        if [ wf5 > 1.0 ] wf5 = 1.0
                        wv = wv * wf5
                    wout[ v ] = wv
                    if [ wv > 0.0 ] non0 += 1
                # the paint lives on ONE side of the face: mirror the
                # weights across X — the painted vert of each pair wins
                if [ hc.base ]
                    for [ v6: i32 0, v6 < hc.nv, v6 += 1 ]
                        if [ wout[ v6 ] > 0.0 ] continue
                        b63 : i32 [ v6 * 3 ]
                        mx6 : f32 [ 0.0 - hc.base[ b63 ] ]
                        my6 : f32 [ hc.base[ b63 + 1 ] ]
                        mz6 : f32 [ hc.base[ b63 + 2 ] ]
                        for [ u6: i32 0, u6 < hc.nv, u6 += 1 ]
                            if [ wout[ u6 ] <= 0.0 ] continue
                            u63 : i32 [ u6 * 3 ]
                            adx : f32 [ hc.base[ u63 ] - mx6 ]
                            if [ adx < -0.0008 || adx > 0.0008 ] continue
                            ady : f32 [ hc.base[ u63 + 1 ] - my6 ]
                            if [ ady < -0.0008 || ady > 0.0008 ] continue
                            adz : f32 [ hc.base[ u63 + 2 ] - mz6 ]
                            if [ adz < -0.0008 || adz > 0.0008 ] continue
                            wout[ v6 ] = wout[ u6 ]
                            non0 += 1
                            break
                puts 'lid group {rname}: {non0}/{hc.nv} cage verts (mirrored)'
                return wout
        return null

    # upper lip: drop the painted _V_LIP_UPPER region straight down from
    # the bridge pivot — drag down = longer eye-to-lip distance
    public func lip_drop [ d: f32 ]
        if [ !anch_set || !vmodel || !lip_w ] return
        pxm : f32 [ (anch_lx + anch_rx) * 0.5 ]
        pym : f32 [ (anch_ly + anch_ry) * 0.5 ]
        pzm : f32 [ (anch_lz + anch_rz) * 0.5 ]
        hc : vmodel.cages[ head_ci ]
        hc.wmap = lip_w
        vmodel.cage_stretch_axis[ head_ci, pxm, pym, pzm, 0.0, -1.0, 0.0, d ]

    # eye size: mirrored scale about the fixed outer corners — the inner
    # side carries the change, so no inner-corner annotation is needed
    public func eye_size [ d: f32 ]
        if [ !anch_set || !vmodel || !eye_w ] return
        hc : vmodel.cages[ head_ci ]
        hc.wmap = eye_w
        vmodel.cage_scale_w[ head_ci, anch_lx, anch_ly, anch_lz, d ]

    # eye slant: rotate the painted _V_EYE region about the OUTER corner in
    # the face plane; the mirrored rotation slants the other eye with it
    public func eye_slant [ d: f32 ]
        if [ !anch_set || !vmodel || !eye_w ] return
        hc : vmodel.cages[ head_ci ]
        hc.wmap = eye_w
        vmodel.cage_rotate_w[ head_ci, anch_lx, anch_ly, anch_lz, 0.0, 0.0, 1.0, d ]

    # aim ONE eye at the target from ITS OWN globe centre — the rig's
    # DAMPED_TRACK onto the Eye Target mark, done exactly: the bone's
    # rest forward is rotated onto the eye->mark line by a shortest-arc
    # quat in the Head Bone frame. no iteration, no residual.
    func solve_eye [ ei: i32, ex: f32, ey: f32, ez: f32, tx: f32, ty: f32, tz: f32, is_l: bool, free: bool ] -> bool
        # the head pose moves this eye about the pair midpoint: aim from
        # the eye's POSED position, not its rest position
        epx : f32 [ cap_rot.m[0]*ex + cap_rot.m[4]*ey + cap_rot.m[8]*ez  + cap_rot.m[12] ]
        epy : f32 [ cap_rot.m[1]*ex + cap_rot.m[5]*ey + cap_rot.m[9]*ez  + cap_rot.m[13] ]
        epz : f32 [ cap_rot.m[2]*ex + cap_rot.m[6]*ey + cap_rot.m[10]*ez + cap_rot.m[14] ]
        dvx : f32 [ tx - epx ]
        dvy : f32 [ ty - epy ]
        dvz : f32 [ tz - epz ]
        # into the head frame (cap_rot transpose for directions)
        dlx : f32 [ cap_rot.m[0]*dvx + cap_rot.m[1]*dvy + cap_rot.m[2]*dvz ]
        dly : f32 [ cap_rot.m[4]*dvx + cap_rot.m[5]*dvy + cap_rot.m[6]*dvz ]
        dlz : f32 [ cap_rot.m[8]*dvx + cap_rot.m[9]*dvy + cap_rot.m[10]*dvz ]
        if [ dlz < 0.01 ] return false
        dll : f32 [ sqrt[ dlx*dlx + dly*dly + dlz*dlz ] ]
        dlx = dlx / dll
        dly = dly / dll
        dlz = dlz / dll
        gxd : f32 [ atan[ (0.0 - dlx) / dlz ] ]
        gyd : f32 [ 0.0 - atan[ dly / sqrt[ dlx*dlx + dlz*dlz ] ] ]
        if [ !free ]
            if [ gxd >  0.6 || gxd < -0.6 ] return false
            if [ gyd >  0.5 || gyd < -0.5 ] return false
        # model-space direction -> Head Bone frame (rotation transpose)
        dpx : f32 [ head_rw.m[0]*dlx + head_rw.m[1]*dly + head_rw.m[2]*dlz ]
        dpy : f32 [ head_rw.m[4]*dlx + head_rw.m[5]*dly + head_rw.m[6]*dlz ]
        dpz : f32 [ head_rw.m[8]*dlx + head_rw.m[9]*dly + head_rw.m[10]*dlz ]
        # rest forward in the same frame: R(rest) applied to the eye's
        # OWN corneal axis (the visible iris direction, not a +Y proxy)
        rq : quatf [ (is_l) ? ebl_rest : ebr_rest ]
        rm : mat4f [ mat4f.identity[] ]
        rm = rm.rotate[ rq ]
        fbx : f32 [ (is_l) ? fwd_lx : fwd_rx ]
        fby : f32 [ (is_l) ? fwd_ly : fwd_ry ]
        fbz : f32 [ (is_l) ? fwd_lz : fwd_rz ]
        fpx : f32 [ rm.m[0]*fbx + rm.m[4]*fby + rm.m[8]*fbz ]
        fpy : f32 [ rm.m[1]*fbx + rm.m[5]*fby + rm.m[9]*fbz ]
        fpz : f32 [ rm.m[2]*fbx + rm.m[6]*fby + rm.m[10]*fbz ]
        dq : quatf [ arc_q[ fpx, fpy, fpz, dpx, dpy, dpz ] ]
        # gaze angles stored in delta_q convention for the lid/caruncle
        # drives: measured, delta_q(+a) lands the bone at -a, so the
        # drive angles are the NEGATED measure-convention target angles
        if [ is_l ]
            eye_dq_l = dq
            gaze_lx = 0.0 - gxd
            gaze_ly = 0.0 - gyd
            # unit gaze dir in the head frame: the pupil label projects
            # from eye centre + this * globe_rad
            gdir_lx = dlx
            gdir_ly = dly
            gdir_lz = dlz
        el
            eye_dq_r = dq
            gaze_rx = 0.0 - gxd
            gaze_ry = 0.0 - gyd
            gdir_rx = dlx
            gdir_ry = dly
            gdir_rz = dlz
        # honesty gate through the real bones: the measured forward must
        # land on the target (catches any frame mistake at zero cost)
        if [ fwd_set ]
            measure_gaze[ ei ]
            ra : f32 [ gxd - meas_az ]
            re : f32 [ gyd - meas_el ]
            puts 'solve_eye L={is_l} want az={gxd} el={gyd} got az={meas_az} el={meas_el}'
            if [ ra > 0.01 || ra < -0.01 || re > 0.01 || re < -0.01 ] return false
        el
            puts 'solve_eye L={is_l} UNGATED (fwd_set false) az={gxd} el={gyd}'
        return true

    # aim the eyes at screen plot (u,v) — or refuse. the target must be
    # within the eyes' mechanical range (same limits as the arrow keys);
    # nothing is clamped, so a saved label is always a true fixation.
    # returns false when this plot is unreachable from the current pose.
    func aim_at_plot [ fp: hyperspace2, u: f32, v: f32 ] -> bool
        tx : f32 [ cap_scx - u * fp.screen_w ]
        ty : f32 [ cap_scy - v * fp.screen_h ]
        tz : f32 [ cap_scz ]
        okl : bool [ true ]
        okr : bool [ true ]
        if [ ebl >= 0 ] okl = solve_eye[ ebl, eyec_lx, eyec_ly, eyec_lz, tx, ty, tz, true, fp.free_gaze ]
        if [ ebr >= 0 ] okr = solve_eye[ ebr, eyec_rx, eyec_ry, eyec_rz, tx, ty, tz, false, fp.free_gaze ]
        if [ !okl || !okr ] return false
        # cyclopean pair: drives the lids and the opening-centre plots
        gaze_x = (gaze_lx + gaze_rx) * 0.5
        gaze_y = (gaze_ly + gaze_ry) * 0.5
        cap_tx = tx
        cap_ty = ty
        cap_tz = tz
        return true

    # ONE eye's ACTUAL gaze angles (head frame) for its current aim:
    # pose the bones, recompose worlds, read that eye's cornea axis
    func measure_gaze [ ei: i32 ]
        aim_eyes[]
        gmodel.compute_worlds[]
        nb2 : gmodel.nodes[ ei ]
        wm2 : mat4f [ nb2.world ]
        fx4 : f32 [ (ei == ebl) ? fwd_lx : fwd_rx ]
        fy4 : f32 [ (ei == ebl) ? fwd_ly : fwd_ry ]
        fz4 : f32 [ (ei == ebl) ? fwd_lz : fwd_rz ]
        axw : f32 [ wm2.m[0]*fx4 + wm2.m[4]*fy4 + wm2.m[8]*fz4 ]
        ayw : f32 [ wm2.m[1]*fx4 + wm2.m[5]*fy4 + wm2.m[9]*fz4 ]
        azw : f32 [ wm2.m[2]*fx4 + wm2.m[6]*fy4 + wm2.m[10]*fz4 ]
        if [ azw < 0.01 ] azw = 0.01
        meas_az = atan[ (0.0 - axw) / azw ]
        meas_el = 0.0 - atan[ ayw / sqrt[ axw*axw + azw*azw ] ]

    # save one plot sample in the hyperspace .agi format: a 3:2 face frame,
    # 3:2 crops around both eyes, and {i}.agi carrying the plots. eye-center
    # plots are the RESTING globe centers (the socket middle — gaze rotates
    # about them, so they hold still), _oc are the outer corners. face_off
    # is the face->screen-center offset in meters (person frame: +x right,
    # +y up, +z toward the person).
    func save_plot_sample [ fp: hyperspace2, cam: i32 ] -> bool
        gw : i32 [ vrender.width ]
        gh : i32 [ vrender.height ]
        # SQUARE frame at full render resolution, like the IR sensor —
        # python crops and averages from this, the app never reduces
        fw2 : i32 [ (gw < gh) ? gw : gh ]
        fh2 : i32 [ fw2 ]
        fx : i32 [ (gw - fw2) / 2 ]
        fy : i32 [ (gh - fh2) / 2 ]
        # eye plots = the RESTING globe centers, gaze-INDEPENDENT by
        # contract: the crop anchor must hold still so the iris MOVES
        # within the crop — that displacement IS the gaze signal. a
        # gaze-following anchor (tried: lid-dragged opening centers)
        # cancels the signal out of the pixels and nothing can train
        # slots 4/5: the PUPIL centres — globe centre pushed along the
        # solved gaze direction to the surface (head frame, like the rest)
        pplx : f32 [ eyec_lx + gdir_lx * globe_rad ]
        pply : f32 [ eyec_ly + gdir_ly * globe_rad ]
        pplz : f32 [ eyec_lz + gdir_lz * globe_rad ]
        pprx : f32 [ eyec_rx + gdir_rx * globe_rad ]
        ppry : f32 [ eyec_ry + gdir_ry * globe_rad ]
        pprz : f32 [ eyec_rz + gdir_rz * globe_rad ]
        wxs : local f32 [ 6 ] [ eyec_lx, eyec_rx, anch_lx, anch_rx, pplx, pprx ]
        wys : local f32 [ 6 ] [ eyec_ly, eyec_ry, anch_ly, anch_ry, pply, ppry ]
        wzs : local f32 [ 6 ] [ eyec_lz, eyec_rz, anch_lz, anch_rz, pplz, pprz ]
        # outer corners project from their LIVE control verts, so the
        # label lands on the rendered pixel under any deformation
        ilx : f32 [ eyec_lx + (eyec_lx - anch_lx) ]
        ily : f32 [ eyec_ly ]
        ilz : f32 [ eyec_lz ]
        irx : f32 [ eyec_rx + (eyec_rx - anch_rx) ]
        iry : f32 [ eyec_ry ]
        irz : f32 [ eyec_rz ]
        if [ anch_lci >= 0 && head_ci >= 0 ]
            hc7 : vmodel.cages[ head_ci ]
            if [ hc7 && hc7.cage_buf ]
                cb7 : @f32 [ hc7.cage_buf.data ]
                wxs[2] = cb7[ anch_lci * 3 + 0 ]
                wys[2] = cb7[ anch_lci * 3 + 1 ]
                wzs[2] = cb7[ anch_lci * 3 + 2 ]
                wxs[3] = cb7[ anch_rci * 3 + 0 ]
                wys[3] = cb7[ anch_rci * 3 + 1 ]
                wzs[3] = cb7[ anch_rci * 3 + 2 ]
                if [ anch_lii >= 0 ]
                    ilx = cb7[ anch_lii * 3 + 0 ]
                    ily = cb7[ anch_lii * 3 + 1 ]
                    ilz = cb7[ anch_lii * 3 + 2 ]
                    irx = cb7[ anch_rii * 3 + 0 ]
                    iry = cb7[ anch_rii * 3 + 1 ]
                    irz = cb7[ anch_rii * 3 + 2 ]
        pxs : local f32 [ 6 ]
        pys : local f32 [ 6 ]
        vm : mat4f [ vshader.view ]
        pm : mat4f [ vshader.proj ]
        for [ k: i32 0, k < 6, k += 1 ]
            wx0 : f32 [ wxs[ k ] ]
            wy0 : f32 [ wys[ k ] ]
            wz0 : f32 [ wzs[ k ] ]
            # apply the sample's head pose (rotation about the eye midpoint)
            px : f32 [ cap_rot.m[0]*wx0 + cap_rot.m[4]*wy0 + cap_rot.m[8]*wz0  + cap_rot.m[12] ]
            py : f32 [ cap_rot.m[1]*wx0 + cap_rot.m[5]*wy0 + cap_rot.m[9]*wz0  + cap_rot.m[13] ]
            pz : f32 [ cap_rot.m[2]*wx0 + cap_rot.m[6]*wy0 + cap_rot.m[10]*wz0 + cap_rot.m[14] ]
            vx : f32 [ vm.m[0]*px + vm.m[4]*py + vm.m[8]*pz  + vm.m[12] ]
            vy : f32 [ vm.m[1]*px + vm.m[5]*py + vm.m[9]*pz  + vm.m[13] ]
            vz : f32 [ vm.m[2]*px + vm.m[6]*py + vm.m[10]*pz + vm.m[14] ]
            cxp : f32 [ pm.m[0]*vx + pm.m[4]*vy + pm.m[8]*vz  + pm.m[12] ]
            cyp : f32 [ pm.m[1]*vx + pm.m[5]*vy + pm.m[9]*vz  + pm.m[13] ]
            cwp : f32 [ pm.m[3]*vx + pm.m[7]*vy + pm.m[11]*vz + pm.m[15] ]
            if [ cwp <= 0.0001 ] cwp = 0.0001
            pxs[ k ] = (cxp / cwp + 1.0) * 0.5 * f32[ gw ]
            pys[ k ] = (cyp / cwp + 1.0) * 0.5 * f32[ gh ]
        # CLIP GATE: the eye crop python takes is a square of side
        # inter-eye-distance / eye_div (2.12), centered on each eye center.
        # if either crop would leave the frame, the sample lies — reject it
        # BEFORE any file is written and let the caller re-roll the pose
        edx : f32 [ pxs[0] - pxs[1] ]
        edy : f32 [ pys[0] - pys[1] ]
        esep : f32 [ sqrt[ edx*edx + edy*edy ] ]
        emrg : f32 [ esep * 0.30 ]
        exlo : f32 [ f32[ fx ] + emrg ]
        exhi : f32 [ f32[ fx + fw2 ] - emrg ]
        eylo : f32 [ f32[ fy ] + emrg ]
        eyhi : f32 [ f32[ fy + fh2 ] - emrg ]
        for [ k: i32 0, k < 2, k += 1 ]
            if [ pxs[ k ] < exlo || pxs[ k ] > exhi ] return false
            if [ pys[ k ] < eylo || pys[ k ] > eyhi ] return false
        mkdir[ '/src/hyperspace-sessions', 493 ]
        sdir : '/src/hyperspace-sessions/{fp.session}'
        mkdir[ sdir.chars, 493 ]
        # the render is a mirror view; real camera output is unmirrored
        # (subject's left eye on the image's right, like basic4) and MONO,
        # like the IR sensor. keep rgba here: the alpha plane is the mask
        # the record frame composites under
        cap : Image [ vrender.color ]
        cimg : cap.crop[ fx, fy, fw2, fh2 ]
        mcap : cimg.mirror_x[]
        # no eye-crop files: the eyes are ANNOTATED in the face image by the
        # plots below. ZERO-CENTERED image coords: (0,0) is the image center,
        # -0.5 left/top, +0.5 right/bottom — same convention as the screen
        # plots. x mirrored with the image. (basic4 real data is 0..1: shift
        # it by -0.5 in the loader to match.)
        flx : f32 [ 0.5 - (pxs[0] - f32[ fx ]) / f32[ fw2 ] ]
        fly : f32 [ (pys[0] - f32[ fy ]) / f32[ fh2 ] - 0.5 ]
        frx : f32 [ 0.5 - (pxs[1] - f32[ fx ]) / f32[ fw2 ] ]
        fry : f32 [ (pys[1] - f32[ fy ]) / f32[ fh2 ] - 0.5 ]
        clx : f32 [ 0.5 - (pxs[2] - f32[ fx ]) / f32[ fw2 ] ]
        cly : f32 [ (pys[2] - f32[ fy ]) / f32[ fh2 ] - 0.5 ]
        crx : f32 [ 0.5 - (pxs[3] - f32[ fx ]) / f32[ fw2 ] ]
        cry : f32 [ (pys[3] - f32[ fy ]) / f32[ fh2 ] - 0.5 ]
        plx : f32 [ 0.5 - (pxs[4] - f32[ fx ]) / f32[ fw2 ] ]
        ply : f32 [ (pys[4] - f32[ fy ]) / f32[ fh2 ] - 0.5 ]
        prx : f32 [ 0.5 - (pxs[5] - f32[ fx ]) / f32[ fw2 ] ]
        pry : f32 [ (pys[5] - f32[ fy ]) / f32[ fh2 ] - 0.5 ]
        sdx : f32 [ flx - frx ]
        sdy : f32 [ fly - fry ]
        fscale : f32 [ sqrt[ sdx*sdx + sdy*sdy ] ]
        # record frame under the mask: the sample's record image is
        # scale-matched by outer-corner span (mask 6% proud so no real
        # eye pixels survive) and shifted so the record's oc midpoint
        # lands at the mask's oc midpoint. the frame must land fully
        # inside the record image — an overflow re-rolls the pose
        if [ cap_rec < 0 ] return false
        rfid : i32 [ fp.recs_fid[ cap_rec ] ]
        rnm : string [ (cam == 0) ? 'top' : 'bot' ]
        rd2 : fp.rec_dir[]
        rim : Image [ uri: path '{rd2}/{rfid}-{rnm}.png' ]
        if [ rim.width <= 0 ] return false
        r6 : i32 [ cap_rec * 9 + 3 + cam * 3 ]
        rmx : f32 [ fp.recs_dat[ r6 + 0 ] ]
        rmy : f32 [ fp.recs_dat[ r6 + 1 ] ]
        rsp : f32 [ fp.recs_dat[ r6 + 2 ] ]
        if [ rsp < 0.02 ] return false
        riw : i32 [ rim.width ]
        rih : i32 [ rim.height ]
        smx : f32 [ ((clx + crx) * 0.5 + 0.5) * f32[ fw2 ] ]
        smy : f32 [ ((cly + cry) * 0.5 + 0.5) * f32[ fh2 ] ]
        sox : f32 [ clx - crx ]
        soy : f32 [ cly - cry ]
        soc : f32 [ sqrt[ sox*sox + soy*soy ] * f32[ fw2 ] ]
        s5 : f32 [ (soc / 1.06) / (rsp * f32[ riw ]) ]
        if [ s5 < 0.05 ] return false
        rcx : f32 [ rmx * f32[ riw ] ]
        rcy : f32 [ rmy * f32[ rih ] ]
        # the record only has to cover what the trainer reads: the face
        # crop (face_scale x 1.75, eye-midpoint centered) plus margin.
        # frame pixels past the record edge-clamp — never cropped
        fcx : f32 [ ((flx + frx) * 0.5 + 0.5) * f32[ fw2 ] ]
        fcy : f32 [ ((fly + fry) * 0.5 + 0.5) * f32[ fh2 ] ]
        fch : f32 [ fscale * f32[ fw2 ] * 1.75 * 1.15 * 0.5 ]
        for [ q5: i32 0, q5 < 4, q5 += 1 ]
            cx5 : f32 [ (q5 % 2 == 0) ? (fcx - fch) : (fcx + fch) ]
            cy5 : f32 [ (q5 < 2) ? (fcy - fch) : (fcy + fch) ]
            ru0 : f32 [ (cx5 - smx) / s5 + rcx ]
            rv0 : f32 [ (cy5 - smy) / s5 + rcy ]
            if [ ru0 < 0.0 || rv0 < 0.0 ] return false
            if [ ru0 > f32[ riw - 1 ] || rv0 > f32[ rih - 1 ] ] return false
        # frame areas past the record's coverage: patch from a noise
        # (no-face) record so the background has real features to
        # train against; black when no noise frames exist
        nw6 : i32 [ 0 ]
        nh6 : i32 [ 0 ]
        nn6 : i32 [ 0 ]
        np8 : @u8
        nimg : Image
        if [ fp.recs_noise_n > 0 ]
            ni6 : i32 [ (cap_idx * 7919 + cam * 13) % fp.recs_noise_n ]
            nfid : i32 [ fp.recs_noise[ ni6 ] ]
            nimg = Image [ uri: path '{rd2}/{nfid}-{rnm}.png' ]
            if [ nimg.width > 0 ]
                nw6 = nimg.width
                nh6 = nimg.height
                nn6 = nimg.channels
                np8 = nimg.pixels
        # photometric augmentation: three perlin frequencies centered on
        # the face drive brightness and contrast — uneven lighting and
        # soft shadows for free. only the iris position and the two eye
        # corners stay truth; the field is baked small and sampled
        # keyed to the POSE GROUP: every look of one pose shares the
        # same lighting field — only gaze differs inside a group
        as9 : i64 [ cap_gseed * 2862933555777941757 + 3037000493 ]
        ab9 : f32 [ f32[ (as9 % 1000 + 1000) % 1000 ] / 1000.0 * 0.45 ]
        as9 = as9 * 6364136223846793005 + 1442695040888963407
        ac9 : f32 [ f32[ (as9 % 1000 + 1000) % 1000 ] / 1000.0 * 0.45 ]
        # GLOBAL exposure, always on: contrast mostly comes OUT (real IR
        # frames run flat, 0.45..1.10), and darkening is gentler than
        # brightening (-15%..+30%)
        as9 = as9 * 6364136223846793005 + 1442695040888963407
        gb9 : f32 [ (f32[ (as9 % 1000 + 1000) % 1000 ] / 1000.0 - 0.333) * 0.45 ]
        as9 = as9 * 6364136223846793005 + 1442695040888963407
        gc9 : f32 [ 0.45 + f32[ (as9 % 1000 + 1000) % 1000 ] / 1000.0 * 0.65 ]
        # a quarter of samples carry NO field at all; the rest scale the
        # whole pattern anywhere from half to 2.5x its base frequency
        as9 = as9 * 6364136223846793005 + 1442695040888963407
        if [ ((as9 % 4 + 4) % 4) == 0 ]
            ab9 = 0.0
            ac9 = 0.0
        as9 = as9 * 6364136223846793005 + 1442695040888963407
        fs9 : f32 [ 0.5 + f32[ (as9 % 1000 + 1000) % 1000 ] / 1000.0 * 2.0 ]
        as9 = as9 * 6364136223846793005 + 1442695040888963407
        sa1 : i64 [ as9 ]
        as9 = as9 * 6364136223846793005 + 1442695040888963407
        sa2 : i64 [ as9 ]
        as9 = as9 * 6364136223846793005 + 1442695040888963407
        sa3 : i64 [ as9 ]
        nf9 : new u8 [ 16384 ]
        for [ fy9: i32 0, fy9 < 128, fy9 += 1 ]
            gy9 : f32 [ (f32[ fy9 ] / 127.0 * f32[ fh2 ] - smy) / soc * fs9 ]
            for [ fx9: i32 0, fx9 < 128, fx9 += 1 ]
                gx9 : f32 [ (f32[ fx9 ] / 127.0 * f32[ fw2 ] - smx) / soc * fs9 ]
                nv9 : f32 [ vnoise2[ sa1, gx9 * 1.5, gy9 * 1.5 ] * 0.5 ]
                nv9 = nv9 + vnoise2[ sa2, gx9 * 3.3, gy9 * 3.3 ] * 0.3
                nv9 = nv9 + vnoise2[ sa3, gx9 * 7.1, gy9 * 7.1 ] * 0.2
                nf9[ fy9 * 128 + fx9 ] = u8[ nv9 * 255.0 ]
        # compose: synthetic (premultiplied alpha) over the record, gray out
        fimg : Image [ width: fw2, height: fh2, format: Pixel.u8, channels: 1 ]
        dp : @u8 [ fimg.pixels ]
        sp8 : @u8 [ mcap.pixels ]
        rp8 : @u8 [ rim.pixels ]
        snch : i32 [ mcap.channels ]
        rnch : i32 [ rim.channels ]
        for [ oy5: i32 0, oy5 < fh2, oy5 += 1 ]
            rpy : f32 [ (f32[ oy5 ] - smy) / s5 + rcy ]
            nv1 : f32 [ f32[ oy5 ] / f32[ fh2 - 1 ] ]
            for [ ox5: i32 0, ox5 < fw2, ox5 += 1 ]
                so5 : i64 [ (i64[ oy5 ] * i64[ fw2 ] + i64[ ox5 ]) * i64[ snch ] ]
                sg : f32 [ f32[ sp8[ so5 ] ] ]
                a8 : f32 [ 1.0 ]
                if [ snch == 4 ] a8 = f32[ sp8[ so5 + 3 ] ] / 255.0
                rpx : f32 [ (f32[ ox5 ] - smx) / s5 + rcx ]
                rg : f32 [ 0.0 ]
                if [ rpx >= 0.0 && rpy >= 0.0 && rpx <= f32[ riw - 1 ] && rpy <= f32[ rih - 1 ] ]
                    rg = img_bilin[ rp8, riw, rih, rnch, 0, rpx / f32[ riw - 1 ], rpy / f32[ rih - 1 ] ] * 255.0
                el [ nw6 > 0 ]
                    nu1 : f32 [ f32[ ox5 ] / f32[ fw2 - 1 ] ]
                    rg = img_bilin[ np8, nw6, nh6, nn6, 0, nu1, nv1 ] * 255.0
                g5 : f32 [ sg + (1.0 - a8) * rg ]
                if [ g5 > 255.0 ] g5 = 255.0
                do5 : i64 [ i64[ oy5 ] * i64[ fw2 ] + i64[ ox5 ] ]
                dp[ do5 ] = u8[ g5 ]
        # hair passes: pooled real-hair patches stamped under perlin
        # section masks — ringed around the face, sometimes across it;
        # a third of samples get none. stamped BEFORE the lighting
        # field so hair shares the sample's light
        if [ fp.hair_n > 0 ]
            hs5 : i64 [ cap_gseed * 3202034522624059733 + 1103515245 ]
            hs5 = hs5 * 6364136223846793005 + 1442695040888963407
            hn5 : i32 [ 0 ]
            if [ ((hs5 % 3 + 3) % 3) > 0 ]
                hs5 = hs5 * 6364136223846793005 + 1442695040888963407
                hn5 = 2 + i32[ (hs5 % 7 + 7) % 7 ]
            for [ hp5: i32 0, hp5 < hn5, hp5 += 1 ]
                hs5 = hs5 * 6364136223846793005 + 1442695040888963407
                hi5 : i32 [ i32[ (hs5 % i64[ fp.hair_n ] + i64[ fp.hair_n ]) % i64[ fp.hair_n ] ] ]
                hs5 = hs5 * 6364136223846793005 + 1442695040888963407
                hang : f32 [ f32[ (hs5 % 1000 + 1000) % 1000 ] / 1000.0 * 6.2831853 ]
                hs5 = hs5 * 6364136223846793005 + 1442695040888963407
                hrad : f32 [ soc * (0.3 + f32[ (hs5 % 1000 + 1000) % 1000 ] / 1000.0 * 1.3) ]
                hs5 = hs5 * 6364136223846793005 + 1442695040888963407
                hscl : f32 [ 0.8 + f32[ (hs5 % 1000 + 1000) % 1000 ] / 1000.0 * 0.8 ]
                hside : f32 [ 0.20 * f32[ riw ] * s5 * hscl ]
                hw5 : i32 [ i32[ hside ] ]
                if [ hw5 < 4 ] continue
                hx0 : i32 [ i32[ smx + cos[ hang ] * hrad - hside * 0.5 ] ]
                hy0 : i32 [ i32[ smy + sin[ hang ] * hrad - hside * 0.5 ] ]
                for [ qy5: i32 0, qy5 < hw5, qy5 += 1 ]
                    dy5 : i32 [ hy0 + qy5 ]
                    if [ dy5 < 0 || dy5 >= fh2 ] continue
                    vq : f32 [ f32[ qy5 ] / f32[ hw5 - 1 ] ]
                    fv5 : f32 [ (vq > 0.5) ? (1.0 - vq) : vq ]
                    for [ qx5: i32 0, qx5 < hw5, qx5 += 1 ]
                        dx5 : i32 [ hx0 + qx5 ]
                        if [ dx5 < 0 || dx5 >= fw2 ] continue
                        uq : f32 [ f32[ qx5 ] / f32[ hw5 - 1 ] ]
                        # two smooth low-frequency octaves + a soft
                        # threshold: big organic sections, no speckle
                        nm5 : f32 [ vnoise2[ hs5, uq * 1.6, vq * 1.6 ] * 0.65 ]
                        nm5 = nm5 + vnoise2[ hs5 + 7919, uq * 3.2, vq * 3.2 ] * 0.35
                        a5 : f32 [ (nm5 - 0.42) * 3.0 ]
                        if [ a5 <= 0.0 ] continue
                        if [ a5 > 1.0 ] a5 = 1.0
                        fu5 : f32 [ (uq > 0.5) ? (1.0 - uq) : uq ]
                        fe5 : f32 [ (fu5 < fv5) ? fu5 : fv5 ]
                        fe5 = fe5 * 6.0
                        if [ fe5 > 1.0 ] fe5 = 1.0
                        a5 = a5 * fe5
                        pxp : i32 [ i32[ uq * 31.9 ] ]
                        pyp : i32 [ i32[ vq * 31.9 ] ]
                        hv5 : f32 [ f32[ fp.hair_pat[ i64[ hi5 ] * 1024 + i64[ pyp ] * 32 + i64[ pxp ] ] ] ]
                        od5 : i64 [ i64[ dy5 ] * i64[ fw2 ] + i64[ dx5 ] ]
                        dp[ od5 ] = u8[ a5 * hv5 + (1.0 - a5) * f32[ dp[ od5 ] ] ]
        # the lighting field covers mask, record, noise and hair alike,
        # so no blend seam ever shows in the lighting; global exposure
        # rides on top of it and is never off
        for [ oy6: i32 0, oy6 < fh2, oy6 += 1 ]
            nvy6 : f32 [ f32[ oy6 ] / f32[ fh2 - 1 ] ]
            for [ ox6: i32 0, ox6 < fw2, ox6 += 1 ]
                nz9 : f32 [ img_bilin[ nf9, 128, 128, 1, 0, f32[ ox6 ] / f32[ fw2 - 1 ], nvy6 ] * 2.0 - 1.0 ]
                do6 : i64 [ i64[ oy6 ] * i64[ fw2 ] + i64[ ox6 ] ]
                v6 : f32 [ f32[ dp[ do6 ] ] ]
                v6 = (v6 - 128.0) * (gc9 * (1.0 + ac9 * nz9)) + 128.0 + (ab9 * nz9 + gb9) * 255.0
                if [ v6 > 255.0 ] v6 = 255.0
                if [ v6 < 0.0 ] v6 = 0.0
                dp[ do6 ] = u8[ v6 ]
        fimg.png[ path '{sdir}/{cap_idx}-face{cam}.png' ]
        # stash this camera's plots; the .agi writes once, after the last
        # camera, with one indexed block per camera. slot 9 = the head's
        # angle off this camera's axis in degrees — an extreme view on
        # one mount is still a sample, the trainer weighs it by this
        if [ !cap_pl ]
            cap_pl = new f32 [ 56 ]
        eex : f32 [ look_x + dist * cos[ pitch ] * sin[ yaw ] ]
        eey : f32 [ look_y + dist * sin[ pitch ] ]
        eez : f32 [ look_z + dist * cos[ pitch ] * cos[ yaw ] ]
        mfx2 : f32 [ (eyec_lx + eyec_rx) * 0.5 ]
        mfy2 : f32 [ (eyec_ly + eyec_ry) * 0.5 ]
        mfz2 : f32 [ (eyec_lz + eyec_rz) * 0.5 ]
        tcx : f32 [ eex - mfx2 ]
        tcy : f32 [ eey - mfy2 ]
        tcz : f32 [ eez - mfz2 ]
        tcl : f32 [ sqrt[ tcx*tcx + tcy*tcy + tcz*tcz ] ]
        if [ tcl < 0.0001 ] tcl = 0.0001
        cdot : f32 [ (cap_rot.m[8]*tcx + cap_rot.m[9]*tcy + cap_rot.m[10]*tcz) / tcl ]
        if [ cdot >  1.0 ] cdot =  1.0
        if [ cdot < -1.0 ] cdot = -1.0
        crel : f32 [ acos[ cdot ] * 57.29578 ]
        c9 : i32 [ cam * 14 ]
        cap_pl[ c9 + 0 ] = flx
        cap_pl[ c9 + 1 ] = fly
        cap_pl[ c9 + 2 ] = frx
        cap_pl[ c9 + 3 ] = fry
        cap_pl[ c9 + 4 ] = fscale
        cap_pl[ c9 + 5 ] = clx
        cap_pl[ c9 + 6 ] = cly
        cap_pl[ c9 + 7 ] = crx
        cap_pl[ c9 + 8 ] = cry
        cap_pl[ c9 + 9 ] = crel
        cap_pl[ c9 + 10 ] = plx
        cap_pl[ c9 + 11 ] = ply
        cap_pl[ c9 + 12 ] = prx
        cap_pl[ c9 + 13 ] = pry
        if [ cam < fp.cameras - 1 ] return true
        # face->screen-center offset in meters (person frame) + head plot:
        # the head AXIS ray (rotated by the sample's pose) intersected with
        # the screen plane. screen placement is this sample's own.
        scx : f32 [ cap_scx ]
        scy : f32 [ cap_scy ]
        scz : f32 [ cap_scz ]
        mxm : f32 [ (eyec_lx + eyec_rx) * 0.5 ]
        mym : f32 [ (eyec_ly + eyec_ry) * 0.5 ]
        mzm : f32 [ (eyec_lz + eyec_rz) * 0.5 ]
        ofx : f32 [ 0.0 - (scx - mxm) ]
        ofy : f32 [ scy - mym ]
        ofz : f32 [ 0.0 - (scz - mzm) ]
        # eye_off: the EYE COORDINATE (oc-ic midpoint per eye on the
        # live cage, then between both eyes, posed) relative to the
        # screen center. meters, person frame: +x their right, +y up,
        # +z toward the person
        mgx : f32 [ ((wxs[2] + ilx) * 0.5 + (wxs[3] + irx) * 0.5) * 0.5 ]
        mgy : f32 [ ((wys[2] + ily) * 0.5 + (wys[3] + iry) * 0.5) * 0.5 ]
        mgz : f32 [ ((wzs[2] + ilz) * 0.5 + (wzs[3] + irz) * 0.5) * 0.5 ]
        mwx : f32 [ cap_rot.m[0]*mgx + cap_rot.m[4]*mgy + cap_rot.m[8]*mgz  + cap_rot.m[12] ]
        mwy : f32 [ cap_rot.m[1]*mgx + cap_rot.m[5]*mgy + cap_rot.m[9]*mgz  + cap_rot.m[13] ]
        mwz : f32 [ cap_rot.m[2]*mgx + cap_rot.m[6]*mgy + cap_rot.m[10]*mgz + cap_rot.m[14] ]
        eox : f32 [ scx - mwx ]
        eoy : f32 [ mwy - scy ]
        eoz : f32 [ scz - mwz ]
        hfx : f32 [ cap_rot.m[8] ]
        hfy : f32 [ cap_rot.m[9] ]
        hfz : f32 [ cap_rot.m[10] ]
        if [ hfz < 0.1 ] hfz = 0.1
        ht : f32 [ (scz - mzm) / hfz ]
        hix : f32 [ mxm + hfx * ht ]
        hiy : f32 [ mym + hfy * ht ]
        hu : f32 [ (scx - hix) / fp.screen_w ]
        hv : f32 [ (scy - hiy) / fp.screen_h ]
        # head rotation relative to the SCREEN CENTER: the camera-relative
        # pose re-expressed in the frame whose forward axis runs from the eye
        # midpoint to the screen center (the mount transform composed in).
        # same yaw/pitch/roll convention as head_rot.
        sdx2 : f32 [ scx - mxm ]
        sdy2 : f32 [ scy - mym ]
        sdz2 : f32 [ scz - mzm ]
        sdl : f32 [ sqrt[ sdx2*sdx2 + sdy2*sdy2 + sdz2*sdz2 ] ]
        if [ sdl < 0.0001 ] sdl = 0.0001
        fwx : f32 [ sdx2 / sdl ]
        fwy : f32 [ sdy2 / sdl ]
        fwz : f32 [ sdz2 / sdl ]
        # right = normalize((0,1,0) x fwd) = (fwd.z, 0, -fwd.x); up = fwd x right
        rgx : f32 [ fwz ]
        rgz : f32 [ 0.0 - fwx ]
        rgl : f32 [ sqrt[ rgx*rgx + rgz*rgz ] ]
        if [ rgl < 0.0001 ] rgl = 0.0001
        rgx = rgx / rgl
        rgz = rgz / rgl
        upx : f32 [ fwy*rgz ]
        upy : f32 [ fwz*rgx - fwx*rgz ]
        upz : f32 [ 0.0 - fwy*rgx ]
        rs02 : f32 [ rgx*cap_rot.m[8] + rgz*cap_rot.m[10] ]
        rs12 : f32 [ upx*cap_rot.m[8] + upy*cap_rot.m[9] + upz*cap_rot.m[10] ]
        rs22 : f32 [ fwx*cap_rot.m[8] + fwy*cap_rot.m[9] + fwz*cap_rot.m[10] ]
        rs10 : f32 [ upx*cap_rot.m[0] + upy*cap_rot.m[1] + upz*cap_rot.m[2] ]
        rs11 : f32 [ upx*cap_rot.m[4] + upy*cap_rot.m[5] + upz*cap_rot.m[6] ]
        sp2 : f32 [ 0.0 - rs12 ]
        if [ sp2 >  1.0 ] sp2 =  1.0
        if [ sp2 < -1.0 ] sp2 = -1.0
        hys : f32 [ atan2[ rs02, rs22 ] ]
        hps : f32 [ asin[ sp2 ] ]
        hrs : f32 [ atan2[ rs10, rs11 ] ]
        # pupil radius as a fraction of the inter-eye distance: python
        # scales it by the pixel eye separation for the weight-map sigma
        iedx : f32 [ eyec_lx - eyec_rx ]
        iedy : f32 [ eyec_ly - eyec_ry ]
        iedz : f32 [ eyec_lz - eyec_rz ]
        ied : f32 [ sqrt[ iedx*iedx + iedy*iedy + iedz*iedz ] ]
        if [ ied < 0.0001 ] ied = 0.0001
        pradn : f32 [ 0.0046 * 0.44 / ied ]
        if [ cshader ] pradn = cshader.iris_radius * cshader.pupil_r / ied
        cl2 : i32 [ (cap_clean) ? 1 : 0 ]
        s2 : string 'labels:\n    head: {hu} {hv}\n    look: {plot_u} {plot_v}\n    head_rot: {cap_hy} {cap_hp} {cap_hr}\n    head_rot_scr: {hys} {hps} {hrs}\n    face_off: {ofx} {ofy} {ofz}\n    eye_off: {eox} {eoy} {eoz}\n    pupil_rad: {pradn}\n    clean: {cl2}\nrig:\n    screen: {fp.screen_w} {fp.screen_h}\n    camera: {fp.cam_x} {fp.cam_y} {fp.cam_z}\n    tilt: {fp.cam_tilt_deg}\n    fov: {fp.cam_fov_deg}\n    cameras: {fp.cameras}\n'
        for [ c2: i32 0, c2 < fp.cameras, c2 += 1 ]
            b9 : i32 [ c2 * 14 ]
            bflx : f32 [ cap_pl[ b9 + 0 ] ]
            bfly : f32 [ cap_pl[ b9 + 1 ] ]
            bfrx : f32 [ cap_pl[ b9 + 2 ] ]
            bfry : f32 [ cap_pl[ b9 + 3 ] ]
            bfsc : f32 [ cap_pl[ b9 + 4 ] ]
            bclx : f32 [ cap_pl[ b9 + 5 ] ]
            bcly : f32 [ cap_pl[ b9 + 6 ] ]
            bcrx : f32 [ cap_pl[ b9 + 7 ] ]
            bcry : f32 [ cap_pl[ b9 + 8 ] ]
            brel : f32 [ cap_pl[ b9 + 9 ] ]
            bplx : f32 [ cap_pl[ b9 + 10 ] ]
            bply : f32 [ cap_pl[ b9 + 11 ] ]
            bprx : f32 [ cap_pl[ b9 + 12 ] ]
            bpry : f32 [ cap_pl[ b9 + 13 ] ]
            s2 = '{s2}image{c2}: {cap_idx}-face{c2}.png\nface_left{c2}: {bflx} {bfly}\nface_right{c2}: {bfrx} {bfry}\nface_scale{c2}: {bfsc}\nface_left_oc{c2}: {bclx} {bcly}\nface_right_oc{c2}: {bcrx} {bcry}\ncam_rel{c2}: {brel}\npupil_left{c2}: {bplx} {bply}\npupil_right{c2}: {bprx} {bpry}\n'
        ag : path '{sdir}/{cap_idx}.agi'
        ag.save[ s2, null ]
        # first 4 samples ship the independent 3D confirmation
        if [ fp.check_obj && cap_idx < 4 ] save_check_obj[ fp, sdir ]
        cap_idx += 1
        return true

    # independent 3D confirmation: the ACTUAL posed face mesh, eye spheres
    # at the posed globe centres, a ray from each eye along the bones'
    # true 3D aim, the screen quad, and the target quad on it. open the
    # .obj in Blender: the rays either pierce the target or the data lies
    func save_check_obj [ fp: hyperspace2, sdir: string ]
        s : string 'o screen\n'
        nv : i32 [ 0 ]
        hw : f32 [ fp.screen_w * 0.5 ]
        hh : f32 [ fp.screen_h * 0.5 ]
        sx0 : f32 [ cap_scx - hw ]
        sx1 : f32 [ cap_scx + hw ]
        sy0 : f32 [ cap_scy - hh ]
        sy1 : f32 [ cap_scy + hh ]
        s = '{s}v {sx0} {sy0} {cap_scz}\nv {sx1} {sy0} {cap_scz}\nv {sx1} {sy1} {cap_scz}\nv {sx0} {sy1} {cap_scz}\nf 1 2 3 4\n'
        nv = 4
        # target: 2cm quad at the plot, slightly toward the person
        tqx : f32 [ cap_scx - plot_u * fp.screen_w ]
        tqy : f32 [ cap_scy - plot_v * fp.screen_h ]
        tqz : f32 [ cap_scz + 0.002 ]
        t0x : f32 [ tqx - 0.01 ]
        t1x : f32 [ tqx + 0.01 ]
        t0y : f32 [ tqy - 0.01 ]
        t1y : f32 [ tqy + 0.01 ]
        s = '{s}o target\nv {t0x} {t0y} {tqz}\nv {t1x} {t0y} {tqz}\nv {t1x} {t1y} {tqz}\nv {t0x} {t1y} {tqz}\nf {nv + 1} {nv + 2} {nv + 3} {nv + 4}\n'
        nv += 4
        # eye spheres + true aim rays, both under the head pose (cap_rot)
        for [ ei2: i32 0, ei2 < 2, ei2 += 1 ]
            ex : f32 [ (ei2 == 0) ? eyec_lx : eyec_rx ]
            ey : f32 [ (ei2 == 0) ? eyec_ly : eyec_ry ]
            ez : f32 [ (ei2 == 0) ? eyec_lz : eyec_rz ]
            px : f32 [ cap_rot.m[0]*ex + cap_rot.m[4]*ey + cap_rot.m[8]*ez  + cap_rot.m[12] ]
            py : f32 [ cap_rot.m[1]*ex + cap_rot.m[5]*ey + cap_rot.m[9]*ez  + cap_rot.m[13] ]
            pz : f32 [ cap_rot.m[2]*ex + cap_rot.m[6]*ey + cap_rot.m[10]*ez + cap_rot.m[14] ]
            # the ACTUAL eyeball mesh under the transforms the renderer
            # uses (node world posed by the aim, then the head pose) —
            # the corneal bulge shows the true rotation in Blender
            enm : string [ (ei2 == 0) ? 'Eye L' : 'Eye R' ]
            emi : i32 [ -1 ]
            ewm : mat4f
            for [ nd4: Node ] in gmodel.nodes
                if [ nd4.name && nd4.name == enm ]
                    emi = i32[ nd4.mesh ]
                    ewm = nd4.world
            if [ emi >= 0 ]
                s = '{s}o eye{ei2}\n'
                emsh2 : gmodel.meshes[ emi ]
                for [ eprim2: Primitive ] in emsh2.primitives
                    epos2 : i32 [ -1 ]
                    for [ value: @i64, a_name: string ] in eprim2.attributes
                        if [ a_name == 'POSITION' ] epos2 = i32[ value[0] ]
                    if [ epos2 < 0 ] continue
                    eac2 : gmodel.accessors[ epos2 ]
                    ebv2 : gmodel.bufferViews[ i32[ eac2.bufferView ] ]
                    ebb2 : gmodel.buffers[ i32[ ebv2.buffer ] ]
                    ebase2 : @i8 [ ebb2.data ]
                    estr2 : i64 [ eac2.stride ]
                    if [ ebv2.byteStride > 0 ] estr2 = ebv2.byteStride
                    eoff2 : i64 [ ebv2.byteOffset + eac2.byteOffset ]
                    evc2 : i32 [ i32[ eac2.count ] ]
                    ebv3 : i32 [ nv ]
                    for [ i: i32 0, i < evc2, i += 1 ]
                        ef2 : @f32 [ ((@ebase2[ eoff2 + i64[ i ] * estr2 ]) to @f32) ]
                        lx2 : f32 [ ef2[0] ]
                        ly2 : f32 [ ef2[1] ]
                        lz2 : f32 [ ef2[2] ]
                        mx2 : f32 [ ewm.m[0]*lx2 + ewm.m[4]*ly2 + ewm.m[8]*lz2  + ewm.m[12] ]
                        my2 : f32 [ ewm.m[1]*lx2 + ewm.m[5]*ly2 + ewm.m[9]*lz2  + ewm.m[13] ]
                        mz2 : f32 [ ewm.m[2]*lx2 + ewm.m[6]*ly2 + ewm.m[10]*lz2 + ewm.m[14] ]
                        gx2 : f32 [ cap_rot.m[0]*mx2 + cap_rot.m[4]*my2 + cap_rot.m[8]*mz2  + cap_rot.m[12] ]
                        gy2 : f32 [ cap_rot.m[1]*mx2 + cap_rot.m[5]*my2 + cap_rot.m[9]*mz2  + cap_rot.m[13] ]
                        gz2 : f32 [ cap_rot.m[2]*mx2 + cap_rot.m[6]*my2 + cap_rot.m[10]*mz2 + cap_rot.m[14] ]
                        s = '{s}v {gx2} {gy2} {gz2}\n'
                        nv += 1
                    eiac : gmodel.accessors[ i32[ eprim2.indices ] ]
                    eibv : gmodel.bufferViews[ i32[ eiac.bufferView ] ]
                    eibb : gmodel.buffers[ i32[ eibv.buffer ] ]
                    eib : @i8 [ eibb.data ]
                    eio : i64 [ eibv.byteOffset + eiac.byteOffset ]
                    eic : i32 [ i32[ eiac.count ] ]
                    ew2 : bool [ eiac.componentType == ComponentType.UNSIGNED_INT ]
                    e16 : @u16 [ ((@eib[ eio ]) to @u16) ]
                    e32 : @u32 [ ((@eib[ eio ]) to @u32) ]
                    for [ i: i32 0, i < eic, i += 3 ]
                        ea2 : i32 [ (ew2) ? i32[ e32[ i ] ] : i32[ e16[ i ] ] ]
                        eb2 : i32 [ (ew2) ? i32[ e32[ i + 1 ] ] : i32[ e16[ i + 1 ] ] ]
                        ec2 : i32 [ (ew2) ? i32[ e32[ i + 2 ] ] : i32[ e16[ i + 2 ] ] ]
                        fa2 : i32 [ ebv3 + ea2 + 1 ]
                        fb2 : i32 [ ebv3 + eb2 + 1 ]
                        fc3 : i32 [ ebv3 + ec2 + 1 ]
                        s = '{s}f {fa2} {fb2} {fc3}\n'
            # the bone's ACTUAL forward (posed by aim), then the head pose
            bi : i32 [ (ei2 == 0) ? ebl : ebr ]
            nb3 : gmodel.nodes[ bi ]
            wm3 : mat4f [ nb3.world ]
            fx5 : f32 [ (ei2 == 0) ? fwd_lx : fwd_rx ]
            fy5 : f32 [ (ei2 == 0) ? fwd_ly : fwd_ry ]
            fz5 : f32 [ (ei2 == 0) ? fwd_lz : fwd_rz ]
            fmx : f32 [ wm3.m[0]*fx5 + wm3.m[4]*fy5 + wm3.m[8]*fz5 ]
            fmy : f32 [ wm3.m[1]*fx5 + wm3.m[5]*fy5 + wm3.m[9]*fz5 ]
            fmz : f32 [ wm3.m[2]*fx5 + wm3.m[6]*fy5 + wm3.m[10]*fz5 ]
            rdx : f32 [ cap_rot.m[0]*fmx + cap_rot.m[4]*fmy + cap_rot.m[8]*fmz ]
            rdy : f32 [ cap_rot.m[1]*fmx + cap_rot.m[5]*fmy + cap_rot.m[9]*fmz ]
            rdz : f32 [ cap_rot.m[2]*fmx + cap_rot.m[6]*fmy + cap_rot.m[10]*fmz ]
            rl2 : f32 [ sqrt[ rdx*rdx + rdy*rdy + rdz*rdz ] ]
            if [ rl2 < 0.0001 ] rl2 = 0.0001
            rlen : f32 [ (cap_scz - pz) / (rdz / rl2) ]
            rlen = rlen * 1.1
            qx : f32 [ px + rdx / rl2 * rlen ]
            qy : f32 [ py + rdy / rl2 * rlen ]
            qz : f32 [ pz + rdz / rl2 * rlen ]
            s = '{s}o ray{ei2}\nv {px} {py} {pz}\nv {qx} {qy} {qz}\nl {nv + 1} {nv + 2}\n'
            nv += 2
        # the actual face mesh (Head/Body materials), posed by cap_rot
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                mnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > midx ]
                    mnm = gmodel.materials[ midx ].name
                if [ mnm != 'Head' && mnm != 'Body' ] continue
                pos_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai = i32[ value[0] ]
                if [ pos_ai < 0 ] continue
                pac : gmodel.accessors[ pos_ai ]
                pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
                pbb : gmodel.buffers[ i32[ pbv.buffer ] ]
                pbase : @i8 [ pbb.data ]
                pstride : i64 [ pac.stride ]
                if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
                poff : i64 [ pbv.byteOffset + pac.byteOffset ]
                vc : i32 [ i32[ pac.count ] ]
                s = '{s}o face\n'
                fbase : i32 [ nv ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
                    wx : f32 [ pf[0] ]
                    wy : f32 [ pf[1] ]
                    wz : f32 [ pf[2] ]
                    ox : f32 [ cap_rot.m[0]*wx + cap_rot.m[4]*wy + cap_rot.m[8]*wz  + cap_rot.m[12] ]
                    oy : f32 [ cap_rot.m[1]*wx + cap_rot.m[5]*wy + cap_rot.m[9]*wz  + cap_rot.m[13] ]
                    oz : f32 [ cap_rot.m[2]*wx + cap_rot.m[6]*wy + cap_rot.m[10]*wz + cap_rot.m[14] ]
                    s = '{s}v {ox} {oy} {oz}\n'
                    nv += 1
                iac : gmodel.accessors[ i32[ prim.indices ] ]
                ibv : gmodel.bufferViews[ i32[ iac.bufferView ] ]
                ibb : gmodel.buffers[ i32[ ibv.buffer ] ]
                ibase : @i8 [ ibb.data ]
                ioff : i64 [ ibv.byteOffset + iac.byteOffset ]
                ic : i32 [ i32[ iac.count ] ]
                wide2 : bool [ iac.componentType == ComponentType.UNSIGNED_INT ]
                i16p : @u16 [ ((@ibase[ ioff ]) to @u16) ]
                i32p : @u32 [ ((@ibase[ ioff ]) to @u32) ]
                for [ i: i32 0, i < ic, i += 3 ]
                    ia : i32 [ (wide2) ? i32[ i32p[ i ] ] : i32[ i16p[ i ] ] ]
                    ib : i32 [ (wide2) ? i32[ i32p[ i + 1 ] ] : i32[ i16p[ i + 1 ] ] ]
                    ic2 : i32 [ (wide2) ? i32[ i32p[ i + 2 ] ] : i32[ i16p[ i + 2 ] ] ]
                    fa : i32 [ fbase + ia + 1 ]
                    fb : i32 [ fbase + ib + 1 ]
                    fc2 : i32 [ fbase + ic2 + 1 ]
                    s = '{s}f {fa} {fb} {fc2}\n'
        ob : path '{sdir}/{cap_idx}-check.obj'
        ob.save[ s, null ]
        puts 'check obj: {cap_idx}-check.obj'

    # verification frame: rendered from the gaze target itself. saved next
    # to the sample it checks (save_plot_sample already advanced cap_idx)
    func save_verify_frame [ fp: hyperspace2 ]
        cap : Image [ vrender.color ]
        gw : i32 [ vrender.width ]
        gh : i32 [ vrender.height ]
        fw2 : i32 [ (gw < gh) ? gw : gh ]
        fx : i32 [ (gw - fw2) / 2 ]
        fy : i32 [ (gh - fw2) / 2 ]
        sdir : '/src/hyperspace-sessions/{fp.session}'
        vid : i32 [ cap_idx - 1 ]
        gimg : cap.gray[]
        cimg : gimg.crop[ fx, fy, fw2, fw2 ]
        fimg : cimg.mirror_x[]
        fimg.png[ path '{sdir}/{vid}-verify.png' ]

    # unproject the click: project every control vert with the render's own
    # view/proj and take the nearest on screen; result in picked_cage/vert
    func pick_cage [ mx: f32, my: f32 ] -> bool
        picked_cage = -1
        picked_vert = -1
        if [ !vmodel || !vshader ] return false
        if [ !vmodel.cages || vmodel.cages.count == 0 ] return false
        vm : mat4f [ vshader.view ]
        pm : mat4f [ vshader.proj ]
        best_d : f32 [ 1e30 ]
        for [ ci: i32 0, ci < vmodel.cages.count, ci += 1 ]
            cg : vmodel.cages[ ci ]
            if [ !cg.cage_buf ] continue
            cpos : @f32 [ cg.cage_buf.data ]
            for [ v: i32 0, v < cg.nv, v += 1 ]
                px : f32 [ cpos[ v*3 + 0 ] ]
                py : f32 [ cpos[ v*3 + 1 ] ]
                pz : f32 [ cpos[ v*3 + 2 ] ]
                vx : f32 [ vm.m[0]*px + vm.m[4]*py + vm.m[8]*pz  + vm.m[12] ]
                vy : f32 [ vm.m[1]*px + vm.m[5]*py + vm.m[9]*pz  + vm.m[13] ]
                vz : f32 [ vm.m[2]*px + vm.m[6]*py + vm.m[10]*pz + vm.m[14] ]
                cxp : f32 [ pm.m[0]*vx + pm.m[4]*vy + pm.m[8]*vz  + pm.m[12] ]
                cyp : f32 [ pm.m[1]*vx + pm.m[5]*vy + pm.m[9]*vz  + pm.m[13] ]
                cwp : f32 [ pm.m[3]*vx + pm.m[7]*vy + pm.m[11]*vz + pm.m[15] ]
                if [ cwp <= 0.0001 ] continue
                sx : f32 [ (cxp / cwp + 1.0) * 0.5 * bounds.w ]
                sy : f32 [ (cyp / cwp + 1.0) * 0.5 * bounds.h ]
                ddx : f32 [ sx - mx ]
                ddy : f32 [ sy - my ]
                sd2 : f32 [ ddx*ddx + ddy*ddy ]
                if [ sd2 < best_d ]
                    best_d = sd2
                    picked_vert = v
                    picked_cage = ci
        return picked_vert >= 0

    public func on_move [ ev: Event ]
        if [ !dragging ] return
        fp : picker[]
        if [ !fp ] return
        dx : f32 [ ev.mouse.pos.x - lastx ]
        dy : f32 [ ev.mouse.pos.y - lasty ]
        ddx : f32 [ ev.mouse.pos.x - press_x ]
        ddy : f32 [ ev.mouse.pos.y - press_y ]
        if [ ddx * ddx + ddy * ddy > 16.0 ] moved = true
        lastx = ev.mouse.pos.x
        lasty = ev.mouse.pos.y
        if [ ev.key.shift && drag_mode > 0 ]
            # shift-drag edits the grabbed feature: eyes slant about
            # their fixed outer corners (up = inner corners up); nose
            # and lip travel their axes (drag down = longer/lower)
            if [ drag_mode == 1 ]
                # vertical slants, horizontal resizes (right = bigger)
                eye_slant[ 0.0 - dy * 0.0005 ]
                eye_size[ dx * 0.0005 ]
            el [ drag_mode == 3 ]
                lip_drop[ dy * 0.0005 ]
            el
                nose_length[ dy * 0.0005 ]
            nose_edited = true
        el [ ev.key.shift ]
            # shift-drag PANS: translate the look target along the camera's
            # right and screen-up axes, scaled so the content tracks the cursor
            sc : f32 [ fp.dist * 0.0016 ]
            syw : f32 [ sin[ fp.yaw ] ]
            cyw : f32 [ cos[ fp.yaw ] ]
            spt : f32 [ sin[ fp.pitch ] ]
            cpt : f32 [ cos[ fp.pitch ] ]
            fp.look_x += (cyw * dx + syw * spt * dy) * sc
            fp.look_y += cpt * dy * sc
            fp.look_z += ((0.0 - syw) * dx + cyw * spt * dy) * sc
        el
            fp.yaw   += dx * 0.01
            fp.pitch += dy * 0.01
            if [ fp.pitch >  1.5 ] fp.pitch =  1.5
            if [ fp.pitch < -1.5 ] fp.pitch = -1.5

    public func on_wheel [ ev: Event ]
        fp : picker[]
        if [ !fp ] return
        fp.dist *= 1.0 - f32[ ev.mouse.wheel_delta.y ] * 0.1
        if [ fp.dist < 0.2 ]  fp.dist = 0.2
        if [ fp.dist > 50.0 ] fp.dist = 50.0

    public func on_key [ ev: Event ]
        if [ !ev.key.state ] return
        if [ ev.key.unicode == 82 ]        # R: reset view
            yaw   = 0.0
            pitch = 0.05
        if [ ev.key.unicode == 81 ] hinge_ang -= 0.1   # Q: rotate joint -
        if [ ev.key.unicode == 69 ] hinge_ang += 0.1   # E: rotate joint +
        if [ ev.key.unicode == 73 ]                    # I: toggle IR / color
            ir_on = !ir_on
            irf : f32 [ (ir_on) ? 1.0 : 0.0 ]
            if [ vshader ] vshader.ir = irf
            if [ rshader ] rshader.ir = irf
            if [ cshader ] cshader.ir = irf
        if [ hinge_ang >  3.0 ] hinge_ang =  3.0
        if [ hinge_ang < -3.0 ] hinge_ang = -3.0
        # arrow keys drag a REAL gaze mark in space (the Blender target):
        # both eyes converge on it, lids and the eyes-down morph follow.
        # plain arrows move it in the plane; shift+up/down changes depth
        tmoved : bool [ false ]
        if [ ev.key.unicode == 263 || ev.key.unicode == 262 || ev.key.unicode == 265 || ev.key.unicode == 264 ]
            if [ tgt_z == 0.0 ]
                tgt_x = (eyec_lx + eyec_rx) * 0.5
                tgt_y = (eyec_ly + eyec_ry) * 0.5
                tgt_z = (eyec_lz + eyec_rz) * 0.5 + 0.4
            if [ ev.key.unicode == 263 ] tgt_x -= 0.03   # left
            if [ ev.key.unicode == 262 ] tgt_x += 0.03   # right
            if [ ev.key.unicode == 265 ]                 # up / shift: closer
                if [ ev.key.shift ]
                    tgt_z -= 0.05
                el
                    tgt_y += 0.03
            if [ ev.key.unicode == 264 ]                 # down / shift: away
                if [ ev.key.shift ]
                    tgt_z += 0.05
                el
                    tgt_y -= 0.03
            tmoved = true
        if [ tmoved ]
            if [ cap_rot.m[15] == 0.0 ] cap_rot = mat4f.identity[]
            if [ ebl >= 0 ] solve_eye[ ebl, eyec_lx, eyec_ly, eyec_lz, tgt_x, tgt_y, tgt_z, true, true ]
            if [ ebr >= 0 ] solve_eye[ ebr, eyec_rx, eyec_ry, eyec_rz, tgt_x, tgt_y, tgt_z, false, true ]
            gaze_x = (gaze_lx + gaze_rx) * 0.5
            gaze_y = (gaze_ly + gaze_ry) * 0.5
            apply_eyes_down[]
            puts 'gaze mark: ({tgt_x}, {tgt_y}, {tgt_z})'
        # S: slant the _V_EYE region about the outer corners; N: stretch the
        # _V_NOSE region along the nose axis (shift inverts); each step
        # persists to the session mask
        edited : bool [ false ]
        if [ ev.key.unicode == 83 ]
            eye_slant[ (ev.key.shift) ? -0.02 : 0.02 ]
            edited = true
        if [ ev.key.unicode == 78 ]
            nose_length[ (ev.key.shift) ? -0.02 : 0.02 ]
            edited = true
        if [ edited ]
            pfk : picker[]
            if [ pfk ] pfk.save_mask[ a ]

    # arm the plot capture on THIS view (the root calls it on the off-screen
    # capture element); forces IR and lets draw's state machine run
    public func begin_capture [ n: i32 ]
        if [ capture_left != 0 || n <= 0 ] return
        # cage_copy_from may have replaced the control cage just before:
        # whatever was applied here is gone with it, so the RELATIVE morph
        # restarts from zero on the copied cage
        edn_wl = 0.0
        edn_wr = 0.0
        capture_left = n
        capture_state = 0
        ir_on = true
        irc : f32 [ 1.0 ]
        if [ vshader ] vshader.ir = irc
        if [ rshader ] rshader.ir = irc
        if [ cshader ] cshader.ir = irc

    # tear down the loaded model so the next draw re-inits with the new fit
    func reload_model []
        if [ eye_tex ]
            for [ tx: Texture ] in eye_tex
                tx.drop[]
            eye_tex = null
        if [ gmodel ] gmodel.drop[]
        if [ joint_buf ] joint_buf.drop[]
        gmodel    = null
        joint_buf = null
        vmodel    = null
        vrender   = null
        skin_idx  = -1
        hinge_node = -1
        gbl = -1
        gbr = -1

    # blend selected shape keys (glTF morph targets) into POSITION at load,
    # weighted by morph_w[name]. runs before skinning and the _V_* detail.
    func apply_morphs []
        if [ !gmodel ] return
        if [ !morph_w ] return
        for [ msh: Mesh ] in gmodel.meshes
            if [ !msh.extras ] continue
            names : msh.extras.targetNames
            if [ !names ] continue
            for [ prim: Primitive ] in msh.primitives
                if [ !prim.targets ] continue
                if [ prim.targets.count == 0 ] continue
                pos_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai = i32[ value[0] ]
                if [ pos_ai < 0 ] continue
                pac : gmodel.accessors[ pos_ai ]
                pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
                pbb : gmodel.buffers[ i32[ pbv.buffer ] ]
                pbase : @i8 [ pbb.data ]
                pstride : i64 [ pac.stride ]
                if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
                poff : i64 [ pbv.byteOffset + pac.byteOffset ]
                vc : i32 [ i32[ pac.count ] ]
                for [ w: f32, nm: string ] in morph_w
                    if [ w < 0.001 ] continue
                    ti : i32 [ -1 ]
                    for [ ni: i32 0, ni < names.count, ni += 1 ]
                        if [ names[ ni ] == nm ] ti = ni
                    if [ ti < 0 ] continue
                    if [ ti >= prim.targets.count ] continue
                    tmap : prim.targets[ ti ]
                    dpos_ai : i32 [ -1 ]
                    for [ value: @i64, a_name: string ] in tmap
                        if [ a_name == 'POSITION' ] dpos_ai = i32[ value[0] ]
                    if [ dpos_ai < 0 ] continue
                    dac : gmodel.accessors[ dpos_ai ]
                    dbv : gmodel.bufferViews[ i32[ dac.bufferView ] ]
                    dbb : gmodel.buffers[ i32[ dbv.buffer ] ]
                    dbase : @i8 [ dbb.data ]
                    dstride : i64 [ dac.stride ]
                    if [ dbv.byteStride > 0 ] dstride = dbv.byteStride
                    doff : i64 [ dbv.byteOffset + dac.byteOffset ]
                    for [ i: i32 0, i < vc, i += 1 ]
                        pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
                        df : @f32 [ ((@dbase[ doff + i64[ i ] * dstride ]) to @f32) ]
                        pf[0] = pf[0] + w * df[0]
                        pf[1] = pf[1] + w * df[1]
                        pf[2] = pf[2] + w * df[2]

    # collect the 'Eyes Down L/R' morph deltas per head-cage vert, with a
    # rest snapshot of the live cage. apply_eyes_down blends them into the
    # cage buffer — the subdiv compute re-reads that buffer every frame
    func setup_eyes_down []
        if [ edn_set || head_ci < 0 || !gmodel || !vmodel ]
            puts 'eyes-down: skip (set={edn_set} head_ci={head_ci})'
            return
        hc : vmodel.cages[ head_ci ]
        if [ !hc.rep || !hc.cage_buf ]
            puts 'eyes-down: cage has no rep/cage_buf'
            return
        for [ msh: Mesh ] in gmodel.meshes
            if [ !msh.extras ]
                puts 'eyes-down: mesh has no extras'
                continue
            names : msh.extras.targetNames
            if [ !names ]
                puts 'eyes-down: extras has no targetNames'
                continue
            for [ prim: Primitive ] in msh.primitives
                if [ !prim.targets ] continue
                if [ prim.targets.count == 0 ] continue
                til : i32 [ -1 ]
                tir : i32 [ -1 ]
                for [ ni: i32 0, ni < names.count, ni += 1 ]
                    sn : string [ names[ ni ] ]
                    if [ sn == 'Eyes Down L' ] til = ni
                    if [ sn == 'Eyes Down R' ] tir = ni
                puts 'eyes-down: prim targets={prim.targets.count} names={names.count} til={til} tir={tir}'
                if [ til < 0 || tir < 0 ] continue
                if [ til >= prim.targets.count || tir >= prim.targets.count ] continue
                lmap : prim.targets[ til ]
                rmap : prim.targets[ tir ]
                lpos : i32 [ -1 ]
                rpos : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in lmap
                    if [ a_name == 'POSITION' ] lpos = i32[ value[0] ]
                for [ value: @i64, a_name: string ] in rmap
                    if [ a_name == 'POSITION' ] rpos = i32[ value[0] ]
                if [ lpos < 0 || rpos < 0 ] continue
                lac : gmodel.accessors[ lpos ]
                rac : gmodel.accessors[ rpos ]
                nsrc : i32 [ i32[ lac.count ] ]
                # Blender exports morph deltas as SPARSE accessors (no base
                # view: implicit zeros + index/value overlay). expand both
                # targets to dense heap tables first
                ns3 : i32 [ nsrc * 3 ]
                dlf : new f32 [ ns3 ]
                drf : new f32 [ ns3 ]
                for [ zi: i32 0, zi < ns3, zi += 1 ]
                    dlf[ zi ] = 0.0
                    drf[ zi ] = 0.0
                if [ lac.sparse && lac.sparse.count > 0 ]
                    scn : i32 [ i32[ lac.sparse.count ] ]
                    sib : gmodel.bufferViews[ i32[ lac.sparse.indices.bufferView ] ]
                    sibb : gmodel.buffers[ i32[ sib.buffer ] ]
                    sip : @i8 [ sibb.data ]
                    svb : gmodel.bufferViews[ i32[ lac.sparse.values.bufferView ] ]
                    svbb : gmodel.buffers[ i32[ svb.buffer ] ]
                    svp : @i8 [ svbb.data ]
                    svf : @f32 [ ((@svp[ svb.byteOffset ]) to @f32) ]
                    u16i : @u16 [ ((@sip[ sib.byteOffset ]) to @u16) ]
                    u32i : @u32 [ ((@sip[ sib.byteOffset ]) to @u32) ]
                    wide : bool [ lac.sparse.indices.componentType == ComponentType.UNSIGNED_INT ]
                    for [ si: i32 0, si < scn, si += 1 ]
                        dv : i32 [ (wide) ? i32[ u32i[ si ] ] : i32[ u16i[ si ] ] ]
                        if [ dv < 0 || dv >= nsrc ] continue
                        dlf[ dv*3 + 0 ] = svf[ si*3 + 0 ]
                        dlf[ dv*3 + 1 ] = svf[ si*3 + 1 ]
                        dlf[ dv*3 + 2 ] = svf[ si*3 + 2 ]
                if [ rac.sparse && rac.sparse.count > 0 ]
                    scn : i32 [ i32[ rac.sparse.count ] ]
                    sib : gmodel.bufferViews[ i32[ rac.sparse.indices.bufferView ] ]
                    sibb : gmodel.buffers[ i32[ sib.buffer ] ]
                    sip : @i8 [ sibb.data ]
                    svb : gmodel.bufferViews[ i32[ rac.sparse.values.bufferView ] ]
                    svbb : gmodel.buffers[ i32[ svb.buffer ] ]
                    svp : @i8 [ svbb.data ]
                    svf : @f32 [ ((@svp[ svb.byteOffset ]) to @f32) ]
                    u16i : @u16 [ ((@sip[ sib.byteOffset ]) to @u16) ]
                    u32i : @u32 [ ((@sip[ sib.byteOffset ]) to @u32) ]
                    wide : bool [ rac.sparse.indices.componentType == ComponentType.UNSIGNED_INT ]
                    for [ si: i32 0, si < scn, si += 1 ]
                        dv : i32 [ (wide) ? i32[ u32i[ si ] ] : i32[ u16i[ si ] ] ]
                        if [ dv < 0 || dv >= nsrc ] continue
                        drf[ dv*3 + 0 ] = svf[ si*3 + 0 ]
                        drf[ dv*3 + 1 ] = svf[ si*3 + 1 ]
                        drf[ dv*3 + 2 ] = svf[ si*3 + 2 ]
                tv : i32 [ hc.nv ]
                nd : i32 [ 0 ]
                for [ v: i32 0, v < tv, v += 1 ]
                    sv : i32 [ hc.rep[ v ] ]
                    if [ sv < 0 || sv >= nsrc ] continue
                    s3 : i32 [ sv * 3 ]
                    if [ dlf[ s3 ] != 0.0 || dlf[ s3+1 ] != 0.0 || dlf[ s3+2 ] != 0.0 || drf[ s3 ] != 0.0 || drf[ s3+1 ] != 0.0 || drf[ s3+2 ] != 0.0 ]
                        nd += 1
                if [ nd == 0 ] continue
                edn_v = new i32 [ nd ]
                nd3 : i32 [ nd * 3 ]
                edn_dl = new f32 [ nd3 ]
                edn_dr = new f32 [ nd3 ]
                k : i32 [ 0 ]
                for [ v: i32 0, v < tv, v += 1 ]
                    sv : i32 [ hc.rep[ v ] ]
                    if [ sv < 0 || sv >= nsrc ] continue
                    s3 : i32 [ sv * 3 ]
                    if [ dlf[ s3 ] != 0.0 || dlf[ s3+1 ] != 0.0 || dlf[ s3+2 ] != 0.0 || drf[ s3 ] != 0.0 || drf[ s3+1 ] != 0.0 || drf[ s3+2 ] != 0.0 ]
                        edn_v[ k ] = v
                        k3 : i32 [ k * 3 ]
                        edn_dl[ k3 + 0 ] = dlf[ s3 + 0 ]
                        edn_dl[ k3 + 1 ] = dlf[ s3 + 1 ]
                        edn_dl[ k3 + 2 ] = dlf[ s3 + 2 ]
                        edn_dr[ k3 + 0 ] = drf[ s3 + 0 ]
                        edn_dr[ k3 + 1 ] = drf[ s3 + 1 ]
                        edn_dr[ k3 + 2 ] = drf[ s3 + 2 ]
                        k += 1
                edn_n = nd
                edn_set = true
                puts 'hyperspace2: eyes-down morph drive on {edn_n} cage verts'
                return

    # blend the eyes-down correctives by how far each eye aims down
    # (delta_q convention: negative pitch = down). RELATIVE: only the
    # weight CHANGE is added onto the live cage, so user cage edits
    # underneath are never touched and weight 0 rolls it back off
    func apply_eyes_down []
        if [ !edn_set || head_ci < 0 ] return
        hc : vmodel.cages[ head_ci ]
        if [ !hc.cage_buf ] return
        wl : f32 [ (gaze_ly < 0.0) ? ((0.0 - gaze_ly) / eyes_down_full) : 0.0 ]
        wr : f32 [ (gaze_ry < 0.0) ? ((0.0 - gaze_ry) / eyes_down_full) : 0.0 ]
        if [ wl > 1.0 ] wl = 1.0
        if [ wr > 1.0 ] wr = 1.0
        sc2 : f32 [ (rig) ? rig.eyes_down : 1.0 ]
        wl = wl * sc2
        wr = wr * sc2
        dwl : f32 [ wl - edn_wl ]
        dwr : f32 [ wr - edn_wr ]
        if [ dwl == 0.0 && dwr == 0.0 ] return
        bp : @f32 [ hc.cage_buf.data ]
        for [ k: i32 0, k < edn_n, k += 1 ]
            v3 : i32 [ edn_v[ k ] * 3 ]
            k3 : i32 [ k * 3 ]
            bp[ v3 + 0 ] = bp[ v3 + 0 ] + dwl * edn_dl[ k3 + 0 ] + dwr * edn_dr[ k3 + 0 ]
            bp[ v3 + 1 ] = bp[ v3 + 1 ] + dwl * edn_dl[ k3 + 1 ] + dwr * edn_dr[ k3 + 1 ]
            bp[ v3 + 2 ] = bp[ v3 + 2 ] + dwl * edn_dl[ k3 + 2 ] + dwr * edn_dr[ k3 + 2 ]
        edn_wl = wl
        edn_wr = wr
        # lid z-follow: the lid the pupil is nearest bulges out along z
        # (the blender rig does this, the down-morph alone doesn't);
        # cap_zamt sets how much this pose shows it
        if [ cap_zamt > 0.0 && hc.base ]
            if [ !cap_zf ] cap_zf = new f32 [ edn_n ]
            gl9 : f32 [ gaze_ly / eyes_down_full ]
            gr9 : f32 [ gaze_ry / eyes_down_full ]
            if [ gl9 >  1.0 ] gl9 =  1.0
            if [ gl9 < -1.0 ] gl9 = -1.0
            if [ gr9 >  1.0 ] gr9 =  1.0
            if [ gr9 < -1.0 ] gr9 = -1.0
            for [ k: i32 0, k < edn_n, k += 1 ]
                v3 : i32 [ edn_v[ k ] * 3 ]
                vx9 : f32 [ hc.base[ v3 ] ]
                vy9 : f32 [ hc.base[ v3 + 1 ] ]
                gz9 : f32 [ (vx9 * eyec_lx >= 0.0) ? gl9 : gr9 ]
                ecy9 : f32 [ (vx9 * eyec_lx >= 0.0) ? eyec_ly : eyec_ry ]
                fz9 : f32 [ 0.0 ]
                if [ vy9 >= ecy9 && gz9 > 0.0 ] fz9 = gz9
                if [ vy9 < ecy9 && gz9 < 0.0 ] fz9 = 0.0 - gz9
                # pinned corner verts never ride the follow
                if [ hc.pin ] fz9 = fz9 * (1.0 - hc.pin[ edn_v[ k ] ])
                nz9 : f32 [ cap_zamt * fz9 ]
                bp[ v3 + 2 ] = bp[ v3 + 2 ] + nz9 - cap_zf[ k ]
                cap_zf[ k ] = nz9
        # perlin lid push: noise bulges the lid outward IN the pupil's
        # look direction, in a broad area around the pupil — augmentation.
        # runs when cap_lnf exists even at amount 0 so the previous
        # pose's push always backs out
        if [ (cap_lnamt > 0.0 || cap_lnf) && hc.base ]
            if [ !cap_lnf ]
                n39 : i32 [ edn_n * 3 ]
                cap_lnf = new f32 [ n39 ]
            inv9 : f32 [ 1.0 / globe_rad ]
            rad9 : f32 [ (cap_lnrad > 1.4) ? cap_lnrad : 2.2 ]
            for [ k: i32 0, k < edn_n, k += 1 ]
                vi9 : i32 [ edn_v[ k ] ]
                v3 : i32 [ vi9 * 3 ]
                k3 : i32 [ k * 3 ]
                vx9 : f32 [ hc.base[ v3 ] ]
                vy9 : f32 [ hc.base[ v3 + 1 ] ]
                lft : bool [ vx9 * eyec_lx >= 0.0 ]
                ex9 : f32 [ (lft) ? eyec_lx : eyec_rx ]
                ey9 : f32 [ (lft) ? eyec_ly : eyec_ry ]
                gx9 : f32 [ (lft) ? gaze_lx : gaze_rx ]
                gy9 : f32 [ (lft) ? gaze_ly : gaze_ry ]
                # pupil xy = globe centre tilted by the gaze angles
                px9 : f32 [ ex9 + gx9 * globe_rad ]
                py9 : f32 [ ey9 + gy9 * globe_rad ]
                dx9 : f32 [ (vx9 - px9) * inv9 ]
                dy9 : f32 [ (vy9 - py9) * inv9 ]
                dd9 : f32 [ sqrt[ dx9 * dx9 + dy9 * dy9 ] ]
                # full inside 1.2 globe radii, fading out at rad9
                fal9 : f32 [ 1.0 - (dd9 - 1.2) / (rad9 - 1.2) ]
                if [ fal9 > 1.0 ] fal9 = 1.0
                if [ fal9 < 0.0 ] fal9 = 0.0
                if [ hc.pin ] fal9 = fal9 * (1.0 - hc.pin[ vi9 ])
                nn9 : f32 [ vnoise2[ cap_lnsd, vx9 * inv9 * 0.9, vy9 * inv9 * 0.9 ] ]
                am9 : f32 [ cap_lnamt * nn9 * fal9 ]
                # push IN the look direction: unit gaze ray (gx, gy, out)
                ln9 : f32 [ sqrt[ gx9 * gx9 + gy9 * gy9 + 1.0 ] ]
                lx9 : f32 [ am9 * gx9 / ln9 ]
                ly9 : f32 [ am9 * gy9 / ln9 ]
                lz9 : f32 [ am9 / ln9 ]
                bp[ v3 ]     = bp[ v3 ]     + lx9 - cap_lnf[ k3 ]
                bp[ v3 + 1 ] = bp[ v3 + 1 ] + ly9 - cap_lnf[ k3 + 1 ]
                bp[ v3 + 2 ] = bp[ v3 + 2 ] + lz9 - cap_lnf[ k3 + 2 ]
                cap_lnf[ k3 ]     = lx9
                cap_lnf[ k3 + 1 ] = ly9
                cap_lnf[ k3 + 2 ] = lz9

    # scale the nose region by the painted _V_NOSE blue mask (gray 0.216 =
    # neutral, brighter = push out). baked into POSITION once, before upload.
    func bake_nose []
        if [ !gmodel ] return
        neutral : f32 [ 0.216 ]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                pos_ai  : i32 [ -1 ]
                nose_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai  = i32[ value[0] ]
                    if [ a_name == '_V_NOSE'  ] nose_ai = i32[ value[0] ]
                if [ pos_ai  < 0 ] continue
                if [ nose_ai < 0 ] continue
                pac : gmodel.accessors[ pos_ai ]
                nac : gmodel.accessors[ nose_ai ]
                pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
                nbv : gmodel.bufferViews[ i32[ nac.bufferView ] ]
                pbb : gmodel.buffers[ i32[ pbv.buffer ] ]
                nbb : gmodel.buffers[ i32[ nbv.buffer ] ]
                pbase : @i8 [ pbb.data ]
                nbase : @i8 [ nbb.data ]
                pstride : i64 [ pac.stride ]
                nstride : i64 [ nac.stride ]
                if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
                if [ nbv.byteStride > 0 ] nstride = nbv.byteStride
                poff : i64 [ pbv.byteOffset + pac.byteOffset ]
                noff : i64 [ nbv.byteOffset + nac.byteOffset ]
                vc : i32 [ i32[ pac.count ] ]
                cx : f32 [ 0.0 ]
                cy : f32 [ 0.0 ]
                cz : f32 [ 0.0 ]
                wsum : f32 [ 0.0 ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : @u16 [ ((@nbase[ noff + i64[ i ] * nstride ]) to @u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
                    cx += pf[0] * m
                    cy += pf[1] * m
                    cz += pf[2] * m
                    wsum += m
                if [ wsum <= 0.0 ] continue
                cx /= wsum
                cy /= wsum
                cz /= wsum
                rad : f32 [ 0.0 ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : @u16 [ ((@nbase[ noff + i64[ i ] * nstride ]) to @u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
                    dx : f32 [ pf[0] - cx ]
                    dy : f32 [ pf[1] - cy ]
                    dz : f32 [ pf[2] - cz ]
                    d  : f32 [ sqrt[ dx * dx + dy * dy + dz * dz ] ]
                    if [ d > rad ] rad = d
                if [ rad <= 0.0 ] continue
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : @u16 [ ((@nbase[ noff + i64[ i ] * nstride ]) to @u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
                    dx : f32 [ pf[0] - cx ]
                    dy : f32 [ pf[1] - cy ]
                    dz : f32 [ pf[2] - cz ]
                    d  : f32 [ sqrt[ dx * dx + dy * dy + dz * dz ] ]
                    if [ d < 0.000001 ] continue
                    s  : f32 [ (m / (1.0 - neutral)) * rad * nose_gain / d ]
                    pf[0] = pf[0] + dx * s
                    pf[1] = pf[1] + dy * s
                    pf[2] = pf[2] + dz * s
                puts 'hyperspace2: baked nose on prim verts={vc} rad={rad}'

    # fit the nose to measured landmarks: lateral width at the nostril and mid
    # bands, a depth profile (top/mid/tip) out from the eye plane, and nostril
    # height. per-vertex bake over the painted _V_NOSE region; each vert's
    # height picks its band. defaults equal the model's rest so no-op until set.
    func bake_nose_landmarks []
        if [ !gmodel ] return
        neutral : f32 [ 0.216 ]
        # eye-plane height (y) datum, from the eye bone
        epy : f32 [ 1.622 ]
        for [ nd: Node ] in gmodel.nodes
            if [ nd.name && nd.name == 'Eye.L' ]
                wl : mat4f [ nd.world ]
                epy = wl.m[13]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                pos_ai  : i32 [ -1 ]
                nose_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai  = i32[ value[0] ]
                    if [ a_name == '_V_NOSE'  ] nose_ai = i32[ value[0] ]
                if [ pos_ai  < 0 ] continue
                if [ nose_ai < 0 ] continue
                pac : gmodel.accessors[ pos_ai ]
                nac : gmodel.accessors[ nose_ai ]
                pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
                nbv : gmodel.bufferViews[ i32[ nac.bufferView ] ]
                pbb : gmodel.buffers[ i32[ pbv.buffer ] ]
                nbb : gmodel.buffers[ i32[ nbv.buffer ] ]
                pbase : @i8 [ pbb.data ]
                nbase : @i8 [ nbb.data ]
                pstride : i64 [ pac.stride ]
                nstride : i64 [ nac.stride ]
                if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
                if [ nbv.byteStride > 0 ] nstride = nbv.byteStride
                poff : i64 [ pbv.byteOffset + pac.byteOffset ]
                noff : i64 [ nbv.byteOffset + nac.byteOffset ]
                vc : i32 [ i32[ pac.count ] ]
                # pass 1: nose y-range
                ny0 : f32 [  1000000.0 ]
                ny1 : f32 [ -1000000.0 ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : @u16 [ ((@nbase[ noff + i64[ i ] * nstride ]) to @u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
                    if [ pf[1] < ny0 ] ny0 = pf[1]
                    if [ pf[1] > ny1 ] ny1 = pf[1]
                if [ ny1 <= ny0 ] continue
                yspan : f32 [ ny1 - ny0 ]
                # pass 2: rest half-width (max |x|) at the nostril and mid bands
                hw0 : f32 [ 0.0 ]
                hw1 : f32 [ 0.0 ]
                cn0 : i32 [ 0 ]
                cn1 : i32 [ 0 ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : @u16 [ ((@nbase[ noff + i64[ i ] * nstride ]) to @u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
                    t  : f32 [ (pf[1] - ny0) / yspan ]
                    ax : f32 [ (pf[0] < 0.0) ? (0.0 - pf[0]) : pf[0] ]
                    if [ t < 0.333 ]
                        if [ ax > hw0 ] hw0 = ax
                        cn0 += 1
                    el [ t < 0.667 ]
                        if [ ax > hw1 ] hw1 = ax
                        cn1 += 1
                if [ cn0 == 0 || cn1 == 0 ] continue
                # target/rest width ratios at nostril (t=0) and mid (t=0.5)
                ns : f32 [ 1.0 ]
                ms : f32 [ 1.0 ]
                if [ hw0 > 0.0 ] ns = (nostril_span / 1000.0) / (2.0 * hw0)
                if [ hw1 > 0.0 ] ms = (mid_nose / 1000.0) / (2.0 * hw1)
                # nostril target y = the person's eye-to-nostril distance
                nyt : f32 [ epy - nostril_y / 1000.0 ]
                dy_full : f32 [ nyt - ny0 ]
                # pass 3: apply
                for [ i: i32 0, i < vc, i += 1 ]
                    pu : @u16 [ ((@nbase[ noff + i64[ i ] * nstride ]) to @u16) ]
                    m  : f32 [ (f32[ pu[2] ] / 65535.0) - neutral ]
                    if [ m <= 0.02 ] continue
                    w  : f32 [ m / (1.0 - neutral) ]
                    if [ w > 1.0 ] w = 1.0
                    pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
                    t  : f32 [ (pf[1] - ny0) / yspan ]
                    if [ t < 0.0 ] t = 0.0
                    if [ t > 1.0 ] t = 1.0
                    # lateral width: nostril -> mid -> unchanged at the root
                    ws : f32 [ 1.0 ]
                    if [ t < 0.5 ]
                        ws = ns + (ms - ns) * (t / 0.5)
                    el
                        ws = ms + (1.0 - ms) * ((t - 0.5) / 0.5)
                    pf[0] = pf[0] * (1.0 + w * (ws - 1.0))
                    # nostril height: shift the lower band in y, taper out by mid
                    yw : f32 [ 1.0 - t / 0.5 ]
                    if [ yw < 0.0 ] yw = 0.0
                    pf[1] = pf[1] + w * yw * dy_full
                puts 'hyperspace2: nose fit hw0={hw0} hw1={hw1} nostril dy={dy_full}'

    # read the skin: inverse-bind matrices + which joint node is the hinge, and
    # allocate the joint-matrix palette storage buffer (one mat4 per joint)
    func setup_skin []
        if [ !gmodel.skins || gmodel.skins.count == 0 ] return
        skin_idx = 0
        sk : gmodel.skins[ 0 ]
        nj : i32 [ i32[ sk.joints.count ] ]
        iba : gmodel.accessors[ sk.inverseBindMatrices ]
        ibv : gmodel.bufferViews[ i32[ iba.bufferView ] ]
        ibb : gmodel.buffers[ i32[ ibv.buffer ] ]
        base : @i8 [ ibb.data ]
        src  : @f32 [ ((@base[ ibv.byteOffset + iba.byteOffset ]) to @f32) ]
        ibm = array mat4f [ ]
        for [ j: i32 0, j < nj, j += 1 ]
            mm : mat4f [ mat4f.identity[] ]
            for [ k: i32 0, k < 16, k += 1 ]
                mm.m[ k ] = src[ j * 16 + k ]
            ibm.push[ mm ]
        for [ j: i32 0, j < nj, j += 1 ]
            jn : gmodel.nodes[ sk.joints[ j ] ]
            if [ jn.name && jn.name == 'Hinge' ] hinge_node = i32[ sk.joints[ j ] ]
        # locate the eye bones and remember their rest local rotation so gaze
        # is applied as a delta on top (node.rotation = gaze x rest)
        # find the eyeball aim bones and the lid-drag / caruncle follow bones
        ni : i32 [ 0 ]
        for [ nd: Node ] in gmodel.nodes
            if [ nd.name && nd.name == 'Eyeball.L' ]
                ebl = ni
                ebl_rest = nd.rotation
                gbl = ni
                gbl_rest = nd.translation
            if [ nd.name && nd.name == 'Eyeball.R' ]
                ebr = ni
                ebr_rest = nd.rotation
                gbr = ni
                gbr_rest = nd.translation
            if [ nd.name && nd.name == 'Eyelids Drag.L' ]
                dgl = ni
                dgl_rest = nd.rotation
            if [ nd.name && nd.name == 'Eyelids Drag.R' ]
                dgr = ni
                dgr_rest = nd.rotation
            if [ nd.name && nd.name == 'Caruncle.L' ]
                crl = ni
                crl_rest = nd.rotation
            if [ nd.name && nd.name == 'Caruncle.R' ]
                crr = ni
                crr_rest = nd.rotation
            ni += 1
        puts 'hyperspace2: ebl={ebl} ebr={ebr} dgl={dgl} dgr={dgr} crl={crl} crr={crr}'
        joint_buf = Buffer [ vk: vshader.vk, size: nj * 64,
            u_storage: true, m_host_visible: true, m_host_coherent: true ]
        joint_buf.hold[]
        puts 'hyperspace2: skin joints={nj} hinge_node={hinge_node}'

    # one eye's TRUE forward: sphere-fit the eyeball mesh, take the
    # corneal apex (the vertex protruding past the fitted sphere), and
    # express centre->apex in the aim bone's local frame. the old
    # "rest gaze is world +z" assumption was 5.8 degrees off the mesh —
    # a constant per-eye lie baked into every gaze label
    func fit_eye_axis [ is_l: bool ]
        enm : string [ (is_l) ? 'Eye L' : 'Eye R' ]
        emi : i32 [ -1 ]
        ewm : mat4f
        for [ nd5: Node ] in gmodel.nodes
            if [ nd5.name && nd5.name == enm ]
                emi = i32[ nd5.mesh ]
                ewm = nd5.world
        if [ emi < 0 ] return
        # normal equations for |v-c|^2 = r^2 (linear in 2c and c^2-r^2)
        mm : local f32 [ 16 ]
        rh : local f32 [ 4 ]
        for [ i: i32 0, i < 16, i += 1 ] mm[ i ] = 0.0
        for [ i: i32 0, i < 4, i += 1 ] rh[ i ] = 0.0
        emsh3 : gmodel.meshes[ emi ]
        for [ ep3: Primitive ] in emsh3.primitives
            pos3 : i32 [ -1 ]
            for [ value: @i64, a_name: string ] in ep3.attributes
                if [ a_name == 'POSITION' ] pos3 = i32[ value[0] ]
            if [ pos3 < 0 ] continue
            ac3 : gmodel.accessors[ pos3 ]
            bv3 : gmodel.bufferViews[ i32[ ac3.bufferView ] ]
            bb3 : gmodel.buffers[ i32[ bv3.buffer ] ]
            pb3 : @i8 [ bb3.data ]
            st3 : i64 [ ac3.stride ]
            if [ bv3.byteStride > 0 ] st3 = bv3.byteStride
            of3 : i64 [ bv3.byteOffset + ac3.byteOffset ]
            vc3 : i32 [ i32[ ac3.count ] ]
            for [ i: i32 0, i < vc3, i += 1 ]
                vf3 : @f32 [ ((@pb3[ of3 + i64[ i ] * st3 ]) to @f32) ]
                row : local f32 [ 4 ] [ 0.0, 0.0, 0.0, 1.0 ]
                row[ 0 ] = vf3[0] * 2.0
                row[ 1 ] = vf3[1] * 2.0
                row[ 2 ] = vf3[2] * 2.0
                bb4 : f32 [ vf3[0]*vf3[0] + vf3[1]*vf3[1] + vf3[2]*vf3[2] ]
                for [ a2: i32 0, a2 < 4, a2 += 1 ]
                    for [ b2: i32 0, b2 < 4, b2 += 1 ]
                        mm[ a2*4 + b2 ] = mm[ a2*4 + b2 ] + row[ a2 ] * row[ b2 ]
                    rh[ a2 ] = rh[ a2 ] + row[ a2 ] * bb4
        # gaussian elimination (tiny ridge keeps it well-posed)
        for [ i: i32 0, i < 4, i += 1 ] mm[ i*4 + i ] = mm[ i*4 + i ] + 0.000000001
        for [ i: i32 0, i < 4, i += 1 ]
            pv : f32 [ mm[ i*4 + i ] ]
            if [ pv > -0.0000001 && pv < 0.0000001 ] return
            for [ j: i32 0, j < 4, j += 1 ]
                if [ j == i ] continue
                fq : f32 [ mm[ j*4 + i ] / pv ]
                for [ k2: i32 0, k2 < 4, k2 += 1 ]
                    mm[ j*4 + k2 ] = mm[ j*4 + k2 ] - fq * mm[ i*4 + k2 ]
                rh[ j ] = rh[ j ] - fq * rh[ i ]
        ccx3 : f32 [ rh[ 0 ] / mm[ 0 ] ]
        ccy3 : f32 [ rh[ 1 ] / mm[ 5 ] ]
        ccz3 : f32 [ rh[ 2 ] / mm[ 10 ] ]
        # apex = farthest vertex from the fitted centre (the cornea)
        bd3 : f32 [ -1.0 ]
        apx : f32 [ 0.0 ]
        apy : f32 [ 0.0 ]
        apz : f32 [ 0.0 ]
        for [ ep3: Primitive ] in emsh3.primitives
            pos3 : i32 [ -1 ]
            for [ value: @i64, a_name: string ] in ep3.attributes
                if [ a_name == 'POSITION' ] pos3 = i32[ value[0] ]
            if [ pos3 < 0 ] continue
            ac3 : gmodel.accessors[ pos3 ]
            bv3 : gmodel.bufferViews[ i32[ ac3.bufferView ] ]
            bb3 : gmodel.buffers[ i32[ bv3.buffer ] ]
            pb3 : @i8 [ bb3.data ]
            st3 : i64 [ ac3.stride ]
            if [ bv3.byteStride > 0 ] st3 = bv3.byteStride
            of3 : i64 [ bv3.byteOffset + ac3.byteOffset ]
            vc3 : i32 [ i32[ ac3.count ] ]
            for [ i: i32 0, i < vc3, i += 1 ]
                vf3 : @f32 [ ((@pb3[ of3 + i64[ i ] * st3 ]) to @f32) ]
                ddx : f32 [ vf3[0] - ccx3 ]
                ddy : f32 [ vf3[1] - ccy3 ]
                ddz : f32 [ vf3[2] - ccz3 ]
                dd3 : f32 [ ddx*ddx + ddy*ddy + ddz*ddz ]
                if [ dd3 > bd3 ]
                    bd3 = dd3
                    apx = ddx
                    apy = ddy
                    apz = ddz
        if [ bd3 <= 0.0 ] return
        al3 : f32 [ sqrt[ bd3 ] ]
        apx = apx / al3
        apy = apy / al3
        apz = apz / al3
        # mesh-local axis -> world -> aim bone local (rotation transpose)
        awx : f32 [ ewm.m[0]*apx + ewm.m[4]*apy + ewm.m[8]*apz ]
        awy : f32 [ ewm.m[1]*apx + ewm.m[5]*apy + ewm.m[9]*apz ]
        awz : f32 [ ewm.m[2]*apx + ewm.m[6]*apy + ewm.m[10]*apz ]
        bi3 : i32 [ (is_l) ? ebl : ebr ]
        if [ bi3 < 0 ] return
        nb5 : gmodel.nodes[ bi3 ]
        bwm : mat4f [ nb5.world ]
        blx : f32 [ bwm.m[0]*awx + bwm.m[1]*awy + bwm.m[2]*awz ]
        bly : f32 [ bwm.m[4]*awx + bwm.m[5]*awy + bwm.m[6]*awz ]
        blz : f32 [ bwm.m[8]*awx + bwm.m[9]*awy + bwm.m[10]*awz ]
        if [ is_l ]
            fwd_lx = blx
            fwd_ly = bly
            fwd_lz = blz
        el
            fwd_rx = blx
            fwd_ry = bly
            fwd_rz = blz
        puts 'eye axis {enm}: bone-local ({blx}, {bly}, {blz})'

    # value noise over angle, wrapping at period p (the perlin mask that
    # drives iris sector cloning); returns -1..1, deterministic per seed
    func vnoise_ang [ seed: i64, t: f32, p: i32 ] -> f32
        tf : f32 [ t - floor[ t / f32[ p ] ] * f32[ p ] ]
        i0 : i32 [ i32[ floor[ tf ] ] % p ]
        i1 : i32 [ (i0 + 1) % p ]
        ft : f32 [ tf - floor[ tf ] ]
        s0 : i64 [ (seed + i64[ i0 ] * 2654435761) * 6364136223846793005 + 1442695040888963407 ]
        s1 : i64 [ (seed + i64[ i1 ] * 2654435761) * 6364136223846793005 + 1442695040888963407 ]
        v0 : f32 [ f32[ s0 % 1000 ] / 1000.0 ]
        v1 : f32 [ f32[ s1 % 1000 ] / 1000.0 ]
        uu : f32 [ ft * ft * (3.0 - 2.0 * ft) ]
        return v0 + (v1 - v0) * uu

    # 2D value noise: LCG-hashed lattice, smoothstep bilinear
    func vnoise2 [ seed: i64, x: f32, y: f32 ] -> f32
        xf : f32 [ floor[ x ] ]
        yf : f32 [ floor[ y ] ]
        x0 : i64 [ i64[ xf ] ]
        y0 : i64 [ i64[ yf ] ]
        fx : f32 [ x - xf ]
        fy : f32 [ y - yf ]
        s00 : i64 [ (seed + x0 * 2654435761 + y0 * 40503) * 6364136223846793005 + 1442695040888963407 ]
        s10 : i64 [ (seed + (x0 + 1) * 2654435761 + y0 * 40503) * 6364136223846793005 + 1442695040888963407 ]
        s01 : i64 [ (seed + x0 * 2654435761 + (y0 + 1) * 40503) * 6364136223846793005 + 1442695040888963407 ]
        s11 : i64 [ (seed + (x0 + 1) * 2654435761 + (y0 + 1) * 40503) * 6364136223846793005 + 1442695040888963407 ]
        v00 : f32 [ f32[ (s00 % 1000 + 1000) % 1000 ] / 1000.0 ]
        v10 : f32 [ f32[ (s10 % 1000 + 1000) % 1000 ] / 1000.0 ]
        v01 : f32 [ f32[ (s01 % 1000 + 1000) % 1000 ] / 1000.0 ]
        v11 : f32 [ f32[ (s11 % 1000 + 1000) % 1000 ] / 1000.0 ]
        sux : f32 [ fx * fx * (3.0 - 2.0 * fx) ]
        suy : f32 [ fy * fy * (3.0 - 2.0 * fy) ]
        a0 : f32 [ v00 + (v10 - v00) * sux ]
        b0 : f32 [ v01 + (v11 - v01) * sux ]
        return a0 + (b0 - a0) * suy

    # bilinear sample of one channel from CPU image pixels, u/v clamped
    func img_bilin [ sp: @u8, iw: i32, ih: i32, nch: i32, co: i32, u: f32, v: f32 ] -> f32
        bux : f32 [ u * f32[ iw - 1 ] ]
        bvy : f32 [ v * f32[ ih - 1 ] ]
        if [ bux < 0.0 ] bux = 0.0
        if [ bvy < 0.0 ] bvy = 0.0
        bmx2 : f32 [ f32[ iw - 1 ] - 0.001 ]
        bmy2 : f32 [ f32[ ih - 1 ] - 0.001 ]
        if [ bux > bmx2 ] bux = bmx2
        if [ bvy > bmy2 ] bvy = bmy2
        x0 : i32 [ i32[ floor[ bux ] ] ]
        y0 : i32 [ i32[ floor[ bvy ] ] ]
        fx2 : f32 [ bux - floor[ bux ] ]
        fy2 : f32 [ bvy - floor[ bvy ] ]
        o00 : i64 [ (i64[ y0 ] * i64[ iw ] + i64[ x0 ]) * i64[ nch ] + i64[ co ] ]
        o10 : i64 [ o00 + i64[ nch ] ]
        o01 : i64 [ o00 + i64[ iw ] * i64[ nch ] ]
        o11 : i64 [ o01 + i64[ nch ] ]
        a0 : f32 [ f32[ sp[ o00 ] ] ]
        a1 : f32 [ f32[ sp[ o10 ] ] ]
        a2 : f32 [ f32[ sp[ o01 ] ] ]
        a3 : f32 [ f32[ sp[ o11 ] ] ]
        t0 : f32 [ a0 + (a1 - a0) * fx2 ]
        t1 : f32 [ a2 + (a3 - a2) * fx2 ]
        return (t0 + (t1 - t0) * fy2) / 255.0

    # 1024-iris atlas (32x32 cells of 64px): every cell is a NEW iris
    # synthesized from the real map by radial sector cloning — three
    # rotated copies of the source blended by value noise over angle,
    # radial jitter, blend form varying per cell. covers the iris DOMAIN;
    # no real person's iris is reproduced or reproducible
    func build_iris_atlas [ src: Image, co_in: i32, seed0: i64 ] -> Image
        cs : i32 [ 128 ]
        nc : i32 [ 32 ]
        aw : i32 [ cs * nc ]
        out : Image [ width: aw, height: aw, format: Pixel.rgba8 ]
        op : @u8 [ out.pixels ]
        sp : @u8 [ src.pixels ]
        iw : i32 [ src.width ]
        ih : i32 [ src.height ]
        nch : i32 [ src.channels ]
        co : i32 [ (co_in < nch) ? co_in : (nch - 1) ]
        for [ cyi: i32 0, cyi < nc, cyi += 1 ]
            for [ cxi: i32 0, cxi < nc, cxi += 1 ]
                cseed : i64 [ seed0 + i64[ cyi * nc + cxi ] * 7919 ]
                cseed = cseed * 6364136223846793005 + 1442695040888963407
                rot1 : f32 [ f32[ cseed % 1000 ] / 1000.0 * 3.14159265 ]
                cseed = cseed * 6364136223846793005 + 1442695040888963407
                rot2 : f32 [ f32[ cseed % 1000 ] / 1000.0 * 3.14159265 ]
                cseed = cseed * 6364136223846793005 + 1442695040888963407
                rot3 : f32 [ f32[ cseed % 1000 ] / 1000.0 * 3.14159265 ]
                # inner iris (collarette) stays coherent: it only gets a
                # per-cell uniform scale, ENLARGING only — never wiggled
                cseed = cseed * 6364136223846793005 + 1442695040888963407
                inns : f32 [ 1.0 + (f32[ (cseed % 1000 + 1000) % 1000 ] / 1000.0) * 0.22 ]
                for [ pyi: i32 0, pyi < cs, pyi += 1 ]
                    for [ pxi: i32 0, pxi < cs, pxi += 1 ]
                        uu2 : f32 [ (f32[ pxi ] + 0.5) / f32[ cs ] ]
                        vv2 : f32 [ (f32[ pyi ] + 0.5) / f32[ cs ] ]
                        ddx : f32 [ uu2 - 0.5 ]
                        ddy : f32 [ vv2 - 0.5 ]
                        rr2 : f32 [ 2.0 * sqrt[ ddx*ddx + ddy*ddy ] ]
                        th2 : f32 [ atan2[ ddy, ddx ] ]
                        tn : f32 [ (th2 + 3.14159265) / 6.2831853 * 8.0 ]
                        # sector cloning ramps in with radius (zero at the
                        # pupil). the clone is PURELY ANGULAR — sectors
                        # move around the ring at the same radius, so the
                        # iris keeps its natural roundness exactly
                        ramp : f32 [ rr2 * rr2 * 2.5 ]
                        if [ ramp > 1.0 ] ramp = 1.0
                        rj : f32 [ rr2 / inns ]
                        w1 : f32 [ 0.5 + 0.5 * vnoise_ang[ cseed + 21, tn, 8 ] ]
                        w2 : f32 [ (0.5 + 0.5 * vnoise_ang[ cseed + 31, tn, 8 ]) * ramp ]
                        w3 : f32 [ (0.5 + 0.5 * vnoise_ang[ cseed + 41, tn, 8 ]) * ramp ]
                        s1v : f32 [ img_bilin[ sp, iw, ih, nch, co, 0.5 + 0.5 * rj * cos[ th2 + rot1 ], 0.5 + 0.5 * rj * sin[ th2 + rot1 ] ] ]
                        s2v : f32 [ img_bilin[ sp, iw, ih, nch, co, 0.5 + 0.5 * rj * cos[ th2 + rot2 ], 0.5 + 0.5 * rj * sin[ th2 + rot2 ] ] ]
                        s3v : f32 [ img_bilin[ sp, iw, ih, nch, co, 0.5 + 0.5 * rj * cos[ th2 + rot3 ], 0.5 + 0.5 * rj * sin[ th2 + rot3 ] ] ]
                        # winner-take-most: each angle shows ONE coherent
                        # rotated copy with narrow smooth seams — a real
                        # sector MOVE, not a translucent 3-way stack (that
                        # stack modulated ring brightness = the wobble)
                        q1 : f32 [ w1 * w1 ]
                        q2 : f32 [ w2 * w2 ]
                        q3 : f32 [ w3 * w3 ]
                        q1 = q1 * q1
                        q2 = q2 * q2
                        q3 = q3 * q3
                        ws : f32 [ q1 + q2 + q3 ]
                        if [ ws < 0.000001 ] ws = 0.000001
                        vo : f32 [ (s1v*q1 + s2v*q2 + s3v*q3) / ws ]
                        if [ vo < 0.0 ] vo = 0.0
                        if [ vo > 1.0 ] vo = 1.0
                        b8 : u8 [ u8[ vo * 255.0 ] ]
                        oo : i64 [ (i64[ cyi * cs + pyi ] * i64[ aw ] + i64[ cxi * cs + pxi ]) * 4 ]
                        op[ oo + 0 ] = b8
                        op[ oo + 1 ] = b8
                        op[ oo + 2 ] = b8
                        op[ oo + 3 ] = b8
        puts 'iris atlas: 1024 variants synthesized ({aw}x{aw})'
        return out

    # hamilton product r = a x b (quaternion compose)
    func qmul [ qa: quatf, qb: quatf ] -> quatf
        r : quatf
        r.w = qa.w * qb.w - qa.x * qb.x - qa.y * qb.y - qa.z * qb.z
        r.x = qa.w * qb.x + qa.x * qb.w + qa.y * qb.z - qa.z * qb.y
        r.y = qa.w * qb.y - qa.x * qb.z + qa.y * qb.w + qa.z * qb.x
        r.z = qa.w * qb.z + qa.x * qb.y - qa.y * qb.x + qa.z * qb.w
        return r

    func qconj [ q: quatf ] -> quatf
        r : quatf
        r.w = q.w
        r.x = 0.0 - q.x
        r.y = 0.0 - q.y
        r.z = 0.0 - q.z
        return r

    # shortest-arc quat rotating unit vector a onto unit vector b
    func arc_q [ ax: f32, ay: f32, az: f32, bx: f32, by: f32, bz: f32 ] -> quatf
        d : f32 [ ax*bx + ay*by + az*bz ]
        r : quatf
        if [ d < -0.9999 ]
            r.w = 0.0
            r.x = 0.0
            r.y = 1.0
            r.z = 0.0
            return r
        cx : f32 [ ay*bz - az*by ]
        cy : f32 [ az*bx - ax*bz ]
        cz : f32 [ ax*by - ay*bx ]
        w2 : f32 [ 1.0 + d ]
        nl : f32 [ sqrt[ w2*w2 + cx*cx + cy*cy + cz*cz ] ]
        r.w = w2 / nl
        r.x = cx / nl
        r.y = cy / nl
        r.z = cz / nl
        return r

    # delta rotation from pitch about local X and yaw about local Z (the eyeball
    # local frame has +Y forward, so pitch=X and yaw=Z, per the DAMPED_TRACK)
    func delta_q [ ax: f32, az: f32 ] -> quatf
        qx : quatf [ x: sin[ ax * 0.5 ], y: 0.0, z: 0.0, w: cos[ ax * 0.5 ] ]
        qz : quatf [ x: 0.0, y: 0.0, z: sin[ az * 0.5 ], w: cos[ az * 0.5 ] ]
        return qmul[ qx, qz ]

    # head-pose quat in world axes: yaw about y, pitch about x, roll about z
    func head_q [ hy: f32, hp: f32, hr: f32 ] -> quatf
        qy : quatf [ x: 0.0, y: sin[ hy * 0.5 ], z: 0.0, w: cos[ hy * 0.5 ] ]
        qx : quatf [ x: sin[ hp * 0.5 ], y: 0.0, z: 0.0, w: cos[ hp * 0.5 ] ]
        qz : quatf [ x: 0.0, y: 0.0, z: sin[ hr * 0.5 ], w: cos[ hr * 0.5 ] ]
        return qmul[ qy, qmul[ qx, qz ] ]

    func set_bone [ idx: i32, rest: quatf, d: quatf ]
        if [ idx < 0 ] return
        nb : gmodel.nodes[ idx ]
        nb.rotation = qmul[ d, rest ]

    # aim each eyeball by ITS OWN angles (vergence); drive each lid by its
    # eye's copy-rotation fractions (Eyelids Drag: 0.8 pitch + 0.2 yaw,
    # Caruncle: 0.8 pitch + 0.5 yaw)
    func aim_eyes []
        if [ ebl < 0 && ebr < 0 ] return
        set_bone[ ebl, ebl_rest, eye_dq_l ]
        set_bone[ ebr, ebr_rest, eye_dq_r ]
        dgql : quatf [ delta_q[ gaze_ly * 0.8, gaze_lx * 0.2 ] ]
        dgqr : quatf [ delta_q[ gaze_ry * 0.8, gaze_rx * 0.2 ] ]
        set_bone[ dgl, dgl_rest, dgql ]
        set_bone[ dgr, dgr_rest, dgqr ]
        crql : quatf [ delta_q[ gaze_ly * 0.8, gaze_lx * 0.5 ] ]
        crqr : quatf [ delta_q[ gaze_ry * 0.8, gaze_rx * 0.5 ] ]
        set_bone[ crl, crl_rest, crql ]
        set_bone[ crr, crr_rest, crqr ]

    # nudge the eyeball globe bones outward so each eyeball follows the socket;
    # local-x maps to world -x on these bones, so subtract to move both apart
    func apply_spacing []
        if [ gbl >= 0 ]
            nl : gmodel.nodes[ gbl ]
            nl.translation = vec3f [ gbl_rest.x - eye_spacing, gbl_rest.y, gbl_rest.z ]
        if [ gbr >= 0 ]
            nr : gmodel.nodes[ gbr ]
            nr.translation = vec3f [ gbr_rest.x + eye_spacing, gbr_rest.y, gbr_rest.z ]

    # move the lid/socket skin to follow the eyeballs: one-time, at load. shift
    # each Head/Body vert along world x toward its nearest eye, by eye_spacing
    # with a smooth falloff to zero at rad. the eyelid verts (skinned to Eye.L/
    # Caruncle/Eyelids Drag) and the surrounding cheek move together -> no squeeze
    func bake_eye_spacing []
        if [ !gmodel ] return
        lcx : f32 [ 0.0 ]
        lcy : f32 [ 0.0 ]
        lcz : f32 [ 0.0 ]
        rcx : f32 [ 0.0 ]
        rcy : f32 [ 0.0 ]
        rcz : f32 [ 0.0 ]
        gotl : bool [ false ]
        gotr : bool [ false ]
        for [ nd: Node ] in gmodel.nodes
            if [ nd.name && nd.name == 'Eye.L' ]
                wl : mat4f [ nd.world ]
                lcx = wl.m[12]
                lcy = wl.m[13]
                lcz = wl.m[14]
                gotl = true
            if [ nd.name && nd.name == 'Eye.R' ]
                wr : mat4f [ nd.world ]
                rcx = wr.m[12]
                rcy = wr.m[13]
                rcz = wr.m[14]
                gotr = true
        if [ !gotl || !gotr ] return
        # the outer eye corner sits about one eyeball radius lateral to the eye
        # centre; measure the globe's x-extent to convert corner span to a shift
        eye_rad : f32 [ 0.0126 ]
        gxmin : f32 [  1000000.0 ]
        gxmax : f32 [ -1000000.0 ]
        gotrad : bool [ false ]
        for [ emsh: Mesh ] in gmodel.meshes
            for [ eprim: Primitive ] in emsh.primitives
                emidx : i32 [ eprim.material ]
                emnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > emidx ]
                    emnm = gmodel.materials[ emidx ].name
                if [ emnm != 'Eyeball' ] continue
                epos_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in eprim.attributes
                    if [ a_name == 'POSITION' ] epos_ai = i32[ value[0] ]
                if [ epos_ai < 0 ] continue
                eac : gmodel.accessors[ epos_ai ]
                ebv : gmodel.bufferViews[ i32[ eac.bufferView ] ]
                ebb : gmodel.buffers[ i32[ ebv.buffer ] ]
                ebase : @i8 [ ebb.data ]
                estride : i64 [ eac.stride ]
                if [ ebv.byteStride > 0 ] estride = ebv.byteStride
                eoff : i64 [ ebv.byteOffset + eac.byteOffset ]
                evc : i32 [ i32[ eac.count ] ]
                for [ i: i32 0, i < evc, i += 1 ]
                    ef : @f32 [ ((@ebase[ eoff + i64[ i ] * estride ]) to @f32) ]
                    if [ ef[0] < gxmin ] gxmin = ef[0]
                    if [ ef[0] > gxmax ] gxmax = ef[0]
                    gotrad = true
        if [ gotrad ] eye_rad = (gxmax - gxmin) * 0.5
        # per-eye shift = half the gap between the target and the rest corner span
        dxc : f32 [ lcx - rcx ]
        rest_ipd : f32 [ (dxc < 0.0) ? (0.0 - dxc) : dxc ]
        rest_span : f32 [ rest_ipd + 2.0 * eye_rad ]
        eye_spacing = (span_mm / 1000.0 - rest_span) * 0.5
        puts 'hyperspace2: corner-span target={span_mm}mm rest={rest_span}m rad={eye_rad}m -> shift={eye_spacing}m'
        rad : f32 [ 0.055 ]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                mnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > midx ]
                    mnm = gmodel.materials[ midx ].name
                keep : bool [ (mnm == 'Head') || (mnm == 'Body') ]
                if [ !keep ] continue
                pos_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai = i32[ value[0] ]
                if [ pos_ai < 0 ] continue
                pac : gmodel.accessors[ pos_ai ]
                pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
                pbb : gmodel.buffers[ i32[ pbv.buffer ] ]
                pbase : @i8 [ pbb.data ]
                pstride : i64 [ pac.stride ]
                if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
                poff : i64 [ pbv.byteOffset + pac.byteOffset ]
                vc : i32 [ i32[ pac.count ] ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
                    dlx : f32 [ pf[0] - lcx ]
                    dly : f32 [ pf[1] - lcy ]
                    dlz : f32 [ pf[2] - lcz ]
                    drx : f32 [ pf[0] - rcx ]
                    dry : f32 [ pf[1] - rcy ]
                    drz : f32 [ pf[2] - rcz ]
                    dl : f32 [ sqrt[ dlx * dlx + dly * dly + dlz * dlz ] ]
                    dr : f32 [ sqrt[ drx * drx + dry * dry + drz * drz ] ]
                    d   : f32 [ dl ]
                    sgn : f32 [ (lcx >= 0.0) ? 1.0 : -1.0 ]
                    if [ dr < dl ]
                        d = dr
                        sgn = (rcx >= 0.0) ? 1.0 : -1.0
                    if [ d >= rad ] continue
                    t : f32 [ d / rad ]
                    fall : f32 [ 1.0 - (t * t * (3.0 - 2.0 * t)) ]
                    pf[0] = pf[0] + sgn * eye_spacing * fall

    # integer lattice hash → value in [-1, 1)
    func ihash [ ia: i32, ib: i32, ic: i32 ] -> f32
        h : i64 [ i64[ ia ] * 73856093 + i64[ ib ] * 19349663 + i64[ ic ] * 83492791 ]
        h = h * 6364136223846793005 + 1442695040888963407
        r : i64 [ (h >> 33) & 2097151 ]
        return f32[ r ] / 1048576.0 - 1.0

    # 3D value noise: smoothstep-interpolated lattice hash, range [-1, 1]
    func vnoise [ x: f32, y: f32, z: f32 ] -> f32
        x0 : i32 [ i32[ floor[ x ] ] ]
        y0 : i32 [ i32[ floor[ y ] ] ]
        z0 : i32 [ i32[ floor[ z ] ] ]
        xf : f32 [ x - f32[ x0 ] ]
        yf : f32 [ y - f32[ y0 ] ]
        zf : f32 [ z - f32[ z0 ] ]
        u : f32 [ xf * xf * (3.0 - 2.0 * xf) ]
        v : f32 [ yf * yf * (3.0 - 2.0 * yf) ]
        w : f32 [ zf * zf * (3.0 - 2.0 * zf) ]
        c000 : f32 [ ihash[ x0,     y0,     z0     ] ]
        c100 : f32 [ ihash[ x0 + 1, y0,     z0     ] ]
        c010 : f32 [ ihash[ x0,     y0 + 1, z0     ] ]
        c110 : f32 [ ihash[ x0 + 1, y0 + 1, z0     ] ]
        c001 : f32 [ ihash[ x0,     y0,     z0 + 1 ] ]
        c101 : f32 [ ihash[ x0 + 1, y0,     z0 + 1 ] ]
        c011 : f32 [ ihash[ x0,     y0 + 1, z0 + 1 ] ]
        c111 : f32 [ ihash[ x0 + 1, y0 + 1, z0 + 1 ] ]
        x00 : f32 [ c000 + (c100 - c000) * u ]
        x10 : f32 [ c010 + (c110 - c010) * u ]
        x01 : f32 [ c001 + (c101 - c001) * u ]
        x11 : f32 [ c011 + (c111 - c011) * u ]
        y0i : f32 [ x00 + (x10 - x00) * v ]
        y1i : f32 [ x01 + (x11 - x01) * v ]
        return y0i + (y1i - y0i) * w

    # two-octave value noise, EVEN about x=0 (both face halves match), at a seed
    # offset. large octave + small octave weighted by esw.
    func ev2 [ ex: f32, ey: f32, ez: f32, efl: f32, efs: f32, esd: f32, esw: f32, eoff: f32 ] -> f32
        gl : f32 [ 0.5 * (vnoise[ ex * efl + esd + eoff, ey * efl + esd + eoff, ez * efl + esd + eoff ] + vnoise[ (0.0 - ex) * efl + esd + eoff, ey * efl + esd + eoff, ez * efl + esd + eoff ]) ]
        gs : f32 [ 0.5 * (vnoise[ ex * efs + esd + eoff, ey * efs + esd + eoff, ez * efs + esd + eoff ] + vnoise[ (0.0 - ex) * efs + esd + eoff, ey * efs + esd + eoff, ez * efs + esd + eoff ]) ]
        return gl + esw * gs

    # universal face generator: two octaves of value noise (a large map for
    # broad shape, a small map added on top for detail) displace the base Head
    # verts in x/y/z. sampled at folded |x| so both halves stay mirror-symmetric;
    # the eye centres are pinned so the outer-eye anchors barely move. one pair of
    # maps + the eye anchors fits basically any face. NOT tied to any painted mask.
    func deform_cage []
        if [ !gmodel ] return
        lcx : f32 [ 0.0 ]
        lcy : f32 [ 0.0 ]
        lcz : f32 [ 0.0 ]
        rcx : f32 [ 0.0 ]
        rcy : f32 [ 0.0 ]
        rcz : f32 [ 0.0 ]
        gotl : bool [ false ]
        gotr : bool [ false ]
        for [ nd: Node ] in gmodel.nodes
            if [ nd.name && nd.name == 'Eye.L' ]
                wl : mat4f [ nd.world ]
                lcx = wl.m[12]
                lcy = wl.m[13]
                lcz = wl.m[14]
                gotl = true
            if [ nd.name && nd.name == 'Eye.R' ]
                wr : mat4f [ nd.world ]
                rcx = wr.m[12]
                rcy = wr.m[13]
                rcz = wr.m[14]
                gotr = true
        if [ !gotl || !gotr ] return
        dxc : f32 [ lcx - rcx ]
        ipd : f32 [ (dxc < 0.0) ? (0.0 - dxc) : dxc ]
        face_sz  : f32 [ ipd * 3.0 ]
        corner_r : f32 [ ipd * 0.6 ]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                mnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > midx ]
                    mnm = gmodel.materials[ midx ].name
                if [ mnm != 'Head' ] continue
                pos_ai : i32 [ -1 ]
                nrm_ai : i32 [ -1 ]
                tan_ai : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai = i32[ value[0] ]
                    if [ a_name == 'NORMAL'   ] nrm_ai = i32[ value[0] ]
                    if [ a_name == 'TANGENT'  ] tan_ai = i32[ value[0] ]
                if [ pos_ai < 0 || nrm_ai < 0 || tan_ai < 0 ] continue
                pac : gmodel.accessors[ pos_ai ]
                nac : gmodel.accessors[ nrm_ai ]
                tac : gmodel.accessors[ tan_ai ]
                pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
                nbv : gmodel.bufferViews[ i32[ nac.bufferView ] ]
                tbv : gmodel.bufferViews[ i32[ tac.bufferView ] ]
                pbase : @i8 [ gmodel.buffers[ i32[ pbv.buffer ] ].data ]
                nbase : @i8 [ gmodel.buffers[ i32[ nbv.buffer ] ].data ]
                tbase : @i8 [ gmodel.buffers[ i32[ tbv.buffer ] ].data ]
                pstride : i64 [ pac.stride ]
                nstride : i64 [ nac.stride ]
                tstride : i64 [ tac.stride ]
                if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
                if [ nbv.byteStride > 0 ] nstride = nbv.byteStride
                if [ tbv.byteStride > 0 ] tstride = tbv.byteStride
                poff : i64 [ pbv.byteOffset + pac.byteOffset ]
                noff : i64 [ nbv.byteOffset + nac.byteOffset ]
                toff : i64 [ tbv.byteOffset + tac.byteOffset ]
                vc : i32 [ i32[ pac.count ] ]
                # per-vertex label buffer (world delta) — the training target
                dsz : i32 [ vc * 3 ]
                if [ cage_n != vc ]
                    cage_delta = new f32 [ dsz ]
                    cage_n = vc
                # large map = broad shape; small map adds detail on top.
                # freq = 1/wavelength (in face_sz units); amp scales the face.
                fl : f32 [ 1.0 / (face_sz * n_large_wl) ]
                fs : f32 [ 1.0 / (face_sz * n_small_wl) ]
                an : f32 [ face_sz * n_large_amp ]        # along-normal magnitude
                at : f32 [ face_sz * n_tan_amp ]          # tangent-plane magnitude
                swt : f32 [ (n_large_amp > 0.0) ? (n_small_amp / n_large_amp) : 0.4 ]
                seam_band : f32 [ ipd * 0.4 ]
                # per-variant seed offset walks the noise field to a new region
                sd : f32 [ f32[ face_idx ] * 17.0 ]
                for [ i: i32 0, i < vc, i += 1 ]
                    pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
                    nf : @f32 [ ((@nbase[ noff + i64[ i ] * nstride ]) to @f32) ]
                    tf : @f32 [ ((@tbase[ toff + i64[ i ] * tstride ]) to @f32) ]
                    px : f32 [ pf[0] ]
                    py : f32 [ pf[1] ]
                    pz : f32 [ pf[2] ]
                    # local surface frame: normal N, tangent T, bitangent B = NxT*w
                    nln : f32 [ sqrt[ nf[0] * nf[0] + nf[1] * nf[1] + nf[2] * nf[2] ] ]
                    tln : f32 [ sqrt[ tf[0] * tf[0] + tf[1] * tf[1] + tf[2] * tf[2] ] ]
                    if [ nln <= 0.0 || tln <= 0.0 ] continue
                    nx : f32 [ nf[0] / nln ]
                    ny : f32 [ nf[1] / nln ]
                    nz : f32 [ nf[2] / nln ]
                    tx : f32 [ tf[0] / tln ]
                    ty : f32 [ tf[1] / tln ]
                    tz : f32 [ tf[2] / tln ]
                    tw : f32 [ tf[3] ]
                    bx : f32 [ (ny * tz - nz * ty) * tw ]
                    by : f32 [ (nz * tx - nx * tz) * tw ]
                    bz : f32 [ (nx * ty - ny * tx) * tw ]
                    # one perlin along the normal, two across the tangent plane
                    pn : f32 [ ev2[ px, py, pz, fl, fs, sd, swt, 11.0 ] ]
                    pt : f32 [ ev2[ px, py, pz, fl, fs, sd, swt, 53.0 ] ]
                    pb : f32 [ ev2[ px, py, pz, fl, fs, sd, swt, 97.0 ] ]
                    # mix the three into a world-space offset
                    ox : f32 [ an * pn * nx + at * pt * tx + at * pb * bx ]
                    oy : f32 [ an * pn * ny + at * pt * ty + at * pb * by ]
                    oz : f32 [ an * pn * nz + at * pt * tz + at * pb * bz ]
                    # keep the midline welded: zero lateral (x) movement at x=0
                    afx : f32 [ (px < 0.0) ? (0.0 - px) : px ]
                    sxt : f32 [ afx / seam_band ]
                    if [ sxt > 1.0 ] sxt = 1.0
                    ox = ox * (sxt * sxt * (3.0 - 2.0 * sxt))
                    dl : f32 [ sqrt[ (px - lcx) * (px - lcx) + (py - lcy) * (py - lcy) + (pz - lcz) * (pz - lcz) ] ]
                    dr : f32 [ sqrt[ (px - rcx) * (px - rcx) + (py - rcy) * (py - rcy) + (pz - rcz) * (pz - rcz) ] ]
                    da : f32 [ (dl < dr) ? dl : dr ]
                    damp : f32 [ da / corner_r ]
                    if [ damp > 1.0 ] damp = 1.0
                    dxv : f32 [ ox * damp ]
                    dyv : f32 [ oy * damp ]
                    dzv : f32 [ oz * damp ]
                    pf[0] += dxv
                    pf[1] += dyv
                    pf[2] += dzv
                    if [ cage_delta ]
                        cage_delta[ i * 3 ]     = dxv
                        cage_delta[ i * 3 + 1 ] = dyv
                        cage_delta[ i * 3 + 2 ] = dzv
                puts 'deform_cage: face={face_idx} an={an} at={at} nv={vc} label={vc * 3}'

    # copy the painted _V_EDGE red channel into TEXCOORD_1.x so subdivide carries
    # it to the GPU; the skinned shader turns it into alpha, fading the mask edge
    # to transparent so it mixes into the background
    func bake_edge_uv1 []
        if [ !gmodel ] return
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                mnm : string [ '' ]
                if [ gmodel.materials && gmodel.materials.count > midx ]
                    mnm = gmodel.materials[ midx ].name
                if [ mnm != 'Head' ] continue
                edge_ai : i32 [ -1 ]
                shad_ai : i32 [ -1 ]
                uv1_ai  : i32 [ -1 ]
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == '_V_EDGE'    ] edge_ai = i32[ value[0] ]
                    if [ a_name == '_V_SHADOWS' ] shad_ai = i32[ value[0] ]
                    if [ a_name == 'TEXCOORD_1' ] uv1_ai  = i32[ value[0] ]
                if [ edge_ai < 0 || uv1_ai < 0 ] continue
                eac : gmodel.accessors[ edge_ai ]
                uac : gmodel.accessors[ uv1_ai ]
                ebv : gmodel.bufferViews[ i32[ eac.bufferView ] ]
                ubv : gmodel.bufferViews[ i32[ uac.bufferView ] ]
                ebase : @i8 [ gmodel.buffers[ i32[ ebv.buffer ] ].data ]
                ubase : @i8 [ gmodel.buffers[ i32[ ubv.buffer ] ].data ]
                estride : i64 [ eac.stride ]
                ustride : i64 [ uac.stride ]
                if [ ebv.byteStride > 0 ] estride = ebv.byteStride
                if [ ubv.byteStride > 0 ] ustride = ubv.byteStride
                eoff : i64 [ ebv.byteOffset + eac.byteOffset ]
                uoff : i64 [ ubv.byteOffset + uac.byteOffset ]
                # shadows: blue 0.5..1.0 -> 0..1 darkening in uv1.y;
                # .y is written for EVERY vert so buffer junk never
                # darkens unpainted skin
                sbase : @i8
                sstride : i64 [ 0 ]
                soff : i64 [ 0 ]
                if [ shad_ai >= 0 ]
                    sac : gmodel.accessors[ shad_ai ]
                    sbv : gmodel.bufferViews[ i32[ sac.bufferView ] ]
                    sbase = gmodel.buffers[ i32[ sbv.buffer ] ].data
                    sstride = sac.stride
                    if [ sbv.byteStride > 0 ] sstride = sbv.byteStride
                    soff = sbv.byteOffset + sac.byteOffset
                vc : i32 [ i32[ eac.count ] ]
                for [ i: i32 0, i < vc, i += 1 ]
                    eu : @u16 [ ((@ebase[ eoff + i64[ i ] * estride ]) to @u16) ]
                    uv : @f32 [ ((@ubase[ uoff + i64[ i ] * ustride ]) to @f32) ]
                    uv[0] = f32[ eu[0] ] / 65535.0
                    uv[1] = 0.0
                    if [ shad_ai >= 0 ]
                        su : @u16 [ ((@sbase[ soff + i64[ i ] * sstride ]) to @u16) ]
                        sw : f32 [ (f32[ su[2] ] / 65535.0 - 0.5) / 0.5 ]
                        if [ sw < 0.0 ] sw = 0.0
                        if [ sw > 1.0 ] sw = 1.0
                        uv[1] = sw
                puts 'bake_edge_uv1: verts={vc} shadows={shad_ai}'

    # pose the rig for this frame (hinge + eyes), recompose worlds, and write the
    # skin palette; the caller then pushes rigid node worlds via update_animated
    func update_palette []
        if [ skin_idx < 0 || !joint_buf ] return
        sk : gmodel.skins[ skin_idx ]
        nj : i32 [ i32[ sk.joints.count ] ]
        if [ hinge_node >= 0 ]
            hn : gmodel.nodes[ hinge_node ]
            s2 : f32 [ sin[ hinge_ang * 0.5 ] ]
            hn.rotation = quatf [ x: s2, y: 0.0, z: 0.0, w: cos[ hinge_ang * 0.5 ] ]
        aim_eyes[]
        apply_spacing[]
        gmodel.compute_worlds[]
        dst : @f32 [ ((joint_buf.data) to @f32) ]
        for [ j: i32 0, j < nj, j += 1 ]
            jn : gmodel.nodes[ sk.joints[ j ] ]
            jm : mat4f [ jn.world.mul[ ibm[ j ] ] ]
            for [ k: i32 0, k < 16, k += 1 ]
                dst[ j * 16 + k ] = jm.m[ k ]

    # point a named material's baseColorTexture at an albedo map. uri is
    # relative to the model dir (models/), so textures one level up under
    # share/textures use '../'. resolves through Res.res_path at load time
    func set_albedo [ matname: string, uri: string ]
        if [ !gmodel || !gmodel.materials ] return
        if [ !gmodel.images ]   gmodel.images   = array GltfImage [ ]
        if [ !gmodel.textures ] gmodel.textures = array GltfTexture [ ]
        img : GltfImage [ uri: path uri ]
        gmodel.images += img
        iidx : i64 [ gmodel.images.count - 1 ]
        tx : GltfTexture [ source: iidx ]
        gmodel.textures += tx
        tidx : i64 [ gmodel.textures.count - 1 ]
        for [ m: Material ] in gmodel.materials
            if [ m.name == matname ]
                if [ !m.pbrMetallicRoughness ]
                    m.pbrMetallicRoughness = PbrMetallicRoughness [ ]
                m.pbrMetallicRoughness.baseColorTexture = TextureInfo [ index: tidx ]

    # give a material a base-color alpha in (0,1) so the pipeline routes it to
    # the transparent shader (drawn after opaque, depth-test no-write)
    func mark_transparent [ matname: string, av: f32 ]
        if [ !gmodel || !gmodel.materials ] return
        for [ m: Material ] in gmodel.materials
            if [ m.name == matname ]
                if [ !m.pbrMetallicRoughness ]
                    m.pbrMetallicRoughness = PbrMetallicRoughness [ ]
                m.pbrMetallicRoughness.baseColorFactor = vec4f [ 1.0, 1.0, 1.0, av ]

    # wire the purchased skin/eye albedo maps onto the model's materials
    func bind_albedos []
        set_albedo[ 'Head',    '../share/textures/head/skin_albedo.1001.png' ]
        set_albedo[ 'Body',    '../share/textures/head/skin_albedo.1002.png' ]
        set_albedo[ 'Eyeball', '../share/textures/eye/sclera_albedo.png' ]
        set_albedo[ 'Iris',    '../share/textures/eye/iris_fibres.png' ]
        # the eyeball is the translucent cornea layer over the iris

    # find the head mesh index (first mesh carrying a 'Head'-material prim)
    func head_mesh_index [] -> i32
        mi : i32 [ 0 ]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                if [ gmodel.materials && gmodel.materials.count > midx ]
                    if [ gmodel.materials[ midx ].name == 'Head' ] return mi
            mi += 1
        return -1

    # overlay the control cage: project every Head vertex and drop a pixel dot
    # so you SEE the cage you are fitting (element-local coords, over the render)
    func draw_cage_dots [ cv: Canvas ] -> none
        if [ !gmodel ] return
        hmesh : i32 [ head_mesh_index[] ]
        if [ hmesh < 0 ] return
        W : mat4f [ mat4f.identity[] ]
        for [ nd: Node ] in gmodel.nodes
            if [ !nd.AF_query_name[ 'mesh' ] ] continue
            if [ i32[ nd.mesh ] == hmesh ] W = nd.world
        mvp : mat4f [ vshader.proj.mul[ vshader.view ].mul[ W ] ]
        pos_ai : i32 [ -1 ]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                if [ !gmodel.materials || gmodel.materials.count <= midx ] continue
                if [ gmodel.materials[ midx ].name != 'Head' ] continue
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai = i32[ value[0] ]
        if [ pos_ai < 0 ] return
        pac : gmodel.accessors[ pos_ai ]
        pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
        pbase : @i8 [ gmodel.buffers[ i32[ pbv.buffer ] ].data ]
        pstride : i64 [ pac.stride ]
        if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
        poff : i64 [ pbv.byteOffset + pac.byteOffset ]
        vc : i32 [ i32[ pac.count ] ]
        bw : f32 [ bounds.w ]
        bh : f32 [ bounds.h ]
        cv.fill_color[ '#39ff14' ]
        for [ i: i32 0, i < vc, i += 1 ]
            pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
            px : f32 [ pf[0] ]
            py : f32 [ pf[1] ]
            pz : f32 [ pf[2] ]
            cw : f32 [ mvp.m[3] * px + mvp.m[7] * py + mvp.m[11] * pz + mvp.m[15] ]
            if [ cw <= 0.0001 ] continue
            cx : f32 [ mvp.m[0] * px + mvp.m[4] * py + mvp.m[8]  * pz + mvp.m[12] ]
            cy : f32 [ mvp.m[1] * px + mvp.m[5] * py + mvp.m[9]  * pz + mvp.m[13] ]
            sx : f32 [ (cx / cw * 0.5 + 0.5) * bw ]
            sy : f32 [ (cy / cw * 0.5 + 0.5) * bh ]
            cv.fill_rect_fast[ sx - 1.0, sy - 1.0, 2.0, 2.0 ]

    # scan the 128px face with a 32px window; each window that catches control
    # points is one training patch (two poses) whose label is those points'
    # normalized position, world offset, and a diffuse center-falloff weight
    func export_patches [ idx: i32 ] -> none
        if [ !gmodel || !cap_a || !vrender || !cage_delta ] return
        cap_b : Image [ vrender.color ]
        # normalize both poses to the scan resolution
        fa : cap_a.resize[ scan_px, scan_px ]
        fb : cap_b.resize[ scan_px, scan_px ]
        hmesh : i32 [ head_mesh_index[] ]
        if [ hmesh < 0 ] return
        W : mat4f [ mat4f.identity[] ]
        for [ nd: Node ] in gmodel.nodes
            if [ !nd.AF_query_name[ 'mesh' ] ] continue
            if [ i32[ nd.mesh ] == hmesh ] W = nd.world
        mvpA : mat4f [ vshader.proj.mul[ view_a ].mul[ W ] ]
        mvpB : mat4f [ vshader.proj.mul[ vshader.view ].mul[ W ] ]
        sdir : path 'samples'
        sdir.make_dir[]
        # locate the head POSITION stream
        pos_ai : i32 [ -1 ]
        for [ msh: Mesh ] in gmodel.meshes
            for [ prim: Primitive ] in msh.primitives
                midx : i32 [ prim.material ]
                if [ !gmodel.materials || gmodel.materials.count <= midx ] continue
                if [ gmodel.materials[ midx ].name != 'Head' ] continue
                for [ value: @i64, a_name: string ] in prim.attributes
                    if [ a_name == 'POSITION' ] pos_ai = i32[ value[0] ]
        if [ pos_ai < 0 ] return
        pac : gmodel.accessors[ pos_ai ]
        pbv : gmodel.bufferViews[ i32[ pac.bufferView ] ]
        pbase : @i8 [ gmodel.buffers[ i32[ pbv.buffer ] ].data ]
        pstride : i64 [ pac.stride ]
        if [ pbv.byteStride > 0 ] pstride = pbv.byteStride
        poff : i64 [ pbv.byteOffset + pac.byteOffset ]
        vc : i32 [ i32[ pac.count ] ]
        sp : f32 [ f32[ scan_px ] ]
        # project every control vert into both poses once (5 f32 per vert)
        if [ pj_cap != vc ]
            pj = new f32 [ vc * 5 ]
            pj_cap = vc
        if [ !recbuf ] recbuf = new f32 [ 6 ]
        for [ i: i32 0, i < vc, i += 1 ]
            pf : @f32 [ ((@pbase[ poff + i64[ i ] * pstride ]) to @f32) ]
            px : f32 [ pf[0] ]
            py : f32 [ pf[1] ]
            pz : f32 [ pf[2] ]
            cwa : f32 [ mvpA.m[3] * px + mvpA.m[7] * py + mvpA.m[11] * pz + mvpA.m[15] ]
            cwb : f32 [ mvpB.m[3] * px + mvpB.m[7] * py + mvpB.m[11] * pz + mvpB.m[15] ]
            ok : f32 [ 1.0 ]
            if [ cwa <= 0.0001 || cwb <= 0.0001 ] ok = 0.0
            if [ ok < 0.5 ]
                pj[ i * 5 + 4 ] = 0.0
                continue
            cxa : f32 [ mvpA.m[0] * px + mvpA.m[4] * py + mvpA.m[8]  * pz + mvpA.m[12] ]
            cya : f32 [ mvpA.m[1] * px + mvpA.m[5] * py + mvpA.m[9]  * pz + mvpA.m[13] ]
            cxb : f32 [ mvpB.m[0] * px + mvpB.m[4] * py + mvpB.m[8]  * pz + mvpB.m[12] ]
            cyb : f32 [ mvpB.m[1] * px + mvpB.m[5] * py + mvpB.m[9]  * pz + mvpB.m[13] ]
            pj[ i * 5 + 0 ] = (cxa / cwa * 0.5 + 0.5) * sp
            pj[ i * 5 + 1 ] = (cya / cwa * 0.5 + 0.5) * sp
            pj[ i * 5 + 2 ] = (cxb / cwb * 0.5 + 0.5) * sp
            pj[ i * 5 + 3 ] = (cyb / cwb * 0.5 + 0.5) * sp
            pj[ i * 5 + 4 ] = 1.0
        pw : f32 [ f32[ patch_px ] ]
        bhalf : i32 [ patch_px / 2 ]
        lim : i32 [ scan_px - patch_px ]
        np : i32 [ 0 ]
        # slide the window; anchor membership in pose A, follow the same points
        # into pose B so both crops frame the same patch of face
        for [ wy: i32 0, wy <= lim, wy += patch_stride ]
            for [ wx: i32 0, wx <= lim, wx += patch_stride ]
                n : i32 [ 0 ]
                bcx : f32 [ 0.0 ]
                bcy : f32 [ 0.0 ]
                for [ i: i32 0, i < vc, i += 1 ]
                    if [ pj[ i * 5 + 4 ] < 0.5 ] continue
                    ax : f32 [ pj[ i * 5 + 0 ] ]
                    ay : f32 [ pj[ i * 5 + 1 ] ]
                    if [ ax < f32[ wx ] || ax >= f32[ wx + patch_px ] ] continue
                    if [ ay < f32[ wy ] || ay >= f32[ wy + patch_px ] ] continue
                    bcx += pj[ i * 5 + 2 ]
                    bcy += pj[ i * 5 + 3 ]
                    n += 1
                if [ n < 1 ] continue
                bcx = bcx / f32[ n ]
                bcy = bcy / f32[ n ]
                bwx : i32 [ i32[ bcx ] - bhalf ]
                bwy : i32 [ i32[ bcy ] - bhalf ]
                ca : fa.crop[ wx, wy, patch_px, patch_px ]
                cb : fb.crop[ bwx, bwy, patch_px, patch_px ]
                ca.png[ path 'samples/{idx}_{wy}_{wx}_a.png' ]
                cb.png[ path 'samples/{idx}_{wy}_{wx}_b.png' ]
                lp : path 'samples/{idx}_{wy}_{wx}.f32'
                f : @FILE [ fopen[ lp, 'wb' ] ]
                if [ f ]
                    for [ i: i32 0, i < vc, i += 1 ]
                        if [ pj[ i * 5 + 4 ] < 0.5 ] continue
                        ax : f32 [ pj[ i * 5 + 0 ] ]
                        ay : f32 [ pj[ i * 5 + 1 ] ]
                        if [ ax < f32[ wx ] || ax >= f32[ wx + patch_px ] ] continue
                        if [ ay < f32[ wy ] || ay >= f32[ wy + patch_px ] ] continue
                        nx : f32 [ (ax - f32[ wx ]) / pw ]
                        ny : f32 [ (ay - f32[ wy ]) / pw ]
                        cx : f32 [ (nx - 0.5) * 2.0 ]
                        cy : f32 [ (ny - 0.5) * 2.0 ]
                        r  : f32 [ sqrt[ cx * cx + cy * cy ] ]
                        if [ r > 1.0 ] r = 1.0
                        wgt : f32 [ (1.0 - r) * (1.0 - r) ]
                        recbuf[ 0 ] = nx
                        recbuf[ 1 ] = ny
                        recbuf[ 2 ] = cage_delta[ i * 3 ]
                        recbuf[ 3 ] = cage_delta[ i * 3 + 1 ]
                        recbuf[ 4 ] = cage_delta[ i * 3 + 2 ]
                        recbuf[ 5 ] = wgt
                        fwrite[ recbuf, 4, i64[ 6 ], f ]
                    fclose[ f ]
                np += 1
        puts 'export: idx={idx} patches={np} scan={scan_px} win={patch_px} stride={patch_stride}'

    # arm a two-angle per-region patch capture (driven in draw[])
    public func begin_export [] -> none
        if [ export_step != 0 ] return
        export_yaw0 = yaw
        export_step = 3

    public func draw [ w: Window ]
        if [ w.draw_stage != CanvasType.screen ] return
        ux.will_animate = true
        if [ bounds.w <= 0.0 || bounds.h <= 0.0 ] return
        # perlin-labeled export: the render target holds the yaw uploaded on the
        # PREVIOUS frame, so aim one frame ahead and grab on the next
        if [ vrender && export_step != 0 ]
            if [ export_step == 3 ]
                yaw = export_yaw0 - export_dyaw
                export_step = 1
            el [ export_step == 1 ]
                cap_a = Image [ vrender.color ]
                cap_a.hold[]
                view_a = vshader.view
                yaw = export_yaw0 + export_dyaw
                export_step = 2
            el [ export_step == 2 ]
                export_patches[ export_idx ]
                yaw = export_yaw0
                if [ cap_a ] cap_a.drop[]
                cap_a = null
                export_idx += 1
                export_step = 0
                puts 'hyperspace2: exported sample {export_idx}'
        # plot capture: aim at a random screen plot one frame, grab and save
        # the next (the render target holds the previous frame's pose)
        if [ vrender && capture_left > 0 && anch_set ]
            fpc : picker[]
            if [ rig ] fpc = rig
            if [ fpc ]
                if [ capture_state == 0 ]
                    # pose GROUPS: look 0 anchors the group seed, later
                    # looks REPLAY it — the same seat, head, identity and
                    # lighting come back out; only the plot stream (its
                    # own seed) moves, so gaze alone varies in the group
                    if [ cap_look_i == 0 ]
                        cap_gseed = cap_seed
                    el
                        cap_seed = cap_gseed
                    # ~10% of pose groups render CLEAN (no augmentation)
                    # and carry clean: 1 — the eval set; augmented frames
                    # must never grade themselves
                    cap_seed = cap_seed * 6364136223846793005 + 1442695040888963407
                    cap_clean = ((cap_seed % 1000 + 1000) % 1000) < 100
                    # the person shifts per sample: lateral/vertical offset
                    # and seat distance vary; the camera axis stays fixed on
                    # the rig, so the face lands off-center in frame. all
                    # camera state is THIS view's own — the shared root
                    # camera is untouched
                    cap_seed = cap_seed * 6364136223846793005 + 1442695040888963407
                    r1 : f32 [ f32[ cap_seed % 1000 ] / 1000.0 ]
                    cap_seed = cap_seed * 6364136223846793005 + 1442695040888963407
                    r2 : f32 [ f32[ cap_seed % 1000 ] / 1000.0 ]
                    cap_seed = cap_seed * 6364136223846793005 + 1442695040888963407
                    r3 : f32 [ f32[ cap_seed % 1000 ] / 1000.0 ]
                    mxc : f32 [ (eyec_lx + eyec_rx) * 0.5 ]
                    myc : f32 [ (eyec_ly + eyec_ry) * 0.5 ]
                    mzc : f32 [ (eyec_lz + eyec_rz) * 0.5 ]
                    # dist_min/max = CAMERA-to-face range, sampled uniform
                    # in APPARENT SIZE (1/range): half the set sits nearer
                    # than ~0.3m, the nearest filling the frame
                    u3 : f32 [ (r3 + 1.0) * 0.5 ]
                    ia : f32 [ 1.0 / fpc.dist_min ]
                    ib : f32 [ 1.0 / fpc.dist_max ]
                    rng : f32 [ 1.0 / (ib + u3 * (ia - ib)) ]
                    # the face is placed INSIDE the camera's view cone: an
                    # angular offset up to 60% of half-fov, capped by the
                    # move_x/y world extents. the camera + screen mount is
                    # then derived around the fixed face — a close face can
                    # no longer fall outside the mounted camera's view
                    hfov : f32 [ radians[ fpc.cam_fov_deg ] * 0.5 ]
                    axm : f32 [ hfov * 0.6 ]
                    aym : f32 [ hfov * 0.6 ]
                    cx2 : f32 [ atan2[ fpc.move_x, rng ] ]
                    cy2 : f32 [ atan2[ fpc.move_y, rng ] ]
                    if [ axm > cx2 ] axm = cx2
                    if [ aym > cy2 ] aym = cy2
                    tilt : f32 [ radians[ fpc.cam_tilt_deg ] ]
                    tnx : f32 [ tan[ r1 * axm ] ]
                    tny : f32 [ tan[ r2 * aym ] ]
                    # ray from camera to face in world: tilted forward plus
                    # the in-frame angular offset along the camera basis
                    dx2 : f32 [ tnx ]
                    dy2 : f32 [ 0.0 - sin[ tilt ] - tny * cos[ tilt ] ]
                    dz2 : f32 [ 0.0 - cos[ tilt ] + tny * sin[ tilt ] ]
                    dl2 : f32 [ sqrt[ dx2*dx2 + dy2*dy2 + dz2*dz2 ] ]
                    dx2 = dx2 / dl2
                    dy2 = dy2 / dl2
                    dz2 = dz2 / dl2
                    ccx : f32 [ mxc - rng * dx2 ]
                    ccy : f32 [ myc - rng * dy2 ]
                    ccz : f32 [ mzc - rng * dz2 ]
                    # screen center hangs below/behind the camera mount
                    cap_scx = ccx + fpc.cam_x
                    cap_scy = ccy - fpc.cam_y
                    cap_scz = ccz + fpc.cam_z
                    # the BOTTOM mount needs a physical working distance
                    # too: closer than dist_min slices the head on the
                    # near plane — a pose no real capture can produce
                    b1x : f32 [ cap_scx - fpc.cam_x - mxc ]
                    b1y : f32 [ cap_scy - fpc.cam_y - myc ]
                    b1z : f32 [ cap_scz - fpc.cam_z - mzc ]
                    bd1 : f32 [ sqrt[ b1x*b1x + b1y*b1y + b1z*b1z ] ]
                    yaw = 0.0
                    pitch = tilt
                    dist = 1.0
                    look_x = ccx
                    look_y = ccy - sin[ tilt ]
                    look_z = ccz - cos[ tilt ]
                    fov_x = fpc.cam_fov_deg
                    # head pose: independent uniform draw, world axes —
                    # gaze plots stay uniform over the screen (coupling the
                    # two was tried and trained WORSE; keep them decoupled)
                    pex0 : f32 [ fpc.plot_extent ]
                    if [ pex0 > 1.0 ] pex0 = 1.0
                    cap_seed = cap_seed * 6364136223846793005 + 1442695040888963407
                    r4 : f32 [ f32[ cap_seed % 1000 ] / 1000.0 ]
                    cap_seed = cap_seed * 6364136223846793005 + 1442695040888963407
                    r5 : f32 [ f32[ cap_seed % 1000 ] / 1000.0 ]
                    cap_seed = cap_seed * 6364136223846793005 + 1442695040888963407
                    r6 : f32 [ f32[ cap_seed % 1000 ] / 1000.0 ]
                    cap_hy = r4 * fpc.rot_yaw
                    cap_hp = r5 * fpc.rot_pitch
                    cap_hr = r6 * fpc.rot_roll
                    # head ORIENTATION comes from a random fitted
                    # recording; position stays the uniform draw
                    if [ fpc.recs_n > 0 ]
