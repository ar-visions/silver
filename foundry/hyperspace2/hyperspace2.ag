                        # face instead, so lid/caruncle skin reads in
                        # profile while the eyes still track the mark
                        if [ fpc.side_verify ]
                            dxv = 0.24
                            dyv = 0.02
                            dzv = 0.10
                        dv : f32 [ sqrt[ dxv*dxv + dyv*dyv + dzv*dzv ] ]
                        if [ dv < 0.05 ] dv = 0.05
                        look_x = mxv
                        look_y = myv
                        look_z = mzv
                        dist = dv
                        pitch = asin[ dyv / dv ]
                        yaw = atan2[ dxv, dzv ]
                        fov_x = 16.0
                el
                    save_verify_frame[ fpc ]
                    capture_state = 0
                    capture_left -= 1
                    cap_look_i += 1
                    if [ cap_look_i >= fpc.looks ] cap_look_i = 0
                    if [ (cap_idx % 100) == 0 ] puts 'plot capture: {cap_idx} done, {capture_left} left'
                    if [ capture_left == 0 ]
                        puts 'plot capture complete: {cap_idx} samples'
                        if [ fpc.gen > 0 ] exit[ 0 ]
        # the picker fed new landmarks -> rebuild this face to them
        if [ vrender && (face_idx != baked_fidx || span_mm != baked_span || nostril_span != baked_nos || mid_nose != baked_mid || nostril_y != baked_ny) ]
            reload_model[]
        cv : Canvas [ w.screen ]
        if [ !vrender ]
            expect model_path, 'no model path given'
            vshader   = SkinnedLit [ vk: cv.vk, name: 'skinned' ]
            rshader   = RigidLit   [ vk: cv.vk, name: 'rigid' ]
            cshader   = CorneaIR   [ vk: cv.vk, name: 'cornea' ]
            # load the body and the eyeball spheres (Eye L/R -> CorneaIR volume,
            # the real bump). drop the flat Iris disc meshes (RigidLit planes)
            vshader.groups = array string [ 'Body', 'Eye L', 'Eye R' ]
            # mount the .res sidecar if present, then resolve the model and
            # its buffer uris through the wrapper: loose files win, else the
            # archive cache. base = the asset root, one dir above the model
            root    : path model_path.parent_dir[].parent_dir[]
            resf    : model_path.change_ext[ "res" ]
            reldir  : model_path.parent_dir[].filename[]
            relname : '{reldir}/{model_path.filename[]}'
            gpath   : model_path
            if [ resf.exists[] ]
                Res.mount[ resf, root, path '{root}/cache', '12345' ]
                gpath = Res.res_path[ relname ]
                GltfBuffer.set_base[ path reldir ]
            el
                GltfBuffer.set_base[ model_path.parent_dir[] ]
            expect gpath && gpath.exists[], 'model does not exist: {model_path}'
            # member sets outside init do NOT retain: without the hold the
            # loaded model drops before Render init and Model.finish silently
            # falls back to the default quad
            gm : GltfModel [ gpath.load[ typeid[ GltfModel ], null ] ]
            gm.hold[]
            gmodel = gm
            gm.compute_worlds[]
            # bind the skin/eye albedo maps onto the named materials before
            # the pipelines build (mat_tex reads baseColorTexture)
            bind_albedos[]
            # blend shape keys into POSITION
            apply_morphs[]
            # generic control-cage deform (random field per variant for now)
            deform_cage[]
            # stash the mask-edge alpha in uv1 so it survives subdivide
            bake_edge_uv1[]
            baked_fidx = face_idx
            baked_span = span_mm
            baked_nos  = nostril_span
            baked_mid  = mid_nose
            baked_ny   = nostril_y
            # read the skin's inverse-bind matrices, find the joint node, build
            # the joint-matrix palette storage buffer
            setup_skin[]
            update_palette[]
            sm : map Au[string] [ ]
            if [ joint_buf ] sm[ 'joints_pal' ] = joint_buf
            # bind every eye map onto the cornea shader; the single frag samples
            # fibres, melanin, three iris displacements, and the sclera veins
            eye_files : array string [ 'iris_fibres.png', 'iris_melanin.png', 'iris_displacement_a.png', 'iris_displacement_b.png', 'iris_displacement_c.png', 'sclera_displacement.png' ]
            eye_keys  : array string [ 'iris', 'iris_melanin', 'iris_disp_a', 'iris_disp_b', 'iris_disp_c', 'sclera_disp' ]
            eye_tex = array Texture [ ]
            for [ ei: i32 0, ei < eye_files.count, ei += 1 ]
                kf : eye_files[ ei ]
                kk : eye_keys[ ei ]
                ep : path '{model_path.parent_dir[]}/../share/textures/eye/{kf}'
                if [ !ep.exists[] ] continue
                eim : Image [ uri: ep ]
                emx : i32 [ (eim.width > eim.height) ? eim.width : eim.height ]
                eml : i32 [ 1 ]
                for [ q: i32 emx, q > 1, q = q / 2 ]
                    eml += 1
                # fibres + melanin + the three speckle overlays become
                # 1024-variant atlases (mips cap at 3 so filtering never
