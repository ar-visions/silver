class SparseInfo
    public bufferView:     u64
    public componentType:  ComponentType

class Sparse
    public count:          u64
    public indices:        SparseInfo
    public values:         SparseInfo

class Accessor
    public normalized:      bool
    public bufferView:      u64
    # start of this accessor's data WITHIN its bufferView (shared/interleaved
    # views place several accessors in one view at different offsets)
    public byteOffset:      u64
    public componentType:   ComponentType
    public type:   CompoundType
    public count:           u64
    public min:             vec3f
    public max:             vec3f
    public sparse:          Sparse
    public stride:          u64
    public total_bytes:     u64
    public vcount:          array u64
    public component_size:  array u64

    func member_type [] -> Au_t
        res : Au_t[null]
        switch [componentType]
        case ComponentType.BYTE
        case ComponentType.UNSIGNED_BYTE
            switch [type]
            case CompoundType.SCALAR
                res = typeid[i8]
            #case CompoundType_VEC2
            #    return typeid[vec2i8]
            #case CompoundType_VEC3
            #    return typeid[vec3i8]
            case CompoundType.VEC4
                res = typeid[rgba8]
            break
        case ComponentType.SHORT
        case ComponentType.UNSIGNED_SHORT
            switch [type]
            case CompoundType.SCALAR
                res = typeid[i16]
            case CompoundType.VEC4
                res = typeid[rgba16]

        case ComponentType.UNSIGNED_INT
            switch [type]
            case CompoundType.SCALAR
                res = typeid[i32]

        case ComponentType.FLOAT
            switch [type]
            case CompoundType.SCALAR
                res = typeid[f32]
            case CompoundType.VEC2
                return typeid[vec2f]
            case CompoundType.VEC3
                return typeid[vec3f]
            case CompoundType.VEC4
                return typeid[vec4f]
            #case CompoundType_MAT2
            #   return typeid[mat2f]
            #case CompoundType_MAT3
            #   return typeid[mat3f]
            case CompoundType.MAT4
                res = typeid[mat4f]
            break
        default
            break
        
        return res

    func vcount_val [] -> u64
        vsize: u64 [0]
        switch [type]
        case CompoundType.SCALAR
            vsize = 1
        case CompoundType.VEC2
            vsize = 2
        case CompoundType.VEC3
            vsize = 3
        case CompoundType.VEC4
            vsize = 4
        case CompoundType.MAT2
            vsize = 4
        case CompoundType.MAT3
            vsize = 9
        case CompoundType.MAT4
            vsize = 16
        default
            fault 'invalid CompoundType2'
        return vsize

    func component_size_val [] -> u64
        scalar_sz: u64 [0]
        switch [componentType]
        case ComponentType.BYTE
            scalar_sz = 1
        case ComponentType.UNSIGNED_BYTE
            scalar_sz = 1
        case ComponentType.SHORT
            scalar_sz = 2
        case ComponentType.UNSIGNED_SHORT
            scalar_sz = 2
        case ComponentType.UNSIGNED_INT
            scalar_sz = 4
        case ComponentType.FLOAT
            scalar_sz = 4
        default
            fault 'invalid ComponentType'
        return scalar_sz

    func init [] 
        stride      = vcount_val[] * component_size_val[]
        total_bytes = stride * vcount_val[]

class BufferView
    public name:            string
    public buffer:          u64
    public byteLength:      u64
    public byteOffset:      u64
    # element stride for INTERLEAVED vertex views; 0/absent = tightly packed
    public byteStride:      u64
    public target:          TargetType

class Skin
    public name:            string
    public joints:          array i64
    public inverseBindMatrices: i32
    public extras:          Au
    public extensions:      Au

class GltfTransform
    mutable jdata:           JData
    mutable local_mat:       mat4f
    mutable local_default:   mat4f
    mutable istate:          i32
    mutable iparent:         i32
    mutable ichildren:       array i64

    func propagate [] 
        m: (iparent != -1) ? jdata.states[iparent] : mat4f.identity[]
        jdata.states[istate] = local_mat.mul[ m ]
        for [i: i64] in ichildren
            t:jdata.transforms[i]
            t.propagate

    func multiply [m: mat4f] 
        local_mat = local_mat.mul[ m ]
        propagate

    func set [m: mat4f] 
        local_mat = m
        propagate

    func set_default [] 
        local_mat = local_default
        propagate

class JData
    mutable states:          array mat4f
    mutable transforms:      array GltfTransform
    mutable local_mat :      mat4f

class Node
    public name:            string
    public parent:          Node
    public skin:            i32
    public mesh:            i32
    public translation:     vec3f
    public rotation:        quatf
    public scale:           vec3f
    # full column-major node transform (a gltf node carries EITHER matrix OR
    # TRS) — sketchfab-style exports use matrix + children hierarchies
    public matrix:          mat4f
    # composed scene-graph WORLD transform (GltfModel.compute_worlds walks the
    # scene hierarchy). m[15] == 0 until computed.
    mutable world:          mat4f
    public weights:         array f32
    public children:        array i64
    mutable joint_index:     i32
    mutable processed:       bool
    mutable mx_joints:       Au

    func get_primitive [mdl: GltfModel, n: cstr] -> Primitive
        m: mdl.meshes[mesh]
        if [m]
            return m.get_primitive [n]
        return null

class Primitive
