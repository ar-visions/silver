class Model
    public nodes:            array Node
    public skins:            array Skin
    public accessors:        array Accessor
    public bufferViews:      array BufferView
    public meshes:           array Mesh
    public buffers:          array Buffer
    public animations:       array Animation
    public scenes:           array Scene
    public materials:        array Material
    public scene:            u64
    public asset:            AssetDesc
    func find [n: cstr] -> Node
        for [node: Node] in nodes
            if [strcmp [node.name, n] == 0]
                return node
        return null

    func index_of [n: cstr] -> i32
        i: i32 [0]
        for [node: Node] in nodes
            if [strcmp [node.name, n] == 0]
                return i
            i += 1
        return -1

    func index [n: string] -> Node
        return find [n]

    func node_transform [joints: JData, parent_mat: mat4f, node_index: i32, parent: Transform] -> Transform
        node: nodes[node_index]
        node.processed = true
        transform: Transform

        if [ node.joint_index >= 0 ]
            transform.jdata = joints
            rotation_m4: mat4f [node.rotation]
            transform.local_mat = mat4f []
            transform.local_mat = transform.local_mat.translate [node.translation]
            transform.local_mat = transform.local_mat.mul[ rotation_m4 ]
            transform.local_mat = transform.local_mat.scale[ node.scale ]
            transform.local_default = transform.local_mat
            transform.iparent = parent.istate
            transform.istate  = node.joint_index
            state_mat: parent_mat.mul[ transform.local_default ]
            joints.states[transform.istate] = state_mat

            for [ child_idx: i64 ] in node.children
                ch: node_transform[ joints, state_mat, child_idx, transform]
                if [ch]
                    transform.ichildren += ch.istate
            
            joints.transforms += transform
        
        return transform

    func joints [node: Node] -> JData
        if [node.mx_joints]
            return node.mx_joints
        j: JData[]
        ident: mat4f.identity
        if [node.skin != -1]
            skin: skins[node.skin]
            all_children: map bool[i64]
            for [node_idx: i64] in skin.joints
                n: nodes[node_idx]
                for [i: i64] in n.children
                    all_children.set [i, true]
            j_index: i32 [0]
            for [node_idx: i64] in skin.joints
                n: nodes[node_idx]
                n.joint_index = j_index
                j_index += 1
            n: i32 [skin.joints.count]
            j.transforms = array Transform []
            j.states     = array mat4f []
            
            for [ i: i32 0, i < n, i += 1 ]
                j.states.push ident

            
            for [node_idx: i64] in skin.joints
                if [all_children.contains [node_idx]]
                    continue
                node_transform [j, ident, node_idx, null]
        el
            n: i32 [j.states.count]
            for [i: i32 0, i < n, i += 1]
                j.states.push [ident]
        node.mx_joints = j
        return j

