import vec
import <stdio.h>
    +LOL=1
    +HI

import <string.h>

enum ComponentType
    NONE:           0
    BYTE:           5120
    UNSIGNED_BYTE:  5121
    SHORT:          5122
    UNSIGNED_SHORT: 5123
    UNSIGNED_INT:   5125
    FLOAT:          5126

enum CompoundType
    NONE:            0
    SCALAR:          1
    VEC2:            2
    VEC3:            3
    VEC4:            4
    MAT2:            5
    MAT3:            6
    MAT4:            7

enum TargetType
    NONE:            0
    ARRAY_BUFFER:    34962
    ELEMENT_BUFFER:  34963

enum Mode
    NONE:           0
    LINES:          1
    LINE_LOOP:      2
    TRIANGLES:      4
    TRIANGLE_STRIP: 5
    TRIANGLE_FAN:   6
    QUADS:          7

enum Interpolation
    LINEAR:                 0
    STEP:                   1
    CUBICSPLINE:            2


enum Polygon
    undefined: 0
    tri:       1
    quad:      2
    wire:      3
    mixed:     4
    ngon:      5

enum Asset
    undefined:     0
    color:         1
    normal:        2
    material:      3
    reflect:       4
    env:           5
    attachment:    6
    depth_stencil: 7
    multisample:   8

enum Sampling
    undefined: 0
    nearest:   1
    linear:    2
    ansio:     3


class Sampler
    public input:          u64
    public output:         u64
    public interpolation:  Interpolation

class ChannelTarget
    public node:           u64
