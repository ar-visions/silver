class GltfModel
    public nodes:            array Node
    public skins:            array Skin
    public accessors:        array Accessor
    public bufferViews:      array BufferView
    public meshes:           array Mesh
    public buffers:          array GltfBuffer
    public animations:       array Animation
    public scenes:           array Scene
    public materials:        array Material
    public images:           array GltfImage
    public textures:         array GltfTexture
    public samplers:         array GltfSampler
    public scene:            u64
    public asset:            AssetDesc

    # resolve a material TextureInfo to its image FILE path (relative uris
    # resolve against GltfBuffer.base, same as the .bin buffers). null when
    # the material has no such texture.
    func texture_uri [ ti: TextureInfo ] -> path
        if [ !ti || !textures ] return null
        if [ ti.index < 0 || ti.index >= textures.count ] return null
        tx : textures[ ti.index ]
        if [ !tx || !images ] return null
        if [ tx.source < 0 || tx.source >= images.count ] return null
        im : images[ tx.source ]
        if [ !im || !im.uri ] return null
        base : GltfBuffer.get_base[]
        if [ base ] return path '{base}/{im.uri}'
        return im.uri
    func find [n: cstr] -> Node
        for [node: Node] in nodes
            if [strcmp [node.name, n] == 0]
                return node
        return null

    # a node's LOCAL transform: its matrix when present, else T·R·S per the
    # gltf spec (guards: absent rotation parses to the ZERO quat — skip it)
    func node_local [ n: Node ] -> mat4f
        if [ n.matrix.m[15] != 0.0 ] return n.matrix
        m : mat4f.identity[]
        m = m.translate[ n.translation ]
        if [ n.rotation.x != 0 || n.rotation.y != 0 || n.rotation.z != 0 || n.rotation.w != 0 ]
            m = m.rotate[ n.rotation ]
        if [ n.scale.x != 0 || n.scale.y != 0 || n.scale.z != 0 ]
            m = m.scale[ n.scale ]
        return m

    func compose_world [ ni: i64, parent: mat4f ]
        n : nodes[ ni ]
        if [ !n ] return
        w : mat4f [ parent.mul[ node_local[ n ] ] ]
        n.world = w
        if [ n.children ]
            for [ ci: i32 0, ci < n.children.count, ci += 1 ]
                compose_world[ n.children[ ci ], w ]

    # compose every node's world matrix from the scene roots — axis-fix and
    # scale live in sketchfab-style parent chains, so flat node transforms
    # render models sideways/unscaled. nodes not reached from a scene keep
    # their local as world (legacy flat files with no scenes).
    func compute_worlds []
        if [ scenes && scenes.count > 0 ]
            sc : scenes[ scene ]
            if [ sc && sc.nodes ]
                for [ ri: i32 0, ri < sc.nodes.count, ri += 1 ]
                    compose_world[ sc.nodes[ ri ], mat4f.identity[] ]
        for [ n: Node ] in nodes
            if [ n.world.m[15] == 0.0 ]
                n.world = node_local[ n ]

    func index_of [n: cstr] -> i32
        i: i32 [0]
        for [node: Node] in nodes
            if [strcmp [node.name, n] == 0]
                return i
            i += 1
        return -1

    func index [n: string] -> Node
        return find [n]

    func node_transform [joints: JData, parent_mat: mat4f, node_index: i32, parent: GltfTransform] -> GltfTransform
        node: nodes[node_index]
        node.processed = true
        transform: GltfTransform

        if [ node.joint_index >= 0 ]
            transform.jdata = joints
            rotation_m4: mat4f [node.rotation]
            transform.local_mat = mat4f []
            transform.local_mat = transform.local_mat.translate [node.translation]
            transform.local_mat = transform.local_mat.mul[ rotation_m4 ]
            transform.local_mat = transform.local_mat.scale[ node.scale ]
            transform.local_default = transform.local_mat
            transform.iparent = parent.istate
            transform.istate  = node.joint_index
            state_mat: parent_mat.mul[ transform.local_default ]
            joints.states[transform.istate] = state_mat

            for [ child_idx: i64 ] in node.children
                ch: node_transform[ joints, state_mat, child_idx, transform]
                if [ch]
                    transform.ichildren += ch.istate
            
            joints.transforms += transform
        
        return transform

    func joints [node: Node] -> JData
        if [node.mx_joints]
            return node.mx_joints
        j: JData[]
        ident: mat4f.identity[]
        if [node.skin != -1]
            skin: skins[node.skin]
            all_children: map bool[i64]
            for [node_idx: i64] in skin.joints
                n: nodes[node_idx]
                for [i: i64] in n.children
                    all_children.set [i, true]
            j_index: i32 [0]
            for [node_idx: i64] in skin.joints
                n: nodes[node_idx]
                n.joint_index = j_index
                j_index += 1
            n: i32 [skin.joints.count]
            j.transforms = array GltfTransform []
            j.states     = array mat4f []
            
            for [ i: i32 0, i < n, i += 1 ]
                j.states.push ident

            
            for [node_idx: i64] in skin.joints
                if [all_children.contains [node_idx]]
                    continue
                node_transform [j, ident, node_idx, null]
        el
            n: i32 [j.states.count]
            for [i: i32 0, i < n, i += 1]
                j.states.push [ident]
        node.mx_joints = j
        return j

struct HumanVertex
    pos:       vec3f
    normal:    vec3f
    uv0:       vec2f
    uv1:       vec2f
    tangent:   vec3f
    joints0:   vec3f
    joints1:   vec3f
    weights0:  vec3f
    weights1:  vec3f


func pbr_defaults [] -> PbrMetallicRoughness
    static pbr: PbrMetallicRoughness
    if [ !pbr ]
        pbr = PbrMetallicRoughness[]
        pbr.baseColorFactor            = vec4f [ 0, 0, 1, 1 ]
        pbr.metallicFactor             = 1.0
        pbr.roughnessFactor            = 1.0
        pbr.emissiveFactor             = vec3f [ 0, 0, 0 ]
        pbr.diffuseFactor              = vec4f [ 1, 1, 1, 1 ]
        pbr.specularFactor             = vec3f [ 1, 1, 1 ]
        pbr.glossinessFactor           = 1.0
        pbr.sheenColorFactor           = vec3f [ 0, 0, 0 ]
        pbr.sheenRoughnessFactor       = 0.0
        pbr.clearcoatFactor            = 0.0
        pbr.clearcoatRoughnessFactor   = 0.0
        pbr.transmissionFactor         = 0.0
        pbr.thicknessFactor            = 0.0
        pbr.attenuationColor           = vec3f [ 1, 1, 1 ]
        pbr.attenuationDistance        = 1e20
        pbr.ior                        = 1.5
        pbr.specularColorFactor        = vec3f [ 1, 1, 1 ]
        pbr.emissiveStrength           = 1.0
        pbr.iridescenceFactor          = 0.0
        pbr.iridescenceIor             = 1.3
        pbr.iridescenceThicknessMinimum = 100.0
        pbr.iridescenceThicknessMaximum = 400.0
    return pbr
