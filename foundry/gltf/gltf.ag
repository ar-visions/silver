import vec
import <stdio.h>
    +LOL=1
    +HI

import <string.h>

enum ComponentType
    NONE:           0
    BYTE:           5120
    UNSIGNED_BYTE:  5121
    SHORT:          5122
    UNSIGNED_SHORT: 5123
    UNSIGNED_INT:   5125
    FLOAT:          5126

enum CompoundType
    NONE:            0
    SCALAR:          1
    VEC2:            2
    VEC3:            3
    VEC4:            4
    MAT2:            5
    MAT3:            6
    MAT4:            7

enum TargetType
    NONE:            0
    ARRAY_BUFFER:    34962
    ELEMENT_BUFFER:  34963

enum Mode
    NONE:           0
    LINES:          1
    LINE_LOOP:      2
    TRIANGLES:      4
    TRIANGLE_STRIP: 5
    TRIANGLE_FAN:   6
    QUADS:          7

enum Interpolation
    LINEAR:                 0
    STEP:                   1
    CUBICSPLINE:            2

class Sampler
    public input:          u64
    public output:         u64
    public interpolation:  Interpolation

class ChannelTarget
    public node:           u64
    public path:           string

class Channel
    public sampler:        u64
    public target:         ChannelTarget

class Animation
    public name:           string
    public samplers:       array Sampler

class SparseInfo
    public bufferView:     u64
    public componentType:  ComponentType

class Sparse
    public count:          u64
    public indices:        SparseInfo
    public values:         SparseInfo

class Accessor
    public normalized:      bool
    public bufferView:      u64
    public componentType:   ComponentType
    public type:            CompoundType
    public count:           u64
    public min:             vec3f
    public max:             vec3f
    public sparse:          Sparse
    public stride:          u64
    public total_bytes:     u64
    public vcount:          array u64
    public component_size:  array u64

    func member_type [] -> Au_t
        res : Au_t[null]
        switch [componentType]
        case ComponentType.BYTE
        case ComponentType.UNSIGNED_BYTE
            switch [type]
            case CompoundType.SCALAR
                res = typeid[i8]
            #case CompoundType_VEC2
            #    return typeid[vec2i8]
            #case CompoundType_VEC3
            #    return typeid[vec3i8]
            case CompoundType.VEC4
                res = typeid[rgba8]
            break
        case ComponentType.SHORT
        case ComponentType.UNSIGNED_SHORT
            switch [type]
            case CompoundType.SCALAR
                res = typeid[i16]
            case CompoundType.VEC4
                res = typeid[rgba16]

        case ComponentType.UNSIGNED_INT
            switch [type]
            case CompoundType.SCALAR
                res = typeid[i32]

        case ComponentType.FLOAT
            switch [type]
            case CompoundType.SCALAR
                res = typeid[f32]
            case CompoundType.VEC2
                res = typeid[vec2f]
            case CompoundType.VEC3
                res = typeid[vec3f]
            case CompoundType.VEC4
                res = typeid[vec4f]
            #case CompoundType_MAT2
            #   return typeid[mat2f]
            #case CompoundType_MAT3
            #   return typeid[mat3f]
            case CompoundType.MAT4
                res = typeid[mat4f]
        
        return res











    func vcount_val [] -> u64
        vsize: u64 [0]
        switch [type]
        case CompoundType.SCALAR
            vsize = 1
        case CompoundType.VEC2
            vsize = 2
        case CompoundType.VEC3
            vsize = 3
        case CompoundType.VEC4
            vsize = 4
        case CompoundType.MAT2
            vsize = 4
        case CompoundType.MAT3
            vsize = 9
        case CompoundType.MAT4
            vsize = 16
        default
            fault 'invalid CompoundType2'
        return vsize

    func component_size_val [] -> u64
        scalar_sz: u64 [0]
        switch [componentType]
        case ComponentType.BYTE
            scalar_sz = 1
        case ComponentType.UNSIGNED_BYTE
            scalar_sz = 1
        case ComponentType.SHORT
            scalar_sz = 2
        case ComponentType.UNSIGNED_SHORT
            scalar_sz = 2
        case ComponentType.UNSIGNED_INT
            scalar_sz = 4
        case ComponentType.FLOAT
            scalar_sz = 4
        default
            fault 'invalid ComponentType'
        return scalar_sz

    func init [] -> none
        stride      = vcount_val * component_size_val
        total_bytes = stride * vcount_val

class BufferView
    public buffer:          u64
    public byteLength:      u64
    public byteOffset:      u64
    public target:          TargetType

class Skin
    public name:            string
    public joints:          array i64
    public inverseBindMatrices: i32
    public extras:          Au
    public extensions:      Au

class Transform
    public jdata:           JData
    public istate:          i32
    public local_mat:       mat4f
    public local_default:   mat4f
    public iparent:         i32
    public ichildren:       array i64

    func propagate [] -> none
        m: (iparent != -1) ? mat4f[ jdata.states[iparent] ] : mat4f.identity
        jdata.states[istate] = local_mat.mul[ m ]
        for [i: i64] in ichildren
            jdata.transforms[i].propagate

    func multiply [m: mat4f] -> none
        local_mat = local_mat.mul[ m ]
        propagate

    func set [m: mat4f] -> none
        local_mat = m
        propagate

    func set_default [] -> none
        local_mat = local_default
        propagate

class JData
    public states:          array mat4f
    public transforms:      array Transform
    public local_mat :      mat4f

class Node
    public name:            string
    public parent:          Node
    public skin:            i32
    public mesh:            i32
    public translation:     vec3f
    public rotation:        quatf
    public scale:           vec3f
    public weights:         array f32
    public children:        array i64
    public joint_index:     i32
    public processed:       bool
    public mx_joints:       Au
    func primitive [mdl: Model, n: cstr] -> Primitive
        m: mdl.meshes[mesh]
        if [m]
            return m.primitive [n]
        return null

class Primitive
    public name:            string
    public attributes:      map map
    public indices:         u64
    public material:        i32
    public mode:            Mode
    public targets:         array map

class MeshExtras
    public target_names:    array string

class Mesh
    public name:            string
    public primitives:      array Primitive
    public weights:         array f32
    public extras:          MeshExtras
    func primitive [n: cstr] -> Primitive
        for [p: Primitive] in primitives
            if [strcmp [p.name, n] == 0]
                return p
        return null

