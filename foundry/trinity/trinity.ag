shader UVQuad
    public model : mat4f
    public view : mat4f
    public proj : mat4f
    attrib Surface [ color ] : 1, rgba8
    func init [ ]
        model = mat4f_ident[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f_look_at[ ref eye, ref center, ref up ]
        proj  = mat4f_ortho[ -1, 1, -1, 1, 0.1, 10.0 ]


