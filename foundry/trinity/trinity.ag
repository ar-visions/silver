# ---- environment cubemap ----
# generates cubemap from equirectangular image
# stays in trinity (uses models/shaders)

# func environment [vk: vk_context, img: image, r_axis: vec3f, rotation: f32] -> texture
#     create 6-face cubemap texture
#     for each face: set up view matrix, render equirect to face
#     generate mipmaps

