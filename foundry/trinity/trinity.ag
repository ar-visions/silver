class uniforms
    public t : trinity
    expect s : shader
    public u_memory : array
    public u_buffers : array
    public func update [ ] -> none
        for [ b: buffer ] in u_buffers
            uniform_transfer[ s, b.data, b.user ]
            update[ b, null ]

    func init [ ]
        types:  list [ unmanaged: true ]
        ty:     typeid[ s ]
        while [ ty != typeid[ shader ] ]
            insert_after[ types, ty, -1 ]
            ty = ty.parent_type
        u_index:  0
        total_uniform: i32 [ 0 ]
        for [ i: types.first, i, i = i.next ]
            ty = i.value
            u_size: uniform_size[ ty ]
            total_uniform += u_size
        u_buffers = array [ 4 ]
        u_memory  = alloc[ typeid[ u8 ], total_uniform ]
        src: u8* [ u_memory ]
        for [ i: types.first, i, i = i.next ]
            ty = i.value
            u_size: uniform_size[ ty ]
            uniform_buf: buffer [ t: t, size: u_size,
                u_uniform: true, u_dst: true, m_host_visible: true, m_host_coherent: true,
                data: ref src[u_index], user: ty ]
            push[ u_buffers, uniform_buf ]
            u_index += u_size

class shader
    public t               : trinity
    public name : string
    public vert : string
    public frag : string
    public comp : string
    public reloads : i32
    intern vk_vert : VkShaderModule
    intern vk_frag : VkShaderModule
    intern vk_comp : VkShaderModule
    func vert [] -> tokens
    func frag [] -> tokens
    func comp [] -> tokens
    public func reload [ reloads: ARef ] -> bool
        r: ref i32 [ reloads ]
        if [ r && *r < reloads ]
            *r = reloads
            return true
        names: string[3] [ frag, vert, comp ]
        values: ref VkShaderModule[3] [ ref vk_frag, ref vk_vert, ref vk_comp ]
        found:      false
        recompiled: false
        for [ i: 0, i < 3, i++ ]
            nm: names[i]
            if [ !nm ]
                continue
            input: path '{nm}'
            if [ !nm || !file_exists[ "%o", input ] ]
                continue
            spv_file: '{nm}.spv'
            found = true
            source_stat: struct stat
            spv_stat:    struct stat
            src_exists: stat[ input.chars, ref source_stat ] == 0
            spv_exists: stat[ spv_file.chars, ref spv_stat ] == 0
            if [ !spv_exists || source_stat.st_mtime > spv_stat.st_mtime ]
                ext_s: ext[ input ]
                tmp: tempfile[ ext_s.chars ]
                replace_includes[ input.chars, tmp.chars ]
                cmd: 'glslangValidator -V100 --target-env vulkan1.2 {tmp} -o {spv_file}'
                print "compiling shader: %o", cmd
                result: system[ cmd.chars ]
                if [ result != 0 ]
                    print "shader compilation failed for: %o", nm
                    exit[ 1 ]
                recompiled = true
            el
                if [ *(values[i]) ]
                    continue
            fp: fopen[ spv_file.chars, "rb" ]
            if [ !fp ]
                print "failed to open SPIR-V file: %o", spv_file
                exit[ 1 ]
            fseek[ fp, 0, SEEK_END ]
            length: ftell[ fp ]
            rewind[ fp ]
            spirv: malloc[ length ]
            if [ !spirv ]
                fclose[ fp ]
                print "Failed to allocate memory for SPIR-V"
                exit[ 1 ]
            fread[ spirv, 1, length, fp ]
            fclose[ fp ]
            createInfo: VkShaderModuleCreateInfo [
                sType:    VK_STRUCTURE_TYPE_SHADER_MODULE_CREATE_INFO,
                codeSize: length,
                pCode:    spirv
            ]
            mod: VkShaderModule
            vkResult: vkCreateShaderModule[ t.device, createInfo, null, ref mod ]
            if [ vkResult != VK_SUCCESS ]
                print "Failed to create Vulkan shader module"
                free[ spirv ]
                exit[ 1 ]
            *(values[i]) = mod
            free[ spirv ]
        if [ recompiled && r ]
            reloads += 1
            *r = reloads
        expect found, "shader not found: %o", name
        return recompiled

    func init [ ]
        if [ !t ]
            return
        frag = 'shaders/{name}.frag'
        vert = 'shaders/{name}.vert'
        comp = 'shaders/{name}.comp'
        if [ !name ]
            ty: Au_t [ isa[ self ] ]
            expect ty != typeid[ shader ], "base shader usage requires a shader name"
            name = string[ ty.name ]
        reload[ null ]

    func dealloc [ ]
        vkDestroyShaderModule[ t.device, vk_vert, null ]
        vkDestroyShaderModule[ t.device, vk_frag, null ]
        vkDestroyShaderModule[ t.device, vk_comp, null ]

