# enums export to A-type
enum Ease
    linear  : 0
    quad    : 1
    cubic   : 2
    quart   : 3
    quint   : 4
    sine    : 5
    expo    : 6
    circ    : 7
    back    : 8
    elastic : 9
    bounce  : 10

enum Direction
    inward  : 0
    outward : 1
    in_out  : 2

enum Duration
    ms : 2
    ns : 1
    s  : 3

enum XAlign : f32
    undefined : 0
    left      : 0.0
    middle    : 0.5
    right     : 1.0
    width     : 2.0

enum YAlign : f32
    undefined : 0
    top       : 0.0
    middle    : 0.5
    bottom    : 1.0
    height    : 2.0

enum UXSurface
    background  : 0
    frost       : 1
    blur        : 2
    compose     : 3
    colorize    : 4
    overlay     : 5
    glyph       : 6

enum Fill : f32
    none      : 0.00f
    blur      : 0.50f
    frost     : 1.00

enum CanvasType
    overlay     : 0
    compose     : 1
    colorize    : 2
    glyph       : 3

enum Pattern
    none : 0
    repeat_x : 1
    repeat_y : 2
    repeat_xy : 3

enum Clip
    none : 0
    clip : 1
    ellipsis : 2


alias Elements : map    element [ string ]
alias Render   : lambda Elements[ Display ]

class element
    mutable parent      : element
    mutable area        : Region
    mutable bounds      : rect
    mutable value       : object
    mutable id          : string
    mutable flags       : i64
    public ltest : Layer
    public layers       : array Layer
    mutable elements    : Elements
    mutable tags        : array string
    mutable group       : string
    mutable tab_index    : i32
    mutable scroll       : vec2f
    mutable ghost        : bool
    mutable captured     : bool
    mutable selectable   : bool
    mutable selected     : bool
    mutable disabled     : bool
    mutable hovered      : bool
    mutable pressed      : bool
    mutable focused      : bool
    public action       : EventDispatch
    public wheel        : EventDispatch
    public context      : EventDispatch
    public text         : EventDispatch
    public hover        : EventDispatch
    public leave        : EventDispatch
    public key_down     : EventDispatch
    public key_up       : EventDispatch
    public press        : EventDispatch
    public move         : EventDispatch
    public release      : EventDispatch
    public got_capture  : EventDispatch
    public lost_capture : EventDispatch
    public focus        : EventDispatch
    public blur         : EventDispatch
    public cursor       : vec2f
    intern ux           : UXComposer
    intern style_avail  : map StyleEntries[string]
    #intern selections   : map
    intern transitions  : map StyleTransition[string]
    intern restyle : bool

    public func set_capture []
        ux.set_capture[ a ]

    public func release_capture []
        ux.release_capture[ a ]

    public func set_focus []
        ux.set_focus[ a ]

    public func release_focus []
        ux.release_focus[ a ]

    public func draw [ w: Window ]

    public func render [ changed: array string ] -> Render
        return null

    func invalidate_element [ ]
        e : a
        if [ e && e.transitions ]
            for [ ct: StyleTransition, k: string ] in e.transitions
                ct.invalidate = true

    func remove_invalid_transitions [ ]
        e: a
        found : true
        while [ found ]
            found = false
            for [ ct:StyleTransition, k:object ] in e.transitions
                if [ ct.invalidate ]
                    e.transitions.rm[ k ]
                    found = true
                    return

    intern func animate_within [ ]
        if [ transitions ]
            cur_millis : i64 [ epoch_millis[] ]
            for [ ct: StyleTransition, k: string ] in transitions
                dur : i64 [ ct.duration.get_millis[] ]
                ms  : i64 [ cur_millis - ct.start ]
                p   : f64 [ ct.pos[ f64[ ms ] / f64[ dur ] ] ]
                if [ ct.type && ct.from && ct.to ]
                    mixed : mix[ ct.from, ct.to, p ]
                    if [ ct.location ]
                        ct.location = mixed
        for [ ee: element, id: string ] in elements
            ee.animate_within[ ]


alias StyleTransitions : map StyleTransition[string]

Composer UXComposer
    public app                  : object
    public w                    : Window
    intern root_styles          : map Style[string]
    public root                 : element
    mutable capture             : element
    mutable focus               : element
    mutable hovered             : element
    mutable action_pressed      : element
    mutable context_pressed     : element
    mutable restyle             : bool
    mutable mouse               : vec2f
    mutable shift               : bool
    mutable alt                 : bool
    public st                   : Style
    public buttons              : array i32[16x1]
    public on_render            : hook

    # Au runtime introspection — member iteration for args/style application
    public func apply_args [ inst: element, e: element ] -> array string
        ty      : typeid[ e ]
        changed : array string [ ]
        while [ ty != typeid[ Au ] ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                mem : Au_t ty.members.origin[m]
                if [ mem.member_type != AU_MEMBER_VAR || mem.ident == 'elements' ]
                    continue
                from_val : inst.member_object[ mem ]
                to_val   :    e.member_object[ mem ]
                if [ to_val && from_val != to_val ]
                    if [ from_val.compare[ to_val ] != 0 ]
                        inst.member_set[ mem, to_val ]
                        changed.push[ string[ mem.ident ] ]
            ty = ty.context
        return changed

    public func apply_style [ inst: element, style_avail: map StyleEntries[string], exceptions: array string ] -> array string
        ty      : Au_t [ typeid[ inst ] ]
        changed : array string [ ]
        while [ ty != typeid[ Au ] ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                member : Au_t ty.members.origin[m]
                if [ member.member_type != AU_MEMBER_VAR || member.ident == 'elements' ]
                    continue
                prop    : string [ member.ident ]
                entries : style_avail [ prop ]
                if [ !entries ]
                    continue
                if [ exceptions && exceptions.index_of[ prop ] >= 0 ]
                    continue
                best : st.best_match[ inst, prop, entries ]
                if [ !best ]
                    continue
                # lazily create instance from string value
                if [ !best.instance ]
                    best.instance = (best.value to typeid[ member.src ]) # convert from string this way
                expect best.instance, 'instance must be initialized'
                changed.push[ prop ]
                cur : inst.member_object[ member ]
                # transition handling
                t  : StyleTransition [ best.trans ]
                ct : StyleTransition
                should_trans : false
                if [ t ]
                    if [ !inst.transitions ]
                        inst.transitions = StyleTransitions [ ]
                    ct = inst.transitions[ prop ]
                    if [ !ct ]
                        ct = t.copy[]
                        ct.reference = t
                        should_trans = true
                        inst.transitions[ prop ] = ct
                    el
                        should_trans = ct.reference != t
                el [ inst.transitions ]
                    inst.transitions.rm[ prop ]
                if [ ct && should_trans ]
                    ct.from     = (cur) ? cur : best.instance
                    ct.to       = best.instance
                    ct.type     = typeid[ best.instance ]
                    ct.start    = epoch_millis[]
                el [ !ct ]
                    inst.member_set[ member, best.instance ]
            ty = ty.context
        return changed

    public func animate []
        if [ !root ]
            return
        invalidate[]
        root.animate_within[ ]
        remove_invalid[]

    public func bind_subs [ instance: element, parent: element ]

    func update [ parent: element, rendered: map element[string] ]
        target : Au [ app ]

        # mark for umount
        for [ e:element, id:string ] in parent.elements
            e.flags |= 1

        # iterate through rendered elements
        for [ e:element, id:string ] in rendered
            ee : element parent.elements[ id ]
            instance : element (parent.elements) ? parent.elements[ id ] : null
            restyle  = restyle || e.restyle

            if [ instance ]
                instance.flags &= ~1
                if [ !instance.id ]
                    instance.id     = id
                    instance.ux     = a
                    instance.parent = parent
                    instance.init[]
                    instance.hold_members[]
                    #bind_subs[ instance, parent ]
                    restyle = true

            changed  : array string [ null ]
            new_inst : bool [ false ]
            if [ !instance ]
                new_inst         = true
                restyle          = true
                instance         = e.hold[]
                instance.id      = id
                instance.ux      = a
                instance.parent  = parent
                instance.init[]
                instance.hold_members[]
                #bind_subs[ instance, parent ] -- implement proper callback
                if [ !parent.elements ]
                    parent.elements = map element[string] [ ]
                parent.elements[ id ] = instance
            el [ !restyle ]
                changed = apply_args[ instance, e ]
                restyle = changed.index_of[ 'tags' ] >= 0

            if [ restyle ]
                e.restyle = false
                avail     : st.compute[ instance ]
                styled    : apply_style[ instance, avail, changed ]
                if [ styled && changed ]
                    for [ prop: string ] in styled
                        if [ changed.index_of[ prop ] == -1 ]
                            changed.push[ prop ]

            irender : instance.render[ changed ]
            if [ !irender ] irender = instance.elements
            if [  irender ] update[ instance, irender ]

        # perform umount on elements not updated in render
        retry : true
        while [ retry ]
            retry = false
            for [ e:element, id:string ] in parent.elements
                if [ e.flags & 1 ]
                    e.flags  = 0
                    retry    = true
                    e.parent = null
                    e.drop_members[]
                    parent.elements.rm[ id ]
                    break

    public func update_all [ render: map element[string] ]
        restyle = false
        if [ !root ]
            root    = element [ id: string[ 'root' ] ]
            root_styles = st.compute[ root ]
            restyle = true
        if [ !restyle ]
            restyle = st.check_reload[]
        if [ restyle ]
            apply_style[ root, root_styles, null ]
        update[ root, render ]

    public func invalidate []
        if [ root ] root.invalidate_element[ ]

    public func remove_invalid []
        if [ root ] root.remove_invalid_transitions[ ]

    public func set_capture [ e: element ]
        if [ capture != e ]
            if [ capture ]
                capture.captured = false
                capture.restyle  = true
                ux_event[ capture, capture.lost_capture, null ]
            if [ e && !e.ghost ]
                capture = e
                capture.captured = true
                capture.restyle  = true
                ux_event[ capture, e.got_capture, null ]

    public func release_capture [ e: element ]
        if [ capture && capture == e ]
            ux_event[ capture, capture.lost_capture, null ]
            capture = null

    public func set_focus [ e: element ]
        if [ focus != e ]
            if [ focus ]
                focus.focused = false
                focus.restyle = true
                ux_event[ focus, focus.blur, null ]
            if [ e && !e.ghost ]
                focus = e
                focus.focused = true
                focus.restyle = true
                ux_event[ focus, e.focus, null ]

    public func release_focus [ e: element ]
        if [ focus && focus == e ]
            focus.focused = false
            focus.restyle = true
            ux_event[ focus, focus.blur, null ]
            focus = null

    public func find_target [ e: element, ev: Event, must: element ] -> element
        if [ !e || e.disabled || e.ghost ]
            return null
        b : rect  [ e.bounds ]
        x : f32   [ ev.mouse.pos.x ]
        y : f32   [ ev.mouse.pos.y ]
        lx : f32  [ x - b.x ]
        ly : f32  [ y - b.y ]
        if [ !must && (lx < 0.0 || ly < 0.0 || lx >= b.w || ly >= b.h) ]
            return null
        ev.mouse.pos.x = lx + e.scroll.x
        ev.mouse.pos.y = ly + e.scroll.y
        for [ child: element, id: string ] in e.elements
            hit   : element [ find_target[ child, ev, must ] ]
            if [ hit ]
                return hit
        ev.mouse.pos.x = x
        ev.mouse.pos.y = y
        return (!must || must == e) ? e : null

    public func text_event [ ev: Event ]
        if [ focus ]
            ux_event[ focus, focus.text, ev ]

    public func key_event [ ev: Event ]
        if [ focus ]
            ux_event[ focus, focus.key_down, ev ]

    public func move_event [ ev: Event ]
        f : element [ find_target[ root, ev, null ] ]
        a : element [ (capture) ? find_target[ root, ev, capture ] : f ]
        if [ hovered != f ]
            if [ hovered ]
                hovered.restyle = true
                hovered.hovered = false
                ux_event[ hovered, hovered.leave, ev ]
            hovered = f
            if [ f ]
                hovered.restyle = true
                hovered.hovered = true
                ux_event[ f, f.hover, ev ]
        if [ a ]
            ux_event[ a, a.move, ev ]

    public func wheel_event [ ev: Event ]
        for [ f: element find_target[ root, ev, capture ], f, f = f.parent ]
            ux_event[ f, f.wheel, ev ]
            if [ ev.no_propagation ]
                return

    public func press_event [ ev: Event ]
        release_capture[ capture ]
        f : element [ find_target[ root, ev, null ] ]
        if [ f ]
            ux_event[ f, f.press, ev ]
        if [ !capture ]
            set_capture[ f ]
        if [ ev.mouse.button == 0 ]
            if [ action_pressed ]
                action_pressed.restyle = true
                action_pressed.pressed = false
            if [ f ]
                f.restyle = true
                f.pressed = true
            action_pressed = f
        el [ ev.mouse.button == 1 ]
            context_pressed = f

    public func release_event [ ev: Event ]
        f : element [ find_target[ root, ev, capture ] ]
        if [ f ]
            ux_event[ f, f.release, ev ]
        if [ ev.mouse.button == 0 ]
            if [ action_pressed ]
                action_pressed.restyle = true
                action_pressed.pressed = false
            if [ f ]
                f.restyle = true
                f.pressed = false
            if [ f && action_pressed == f && f.hovered ]
                ux_event[ f, f.action, ev ]
            action_pressed  = null
            context_pressed = null
        el [ ev.mouse.button == 1 ]
            if [ f && action_pressed == f && f.hovered ]
                ux_event[ f, f.context, ev ]
            action_pressed  = null
            context_pressed = null
        if [ !action_pressed && !context_pressed ]
            release_capture[ capture ]



Display Window
    
    ux : UXComposer[w:a]

    public app_object           : app

    public compose              : Canvas
    public colorize             : Canvas
    public overlay              : Canvas
    public glyph                : Canvas

    # this needs to be in trinity in form of a declarative stack for our rendering pipeline
    # if we can do such a thing for elements, we should be able to express it
    public m_reduce             : Model
    public r_reduce             : Target
    public m_reduce0            : Model
    public r_reduce0            : Target
    public m_reduce1            : Model
    public r_reduce1            : Target
    public m_reduce2            : Model
    public r_reduce2            : Target
    public m_reduce3            : Model
    public r_reduce3            : Target
    public m_blur_v             : Model
    public r_blur_v             : Target
    public m_blur               : Model
    public r_blur               : Target
    public m_frost_v            : Model
    public r_frost_v            : Target
    public m_frost              : Model
    public r_frost              : Target
    public m_view               : Model
    public r_view               : Target

    func update_canvas [ ]
        # compose  || (omitting this to show actual issue with parse member not being part of read-enode)
        compose  = (Canvas [ w:a, vk: vk, format: Pixel.rgba8, :width, :height ]).resize[ width, height ]
        colorize = (colorize || Canvas [ w:a, vk: vk, format: Pixel.rgba8, :width, :height ]).resize[ width, height ]
        overlay  = (overlay  || Canvas [ w:a, vk: vk, format: Pixel.rgba8, :width, :height ]).resize[ width, height ]
        glyph    = (glyph    || Canvas [ w:a, vk: vk, format: Pixel.rgba8, :width, :height ]).resize[ width, height ]
        compose .clear[ string[ "#008"  ] ]
        colorize.clear[ string[ "#fff"  ] ]
        overlay .clear[ string[ "#fff0" ] ]
        glyph   .clear[ string[ "#000"  ] ]
        #sk_sync[] -- hopefully no need to have a global flush

    public func resize [ w: i32, h: i32 ] -> Window
        super.resize[ w, h ]
        update_canvas[]
        return a

    public func draw_element [ e: element* ]
        expect e inherits element, 'e is not an element'
        canvas_arr : new Canvas[4] [ overlay, compose, colorize, glyph ]
        rel : rect [ (e.parent) ?
            rect [ x: 0, y: 0, w: e.parent.bounds.w, h: e.parent.bounds.h ] :
            rect [ x: 0, y: 0, w: width, h: height ] ]

        # compute element bounds from its area
        e.bounds = e.area.rectangle[ rel, null ]

        # compute layer bounds and draw each layer
        for [ layer: Layer ] in e.layers
            layer.bounds = (layer.area) ? layer.area.rectangle[ e.bounds, null ] : e.bounds
            cv : Canvas [ canvas_arr[layer.ctype] ]

            fill : layer inherits FillLayer
            if [ fill && layer.color ]
                cv.save[]
                b : layer.bounds
                rx:f32 layer.radius[0]
                ry:f32 layer.radius[1]
                cv.rounded_rect_to[ b.x, b.y, b.w, b.h, rx, ry ]
                cv.set_fill_color[ sk_color[ layer.color ] ]
                cv.draw_fill[]
                cv.restore[]

            border : layer inherits Border
            if [ border && border.color && border.size > 0.0 ]
                cv.save[]
                cv.set_stroke_size[ border.size ]
                cv.set_stroke_cap[ border.cap ]
                cv.set_stroke_join[ border.join ]
                b : rect [ layer.bounds ]
                rx:f32 layer.radius[0]
                ry:f32 layer.radius[1]
                cv.rounded_rect_to[ b.x, b.y, b.w, b.h, rx, ry ]
                cv.set_stroke_color[ sk_color[ border.color ] ]
                cv.draw_stroke[]
                cv.restore[]

            txt : layer inherits Text
            if [ txt && txt.label ]
                cv.save[]
                b : rect [ layer.bounds ]
                x0 : f32 txt.xalign
                y0 : f32 txt.yalign
                al : vec2f [ x0, y0 ]
                offset : vec2f [ x: 0.0, y: 0.0 ]
                cv.set_fill_color[ sk_color[ layer.color ] ]
                cv.draw_text[ txt.label, b, al, offset, false ]
                cv.restore[]

        e.draw[ a ]
        for [ ee: element, id: string ] in e.elements
            draw_element[ ee ]


media_app trinity
    expect vk           : vk_context
    intern msaa_samples : i64
    public on_render    : Render

    w : Window 
    # this is an elaboration; auto-view-cast without actually adding a new member
    # it may even do an additional run-time instance check; it will have the same visibility

    func render[]
        elements : on_render[ w ] # type from on_render
        #render : map element[ string ]
        if [ elements ]
            #w.ux.update_all[ render ]
            w.ux.update_all[ elements ]

        w.ux.animate[]
        if [ w.compose && w.colorize && w.glyph ]
            w.compose .clear [ '#000' ]
            w.colorize.clear [ '#000' ]
            w.glyph   .clear [ '#000' ]
        w.overlay.clear[ '#0000' ]
        w.draw_element[ w.ux.root ]
        w.draw[]


class LineInfo
    intern data            :  string
    intern len             :  num
    intern adv             :  array f64[]
    intern bounds          :  rect
    intern placement       :  rect

class TextSel
    public column : num
    public row    : num

class text
    public lines   : array LineInfo
    public replace : text

class StyleEntry
    mutable member   : string
    mutable value    : string
    mutable trans    : StyleTransition
    mutable bl       : StyleBlock
    mutable instance : object

alias StyleEntries : array StyleEntry


class StyleBlock
    mutable parent  : StyleBlock
    public quals    : array StyleQualifier
    public entries  : StyleEntries
    public blocks   : array StyleBlock
    public types    : array Au_t

    construct [ p_sc: ref cstr ]
        sc : cstr [ p_sc[0] ]
        ws[ ref sc ]
        expect sc[0] == '.' || is_alpha2[sc[0]], 'expected Type[.id], or .id'
        quals = parse_qualifiers[ a, ref sc ]
        sc += 1
        ws[ ref sc ]
        while [ sc[0] && sc[0] != '}' ]
            ws[ ref sc ]
            start : cstr [ sc ]
            expect scan_to[ ref sc, ';{{}}' ], 'expected member expression or qualifier'
            if [ sc[0] == '{' ]
                bl_n : StyleBlock [ ref sc ]
                blocks.push[ bl_n ]
                bl_n.parent = a
                sc = start
                expect sc[0] == '}', 'expected }}'
                sc += 1
                ws[ ref sc ]
            el [ sc[0] == ';' ]
                cur : cstr [ start ]
                expect scan_to[ ref cur, ':' ] && cur < sc, 'expected [member:]value;'
                member : string [ chars: start, ref_length: distance[ start, cur ] ]
                for [ i: i32 0, i < member.count, i += 1 ]
                    if [ member.chars[i] == '-' ]
                        member.chars[i] = '_'
                cur += 1
                ws[ ref cur ]
                vstart : cstr [ cur ]
                expect scan_to[ ref cur, ';' ], 'expected member:value[, transition];'
                vlen     : distance[ vstart, cur ]
                cb_value : string[ chars: vstart, ref_length: vlen ]
                cb_value = cb_value.trim[]
                qs       : cb_value.mid[  0, 1 ] == '"'
                qe       : cb_value.mid[ -1, 1 ] == '"'
                if [ qs && qe ]
                    cs : cstr [ cb_value.chars ]
                    cb_value = parse_quoted[ ref cs, cb_value.count ]
                param : string [ null ]
                value : object [ null ]
                ai    : num    [ cb_value.index_of[ '[' ] ]
                ci    : num    [ cb_value.index_of[ ',' ] ]
                if [ ai != -1 && (ci == -1 || ai < ci) ]
                    ae    : num[ cb_value.index_of[ ']' ] ]
                    expect ae != -1, 'expected ] character'
                    items : cb_value.mid[ ai + 1, ae - 1 ].trim[]
                    ln    : cb_value.count - ae
                    param = cb_value.mid[ ae + 1, ln ].trim[]
                    if [ param.first[] == ',' ]
                        param = param.mid[ 1, param.count - 1 ].trim[]
                    el
                        param = null
                    sp : items.split[ ',' ]
                    value = array Au [ sp.count ]
                    v : array Au[ value ]
                    for [ raw: string ] in sp
                        v.push[ raw.trim[] ]
                el
                    param = (ci >= 0) ? cb_value.mid[ ci + 1, cb_value.count - (ci + 1) ].trim[] : null
                    value = (ci >= 0) ? cb_value.mid[ 0, ci ].trim[] : cb_value
                trans : StyleTransition [ (param) ? StyleTransition[ param ] : null ]
                expect member, 'member cannot be blank'
                expect value,  'value cannot be blank'
                entries[ member ] = StyleEntry [ member: member, value: value, trans: trans, bl: a ]
                sc += 1
                ws[ ref sc ]
        expect !sc[0] || sc[0] == '}', 'expected closed-brace'
        if [ sc[0] == '}' ]
            sc += 1
        p_sc[0] = sc


    public func score [ n: element, score_state: bool ] -> f32
        best_sc : f32 [ 0.0 ]
        cur     : element [ n ]
        for [ q: StyleQualifier ] in quals
            best_this : f32 [ 0.0 ]
            while [ true ]
                id_match    : bool [ q.id && q.id == cur.id ]
                id_reject   : bool [ q.id && !id_match ]
                type_match  : bool [ q.ty && (typeid[ cur ] inherits typeid[ q.ty ]) ]
                type_reject : bool [ q.ty && !type_match ]
                state_match : bool [ score_state && q.state ]
                if [ state_match ]
                    expect q.state.count > 0, 'null state'
                    addr : cur.get_property[ q.state ]
                    if [ addr ]
                        state_match = bool[ addr ]
                state_reject : bool [ score_state && q.state && !state_match ]
                if [ !id_reject && !type_reject && !state_reject ]
                    sc : f64 [ i64[ id_match ] << 1 | i64[ type_match ] | i64[ state_match ] << 2 ]
                    best_this = max[ sc, best_this ]
                el
                    best_this = 0.0
                if [ q.parent && best_this > 0.0 ]
                    q   = q.parent
                    cur = (cur.parent) ? cur.parent : element[]
                el
                    return 0.0
            best_sc = max[ best_sc, best_this ]
        return (best_sc > 0.0) ? 1.0 : 0.0

    func init []
        if [ !entries ]
            entries = StyleEntries [ ]
        if [ !blocks ]
            blocks = array StyleBlock [ ]


class Style
    public  css_path  : path
    public  members   : map StyleEntries[string]
    public  reloader  : watch
    public  base      : array StyleBlock
    intern  mtx       : mutex
    intern  mod_time  : i64
    intern  reloaded  : bool
    intern  loaded    : bool

    func cache_block [ bl: StyleBlock ]
        for [ e: StyleEntry ] in bl.entries
            cache : members [ e.member ]
            if [ !cache ]
                cache = StyleEntries[]
                members.set[ e.member, cache ]
            found : false
            for [ cb: StyleBlock ] in cache
                found |= cb == bl
            if [ !found ]
                cache.push[ bl ]
        for [ s: StyleBlock ] in bl.blocks
            cache_block [ s ]

    func applicable [ n: element, prop_name: string, result: StyleEntries ] -> bool
        blocks : members[ prop_name ]
        ty     : typeid[ n ]
        ret    : false
        result.clear[]
        for [ block: StyleBlock ] in blocks
            if [ !block.types.count || block.types.index_of[ ty ] >= 0 ]
                f : block.entries[ prop_name ]
                if [ f && block.score[ n, false ] > 0 ]
                    result.push[ f ]
                    ret = true
        return ret

    func process [ code: string ]
        base = array StyleBlock [ ]
        sc : symbol [ code.chars ]
        while [ sc && sc[0] ]
            base.push [ StyleBlock [ ref sc ] ]

    func cache_members [ ]
        for [ b: StyleBlock ] in base
            cache_block[ b ]

    func best_match [ n: element, prop_name: string, entries: array StyleEntry ] -> StyleEntry
        match      : StyleEntry [ null ]
        best_score : f32 [ 0.0 ]
        for [ e: StyleEntry ] in entries
            bl : StyleBlock [ e.bl ]
            sc : f32 [ bl.score[ n, true ] ]
            if [ sc > 0.0 && sc >= best_score ]
                match      = bl.entries[ prop_name ]
                expect match, 'should have matched'
                best_score = sc
        return match

    func compute [ n: element ] -> map StyleEntries[string]
        avail : map StyleEntries[string]
        ty    : Au_t [ typeid[ n ] ]
        expect n inherits element, 'must inherit element'
        while [ ty != typeid[ Au ] ]
            all : array StyleEntry [ ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                mem : Au_t [ ty.members.origin[m] ]
                if [ mem.member_type != AU_MEMBER_VAR || mem.access_type == 1 ] # 1 == intern!
                    continue
                name : string [ mem.ident ]
                if [ applicable[ n, name, all ] ]
                    avail[ name ] = all
                    all = array  StyleEntry[ ]
            ty = ty.context
        return avail

    func check_reload [ ] -> bool
        expect css_path, 'style not loaded with path'
        m : css_path.modified_time[ ]
        if [ mod_time != m ]
            mod_time = m
            process[ css_path.load[ typeid[ string ], null ] ]
            cache_members[]
            loaded   = true
            reloaded = true
            return true
        return false

    construct [ p: path ]
        expect p.exists, 'css path does not exist'
        style_str : string [ p.load[ typeid[ string ], null ] ]
        base      = array StyleBlock [ ]
        css_path  = p
        mod_time  = p.modified_time[ ]
        members   = map StyleEntries[string] []
        process[ style_str ]
        cache_members[]
        loaded   = true
        reloaded = true

    construct [ app_instance: object ]
        app_type  : typeid app_instance
        root_type : string app_type.ident
        p         : path   'style/{root_type}.css'
        construct [ p ]


struct XCoord
    x_type   : XAlign
    offset   : f32
    relative : bool
    percent  : bool

    construct [ sx: string ]
        f         : string [ sx.first[] ]
        x_type    = XAlign[f]
        sx_offset : sx.mid[ 1, sx.count - 1 ]
        if [ sx_offset.last[] == '%' ]
            sx_offset = sx_offset.mid[ 0, sx_offset.count - 1 ]
            percent   = true
        if [ sx_offset ]
            if [ sx_offset.last[] == '+' ]
                sx_offset = sx_offset.mid[ 0, sx_offset.count - 1 ]
                relative  = true
        offset = sx_offset.real_value[]

    func plot [ from: f32, vto: f32, left: ref XCoord, left_val: f32, rel: rect ] -> f32
        val : f32 [ mix[ offset, offset * (vto - from), percent ] ]
        if [ x_type > XAlign.right ]
            expect (left.x_type <= XAlign.right), 'invalid left-operand (xcoord)'
            return left_val + val
        r : f32 [ (rel && relative) ? rel.w * relative : 0.0 ]
        hsz : f32 [ (vto - from) / 2.0 ]
        if [ x_type < XAlign.middle ]
            M : f32 [ f32[x_type] * 2.0 ]
            return from + hsz * M + val + r
        R : f32 [ (f32[x_type] - f32[XAlign.middle]) * 2.0 ]
        return from + ((hsz + val) * (1.0 - R)) + ((hsz * 2.0 - val) * R) + r

    func mix [ other: XCoord, f: f32 ] -> XCoord
        return XCoord [
            x_type:  (mix[ (x_type to f32),   (other.x_type   to f32), f ]) to XAlign,
            offset:   mix[  offset,            other.offset,           f ],
            percent: (mix[ (percent to f32),  (other.percent  to f32), f ]) to bool,
            relative:(mix[ (relative to f32), (other.relative to f32), f ]) to bool
        ]


struct YCoord
    y_type   : YAlign
    offset   : f32
    relative : bool
    percent  : bool

    construct [ sy: string ]
        f         : string [ sy.first[] ]
        y_type    = YAlign[ f ]
        sy_offset : sy.mid[ 1, sy.count - 1 ]
        if [ sy_offset.last[] == '%' ]
            sy_offset = sy_offset.mid[ 0, sy_offset.count - 1 ]
            percent   = true
        if [ sy_offset ]
            if [ sy_offset.last[] == '+' ]
                sy_offset = sy_offset.mid[ 0, sy_offset.count - 1 ]
                relative  = true
        offset = sy_offset.real_value[]

    func plot [ from: f32, vto: f32, top: ref YCoord, top_val: f32, rel: rect ] -> f32
        val : f32 [ mix[ offset, offset * (vto - from), percent ] ]
        if [ y_type > YAlign.bottom ]
            expect top.y_type <= YAlign.bottom, 'invalid top-operand (ycoord)'
            return top_val + val
        r : f32 [ (rel && relative) ? rel.h * relative : 0.0 ]
        hsz : f32 [ (vto - from) / 2.0 ]
        if [ y_type < YAlign.middle ]
            M : f32 [ (y_type to f32) * 2.0 ]
            return from + hsz * M + val + r
        R : f32 [ ((y_type to f32) - (YAlign.middle to f32)) * 2.0 ]
        return from + ((hsz + val) * (1.0 - R)) + ((hsz * 2.0 - val) * R) + r

    func mix [ other: YCoord, f: f32 ] -> YCoord
        return YCoord [
            y_type:  (mix[ (y_type   to f32),  (other.y_type   to f32), f ]) to YAlign,
            offset:   mix[ offset,              other.offset,           f ],
            percent: (mix[ (percent  to f32),  (other.percent  to f32), f ]) to bool,
            relative:(mix[ (relative to f32),  (other.relative to f32), f ]) to bool
        ]


class Region
    public l   : XCoord
    public t   : YCoord
    public r   : XCoord
    public b   : YCoord
    public set : bool

    construct [ f: f32 ]
        l   = XCoord [ x_type: XAlign.left,   offset: f ]
        t   = YCoord [ y_type: YAlign.top,    offset: f ]
        r   = XCoord [ x_type: XAlign.right,  offset: f ]
        b   = YCoord [ y_type: YAlign.bottom, offset: f ]
        set = true

    construct [ rc: rect ]
        l   = XCoord [ x_type: XAlign.left,   offset: rc.x ]
        t   = YCoord [ y_type: YAlign.top,    offset: rc.y ]
        r   = XCoord [ x_type: XAlign.width,  offset: rc.w ]
        b   = YCoord [ y_type: YAlign.height, offset: rc.h ]
        set = true

    construct [ s: string ]
        aa : array string [ s.split[ ' ' ] ]
        if [ a.count == 4 ]
            l = XCoord [ aa[0] ]
            t = YCoord [ aa[1] ]
            r = XCoord [ aa[2] ]
            b = YCoord [ aa[3] ]
        el [ a.count == 1 ]
            l = XCoord [ aa[0] ]
            t = YCoord [ aa[0] ]
            r = XCoord [ aa[0] ]
            b = YCoord [ aa[0] ]
        set = true

    func rectangle_offset [ rel: rect ] -> rect
        area: a
        reg: Region
        if [ !area ]
            reg = Region [ 0.0 ]
            area = reg
        r: area.rectangle[ rel, null ]
        return r

    func rectangle [ win: rect, rel: rect ] -> rect
        lv : l.plot[ win.x, win.x + win.w, null,  0.0, rel ]
        rv : r.plot[ win.x, win.x + win.w, ref l, lv,  rel ]
        tv : t.plot[ win.y, win.y + win.h, null,  0.0, rel ]
        bv : b.plot[ win.y, win.y + win.h, ref t, tv,  rel ]
        return rect [ x: lv, y: tv, w: rv - lv, h: bv - tv ]

    func mix [ other: Region, f: f32 ] -> Region
        reg : Region [ set: true ]
        reg.l = l.mix[ other.l, f ]
        reg.t = t.mix[ other.t, f ]
        reg.r = r.mix[ other.r, f ]
        reg.b = b.mix[ other.b, f ]
        return reg

class Scaling
    public value : vec3f

    construct [ f: vec3f ]
        value = f

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        expect sp.count == 3, 'expected x y z'
        value.x = sp[0].real_value[]
        value.y = sp[1].real_value[]
        value.z = sp[2].real_value[]

    func mix [ b: Scaling, f: f64 ] -> Scaling
        s2 : Scaling value.mix[ b.value, f ]
        return s2


class Rotation
    public axis : vec3f
    public degs : f32

    construct [ f: vec4f ]
        axis.x = f.x
        axis.y = f.y
        axis.z = f.z
        degs   = f.w

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        expect sp.count == 4, 'expected x y z Ndeg'
        f : string[ sp[3] ]
        expect f.ends_with[ 'deg' ], 'expected Ndeg'
        axis.x = sp[0].real_value[]
        axis.y = sp[1].real_value[]
        axis.z = sp[2].real_value[]
        degs   = sp[3].real_value[]

    public func mix [ b: Rotation, f: f32 ] -> Rotation
        return Rotation [
            axis: axis.mix[ b.axis, f ],
            degs: mix[ degs, b.degs, f ]
        ]


class Translation
    public value : vec3f

    construct [ f: vec3f ]
        value = f

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        expect sp.count == 3, 'expected x y z'
        value.x = sp[0].real_value[]
        value.y = sp[1].real_value[]
        value.z = sp[2].real_value[]

    public func mix [ b: Translation, f: f32 ] -> Translation
        return Translation []













    


class TimeCoord
    millis : i64

    construct [ nanoseconds: ns ]
        millis = i64[ nanoseconds ] / 1000000

    construct [ milliseconds: ms ]
        millis = i64[ milliseconds ]

    construct [ secs: sec ]
        millis = i64[ secs ] * 1000

    func get_millis [] -> i64
        return millis
        


class StyleTransition
    public easing       : Ease
    public dir          : Direction
    public duration     : TimeCoord
    intern from         : object
    intern to           : object
    intern start        : i64
    intern invalidate   : bool
    intern reference    : StyleTransition
    intern is_inlay     : bool
    intern type         : Au_t
    intern location     : ref object

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        ln : i32 [ sp.count ]
        # syntax: 500ms [ease [out]]
        dur_string : string [ sp[0] ]
        duration   = TimeCoord [ dur_string ]
        easing     = (ln > 1) ? Ease[ sp[1] ]      : Ease.linear
        dir        = (ln > 2) ? Direction[ sp[2] ]  : Direction.inward

    func pos [ tf: f64 ] -> f64
        x : f64 [ clamp[ tf, 0.0, 1.0 ] ]
        switch [ easing ]
            case linear
                return x
            case quad
                switch [ dir ]
                    case inward
                        return x * x
                    case outward
                        return 1.0 - (1.0 - x) * (1.0 - x)
                    case in_out
                        return (x < 0.5) ? 2.0 * x * x : 1.0 - pow[ -2.0 * x + 2.0, 2.0 ] / 2.0
            case cubic
                switch [ dir ]
                    case inward
                        return x * x * x
                    case outward
                        return 1.0 - pow[ 1.0 - x, 3.0 ]
                    case in_out
                        return (x < 0.5) ? 4.0 * x * x * x : 1.0 - pow[ -2.0 * x + 2.0, 3.0 ] / 2.0
            case quart
                switch [ dir ]
                    case inward
                        return x * x * x * x
                    case outward
                        return 1.0 - pow[ 1.0 - x, 4.0 ]
                    case in_out
                        return (x < 0.5) ? 8.0 * x * x * x * x : 1.0 - pow[ -2.0 * x + 2.0, 4.0 ] / 2.0
            case quint
                switch [ dir ]
                    case inward
                        return x * x * x * x * x
                    case outward
                        return 1.0 - pow[ 1.0 - x, 5.0 ]
                    case in_out
                        return (x < 0.5) ? 16.0 * x * x * x * x * x : 1.0 - pow[ -2.0 * x + 2.0, 5.0 ] / 2.0
            case sine
                PI : f64 [ 3.14159265358979323846 ]
                switch [ dir ]
                    case inward
                        return 1.0 - cos[ x * PI / 2.0 ]
                    case outward
                        return sin[ x * PI / 2.0 ]
                    case in_out
                        return -(cos[ PI * x ] - 1.0) / 2.0
            case expo
                switch [ dir ]
                    case inward
                        return (x == 0.0) ? 0.0 : pow[ 2.0, 10.0 * x - 10.0 ]
                    case outward
                        return (x == 1.0) ? 1.0 : 1.0 - pow[ 2.0, -10.0 * x ]
                    case in_out
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : (x < 0.5) ? pow[ 2.0, 20.0 * x - 10.0 ] / 2.0 : (2.0 - pow[ 2.0, -20.0 * x + 10.0 ]) / 2.0
            case circ
                switch [ dir ]
                    case inward
                        return 1.0 - sqrt[ 1.0 - pow[ x, 2.0 ] ]
                    case outward
                        return sqrt[ 1.0 - pow[ x - 1.0, 2.0 ] ]
                    case in_out
                        return (x < 0.5) ? (1.0 - sqrt[ 1.0 - pow[ 2.0 * x, 2.0 ] ]) / 2.0 : (sqrt[ 1.0 - pow[ -2.0 * x + 2.0, 2.0 ] ] + 1.0) / 2.0
            case back
                c1 : f64 [ 1.70158 ]
                c2 : f64 [ c1 * 1.525 ]
                c3 : f64 [ c1 + 1.0 ]
                switch [ dir ]
                    case inward
                        return c3 * x * x * x - c1 * x * x
                    case outward
                        return 1.0 + c3 * pow[ x - 1.0, 3.0 ] + c1 * pow[ x - 1.0, 2.0 ]
                    case in_out
                        return (x < 0.5) ? (pow[ 2.0 * x, 2.0 ] * ((c2 + 1.0) * 2.0 * x - c2)) / 2.0 : (pow[ 2.0 * x - 2.0, 2.0 ] * ((c2 + 1.0) * (x * 2.0 - 2.0) + c2) + 2.0) / 2.0
            case elastic
                PI  : f64 [ 3.14159265358979323846 ]
                c4  : f64 [ 2.0 * PI / 3.0 ]
                c5e : f64 [ 2.0 * PI / 4.5 ]
                switch [ dir ]
                    case inward
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : -pow[ 2.0, 10.0 * x - 10.0 ] * sin[ (x * 10.0 - 10.75) * c4 ]
                    case outward
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : pow[ 2.0, -10.0 * x ] * sin[ (x * 10.0 - 0.75) * c4 ] + 1.0
                    case in_out
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : (x < 0.5) ? -(pow[ 2.0, 20.0 * x - 10.0 ] * sin[ (20.0 * x - 11.125) * c5e ]) / 2.0 : (pow[ 2.0, -20.0 * x + 10.0 ] * sin[ (20.0 * x - 11.125) * c5e ]) / 2.0 + 1.0
            case bounce
                switch [ dir ]
                    case inward
                        return 1.0 - bounce_out[ 1.0 - x ]
                    case outward
                        return bounce_out[ x ]
                    case in_out
                        return (x < 0.5) ? (1.0 - bounce_out[ 1.0 - 2.0 * x ]) / 2.0 : (1.0 + bounce_out[ 2.0 * x - 1.0 ]) / 2.0
            default
                return x
        return x

    cast -> bool
        return duration.get_millis[] > 0


