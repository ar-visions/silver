# kind of ridiuclous looking but it does work
func window_canvas [ a: Window, ct: CanvasType ] -> Canvas
    switch [ ct ]
    case overlay
        return overlay
    case compose
        return compose
    case colorize
        return colorize
    case glyph
        return glyph
    default
        return overlay

func app_render [ a: app ] 
    w:        a.w
    ux:       w.ux
    elements: a.ason_render
    if [ a.on_render ]
        elements = a.on_render[ a, a.w ]
    el [ !a.ason_render || modified_time[ a.ason_path ] > a.ason_modified ]
        a.ason_modified = modified_time[ a.ason_path ]
        if [ !a.app_context ]
            a.app_context = hold[ ctx [ hsize: 32 ] ]
        type: Au_t [ isa[ a ] ]
        ty: Au_t [ type ]
        while [ ty != typeid[ Au ] ]
            for [ m: num 0, m < ty.member_count, m += 1 ]
                mem: ref type_member_t [ ref ty.members[m] ]
                from: object [ A_member_object[ a, mem ] ]
                if [ !from ]
                    continue
                ctx_val: object [ get[ a.app_context, mem.sname ] ]
                if [ from && !ctx_val || compare[ from, ctx_val ] != 0 ]
                    set[ a.app_context, mem.sname, from ]
            ty = ty.parent_type
        ason_render: map [ read[ a.ason_path, typeid[ map ], a.app_context ] ]
        ty = type
        while [ ty != typeid[ Au ] ]
            for [ m: num 0, m < ty.member_count, m += 1 ]
                mem: ref type_member_t [ ref ty.members[m] ]
                if [ !(mem.member_type & A_MEMBER_PROP) ]
                    continue
                member: object [ A_member_object[ a, mem ] ]
                to:     object [ get[ a.app_context, mem.sname ] ]
                if [ (!member && to) || (!to && member) || (member && to && A_memcmp[ member, to ] != 0) ]
                    A_member_set[ a, mem, to ]
            ty = ty.parent_type
        a.ason_render = hold[ ason_render ]
        elements = a.ason_render
    if [ elements ]
        update_all[ w.ux, elements ]
    animate[ ux ]
    if [ w.compose && w.colorize && w.glyph ]
        clear[ w.compose,  string[ "#000" ] ]
        clear[ w.colorize, string[ "#000" ] ]
        clear[ w.glyph,    string[ "#000" ] ]
    clear[ w.overlay, string[ "#0000" ] ]
    draw_element[ w, ux.root ]
    sk_sync[]
    draw[ w ]

# --- globals ---


# ========================================================================
# SCRATCH — functions from trinity.c to convert to Silver
# ========================================================================


# ---- target (render pass / framebuffer) ----
# allocates command buffer, creates render pass with color+depth attachments,
# semaphores, fence, then calls update for framebuffer creation

# func target.init [] 
#     alloc command buffer from vk.command_pool
#     create render pass: color attachment (surface format) + depth (D32_SFLOAT)
#     subpass with color+depth refs
#     dependencies for layout transitions
#     create semaphores (if not backbuffer)
#     create fence (signaled)
#     if reduce: create reduce_model with reduce_shader
#     call update
#     finish all models on their render pass

# func target.update [] 
#     scale width/height from wscale if set
#     if color exists: resize color, depth, reduction textures
#     else: create color texture (surface format), depth (D32_SFLOAT), reduction
#     transition layouts (color attachment or shader read depending on backbuffer)
#     create framebuffers for each render pass

# func target.draw [] 
#     for each pass (main + reduce):
#       transition color/reduction to COLOR_ATTACHMENT_OPTIMAL
#       reset fence, reset command buffer, begin recording
#       set viewport + scissor
#       begin render pass with clear values
#       draw all models/pipelines (pass 0) or reduce model (pass 1)
#       end render pass, end command buffer
#       submit with semaphore wait/signal if swap Image

# func target.sync_fence [] 
#     vkWaitForFences on vk_fence

# func target.dealloc [] 
#     destroy framebuffers, render passes, fence, semaphores


# ---- window ----
# GLFW window creation, Vulkan surface, swapchain, present mode selection

# func window.init [] 
#     set defaults (format rgba8, width 1200, height 1200)
#     create Event object
#     if not backbuffer:
#       glfwCreateWindow, set callbacks (key, mouse, scroll, char, cursor, resize)
#       glfwCreateWindowSurface
#     call vk.attach[surface]
#     query surface capabilities, formats, present modes
#     choose B8G8R8A8_UNORM format, MAILBOX present mode
#     set extent from glfw window size

# func window.resize [width: i32, height: i32] 
#     vkDeviceWaitIdle
#     update all targets
#     rebind models if resized
#     query new surface capabilities
#     recreate swapchain with new dimensions
#     recreate swap images and swap renders
#     update canvas

# func window.draw [] 
#     if not backbuffer:
#       acquire next swap Image
#       draw swap render target
#       present to queue
#       advance swap Image index

# func window.dealloc [] 
#     destroy swapchain, surface, swap images

# func window.cast_image [] -> Image
#     create transfer buffer, copy color to it, return as Image

# func window.update_canvas [] 
#     resize or create compose/colorize/overlay/glyph skia surfaces
#     clear each with default colors


# ---- GLFW callbacks ----
# each gets window from glfwGetWindowUserPointer, fills Event, dispatches to ux

# func handle_glfw_framebuffer_size [win, width, height]
#     if minimized return; call resize

# func handle_glfw_key [win, key, scan_code, action, mods]
#     fill Event key fields, dispatch key_event to ux

# func handle_glfw_scroll [win, x, y]
#     fill mouse wheel_delta, dispatch wheel_event

# func handle_glfw_mouse [win, id, action, mods]
#     fill mouse button/state, dispatch press/release Event

# func handle_glfw_char [win, code_point]
#     create text string, dispatch text_event

# func handle_glfw_cursor [win, x, y]
#     update mouse pos, dispatch move_event


# ---- app ----

# func app.init [] 
#     create vk_context
#     create style, composer
#     bind on_render or load ason_path

# func app.initialize [win: window] 
#     set ux.w = win, w.ux = ux
#     update_canvas, app_render, resize

# func app.run [] 
#     main loop: glfwPollEvents, render, present
#     cleanup on exit

# func app.dealloc [] 
#     cleanup


# ---- pipeline ----
# Vulkan graphics pipeline: descriptor sets, pipeline layout, shaders, vertex input

# func pipeline.init [] 
#     create descriptor set layout from shader uniforms
#     create pipeline layout
#     create graphics pipeline (vert/frag stages, vertex input, rasterizer, multisampling, depth, blend)
#     allocate descriptor sets

# func pipeline.draw [frame: VkCommandBuffer] 
#     update uniforms
#     bind pipeline, descriptor sets, vertex/index buffers
#     draw indexed or draw vertices

# func pipeline.bind_resources [] 
#     for each descriptor: bind uniform buffers and texture samplers
#     write descriptor sets

# func pipeline.reassemble [] 
#     rebuild pipeline on shader reload

# func pipeline.dealloc [] 
#     destroy pipeline, pipeline layout, descriptor pool/sets


# ---- model ----
# groups pipelines with vertex data, manages gltf scene binding

# func model.finish [r: target, pass_id: i32] 
#     init_pipeline for each gltf primitive
#     sync gpu objects
#     bind resources on all pipelines

# func model.dealloc [] 
#     cleanup pipelines, gpu objects

# func model.rebind [] 
#     rebind all pipelines


# ---- gpu (mesh object) ----
# vertex/index buffer management for draw calls

# func gpu.init [] 
#     create VBO from vertex_data, IBO from index_data
#     create texture from sampler if provided

# func gpu.sync [w: window] 
#     upload vertex/index data to GPU buffers

# func gpu.dealloc [] 
#     destroy VBO, IBO, texture


# ---- uniforms ----

# func uniforms.init [] 
#     create uniform buffers for each shader binding
#     allocate descriptor pool and sets

# func uniforms.update [] 
#     map each uniform buffer, memcpy shader data, unmap


