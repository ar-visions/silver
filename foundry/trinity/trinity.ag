    public focused      : bool
    public action       : EventDispatch
    public wheel        : EventDispatch
    public context      : EventDispatch
    public text         : EventDispatch
    public hover        : EventDispatch
    public leave        : EventDispatch
    public key_down     : EventDispatch
    public key_up       : EventDispatch
