element World
    public target       : Target
    public models       : array Model
    public render_scale : f32 1.0
    public clear_color  : vec4f
    public rotate       : array Rotation
    public translate    : array Translation
    public scale        : array Scaling
    public update       : EventDispatch

    func init []
        expect ux, 'ux not set'

    func load [ w: Window ]
        if [ !target ]
            width  : int ((bounds) ? (bounds.w) : (w.width))  * render_scale
            height : int ((bounds) ? (bounds.h) : (w.height)) * render_scale
            target = Target [
                vk:             w.vk,
                w:              w,
                width:          width,
                height:         height,
                reduce:         (render_scale == 4.0) ? true : false,
                clear_color:    clear_color,
                models:         models]
            w.element_targets[id] = target
        
    func draw [ w: Window ]
        #expect update, 'update subs not set'
        load[ w ]

        width  : i32 [ bounds.w * render_scale ]
        height : i32 [ bounds.h * render_scale ]
        target.width  = width
        target.height = height
        target.wscale = 0.0

        target.update[]

        #expect update, '{id}_update sub not declared by the app'
        ev : Event[ target: a ]
        update.invoke[ ev ]

        at : translate
        ar : rotate
        as : scale

        if [ at || ar || as ]
            for [ m: Model ] in target.models
                ln0 : i32 [ (at) ? at.count : 0 ]
                ln1 : i32 [ (ar) ? ar.count : 0 ]
                ln2 : i32 [ (as) ? as.count : 0 ]
                ln  : i32 [ (ln0 > ln1 && ln0 > ln2) ? ln0 : (ln1 > ln0 && ln1 > ln2) ? ln1 : ln2 ]
                m.transforms      = new mat4f [ ln ]
                m.transform_count = ln
                for [ i: i32 0, i < ln, i += 1 ]
                    mat : mat4f.identity[]
                    s : Scaling [ (as) ? as.peek[ i ] : null ]
                    if [ s ]
                        mat = mat.scale[ s.value ]
                    r : Rotation [ (ar) ? ar.peek[ i ] : null ]
                    if [ r ]
                        v   : vec4f [ r.axis.x, r.axis.y, r.axis.z, radians[ r.degs ] ]
                        q   : quatf[ v ]
                        mat = mat.rotate[ q ]
                    t : Translation [ (at) ? at.peek[ i ] : null ]
                    if [ t ]
                        mat = mat.translate[ t.value ]
                    m.transforms[i] = mat

        if [ typeid[ a ] == typeid[ Background ] ]
            return

        w.overlay.set_texture[ (target.reduction) ? target.reduction : target.color ]
        w.overlay.draw_fill[]

    func dealloc []

World Stage
