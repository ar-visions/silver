class Background
    expect window: Window
    public color:  rgba
    public render: Render
    public models: array Model

    func init[]
        test2: i32 22
        test2 += 22
        
    func update[]
        return

abstract live_app media_app
    context w           : Display*
    context vk          : vk_context
    intern  arg         : object
    public  width       : i32
    public  height      : i32
    intern  next_second : i64
    intern  frames      : i32

    func run [ ]
        Au.auto_free[true]

    func frame [ ] -> bool
        # free-running loop: poll (don't block on events) so we render every iteration
        # at full speed — measures raw throughput instead of event-gated repaints.
        glfwPollEvents[]
        second : epoch_millis[] / 1000
        if [ next_second != second ]
            next_second = second
            puts 'PERF fps={frames} draw={vk.draw_us} passes={vk.pass_calls} submits={vk.submit_calls} waits={vk.sync_calls} syncus={vk.sync_us} paints={vk.paint_calls}'
            vk.resize_us    = 0
            vk.resize_calls = 0
            frames = 0
            vk.submit_calls = 0
            vk.pass_calls   = 0
            vk.sync_calls   = 0
            vk.sync_us      = 0
            vk.update_us    = 0
            vk.draw_us      = 0
            vk.paint_calls  = 0
            vk.sdf_hit      = 0
            vk.sdf_miss     = 0
            vk.geom_us      = 0
            vk.render_allocs = 0
            vk.bindres_calls = 0
            vk.bindres_us    = 0
            vk.br_schema_us  = 0
        render*[]
        Au.auto_free[false]
        return !glfwWindowShouldClose[ w.glfw ]

    func destroy [ ]
        # hot-reload: vk_context persists (held in libAu), but this module's code
        # is about to be dlclose'd. drop the cached fonts NOW, while their vtables
        # are still mapped — otherwise the next instance returns a stale CanvasFont
        # and calling its methods jumps into freed code (SIGSEGV). ensure_font
        # rebuilds the cache lazily on the new instance.
        if [ vk ]
            vk.font_cache = null
        if [ w ]
            w.drop[]

    func render [ ]
        return

    func init [ ]
        next_second = epoch_millis[] / 1000
        if [ !Au.live_window_get[] ]
            init_res : glfwInit[]
            expect init_res, "glfw init"
            if [ !glfwVulkanSupported[] ]
                fault "glfw does not support vulkan"
                glfwTerminate[]
                return
        existing_vk : handle Au.live_vk_get[]
        if [ existing_vk ]
            vk = (existing_vk to vk_context)
            # startup never reuses the font cache: destroy[] already dropped it at
            # the reload boundary (while the old code was still mapped), so it's
            # null here — ensure_font rebuilds fresh against THIS module's code.
            vk.font_cache = null
        el
            vk = vk_context[]
            Au.live_vk_set[ handle[vk] ]

    func dealloc [ ]
        destroy[]


class CursorPos
    public x : f32
    public y : f32
    public h : f32

# a draggable layout seam — a bound coord's edge. mem/app is the app field a drag
# writes (via member_ref); axis 0 = x (l/r → horizontal drag), 1 = y (t/b → vertical);
# sign +1 for left/top anchors, -1 for right/bottom; fc = px-per-unit at that edge.
class BindSeam
    public mem  : Au_t
    public app  : Au
    public axis : i32
    public sign : f32
    public fc   : f32
    # px clamp (from the coord) + the parent extent along the axis, so the drag
    # can clamp the value: collapse floor = max/fc, full = (span - min)/fc.
    public min       : f32
    public max       : f32
    public span      : f32
    public has_range : bool
    # optional companion field `<varname>_user`: the last NON-snapped (open)
    # position. updated on open drags, left alone when the drag snaps to collapse,
    # so the app can restore the user's real size after a collapse.
    public user_mem  : Au_t


Display Window
    mutable app_object          : trinity*
    mutable cursors             : array CursorPos
    # GLFW resize cursors for seam hover/drag (created lazily, cached). cursor_kind
