Button Option
    public left_view  : bool
    public right_view : bool
    public toggle     : bool
    # when set, the option never toggles its own `selected` — the app owns that
    # state and drives it (e.g. a play↔stop button bound to a running flag).
    public manual_mode : bool
    func on_press[ ev:Event ]
        if [ manual_mode ] return
        if [ ev.mouse.pos.y != (0 ..< 48) ]
            return
        if [ selected && !toggle ]
            return
        new_state : bool [ !selected ]
        for [ e:element, id:string ] in parent.elements
            op : Option e
            if [ op ]
                op.selected = (new_state && a == e)
                op.restyle  = true

    func render[] -> Elements
        return null

