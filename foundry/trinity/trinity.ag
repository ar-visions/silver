    mutable cursor_hresize      : handle
    mutable cursor_vresize      : handle
    mutable cursor_kind         : i32

    public compose              : Canvas
    public glyph                : Canvas
    public screen               : Canvas

    public background            : Background
    public background_type       : Au_t
    mutable m_reduce             : Model
    mutable r_reduce             : Render
    mutable m_reduce0            : Model
    mutable r_reduce0            : Render
