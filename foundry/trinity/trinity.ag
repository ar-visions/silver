func ux_event [ e: element, esubs: subs, ev: Event ]
    if [ !esubs ]
        return
    for [ sub: subscriber ] in esubs.entries
        ev.target = e
        sub.method[ sub.target, ev ]
        if [ ev.stop_propagation ]
            return


element World
    public target       : Target
    public models       : array
    public render_scale : f32 1.0
    public clear_color  : vec4f
    public rotate       : array Rotation
    public translate    : array Translation
    public scale        : array Scaling
    public update       : subs

    func init []
        expect ux, 'ux not set'

    func draw [ w: Window ]
        expect update, 'update subs not set'
        scene_load[ w ]

        width  : i32 [ bounds.w * render_scale ]
        height : i32 [ bounds.h * render_scale ]
        target.width  = width
        target.height = height
        target.wscale = 0.0

        target.update[]

        expect update, '{id}_update sub not declared by the app'
        if [ update ]
            invoke[ update, self ]

        at : array [ translate ]
        ar : array [ rotate ]
        as : array [ scale ]

        if [ at || ar || as ]
            for [ m: model ] in target.models
                free[ m.transforms ]
                ln0 : i32 [ at ? at.count : 0 ]
                ln1 : i32 [ ar ? ar.count : 0 ]
                ln2 : i32 [ as ? as.count : 0 ]
                ln  : i32 [ ln0 > ln1 && ln0 > ln2 ? ln0 : ln1 > ln0 && ln1 > ln2 ? ln1 : ln2 ]
                m.transforms      = new mat4f [ ln ]
                m.transform_count = ln
                for [ i: i32 0, i < ln, i += 1 ]
                    mat : mat4f [ mat4f.identity[] ]
                    s : Scaling [ as ? peek[ as, i ] : null ]
                    if [ s ]
                        mat = mat4f.scale[ ref mat, ref s.value ]
                    r : Rotation [ ar ? peek[ ar, i ] : null ]
                    if [ r ]
                        v   : vec4f [ r.axis.x, r.axis.y, r.axis.z, radians[ r.degs ] ]
                        q   : quatf [ quatf[ ref v ] ]
                        mat = mat4f.rotate[ ref mat, ref q ]
                    t : Translation [ at ? peek[ at, i ] : null ]
                    if [ t ]
                        mat = mat4f.translate[ ref mat, ref t.value ]
                    m.transforms[i] = mat

        if [ typeid[ self ] == typeid[ background ] ]
            return

        w.overlay.set_texture[ target.reduction ? target.reduction : target.color ]
        w.overlay.draw_fill[]

    func dealloc []

