shader UXCompose
    mutable model        : mat4f
    mutable view         : mat4f
    mutable proj         : mat4f
    mutable low_color    : vec4f
    mutable high_color   : vec4f

    public background : attrib [ type:typeid[ UXSurface ], id:UXSurface.background,  count:1, format: typeid[ rgba8 ] ]
    public frost      : attrib [ type:typeid[ UXSurface ], id:UXSurface.frost,       count:1, format: typeid[ rgba8 ] ]
    public blur       : attrib [ type:typeid[ UXSurface ], id:UXSurface.overlay,     count:1, format: typeid[ rgba8 ] ]
    public compose    : attrib [ type:typeid[ UXSurface ], id:UXSurface.compose,     count:1, format: typeid[ rgba8 ] ]
    public colorize   : attrib [ type:typeid[ UXSurface ], id:UXSurface.colorize,    count:1, format: typeid[ rgba8 ] ]
    public overlay    : attrib [ type:typeid[ UXSurface ], id:UXSurface.overlay,     count:1, format: typeid[ rgba8 ] ]
    public glyph      : attrib [ type:typeid[ UXSurface ], id:UXSurface.glyph,       count:1, format: typeid[ rgba8 ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]


shader UXSimple
    mutable model : mat4f
    mutable view  : mat4f
    mutable proj  : mat4f
    
    public background : attrib [ type:typeid[ UXSurface ], id:UXSurface.background,  count:1, format: typeid[ rgba8 ] ]
    public colorize   : attrib [ type:typeid[ UXSurface ], id:UXSurface.colorize,    count:1, format: typeid[ rgba8 ] ]
    public overlay    : attrib [ type:typeid[ UXSurface ], id:UXSurface.overlay,     count:1, format: typeid[ rgbaf ] ]
    public glyph      : attrib [ type:typeid[ UXSurface ], id:UXSurface.glyph,       count:1, format: typeid[ u8 ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]


