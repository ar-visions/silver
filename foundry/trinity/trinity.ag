    func init[]
        puts 'window constructing'

    public func apply_args [ inst: element, e: element ] -> bool
        if [ typeid[ inst ] != typeid[ e ] ] return false
        changed : false
        if [ inst.transparency != e.transparency ]
            inst.transparency = e.transparency
        if [ inst.disable != e.disable ]
            inst.disable = e.disable
            changed = true
        if [ inst.label != e.label ]
            inst.label = e.label
            # the displayed source changed (e.g. a new file opened in this
            # editor) — drop any in-progress edit AND release focus so the
            # element leaves its label-edit state entirely (no stale query, not
            # stuck dimmed/focused). this is how the element "knows" it was
            # updated, independent of which path opened the file. release_focus
            # is a no-op unless this element is the focused one.
            inst.edit       = ''
            inst.sel_col    = 0
            inst.anchor_col = 0
            release_focus[ inst ]
            changed = true
        inst_opt : (inst to Option)
        e_opt    : (e    to Option)
        if [ inst_opt && e_opt ]
            if [ inst_opt.selected != e_opt.selected ]
                inst_opt.selected = e_opt.selected
                changed = true
            if [ inst_opt.left_view != e_opt.left_view ]
                inst_opt.left_view = e_opt.left_view
                changed = true
            if [ inst_opt.right_view != e_opt.right_view ]
                inst_opt.right_view = e_opt.right_view
                changed = true
        return changed

    
    public func transition_or_set [ inst:element, value_holder:Au, cur:Au, member:Au_t, best:StyleEntry ]
        # transition handling
        t            : best.trans
        ct           : StyleTransition
        should_trans : false
        mem          : string [ (best.bl && best.bl.key && best.bl.key.count) ? '{best.bl.key}.{member.ident}' : member.ident ]

        if [ t ]
            if [ !inst.transitions ]
                inst.transitions = StyleTransitions [ ]
            ct = inst.transitions[ mem ]
            if [ !ct ]
                ct = t.copy[]
                ct.reference = t
                should_trans = true
                inst.transitions[ mem ] = ct
            el [ ct.invalidate ]
                ct.invalidate = false
                should_trans = true
        el [ inst.transitions ]
            inst.transitions.rm[ mem ]

        if [ ct && should_trans ]
            if [ cur            ] cur.hold[]
            if [ best.instance  ] best.instance.hold[]
            if [ ct.from ] ct.from.drop[]
            if [ ct.to   ] ct.to.drop[]
            ct.from      = (cur) ? cur.hold[] : best.instance.hold[]
            ct.dbg_val   = best.value
            ct.to        = best.instance.hold[]
            ct.type      = typeid[ best.instance ]
            ct.start     = epoch_millis[]
            ct.member    = member
            ct.invalidate = false
            ct.container  = value_holder
            if [ cur            ] cur.drop[]
            if [ best.instance  ] best.instance.drop[]
            return

        float_count : i32 [ member.src.typesize / 4 ]
        dst_ptr     : ref f32 [ value_holder.member_ref[ member ] ]
        is_f_color : bool [ strcmp[ member.ident, 'fill_color_pos' ] == 0 ]

        # binding: read source member directly from element and apply (with optional filter)
        if [ best.binding ]
            src_m : Au.find_member[ typeid[ inst ], best.binding.chars, AU_MEMBER_VAR, 0, true ]
            if [ src_m ]
                src_ptr : ref f32 [ inst.member_ref[ src_m ] ]

                if [ best.filter > 0.0 ]
                    decay : pow[ best.filter, inst.ux.frame_factor ]
                    for [ i: i32 0, i < float_count, i += 1 ]
                        dst_ptr[i] = dst_ptr[i] + (src_ptr[i] - dst_ptr[i]) * (1.0 - decay)
                el
                    for [ i: i32 0, i < float_count, i += 1 ]
                        dst_ptr[i] = src_ptr[i]

                inst.volatile = true
            return

        # filter: EMA dst in-place toward best.instance; snap from zero on first use
        if [ best.filter > 0.0 ]
            target_ptr  : ref f32 [ best.instance ]
            unset       : true
            for [ i: i32 0, i < float_count, i += 1 ]
                if [ dst_ptr[i] != 0.0 ] unset = false
            if [ unset ]
                for [ i: i32 0, i < float_count, i += 1 ]
                    dst_ptr[i] = target_ptr[i]
            el
                decay : f32 [ pow[ best.filter, inst.ux.frame_factor ] ]
                moving : false
                for [ i: i32 0, i < float_count, i += 1 ]
                    delta : f32 [ target_ptr[i] - dst_ptr[i] ]
                    if [ delta > 0.0001 || delta < -0.0001 ]
                        moving = true
                    if [ target_ptr[i] != 0.0 ]
                        dst_ptr[i] = dst_ptr[i] + delta * (1.0 - decay)
                    el
                        dst_ptr[i] = dst_ptr[i] * decay
                if [ moving ]
                    inst.volatile = true
            #inst.volatile = true
            return

        value_holder.member_set[ member, best.instance ]


    public func cache_style [ inst:element, style_avail: map StyleEntries[string], force_update:bool, home_object:Au ]
        if [ inst.maps_populated && !force_update ]
            return
 
        inst.maps_populated = true
        for [ ty : typeid[ inst ], ty != typeid[ Au ], ty = ty.context ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                member : Au_t ty.members.origin[m]
                if [ member.member_type != AU_MEMBER_VAR || strcmp[ member.ident, "elements" ] == 0 ]
                    continue
                prop    : string [ member.ident ]
                entries : style_avail [ prop ]
                for [ entry : StyleEntry ] reverse in entries
                    if [ !(entry.bl.property && entry.bl.key) ]
                        continue
                    entry.member_map = Au.find_member [ typeid[inst], entry.bl.property.chars, AU_MEMBER_VAR, 0, true ]
                    expect entry.member_map, 'member not found on {ty.ident}: {entry.bl.property}'
                    meta_type : Au_t [ entry.member_map.meta.a ]
                    v : Au inst.member_object[ entry.member_map ]
                    mtype : typeid[ v ]
                    mc : (inst.member_object[ entry.member_map ] to map Layer[string])
                    if [ mc && mc.hsize <= 0 ]
                        info : header [ mc ]
                        puts 'bad mc: inst={inst.id} member={entry.member_map.ident} hsize={mc.hsize} key={entry.bl.key}'
                    if [ !mc || mc.hsize <= 0 ]
                        mc = map Layer[string][]
                        printf["mc object for %s (%p) is %p\n", inst.id.chars, inst, mc]
                        inst.member_set[ entry.member_map, mc ]
                        mc.hold[]
                    if [ !mc.contains[entry.bl.key] ]
                        inst_type : Au_t [ (entry.bl.type_name && entry.bl.type_name.count) ? Au.find_type[entry.bl.type_name.chars, null] : null ]
                        if [ !inst_type ]
                            has_state : bool [ false ]
                            for [ q: StyleQualifier ] in entry.bl.quals
                                if [ q.state ] has_state = true
                            if [ !has_state ] inst_type = meta_type
                        if [ inst_type ]
                            n : Au.new_object[inst_type, null, null, false, __FILE__, __LINE__, __SEQUENCE__]
                            ele : (home_object to element)
                            home_type : typeid[ home_object ]
                            inst_type : typeid[ inst ]
                            n.set_context_from[ home_object ]
                            n.set_context_from[ inst ]
                            n.initialize[]
                            mc[entry.bl.key] = n
                            
                   
    # needs copies
    public func apply_style [ inst: element, style_avail: map StyleEntries[string], home_object:Au ]
        #puts 'apply_style: inst={inst.id} hovered={inst.hovered} pressed={inst.pressed}'
        inst.volatile = false
        inst.pristine = false
        inst.maps_populated = false
        if [!inst.layers]
            inst.layers = map Layer[string] []

        # create layers in the order they render
        cache_style[inst, style_avail, false, home_object]
        
        applied : map StyleEntry[string][]
        for [ ty : typeid[ inst ], ty != typeid[ Au ], ty = ty.context ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                member : Au_t ty.members.origin[m]
                if [ member.member_type != AU_MEMBER_VAR || strcmp[ member.ident, "elements" ] == 0 ]
                    continue
                prop    : string [ member.ident ]
                entries : style_avail [ prop ]
                if [ !entries ]
                    continue
                #puts 'apply_style:   {prop} entries={entries.count}'
                first : (entries[0] to StyleEntry)

                # we sometimes have to create a map for 'layers' as well as a Layer instance inside
                if [ first.bl.property && first.bl.key ]
                    # find the layers member Au_t
                    for [ best : StyleEntry ] in entries
                        score : best.bl.score[ inst, true ]
                        if [ score == 0 ]
                            continue
                        f : (best.bl.key) ? '{best.member}.{best.bl.key}' : best.member
                        if [ applied[f] ]
                            continue
                        applied[f] = best

                        if [!best.member_map]
                            cache_style[inst, style_avail, true, home_object]

                        mc : (inst.member_object[ best.member_map ] to map)
                        expect mc, "expected map container"
                        layer_inst  : mc.get[best.bl.key]
                        inst_type   : Au.__typeid[layer_inst]
                        layer_member : Au.find_member[ inst_type, best.member, AU_MEMBER_VAR, 0, true ]
                        if [ !layer_member ]
                            continue
                        expect layer_member, 'member not found on {inst_type.ident}: {best.member}'

                        if [ !best.instance ]
                            if [ (layer_member.src.traits & (1 << 11)) && typeid[best.value] != typeid[array] ]
                                best.instance = Au.new_object[ layer_member.src, null, null, false, __FILE__, __LINE__, __SEQUENCE__ ]
                                best.instance.set_context_from[ home_object ]
                                best.instance.call_construct[ best.value ]
                            el
                                best.instance = (best.value to layer_member.src)
                            best.instance.hold[]

                        cur : layer_inst.member_object[ layer_member ]
                        if [ !cur ]
                            cur = best.instance

                        transition_or_set[ inst, layer_inst, cur, layer_member, best ]

                el
                    best : st.best_match[ inst, prop, entries ]
                    if [ !best ]
                        continue

                    if [ !best.instance ]
                        info      : header [ best.value ]
                        val_type  : Au_t [ info.au ]
                        meta_type : Au_t [ member.meta.a ]
                        if [ val_type == typeid[ array ] && member.src == typeid[ array ] && meta_type ]
                            src_arr  : (best.value to array string)
                            dst_arr  : array Au [ ]
                            for [ s: string ] in src_arr
                                obj : Au.new_object[ meta_type, null, null, false, __FILE__, __LINE__, __SEQUENCE__ ]
                                obj.set_context_from[ home_object ]
                                obj.call_construct[ s ]
                                dst_arr.push[ obj ]
                            best.instance = dst_arr
                        el [ member.src == typeid[ Au_t ] ]
                            str : (best.value to string)
                            found_type : Au.find_type[ str.chars, null ]
                            if [ found_type ]
                                inst.member_set[ member, found_type ]
                            continue
                        el
                            if [ member.src.traits & (1 << 11) ]
                                best.instance = Au.new_object[ member.src, null, null, false, __FILE__, __LINE__, __SEQUENCE__ ]
                                best.instance.set_context_from[ home_object ]
                                best.instance.call_construct[ best.value ]
                            el
                                best.instance = (best.value to member.src)
                        
                        best.instance.hold[]

                    cur : inst.member_object[ member ]
                    if [ !cur ]
                        cur = best.instance

                    transition_or_set[ inst, inst, cur, member, best ]


    public func animate []
        if [ !root ]
            return

        now          : i64 [ epoch_millis[] ]
        if [ !start_ms ] start_ms = now
        time          = f64[ now - start_ms ] / 1000.0
        frame_factor = (1.0 / 60.0) / (last_frame_ms > 0) ? f32[ now - last_frame_ms ] / 1000.0 : 0.016
        last_frame_ms = now
        frame_seq += 1
        root.animate_within [ ]

    func update_element [ parent: element, rendered: map element[string], force: bool ]
        if [!parent.elements] parent.elements = Elements[]

        # obtain instance of parent
        # if a parent reads element within another subclass it contains, then it has access.to
        home_type   : Au_t
        home_object : element

        # mark for umount
        for [ e:element, id:string ] in parent.elements
            e.flags |= 1

        # count rendered children for positional flags
        total_rendered : i32 [ 0 ]
        for [ e:element, id:string ] in rendered
            total_rendered += 1

        # iterate through rendered elements
        child_pos : i32 [ 0 ]
        for [ e:element, id:string ] in rendered
            instance  : element* parent.elements[ id ]
            changed   : bool e.restyle
            new_inst  : false
            brand_new : false
            call_init : false

            if [ instance ]
                instance.flags &= ~1
                if [ !instance.id ]
                    brand_new = true # component within element map
                el [ typeid[instance] != typeid[e] ]
                    parent.elements.rm[ id ]
                    instance = null

            if [ brand_new || !instance ]
                if [ id == "toolbar" ]
                    test2 :  2
                    test2 += 2
                    win : cast Window[ w ]
                    win.test_element = e
                
                new_inst         = true
                instance         = (instance) ? instance : e.hold[]
                instance.restyle = true
                instance.id      = id
                instance.ux      = a
                instance.parent  = parent

                if [ !parent.elements ]
                    parent.elements = map element[string] [ ]

                if [ !brand_new ]
                    parent.elements[ id ] = instance

                # auto-bind instance to 'home' if defined
                if [ !home_type ]
                    home_type   = typeid[ parent ]
                    home_object = parent
                    if [ home_type == typeid[ element ]]
                        while [ home_object ]
                            home_object = home_object.parent
                            if [ !home_object ]
                                break
                            home_type   = typeid[ home_object ]
                            if [ home_type != typeid[ element ]]
                                break
                    if [ !home_object ]
                        home_object = (parent.ux.app_object to element)
                        home_type   = typeid[ home_object ]
                
                imember : find_member[ home_type, id.chars, AU_MEMBER_VAR, 0, true ]
                if [ imember ]
                    home_object.member_set[ imember, instance ]
                 
                instance.set_context_from[ home_object ]
                call_init = true
                changed = true
            el
                ta0 : i64 [ epoch_micros[] ]
                args_changed : bool apply_args[ instance, e ]
                a.t_apply_args += epoch_micros[] - ta0
                changed = args_changed || instance.restyle || force
                instance.restyle = false

            new_first  : bool [ child_pos == 0 ]
            new_last   : bool [ child_pos == total_rendered - 1 ]
            new_middle : bool [ child_pos > 0 && child_pos < total_rendered - 1 ]
            if [ instance.first != new_first || instance.last != new_last || instance.middle != new_middle ]
                instance.first  = new_first
                instance.last   = new_last
                instance.middle = new_middle
                changed = true
            instance.odd  = (child_pos % 2 == 0)
            instance.even = (child_pos % 2 == 1)
            child_pos += 1

            if [ changed ]
                e.restyle = false
                avail  : st.compute[ instance ]
                ts0 : i64 [ epoch_micros[] ]
                apply_style[ instance, avail, home_object ]
                a.t_apply_style += epoch_micros[] - ts0

                # init finally called after context and style is applied
                # our holds are too many for properties applied in style, though.
                if [ call_init ]
                    expect instance.vk, "no vk context set for new instance"
                    instance.initialize[]
                    instance.hold_members[]
                    instance.restyle = true

            inst    : typeid[ instance ]
            tr0 : i64 [ epoch_micros[] ]
            irender : instance.render[]
            a.t_render += epoch_micros[] - tr0
            if [ !irender ] irender = e.elements
            if [ !irender ] irender = instance.elements
            if [ irender ] update_element[ instance, irender, force ]

        # perform umount on elements not updated in render
        retry : true
        while [ retry ]
            retry = false
            for [ e:element, id:string ] in parent.elements
                if [ e.flags & 1 ]
                    e.flags  = 0
                    retry    = true
                    e.parent = null
                    e.drop_members[]
                    parent.elements.rm[ id ]
                    break

    public func is_animating [] -> bool
        if [ !root ] return true
        if [ capture ] return true
        return root.is_animating[]

    public func update_all [ render: Elements ]
        if [ !root ]
            root    = element [ id: string[ 'root' ], ux:a ]
            root_styles = st.compute[ root ]
            restyle = true
        
        force_restyle : (!restyle) ? st.check_reload[] : false
        if [ force_restyle ]
            root_styles = st.compute[ root ]
            restyle     = true

        if [ force_restyle ]
            root.invalidate_transitions[ ]
            apply_style[ root, root_styles, null ]
            root.remove_invalid_transitions[ ]

        t_apply_args  = 0
        t_apply_style = 0
        t_render      = 0
        t0 : i64 [ epoch_micros[] ]
        update_element[ root, render, restyle ]
        t1 : i64 [ epoch_micros[] ]
        dt : i64 [ t1 - t0 ]
        #if [ dt > 100 ] puts 'update:{dt}us  args:{t_apply_args}us  style:{t_apply_style}us  render:{t_render}us'
        restyle = false

    public func set_capture [ e: element ]
        if [ capture != e ]
            if [ capture ]
                capture.captured = false
                capture.restyle  = true
            if [ e && !e.ghost ]
                capture = e
                capture.captured = true
                capture.restyle  = true

    public func release_capture [ e: element ]
        if [ capture && capture == e ]
            capture = null

    public func set_focus [ e: element ]
        if [ focus != e ]
            if [ focus ]
                focus.focused = false
                focus.restyle = true
            if [ e && !e.ghost ]
                focus = e
                focus.focused = true
                focus.restyle = true
                focus.pristine = false

    public func release_focus [ e: element ]
        if [ focus && focus == e ]
            focus.focused = false
            focus.restyle = true
            focus = null

    public func find_target [ e: element, ev: Event, must: element ] -> element
        # fully-transparent elements are hidden — ignore them (and their
        # children) in event hit-testing so they don't capture clicks.
        if [ !e || e.disable || e.ghost || e.transparency >= 1.0 ]
            return null
        b : rect  [ e.bounds ]
        x : f32   [ ev.mouse.pos.x ]
        y : f32   [ ev.mouse.pos.y ]
        lx : f32  [ x - b.x ]
        ly : f32  [ y - b.y ]

        if [ !must && (lx < 0.0 || ly < 0.0 || lx >= b.w || ly >= b.h) ]
            return null

        # update cursor on every element in the traversal path — cursor is
        # always live on all controls, normalized to element-local [0..1].
        bw : f32 [ (b.w > 0.0) ? b.w : 1.0 ]
        bh : f32 [ (b.h > 0.0) ? b.h : 1.0 ]
        e.cursor = vec2f [ x: lx / bw, y: ly / bh ]

        ev.mouse.pos.x = lx + e.scroll.x
        ev.mouse.pos.y = ly + e.scroll.y

        # hit-test in REVERSE of paint order: children are painted first→last
        # (later draws on top), so the topmost-drawn sibling must be tested
        # first. iterate reverse; topmost-flagged children still come before the
        # rest. this is why a later-declared sibling (e.g. the filter) wins its
        # own click without needing a per-element topmost.
        for [ child: element, id: string ] reverse in e.elements
            if [ !child.topmost ] continue
            hit : find_target[ child, ev, must ]
            if [ hit ]
                return hit
        for [ child: element, id: string ] reverse in e.elements
            if [ child.topmost ] continue
            hit : find_target[ child, ev, must ]
            if [ hit ]
                return hit

        r : element [ ( !must || must == e ) ? e : null ]
        if [ !r ]
            ev.mouse.pos.x = x
            ev.mouse.pos.y = y
        return r

    public func text_event [ ev: Event ]
        ev.target = focus
        if [ focus && focus.on_char*[ ev ] ] return
        if [ app_object && app_object.on_char*[ ev ] ] return
        if [ focus && ev.key.text && ev.key.text.count > 0 ]
            for [ l: Layer, k: string ] in focus.layers
                if [ l.editable ]
                    l.on_char[ ev ]
                    break

    public func key_event [ ev: Event ]
        ev.target = focus
        if [ focus && focus.on_key*[ ev ] ] return
        if [ app_object && app_object.on_key*[ ev ] ] return
        if [ focus ]
            for [ l: Layer, k: string ] in focus.layers
                if [ l.editable ]
                    l.on_key[ ev ]
                    break

    # recursive bubble: from deepest element up through parents, each gets
    # a chance to consume. stops on first `true` return. after the element
    # chain, the app sees it; finally window's default handler runs (focus
    # transfer, capture, pressed/hovered bookkeeping) regardless of consume.
    public func move_event [ ev: Event ]
        orig_pos : vec2f [ ev.mouse.pos ]
        f : find_target[ root, ev, null ]
        ev.mouse.pos = orig_pos
        m : element [ (capture) ? find_target[ root, ev, capture ] : f ]
        # hover / leave bubble — flip state bools and set restyle; the next
        # update_element pass picks up restyle and re-applies CSS.
        if [ hovered != f ]
            #puts 'hover: changed (prev={(hovered) ? hovered.id : null}, new={(f) ? f.id : null})'
            prev : element [ hovered ]
            if [ prev ]
                if [ prev inherits Button ]
                    prev = prev
                prev.hovered = false
                prev.restyle = true
                restyle = true
                
                leave_consumed : bool [ false ]
                for [ e: element* prev, e && !leave_consumed, e = e.parent ]
                    ev.target = e
                    if [ e.on_leave*[ ev ] ] leave_consumed = true
                if [ !leave_consumed && app_object ]
                    ev.target = prev
                    app_object.on_leave*[ ev ]
            hovered = f
            if [ f ]
                f.hovered = true
                f.restyle = true
                restyle = true
                hover_consumed : bool [ false ]
                for [ e: element* f, e && !hover_consumed, e = e.parent ]
                    ev.target = e
                    if [ e.on_hover*[ ev ] ] hover_consumed = true
                if [ !hover_consumed && app_object ]
                    ev.target = f
                    app_object.on_hover*[ ev ]
        # move bubble
        if [ m ]
            move_consumed : bool [ false ]
            for [ e: element* m, e && !move_consumed, e = e.parent ]
                ev.target = e
                e.on_move*[ ev ]
            if [ !ev.no_propagation && app_object ]
                ev.target = m
                app_object.on_move*[ ev ]
        if [ focus && focus.text_dragging ]
            for [ l: Layer, k: string ] in focus.layers
                if [ l.editable ]
                    l.on_move[ ev ]
                    break

    public func wheel_event [ ev: Event ]
        target_el : element [ (capture) ? capture : (focus) ? focus : find_target[ root, ev, null ] ]
        consumed_w : bool [ false ]
        for [ e: element* target_el, e && !consumed_w, e = e.parent ]
            ev.target = e
            e.on_wheel*[ ev ]
        if [ !ev.no_propagation && app_object ]
            ev.target = target_el
            app_object.on_wheel*[ ev ]
        # window default: scroll focused/target element (no-op hook for now)

    public func press_event [ ev: Event ]
        release_capture[ capture ]
        f : find_target[ root, ev, null ]
        element_pos : vec2f [ ev.mouse.pos ]
        # element bubble. element* gives poly dispatch so subclasses
        # (Button, CameraView, ...) see their own on_press override.
        consumed_p : bool [ false ]
        for [ e: element* f, e, e = e.parent ]
            cl : typeid[e]
            ev.target = e
            e.on_press*[ ev ]
            ev.mouse.pos.x += e.bounds.x - e.scroll.x
            ev.mouse.pos.y += e.bounds.y - e.scroll.y
            if [ ev.no_propagation ]
                break

        au : typeid[ f ]
        # app
        if [ !ev.no_propagation && app_object ]
            ev.target = f
            app_object.on_press*[ ev ]
        # window defaults: focus transfer on left button (only focusable
        # elements get focus — buttons, text controls, etc. opt in), then
        # capture, then pressed/hovered state bookkeeping.
        edit_l : Layer [ null ]
        if [ f ]
            for [ l: Layer, k: string ] in f.layers
                if [ l.editable ]
                    edit_l = l
                    break
        if [ ev.mouse.button == 0 && f && (f.focusable || edit_l) && !ev.no_default ]
            set_focus[ f ]
        if [ edit_l && ev.mouse.button == 0 ]
            ev.mouse.pos = element_pos
            edit_l.on_press[ ev ]
        if [ !capture ]
            set_capture[ f ]
        if [ ev.mouse.button == 0 ]
            if [ action_pressed ]
                action_pressed.restyle = true
                action_pressed.pressed = false
            if [ f ]
                f.restyle = true
                f.pressed = true
                restyle = true
            
            action_pressed = f
        el [ ev.mouse.button == 1 ]
            context_pressed = f

    public func release_event [ ev: Event ]
        f : find_target[ root, ev, capture ]
        consumed_r : bool [ false ]
        for [ e: element* f, e && !consumed_r, e = e.parent ]
            ev.target = e
            if [ e.on_release*[ ev ] ] consumed_r = true
        if [ !consumed_r && app_object ]
            ev.target = f
            app_object.on_release*[ ev ]
        if [ ev.mouse.button == 0 ]
            if [ action_pressed ]
                action_pressed.restyle = true
                action_pressed.pressed = false
            if [ f ]
                f.restyle = true
                f.pressed = false
                restyle = true
            
            if [ f && action_pressed == f && f.hovered ]
                for [ e: element* f, e, e = e.parent ]
                    ev.target = e
                    e.on_click*[ ev ]
                    if [ ev.no_propagation ]
                        break
                if [ !ev.no_propagation && app_object ]
                    ev.target = f
                    app_object.on_click*[ ev ]
            action_pressed  = null
            context_pressed = null
        el [ ev.mouse.button == 1 ]
            action_pressed  = null
            context_pressed = null
        if [ !action_pressed && !context_pressed ]
            release_capture[ capture ]
        if [ focus && focus.text_dragging ]
            for [ l: Layer, k: string ] in focus.layers
                if [ l.editable ]
                    l.on_release[ ev ]
                    break
    
    func update_background[ type:Au_t ]
        if [ !background || type != background_type ]
            if [ background ]
                drop background
            
            background_type = type
            if [ background_type ]
                args : map Au[string] [ "window": a ]
                background = Au.construct_with[ background_type, args, null ]
                if [ !background.color ]
                    background.color = rgba[ r:0.022, g:0.088, b:0.188, a:1.0 ]
                background.render = Render [ vk: a.vk, w: a, wscale: 1.0,
                    #clear_color: vec4f [ 0.022, 0.088, 0.188, 1.0 ],
                    clear_color: vec4f [
                        background.color.r,
                        background.color.g,
                        background.color.b, 1.0 ],
                    models: background.models ]
            el
                background = null

            expect (!background || background.render),
                "no render object found on background"

        if [ background ]
            background.update*[]
    
    func update [ ]
        # DEBUG step 3: full canvases + full composition chain using UX shader.
        compose  = (compose  || Canvas [ w:a, vk: vk, format: Pixel.rgba8, load_existing: true, :width, :height ]).resize[ width, height ]
        glyph    = (glyph    || Canvas [ w:a, vk: vk, format: Pixel.u8,    :width, :height ]).resize[ width, height ]
        screen   = (screen   || Canvas [ w:a, vk: vk, format: Pixel.rgba8, load_existing: true, :width, :height ]).resize[ width, height ]

        compose .update[]
        glyph   .update[]
        screen  .update[]

        compose .clear[ string[ "#888" ] ]
        glyph   .clear[ string[ "#000" ] ]
        screen  .clear[ string[ "#000" ] ]

        if [ !is_setup ]
            is_setup = true
            ctx: vk_context[ a.vk ]

            if [ !background ]
                update_background[ background_type ]

            if [ background ]
                background.render.update[]

            # todo: we need ability to skip this sequence if background is a clear_color
            m_reduce  = Model  [ w: a, samplers: map Texture[string] [ 'color': background.render.color ] ]
            r_reduce  = Render [ vk: ctx, w: a, wscale: 1.0, models: array Model [ m_reduce ] ]

            m_reduce0 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce.color ] ]
            r_reduce0 = Render [ vk: ctx, w: a, wscale: 0.5, models: array Model [ m_reduce0 ] ]

            m_reduce1 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce0.color ] ]
            r_reduce1 = Render [ vk: ctx, w: a, wscale: 0.25, models: array Model [ m_reduce1 ] ]

            fbv : BlurV [ vk: ctx, name: 'blur-v', reduction_scale: 4.0 ]
            m_blur_v  = Model  [ w: a, s: fbv, samplers: map Texture[string] [ 'color': r_reduce1.color ] ]
            r_blur_v  = Render [ vk: ctx, w: a, wscale: 1.0, models: array Model [ m_blur_v ] ]

            fbl : Blur [ vk: ctx, name: 'blur', reduction_scale: 4.0 ]
            m_blur    = Model  [ w: a, s: fbl, samplers: map Texture[string] [ 'color': r_blur_v.color ] ]
            r_blur    = Render [ vk: ctx, w: a, wscale: 1.0, models: array Model [ m_blur ] ]

            m_reduce2 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce1.color ] ]
            r_reduce2 = Render [ vk: ctx, w: a, wscale: 0.125, models: array Model [ m_reduce2 ] ]

            m_reduce3 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce2.color ] ]
            r_reduce3 = Render [ vk: ctx, w: a, wscale: 0.0625, models: array Model [ m_reduce3 ] ]

            bv : BlurV [ vk: ctx, name: 'blur-v', reduction_scale: 16.0 ]
            m_frost_v = Model  [ w: a,   s: bv, samplers: map Texture[string] [ 'color': r_reduce3.color ] ]
            r_frost_v = Render [ vk: ctx, w: a, wscale: 1.0, models: array Model [ m_frost_v ] ]

            bl : Blur [ vk: ctx, name: 'blur', reduction_scale: 16.0 ]
            m_frost   = Model  [ w: a,   s: bl, samplers: map Texture[string] [ 'color': r_frost_v.color ] ]
            r_frost   = Render [ vk: ctx, w: a, wscale: 1.0, models: array Model [ m_frost ] ]

            m_view    = Model [ w: w, s: UXBackground [ vk: ctx, name: 'ux' ],
                samplers: map Texture[string] [
                    'background':     background.render.color,
                    'frost':          r_frost.color,
                    'blur':           r_blur.color,
                    'compose':        compose.color
                ]
            ]

            r_view    = Render [ vk: ctx, w: a,
                color: screen.color,
                wscale: 1.0, clear_color: vec4f [ 1.0, 1.0, 1.0, 1.0 ],
                models: array Model [ m_view ] ]

            ux_shader : UXBackground [ m_view.s ]
            ux_shader.low_color  = vec4f [ 0.0, 0.1, 0.2, 1.0 ]
            ux_shader.high_color = vec4f [ 1.0, 0.8, 0.8, 1.0 ]

            list = array Render [
                background.render, r_reduce, r_reduce0, r_reduce1, r_blur_v, r_blur,
                r_reduce2, r_reduce3, r_frost_v, r_frost,
                r_view ]
            # throttle the entire background chain (all but r_view); r_view composites
            # fresh UI over a cached background frost so it must draw every frame
            for [ i: i32 0, i < list.count - 1, i += 1 ]
                bg : Render list[i]
                bg.draw_interval = 16
        el
            if [ list ]
                for [ r: Render ] in list
                    r.update[]
                for [ r: Render ] in list
                    if [ r.models ]
                        for [ m: Model ] in r.models
                            m.rebind_model[]

    # borderless fullscreen toggle — no video mode change, just sizes the
    # window to fit the monitor and removes decorations. restores on exit.
    func set_fullscreen [ on: bool ]
        if [ on == fs_active ]
            return
        if [ on ]
            # remember windowed geometry
            sx : i32
            sy : i32
            sw : i32
            sh : i32
            glfwGetWindowPos [ glfw, ref sx, ref sy ]
            glfwGetWindowSize[ glfw, ref sw, ref sh ]
            fs_saved_x = sx
            fs_saved_y = sy
            fs_saved_w = sw
            fs_saved_h = sh
            mon  : glfwGetPrimaryMonitor[]
            mode : ref GLFWvidmode [ glfwGetVideoMode[ mon ] ]
            # real fullscreen: GLFW sets _NET_WM_STATE_FULLSCREEN so the
            # taskbar is hidden. passing the native refresh rate avoids a
            # video-mode change.
            glfwSetWindowMonitor[ glfw, mon, 0, 0,
                mode.width, mode.height, mode.refreshRate ]
        el
            glfwSetWindowMonitor[ glfw, null, fs_saved_x, fs_saved_y,
                fs_saved_w, fs_saved_h, 0 ]
        fs_active = on

    public func resize [ w: i32, h: i32 ] -> Window
        resizing = true
        if [ vk && vk.device ]
            vkDeviceWaitIdle[ vk.device ]
        super.resize[ w, h ]
        update[]
        resizing = false
        return a

    mutable blur_anim : f32


    func on_compose []
        if [ !compose ] return
        if [ resizing ] return
        compose.save    [ ]
        compose.clear   [ '#00a' ]
        update_all      [ app_object.on_render*[ a ] ]
        animate         [ ]
        draw_element    [ root, CanvasType.compose, null ]
        compose.paint   [ ]
        compose.sync_fence[ ]
        compose.restore [ ]

    func on_screen []
        if [ !screen ] return
        if [ resizing ] return
        screen.save[]

        app_object.on_canvas*[ screen ]

        draw_element[ root, CanvasType.screen, null ]

        ##
        screen.fill_color[ '#f00' ]
        screen.rect_to[ 64.0, 64.0, 240.0, 120.0 ]
        screen.fill_color[ "#fff" ]
        screen.font_size [ 32 ]
        screen.draw_text[
            "Aura",
            rect [ x: 128.0 + 128.0 + 24.0 + 8.0 - 0.5, y: 64.0 + 32.0 - 32.0 - 0.5, w: 64.0, h: 32.0 ],
            vec2f [ 0.5, 0.5 ],
            vec2f [ 0.0, 0.0 ],
            false ]
        ##
        screen.paint[]
        screen.sync_fence[]
        screen.restore[]

    public func draw_element [ e: element*, stage: CanvasType, last:element ]
        expect e inherits element, 'e is not an element'
        canvas_arr : new Canvas[2] [ screen, compose ]
        cv : canvas_arr[stage]
        rel : rect [ (e.parent) ?
            rect [ x: 0, y: 0, w: e.parent.bounds.w, h: e.parent.bounds.h ] :
            rect [ x: 0, y: 0, w: width, h: height ] ]

        # fc must be set before bounds so layout uses the correct scale
        e.fc = 22.0
        if [ cv.font ]
            e.fc = cv.font.line_height

        # compute element bounds from its area
        if [ !e.area ]
            e.area = Region [ 0.0 ]

        if [!e.bounds] e.bounds = rect[]

        bounds : e.area.rectangle[ rel, null, (last) ? last.bounds : null, e.fc ]

        # percent sizing: override h/w with fraction of remaining sibling space
        if [ e.area && e.parent && e.parent.elements && (e.area.b.percent || e.area.r.percent) ]
            prel   : rect [ x: 0, y: 0, w: rel.w, h: rel.h ]
            pfc    : f32  [ (e.parent.fc > 0.0) ? e.parent.fc : e.fc ]
            fixed_h : f32 0.0
            fixed_w : f32 0.0
            for [ sib: element, sid: string ] in e.parent.elements
                if [ sib == e || !sib.area ] continue
                if [ e.area.b.percent && sib.area.b.y_type == YAlign.height && !sib.area.b.percent ]
                    sfc : f32 [ (sib.fc > 0.0) ? sib.fc : pfc ]
                    tb  : sib.area.rectangle[ prel, null, null, sfc ]
                    fixed_h += tb.h
                if [ e.area.r.percent && sib.area.r.x_type == XAlign.width && !sib.area.r.percent ]
                    sfc : f32 [ (sib.fc > 0.0) ? sib.fc : pfc ]
                    tb  : sib.area.rectangle[ prel, null, null, sfc ]
                    fixed_w += tb.w
            if [ e.area.b.percent ] bounds.h = e.area.b.offset * (rel.h - fixed_h)
            if [ e.area.r.percent ] bounds.w = e.area.r.offset * (rel.w - fixed_w)

        # content size (wc / hc): measure the element's content, then size to it.
        # a right anchor (l-slot is right-typed) offsets the element LEFT by its
        # computed width; a bottom anchor offsets it UP by its computed height.
        if [ e.area.r.content || e.area.b.content ]
            cw : f32 [ bounds.w ]
            ch : f32 [ bounds.h ]
            if [ e.elements && e.elements.count > 0 ]
                # content = extent of laid-out children (flow-aware via `last`)
                prov  : rect [ x: 0.0, y: 0.0, w: 100000.0, h: 100000.0 ]
                lastc : rect [ null ]
                maxr  : f32 [ 0.0 ]
                maxb  : f32 [ 0.0 ]
                for [ ce: element, ck: string ] in e.elements
                    if [ !ce.area ] continue
                    cb : ce.area.rectangle[ prov, null, lastc, e.fc ]
                    if [ cb.x + cb.w > maxr ] maxr = cb.x + cb.w
                    if [ cb.y + cb.h > maxb ] maxb = cb.y + cb.h
                    lastc = cb
                cw = maxr
                ch = maxb
            el [ cv.font && e.label && e.label.count > 0 ]
                tm : cv.measure_text[ e.label ]
                cw = tm.w
                ch = tm.ascent - tm.descent
            if [ e.area.r.content ]
                if [ e.area.l.x_type == XAlign.right ] bounds.x = bounds.x - cw
                bounds.w = cw
            if [ e.area.b.content ]
                if [ e.area.t.y_type == YAlign.bottom ] bounds.y = bounds.y - ch
                bounds.h = ch

        e.bounds.x = bounds.x
        e.bounds.y = bounds.y
        e.bounds.w = bounds.w
        e.bounds.h = bounds.h
        if [ e.transparency >= 1.0 ] return
        # pre-scan layers to measure any outset beyond element bounds
        margin_l : i32 [ 0 ]
        margin_t : i32 [ 0 ]
        margin_r : i32 [ 0 ]
        margin_b : i32 [ 0 ]
        for [ psc_au: Au, psc_k: string ] in e.layers
            psc_lay : Layer [ psc_au to Layer ]
            if [ !psc_lay || !psc_lay.area ] continue
            psc_b  : psc_lay.area.rectangle[ e.bounds, null, null, e.fc ]
            psc_lx : f32  [ psc_b.x - e.bounds.x ]
            psc_ly : f32  [ psc_b.y - e.bounds.y ]
            psc_rx : f32  [ psc_b.x + psc_b.w - e.bounds.x - e.bounds.w ]
            psc_by : f32  [ psc_b.y + psc_b.h - e.bounds.y - e.bounds.h ]
            if [ psc_lx < 0.0 ]
                ol : i32 ceilf[ 0.0 - psc_lx ]
                if [ ol > margin_l ] margin_l = ol
            if [ psc_ly < 0.0 ]
                ot : i32 ceilf[ 0.0 - psc_ly ]
                if [ ot > margin_t ] margin_t = ot
            if [ psc_rx > 0.0 ]
                or2 : i32 ceilf[ psc_rx ]
                if [ or2 > margin_r ] margin_r = or2
            if [ psc_by > 0.0 ]
                ob2 : i32 ceilf[ psc_by ]
                if [ ob2 > margin_b ] margin_b = ob2
        if [ margin_l > 0 ] margin_l += 1
        if [ margin_t > 0 ] margin_t += 1
        if [ margin_r > 0 ] margin_r += 1
        if [ margin_b > 0 ] margin_b += 1
        ew : i32 [ i32[ceilf[e.bounds.w]] + 1 + margin_l + margin_r ]
        eh : i32 [ i32[ceilf[e.bounds.h]] + 1 + margin_t + margin_b ]
        if [ ( ew > 0 && eh > 0 ) && ( !e.cache_canvas || e.cache_w != ew || e.cache_h != eh ) ]
            #if [ frame_seq > 1 ]
            #    fault 'cache-frame2 id={e.id} ew={ew} eh={eh} cw={e.cache_w} ch={e.cache_h} no_cc={!e.cache_canvas}'
            e.cache_canvas = Canvas [ w: a, vk: vk, format: Pixel.rgba8, width: ew, height: eh, load_existing: true ]
            e.cache_canvas.update[]
            e.cache_w = ew
            e.cache_h = eh
            e.cache_ox = margin_l
            e.cache_oy = margin_t
            e.pristine = false

        #puts 'target_cv set'
        target_cv : (e.cache_canvas && !e.volatile && stage == CanvasType.screen) ? e.cache_canvas : cv
        element_text : (e.label && e.label.count) ? e.label : null

        sx       : f32  [ (e.scaling.x != 0.0) ? e.scaling.x : 1.0 ]
        sy       : f32  [ (e.scaling.y != 0.0) ? e.scaling.y : 1.0 ]
        has_rot  : bool [ e.rotation != 0.0 ]
        has_sc   : bool [ sx != 1.0 || sy != 1.0 ]
        xform    : bool [ has_rot || has_sc ]

        if [ xform ]
            ox : f32 [ (e.transform_origin.x != 0.0) ? e.transform_origin.x : 0.5 ]
            oy : f32 [ (e.transform_origin.y != 0.0) ? e.transform_origin.y : 0.5 ]
            pivot_x : f32 [ e.bounds.w * ox ]
            pivot_y : f32 [ e.bounds.h * oy ]
            cv.save[]
            cv.translate[ pivot_x, pivot_y ]
            if [ has_rot ]
                cv.rotate[ e.rotation ]
            if [ has_sc ]
                cv.scale_xy[ sx, sy ]
            cv.translate[ -pivot_x, -pivot_y ]

        redraw : bool [ e.volatile || !e.pristine || stage == CanvasType.compose ]
        if [ redraw && e.cache_canvas && !e.volatile && stage == CanvasType.screen ]
            e.cache_canvas.reset[ vec4f[0.0, 0.0, 0.0, 0.0] ]
            if [ e.cache_ox > 0 || e.cache_oy > 0 ]
                target_cv.save[]
                target_cv.translate[ f32 e.cache_ox, f32 e.cache_oy ]

        e.needs_frame = false

        # compute layer bounds and draw each layer
        for [ layer_au: Au, lkey: string ] in e.layers
            if [ !redraw ] break
            layer : Layer [ layer_au to Layer ]
            if [ !layer || layer.ctype != stage || layer.hide ]
                continue

            layer.bounds = (layer.area) ? layer.area.rectangle[ e.bounds, null, null, e.fc ] : e.bounds.copy[]
            layer.bounds.x -= e.bounds.x
            layer.bounds.y -= e.bounds.y
            b  : rect   [ layer.bounds ]
            r_tl : f32 [ 0.0 ]
            r_tr : f32 [ 0.0 ]
            r_br : f32 [ 0.0 ]
            r_bl : f32 [ 0.0 ]
            if [ layer.radius ]
                r_tl = layer.radius.tl
                r_tr = layer.radius.tr
                r_br = layer.radius.br
                r_bl = layer.radius.bl

            # blur setup: draw to per-layer canvas when blur is active.
            # dirty on first use, size change, or active transition.
            needs_blur  : bool [ layer.blur_x > 0.0 || layer.blur_y > 0.0 ]
            draw_cv     : target_cv
            blur_redraw : bool [ false ]

            if [ needs_blur ]
                blur_r  : f32 [ (layer.blur_x > layer.blur_y) ? layer.blur_x : layer.blur_y ]
                pad     : f32 [ blur_r * 2.0 ]
                bw : i32 [ i32[b.w + pad] + 1 ]
                bh : i32 [ i32[b.h + pad] + 1 ]
                if [ !layer.blur_canvas || layer.blur_bw != bw || layer.blur_bh != bh ]
                    puts 'creating blur Canvas'
                    layer.blur_canvas = Canvas [ w: a, vk: vk, format: Pixel.rgba8, width: bw, height: bh ]
                    layer.blur_canvas.update[]
                    layer.blur_bw = bw
                    layer.blur_bh = bh
                    layer.blur_dirty = true
                if [ e.volatile ]
                    layer.blur_dirty = true
                if [ layer.blur_dirty ]
                    layer.blur_canvas.reset[ vec4f[0.0, 0.0, 0.0, 0.0] ]
                    draw_cv = layer.blur_canvas
                    draw_cv.save[]
                    draw_cv.translate[ -b.x + pad * 0.5, -b.y + pad * 0.5 ]
                    blur_redraw = true

            if [ (!needs_blur || blur_redraw) && ((layer.fill_color && layer.fill_color.a > 0.0) || (layer.stroke_color && layer.stroke_color.a > 0.0) || layer.inner_glow) ]
                draw_cv.save             [ ]
                sw_top   : f32 [ (layer.stroke_width) ? layer.stroke_width.top    : 0.0 ]
                sw_right : f32 [ (layer.stroke_width) ? layer.stroke_width.right  : 0.0 ]
                sw_bot   : f32 [ (layer.stroke_width) ? layer.stroke_width.bottom : 0.0 ]
                sw_left  : f32 [ (layer.stroke_width) ? layer.stroke_width.left   : 0.0 ]
                sw_max   : f32 [ maxf[ maxf[ sw_top, sw_right ], maxf[ sw_bot, sw_left ] ] ]
                # crisp-pixel offset: odd max stroke width needs half-pixel nudge
                sw_int : i32 [ i32 sw_max ]
                crisp  : f32 [ ((sw_int % 2) == 1) ? 0.5 : 0.0 ]
                if [ crisp > 0.0 ]
                    draw_cv.translate    [ crisp, crisp ]
                draw_cv.set_stroke_size  [ sw_max ]
                draw_cv.set_stroke_cap   [ layer.stroke_cap  ]
                draw_cv.set_stroke_join  [ layer.stroke_join ]
                draw_cv.rounded          [ r_tl, r_tr, r_br, r_bl ]
                draw_cv.stroke_sides     [ sw_top, sw_right, sw_bot, sw_left ]
                draw_cv.rounded_rect     [ b.x, b.y, b.w, b.h, r_tl, r_tr, r_br, r_bl ]
                draw_cv.fill_color       [ (layer.fill_color && layer.fill_color.a > 0.0) ? layer.fill_color : rgba [ '#00000000' ] ]
                draw_cv.stroke_color     [ layer.stroke_color ]
                # fill gradient anchors — same element-unit → world-pixel
                # convention as the label gradient. axis straddles the anchor
                # so mirror puts the highlight ON the anchor point.
                fp_x : f32 [ layer.fill_color_pos.x * e.bounds.w ]
                fp_y : f32 [ layer.fill_color_pos.y * e.bounds.h ]
                # DEBUG: hardcoded to test whether layer fields reach here.
                f_rad : f32 [ layer.fill_gradient_radius ]
                f_ax  : f32 [ draw_cv.transform_tx[] + fp_x ]
                f_ay  : f32 [ draw_cv.transform_ty[] + fp_y ]
                draw_cv.fill_grad        [ layer.fill_gradient_color ]
                if [ layer.fill_gradient == GradientType.radial ]
                    f_ry : f32 [ (layer.fill_gradient_radius_y > 0.0) ? layer.fill_gradient_radius_y : f_rad ]
                    draw_cv.fill_color_pos   [ f_ax, f_ay ]
                    draw_cv.fill_grad_pos    [ f_ax + f_rad, f_ay + f_ry ]
                    draw_cv.fill_grad_radial [ true ]
                    draw_cv.fill_grad_mirror [ false ]
                el [ layer.fill_gradient == GradientType.linear ]
                    draw_cv.fill_color_pos   [ f_ax, f_ay ]
                    fill_rad : f32 [ layer.fill_gradient_angle * 3.14159265 / 180.0 ]
                    fill_ext : f32 [ (f_rad > 0.0) ? f_rad : abs[b.w * cos[fill_rad]] + abs[b.h * sin[fill_rad]] ]
                    draw_cv.fill_grad_pos    [ f_ax + fill_ext * cos[ fill_rad ], f_ay + fill_ext * sin[ fill_rad ] ]
                    draw_cv.fill_grad_radial [ false ]
                    draw_cv.fill_grad_mirror [ false ]
                el
                    draw_cv.fill_grad_radial [ false ]
                    draw_cv.fill_grad_mirror [ false ]
                # stroke gradient anchor — independent of fill anchor
                sp_x  : f32 [ layer.stroke_color_pos.x * e.bounds.w ]
                sp_y  : f32 [ layer.stroke_color_pos.y * e.bounds.h ]
                s_ax  : f32 [ draw_cv.transform_tx[] + sp_x ]
                s_ay  : f32 [ draw_cv.transform_ty[] + sp_y ]
                s_rad : f32 [ layer.stroke_gradient_radius ]
                draw_cv.stroke_grad      [ layer.stroke_gradient_color ]
                if [ layer.stroke_gradient == GradientType.radial ]
                    s_ry : f32 [ (layer.stroke_gradient_radius_y > 0.0) ? layer.stroke_gradient_radius_y : s_rad ]
                    draw_cv.stroke_color_pos [ s_ax, s_ay ]
                    draw_cv.stroke_grad_pos  [ s_ax + s_rad, s_ay + s_ry ]
                    draw_cv.stroke_grad_radial [ true ]
                    draw_cv.stroke_grad_mirror [ false ]
                el [ layer.stroke_gradient == GradientType.linear ]
                    draw_cv.stroke_color_pos [ s_ax, s_ay ]
                    stroke_rad : f32 [ layer.stroke_gradient_angle * 3.14159265 / 180.0 ]
                    stroke_ext : f32 [ (s_rad > 0.0) ? s_rad : abs[b.w * cos[stroke_rad]] + abs[b.h * sin[stroke_rad]] ]
                    draw_cv.stroke_grad_pos  [ s_ax + stroke_ext * cos[ stroke_rad ], s_ay + stroke_ext * sin[ stroke_rad ] ]
                    draw_cv.stroke_grad_radial [ false ]
                    draw_cv.stroke_grad_mirror [ false ]
                el
                    draw_cv.stroke_grad_radial [ false ]
                    draw_cv.stroke_grad_mirror [ false ]
                if [ layer.inner_glow ]
                    draw_cv.inner_glow   [ layer.inner_glow.color, layer.inner_glow.blur ]
                draw_cv.paint            [ ]
                draw_cv.restore          [ ]

            if [ (!needs_blur || blur_redraw) && layer.image_svg ]
                sc : f32 (layer.image_scale > 0.0) ? layer.image_scale : 1.0
                dw : f32 layer.image_svg.w * sc
                dh : f32 layer.image_svg.h * sc
                dx : f32 b.x + (b.w - dw) * 0.5
                dy : f32 b.y + (b.h - dh) * 0.5
                draw_cv.save[]
                draw_cv.set_opacity[ (layer.opacity > 0.0) ? layer.opacity : 1.0 ]
                draw_cv.draw_svg[ layer.image_svg, dx, dy, dw, dh ]
                draw_cv.restore[]

            label : string (layer.label && layer.label.count > 0) ? layer.label : null

            if [ (!needs_blur || blur_redraw) && !layer.editable && (element_text || label) && layer.label_size > 0 && layer.label_color && layer.label_color.a > 0 ]
                draw_cv.save[]
                prev_font : CanvasFont draw_cv.font
                if [ layer.label_font && layer.label_font.count > 0 ]
                    if [ !layer.label_font_cache ]
                        layer.label_font_cache = CanvasFont [ ft_lib: draw_cv.ft_lib, uri: layer.label_font, size_px: i32[layer.label_size] ]
                    draw_cv.set_font[ layer.label_font_cache ]
                align  : vec2f [ x: layer.label_align.x, y: layer.label_align.y ]
                offset : vec2f  [ x: layer.label_offset.x, y: layer.label_offset.y ]
                draw_cv.fill_color   [ layer.label_color ]
                draw_cv.font_size    [ layer.label_size ]
                draw_cv.line_height  [ layer.label_height ]
                # gradient anchor: element-unit → world-pixel. |v| < 1 means
                # a fraction of e.bounds; otherwise pixels. the axis straddles
                # the anchor point (p0 = anchor - halfDir, p1 = anchor + halfDir)
                # so mirror puts the highlight ON the anchor (cursor-following
                # chrome). direction is label_grad_degrees from +x (screen
                # coords: 0 = right, 90 = down).
                cp_x : f32 [ layer.label_color_pos.x * e.bounds.w ]
                cp_y : f32 [ layer.label_color_pos.y * e.bounds.h ]
                rad  : f32 [ layer.label_gradient_radius ]
                ang  : f32 [ radians[ layer.label_gradient_degrees ] ]
                hx   : f32 [ cosf[ ang ] * rad * 0.5 ]
                hy   : f32 [ sinf[ ang ] * rad * 0.5 ]
                # canvas transform is already at the element's world origin
                # (parent called cv.translate[e.bounds.x, e.bounds.y] before
                # recursing). v_pos in the shader is world-space, so the
                # anchor must use the transform, not e.bounds.x/y.
                ax   : f32 [ draw_cv.transform_tx[] + cp_x ]
                ay   : f32 [ draw_cv.transform_ty[] + cp_y ]
                draw_cv.text_grad        [ layer.label_gradient ]
                draw_cv.text_color_pos   [ ax - hx, ay - hy ]
                draw_cv.text_grad_pos    [ ax + hx, ay + hy ]
                draw_cv.text_grad_mirror [ layer.label_gradient_mirror ]

                lsh : Shadow [
                    color:  layer.label_shadow,
                    offset: layer.label_shadow_offset,
                    blur:   layer.label_shadow_blur ]
                tx0 : f32 [ draw_cv.transform_tx[] + b.x ]
                ty0 : f32 [ draw_cv.transform_ty[] + b.y ]
                draw_cv.set_crop[ tx0, ty0, tx0 + b.w, ty0 + b.h ]
                draw_cv.draw_text    [ (label || element_text), b, align, offset, layer.label_overflow, lsh ]
                draw_cv.clear_crop[]
                if [ layer.label_font && layer.label_font.count > 0 ]
                    draw_cv.set_font[ prev_font ]
                draw_cv.restore      [ ]

            layer.draw*[ draw_cv ]

            if [ needs_blur ]
                if [ blur_redraw ]
                    draw_cv.restore[]
                    br : f32 [ (layer.blur_x > layer.blur_y) ? layer.blur_x : layer.blur_y ]
                    layer.blur_canvas.blur[ br ]
                    layer.blur_dirty = false
                bpad : f32 [ ((layer.blur_x > layer.blur_y) ? layer.blur_x : layer.blur_y) * 2.0 ]
                target_cv.draw_canvas[ layer.blur_canvas, b.x - bpad * 0.5, b.y - bpad * 0.5, b.w + bpad, b.h + bpad ]

        if [ xform ]
            cv.restore[]

        if [ redraw ]
            # redirect window canvases so e.draw* sees the cache target
            prev_screen  : a.screen
            prev_compose : a.compose
            if [ stage == CanvasType.screen ]  a.screen  = target_cv
            if [ stage == CanvasType.compose ] a.compose = target_cv
            e.draw*[ a ]
            a.screen  = prev_screen
            a.compose = prev_compose
            if [ !e.volatile && stage == CanvasType.screen ]
                if [ e.cache_ox > 0 || e.cache_oy > 0 ]
                    target_cv.restore[]
                if [ !e.needs_frame ]
                    e.pristine = true

        # blit element cache into parent canvas (screen stage only). when the
        # element wants an edge fade, build/refresh a grayscale mask (white
        # center, black inner glow) sized to the cache and composite through it.
        mask_on : bool [ e.mask_glow.x > 0.0 || e.mask_glow.y > 0.0 || e.mask_glow.z > 0.0 || e.mask_glow.w > 0.0 ]
        if [ e.cache_canvas && !e.volatile && stage == CanvasType.screen ]
            if [ mask_on ]
                if [ !e.mask_canvas || e.mask_w != ew || e.mask_h != eh ]
                    e.mask_canvas = Canvas [ w: a, vk: vk, format: Pixel.rgba8, width: ew, height: eh, load_existing: true ]
                    e.mask_canvas.update[]
                    e.mask_w = ew
                    e.mask_h = eh
                    e.mask_canvas.reset[ vec4f[ 0.0, 0.0, 0.0, 1.0 ] ]
                    e.mask_canvas.save[]
                    # linear falloff so the fade is a straight ramp on the edges
                    e.mask_canvas.glow_falloff[ 1.0 ]
                    e.mask_canvas.fill_color[ rgba['#fff'] ]
                    # mask_glow = (top, right, bottom, left) px
                    e.mask_canvas.inner_glow_sides[ rgba['#000'],
                        e.mask_glow.x, e.mask_glow.y, e.mask_glow.z, e.mask_glow.w ]
                    # mask_inset = (top, right, bottom, left) px: shrink the rect
                    # so the fade starts inset; outside stays fully masked.
                    mrx : f32 [ e.mask_inset.w ]
                    mry : f32 [ e.mask_inset.x ]
                    mrw : f32 [ f32 ew - e.mask_inset.w - e.mask_inset.y ]
                    mrh : f32 [ f32 eh - e.mask_inset.x - e.mask_inset.z ]
                    e.mask_canvas.rect_to[ mrx, mry, mrw, mrh ]
                    e.mask_canvas.paint[]
                    e.mask_canvas.restore[]
                cv.draw_canvas_masked[ e.cache_canvas, e.mask_canvas, 0.0 - f32 e.cache_ox, 0.0 - f32 e.cache_oy, f32 ew, f32 eh ]
            el
                cv.draw_canvas[ e.cache_canvas, 0.0 - f32 e.cache_ox, 0.0 - f32 e.cache_oy, f32 ew, f32 eh ]

        last_2 : element
        # paint normal children first, then topmost children over them
        for [ ee: element, id: string ] in e.elements
            if [ ee.topmost ] continue
            cv.save[]
            if [ ee.bounds ]
                cv.translate[ ee.bounds.x, ee.bounds.y ]
            draw_element[ ee, stage, last_2 ]
            last_2 = ee
            cv.restore[]
        for [ ee: element, id: string ] in e.elements
            if [ !ee.topmost ] continue
            cv.save[]
            if [ ee.bounds ]
                cv.translate[ ee.bounds.x, ee.bounds.y ]
            draw_element[ ee, stage, last_2 ]
            last_2 = ee
            cv.restore[]


abstract media_app trinity
    public background   : string
    public title        : string
    intern msaa_samples : i64
    intern istroke      : f32 0
    intern ifill        : f32 0

    public func on_canvas [ cv: Canvas ]
        return

    # input event hooks. return true to swallow; otherwise just observe.
    # ev.target is the element the event was dispatched to (null if none).
    # elements get these virtuals first (they can intercept); if the element
    # returns false or there's no target, the app sees it here.
    public func on_click   [ ev: Event ] return
    public func on_press   [ ev: Event ] return
    public func on_release [ ev: Event ] return
    public func on_hover   [ ev: Event ] return
    public func on_leave   [ ev: Event ] return
    public func on_move    [ ev: Event ] return
    public func on_wheel   [ ev: Event ] return
    public func on_key     [ ev: Event ] return
    public func on_char    [ ev: Event ] return

    public func on_render  [ w: Window ] -> Elements
        return Elements [
            "root": element [
                elements: [
                    "one": Button[],
                    "two": Button[]
                ]
            ]
        ]

    func init         [] return
    func load_scene   [] return
    func update_scene [] return
         
    func run[]
        puts 'reload 2'
        type : typeid[a]
        background_type : Au.find_type[ (background) ? background.chars : null, null ]
        window : Window[ app_object: a, title:(title) ?? type.ident, st: Style [ a ],
            width:(width) ?? 1888, height:(height) ?? 888, background_type:background_type ]
        expect window.vk, "context didnt work"
        window.hold[]
        w = window
        w.update *[]
        render   *[]
        w.resize[w.width, w.height]
        super.run[]

    # 22
    func render[]
        window : Window[w]
        wa : bool [ window.will_animate ]
        window.will_animate = false
        if [ window.restyle || wa || window.is_animating[] ]
            update_scene*[]
            window.draw[]
            frames += 1


# scrolling requires defined children Region
Layer Children
    public scroll : vec2f

Layer ScrollLayer
    public thumb_color  : string
    public thumb_w      : f32
    public thumb_min_h  : f32
    public thumb_radius : f32

    func draw [ cv: Canvas ]
        e : element [ parent ]
        if [ !e || e.content_h <= 0.0 || e.bounds.h >= e.content_h ] return
        total_h : f32 [ e.content_h ]
        vis_h   : f32 [ bounds.h ]
        ratio   : f32 [ vis_h / total_h ]
        min_h   : f32 [ (thumb_min_h > 0.0) ? thumb_min_h : 32.0 ]
        thumb_h : f32 [ (ratio * vis_h < min_h) ? min_h : ratio * vis_h ]
        travel  : f32 [ vis_h - thumb_h ]
        max_sc  : f32 [ total_h - vis_h ]
        thumb_y : f32 [ bounds.y + (max_sc > 0.0) ? (e.scroll.y / max_sc) * travel : 0.0 ]
        thumb_x : f32 [ bounds.x + bounds.w - thumb_w ]
        r       : f32 [ thumb_radius ]
        cv.fill_color[ thumb_color ]
        cv.rounded_rect[ thumb_x, thumb_y, thumb_w, thumb_h, r, r, r, r ]
        cv.paint[]


element View
    func render[] -> Elements
        return null

element Group
    public selected : bool
    func render[] -> Elements
        return null

element Control
    focusable : true
    func render[] -> Elements
        return null

Control Button
    func render[] -> Elements
        return null

Button Check
    mutable selected : bool
    func init[]
        selected = true
    
    func on_click[ ev:Event ]
        selected = !selected
    
    func render[] -> Elements
        return null

Button Option
    public selected   : bool
    public left_view  : bool
    public right_view : bool
    public toggle     : bool
    func on_press[ ev:Event ]
        if [ ev.mouse.pos.y != (0 ..< 48) ]
            return
        if [ selected && !toggle ]
            return
        new_state : bool [ !selected ]
        for [ e:element, id:string ] in parent.elements
            op : Option e
            if [ op ]
                op.selected = (new_state && a == e)
                op.restyle  = true

    func render[] -> Elements
        return null

element Toolbar
    func render[] -> Elements
        return null

Option Edit
    func on_press[ ev:Event ] return
    func render[] -> Elements
        return null


ModelViewProject UXBackground
    mutable low_color    : vec4f
    mutable high_color   : vec4f

    attrib background     : LayoutBinding [ type:typeid[ UXSurface ], id:UXSurface.background,     count:1, format: typeid[ rgba8 ] ]
    attrib frost          : LayoutBinding [ type:typeid[ UXSurface ], id:UXSurface.frost,          count:1, format: typeid[ rgba8 ] ]
    attrib blur           : LayoutBinding [ type:typeid[ UXSurface ], id:UXSurface.blur,           count:1, format: typeid[ rgba8 ] ]
    attrib compose        : LayoutBinding [ type:typeid[ UXSurface ], id:UXSurface.compose,        count:1, format: typeid[ rgba8 ] ]
    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

    func rgb2hsv [ c: vec3f ] -> GLSL vec3f {
        vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
        vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
        vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
        float d = q.x - min(q.w, q.y);
        float e = 1.0e-10;
        return vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
    }

    func hsv2rgb [ c: vec3f ] -> GLSL vec3f {
        vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
        vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
        return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
    }

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    # 44
    func fragment [] -> GLSL none {
        vec4  comp     = texture(compose,        v_uv);
        float luminance = 1.0 - ((comp.b - 0.5020) * 2.0);
        vec3  f;
        
        if (comp.r < 0.5020) {
            f = mix(
                texture(background, v_uv).rgb,
                texture(blur,       v_uv).rgb,
                comp.r / 0.5020) * luminance;
        } else {
            f = mix(
                texture(blur,       v_uv).rgb,
                texture(frost,      v_uv).rgb,
                (comp.r - 0.5020) / (1.0 - 0.5020)) * luminance;
        }

        fragColor = vec4(f, 1.0);
    }


expect func test [ vk: vk_context ] -> bool
    w: Display [ vk: vk, format: Pixel.rgba8, backbuffer: true, width: 1024, height: 1024 ]
    c: Canvas [ vk: vk, w: w, width: 1024, height: 1024 ]
    c.update[]

    # outer blob
    c.path.clear[]
    c.path.move_to[ 200.0, 200.0 ]
    c.path.cubic_to[ 400.0, 100.0, 600.0, 300.0, 800.0, 200.0 ]
    c.path.cubic_to[ 900.0, 500.0, 700.0, 700.0, 500.0, 800.0 ]
    c.path.cubic_to[ 300.0, 900.0, 100.0, 600.0, 200.0, 200.0 ]
    c.path.close_path[]

    c.save[]
    c.fill_color[ '#3366AA' ]
    c.paint[]

    # inner cutout (opposite winding)
    c.path.clear[]
    c.path.move_to[ 450.0, 350.0 ]
    c.path.cubic_to[ 550.0, 300.0, 650.0, 400.0, 600.0, 500.0 ]
    c.path.cubic_to[ 550.0, 600.0, 400.0, 550.0, 450.0, 350.0 ]
    c.path.close_path[]
    c.fill_color[ '#0000' ]
    c.paint[]
    c.restore[]

    # fetch Texture and verify
    img: Image[c.color]
    p: path 'canvas_test.png'
    p.save[ img, null ]
    puts 'wrote canvas_test.png'

    # average color across Image
    pixels: img.width * img.height
    data: ref u8 img.vdata[]
    r_sum: i64 [ 0 ]
    g_sum: i64 [ 0 ]
    b_sum: i64 [ 0 ]
    a_sum: i64 [ 0 ]
    for [ i: i32 0, i < pixels, i += 1 ]
        r_sum += data[i * 4 + 0]
        g_sum += data[i * 4 + 1]
        b_sum += data[i * 4 + 2]
        a_sum += data[i * 4 + 3]
    avg_r: r_sum / pixels
    avg_g: g_sum / pixels
    avg_b: b_sum / pixels
    avg_a: a_sum / pixels
    puts 'average color: r={avg_r} g={avg_g} b={avg_b} a={avg_a}'

    # the blob should produce non-zero color and non-zero alpha
    # transparent cutout lowers the averages but doesn't zero them
    return avg_a > 10 && (avg_r > 0 || avg_g > 0 || avg_b > 0)
