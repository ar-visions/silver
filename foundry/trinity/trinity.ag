    public scroll : vec2f


element World
    public target       : Render
    public models       : array Model
    public render_scale : f32 1.0
    public clear_color  : vec4f
    public rotate       : array Rotation
    public translate    : array Translation
    public scale        : array Scaling
    public update       : EventDispatch

    func init []
        expect ux, 'ux not set'

    func load [ w: Window ]
        if [ !target ]
            width  : int ((bounds) ? (bounds.w) : (w.width))  * render_scale
            height : int ((bounds) ? (bounds.h) : (w.height)) * render_scale
            target = Render [
                vk:             w.vk,
                w:              w,
                width:          width,
                height:         height,
                reduce:         (render_scale == 4.0) ? true : false,
                clear_color:    clear_color,
                models:         models]
            w.element_targets[id] = target
        
    func draw [ w: Window ]
        #expect update, 'update subs not set'
        load[ w ]

        width  : i32 [ bounds.w * render_scale ]
        height : i32 [ bounds.h * render_scale ]
        target.width  = width
        target.height = height
        target.wscale = 0.0

        target.update[]

        #expect update, '{id}_update sub not declared by the app'
        ev : Event[ target: a ]
        update.invoke[ ev ]

        at : translate
        ar : rotate
        as : scale

        if [ at || ar || as ]
            for [ m: Model ] in target.models
                ln0 : i32 [ (at) ? at.count : 0 ]
                ln1 : i32 [ (ar) ? ar.count : 0 ]
                ln2 : i32 [ (as) ? as.count : 0 ]
                ln  : i32 [ (ln0 > ln1 && ln0 > ln2) ? ln0 : (ln1 > ln0 && ln1 > ln2) ? ln1 : ln2 ]
                m.transforms      = new mat4f [ ln ]
                m.transform_count = ln
                for [ i: i32 0, i < ln, i += 1 ]
                    mat : mat4f.identity[]
                    s : Scaling [ (as) ? as.peek[ i ] : null ]
                    if [ s ]
                        mat = mat.scale[ s.value ]
                    r : Rotation [ (ar) ? ar.peek[ i ] : null ]
                    if [ r ]
                        v   : vec4f [ r.axis.x, r.axis.y, r.axis.z, radians[ r.degs ] ]
                        q   : quatf[ v ]
                        mat = mat.rotate[ q ]
                    t : Translation [ (at) ? at.peek[ i ] : null ]
                    if [ t ]
                        mat = mat.translate[ t.value ]
                    m.transforms[i] = mat

        if [ typeid[ a ] == typeid[ Background ] ]
            return

        w.overlay.set_texture[ (target.reduction) ? target.reduction : target.color ]
        w.overlay.draw_fill[]

World Stage
    public frost : bool

    func init []
        w : Window [ ux.w ]
        vk: w.vk
        
        load[ w ]

        if [ frost ]
            #sk_set_bs[ target.color ]
            
            w.m_reduce  = Model  [ w: w, samplers: map Texture[string] [ 'color': target.color ] ]
            w.r_reduce  = Render [ vk: vk, w: w, wscale: 1.0, models: array Model [ w.m_reduce ] ]

            w.m_reduce0 = Model  [ w: w, samplers: map Texture[string] [ 'color': w.r_reduce.color ] ]
            w.r_reduce0 = Render [ vk: vk, w: w, wscale: 0.5, models: array Model [ w.m_reduce0 ] ]

            w.m_reduce1 = Model  [ w: w, samplers: map Texture[string] [ 'color': w.r_reduce0.color ] ]
            w.r_reduce1 = Render [ vk: vk, w: w, wscale: 0.25, models: array Model [ w.m_reduce1 ] ]

            fbv : BlurV [ vk: w.vk, name: 'blur-v', reduction_scale: 4.0 ]
            w.m_blur_v  = Model  [ w: w, s: fbv, samplers: map Texture[string] [ 'color': w.r_reduce1.color ] ]
            w.r_blur_v  = Render [ vk: vk, w: w, wscale: 1.0, models: array Model [ w.m_blur_v ] ]

            fbl : Blur [ vk: w.vk, name: 'blur', reduction_scale: 4.0 ]
            w.m_blur    = Model  [ w: w, s: fbl, samplers: map Texture[string] [ 'color': w.r_blur_v.color ] ]
            w.r_blur    = Render [ vk: vk, w: w, wscale: 1.0, models: array Model [ w.m_blur ] ]

            w.m_reduce2 = Model  [ w: w, samplers: map Texture[string] [ 'color': w.r_reduce1.color ] ]
            w.r_reduce2 = Render [ vk: vk, w: w, wscale: 0.125, models: array Model [ w.m_reduce2 ] ]

            w.m_reduce3 = Model  [ w: w, samplers: map Texture[string] [ 'color': w.r_reduce2.color ] ]
            w.r_reduce3 = Render [ vk: vk, w: w, wscale: 0.0625, models: array Model [ w.m_reduce3 ] ]

            bv : BlurV [ vk: w.vk, name: 'blur-v', reduction_scale: 16.0 ]
            w.m_frost_v = Model  [ w: w, s: bv, samplers: map Texture[string] [ 'color': w.r_reduce3.color ] ]
            w.r_frost_v = Render [ vk: vk, w: w, wscale: 1.0, models: array Model [ w.m_frost_v ] ]

            bl : Blur [ vk: w.vk, name: 'blur', reduction_scale: 16.0 ]
            w.m_frost   = Model  [ w: w, s: bl, samplers: map Texture[string] [ 'color': w.r_frost_v.color ] ]
            w.r_frost   = Render [ vk: vk, w: w, wscale: 1.0, models: array Model [ w.m_frost ] ]

            w.m_view    = Model [ w: w, s: UXCompose [ vk: vk, name: 'ux' ],
                samplers: map Texture[string] [
                    'background': target.color,
                    'frost':      w.r_frost.color,
                    'blur':       w.r_blur.color,
                    'compose':    w.compose.color,
                    'colorize':   w.colorize.color,
                    'overlay':    w.overlay.color,
                    'glyph':      w.glyph.color
                ]
            ]

            w.r_view    = Render [ vk: vk, w: w, wscale: 1.0, clear_color: vec4f [ 1.0, 1.0, 1.0, 1.0 ],
                models: array Model [ w.m_view ] ]

            ux_shader : UXCompose [ w.m_view.s ]
            ux_shader.low_color  = vec4f [ 0.0, 0.1, 0.2, 1.0 ]
            ux_shader.high_color = vec4f [ 1.0, 0.8, 0.8, 1.0 ]
        el
            w.m_view = Model [ vk: vk, w: w, s: UXSimple [ vk: vk, name: 'simple' ],
                samplers: map Texture[string] [
                    'background': target.color,
                    'overlay':    w.overlay.color
                ]
            ]
            w.r_view = Render [ vk: vk, w: w, wscale: 1.0, clear_color: vec4f [ 1.0, 1.0, 1.0, 1.0 ],
                models: array Model [ w.m_view ] ]

        if [ frost ]
            w.list = array Render [
                target, w.r_reduce, w.r_reduce0, w.r_reduce1, w.r_blur_v, w.r_blur,
                w.r_reduce2, w.r_reduce3, w.r_frost_v, w.r_frost,
                w.r_view ]
            # r_view is last in list
        el
            w.list = array Render [ target, w.r_view ]
            # r_view is last in list

