class Background
    expect window: Window
    public color:  rgba
    public render: Render
    public models: array Model
    func update[]
        return

abstract live_app media_app
    context w           : Display*
    context vk          : vk_context
    intern  arg         : object
    public  width       : i32
    public  height      : i32
    intern  next_second : i64
    intern  frames      : i32

    func run [ ]
        Au.auto_free[true]

    func frame [ ] -> bool
        glfwWaitEventsTimeout[ 0.016 ]
        second : epoch_millis[] / 1000
        if [ next_second != second ]
            next_second = second
            buf : local char [ 128 ]
            sprintf[ buf, "fps: %i  samplers: %i", frames, vk.sampler_count ]
            puts buf
            frames = 0
        render*[]
        Au.auto_free[false]
        return !glfwWindowShouldClose[ w.glfw ]

    func destroy [ ]
        if [ w ]
            w.drop[]

    func render [ ]
        return

    func init [ ]
        next_second = epoch_millis[] / 1000
        if [ !Au.live_window_get[] ]
            init_res : glfwInit[]
            expect init_res, "glfw init"
            if [ !glfwVulkanSupported[] ]
                fault "glfw does not support vulkan"
                glfwTerminate[]
                return
        existing_vk : handle Au.live_vk_get[]
        if [ existing_vk ]
            vk = (existing_vk to vk_context)
        el
            vk = vk_context[]
            Au.live_vk_set[ handle[vk] ]

    func dealloc [ ]
        destroy[]


