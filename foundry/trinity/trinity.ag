class Background
    expect window: Window
    public color:  rgba
    public render: Render
    public models: array Model

    func update[]
        return

abstract live_app media_app
    context w           : Display*
    context vk          : vk_context
    intern  arg         : object
    public  width       : i32
    public  height      : i32
    # render to a terminal character grid (box-drawing borders) instead of the
    # GLFW/Vulkan window. when set, init/frame/run never touch glfw or vk_context;
    # the element tree, layout and styles run unchanged — only the paint differs.
    # default OFF: apps render to the GLFW/Vulkan window; set this true to opt into
    # the terminal renderer.
    public  console     : bool [ false ]
    intern  next_second : i64
    intern  frames      : i32

    func run [ ]
        Au.auto_free[true]

    func frame [ ] -> bool
        # console mode: no glfw event pump, no swapchain, no vk perf counters.
        # render the terminal grid each tick and keep running (Ctrl-C to exit).
        if [ console ]
            render*[]
            Au.auto_free[false]
            usleep[ 16000 ]
            return true
        # free-running loop: poll (don't block on events) so we render every iteration
        # at full speed — measures raw throughput instead of event-gated repaints.
        glfwPollEvents[]
        second : epoch_millis[] / 1000
        if [ next_second != second ]
            next_second = second
            puts 'PERF fps={frames} draw={vk.draw_us} syncs={vk.sync_calls} syncus={vk.sync_us} bindus={vk.bindres_us} rallocs={vk.render_allocs} resize={vk.resize_us} rcalls={vk.resize_calls} paints={vk.paint_calls} samplers={vk.sampler_count}'
            vk.resize_us    = 0
            vk.resize_calls = 0
            frames = 0
            vk.submit_calls = 0
            vk.sync_calls   = 0
            vk.sync_us      = 0
            vk.update_us    = 0
            vk.draw_us      = 0
            vk.paint_calls  = 0
            vk.sdf_hit      = 0
            vk.sdf_miss     = 0
            vk.geom_us      = 0
            vk.render_allocs = 0
            vk.bindres_calls = 0
            vk.bindres_us    = 0
            vk.br_schema_us  = 0
        render*[]
        Au.auto_free[false]
        return !glfwWindowShouldClose[ w.glfw ]

    func destroy [ ]
        # hot-reload: vk_context persists (held in libAu), but this module's code
        # is about to be dlclose'd. drop the cached fonts NOW, while their vtables
        # are still mapped — otherwise the next instance returns a stale CanvasFont
        # and calling its methods jumps into freed code (SIGSEGV). ensure_font
        # rebuilds the cache lazily on the new instance.
        # console mode: restore the terminal (cooked mode, mouse off, cursor on).
        if [ console && w ]
            cwin : Window [ w ]
            cwin.console_input_close[]
        if [ vk ]
            vk.font_cache = null
        if [ w ]
            w.drop[]

    func render [ ]
        return

    func init [ ]
        next_second = epoch_millis[] / 1000
        # console mode draws to the terminal — no window, no vulkan context.
        if [ console ]
            return
        if [ !Au.live_window_get[] ]
            init_res : glfwInit[]
            expect init_res, "glfw init"
            if [ !glfwVulkanSupported[] ]
                fault "glfw does not support vulkan"
                glfwTerminate[]
                return
        existing_vk : handle Au.live_vk_get[]
        if [ existing_vk ]
            vk = (existing_vk to vk_context)
            # startup never reuses the font cache: destroy[] already dropped it at
            # the reload boundary (while the old code was still mapped), so it's
            # null here — ensure_font rebuilds fresh against THIS module's code.
            vk.font_cache = null
        el
            vk = vk_context[]
            Au.live_vk_set[ handle[vk] ]

    func dealloc [ ]
        destroy[]


class CursorPos
    public x : f32
    public y : f32
    public h : f32

# a draggable layout seam — a bound coord's edge. mem/app is the app field a drag
# writes (via member_ref); axis 0 = x (l/r → horizontal drag), 1 = y (t/b → vertical);
# sign +1 for left/top anchors, -1 for right/bottom; fc = px-per-unit at that edge.
class BindSeam
    public mem  : Au_t
    public app  : Au
    public axis : i32
    public sign : f32
    public fc   : f32
    # px clamp (from the coord) + the parent extent along the axis, so the drag
    # can clamp the value: collapse floor = max/fc, full = (span - min)/fc.
    public min       : f32
    public max       : f32
    public span      : f32
    public has_range : bool
    # optional companion field `<varname>_user`: the last NON-snapped (open)
    # position. updated on open drags, left alone when the drag snaps to collapse,
    # so the app can restore the user's real size after a collapse.
    public user_mem  : Au_t


Display Window
    mutable app_object          : trinity*
    mutable cursors             : array CursorPos
    # GLFW resize cursors for seam hover/drag (created lazily, cached). cursor_kind
    # tracks the active one (0=arrow,1=horizontal,2=vertical) to skip redundant sets.
    mutable cursor_hresize      : handle
    mutable cursor_vresize      : handle
    mutable cursor_kind         : i32

    public compose              : Canvas
    public glyph                : Canvas
    public screen               : Canvas

    public background            : Background
    public background_type       : Au_t
    mutable m_reduce             : Model
    mutable r_reduce             : Render
    mutable m_reduce0            : Model
    mutable r_reduce0            : Render
    mutable m_reduce1            : Model
    mutable r_reduce1            : Render
    mutable m_reduce2            : Model
    mutable r_reduce2            : Render
    mutable m_reduce3            : Model
    mutable r_reduce3            : Render
    mutable m_blur_v             : Model
    mutable r_blur_v             : Render
    mutable m_blur               : Model
    mutable r_blur               : Render
    mutable m_frost_v            : Model
    mutable r_frost_v            : Render
    mutable m_frost              : Model
    mutable r_frost              : Render
    mutable m_view               : Model
    mutable r_view               : Render

    mutable test_element : element

    mutable is_setup             : bool
    mutable user_compose         : bool
    # console mode: fd of /dev/tty opened for direct terminal I/O. silver forwards
    # keystrokes to our stdin but not the mouse escape sequences, so we read the real
    # terminal directly to get clicks. -1 until console_input_open succeeds.
    intern  tty_in               : i32 [ -1 ]


    intern root_styles          : map Style[string]
    intern last_frame_ms        : i64
    intern start_ms             : i64
    mutable frame_factor        : f32
    intern frame_seq            : i32
    public root                 : element
    mutable capture             : element
    mutable focus               : element
    mutable hovered             : element
    mutable action_pressed      : element
    mutable context_pressed     : element
    mutable restyle             : bool
    mutable will_animate        : bool
    mutable mouse               : vec2f
    # layout-seam drag: seam_hover = bound edge under the cursor this hit-test;
    # seam_drag = the one being dragged; start_m/v = mouse axis + var at drag start
    mutable seam_hover          : BindSeam
    mutable seam_hl             : rect
    # draw the hover/drag seam band — debug-only now (seams are grabbable without it)
    public  seam_debug          : bool
    mutable seam_drag           : BindSeam
    mutable seam_start_m        : f32
    mutable seam_start_v        : f32
    mutable t_apply_args        : i64
    mutable t_apply_style       : i64
    mutable t_render            : i64
    mutable shift               : bool
    mutable alt                 : bool
    mutable time                : f64
    public st                   : Style


    # at instance birth, fill the instance's public fields from a source object
    # (its render parent, then the app) when the source declares a public of the
    # SAME name and EXACT type. union {src,rtype,type} is the field's type.
    func attempt_instance_write [ src: element, dst: element ]
        if [ !src || !dst ] return
        dt : Au_t typeid[ dst ]
        for [ m: i32 0, m < dt.members.count, m += 1 ]
            mem : Au_t dt.members.origin[m]
            if [ mem.member_type != AU_MEMBER_VAR || mem.access_type != 2 ] continue
            if [ strcmp[ mem.ident, "elements" ] == 0 ] continue
            sm : Au_t find_member[ typeid[ src ], mem.ident, AU_MEMBER_VAR, 0, true ]
            if [ sm && sm.access_type == 2 && sm.src == mem.src ]
                dst.member_set[ mem, src.member_object[ sm ] ]

    public func apply_args [ inst: element, e: element ] -> bool
        if [ typeid[ inst ] != typeid[ e ] ] return false
        changed : false
        # label is compared BY VALUE (a real change = a new file opened in an editor
        # title) and carries a side effect: drop any in-progress edit + release focus.
        # the generic object compare below is byte/identity and would see a constant
        # label like 'Find' as "changed" every frame, releasing focus and breaking
        # the find/replace inputs — so handle label here, value-wise, and skip it below.
        # treat null and '' as the same: an element that sets no label (e.g. the
        # code Editor) has empty on both sides every frame and must NOT be seen as
        # "changed" — otherwise the input-reset below zeroes its cursor each frame.
        il        : string [ inst.label ]
        el_       : string [ e.label ]
        il_empty  : bool   [ !il  || il.count  == 0 ]
        el_empty  : bool   [ !el_ || el_.count == 0 ]
        # a real change = emptiness flipped, or both non-empty with different text
        label_changed : bool [ (il_empty != el_empty) || (!il_empty && !el_empty && il != el_) ]
        if [ label_changed ]
            inst.label      = e.label
            # the label IS the bound value for a text input, so a new value drops the
            # in-progress edit buffer + releases focus. do NOT reset sel_col/anchor_col
            # here: that is the code Editor's caret, which it owns across frames and
            # which apply_args must never clobber (was zeroing the caret every frame).
            inst.edit       = ''
            release_focus[ inst ]
            changed = true
        # copy every other explicitly-set arg (af bit) from the rendered template `e`
        # to the persistent instance, walking the whole type chain (poly) so ANY
        # component arg propagates without a hardcoded list. skip `elements` (children
        # are reconciled by update_element), `label` (handled above), and `edit` (the
        # live editable buffer, managed by the framework + on_char).
        for [ ty : typeid[ inst ], ty != typeid[ Au ], ty = ty.context ]
            for [ mi: i32 0, mi < ty.members.count, mi += 1 ]
                member : Au_t ty.members.origin[mi]
                if [ member.member_type != AU_MEMBER_VAR ] continue
                if [ strcmp[ member.ident, "elements" ] == 0 ] continue
                if [ strcmp[ member.ident, "label" ] == 0 ] continue
                if [ strcmp[ member.ident, "edit" ] == 0 ] continue
                if [ inst.id == 'play' && strcmp[ member.ident, 'selected' ] == 0 ]
                    ibits : ref u64 [ inst.AF_bits[] ]
                    ebits : ref u64 [ e.AF_bits[] ]
                    #puts 'PLAY af: af_index={member.af_index} member_index={member.member_index} af_e={e.AF_get_member[member]} af_inst={inst.AF_get_member[member]} e_w0={ebits[0]} e_w1={ebits[1]} i_w0={ibits[0]} i_w1={ibits[1]}'
                if [ !e.AF_get_member[ member ] ] continue
                cur : inst.member_object[ member ]
                nv  : e.member_object[ member ]
                # a change is: presence flipped, OR both present and unequal. a false/0
                # value boxes as null, so a false→true flip is cur=null, nv=non-null —
                # the old `cur.compare[nv]` then ran compare on a null cur and missed it
                # (left manual_mode :selected styles, e.g. the play↔stop icon, stale).
                if [ (!cur) != (!nv) || ((cur && nv) && cur.compare[ nv ] != 0) ]
                    inst.member_set[ member, nv ]
                    changed = true
        return changed

    
    public func transition_or_set [ inst:element, value_holder:Au, cur:Au, member:Au_t, best:StyleEntry ]
        # transition handling
        t            : best.trans
        ct           : StyleTransition
        should_trans : false
        mem          : string [ (best.bl && best.bl.key && best.bl.key.count) ? '{best.bl.key}.{member.ident}' : member.ident ]

        if [ t ]
            if [ !inst.transitions ]
                inst.transitions = StyleTransitions [ ]
            ct = inst.transitions[ mem ]
            if [ !ct ]
                ct = t.copy[]
                ct.reference = t
                should_trans = true
                inst.transitions[ mem ] = ct
            el [ ct.invalidate ]
                ct.invalidate = false
                should_trans = true
        el [ inst.transitions ]
            inst.transitions.rm[ mem ]

        if [ ct && should_trans ]
            if [ cur            ] cur.hold[]
            if [ best.instance  ] best.instance.hold[]
            if [ ct.from ] ct.from.drop[]
            if [ ct.to   ] ct.to.drop[]
            ct.from      = (cur) ? cur.hold[] : best.instance.hold[]
            ct.dbg_val   = best.value
            ct.to        = best.instance.hold[]
            ct.type      = typeid[ best.instance ]
            ct.start     = epoch_millis[]
            ct.member    = member
            ct.invalidate = false
            ct.container  = value_holder
            if [ cur            ] cur.drop[]
            if [ best.instance  ] best.instance.drop[]
            return

        float_count : i32 [ member.src.typesize / 4 ]
        dst_ptr     : ref f32 [ value_holder.member_ref[ member ] ]
        is_f_color : bool [ strcmp[ member.ident, 'fill_color_pos' ] == 0 ]

        # binding: read source member directly from element and apply (with optional filter)
        if [ best.binding ]
            src_m : Au.find_member[ typeid[ inst ], best.binding.chars, AU_MEMBER_VAR, 0, true ]
            if [ src_m ]
                src_ptr : ref f32 [ inst.member_ref[ src_m ] ]

                if [ best.filter > 0.0 ]
                    decay : pow[ best.filter, inst.ux.frame_factor ]
                    for [ i: i32 0, i < float_count, i += 1 ]
                        dst_ptr[i] = dst_ptr[i] + (src_ptr[i] - dst_ptr[i]) * (1.0 - decay)
                el
                    for [ i: i32 0, i < float_count, i += 1 ]
                        dst_ptr[i] = src_ptr[i]

                inst.volatile = true
            return

        # filter: EMA dst in-place toward best.instance; snap from zero on first use
        if [ best.filter > 0.0 ]
            target_ptr  : ref f32 [ best.instance ]
            unset       : true
            for [ i: i32 0, i < float_count, i += 1 ]
                if [ dst_ptr[i] != 0.0 ] unset = false
            if [ unset ]
                for [ i: i32 0, i < float_count, i += 1 ]
                    dst_ptr[i] = target_ptr[i]
            el
                decay : f32 [ pow[ best.filter, inst.ux.frame_factor ] ]
                moving : false
                for [ i: i32 0, i < float_count, i += 1 ]
                    delta : f32 [ target_ptr[i] - dst_ptr[i] ]
                    if [ delta > 0.0001 || delta < -0.0001 ]
                        moving = true
                    if [ target_ptr[i] != 0.0 ]
                        dst_ptr[i] = dst_ptr[i] + delta * (1.0 - decay)
                    el
                        dst_ptr[i] = dst_ptr[i] * decay
                if [ moving ]
                    inst.volatile = true
            #inst.volatile = true
            return

        value_holder.member_set[ member, best.instance ]


    public func cache_style [ inst:element, style_avail: map StyleEntries[string], force_update:bool, home_object:Au ]
        if [ inst.maps_populated && !force_update ]
            return
 
        inst.maps_populated = true
        for [ ty : typeid[ inst ], ty != typeid[ Au ], ty = ty.context ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                member : Au_t ty.members.origin[m]
                if [ member.member_type != AU_MEMBER_VAR || strcmp[ member.ident, "elements" ] == 0 ]
                    continue
                prop    : string [ member.ident ]
                entries : style_avail [ prop ]
                for [ entry : StyleEntry ] reverse in entries
                    if [ !(entry.bl.property && entry.bl.key) ]
                        continue
                    entry.member_map = Au.find_member [ typeid[inst], entry.bl.property.chars, AU_MEMBER_VAR, 0, true ]
                    expect entry.member_map, 'member not found on {ty.ident}: {entry.bl.property}'
                    meta_type : Au_t [ entry.member_map.meta.a ]
                    v : Au inst.member_object[ entry.member_map ]
                    mtype : typeid[ v ]
                    mc : (inst.member_object[ entry.member_map ] to map Layer[string])
                    if [ mc && mc.hsize <= 0 ]
                        info : header [ mc ]
                        puts 'bad mc: inst={inst.id} member={entry.member_map.ident} hsize={mc.hsize} key={entry.bl.key}'
                    if [ !mc || mc.hsize <= 0 ]
                        mc = map Layer[string][]
                        printf["mc object for %s (%p) is %p\n", inst.id.chars, inst, mc]
                        inst.member_set[ entry.member_map, mc ]
                        mc.hold[]
                    if [ !mc.contains[entry.bl.key] ]
                        inst_type : Au_t [ (entry.bl.type_name && entry.bl.type_name.count) ? Au.find_type[entry.bl.type_name.chars, null] : null ]
                        if [ !inst_type ]
                            has_state : bool [ false ]
                            for [ q: StyleQualifier ] in entry.bl.quals
                                if [ q.state ] has_state = true
                            if [ !has_state ] inst_type = meta_type
                        if [ inst_type ]
                            n : Au.new_object[inst_type, null, null, false, __FILE__, __LINE__, __SEQUENCE__]
                            ele : (home_object to element)
                            home_type : typeid[ home_object ]
                            inst_type : typeid[ inst ]
                            n.set_context_from[ home_object ]
                            n.set_context_from[ inst ]
                            n.initialize[]
                            mc[entry.bl.key] = n
                            
                   
    # needs copies
    public func apply_style [ inst: element, style_avail: map StyleEntries[string], home_object:Au ]
        #puts 'apply_style: inst={inst.id} hovered={inst.hovered} pressed={inst.pressed}'
        inst.volatile = false
        inst.pristine = false
        inst.maps_populated = false
        if [!inst.layers]
            inst.layers = map Layer[string] []

        # create layers in the order they render
        cache_style[inst, style_avail, false, home_object]
        
        applied : map StyleEntry[string][]
        for [ ty : typeid[ inst ], ty != typeid[ Au ], ty = ty.context ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                member : Au_t ty.members.origin[m]
                if [ member.member_type != AU_MEMBER_VAR || strcmp[ member.ident, "elements" ] == 0 ]
                    continue
                prop    : string [ member.ident ]
                entries : style_avail [ prop ]
                if [ !entries ]
                    continue
                #puts 'apply_style:   {prop} entries={entries.count}'
                first : (entries[0] to StyleEntry)

                # we sometimes have to create a map for 'layers' as well as a Layer instance inside
                if [ first.bl.property && first.bl.key ]
                    # find the layers member Au_t
                    for [ best : StyleEntry ] in entries
                        score : best.bl.score[ inst, true ]
                        if [ score == 0 ]
                            continue
                        f : (best.bl.key) ? '{best.member}.{best.bl.key}' : best.member
                        if [ applied[f] ]
                            continue
                        applied[f] = best

                        if [!best.member_map]
                            cache_style[inst, style_avail, true, home_object]

                        mc : (inst.member_object[ best.member_map ] to map)
                        expect mc, "expected map container"
                        layer_inst  : mc.get[best.bl.key]
                        inst_type   : Au.__typeid[layer_inst]
                        layer_member : Au.find_member[ inst_type, best.member, AU_MEMBER_VAR, 0, true ]
                        if [ !layer_member ]
                            continue
                        expect layer_member, 'member not found on {inst_type.ident}: {best.member}'

                        if [ !best.instance ]
                            if [ (layer_member.src.traits & (1 << 11)) && typeid[best.value] != typeid[array] ]
                                best.instance = Au.new_object[ layer_member.src, null, null, false, __FILE__, __LINE__, __SEQUENCE__ ]
                                best.instance.set_context_from[ home_object ]
                                best.instance.call_construct[ best.value ]
                            el
                                best.instance = (best.value to layer_member.src)
                            best.instance.hold[]

                        cur : layer_inst.member_object[ layer_member ]
                        if [ !cur ]
                            cur = best.instance

                        transition_or_set[ inst, layer_inst, cur, layer_member, best ]

                el
                    best : st.best_match[ inst, prop, entries ]
                    if [ !best ]
                        continue

                    if [ !best.instance ]
                        info      : header [ best.value ]
                        val_type  : Au_t [ info.au ]
                        meta_type : Au_t [ member.meta.a ]
                        if [ val_type == typeid[ array ] && member.src == typeid[ array ] && meta_type ]
                            src_arr  : (best.value to array string)
                            dst_arr  : array Au [ ]
                            for [ s: string ] in src_arr
                                obj : Au.new_object[ meta_type, null, null, false, __FILE__, __LINE__, __SEQUENCE__ ]
                                obj.set_context_from[ home_object ]
                                obj.call_construct[ s ]
                                dst_arr.push[ obj ]
                            best.instance = dst_arr
                        el [ member.src == typeid[ Au_t ] ]
                            str : (best.value to string)
                            found_type : Au.find_type[ str.chars, null ]
                            if [ found_type ]
                                inst.member_set[ member, found_type ]
                            continue
                        el
                            if [ member.src.traits & (1 << 11) ]
                                best.instance = Au.new_object[ member.src, null, null, false, __FILE__, __LINE__, __SEQUENCE__ ]
                                best.instance.set_context_from[ home_object ]
                                best.instance.call_construct[ best.value ]
                            el
                                best.instance = (best.value to member.src)
                        
                        best.instance.hold[]

                    cur : inst.member_object[ member ]
                    if [ !cur ]
                        cur = best.instance

                    transition_or_set[ inst, inst, cur, member, best ]


    public func animate []
        if [ !root ]
            return

        now          : i64 [ epoch_millis[] ]
        if [ !start_ms ] start_ms = now
        time          = f64[ now - start_ms ] / 1000.0 / 10.0
        # frame-rate-independent filter rate: dt as a multiple of a 60fps frame, so
        # decay = (1-amount)^frame_factor converges at the same REAL-TIME rate no
        # matter the fps. at 60fps frame_factor=1; at 30fps=2 (one frame covers two
        # 60fps steps); at 155fps≈0.39. (was (1/60)/dt — inverse, and dt² overall.)
        # `raw` is the gap since the last PAINT. the ux is event-driven, so after an
        # idle stretch raw is huge and meaningless — using it would snap the filter
        # on the first frame of a drag. so if we haven't painted in > 100ms, just
        # treat this as one normal 60fps step (frame_factor = 1.0); otherwise use the
        # real dt so a steady animation stays frame-rate independent.
        raw : f32 [ (last_frame_ms > 0) ? f32[ now - last_frame_ms ] / 1000.0 : 0.016 ]
        frame_factor = (raw > 0.1) ? 1.0 : raw * 60.0
        #puts 'frame_factor: raw={raw}s frame_factor={frame_factor}'
        last_frame_ms = now
        frame_seq += 1
        root.animate_within [ ]

    func update_element [ parent: element, rendered: map element[string], force: bool ]
        if [!parent.elements] parent.elements = Elements[]

        # obtain instance of parent
        # if a parent reads element within another subclass it contains, then it has access.to
        home_type   : Au_t
        home_object : element

        # mark for umount
        for [ e:element, id:string ] in parent.elements
            e.flags |= 1

        # count rendered children for positional flags
        total_rendered : i32 [ 0 ]
        for [ e:element, id:string ] in rendered
            total_rendered += 1

        # iterate through rendered elements
        child_pos : i32 [ 0 ]
        for [ e:element, id:string ] in rendered
            instance  : element* parent.elements[ id ]
            changed   : bool e.restyle
            new_inst  : false
            brand_new : false
            call_init : false

            if [ instance ]
                instance.flags &= ~1
                if [ !instance.id ]
                    brand_new = true # component within element map
                el [ typeid[instance] != typeid[e] ]
                    parent.elements.rm[ id ]
                    instance = null

            if [ brand_new || !instance ]
                if [ id == "toolbar" ]
                    test2 :  2
                    test2 += 2
                    win : cast Window[ w ]
                    win.test_element = e
                
                new_inst         = true
                instance         = (instance) ? instance : e.hold[]
                instance.restyle = true
                instance.id      = id
                instance.ux      = a
                instance.parent  = parent

                if [ !parent.elements ]
                    parent.elements = map element[string] [ ]

                if [ !brand_new ]
                    parent.elements[ id ] = instance

                # auto-bind instance to 'home' if defined
                if [ !home_type ]
                    home_type   = typeid[ parent ]
                    home_object = parent
                    if [ home_type == typeid[ element ]]
                        while [ home_object ]
                            home_object = home_object.parent
                            if [ !home_object ]
                                break
                            home_type   = typeid[ home_object ]
                            if [ home_type != typeid[ element ]]
                                break
                    if [ !home_object ]
                        home_object = (parent.ux.app_object to element)
                        home_type   = typeid[ home_object ]
                
                imember : find_member[ home_type, id.chars, AU_MEMBER_VAR, 0, true ]
                if [ imember ]
                    home_object.member_set[ imember, instance ]
                 
                instance.set_context_from[ home_object ]
                # inherit public fields by name+type: render parent first, app next
                attempt_instance_write[ parent, instance ]
                attempt_instance_write[ (parent.ux.app_object to element), instance ]
                call_init = true
                changed = true
            el
                ta0 : i64 [ epoch_micros[] ]
                args_changed : bool apply_args[ instance, e ]
                a.t_apply_args += epoch_micros[] - ta0
                changed = args_changed || instance.restyle || force
                instance.restyle = false
                if [ instance.id == 'play' ]
                    op2  : Option instance
                    et2  : Option e
                    isel : bool [ (op2) ? op2.selected : false ]
                    tsel : bool [ (et2) ? et2.selected : false ]
                    #puts 'PLAY upd: args_changed={args_changed} force={force} changed={changed} inst.selected={isel} tmpl.selected={tsel}'

            new_first  : bool [ child_pos == 0 ]
            new_last   : bool [ child_pos == total_rendered - 1 ]
            new_middle : bool [ child_pos > 0 && child_pos < total_rendered - 1 ]
            if [ instance.first != new_first || instance.last != new_last || instance.middle != new_middle ]
                instance.first  = new_first
                instance.last   = new_last
                instance.middle = new_middle
                changed = true
            instance.odd  = (child_pos % 2 == 0)
            instance.even = (child_pos % 2 == 1)
            child_pos += 1

            if [ changed ]
                e.restyle = false
                avail  : st.compute[ instance ]
                ts0 : i64 [ epoch_micros[] ]
                apply_style[ instance, avail, home_object ]
                a.t_apply_style += epoch_micros[] - ts0

                # init finally called after context and style is applied
                # our holds are too many for properties applied in style, though.
                if [ call_init ]
                    # console mode has no vk context; elements still init + lay out.
                    if [ !console ]
                        expect instance.vk, "no vk context set for new instance"
                    instance.initialize[]
                    instance.hold_members[]
                    instance.restyle = true

            inst    : typeid[ instance ]
            tr0 : i64 [ epoch_micros[] ]
            irender : instance.render[]
            a.t_render += epoch_micros[] - tr0
            if [ !irender ] irender = e.elements
            if [ !irender ] irender = instance.elements
            if [ irender ] update_element[ instance, irender, force ]

        # perform umount on elements not updated in render
        retry : true
        while [ retry ]
            retry = false
            for [ e:element, id:string ] in parent.elements
                if [ e.flags & 1 ]
                    e.flags  = 0
                    retry    = true
                    e.parent = null
                    e.drop_members[]
                    parent.elements.rm[ id ]
                    break

    public func is_animating [] -> bool
        if [ !root ] return true
        if [ capture ] return true
        return root.is_animating[]

    public func update_all [ render: Elements ]
        if [ !root ]
            root    = element [ id: string[ 'root' ], ux:a ]
            root_styles = st.compute[ root ]
            restyle = true
        
        force_restyle : (!restyle) ? st.check_reload[] : false
        if [ force_restyle ]
            root_styles = st.compute[ root ]
            restyle     = true

        if [ force_restyle ]
            root.invalidate_transitions[ ]
            apply_style[ root, root_styles, null ]
            root.remove_invalid_transitions[ ]

        t_apply_args  = 0
        t_apply_style = 0
        t_render      = 0
        t0 : i64 [ epoch_micros[] ]
        update_element[ root, render, restyle ]
        t1 : i64 [ epoch_micros[] ]
        dt : i64 [ t1 - t0 ]
        #if [ dt > 100 ] puts 'update:{dt}us  args:{t_apply_args}us  style:{t_apply_style}us  render:{t_render}us'
        restyle = false

    public func set_capture [ e: element ]
        if [ capture != e ]
            if [ capture ]
                capture.captured = false
                capture.restyle  = true
            if [ e && !e.ghost ]
                capture = e
                capture.captured = true
                capture.restyle  = true

    public func release_capture [ e: element ]
        if [ capture && capture == e ]
            capture = null

    public func set_focus [ e: element ]
        if [ focus != e ]
            if [ focus ]
                focus.focused = false
                focus.restyle = true
            if [ e && !e.ghost ]
                focus = e
                focus.focused = true
                focus.restyle = true
                focus.pristine = false

    public func release_focus [ e: element ]
        if [ focus && focus == e ]
            focus.focused = false
            focus.restyle = true
            focus = null

    # build a seam descriptor for a child's bound coord edge (app field via member_ref)
    func make_seam [ bc: BindCoord, c: element, axis: i32, sign: f32 ] -> BindSeam
        if [ !bc || !c.ux || !c.ux.app_object ] return null
        ap : Au c.ux.app_object
        m  : find_member[ typeid[ ap ], bc.varname.chars, AU_MEMBER_VAR, 0, true ]
        if [ !m ] return null
        # optional `<varname>_user` companion that records the last open position.
        un : bc.varname + '_user'
        um : find_member[ typeid[ ap ], un.chars, AU_MEMBER_VAR, 0, true ]
        # parent extent along the drag axis (px), for clamping the seam travel.
        sp : f32 [ (c.parent && c.parent.bounds) ?
            ( (axis == 1) ? c.parent.bounds.h : c.parent.bounds.w ) :
            ( (axis == 1) ? height : width ) ]
        return BindSeam [ mem: m, app: ap, axis: axis, sign: sign, fc: c.fc,
            min: bc.min, max: bc.max, span: sp, has_range: bc.has_range, user_mem: um ]

    # show the OS resize cursor over a seam: kind 0=arrow, 1=horizontal (x-axis
    # seam), 2=vertical (y-axis seam). standard cursors are created on first use
    # and cached; cursor_kind skips redundant glfwSetCursor calls.
    func seam_cursor [ kind: i32 ]
        if [ kind == cursor_kind ] return
        g : handle [ Au.live_window_get[] ]
        if [ !g ] return
        cursor_kind = kind
        if [ kind == 1 ]
            if [ !cursor_hresize ] cursor_hresize = glfwCreateStandardCursor[ GLFW_HRESIZE_CURSOR ]
            glfwSetCursor[ g, cursor_hresize ]
        el [ kind == 2 ]
            if [ !cursor_vresize ] cursor_vresize = glfwCreateStandardCursor[ GLFW_VRESIZE_CURSOR ]
            glfwSetCursor[ g, cursor_vresize ]
        el
            glfwSetCursor[ g, null ]

    # is the mouse (in this child's coordinate space) on a bound edge's 6px inset
    # slider band? bands run from the edge INTO the control (the embedded-on-edges
    # model — no centered origin). sets seam_hover when hit.
    func seam_check [ c: element, mx: f32, my: f32 ]
        if [ !c.area ] return
        if [ !(c.area.bind_l || c.area.bind_t || c.area.bind_r || c.area.bind_b) ] return
        b : rect c.bounds
        # a collapsed / sub-band-width child can't host the 6px grab band — skip it, else
        # its phantom seam sits at the edge over the scrollbar, shows the <-> resize
        # cursor, and steals the press across that strip (can't drag a 0-width panel).
        if [ b.w < 6.0 || b.h < 6.0 ] return
        # band is the slot's element edge; drag sign follows the coord's ANCHOR
        # (bottom/right-anchored offsets shrink as the mouse moves toward them).
        if      [ c.area.bind_t && mx >= b.x && mx <= b.x + b.w && my >= b.y && my <= b.y + 6.0 ]
            seam_hover = make_seam[ c.area.bind_t, c, 1, (c.area.t.y_type == YAlign.bottom) ? -1.0 : 1.0 ]
            seam_hl    = rect [ x: b.x, y: b.y, w: b.w, h: 6.0 ]
        el [ c.area.bind_b && mx >= b.x && mx <= b.x + b.w && my >= b.y + b.h - 6.0 && my <= b.y + b.h ]
            seam_hover = make_seam[ c.area.bind_b, c, 1, (c.area.b.y_type == YAlign.bottom) ? -1.0 : 1.0 ]
            seam_hl    = rect [ x: b.x, y: b.y + b.h - 6.0, w: b.w, h: 6.0 ]
        el [ c.area.bind_l && my >= b.y && my <= b.y + b.h && mx >= b.x && mx <= b.x + 6.0 ]
            seam_hover = make_seam[ c.area.bind_l, c, 0, (c.area.l.x_type == XAlign.right) ? -1.0 : 1.0 ]
            seam_hl    = rect [ x: b.x, y: b.y, w: 6.0, h: b.h ]
        el [ c.area.bind_r && my >= b.y && my <= b.y + b.h && mx >= b.x + b.w - 6.0 && mx <= b.x + b.w ]
            # a visible vertical scrollbar lives on this right edge and its grab zone owns
            # the strip — so the seam is off-limits on this side (drag it from the
            # neighbor's edge instead). otherwise the <-> cursor steals the scrollbar.
            has_vscroll : bool [ c.content_h > 0.0 && b.h < c.content_h && c.layers && c.layers['scrollbar'] != null ]
            if [ !has_vscroll ]
                seam_hover = make_seam[ c.area.bind_r, c, 0, (c.area.r.x_type == XAlign.right) ? -1.0 : 1.0 ]
                seam_hl    = rect [ x: b.x + b.w - 6.0, y: b.y, w: 6.0, h: b.h ]

    public func find_target [ e: element, ev: Event, must: element ] -> element
        # fully-transparent elements are hidden — ignore them (and their
        # children) in event hit-testing so they don't capture clicks. an element
        # with no bounds yet (not laid out this frame) can't be hit either.
        if [ !e || !e.bounds || e.disable || e.ghost || e.transparency >= 1.0 ]
            return null
        b : rect  [ e.bounds ]
        x : f32   [ ev.mouse.pos.x ]
        y : f32   [ ev.mouse.pos.y ]
        lx : f32  [ x - b.x ]
        ly : f32  [ y - b.y ]

        if [ !must && (lx < 0.0 || ly < 0.0 || lx >= b.w || ly >= b.h) ]
            return null

        # update cursor on every element in the traversal path — cursor is
        # always live on all controls, normalized to element-local [0..1].
        bw : f32 [ (b.w > 0.0) ? b.w : 1.0 ]
        bh : f32 [ (b.h > 0.0) ? b.h : 1.0 ]
        e.cursor = vec2f [ x: lx / bw, y: ly / bh ]

        fx : f32 [ lx + e.scroll.x ]
        fy : f32 [ ly + e.scroll.y ]
        ev.mouse.pos.x = fx
        ev.mouse.pos.y = fy

        # seam detection: a child's bound edge is a draggable slider. mouse and
        # child.bounds are both in THIS element's local space here, so the inset
        # band test is in the right relative coordinate space.
        for [ sc: element, scid: string ] in e.elements
            seam_check[ sc, ev.mouse.pos.x, ev.mouse.pos.y ]

        # hit-test in REVERSE of paint order: children are painted first→last
        # (later draws on top), so the topmost-drawn sibling must be tested
        # first. iterate reverse; topmost-flagged children still come before the
        # rest. this is why a later-declared sibling (e.g. the filter) wins its
        # own click without needing a per-element topmost.
        # a no_scroll child is fixed (not in this element's scrolled content), so it's
        # tested in UNSCROLLED local space (lx/ly) — otherwise a scrolled parent (e.g.
        # the editor) folds its content scroll in and the child's hit area drifts.
        for [ child: element, id: string ] reverse in e.elements
            if [ !child.topmost ] continue
            ev.mouse.pos.x = (child.no_scroll) ? lx : fx
            ev.mouse.pos.y = (child.no_scroll) ? ly : fy
            hit : find_target[ child, ev, must ]
            if [ hit ]
                return hit
        for [ child: element, id: string ] reverse in e.elements
            if [ child.topmost ] continue
            ev.mouse.pos.x = (child.no_scroll) ? lx : fx
            ev.mouse.pos.y = (child.no_scroll) ? ly : fy
            hit : find_target[ child, ev, must ]
            if [ hit ]
                return hit

        ev.mouse.pos.x = fx
        ev.mouse.pos.y = fy
        r : element [ ( !must || must == e ) ? e : null ]
        if [ !r ]
            ev.mouse.pos.x = x
            ev.mouse.pos.y = y
        return r

    public func text_event [ ev: Event ]
        ev.target = focus
        if [ focus && focus.on_char*[ ev ] ] return
        if [ app_object && app_object.on_char*[ ev ] ] return
        if [ focus && ev.key.text && ev.key.text.count > 0 ]
            for [ l: Layer, k: string ] in focus.layers
                if [ l.editable ]
                    l.on_char[ ev ]
                    break

    public func key_event [ ev: Event ]
        ev.target = focus
        if [ focus && focus.on_key*[ ev ] ] return
        if [ app_object && app_object.on_key*[ ev ] ] return
        if [ focus ]
            for [ l: Layer, k: string ] in focus.layers
                if [ l.editable ]
                    l.on_key[ ev ]
                    break

    # recursive bubble: from deepest element up through parents, each gets
    # a chance to consume. stops on first `true` return. after the element
    # chain, the app sees it; finally window's default handler runs (focus
    # transfer, capture, pressed/hovered bookkeeping) regardless of consume.
    public func move_event [ ev: Event ]
        # active seam drag: write the app var from the mouse delta (px / fc → units,
        # signed by the anchor). next layout reflows; skip normal hover/move.
        if [ seam_drag ]
            seam_cursor[ (seam_drag.axis == 0) ? 1 : 2 ]
            cur : f32 [ (seam_drag.axis == 0) ? ev.mouse.pos.x : ev.mouse.pos.y ]
            sc  : f32 [ (seam_drag.fc > 0.0) ? seam_drag.fc : 1.0 ]
            dp  : ref f32 [ seam_drag.app.member_ref[ seam_drag.mem ] ]
            v   : f32 [ seam_start_v + (cur - seam_start_m) / sc * seam_drag.sign ]
            # snap travel to the coord's px range: far-side floor (collapse) =
            # max/fc, near-side limit (full) = (span - min)/fc. magnetic — drag
            # within (or past) the snap radius of an end and it jumps to that
            # detent, so the bottom collapses (editor appears higher) and the
            # top fills, instead of overshooting.
            if [ seam_drag.has_range ]
                lo   : f32 [ seam_drag.max / sc ]
                hi   : f32 [ (seam_drag.span - seam_drag.min) / sc ]
                snap : f32 [ 1.5 ]
                if [ v < lo + snap ] v = lo
                if [ hi > lo && v > hi - snap ] v = hi
            dp[0] = v
            # NOTE: user_mem (the restore position) is recorded on release, NOT
            # per-move — otherwise dragging toward a collapse leaves it at the last
            # near-snap value instead of the user's real open size.
            # will_animate (NOT restyle): bind_value eases the active position and
            # draw_element repaints the moved controls (pristine=false) each frame.
            # restyle here would re-run the whole stylesheet per mouse event (the
            # 155→20fps cap + the void banding from incomplete per-event repaints).
            will_animate = true
            return
        seam_hover = null
        seam_hl    = rect[]
        orig_pos : vec2f [ ev.mouse.pos ]
        f : find_target[ root, ev, null ]
        # resize cursor while hovering a seam band (find_target set seam_hover)
        seam_cursor[ (seam_hover) ? ((seam_hover.axis == 0) ? 1 : 2) : 0 ]
        # find_target folded the leaf-local mouse pos into ev.mouse.pos; keep it for the
        # move bubble (which unwinds it per level like press_event). re-fold to the
        # capture target when one is held.
        m : element [ f ]
        if [ capture ]
            ev.mouse.pos = orig_pos
            m = find_target[ root, ev, capture ]
        move_pos : vec2f [ ev.mouse.pos ]
        # hover / leave bubble runs in screen space, as before
        ev.mouse.pos = orig_pos
        # hover / leave bubble — flip state bools and set restyle; the next
        # update_element pass picks up restyle and re-applies CSS.
        if [ hovered != f ]
            #puts 'hover: changed (prev={(hovered) ? hovered.id : null}, new={(f) ? f.id : null})'
            prev : element [ hovered ]
            if [ prev ]
                if [ prev inherits Button ]
                    prev = prev
                prev.hovered = false
                prev.restyle = true
                restyle = true
                
                leave_consumed : bool [ false ]
                for [ e: element* prev, e && !leave_consumed, e = e.parent ]
                    ev.target = e
                    if [ e.on_leave*[ ev ] ] leave_consumed = true
                if [ !leave_consumed && app_object ]
                    ev.target = prev
                    app_object.on_leave*[ ev ]
            hovered = f
            if [ f ]
                f.hovered = true
                f.restyle = true
                restyle = true
                hover_consumed : bool [ false ]
                for [ e: element* f, e && !hover_consumed, e = e.parent ]
                    ev.target = e
                    if [ e.on_hover*[ ev ] ] hover_consumed = true
                if [ !hover_consumed && app_object ]
                    ev.target = f
                    app_object.on_hover*[ ev ]
        # move bubble — element-local coords unwound per level (mirrors press_event),
        # so each on_move sees its own folded coords instead of raw screen space (which
        # left every on_move off by the element's offset once it moved away from 0,0).
        ev.mouse.pos = move_pos
        if [ m ]
            move_consumed : bool [ false ]
            for [ e: element* m, e && !move_consumed, e = e.parent ]
                ev.target = e
                e.on_move*[ ev ]
                ev.mouse.pos.x += e.bounds.x - e.scroll.x
                ev.mouse.pos.y += e.bounds.y - e.scroll.y
            if [ !ev.no_propagation && app_object ]
                ev.target = m
                app_object.on_move*[ ev ]
        # restore the leaf/capture-folded pos for the trailing handlers below
        ev.mouse.pos = move_pos
        # scrollbar proximity: while the cursor is within a scrollbar's widen zone,
        # request a frame this move so the bar can track + widen (a layer can't
        # repaint without a frame). gated to the zone so we don't relayout elsewhere;
        # the zone's outer edge is already thin, so leaving it needs no extra frame.
        if [ f && f.layers ]
            sbl : ScrollLayer (f.layers['scrollbar'] to ScrollLayer)
            if [ sbl && sbl.scroll_max > 0.0 ]
                fr : f32 [ (1.0 - f.cursor.x) * f.bounds.w ]
                # generous, bar-independent approach distance so the bar responds well
                # before you're on it. set pristine=false too: will_animate alone gives
                # a frame, but the element stays cached so its scrollbar layer isn't
                # repainted — the dirty flag forces the layers (incl. the bar) to redraw.
                if [ fr < 90.0 ]
                    f.pristine = false
                    will_animate = true
        if [ focus && focus.text_dragging ]
            for [ l: Layer, k: string ] in focus.layers
                if [ l.editable ]
                    l.on_move[ ev ]
                    break

    public func wheel_event [ ev: Event ]
        # wheel follows the mouse like every OS: the element UNDER the cursor gets
        # it (then bubbles to parents), regardless of focus. capture still wins
        # during an active drag.
        target_el : element [ (capture) ? capture : find_target[ root, ev, null ] ]
        consumed_w : bool [ false ]
        for [ e: element* target_el, e && !consumed_w, e = e.parent ]
            ev.target = e
            e.on_wheel*[ ev ]
        if [ !ev.no_propagation && app_object ]
            ev.target = target_el
            app_object.on_wheel*[ ev ]
        # window default: scroll focused/target element (no-op hook for now)

    public func press_event [ ev: Event ]
        release_capture[ capture ]
        world_m : vec2f [ ev.mouse.pos ]   # world coords before find_target mangles it
        seam_hover = null
        seam_hl    = rect[]
        f : find_target[ root, ev, null ]
        # a bound seam under the cursor wins the press: start a drag instead of
        # pressing an element. the seam writes its app var as the mouse moves.
        if [ seam_hover ]
            seam_drag    = seam_hover
            seam_start_m = (seam_hover.axis == 0) ? world_m.x : world_m.y
            sp : ref f32 [ seam_hover.app.member_ref[ seam_hover.mem ] ]
            seam_start_v = sp[0]
            return
        element_pos : vec2f [ ev.mouse.pos ]
        # element bubble. element* gives poly dispatch so subclasses
        # (Button, CameraView, ...) see their own on_press override.
        consumed_p : bool [ false ]
        for [ e: element* f, e, e = e.parent ]
            cl : typeid[e]
            ev.target = e
            e.on_press*[ ev ]
            ev.mouse.pos.x += e.bounds.x - e.scroll.x
            ev.mouse.pos.y += e.bounds.y - e.scroll.y
            if [ ev.no_propagation ]
                break

        au : typeid[ f ]
        # app
        if [ !ev.no_propagation && app_object ]
            ev.target = f
            app_object.on_press*[ ev ]
        # window defaults: focus transfer on left button (only focusable
        # elements get focus — buttons, text controls, etc. opt in), then
        # capture, then pressed/hovered state bookkeeping.
        edit_l : Layer [ null ]
        if [ f ]
            for [ l: Layer, k: string ] in f.layers
                if [ l.editable ]
                    edit_l = l
                    break
        if [ ev.mouse.button == 0 && f && (f.focusable || edit_l) && !ev.no_default ]
            set_focus[ f ]
        if [ edit_l && ev.mouse.button == 0 ]
            ev.mouse.pos = element_pos
            edit_l.on_press[ ev ]
        if [ !capture ]
            set_capture[ f ]
        if [ ev.mouse.button == 0 ]
            if [ action_pressed ]
                action_pressed.restyle = true
                action_pressed.pressed = false
            if [ f ]
                f.restyle = true
                f.pressed = true
                restyle = true
            
            action_pressed = f
        el [ ev.mouse.button == 1 ]
            context_pressed = f

    public func release_event [ ev: Event ]
        # end an active seam drag; don't dispatch a release to elements
        if [ seam_drag ]
            # record the settled OPEN position as the restore point — but skip a
            # collapse snap (value at the floor), so a later restore returns to the
            # real size, not the near-snap value the drag ended on.
            if [ seam_drag.user_mem && seam_drag.fc > 0.0 ]
                dp    : ref f32 [ seam_drag.app.member_ref[ seam_drag.mem ] ]
                lo    : f32 [ seam_drag.max / seam_drag.fc ]
                if [ dp[0] > lo + 0.5 ]
                    up : ref f32 [ seam_drag.app.member_ref[ seam_drag.user_mem ] ]
                    up[0] = dp[0]
            seam_drag = null
            return
        f : find_target[ root, ev, capture ]
        consumed_r : bool [ false ]
        for [ e: element* f, e && !consumed_r, e = e.parent ]
            ev.target = e
            if [ e.on_release*[ ev ] ] consumed_r = true
        if [ !consumed_r && app_object ]
            ev.target = f
            app_object.on_release*[ ev ]
        if [ ev.mouse.button == 0 ]
            if [ action_pressed ]
                action_pressed.restyle = true
                action_pressed.pressed = false
            if [ f ]
                f.restyle = true
                f.pressed = false
                restyle = true
            
            if [ f && action_pressed == f && f.hovered ]
                for [ e: element* f, e, e = e.parent ]
                    ev.target = e
                    e.on_click*[ ev ]
                    if [ ev.no_propagation ]
                        break
                if [ !ev.no_propagation && app_object ]
                    ev.target = f
                    app_object.on_click*[ ev ]
            action_pressed  = null
            context_pressed = null
        el [ ev.mouse.button == 1 ]
            action_pressed  = null
            context_pressed = null
        if [ !action_pressed && !context_pressed ]
            release_capture[ capture ]
        if [ focus && focus.text_dragging ]
            for [ l: Layer, k: string ] in focus.layers
                if [ l.editable ]
                    l.on_release[ ev ]
                    break
    
    func update_background[ type:Au_t ]
        if [ !background || type != background_type ]
            if [ background ]
                drop background
            
            background_type = type
            if [ background_type ]
                args : map Au[string] [ "window": a ]
                background = Au.construct_with[ background_type, args, null ]
                if [ !background.color ]
                    background.color = rgba[ r:0.022, g:0.088, b:0.122, a:1.0 ]
                background.render = Render [ vk: a.vk, w: a, wscale: 1.0,
                    #clear_color: vec4f [ 0.022, 0.088, 0.188, 1.0 ],
                    clear_color: vec4f [
                        background.color.r,
                        background.color.g,
                        background.color.b, 1.0 ],
                    models: background.models ]
            el
                background = null

            expect (!background || background.render),
                "no render object found on background"

        if [ background ]
            background.update*[]
    
    func update [ ]
        # determine the background up front so the frosted-compositor chain below is built
        # only when there's a real (non-solid) background. solid-color app → background null.
        if [ !background && background_type ]
            update_background[ background_type ]

        # glyph (text atlas) and screen are always needed; compose only feeds the frosted
        # compositor, so it's allocated only when there's a background to frost.
        glyph    = (glyph    || Canvas [ w:a, vk: vk, format: Pixel.u8,    :width, :height ]).resize[ width, height ]
        screen   = (screen   || Canvas [ w:a, vk: vk, format: Pixel.rgba8, load_existing: true, :width, :height ]).resize[ width, height ]
        glyph   .update[]
        screen  .update[]
        glyph   .clear[ string[ "#000" ] ]
        screen  .clear[ string[ "#000" ] ]

        if [ background ]
            compose = (compose || Canvas [ w:a, vk: vk, format: Pixel.rgba8, load_existing: true, :width, :height ]).resize[ width, height ]
            compose.update[]
            compose.clear[ string[ "#888" ] ]

        if [ !is_setup ]
            is_setup = true
            ctx: vk_context[ a.vk ]

            # frosted-background compositor: built ONLY when there's a real (non-solid)
            # background to frost. a solid-color app has background == null and skips this
            # whole chain — no compose, reduction pyramid, blur/frost, or m_view/r_view —
            # so it costs nothing and elements draw straight to screen over the clear color.
            if [ background ]
                background.render.update[]

                m_reduce  = Model  [ w: a, samplers: map Texture[string] [ 'color': background.render.color ] ]
                r_reduce  = Render [ vk: ctx, w: a, wscale: 1.0, models: array Model [ m_reduce ] ]

                m_reduce0 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce.color ] ]
                r_reduce0 = Render [ vk: ctx, w: a, wscale: 0.5, models: array Model [ m_reduce0 ] ]

                m_reduce1 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce0.color ] ]
                r_reduce1 = Render [ vk: ctx, w: a, wscale: 0.25, models: array Model [ m_reduce1 ] ]

                fbv : BlurV [ vk: ctx, name: 'blur-v', reduction_scale: 4.0 ]
                m_blur_v  = Model  [ w: a, s: fbv, samplers: map Texture[string] [ 'color': r_reduce1.color ] ]
                r_blur_v  = Render [ vk: ctx, w: a, wscale: 1.0, models: array Model [ m_blur_v ] ]

                fbl : Blur [ vk: ctx, name: 'blur', reduction_scale: 4.0 ]
                m_blur    = Model  [ w: a, s: fbl, samplers: map Texture[string] [ 'color': r_blur_v.color ] ]
                r_blur    = Render [ vk: ctx, w: a, wscale: 1.0, models: array Model [ m_blur ] ]

                m_reduce2 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce1.color ] ]
                r_reduce2 = Render [ vk: ctx, w: a, wscale: 0.125, models: array Model [ m_reduce2 ] ]

                m_reduce3 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce2.color ] ]
                r_reduce3 = Render [ vk: ctx, w: a, wscale: 0.0625, models: array Model [ m_reduce3 ] ]

                bv : BlurV [ vk: ctx, name: 'blur-v', reduction_scale: 16.0 ]
                m_frost_v = Model  [ w: a,   s: bv, samplers: map Texture[string] [ 'color': r_reduce3.color ] ]
                r_frost_v = Render [ vk: ctx, w: a, wscale: 1.0, models: array Model [ m_frost_v ] ]

                bl : Blur [ vk: ctx, name: 'blur', reduction_scale: 16.0 ]
                m_frost   = Model  [ w: a,   s: bl, samplers: map Texture[string] [ 'color': r_frost_v.color ] ]
                r_frost   = Render [ vk: ctx, w: a, wscale: 1.0, models: array Model [ m_frost ] ]

                m_view    = Model [ w: w, s: UXBackground [ vk: ctx, name: 'ux' ],
                    samplers: map Texture[string] [
                        'background':     background.render.color,
                        'frost':          r_frost.color,
                        'blur':           r_blur.color,
                        'compose':        compose.color
                    ]
                ]

                r_view    = Render [ vk: ctx, w: a,
                    color: screen.color,
                    wscale: 1.0, clear_color: vec4f [ 1.0, 1.0, 1.0, 1.0 ],
                    models: array Model [ m_view ] ]

                ux_shader : UXBackground [ m_view.s ]
                ux_shader.low_color  = vec4f [ 0.0, 0.1, 0.2, 1.0 ]
                ux_shader.high_color = vec4f [ 1.0, 0.8, 0.8, 1.0 ]

                list = array Render [
                    background.render, r_reduce, r_reduce0, r_reduce1, r_blur_v, r_blur,
                    r_reduce2, r_reduce3, r_frost_v, r_frost,
                    r_view ]
                # throttle the entire background chain (all but r_view); r_view composites
                # fresh UI over a cached background frost so it must draw every frame
                for [ i: i32 0, i < list.count - 1, i += 1 ]
                    bg : Render list[i]
                    bg.draw_interval = 16
        el
            if [ list ]
                for [ r: Render ] in list
                    r.update[]
                for [ r: Render ] in list
                    if [ r.models ]
                        for [ m: Model ] in r.models
                            m.rebind_model[]

    # borderless fullscreen toggle — no video mode change, just sizes the
    # window to fit the monitor and removes decorations. restores on exit.
    func set_fullscreen [ on: bool ]
        if [ on == fs_active ]
            return
        if [ on ]
            # remember windowed geometry
            sx : i32
            sy : i32
            sw : i32
            sh : i32
            glfwGetWindowPos [ glfw, ref sx, ref sy ]
            glfwGetWindowSize[ glfw, ref sw, ref sh ]
            fs_saved_x = sx
            fs_saved_y = sy
            fs_saved_w = sw
            fs_saved_h = sh
            mon  : glfwGetPrimaryMonitor[]
            mode : ref GLFWvidmode [ glfwGetVideoMode[ mon ] ]
            # real fullscreen: GLFW sets _NET_WM_STATE_FULLSCREEN so the
            # taskbar is hidden. passing the native refresh rate avoids a
            # video-mode change.
            glfwSetWindowMonitor[ glfw, mon, 0, 0,
                mode.width, mode.height, mode.refreshRate ]
        el
            glfwSetWindowMonitor[ glfw, null, fs_saved_x, fs_saved_y,
                fs_saved_w, fs_saved_h, 0 ]
        fs_active = on

    public func resize [ w: i32, h: i32 ] -> Window
        resizing = true
        if [ vk && vk.device ]
            vkDeviceWaitIdle[ vk.device ]
        super.resize[ w, h ]
        update[]
        resizing = false
        return a

    mutable blur_anim : f32


    func on_compose []
        if [ !compose ] return
        if [ resizing ] return
        # per-frame state update — runs every frame regardless of the compose pass.
        update_all      [ app_object.on_render*[ a ] ]
        animate         [ ]
        # advance every seam's eased active ONCE here, before the layout pass reads it.
        tick_binds      [ root ]
        # UI bounds + paint now live entirely in on_screen (layout_element then
        # draw_element); the compose canvas is no longer part of that path. kept below
        # for future 3D scene compositing — disabled for now via the early return.
        if [ true ] return
        compose.save    [ ]
        compose.clear   [ '#00a' ]
        draw_element    [ root, CanvasType.compose, null ]
        compose.paint   [ ]
        compose.sync_fence[ ]
        compose.restore [ ]

    func on_screen []
        if [ !screen ] return
        if [ resizing ] return
        # while a seam/split is being dragged, every canvas drains each paint (no batched
        # ring) so the per-frame composites can't desync their per-slot UBO/UV. set from the
        # live drag state each frame so it always clears the moment the drag ends.
        vk.sync_paints = bool[ seam_drag ]
        screen.save[]

        app_object.on_canvas*[ screen ]

        # compute the whole tree's bounds first, then paint — so every element
        # (and its cv.translate / cache size) reads THIS frame's bounds, not last
        # frame's. fc comes from the screen canvas (the paint target).
        layout_element[ root, null, screen ]

        draw_element[ root, CanvasType.screen, null ]

        # highlight the hovered/dragged layout seam band — debug-only overlay
        if [ seam_debug && seam_hl && seam_hl.w > 0.0 && seam_hl.h > 0.0 ]
            screen.fill_color[ '#ffcc00cc' ]
            screen.rect_to[ seam_hl.x, seam_hl.y, seam_hl.w, seam_hl.h ]
            screen.paint[]

        ##
        screen.fill_color[ '#f00' ]
        screen.rect_to[ 64.0, 64.0, 240.0, 120.0 ]
        screen.fill_color[ "#fff" ]
        screen.font_size [ 32 ]
        screen.draw_text[
            "Aura",
            rect [ x: 128.0 + 128.0 + 24.0 + 8.0 - 0.5, y: 64.0 + 32.0 - 32.0 - 0.5, w: 64.0, h: 32.0 ],
            vec2f [ 0.5, 0.5 ],
            vec2f [ 0.0, 0.0 ],
            false ]
        ##
        screen.paint[]
        screen.flush_text[]
        screen.sync_fence[]
        screen.restore[]

    # ---- console (terminal) rendering --------------------------------------
    # parallel paint path: no Canvas / vk. the element tree, styles and layout
    # run exactly as for the vulkan path, but each element is stamped as a
    # box-drawing rectangle into a character grid (1 unit = 1 cell) and the grid
    # is flushed to the terminal in one write. the border consumes 1 cell on
    # every side, so children lay out inside the parent's inner (bounds-2) area.

    # light box-drawing chars as edge bitmasks (U=1 D=2 L=4 R=8) and back, so two
    # overlapping borders merge into the right junction (│+│=│, ┐+┌=┬, ┘+└=┴, etc.)
    # rather than one clobbering the other.
    func box_bits [ cp: i32 ] -> i32
        if [ cp == 0x2500 ] return 12
        if [ cp == 0x2502 ] return 3
        if [ cp == 0x250C ] return 10
        if [ cp == 0x2510 ] return 6
        if [ cp == 0x2514 ] return 9
        if [ cp == 0x2518 ] return 5
        if [ cp == 0x256D ] return 10
        if [ cp == 0x256E ] return 6
        if [ cp == 0x2570 ] return 9
        if [ cp == 0x256F ] return 5
        if [ cp == 0x251C ] return 11
        if [ cp == 0x2524 ] return 7
        if [ cp == 0x252C ] return 14
        if [ cp == 0x2534 ] return 13
        if [ cp == 0x253C ] return 15
        return 0

    func bits_box [ b: i32 ] -> i32
        if [ b == 12 ] return 0x2500
        if [ b == 3  ] return 0x2502
        if [ b == 10 ] return 0x256D
        if [ b == 6  ] return 0x256E
        if [ b == 9  ] return 0x2570
        if [ b == 5  ] return 0x256F
        if [ b == 11 ] return 0x251C
        if [ b == 7  ] return 0x2524
        if [ b == 14 ] return 0x252C
        if [ b == 13 ] return 0x2534
        if [ b == 15 ] return 0x253C
        return 0

    # write one codepoint (+ color slot) into the grid (bounds-checked). when both the
    # existing and incoming chars are box-drawing, write their merged junction so
    # adjacent/overlapping frames share a single line instead of doubling.
    func cell_set [ grid: ref i32, colg: ref i32, cols: i32, rows: i32, x: i32, y: i32, cp: i32, color: i32 ]
        if [ x < 0 || y < 0 || x >= cols || y >= rows ] return
        idx : i32 [ y * cols + x ]
        out : i32 [ cp ]
        ob  : i32 [ box_bits[ grid[ idx ] ] ]
        nb  : i32 [ box_bits[ cp ] ]
        if [ ob != 0 && nb != 0 ]
            merged : i32 [ bits_box[ ob | nb ] ]
            if [ merged ] out = merged
        grid[ idx ] = out
        colg[ idx ] = color

    # search the whole element tree (from any node down) for a bordered box — other
    # than `skip` — whose BOTTOM border is on row `ty` and which overlaps the column
    # span [cx0,cx1]. used to merge a box up onto an adjoining one even when they live
    # in different containers (e.g. the console's top onto the editors' bottom). uses
    # last-frame bounds, so it's order-independent.
    # bounds are stored PARENT-LOCAL (so find_target can subtract each level), so the
    # absolute screen position of a node is the running sum of bounds.x/.y up the parent
    # chain. the adjoin search needs absolute edges to compare boxes across containers.
    func abs_x [ n: element* ] -> f32
        v : f32 [ 0.0 ]
        p : element [ n ]
        while [ p && p.bounds ]
            v += p.bounds.x
            p = p.parent
        return v

    func abs_y [ n: element* ] -> f32
        v : f32 [ 0.0 ]
        p : element [ n ]
        while [ p && p.bounds ]
            v += p.bounds.y
            p = p.parent
        return v

    func adjoin_bottom_at [ node: element*, skip: element, cx0: i32, cx1: i32, ty: i32 ] -> bool
        if [ !node ] return false
        if [ node != skip && node.bordering && node.bounds ]
            ax : f32 [ abs_x[ node ] ]
            ay : f32 [ abs_y[ node ] ]
            nb  : i32 [ i32 (ay + node.bounds.h) - 1 ]
            nx0 : i32 [ i32 ax ]
            nx1 : i32 [ i32 (ax + node.bounds.w) - 1 ]
            if [ nb == ty && nx0 <= cx1 && nx1 >= cx0 ] return true
        if [ node.elements ]
            for [ ce: element, ck: string ] in node.elements
                if [ adjoin_bottom_at[ ce, skip, cx0, cx1, ty ] ] return true
        return false

    # as above, for a bordered box whose RIGHT border is on column `tx` overlapping
    # the row span [ry0,ry1] (the left-seam / vertical-share case).
    func adjoin_right_at [ node: element*, skip: element, ry0: i32, ry1: i32, tx: i32 ] -> bool
        if [ !node ] return false
        if [ node != skip && node.bordering && node.bounds ]
            ax : f32 [ abs_x[ node ] ]
            ay : f32 [ abs_y[ node ] ]
            nr  : i32 [ i32 (ax + node.bounds.w) - 1 ]
            ny0 : i32 [ i32 ay ]
            ny1 : i32 [ i32 (ay + node.bounds.h) - 1 ]
            if [ nr == tx && ny0 <= ry1 && ny1 >= ry0 ] return true
        if [ node.elements ]
            for [ ce: element, ck: string ] in node.elements
                if [ adjoin_right_at[ ce, skip, ry0, ry1, tx ] ] return true
        return false

    # stamp a single-line box border (unicode light box-drawing) in `color`.
    func draw_box [ grid: ref i32, colg: ref i32, cols: i32, rows: i32, x: i32, y: i32, w: i32, h: i32, color: i32 ]
        # clamp the box to the visible grid so a frame wider/taller than the terminal
        # still closes on screen — its right/bottom border lands on the last cell
        # instead of being dropped by cell_set's bounds check (which read as "no side").
        x0 : i32 [ (x < 0) ? 0 : x ]
        y0 : i32 [ (y < 0) ? 0 : y ]
        x1 : i32 [ x + w - 1 ]
        y1 : i32 [ y + h - 1 ]
        if [ x1 > cols - 1 ] x1 = cols - 1
        if [ y1 > rows - 1 ] y1 = rows - 1
        if [ x1 < x0 || y1 < y0 ] return
        # rounded (arc) corners: ╭ ╮ ╰ ╯
        cell_set[ grid, colg, cols, rows, x0, y0, 0x256D, color ]
        cell_set[ grid, colg, cols, rows, x1, y0, 0x256E, color ]
        cell_set[ grid, colg, cols, rows, x0, y1, 0x2570, color ]
        cell_set[ grid, colg, cols, rows, x1, y1, 0x256F, color ]
        for [ i: i32 x0 + 1, i < x1, i += 1 ]
            cell_set[ grid, colg, cols, rows, i, y0, 0x2500, color ]
            cell_set[ grid, colg, cols, rows, i, y1, 0x2500, color ]
        for [ j: i32 y0 + 1, j < y1, j += 1 ]
            cell_set[ grid, colg, cols, rows, x0, j, 0x2502, color ]
            cell_set[ grid, colg, cols, rows, x1, j, 0x2502, color ]

    # stamp text on one row, clipped to maxw cells. UTF-8 aware: a multibyte sequence
    # decodes to ONE codepoint in ONE cell (the grid stores codepoints and the flush
    # re-encodes them, so a glyph like ▶ must arrive as 0x25B6, not its raw bytes).
    # tabs expand to spaces against the field-local column (tab width 4); NO raw \t can
    # reach the grid — the flush emits cells verbatim and a literal tab would expand to
    # the terminal's ABSOLUTE stops, cascading any text not starting at column 0.
    func stamp_text [ grid: ref i32, colg: ref i32, cols: i32, rows: i32, x: i32, y: i32, s: string, maxw: i32, color: i32 ]
        if [ !s || maxw <= 0 ] return
        i   : i32 [ 0 ]
        col : i32 [ 0 ]
        while [ i < s.count && col < maxw ]
            b0 : i32 [ (i32 s.chars[i]) & 0xFF ]
            if [ b0 == 9 ]
                nsp : i32 [ 4 - (col % 4) ]
                k : i32 [ 0 ]
                while [ k < nsp && col < maxw ]
                    cell_set[ grid, colg, cols, rows, x + col, y, 32, color ]
                    col += 1
                    k += 1
                i += 1
            el [ b0 < 0x20 ]
                i += 1
            el [ b0 < 0x80 ]
                cell_set[ grid, colg, cols, rows, x + col, y, b0, color ]
                col += 1
                i += 1
            el [ b0 < 0xC0 ]
                i += 1
            el [ b0 < 0xE0 ]
                cp : i32 [ b0 & 0x1F ]
                if [ i + 1 < s.count ] cp = (cp << 6) | ((i32 s.chars[i+1]) & 0x3F)
                cell_set[ grid, colg, cols, rows, x + col, y, cp, color ]
                col += 1
                i += 2
            el [ b0 < 0xF0 ]
                cp : i32 [ b0 & 0x0F ]
                if [ i + 2 < s.count ]
                    cp = (cp << 6) | ((i32 s.chars[i+1]) & 0x3F)
                    cp = (cp << 6) | ((i32 s.chars[i+2]) & 0x3F)
                cell_set[ grid, colg, cols, rows, x + col, y, cp, color ]
                col += 1
                i += 3
            el
                cp : i32 [ b0 & 0x07 ]
                if [ i + 3 < s.count ]
                    cp = (cp << 6) | ((i32 s.chars[i+1]) & 0x3F)
                    cp = (cp << 6) | ((i32 s.chars[i+2]) & 0x3F)
                    cp = (cp << 6) | ((i32 s.chars[i+3]) & 0x3F)
                cell_set[ grid, colg, cols, rows, x + col, y, cp, color ]
                col += 1
                i += 4

    # true if the focused element is this element or one of its descendants —
    # i.e. an editable layer within this subtree currently has focus.
    func has_focus_within [ e: element* ] -> bool
        f : element [ focus ]
        while [ f ]
            if [ f == e ] return true
            f = f.parent
        return false

    # recursively lay out + stamp an element and its children.
    # (ox,oy) is the element's available cell origin; (aw,ah) the available size.
    # (pbx0,pbx1) are the enclosing frame's left/right border columns and pbordered
    # says whether that frame exists — a bordered element inside a bordered parent
    # is drawn as a "header": it shares the parent's top + side borders and adds only
    # a unique bottom rule under its text (├──┤), so nested frames don't endlessly embed.
    func draw_element_console [ e: element*, grid: ref i32, colg: ref i32, cols: i32, rows: i32, ox: i32, oy: i32, aw: i32, ah: i32, pbx0: i32, pbx1: i32, pbordered: bool, pax: i32, pay: i32 ]
        if [ !e ] return
        if [ !e.area ] e.area = Region [ 0.0 ]
        if [ !e.bounds ] e.bounds = rect[]
        # console layout: 1 unit (line-height) = 1 cell, and px coords collapse to
        # 1 unit each (px is meaningless in a character grid). fc = 1; the px→1-unit
        # rule is applied by rectangle when console_units is set below.
        e.fc = 1.0
        rel : rect [ x: 0, y: 0, w: f32 aw, h: f32 ah ]
        # resolve bound coords (`<axis>@var=default`, e.g. the editor split seams)
        # against the live app object, same as the vk path — without this the panes
        # ignore split1/split2 and never fill the console window.
        if [ e.ux && e.ux.app_object && e.area ]
            app_obj : Au e.ux.app_object
            if [ e.area.bind_l ] e.area.l.offset = bind_value[ e.area.bind_l, app_obj, f32 aw, 1.0 ]
            if [ e.area.bind_t ] e.area.t.offset = bind_value[ e.area.bind_t, app_obj, f32 ah, 1.0 ]
            if [ e.area.bind_r ] e.area.r.offset = bind_value[ e.area.bind_r, app_obj, f32 aw, 1.0 ]
            if [ e.area.bind_b ] e.area.b.offset = bind_value[ e.area.bind_b, app_obj, f32 ah, 1.0 ]
        b : e.area.rectangle[ rel, null, null, 1.0, true ]
        bw : i32 [ i32 b.w ]
        bh : i32 [ i32 b.h ]
        # the root fills the screen if it carries no explicit size; children must
        # size themselves via their area. a collapsed / unselected control computes
        # 0 here and is skipped below — exactly as the vk path bails on bounds <= 0,
        # so things hidden in the window (e.g. an unselected In-File option) stay
        # hidden in the console instead of being force-filled into view.
        if [ !e.parent ]
            if [ bw < 1 ] bw = aw
            if [ bh < 1 ] bh = ah
        x0 : i32 [ ox + i32 b.x ]
        y0 : i32 [ oy + i32 b.y ]
        # bounds are stored PARENT-LOCAL (absolute minus the parent's absolute origin),
        # because find_target/event hit-testing subtracts each level's bounds as a
        # local offset. x0/y0 stay absolute for grid stamping.
        e.bounds.x = f32 (x0 - pax)
        e.bounds.y = f32 (y0 - pay)
        e.bounds.w = f32 bw
        e.bounds.h = f32 bh
        if [ bw < 1 || bh < 1 ] return
        if [ e.transparency >= 1.0 ] return

        # compute layer bounds (as the vk path does) so app handlers that read
        # layer.bounds (e.g. Editor.on_press caret math) don't deref a null rect.
        if [ e.layers ]
            for [ lau: Au, lk: string ] in e.layers
                lyr : Layer [ lau to Layer ]
                if [ lyr ]
                    lyr.bounds = (lyr.area) ? lyr.area.rectangle[ e.bounds, null, null, 1.0, true ] : e.bounds.copy[]

        # a frame is drawn only when the element opts in via `bordering`. borderless
        # elements (the common case) just position their children, so structural
        # wrappers don't each draw a box.
        bordered : bool [ e.bordering ]
        # header: a bordered element inside a bordered parent. it reuses the parent's
        # top + side borders and contributes only a bottom rule — the shortcut that
        # keeps nested bordered elements from drawing endlessly-embedded frames.
        header   : bool [ bordered && pbordered ]
        # uniform dark-blue border (color 4). focus is shown on the text/cursor, not
        # the chrome — shared seams/junctions belong to two panes, so per-pane border
        # tinting would color the neighbor's ┬/┼/┴ and read wrong.
        bcolor : i32 [ 4 ]

        # share a seam with an adjoining bordered box (searched across the whole tree,
        # so it works between different containers — editors vs console). if one's
        # right border is one cell left of ours, extend our box left; if one's bottom
        # border is one row above ours, extend our box up. the overlapped │/─ borders
        # then merge in cell_set into the right junctions (┬ ┴ ├ ┤ ┼) — one shared line.
        lshift : i32 [ 0 ]
        tshift : i32 [ 0 ]
        if [ bordered && !header && e.ux && e.ux.root ]
            rootn : element [ e.ux.root ]
            if [ adjoin_right_at [ rootn, e, y0, y0 + bh - 1, x0 - 1 ] ] lshift = 1
            if [ adjoin_bottom_at[ rootn, e, x0, x0 + bw - 1, y0 - 1 ] ] tshift = 1

        if [ header ]
            # the divider is the implicit bottom of the border, drawn just BELOW the
            # element's content rows (it doesn't count toward the element's unit
            # height) and extended to the parent's side borders with ├ / ┤ junctions.
            # top + sides are the parent's frame. clamp the junction columns to the
            # visible grid so they land on the SAME clamped column draw_box used for
            # the parent's side border (an overflowing pane otherwise loses its ┤).
            ry  : i32 [ y0 + bh ]
            jx0 : i32 [ (pbx0 < 0) ? 0 : pbx0 ]
            jx1 : i32 [ (pbx1 > cols - 1) ? cols - 1 : pbx1 ]
            cell_set[ grid, colg, cols, rows, jx0, ry, 0x251C, bcolor ]
            cell_set[ grid, colg, cols, rows, jx1, ry, 0x2524, bcolor ]
            for [ rx: i32 jx0 + 1, rx < jx1, rx += 1 ]
                cell_set[ grid, colg, cols, rows, rx, ry, 0x2500, bcolor ]
        el [ bordered && bw >= 2 && bh >= 2 ]
            draw_box[ grid, colg, cols, rows, x0 - lshift, y0 - tshift, bw + lshift, bh + tshift, bcolor ]

        # per-side content insets. a full box insets all four sides; a header insets
        # nothing — its border is implicit around the content (the divider is drawn
        # below, decoration, not stealing a content row).
        il : i32 [ (bordered && !header) ? 1 : 0 ]
        it : i32 [ (bordered && !header) ? 1 : 0 ]
        ir : i32 [ (bordered && !header) ? 1 : 0 ]
        ib : i32 [ (bordered && !header) ? 1 : 0 ]
        # the box may have been extended left/up by lshift/tshift to share a seam;
        # measure content + labels against that EXTENDED box so they sit just inside
        # the shared border instead of leaving an empty cell/row where the original
        # edge used to be.
        bx0 : i32 [ x0 - lshift ]
        by0 : i32 [ y0 - tshift ]
        bbw : i32 [ bw + lshift ]
        bbh : i32 [ bh + tshift ]
        # an element is an editable field when one of its layers is editable (the
        # css marks the title's face editable on focus) — render it as a search box.
        editing : bool [ false ]
        if [ e.layers ]
            for [ ela: Au, elk: string ] in e.layers
                elay : Layer [ ela to Layer ]
                if [ elay && elay.editable ]
                    editing = true
                    break

        # a borderless element with a label reserves its top row for that label.
        has_lbl  : bool [ e.label && e.label.count > 0 ]
        lbl_row  : i32 [ (!bordered && has_lbl) ? 1 : 0 ]
        if [ editing ]
            # editable title: the label is a dim gray placeholder; the typed `edit`
            # text overlaps it from the left in white, with a block (reverse-video)
            # cursor at the insertion point — so you type the search over the name.
            bxl : i32 [ bx0 + il ]
            bxw : i32 [ bbw - il - ir ]
            if [ bxw > 0 ]
                ph : string [ (e.label) ? e.label : '' ]
                ed : string [ (e.edit)  ? e.edit  : '' ]
                # gray placeholder shows only until the user has typed more than one
                # char; past that the whole name is erased, leaving just the query.
                if [ ph.count > 0 && ed.count <= 1 ] stamp_text[ grid, colg, cols, rows, bxl, by0 + it, ph, bxw, 2 ]
                if [ ed.count > 0 ] stamp_text[ grid, colg, cols, rows, bxl, by0 + it, ed, bxw, 1 ]
                cpos : i32 [ ed.count ]
                if [ cpos > bxw - 1 ] cpos = bxw - 1
                ccx : i32 [ bxl + cpos ]
                ccy : i32 [ by0 + it ]
                if [ ccx >= 0 && ccx < cols && ccy >= 0 && ccy < rows ]
                    colg[ ccy * cols + ccx ] = 3
        el [ has_lbl ]
            lx : i32 [ bx0 + il ]
            lw : i32 [ bbw - il - ir ]
            if [ lw > 0 ] stamp_text[ grid, colg, cols, rows, lx, by0 + it, e.label, lw, 0 ]

        # children overlap this element's frame only when it drew a full box (then
        # its own border columns are the frame they share); a header passes the
        # grandparent frame through unchanged.
        child_bordered : bool [ bordered && !header ]
        cpx0 : i32 [ (child_bordered) ? x0 - lshift : pbx0 ]
        cpx1 : i32 [ (child_bordered) ? x0 + bw - 1 : pbx1 ]
        cpb  : bool [ child_bordered || (header && pbordered) ]

        cx : i32 [ bx0 + il ]
        cy : i32 [ by0 + it + lbl_row ]
        cw : i32 [ bbw - il - ir ]
        ch : i32 [ bbh - it - ib - lbl_row ]

        # the topbar (play + project/console tabs) renders as a bordered strip: a top
        # border, a row of ` label ` buttons separated by │ that connect up to ┬ and
        # down to ┴, and a bottom border that lands on the editor frame's top row so
        # cell_set merges the two into one continuous frame (├ ┼ ┤ junctions). no
        # brackets — the dividers are the chrome. each button's bounds stays
        # parent-local to its Tabs group so clicks still route topbar → Tabs → Option.
        if [ e.id && e.id == 'topbar' ]
            tby : i32 [ y0 ]
            mby : i32 [ y0 + 1 ]
            bby : i32 [ y0 + 2 ]
            e.bounds.h = 3.0
            rcol : i32 [ x0 + bw - 1 ]
            # measure the right-anchored groups (the AI/console tabs) so they can be
            # placed flush to the right border: each button is ` label ` plus a leading
            # divider = label + 3 cells.
            rwidth : i32 [ 0 ]
            for [ tb: element, tk: string ] in e.elements
                if [ !(tb.area && tb.area.l.x_type == XAlign.right) ] continue
                if [ tb.elements ]
                    for [ ob: element, ok: string ] in tb.elements
                        ropt : Option ob
                        if [ !ropt ] continue
                        rtxt : string [ '?' ]
                        if [ ob.label && ob.label.count > 0 ]
                            rtxt = '{ob.label}'
                        el [ ob.id && ob.id == 'play' ]
                            rtxt = '>'
                        el [ ob.id && ob.id.count > 0 ]
                            rtxt = '{ob.id}'
                        rwidth += rtxt.count + 3
            rstart : i32 [ rcol - rwidth ]
            # single pass: left-anchored groups flow from the left edge, right-anchored
            # ones from rstart. each button = leading divider (┬/┴ tying into the top &
            # bottom borders) + ` label `; bounds stay parent-local to the Tabs group so
            # clicks route topbar → Tabs → Option.
            lcol : i32 [ x0 ]
            rcur : i32 [ rstart ]
            left_end : i32 [ x0 ]
            for [ tb: element, tk: string ] in e.elements
                right : bool [ tb.area && tb.area.l.x_type == XAlign.right ]
                col : i32 [ (right) ? rcur : lcol ]
                gstart : i32 [ col ]
                if [ tb.elements ]
                    for [ ob: element, ok: string ] in tb.elements
                        opt : Option ob
                        if [ !opt ] continue
                        txt : string [ '?' ]
                        if [ ob.label && ob.label.count > 0 ]
                            txt = '{ob.label}'
                        el [ ob.id && ob.id == 'play' ]
                            txt = '▶'
                        el [ ob.id && ob.id.count > 0 ]
                            txt = '{ob.id}'
                        bs : i32 [ col ]
                        cell_set[ grid, colg, cols, rows, col, tby, 0x252C, 4 ]
                        cell_set[ grid, colg, cols, rows, col, mby, 0x2502, 4 ]
                        cell_set[ grid, colg, cols, rows, col, bby, 0x2534, 4 ]
                        lbl : ' {txt} '
                        # cell width counts codepoints, not bytes (▶ is 3 bytes / 1 cell),
                        # so the border fill + layout advance stay aligned to the glyph.
                        cw2 : i32 [ 0 ]
                        ci : i32 [ 0 ]
                        while [ ci < lbl.count ]
                            if [ ((i32 lbl.chars[ci]) & 0xC0) != 0x80 ] cw2 += 1
                            ci += 1
                        k : i32 [ 0 ]
                        while [ k < cw2 ]
                            cell_set[ grid, colg, cols, rows, col + 1 + k, tby, 0x2500, 4 ]
                            cell_set[ grid, colg, cols, rows, col + 1 + k, bby, 0x2500, 4 ]
                            k += 1
                        bcol : i32 [ (opt.selected) ? 1 : 0 ]
                        stamp_text[ grid, colg, cols, rows, col + 1, mby, lbl, cw2, bcol ]
                        if [ !ob.bounds ] ob.bounds = rect[]
                        ob.bounds.x = f32 (bs - gstart)
                        ob.bounds.y = 0.0
                        ob.bounds.w = f32 (cw2 + 1)
                        ob.bounds.h = 1.0
                        col = col + 1 + cw2
                if [ !tb.bounds ] tb.bounds = rect[]
                tb.bounds.x = f32 (gstart - x0)
                tb.bounds.y = f32 (mby - y0)
                tb.bounds.w = f32 (col - gstart)
                tb.bounds.h = 1.0
                if [ right ] rcur = col
                el
                    lcol = col
                    left_end = col
            # bordered fill in the gap between the left and right groups
            j : i32 [ left_end ]
            while [ j < rstart ]
                cell_set[ grid, colg, cols, rows, j, tby, 0x2500, 4 ]
                cell_set[ grid, colg, cols, rows, j, mby, 32, 0 ]
                cell_set[ grid, colg, cols, rows, j, bby, 0x2500, 4 ]
                j += 1
            # force the frame edge cells directly: cell_set MERGES box glyphs, so it
            # would turn the first button's leading ┬/┴ into a junction instead of a
            # clean corner. the bottom corners (╰ ╯) are left for the editor frame below
            # to merge onto (╰+╭ → ├), keeping the two boxes joined into one frame.
            if [ x0 >= 0 && rcol < cols && bby < rows ]
                grid[ tby * cols + x0 ]   = 0x256D
                colg[ tby * cols + x0 ]   = 4
                grid[ mby * cols + x0 ]   = 0x2502
                colg[ mby * cols + x0 ]   = 4
                grid[ bby * cols + x0 ]   = 0x2570
                colg[ bby * cols + x0 ]   = 4
                grid[ tby * cols + rcol ] = 0x256E
                colg[ tby * cols + rcol ] = 4
                grid[ mby * cols + rcol ] = 0x2502
                colg[ mby * cols + rcol ] = 4
                grid[ bby * cols + rcol ] = 0x256F
                colg[ bby * cols + rcol ] = 4
            return

        if [ cw > 0 && ch > 0 && e.elements ]
            for [ ce: element, ck: string ] in e.elements
                draw_element_console[ ce, grid, colg, cols, rows, cx, cy, cw, ch, cpx0, cpx1, cpb, x0, y0 ]

        # text content: an element that paints rows (the editor's source, a console
        # log) stamps them into the body. a bordered element reserves its top row(s)
        # for a title header + its divider, so the code begins below that; a plain
        # one fills from the content origin. rows are clipped to the box interior so
        # the bottom border is never overwritten.
        lc : i32 [ e.console_line_count*[] ]
        if [ lc > 0 ]
            tx : i32 [ cx ]
            tw : i32 [ cw ]
            ty : i32 [ (bordered) ? cy + 2 : cy ]
            bot : i32 [ by0 + bbh - 1 ]
            body : i32 [ bot - ty ]
            if [ body < 1 ] body = 1
            # wheel scroll: reuse scroll.y as the first-visible line (1 cell = 1 line).
            # content_h is set in those same line units so the element's on_wheel can
            # clamp and step (gentle per-notch speed); the wheel dispatches to on_wheel
            # for whichever editor the cursor is over (see wheel_event).
            e.content_h    = f32 (lc + (bbh - body))
            e.scroll_speed = 3.0
            maxs : i32 [ (lc > body) ? lc - body : 0 ]
            first : i32 [ i32 e.scroll.y ]
            if [ first < 0 ] first = 0
            if [ first > maxs ] first = maxs
            vr : i32 [ 0 ]
            while [ vr < body && first + vr < lc ]
                ln : e.console_line*[ first + vr ]
                if [ ln && ln.count > 0 ] stamp_text[ grid, colg, cols, rows, tx, ty + vr, ln, tw, 0 ]
                vr += 1
            # scrollbar: thicken the segment of the RIGHT border that maps to the
            # visible window — a heavy │ (┃) over [first, first+body) of lc total. only
            # when the content actually overflows the box.
            if [ bordered && lc > body ]
                rbx : i32 [ bx0 + bbw - 1 ]
                th0 : i32 [ ty + (first * body) / lc ]
                th1 : i32 [ ty + ((first + body) * body) / lc ]
                if [ th1 <= th0 ] th1 = th0 + 1
                rr : i32 [ th0 ]
                while [ rr < th1 && rr < bot ]
                    cell_set[ grid, colg, cols, rows, rbx, rr, 0x2503, 1 ]
                    rr += 1

    # ---- console input (terminal mouse + keyboard) -------------------------
    # raw, non-echoing, non-blocking stdin (via stty) + xterm SGR mouse reporting
    # with button-motion tracking (?1002) so drags report too; hide the cursor.
    # write a control string straight to the tty fd (raw syscall, no stdio buffering).
    func tty_write [ s: string ]
        if [ tty_in >= 0 && s ] write[ tty_in, s.chars, s.count ]

    # append a string's bytes into the frame buffer starting at p; returns the new p.
    # lets the flush use plain escape-string literals now that the octal \033 escape
    # is fixed (returns the position rather than taking a ref i32, which mis-GEPs).
    func emit_bytes [ dst: ref u8, p: i32, s: string ] -> i32
        q : i32 [ p ]
        i : i32 [ 0 ]
        while [ i < s.count ]
            dst[ q ] = u8 s.chars[i]
            q += 1
            i += 1
        return q

    func console_input_open []
        system[ "stty -icanon -echo min 0 time 0" ]
        # open the real terminal; grab its fd via fileno and do raw write/read on it.
        # ESC[?1000h click, ?1002h drag, ?1006h SGR coords, ?7l no-autowrap, ?25l hide.
        tty : handle [ fopen[ "/dev/tty", "r+" ] ]
        if [ tty ]
            tty_in = fileno[ tty ]
            # alt screen buffer: a dedicated full-screen page that never scrolls the
            # user's shell history and lets us paint the true last row (the box's
            # bottom border) — leaving it restores their terminal cleanly on exit.
            tty_write[ "\033[?1049h" ]
            tty_write[ "\033[?1000h" ]
            tty_write[ "\033[?1002h" ]
            tty_write[ "\033[?1006h" ]
            tty_write[ "\033[?7l" ]
            tty_write[ "\033[?25l" ]

    func console_input_close []
        tty_write[ "\033[?1000l" ]
        tty_write[ "\033[?1002l" ]
        tty_write[ "\033[?1006l" ]
        tty_write[ "\033[?7h" ]
        tty_write[ "\033[?25h" ]
        # leave the alt screen → restore the user's shell and scrollback.
        tty_write[ "\033[?1049l" ]
        system[ "stty sane" ]

    # read whatever stdin bytes are queued and turn them into the same events the
    # GLFW callbacks raise (mouse pos is in cells — our layout space — so the
    # existing find_target hit-test works unchanged).
    func console_input_poll []
        buf : local u8 [ 128 ]
        # read the real terminal (mouse + keyboard) directly when /dev/tty is open;
        # else fall back to stdin. stty set the controlling terminal raw (min 0 time 0)
        # so this read is non-blocking either way.
        src : i32 [ (tty_in >= 0) ? tty_in : 0 ]
        nb : i32 [ read[ src, ref buf[0], 127 ] ]
        if [ nb <= 0 ] return
        rb0 : i32 [ i32 buf[0] ]
        rb1 : i32 [ 0 ]
        rb2 : i32 [ 0 ]
        if [ nb > 1 ] rb1 = i32 buf[1]
        if [ nb > 2 ] rb2 = i32 buf[2]
        rdbg : handle [ fopen[ "/tmp/orbclick.txt", "a" ] ]
        if [ rdbg ]
            fputs[ 'READ nb={nb} b0={rb0} b1={rb1} b2={rb2}\n', rdbg ]
            fclose[ rdbg ]
        i : i32 [ 0 ]
        while [ i < nb ]
            c : i32 [ i32 buf[i] ]
            # SGR mouse: ESC [ < btn ; col ; row (M=press / m=release)
            if [ c == 0x1b && i + 2 < nb && buf[i+1] == 0x5B && buf[i+2] == 0x3C ]
                j   : i32 [ i + 3 ]
                btn : i32 [ 0 ]
                mx  : i32 [ 0 ]
                my  : i32 [ 0 ]
                while [ j < nb && buf[j] >= 0x30 && buf[j] <= 0x39 ]
                    btn = btn * 10 + (i32 buf[j] - 0x30)
                    j += 1
                if [ j < nb && buf[j] == 0x3B ] j += 1
                while [ j < nb && buf[j] >= 0x30 && buf[j] <= 0x39 ]
                    mx = mx * 10 + (i32 buf[j] - 0x30)
                    j += 1
                if [ j < nb && buf[j] == 0x3B ] j += 1
                while [ j < nb && buf[j] >= 0x30 && buf[j] <= 0x39 ]
                    my = my * 10 + (i32 buf[j] - 0x30)
                    j += 1
                press : bool [ j < nb && buf[j] == 0x4D ]
                # report columns/rows are 1-based; cells are 0-based
                mouse.x = f32 (mx - 1)
                mouse.y = f32 (my - 1)
                ev.clear[]
                ev.mouse.pos.x = mouse.x
                ev.mouse.pos.y = mouse.y
                if [ btn & 64 ]
                    ev.mouse.wheel_delta.y = (btn == 64) ? 1.0 : -1.0
                    wheel_event[ ev ]
                el [ btn & 32 ]
                    move_event[ ev ]
                el
                    ev.mouse.button = btn & 3
                    ev.mouse.state  = press
                    if [ press ]
                        press_event[ ev ]
                    el
                        release_event[ ev ]
                i = j + 1
                continue
            # arrow / nav keys: ESC [ A/B/C/D
            if [ c == 0x1b && i + 2 < nb && buf[i+1] == 0x5B ]
                k    : i32 [ i32 buf[i+2] ]
                code : i32 [ 0 ]
                if [ k == 0x41 ]
                    code = 265
                el [ k == 0x42 ]
                    code = 264
                el [ k == 0x43 ]
                    code = 262
                el [ k == 0x44 ]
                    code = 263
                if [ code ]
                    ev.clear[]
                    ev.key.unicode = code
                    ev.key.state   = 1
                    key_event[ ev ]
                    i += 3
                    continue
            # bare escape
            if [ c == 0x1b ]
                ev.clear[]
                ev.key.unicode = 256
                ev.key.state   = 1
                key_event[ ev ]
                i += 1
                continue
            # enter
            if [ c == 0x0d || c == 0x0a ]
                ev.clear[]
                ev.key.unicode = 257
                ev.key.state   = 1
                key_event[ ev ]
                i += 1
                continue
            # backspace
            if [ c == 0x7f || c == 0x08 ]
                ev.clear[]
                ev.key.unicode = 259
                ev.key.state   = 1
                key_event[ ev ]
                i += 1
                continue
            # printable ASCII → character insertion
            if [ c >= 0x20 && c < 0x7f ]
                tb : local i8 [ 2 ]
                tb[0] = i8 c
                tb[1] = 0
                ev.clear[]
                ev.key.text = string[ ref tb[0] ]
                text_event[ ev ]
                i += 1
                continue
            i += 1

    func draw_console []
        console_input_poll[]
        # terminal size in cells (re-queried each frame for live resize). TIOCGWINSZ
        # is a sizeof-based _IOR macro the compiler can't fold, so pass the literal
        # request value per platform (mac differs from linux) — otherwise ioctl fails
        # on the real tty and we'd be stuck at the fallback size with no resize.
        ws : winsize
        cols : i32 [ 80 ]
        rows : i32 [ 24 ]
        # TIOCGWINSZ differs by platform (mac 0x40087468, linux 0x5413) and the
        # sizeof-based macro doesn't fold, so use the literal value. try the request
        # across stdin/stdout/stderr: --log dup2's stdout+stderr onto a pipe, so only
        # stdin (the input tty) may still answer. mac value first, then linux.
        ok : bool [ ioctl[ 0, 0x40087468, ref ws ] == 0 && ws.ws_col > 0 ]
        if [ !ok ] ok = ioctl[ 1, 0x40087468, ref ws ] == 0 && ws.ws_col > 0
        if [ !ok ] ok = ioctl[ 2, 0x40087468, ref ws ] == 0 && ws.ws_col > 0
        if [ !ok ] ok = ioctl[ 0, 0x5413, ref ws ] == 0 && ws.ws_col > 0
        if [ !ok ] ok = ioctl[ 1, 0x5413, ref ws ] == 0 && ws.ws_col > 0
        if [ !ok ] ok = ioctl[ 2, 0x5413, ref ws ] == 0 && ws.ws_col > 0
        if [ ok ]
            cols = i32 ws.ws_col
            rows = i32 ws.ws_row
        # the alt screen + no-autowrap (?7l) lets us paint every row including the
        # last without scrolling, so the box bottom border lands on the true final
        # line — no reserved row.
        width  = cols
        height = rows

        # build / reconcile the element tree + advance animation (no Canvas)
        update_all[ app_object.on_render*[ a ] ]
        animate[]
        if [ root ] tick_binds[ root ]

        # fill the grid with spaces (default color), then stamp the tree
        n : i32 [ cols * rows ]
        grid : new i32 [ n ]
        colg : new i32 [ n ]
        for [ i: i32 0, i < n, i += 1 ]
            grid[ i ] = 32
            colg[ i ] = 0
        if [ root ]
            draw_element_console[ root, grid, colg, cols, rows, 0, 0, cols, rows, 0, 0, false, 0, 0 ]

        # serialize to UTF-8 with a leading cursor-home + clear-to-end, one write.
        # control prefix written numerically so we never depend on string escapes:
        #   ESC [ H  (home)   ESC [ J  (clear to end of screen)
        # color runs are emitted as SGR escapes whenever the cell color changes:
        #   ESC [ 0 m default   ESC [ 9 7 m white   ESC [ 9 0 m gray
        cap : i32 [ n * 24 + rows + 64 ]
        out : new u8 [ cap ]
        p : i32 [ 0 ]
        # re-assert no-autowrap (?7l) + home + clear-to-end. ?7l every frame is the key
        # to the bottom border: with autowrap ON, writing the bottom-right cell arms a
        # "pending wrap" and the next byte (the next frame, or silver-host's rebuild
        # newline) scrolls the screen — eating the bottom edge and leaving a blank line.
        # autowrap OFF means the last cell never arms that scroll. (it can get re-enabled
        # by other output, so we set it per frame rather than once at startup.)
        p = emit_bytes[ out, p, "\033[?7l\033[H\033[J" ]
        cur_col : i32 [ -1 ]
        for [ y: i32 0, y < rows, y += 1 ]
            for [ x: i32 0, x < cols, x += 1 ]
                idx : i32 [ y * cols + x ]
                c   : i32 [ colg[ idx ] ]
                if [ c != cur_col ]
                    cur_col = c
                    # reset-prefixed (ESC[0;..) so reverse never leaks. default text,
                    # 2 = dim, 3 = reverse cursor, 4 = mid/dark-gray border (256-color 240).
                    if [ c == 4 ]
                        p = emit_bytes[ out, p, "\033[0;38;5;240m" ]
                    el [ c == 2 ]
                        p = emit_bytes[ out, p, "\033[0;90m" ]
                    el [ c == 3 ]
                        p = emit_bytes[ out, p, "\033[0;7m" ]
                    el [ c == 1 ]
                        p = emit_bytes[ out, p, "\033[0;97m" ]
                    el
                        p = emit_bytes[ out, p, "\033[0m" ]
                cp : i32 [ grid[ idx ] ]
                if [ cp < 0x80 ]
                    out[p] = u8 cp
                    p += 1
                el [ cp < 0x800 ]
                    out[p] = u8 (0xC0 | (cp >> 6))
                    p += 1
                    out[p] = u8 (0x80 | (cp & 0x3F))
                    p += 1
                el
                    out[p] = u8 (0xE0 | (cp >> 12))
                    p += 1
                    out[p] = u8 (0x80 | ((cp >> 6) & 0x3F))
                    p += 1
                    out[p] = u8 (0x80 | (cp & 0x3F))
                    p += 1
            if [ y < rows - 1 ]
                out[p] = 0x0A
                p += 1
        # reset color at the end of the frame
        p = emit_bytes[ out, p, "\033[0m" ]
        out[p] = 0
        printf[ "%s", out ]

    # resolve a bound coord against the app object: read the named f32 field via
    # member_ref (the app object is the only scope — never the element/parent).
    # a missing field falls back to the coord's inline default.
    # READ-ONLY accessor used during layout — called in BOTH the compose and screen
    # tree walks. it returns the eased ACTIVE position only; it must NOT advance the
    # filter here. if it did, active would step once per walk (twice per frame) and
    # the cache content (composed at one active) would be blitted into a rect sized
    # from a further-stepped active — a per-frame scale distortion on the moving edge
    # that grows with the filter rate. the ease is advanced exactly once per frame by
    # tick_binds, before any walk, so both walks read the same settled value.
    func bind_value [ b: BindCoord, app_obj: Au, span: f32, fc: f32 ] -> f32
        if [ !b ] return 0.0
        if [ !b.has_active ] return b.dflt
        return b.active

    # advance ONE bound coord's eased active toward its goal. called once per frame
    # by tick_binds, before on_compose draws. `v` is the GOAL (where drag/toggle put
    # the seam); active is filtered toward it. clamps the app var into the style's
    # range (`|min|max`, px) and writes the clamped goal back so the var never holds
    # an out-of-range value. `moving` is set on any frame active changed (incl. the
    # snap frame) so draw_element repaints the edge and the loop keeps animating until
    # it settles.
    func bind_advance [ b: BindCoord, app_obj: Au, span: f32, fc: f32 ]
        if [ !b || !app_obj ] return
        m : find_member[ typeid[ app_obj ], b.varname.chars, AU_MEMBER_VAR, 0, true ]
        if [ !m ] return
        p : ref f32 [ app_obj.member_ref[ m ] ]
        v : f32 [ p[0] ]
        # console: the range min/max are px values that don't divide down at fc=1, so
        # the px-range clamp would corrupt the value (e.g. force console_h up to 50).
        # take the app var directly, no clamp and no easing — a grid has no sub-frame
        # animation to settle anyway.
        if [ console ]
            b.active     = v
            b.has_active = true
            b.moving     = false
            return
        if [ b.has_range && fc > 0.0 && span > 0.0 ]
            lo : f32 [ b.max / fc ]
            hi : f32 [ (span - b.min) / fc ]
            if [ v < lo ] v = lo
            if [ hi > lo && v > hi ] v = hi
            p[0] = v
        if [ !b.has_active ]
            b.active     = v
            b.has_active = true
            b.moving     = false
        el
            d : f32 [ v - b.active ]
            if [ d != 0.0 ]
                b.moving = true
                if [ d < 0.02 && d > -0.02 ]
                    b.active = v
                el
                    b.active = filter_n[ b.active, v, 0.28, frame_factor ]
                    #b.active = b.active * 0.7 + v * 0.3
            el
                b.moving = false
        if [ b.moving ] will_animate = true

    # advance every bound coord in the element tree once per frame (see bind_advance),
    # before on_compose draws. uses the parent's last-laid-out bounds for the clamp
    # span — fine, that only keeps the goal in range. recurses the whole tree.
    func tick_binds [ e: element* ]
        if [ !e ] return
        if [ e.ux && e.ux.app_object && e.area ]
            app_obj : Au e.ux.app_object
            rel_w : f32 [ (e.parent && e.parent.bounds) ? e.parent.bounds.w : width ]
            rel_h : f32 [ (e.parent && e.parent.bounds) ? e.parent.bounds.h : height ]
            fcv   : f32 [ (e.fc > 0.0) ? e.fc : 22.0 ]
            if [ e.area.bind_l ] bind_advance[ e.area.bind_l, app_obj, rel_w, fcv ]
            if [ e.area.bind_t ] bind_advance[ e.area.bind_t, app_obj, rel_h, fcv ]
            if [ e.area.bind_r ] bind_advance[ e.area.bind_r, app_obj, rel_w, fcv ]
            if [ e.area.bind_b ] bind_advance[ e.area.bind_b, app_obj, rel_h, fcv ]
        if [ e.elements ]
            for [ ce: element, ck: string ] in e.elements
                tick_binds[ ce ]

    # LAYOUT pass — compute e.bounds for the whole tree BEFORE any painting. the
    # paint walk (draw_element) reads e.bounds (its own, its parent's via rel, its
    # flow sibling's via last); if layout and paint share one walk, a child's
    # cv.translate / cache size reads bounds that this frame hasn't finalized yet,
    # so a seam drag paints one frame behind. separating the two fixes that with no
    # compose pre-pass. cv supplies the per-target font metric (fc) only — no drawing.
    func layout_element [ e: element*, last: element, cv: Canvas ]
        expect e inherits element, 'e is not an element'
        rel : rect [ (e.parent) ?
            rect [ x: 0, y: 0, w: e.parent.bounds.w, h: e.parent.bounds.h ] :
            rect [ x: 0, y: 0, w: width, h: height ] ]

        # fc = px-per-unit from THIS canvas's font line height — per-target, so
        # console apps (normalized 1-cell fonts) stay compatible. the font is
        # cached (loaded once), and ensure_font makes line_height available even
        # for controls that never draw text (FileList etc.).
        cv.ensure_font[]
        e.fc = 22.0
        if [ cv.font ]
            # font.line_height is in DEVICE pixels (atlas rasterized at sz*scale);
            # fc is px-per-unit in LOGICAL space, so divide by the canvas's device
            # scale — otherwise every unit-based size (h2/w6/toolbars) doubles.
            cs : f32 [ (cv.w && cv.w.scale > 0.0) ? cv.w.scale : 1.0 ]
            e.fc = cv.font.line_height / cs

        # compute element bounds from its area
        if [ !e.area ]
            e.area = Region [ 0.0 ]

        if [!e.bounds] e.bounds = rect[]

        # resolve any bound coords (`r[varname:default]`) against the app object so
        # the live variable drives layout — read each frame, so a drag reflows.
        if [ e.ux && e.ux.app_object && e.area ]
            app_obj : Au e.ux.app_object
            if [ e.area.bind_l ] e.area.l.offset = bind_value[ e.area.bind_l, app_obj, rel.w, e.fc ]
            if [ e.area.bind_t ] e.area.t.offset = bind_value[ e.area.bind_t, app_obj, rel.h, e.fc ]
            if [ e.area.bind_r ] e.area.r.offset = bind_value[ e.area.bind_r, app_obj, rel.w, e.fc ]
            if [ e.area.bind_b ] e.area.b.offset = bind_value[ e.area.bind_b, app_obj, rel.h, e.fc ]
            # a bound coord still easing → this control's box moved: repaint it and
            # keep the loop animating until it settles (the goal/active diff hits 0).
            if [ (e.area.bind_l && e.area.bind_l.moving) || (e.area.bind_t && e.area.bind_t.moving) || (e.area.bind_r && e.area.bind_r.moving) || (e.area.bind_b && e.area.bind_b.moving) ]
                e.pristine   = false
                will_animate = true

        bounds : e.area.rectangle[ rel, null, (last) ? last.bounds : null, e.fc, false ]

        # percent sizing: override h/w with fraction of remaining sibling space
        if [ e.area && e.parent && e.parent.elements && (e.area.b.percent || e.area.r.percent) ]
            prel   : rect [ x: 0, y: 0, w: rel.w, h: rel.h ]
            pfc    : f32  [ (e.parent.fc > 0.0) ? e.parent.fc : e.fc ]
            fixed_h : f32 0.0
            fixed_w : f32 0.0
            for [ sib: element, sid: string ] in e.parent.elements
                if [ sib == e || !sib.area ] continue
                if [ e.area.b.percent && sib.area.b.y_type == YAlign.height && !sib.area.b.percent ]
                    sfc : f32 [ (sib.fc > 0.0) ? sib.fc : pfc ]
                    tb  : sib.area.rectangle[ prel, null, null, sfc, false ]
                    fixed_h += tb.h
                if [ e.area.r.percent && sib.area.r.x_type == XAlign.width && !sib.area.r.percent ]
                    sfc : f32 [ (sib.fc > 0.0) ? sib.fc : pfc ]
                    tb  : sib.area.rectangle[ prel, null, null, sfc, false ]
                    fixed_w += tb.w
            if [ e.area.b.percent ] bounds.h = e.area.b.offset * (rel.h - fixed_h)
            if [ e.area.r.percent ] bounds.w = e.area.r.offset * (rel.w - fixed_w)

        # content size (wc / hc): measure the element's content, then size to it.
        # a right anchor (l-slot is right-typed) offsets the element LEFT by its
        # computed width; a bottom anchor offsets it UP by its computed height.
        if [ e.area.r.content || e.area.b.content ]
            cw : f32 [ bounds.w ]
            ch : f32 [ bounds.h ]
            if [ e.elements && e.elements.count > 0 ]
                # content = extent of laid-out children (flow-aware via `last`)
                prov  : rect [ x: 0.0, y: 0.0, w: 100000.0, h: 100000.0 ]
                lastc : rect [ null ]
                maxr  : f32 [ 0.0 ]
                maxb  : f32 [ 0.0 ]
                for [ ce: element, ck: string ] in e.elements
                    if [ !ce.area ] continue
                    cb : ce.area.rectangle[ prov, null, lastc, e.fc, false ]
                    if [ cb.x + cb.w > maxr ] maxr = cb.x + cb.w
                    if [ cb.y + cb.h > maxb ] maxb = cb.y + cb.h
                    lastc = cb
                cw = maxr
                ch = maxb
            el [ cv.font && e.label && e.label.count > 0 ]
                tm : cv.measure_text[ e.label ]
                cw = tm.w
                ch = tm.ascent - tm.descent
            if [ e.area.r.content ]
                if [ e.area.l.x_type == XAlign.right ]  bounds.x = bounds.x - cw
                # middle anchor: center the content on m — shift left by half the width
                if [ e.area.l.x_type == XAlign.middle ] bounds.x = bounds.x - cw / 2.0
                bounds.w = cw
            if [ e.area.b.content ]
                if [ e.area.t.y_type == YAlign.bottom ]  bounds.y = bounds.y - ch
                if [ e.area.t.y_type == YAlign.middle ] bounds.y = bounds.y - ch / 2.0
                bounds.h = ch

        e.bounds.x = bounds.x
        e.bounds.y = bounds.y
        e.bounds.w = bounds.w
        e.bounds.h = bounds.h
        # collapsed to nothing (e.g. the editor section when the console seam is
        # snapped fully up) — skip this element and all its children.
        if [ e.bounds.w <= 0.0 || e.bounds.h <= 0.0 ] return
        if [ e.transparency >= 1.0 ] return
        # bounds final for this element — lay out children in the SAME order
        # draw_element paints them (normal first, then topmost), threading the
        # previous sibling for flow layout. no painting here.
        last_2 : element
        for [ ee: element, id: string ] in e.elements
            if [ ee.topmost ] continue
            layout_element[ ee, last_2, cv ]
            last_2 = ee
        for [ ee: element, id: string ] in e.elements
            if [ !ee.topmost ] continue
            layout_element[ ee, last_2, cv ]
            last_2 = ee

    public func draw_element [ e: element*, stage: CanvasType, last:element ]
        expect e inherits element, 'e is not an element'
        # select target canvas directly. (was: new Canvas[2] [screen,compose]
        # then index — that per-call vector dropped its elements on teardown
        # without holding them on init, underflowing screen/compose to 0.)
        cv : (stage == CanvasType.screen) ? screen : compose
        # bounds were finalized by layout_element before this paint pass. collapsed
        # or fully-transparent elements (and their children) were skipped there, so
        # mirror those skips here to keep the two walks in lockstep.
        if [ !e.bounds || e.bounds.w <= 0.0 || e.bounds.h <= 0.0 ] return
        if [ e.transparency >= 1.0 ] return
        # pre-scan layers to measure any outset beyond element bounds
        margin_l : i32 [ 0 ]
        margin_t : i32 [ 0 ]
        margin_r : i32 [ 0 ]
        margin_b : i32 [ 0 ]
        for [ psc_au: Au, psc_k: string ] in e.layers
            psc_lay : Layer [ psc_au to Layer ]
            if [ !psc_lay || !psc_lay.area ] continue
            psc_b  : psc_lay.area.rectangle[ e.bounds, null, null, e.fc, false ]
            psc_lx : f32  [ psc_b.x - e.bounds.x ]
            psc_ly : f32  [ psc_b.y - e.bounds.y ]
            psc_rx : f32  [ psc_b.x + psc_b.w - e.bounds.x - e.bounds.w ]
            psc_by : f32  [ psc_b.y + psc_b.h - e.bounds.y - e.bounds.h ]
            if [ psc_lx < 0.0 ]
                ol : i32 ceilf[ 0.0 - psc_lx ]
                if [ ol > margin_l ] margin_l = ol
            if [ psc_ly < 0.0 ]
                ot : i32 ceilf[ 0.0 - psc_ly ]
                if [ ot > margin_t ] margin_t = ot
            if [ psc_rx > 0.0 ]
                or2 : i32 ceilf[ psc_rx ]
                if [ or2 > margin_r ] margin_r = or2
            if [ psc_by > 0.0 ]
                ob2 : i32 ceilf[ psc_by ]
                if [ ob2 > margin_b ] margin_b = ob2
        if [ margin_l > 0 ] margin_l += 1
        if [ margin_t > 0 ] margin_t += 1
        if [ margin_r > 0 ] margin_r += 1
        if [ margin_b > 0 ] margin_b += 1
        ew : i32 [ i32[ceilf[e.bounds.w]] + 1 + margin_l + margin_r ]
        eh : i32 [ i32[ceilf[e.bounds.h]] + 1 + margin_t + margin_b ]
        if [ ( ew > 0 && eh > 0 ) && ( !e.cache_canvas || e.cache_w != ew || e.cache_h != eh ) ]
            # reuse the existing canvas at the new size — resizes its textures +
            # framebuffers, keeps the pipelines/shaders/atlas (no VkPipeline
            # rebuild, which was the resize fps cost). quantize=true rounds the GPU
            # allocation up to a 64px grid, so most 1px drag steps reuse the same
            # textures (no realloc) and only the content size + blit UV change; the
            # cache_w/cache_h we track stays the exact logical size for the blit.
            if [ e.cache_canvas ]
                e.cache_canvas.resize[ ew, eh ]
                # ANY logical size change re-renders this cache, so every element reflows at
                # its new size IN THE SAME frame — chrome and scroll content alike. the old
                # "resize within capacity → keep the pixels, just blit" shortcut desynced the
                # tree during a seam drag: a re-rastered title narrowed a frame before the
                # blit-only editor caught up (title too narrow, editor scrollbar overhanging).
                # the per-line text cache makes the editor's re-render cheap (re-composite
                # cached line blits, not re-raster glyphs), so resize-in-sync wins.
                e.pristine = false
            el
                e.cache_canvas = Canvas [ w: a, vk: vk, format: Pixel.rgba8, width: ew, height: eh, load_existing: true, quantize: true ]
                e.cache_canvas.update[]
                e.pristine = false
            e.cache_w = ew
            e.cache_h = eh
            e.cache_ox = margin_l
            e.cache_oy = margin_t

        #puts 'target_cv set'
        target_cv : (e.cache_canvas && !e.volatile && stage == CanvasType.screen) ? e.cache_canvas : cv
        element_text : (e.label && e.label.count) ? e.label : null

        sx       : f32  [ (e.scaling.x != 0.0) ? e.scaling.x : 1.0 ]
        sy       : f32  [ (e.scaling.y != 0.0) ? e.scaling.y : 1.0 ]
        has_rot  : bool [ e.rotation != 0.0 ]
        has_sc   : bool [ sx != 1.0 || sy != 1.0 ]
        xform    : bool [ has_rot || has_sc ]

        if [ xform ]
            ox : f32 [ (e.transform_origin.x != 0.0) ? e.transform_origin.x : 0.5 ]
            oy : f32 [ (e.transform_origin.y != 0.0) ? e.transform_origin.y : 0.5 ]
            pivot_x : f32 [ e.bounds.w * ox ]
            pivot_y : f32 [ e.bounds.h * oy ]
            cv.save[]
            cv.translate[ pivot_x, pivot_y ]
            if [ has_rot ]
                cv.rotate[ e.rotation ]
            if [ has_sc ]
                cv.scale_xy[ sx, sy ]
            cv.translate[ -pivot_x, -pivot_y ]

        redraw : bool [ e.volatile || !e.pristine || stage == CanvasType.compose ]
        # DIAG: log every element that re-rasterizes its layers (text) this frame into its
        # cache — during a resize the cache is invalidated (pristine=false) per frame, so
        # this fires continuously and proves the text is being re-rendered on every drag step.
        if [ redraw && e.cache_canvas && !e.volatile && stage == CanvasType.screen ]
            eid : string [ (e.id && e.id.count > 0) ? e.id : '(noid)' ]
            #puts 'REDRAW {eid} {ew}x{eh} pristine={e.pristine}'
        if [ redraw && e.cache_canvas && !e.volatile && stage == CanvasType.screen ]
            e.cache_canvas.reset[ vec4f[0.0, 0.0, 0.0, 0.0] ]
            if [ e.cache_ox > 0 || e.cache_oy > 0 ]
                target_cv.save[]
                target_cv.translate[ f32 e.cache_ox, f32 e.cache_oy ]

        e.needs_frame = false

        # the vertical scrollbar is painted LAST — after the masked cache blit and
        # without the mask (see below) — so the edge fade never dims the bar. when this
        # element caches to the screen, skip it in the cached layer loop and defer it.
        defer_scroll : bool [ e.cache_canvas && !e.volatile && stage == CanvasType.screen ]

        # compute layer bounds and draw each layer
        for [ layer_au: Au, lkey: string ] in e.layers
            if [ !redraw ] break
            layer : Layer [ layer_au to Layer ]
            if [ !layer || layer.ctype != stage || layer.hide ]
                continue
            if [ defer_scroll && lkey == 'scrollbar' ]
                continue

            layer.bounds = (layer.area) ? layer.area.rectangle[ e.bounds, null, null, e.fc, false ] : e.bounds.copy[]
            layer.bounds.x -= e.bounds.x
            layer.bounds.y -= e.bounds.y
            b  : rect   [ layer.bounds ]
            r_tl : f32 [ 0.0 ]
            r_tr : f32 [ 0.0 ]
            r_br : f32 [ 0.0 ]
            r_bl : f32 [ 0.0 ]
            if [ layer.radius ]
                r_tl = layer.radius.tl
                r_tr = layer.radius.tr
                r_br = layer.radius.br
                r_bl = layer.radius.bl

            # blur setup: draw to per-layer canvas when blur is active.
            # dirty on first use, size change, or active transition.
            needs_blur  : bool [ layer.blur_x > 0.0 || layer.blur_y > 0.0 ]
            draw_cv     : target_cv
            blur_redraw : bool [ false ]

            if [ needs_blur ]
                blur_r  : f32 [ (layer.blur_x > layer.blur_y) ? layer.blur_x : layer.blur_y ]
                pad     : f32 [ blur_r * 2.0 ]
                bw : i32 [ i32[b.w + pad] + 1 ]
                bh : i32 [ i32[b.h + pad] + 1 ]
                if [ !layer.blur_canvas || layer.blur_bw != bw || layer.blur_bh != bh ]
                    # force-free the old canvas's GPU textures/samplers before replacing
                    # it — a Model/Pipeline still references them, so refcount dealloc
                    # never runs and the samplers leak on every resize step.
                    if [ layer.blur_canvas ] layer.blur_canvas.teardown_gpu[]
                    layer.blur_canvas = Canvas [ w: a, vk: vk, format: Pixel.rgba8, width: bw, height: bh ]
                    layer.blur_canvas.update[]
                    layer.blur_bw = bw
                    layer.blur_bh = bh
                    layer.blur_dirty = true
                if [ e.volatile ]
                    layer.blur_dirty = true
                if [ layer.blur_dirty ]
                    layer.blur_canvas.reset[ vec4f[0.0, 0.0, 0.0, 0.0] ]
                    draw_cv = layer.blur_canvas
                    draw_cv.save[]
                    draw_cv.translate[ -b.x + pad * 0.5, -b.y + pad * 0.5 ]
                    blur_redraw = true

            if [ (!needs_blur || blur_redraw) && ((layer.fill_color && layer.fill_color.a > 0.0) || (layer.stroke_color && layer.stroke_color.a > 0.0) || layer.inner_glow) ]
                draw_cv.save             [ ]
                sw_top   : f32 [ (layer.stroke_width) ? layer.stroke_width.top    : 0.0 ]
                sw_right : f32 [ (layer.stroke_width) ? layer.stroke_width.right  : 0.0 ]
                sw_bot   : f32 [ (layer.stroke_width) ? layer.stroke_width.bottom : 0.0 ]
                sw_left  : f32 [ (layer.stroke_width) ? layer.stroke_width.left   : 0.0 ]
                sw_max   : f32 [ maxf[ maxf[ sw_top, sw_right ], maxf[ sw_bot, sw_left ] ] ]
                # crisp-pixel offset: odd max stroke width needs half-pixel nudge
                sw_int : i32 [ i32 sw_max ]
                crisp  : f32 [ ((sw_int % 2) == 1) ? 0.5 : 0.0 ]
                if [ crisp > 0.0 ]
                    draw_cv.translate    [ crisp, crisp ]
                draw_cv.set_stroke_size  [ sw_max ]
                draw_cv.set_stroke_cap   [ layer.stroke_cap  ]
                draw_cv.set_stroke_join  [ layer.stroke_join ]
                draw_cv.rounded          [ r_tl, r_tr, r_br, r_bl ]
                draw_cv.stroke_sides     [ sw_top, sw_right, sw_bot, sw_left ]
                draw_cv.rounded_rect     [ b.x, b.y, b.w, b.h, r_tl, r_tr, r_br, r_bl ]
                draw_cv.fill_color       [ (layer.fill_color && layer.fill_color.a > 0.0) ? layer.fill_color : rgba [ '#00000000' ] ]
                draw_cv.stroke_color     [ layer.stroke_color ]
                # fill gradient anchors — same element-unit → world-pixel
                # convention as the label gradient. axis straddles the anchor
                # so mirror puts the highlight ON the anchor point.
                fp_x : f32 [ layer.fill_color_pos.x * e.bounds.w ]
                fp_y : f32 [ layer.fill_color_pos.y * e.bounds.h ]
                # DEBUG: hardcoded to test whether layer fields reach here.
                f_rad : f32 [ layer.fill_gradient_radius ]
                f_ax  : f32 [ draw_cv.transform_tx[] + fp_x ]
                f_ay  : f32 [ draw_cv.transform_ty[] + fp_y ]
                draw_cv.fill_grad        [ layer.fill_gradient_color ]
                if [ layer.fill_gradient == GradientType.radial ]
                    f_ry : f32 [ (layer.fill_gradient_radius_y > 0.0) ? layer.fill_gradient_radius_y : f_rad ]
                    draw_cv.fill_color_pos   [ f_ax, f_ay ]
                    draw_cv.fill_grad_pos    [ f_ax + f_rad, f_ay + f_ry ]
                    draw_cv.fill_grad_radial [ true ]
                    draw_cv.fill_grad_mirror [ false ]
                el [ layer.fill_gradient == GradientType.linear ]
                    draw_cv.fill_color_pos   [ f_ax, f_ay ]
                    fill_rad : f32 [ layer.fill_gradient_angle * 3.14159265 / 180.0 ]
                    fill_ext : f32 [ (f_rad > 0.0) ? f_rad : abs[b.w * cos[fill_rad]] + abs[b.h * sin[fill_rad]] ]
                    draw_cv.fill_grad_pos    [ f_ax + fill_ext * cos[ fill_rad ], f_ay + fill_ext * sin[ fill_rad ] ]
                    draw_cv.fill_grad_radial [ false ]
                    draw_cv.fill_grad_mirror [ false ]
                el
                    draw_cv.fill_grad_radial [ false ]
                    draw_cv.fill_grad_mirror [ false ]
                # stroke gradient anchor — independent of fill anchor
                sp_x  : f32 [ layer.stroke_color_pos.x * e.bounds.w ]
                sp_y  : f32 [ layer.stroke_color_pos.y * e.bounds.h ]
                s_ax  : f32 [ draw_cv.transform_tx[] + sp_x ]
                s_ay  : f32 [ draw_cv.transform_ty[] + sp_y ]
                s_rad : f32 [ layer.stroke_gradient_radius ]
                draw_cv.stroke_grad      [ layer.stroke_gradient_color ]
                if [ layer.stroke_gradient == GradientType.radial ]
                    s_ry : f32 [ (layer.stroke_gradient_radius_y > 0.0) ? layer.stroke_gradient_radius_y : s_rad ]
                    draw_cv.stroke_color_pos [ s_ax, s_ay ]
                    draw_cv.stroke_grad_pos  [ s_ax + s_rad, s_ay + s_ry ]
                    draw_cv.stroke_grad_radial [ true ]
                    draw_cv.stroke_grad_mirror [ false ]
                el [ layer.stroke_gradient == GradientType.linear ]
                    draw_cv.stroke_color_pos [ s_ax, s_ay ]
                    stroke_rad : f32 [ layer.stroke_gradient_angle * 3.14159265 / 180.0 ]
                    stroke_ext : f32 [ (s_rad > 0.0) ? s_rad : abs[b.w * cos[stroke_rad]] + abs[b.h * sin[stroke_rad]] ]
                    draw_cv.stroke_grad_pos  [ s_ax + stroke_ext * cos[ stroke_rad ], s_ay + stroke_ext * sin[ stroke_rad ] ]
                    draw_cv.stroke_grad_radial [ false ]
                    draw_cv.stroke_grad_mirror [ false ]
                el
                    draw_cv.stroke_grad_radial [ false ]
                    draw_cv.stroke_grad_mirror [ false ]
                if [ layer.inner_glow ]
                    draw_cv.inner_glow   [ layer.inner_glow.color, layer.inner_glow.blur ]
                draw_cv.paint            [ ]
                draw_cv.restore          [ ]

            if [ (!needs_blur || blur_redraw) && layer.image_svg ]
                sc : f32 (layer.image_scale > 0.0) ? layer.image_scale : 1.0
                dw : f32 layer.image_svg.w * sc
                dh : f32 layer.image_svg.h * sc
                dx : f32 b.x + (b.w - dw) * 0.5
                dy : f32 b.y + (b.h - dh) * 0.5
                draw_cv.save[]
                draw_cv.set_opacity[ (layer.opacity > 0.0) ? layer.opacity : 1.0 ]
                draw_cv.draw_svg[ layer.image_svg, dx, dy, dw, dh ]
                draw_cv.restore[]

            label : string (layer.label && layer.label.count > 0) ? layer.label : null

            if [ (!needs_blur || blur_redraw) && !layer.editable && (element_text || label) && layer.label_size > 0 && layer.label_color && layer.label_color.a > 0 ]
                draw_cv.save[]
                prev_font : CanvasFont draw_cv.font
                if [ layer.label_font && layer.label_font.count > 0 ]
                    if [ !layer.label_font_cache ]
                        layer.label_font_cache = CanvasFont [ ft_lib: draw_cv.ft_lib, uri: layer.label_font, size_px: i32[layer.label_size] ]
                    draw_cv.set_font[ layer.label_font_cache ]
                align  : vec2f [ x: layer.label_align.x, y: layer.label_align.y ]
                offset : vec2f  [ x: layer.label_offset.x, y: layer.label_offset.y ]
                draw_cv.fill_color   [ layer.label_color ]
                draw_cv.font_size    [ layer.label_size ]
                draw_cv.line_height  [ layer.label_height ]
                # gradient anchor: element-unit → world-pixel. |v| < 1 means
                # a fraction of e.bounds; otherwise pixels. the axis straddles
                # the anchor point (p0 = anchor - halfDir, p1 = anchor + halfDir)
                # so mirror puts the highlight ON the anchor (cursor-following
                # chrome). direction is label_grad_degrees from +x (screen
                # coords: 0 = right, 90 = down).
                cp_x : f32 [ layer.label_color_pos.x * e.bounds.w ]
                cp_y : f32 [ layer.label_color_pos.y * e.bounds.h ]
                rad  : f32 [ layer.label_gradient_radius ]
                ang  : f32 [ radians[ layer.label_gradient_degrees ] ]
                hx   : f32 [ cosf[ ang ] * rad * 0.5 ]
                hy   : f32 [ sinf[ ang ] * rad * 0.5 ]
                # canvas transform is already at the element's world origin
                # (parent called cv.translate[e.bounds.x, e.bounds.y] before
                # recursing). v_pos in the shader is world-space, so the
                # anchor must use the transform, not e.bounds.x/y.
                ax   : f32 [ draw_cv.transform_tx[] + cp_x ]
                ay   : f32 [ draw_cv.transform_ty[] + cp_y ]
                draw_cv.text_grad        [ layer.label_gradient ]
                draw_cv.text_color_pos   [ ax - hx, ay - hy ]
                draw_cv.text_grad_pos    [ ax + hx, ay + hy ]
                draw_cv.text_grad_mirror [ layer.label_gradient_mirror ]

                lsh : Shadow [
                    color:  layer.label_shadow,
                    offset: layer.label_shadow_offset,
                    blur:   layer.label_shadow_blur ]
                tx0 : f32 [ draw_cv.transform_tx[] + b.x ]
                ty0 : f32 [ draw_cv.transform_ty[] + b.y ]
                draw_cv.set_crop[ tx0, ty0, tx0 + b.w, ty0 + b.h ]
                draw_cv.draw_text    [ (label || element_text), b, align, offset, layer.label_overflow, lsh ]
                draw_cv.clear_crop[]
                if [ layer.label_font && layer.label_font.count > 0 ]
                    draw_cv.set_font[ prev_font ]
                draw_cv.restore      [ ]

            layer.draw*[ draw_cv ]

            if [ needs_blur ]
                if [ blur_redraw ]
                    draw_cv.restore[]
                    br : f32 [ (layer.blur_x > layer.blur_y) ? layer.blur_x : layer.blur_y ]
                    layer.blur_canvas.blur[ br ]
                    layer.blur_dirty = false
                bpad : f32 [ ((layer.blur_x > layer.blur_y) ? layer.blur_x : layer.blur_y) * 2.0 ]
                target_cv.draw_canvas[ layer.blur_canvas, b.x - bpad * 0.5, b.y - bpad * 0.5, b.w + bpad, b.h + bpad ]

        if [ xform ]
            cv.restore[]

        if [ redraw ]
            # redirect window canvases so e.draw* sees the cache target.
            # hold the saved canvases: `a.screen = target_cv` is a `=` reassign
            # that drops the field's previous value, and the save is a borrow
            # (no hold) — without this, the reassign frees screen/compose when
            # nothing else pads their refcount. released after the restore.
            prev_screen  : hold[ a.screen ]
            #prev_compose : hold[ a.compose ]
            if [ stage == CanvasType.screen ]  a.screen  = target_cv
            #if [ stage == CanvasType.compose ] a.compose = target_cv
            e.draw*[ a ]
            a.screen  = prev_screen
            #a.compose = prev_compose
            drop[ prev_screen ]
            #drop[ prev_compose ]
            if [ !e.volatile && stage == CanvasType.screen ]
                if [ e.cache_ox > 0 || e.cache_oy > 0 ]
                    target_cv.restore[]
                if [ !e.needs_frame ]
                    e.pristine = true

        # blit element cache into parent canvas (screen stage only). when the
        # element wants an edge fade, build/refresh a grayscale mask (white
        # center, black inner glow) sized to the cache and composite through it.
        mask_on : bool [ e.mask_glow.x > 0.0 || e.mask_glow.y > 0.0 || e.mask_glow.z > 0.0 || e.mask_glow.w > 0.0 ]
        if [ e.cache_canvas && !e.volatile && stage == CanvasType.screen ]
            if [ mask_on ]
                glow_changed : bool [ e.mask_bg.x != e.mask_glow.x || e.mask_bg.y != e.mask_glow.y || e.mask_bg.z != e.mask_glow.z || e.mask_bg.w != e.mask_glow.w ]
                # during a seam drag the cache re-rasters every frame (sub-pixel bounds shifts)
                # while ew (integer) can hold for a frame — refresh the fade mask in lockstep so
                # its edge extent never lags the cache, else the masked glow reads a stale extent
                # and squishes. cheap: only while dragging, and the mask is a small canvas.
                if [ !e.mask_canvas || e.mask_w != ew || e.mask_h != eh || glow_changed || vk.sync_paints ]
                    # size the mask to the SRC cache's actual (quantized) texture and
                    # give it the same logical content_w/h, so draw_canvas_masked's
                    # shared uv (content/texture) maps both identically — otherwise the
                    # fade samples the wrong place when the cache is quantized.
                    # cache.width is already device pixels; Canvas init multiplies the
                    # constructor size by scale, so pre-divide to land exactly on it.
                    mcs : f32 [ (a.scale > 0.0) ? a.scale : 1.0 ]
                    if [ !e.mask_canvas ]
                        # create the Render ONCE; afterwards we only resize (quantized, so a
                        # logical-size change within capacity is a no-op realloc) and re-paint
                        # the fade. recreating it per frame churned a framebuffer (~20ms each)
                        # on every drag step — the resize 10fps. quantize=true mirrors the
                        # cache's UV layout so the shared content/texture uv still aligns.
                        e.mask_canvas = Canvas [ w: a, vk: vk, format: Pixel.rgba8, width: i32[ e.cache_canvas.width / mcs ], height: i32[ e.cache_canvas.height / mcs ], load_existing: true, quantize: true ]
                        e.mask_canvas.update[]
                    el
                        # match the cache's capacity (same quantized logical size) — within a
                        # 64px bucket this changes only content_w/h + uv, no GPU realloc.
                        e.mask_canvas.resize[ i32[ e.cache_canvas.width / mcs ], i32[ e.cache_canvas.height / mcs ] ]
                    e.mask_canvas.content_w = ew
                    e.mask_canvas.content_h = eh
                    e.mask_w = ew
                    e.mask_h = eh
                    e.mask_canvas.reset[ vec4f[ 0.0, 0.0, 0.0, 1.0 ] ]
                    e.mask_canvas.save[]
                    # linear falloff so the fade is a straight ramp on the edges
                    e.mask_canvas.glow_falloff[ 1.0 ]
                    e.mask_canvas.fill_color[ rgba['#fff'] ]
                    # mask_glow = (top, right, bottom, left) px
                    e.mask_canvas.inner_glow_sides[ rgba['#000'],
                        e.mask_glow.x, e.mask_glow.y, e.mask_glow.z, e.mask_glow.w ]
                    # mask_inset = (top, right, bottom, left) px: shrink the rect
                    # so the fade starts inset; outside stays fully masked.
                    mrx : f32 [ e.mask_inset.w ]
                    mry : f32 [ e.mask_inset.x ]
                    mrw : f32 [ f32 ew - e.mask_inset.w - e.mask_inset.y ]
                    mrh : f32 [ f32 eh - e.mask_inset.x - e.mask_inset.z ]
                    e.mask_canvas.rect_to[ mrx, mry, mrw, mrh ]
                    e.mask_canvas.paint[]
                    # keep a left strip fully opaque (e.g. a fixed gutter) — the left
                    # fade then originates just right of it. clear the inner glow first
                    # so this strip is PURE white (otherwise it inherits the fade's glow
                    # on its own edges and the gutter dims).
                    if [ e.mask_keep_l > 0.0 ]
                        e.mask_canvas.inner_glow_sides[ rgba['#fff'], 0.0, 0.0, 0.0, 0.0 ]
                        e.mask_canvas.fill_color[ rgba['#fff'] ]
                        e.mask_canvas.rect_to[ 0.0, mry, e.mask_keep_l, mrh ]
                        e.mask_canvas.paint[]
                    e.mask_canvas.restore[]
                    e.mask_bg = e.mask_glow
                cv.draw_canvas_masked[ e.cache_canvas, e.mask_canvas,
                    0.0 - f32 [ e.cache_ox ], 0.0 - f32 [ e.cache_oy ], f32 [ ew ], f32 [ eh ] ]
            el
                cv.draw_canvas[ e.cache_canvas, 0.0 - f32 [ e.cache_ox ], 0.0 - f32 [ e.cache_oy ], f32 [ ew ], f32 [ eh ] ]
            # scrollbar over the freshly-blitted (edge-faded) content, in element-local
            # space, with NO mask. runs every screen frame so the bar can widen/animate
            # without the element having to redraw its whole cache.
            sbl : ScrollLayer (e.layers) ? (e.layers['scrollbar'] to ScrollLayer) : null
            if [ sbl && sbl.ctype == stage && !sbl.hide ]
                sbl.bounds = (sbl.area) ? sbl.area.rectangle[ e.bounds, null, null, e.fc, false ] : e.bounds.copy[]
                sbl.bounds.x -= e.bounds.x
                sbl.bounds.y -= e.bounds.y
                cv.save[ ]
                sbl.draw[ cv ]
                cv.restore[ ]

        last_2 : element
        # paint normal children first, then topmost children over them
        for [ ee: element, id: string ] in e.elements
            if [ ee.topmost ] continue
            cv.save[]
            if [ ee.bounds ]
                cv.translate[ ee.bounds.x, ee.bounds.y ]
            draw_element[ ee, stage, last_2 ]
            last_2 = ee
            cv.restore[]
        for [ ee: element, id: string ] in e.elements
            if [ !ee.topmost ] continue
            cv.save[]
            if [ ee.bounds ]
                cv.translate[ ee.bounds.x, ee.bounds.y ]
            draw_element[ ee, stage, last_2 ]
            last_2 = ee
            cv.restore[]


abstract media_app trinity
    public background   : string
    public title        : string
    # the working directory the app started in (its install/share/<app> dir, set
    # by the host before any app code runs). resources/config resolve against it.
    public startup_path : path
    intern msaa_samples : i64
    intern istroke      : f32 0
    intern ifill        : f32 0

    public func on_canvas [ cv: Canvas ]
        return

    # input event hooks. return true to swallow; otherwise just observe.
    # ev.target is the element the event was dispatched to (null if none).
    # elements get these virtuals first (they can intercept); if the element
    # returns false or there's no target, the app sees it here.
    public func on_click   [ ev: Event ] return
    public func on_press   [ ev: Event ] return
    public func on_release [ ev: Event ] return
    public func on_hover   [ ev: Event ] return
    public func on_leave   [ ev: Event ] return
    public func on_move    [ ev: Event ] return
    public func on_wheel   [ ev: Event ] return
    public func on_key     [ ev: Event ] return
    public func on_char    [ ev: Event ] return

    public func on_render  [ w: Window ] -> Elements
        return Elements [
            "root": element [
                elements: [
                    "one": Button[],
                    "two": Button[]
                ]
            ]
        ]

    func init         [] return
    func load_scene   [] return
    func update_scene [] return
         
    # read the terminal size (cells) into width/height for console mode. literal
    # TIOCGWINSZ request per platform (the macro is a sizeof-based _IOR the compiler
    # can't fold; the wrong value makes ioctl fail on the tty).
    func console_size []
        ws : winsize
        ok : bool [ ioctl[ 1, 0x40087468, ref ws ] == 0 && ws.ws_col > 0 ]
        if [ !ok ] ok = ioctl[ 1, 0x5413, ref ws ] == 0 && ws.ws_col > 0
        if [ ok ]
            width  = i32 ws.ws_col
            height = i32 ws.ws_row
        if [ width  <= 0 ] width  = 80
        if [ height <= 0 ] height = 24

    func run[]
        # the cwd we launched in (Au captured it in engage before cd'ing to share).
        startup_path = path.path_startup[]
        type : typeid[a]
        background_type : Au.find_type[ (background) ? background.chars : null, null ]
        # console mode: no vk context, no GLFW window — host the tree + layout only.
        if [ console ]
            console_size[]
            cwin : Window[ app_object: a, title:(title) ?? type.ident, st: Style [ a ],
                width:width, height:height, background_type:background_type, console: true ]
            cwin.hold[]
            w = cwin
            cwin.console_input_open[]
            render *[]
            cwin.restyle = true
            super.run[]
            return
        window : Window[ app_object: a, title:(title) ?? type.ident, st: Style [ a ],
            width:(width) ?? 1888, height:(height) ?? 888, background_type:background_type ]
        expect window.vk, "context didnt work"
        window.hold[]
        w = window
        w.update *[]
        render   *[]
        w.resize[w.width, w.height]
        # the startup resize ran update[] with resizing=true, so on_compose skipped the
        # first paint; nothing else flags a repaint, so the loop would idle until the
        # first mouse event. force the initial paint here (resizing is false again now).
        window.restyle = true
        super.run[]

    # 22
    func render[]
        if [ console ]
            update_scene*[]
            cwin : Window[w]
            cwin.draw_console[]
            frames += 1
            return
        window : Window[w]
        wa : bool [ window.will_animate ]
        window.will_animate = false
        # full-speed test: render every frame regardless of the dirty/animation gate.
        if [ true ]
            u0 : i64 [ epoch_micros[] ]
            update_scene*[]
            u1 : i64 [ epoch_micros[] ]
            window.draw[]
            vk.update_us += u1 - u0
            vk.draw_us   += epoch_micros[] - u1
            frames += 1


# scrolling requires defined children Region
Layer Children
    public scroll : vec2f

Layer ScrollLayer
    public thumb_color  : string
    public thumb_w      : f32
    public thumb_min_h  : f32
    public thumb_radius : f32
    # geometry cached each draw so the owning element's press/drag can hit-test and
    # map a mouse-y to a scroll offset (drag_to). all in element-local screen space.
    mutable thumb_y_px  : f32
    mutable thumb_h_px  : f32
    mutable track_vis   : f32
    mutable scroll_max  : f32
    mutable grab_w      : f32
    # offset from the thumb top to where it was grabbed — kept constant during a
    # drag so the thumb doesn't snap its center to the cursor (relative grab).
    mutable grab_off    : f32
    # set by the owning element while the thumb is grabbed — pins the bar to its
    # full expanded state (max width, squared, border) for the whole drag.
    public  active      : bool

    func draw [ cv: Canvas ]
        e : element [ parent ]
        if [ !e || e.content_h <= 0.0 || e.bounds.h >= e.content_h ] return
        # align the track top with the content layer — it may be pushed down
        # below our own area top (e.g. the editor's find/replace bar adds a row).
        top     : f32 [ bounds.y ]
        cl      : Layer (e.layers) ? e.layers['content'] : null
        if [ cl && cl.bounds ] top = cl.bounds.y
        total_h : f32 [ e.content_h ]
        vis_h   : f32 [ bounds.y + bounds.h - top ]
        ratio   : f32 [ vis_h / total_h ]
        min_h   : f32 [ (thumb_min_h > 0.0) ? thumb_min_h : 32.0 ]
        thumb_h : f32 [ (ratio * vis_h < min_h) ? min_h : ratio * vis_h ]
        travel  : f32 [ vis_h - thumb_h ]
        max_sc  : f32 [ total_h - vis_h ]
        thumb_y : f32 [ top + (max_sc > 0.0) ? (e.scroll.y / max_sc) * travel : 0.0 ]
        base_w  : f32 [ thumb_w ]
        # proximity: widen + un-round as the mouse nears the bar (within base_w*2 of
        # the right edge). cursor is element-normalized and only valid while hovered,
        # so the bar rests thin + rounded when the mouse is away.
        # widen over a generous approach distance so the bar visibly responds as the
        # mouse nears it (not just in the last few px). grab precision is handled
        # separately by the element's hit zone.
        # approach distance over which the bar widens — flat px (not bar-relative) so
        # a thin bar still has a comfortable zone. matches move_event's frame zone.
        near : f32 [ 90.0 ]
        prox : f32 [ 0.0 ]
        if [ e.hovered ]
            from_right : f32 [ (1.0 - e.cursor.x) * e.bounds.w ]
            prox = clamp[ 1.0 - from_right / near, 0.0, 1.0 ]
        # while grabbed, stay fully expanded no matter where the cursor drifts
        if [ active ] prox = 1.0
        eff_w : f32 [ base_w * (1.0 + prox) ]
        r     : f32 [ thumb_radius * (1.0 - prox) ]
        thumb_x : f32 [ bounds.x + bounds.w - eff_w ]
        # cache geometry for the element's drag handling. track_vis is the track
        # height starting at the content top, which is also where mouse-y is measured
        # from (ev.mouse.pos.y - content_layer.bounds.y), so drag_to needs no offset.
        # thumb_y_px is TRACK-RELATIVE (0 = content/track top) so it matches the
        # mouse-y the element passes to drag_to (also track-relative).
        thumb_y_px = thumb_y - top
        thumb_h_px = thumb_h
        track_vis  = vis_h
        scroll_max = max_sc
        grab_w     = base_w * 2.0 + 6.0
        # while widening, fade in a 1px border around the whole scroll area (the
        # widened track column) to visually contain the scrollbar. #fff2 at full prox.
        if [ prox > 0.0 ]
            cv.fill_color  [ rgba['#0000'] ]
            cv.stroke_color[ rgba[ r:1.0, g:1.0, b:1.0, a: 0.133 * prox ] ]
            cv.stroke_width[ 1.0 ]
            cv.rect_to     [ thumb_x, top, eff_w, vis_h ]
            cv.paint       [ ]
            cv.stroke_width[ 0.0 ]
        cv.fill_color[ thumb_color ]
        cv.rounded_rect[ thumb_x, thumb_y, eff_w, thumb_h, r, r, r, r ]
        cv.paint[]

    # map a mouse-y (element-local screen space) to a scroll offset, centering the
    # thumb under the cursor. returns -1 when there's nothing to scroll. the owning
    # element applies the result to its own scroll while the bar is grabbed.
    # map a (track-relative) mouse-y to a scroll offset, keeping the grab offset so
    # the thumb tracks the cursor without snapping. returns -1 if nothing to scroll.
    public func drag_to [ my: f32 ] -> f32
        travel : f32 [ track_vis - thumb_h_px ]
        if [ travel <= 0.0 ] return -1.0
        thumb_top : f32 [ my - grab_off ]
        return clamp[ (thumb_top / travel) * scroll_max, 0.0, scroll_max ]

    # call on grab: record where in the thumb the cursor landed (relative grab when
    # on the thumb; centered when clicking the empty track).
    public func grab_at [ my: f32 ]
        if [ my >= thumb_y_px && my <= thumb_y_px + thumb_h_px ]
            grab_off = my - thumb_y_px
        el
            grab_off = thumb_h_px * 0.5


element View
    func render[] -> Elements
        return null

element Group
    func render[] -> Elements
