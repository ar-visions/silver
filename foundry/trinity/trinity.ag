# window ref creates window-sized texture
# last render in list draws to swap-image
# renders to texture or swap
class target
    public vk              : vk_context
    public w               : window
    public id               : i32
    public wscale           : f32
    public width            : i32
    public height           : i32
    public reduce           : bool
    public models           : array
    public clear_color      : vec4f
    public reduction        : texture
    public color            : texture
    public depth            : texture
    intern reduce_model     : model
    intern vk_command_buffer                : VkCommandBuffer
    intern vk_swap_image                    : VkImage
    intern vk_fence                         : VkFence
    intern vk_semaphore                     : VkSemaphore
    intern vk_image_available_semaphore     : VkSemaphore
    intern vk_render_finished_semaphore     : VkSemaphore
    intern vk_framebuffer                   : array VkFramebuffer [ 2 ]
    intern vk_render_pass                   : array VkRenderPass  [ 2 ]
    intern last_width : i32
    intern last_height : i32
    public func update [ ] -> none
        w_width:  wscale > 0 ? w.width  * wscale : width
        w_height: wscale > 0 ? w.height * wscale : height
        width  = w_width
        height = w_height
        if [ !width || !height ]
            fault[ "width / height or wscale not set on render target" ]
            exit[ 0 ]
        if [ width == last_width && height == last_height ]
            return
        last_width  = width
        last_height = height
        if [ color ]
            resize[ color, width, height ]
            resize[ depth, width, height ]
            if [ reduce ]
                resize[ reduction, width / 4, height / 4 ]
        el
            color = texture [ vk: vk, w: w, width: width, height: height,
                vk_format: w.surface_format.format, swap: !vk_swap_image,
                surface: Surface_color, vk_image: vk_swap_image ]
            depth = texture [ vk: vk, w: w, width: width, height: height,
                vk_format: VK_FORMAT_D32_SFLOAT, swap: !vk_swap_image ]
            if [ reduce ]
                reduction = texture [ vk: vk, w: w, width: width / 4, height: height / 4,
                    vk_format: w.surface_format.format, swap: !vk_swap_image ]
        if [ !vk_swap_image ]
            transition[ color, VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
            if [ reduce ]
                transition[ reduction, VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
        el
            transition[ color, VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
        for [ i: 0, i < 1 + i32[reduce], i++ ]
            vk_view_attachments: VkImageView[2] [
                i == 0 ? color.vk_image_view : reduction.vk_image_view,
                depth.vk_image_view
            ]
            result: vkCreateFramebuffer[ vk.device, VkFramebufferCreateInfo [
                sType:           VK_STRUCTURE_TYPE_FRAMEBUFFER_CREATE_INFO,
                renderPass:      vk_render_pass[i],
                attachmentCount: i == 0 ? 2 : 1,
                pAttachments:    vk_view_attachments,
                width:           width  / (i == 0 ? 1 : 4),
                height:          height / (i == 0 ? 1 : 4),
                layers:          1
            ], null, ref vk_framebuffer[i] ]
            expect result == VK_SUCCESS, "Failed to create framebuffer"

    public func draw [ ] -> none
        index: u32 [ 0 ]
        for [ i: 0, i < 1 + i32[reduce], i++ ]
            if [ i == 0 && color ]
                transition[ color, VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
            el [ i == 1 && reduction ]
                transition[ reduction, VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
                sync_fence[]
            vkResetFences[ vk.device, 1, ref vk_fence ]
            frame: vk_command_buffer
            vkResetCommandBuffer[ frame, 0 ]
            vkBeginCommandBuffer[ frame, VkCommandBufferBeginInfo [
                sType: VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO,
                flags: VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT
            ]]
            fw: i == 0 ? width  : width  / 4
            fh: i == 0 ? height : height / 4
            vkCmdSetViewport[ frame, 0, 1, VkViewport [
                x: 0.0, y: 0.0,
                width: f32[fw], height: f32[fh],
                minDepth: 0.0, maxDepth: 1.0
            ]]
            vkCmdSetScissor[ frame, 0, 1, VkRect2D [
                offset: VkOffset2D [ 0, 0 ],
                extent: VkExtent2D [ fw, fh ]
            ]]
            clears: VkClearValue[2] [
                VkClearValue [ color: VkClearColorValue [
                    float32: [ clear_color.x, clear_color.y, clear_color.z, clear_color.w ]
                ]],
                VkClearValue [ depthStencil: VkClearDepthStencilValue [ depth: 1.0, stencil: 0 ] ]
            ]
            vkCmdBeginRenderPass[ frame, VkRenderPassBeginInfo [
                sType:           VK_STRUCTURE_TYPE_RENDER_PASS_BEGIN_INFO,
                renderPass:      vk_render_pass[i],
                framebuffer:     vk_framebuffer[i],
                renderArea:      VkRect2D [ offset: VkOffset2D [ 0, 0 ], extent: VkExtent2D [ fw, fh ] ],
                clearValueCount: 2,
                pClearValues:    clears
            ], VK_SUBPASS_CONTENTS_INLINE ]
            if [ i == 0 ]
                for [ m: model ] in models
                    for [ p: pipeline ] in m.pipelines
                        if [ m.transform_count && instanceof[ p.s, PBR ] ]
                            s: PBR [ p.s ]
                            s.model = p.default_model
                            for [ j: 0, j < m.transform_count, j++ ]
                                s.model = mat4f_mul[ ref m.transforms[j], ref s.model ]
                        draw[ p, frame ]
            el
                for [ p: pipeline ] in reduce_model.pipelines
                    draw[ p, frame ]
            vkCmdEndRenderPass[ frame ]
            vkEndCommandBuffer[ frame ]
            s_flags: VkPipelineStageFlags [ VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT ]
            submitInfo: VkSubmitInfo [
                sType:                VK_STRUCTURE_TYPE_SUBMIT_INFO,
                commandBufferCount:   1,
                pCommandBuffers:      ref frame,
                waitSemaphoreCount:   vk_swap_image ? 1 : 0,
                pWaitSemaphores:      vk_swap_image ? ref w.semaphore_frame.vk_image_available_semaphore : null,
                pWaitDstStageMask:    vk_swap_image ? ref s_flags : null,
                signalSemaphoreCount: vk_swap_image ? 1 : 0,
                pSignalSemaphores:    vk_swap_image ? ref w.semaphore_frame.vk_render_finished_semaphore : null
            ]
            vkQueueSubmit[ vk.queue, 1, submitInfo, vk_fence ]

    public func sync_fence [ ] -> none
        result: vkWaitForFences[ vk.device, 1, ref vk_fence, VK_TRUE, UINT64_MAX ]
        expect result == VK_SUCCESS, "fence wait failed"

    func init [ ]
        backbuffer: !vk_swap_image
        if [ !vk ]
            vk = w.vk
        result: vkAllocateCommandBuffers[ vk.device, VkCommandBufferAllocateInfo [
            sType:              VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO,
            commandPool:        vk.command_pool,
            level:              VK_COMMAND_BUFFER_LEVEL_PRIMARY,
            commandBufferCount: 1
        ], ref vk_command_buffer ]
        expect result == VK_SUCCESS, "failed to allocate command buffers"
        attachments: VkAttachmentDescription[2] [
            VkAttachmentDescription [
                format:         w.surface_format.format,
                samples:        VK_SAMPLE_COUNT_1_BIT,
                loadOp:         VK_ATTACHMENT_LOAD_OP_CLEAR,
                storeOp:        VK_ATTACHMENT_STORE_OP_STORE,
                stencilLoadOp:  VK_ATTACHMENT_LOAD_OP_CLEAR,
                stencilStoreOp: VK_ATTACHMENT_STORE_OP_DONT_CARE,
                initialLayout:  VK_IMAGE_LAYOUT_UNDEFINED,
                finalLayout:    VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL
            ],
            VkAttachmentDescription [
                format:         VK_FORMAT_D32_SFLOAT,
                samples:        VK_SAMPLE_COUNT_1_BIT,
                loadOp:         VK_ATTACHMENT_LOAD_OP_CLEAR,
                storeOp:        VK_ATTACHMENT_STORE_OP_STORE,
                stencilLoadOp:  VK_ATTACHMENT_LOAD_OP_DONT_CARE,
                stencilStoreOp: VK_ATTACHMENT_STORE_OP_STORE,
                initialLayout:  VK_IMAGE_LAYOUT_UNDEFINED,
                finalLayout:    VK_IMAGE_LAYOUT_DEPTH_STENCIL_ATTACHMENT_OPTIMAL
            ]
        ]
        color_ref: VkAttachmentReference [ attachment: 0, layout: VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
        depth_ref: VkAttachmentReference [ attachment: 1, layout: VK_IMAGE_LAYOUT_DEPTH_STENCIL_ATTACHMENT_OPTIMAL ]
        subpass: VkSubpassDescription [
            pipelineBindPoint:       VK_PIPELINE_BIND_POINT_GRAPHICS,
            colorAttachmentCount:    1,
            pColorAttachments:       color_ref,
            pDepthStencilAttachment: depth_ref,
            pResolveAttachments:     null
        ]
        dependencies: VkSubpassDependency[2] [
            VkSubpassDependency [
                srcSubpass:      VK_SUBPASS_EXTERNAL,
                dstSubpass:      0,
                srcStageMask:    VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT,
                dstStageMask:    VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT,
                srcAccessMask:   VK_ACCESS_MEMORY_READ_BIT,
                dstAccessMask:   VK_ACCESS_COLOR_ATTACHMENT_READ_BIT | VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT,
                dependencyFlags: VK_DEPENDENCY_BY_REGION_BIT
            ],
            VkSubpassDependency [
                srcSubpass:      0,
                dstSubpass:      VK_SUBPASS_EXTERNAL,
                srcStageMask:    VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT,
                dstStageMask:    VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT,
                srcAccessMask:   VK_ACCESS_COLOR_ATTACHMENT_READ_BIT | VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT,
                dstAccessMask:   VK_ACCESS_MEMORY_READ_BIT,
                dependencyFlags: VK_DEPENDENCY_BY_REGION_BIT
            ]
        ]
        render_pass_info: VkRenderPassCreateInfo [
            sType:           VK_STRUCTURE_TYPE_RENDER_PASS_CREATE_INFO,
            attachmentCount: 2,
            pAttachments:    attachments,
            subpassCount:    1,
            pSubpasses:      subpass,
            dependencyCount: 2,
            pDependencies:   dependencies
        ]
        for [ i: 0, i < 1 + i32[reduce], i++ ]
            if [ i == 1 ]
                render_pass_info.dependencyCount = 1
                render_pass_info.attachmentCount = 1
                subpass.pDepthStencilAttachment = null
            result = vkCreateRenderPass[ vk.device, render_pass_info, null, ref vk_render_pass[i] ]
            expect result == VK_SUCCESS, "failed to create render pass"
        if [ backbuffer ]
            semaphore_info: VkSemaphoreCreateInfo [ sType: VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO ]
            result = vkCreateSemaphore[ vk.device, semaphore_info, null, ref vk_image_available_semaphore ]
            expect result == VK_SUCCESS, "failed to create image available semaphore"
            result = vkCreateSemaphore[ vk.device, semaphore_info, null, ref vk_render_finished_semaphore ]
            expect result == VK_SUCCESS, "failed to create render finished semaphore"
        result = vkCreateFence[ vk.device, VkFenceCreateInfo [
            sType: VK_STRUCTURE_TYPE_FENCE_CREATE_INFO,
            flags: VK_FENCE_CREATE_SIGNALED_BIT
        ], null, ref vk_fence ]
        expect result == VK_SUCCESS, "failed to create fence"
        if [ reduce ]
            reduce_model = model [ vk: vk, w: w, s: reduce_shader[ vk ], r: self ]
        update[]
        if [ reduce ]
            reduce_model.samplers = m[ "color", color ]
        for [ m: model ] in models
            finish[ m, self, 0 ]
        if [ reduce ]
            finish[ reduce_model, self, 1 ]

    func dealloc [ ]
        for [ i: 0, i < 2, i++ ]
            vkDestroyFramebuffer[ vk.device, vk_framebuffer[i], null ]
            vkDestroyRenderPass[ vk.device, vk_render_pass[i], null ]
        vkDestroyFence[ vk.device, vk_fence, null ]
        vkDestroySemaphore[ vk.device, vk_image_available_semaphore, null ]
        vkDestroySemaphore[ vk.device, vk_render_finished_semaphore, null ]

class app
    public w : window
    public ux : composer
    public vk : vk_context
    public app_context : ctx
    public ason_path : path
    public ason_render : map
    intern ason_modified : i64
    public style : style
    intern arg : object
    public on_render : callback
    public func initialize [ win: window ] -> none
        ux.w = win
        win.ux = ux
        update_canvas[ win ]
        app_render[ self ]
        resize[ win, win.extent.width, win.extent.height ]

    public func run [ ] -> i32
        next_second: epoch_millis[] / 1000
        frames: 0
        while [ !glfwWindowShouldClose[ w.window ] ]
            glfwPollEvents[]
            if [ next_second != epoch_millis[] / 1000 ]
                next_second = epoch_millis[] / 1000
                frames = 0
            frames += 1
            app_render[ self ]
            recycle[]
        return 0

    func init [ ]
        vk    = vk_context[]
        style = style [ object[ self ] ]
        ux    = composer [ app: self ]
        ux.style = style
        if [ !on_render ]
            on_render = bind[ self, self, false, typeid[ map ], typeid[ window ], null, "render" ]
        if [ !on_render ]
            ty: Au_t [ isa[ self ] ]
            ason_path = path 'apps/{ty.name}.ason'
            expect file_exists[ "%o", ason_path ], "app path not found: %o", ason_path

    func dealloc [ ]


class window
    intern window               : handle
    expect width                : u32
    expect height               : u32
    public vk                   : vk_context
    public mouse                : vec2f
    public ux                   : composer
    public element_targets      : map
    public list                 : array
    intern swap_renders         : array
    intern swap_model           : model
    intern vk_swap_images       : ref VkImage
    intern surface              : VkSurfaceKHR
    intern swapchain            : VkSwapchainKHR
    intern swap_targets         : array
    intern surface_caps         : ref VkSurfaceCapabilitiesKHR
    intern surface_format       : VkSurfaceFormatKHR
    intern present_mode         : VkPresentModeKHR
    intern extent               : VkExtent2D
    intern swap_render_current  : target
    intern semaphore_frame      : target
    intern swap_image_count     : u32
    intern swap_image_current   : u32
    intern ev                   : event
    public app_object           : app
    public compose              : sk
    public colorize             : sk
    public overlay              : sk
    public glyph                : sk
    public format               : Pixel
    public title                : string
    public debug_value          : f32
    public current_swap_index   : i32
    intern resized              : bool
    public backbuffer           : bool
    intern last_target          : target
    public m_reduce             : model
    public r_reduce             : target
    public m_reduce0            : model
    public r_reduce0            : target
    public m_reduce1            : model
    public r_reduce1            : target
    public m_reduce2            : model
    public r_reduce2            : target
    public m_reduce3            : model
    public r_reduce3            : target
    public m_blur_v             : model
    public r_blur_v             : target
    public m_blur               : model
    public r_blur               : target
    public m_frost_v            : model
    public r_frost_v            : target
    public m_frost              : model
    public r_frost              : target
    public m_view               : model
    public r_view               : target

    public func update_canvas [ ] -> none
        if [ compose ]
            resize[ compose,  width, height ]
            resize[ colorize, width, height ]
            resize[ overlay,  width, height ]
            resize[ glyph,    width, height ]
        el
            compose  = sk [ vk: vk, format: Pixel_rgba8, :width, :height ]
            colorize = sk [ vk: vk, format: Pixel_rgba8, :width, :height ]
            overlay  = sk [ vk: vk, format: Pixel_rgba8, :width, :height ]
            glyph    = sk [ vk: vk, format: Pixel_rgba8, :width, :height ]
        clear[ compose,  string[ "#008" ] ]
        clear[ colorize, string[ "#fff" ] ]
        clear[ overlay,  string[ "#fff0" ] ]
        clear[ glyph,    string[ "#000" ] ]
        sk_sync[]

    public func resize [ w_new: i32, h_new: i32 ] -> none
        vkDeviceWaitIdle[ vk.device ]
        width  = w_new
        height = h_new
        extent.width  = w_new
        extent.height = h_new

        for [ r: target, id: string ] in element_targets
            update[ r ]
            if [ resized && r.models ]
                for [ m: model ] in r.models
                    rebind_model[ m ]
        for [ r: target ] in list
            update[ r ]
            if [ resized && r.models ]
                for [ m: model ] in r.models
                    rebind_model[ m ]
        resized = true
        if [ !backbuffer ]
            capabilities: VkSurfaceCapabilitiesKHR
            vkGetPhysicalDeviceSurfaceCapabilitiesKHR[ vk.physical_device, surface, ref capabilities ]
            if [ capabilities.currentExtent.width != UINT32_MAX ]
                width  = capabilities.currentExtent.width
                height = capabilities.currentExtent.height
        if [ !backbuffer ]
            old_swapchain: swapchain
            result: vkCreateSwapchainKHR[ vk.device, VkSwapchainCreateInfoKHR [
                sType:                 VK_STRUCTURE_TYPE_SWAPCHAIN_CREATE_INFO_KHR,
                surface:               surface,
                minImageCount:         surface_caps.minImageCount,
                imageFormat:           surface_format.format,
                imageColorSpace:       surface_format.colorSpace,
                imageExtent:           VkExtent2D [ width, height ],
                imageArrayLayers:      1,
                imageUsage:            VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT,
                imageSharingMode:      VK_SHARING_MODE_EXCLUSIVE,
                preTransform:          surface_caps.currentTransform,
                compositeAlpha:        VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR,
                presentMode:           present_mode,
                clipped:               VK_TRUE,
                oldSwapchain:          old_swapchain != VK_NULL_HANDLE ? old_swapchain : VK_NULL_HANDLE
            ], null, ref swapchain ]
            expect result == VK_SUCCESS, "Failed to create swapchain"
            if [ old_swapchain != VK_NULL_HANDLE ]
                vkDestroySwapchainKHR[ vk.device, old_swapchain, null ]
        
        if [ !backbuffer ]
            if [ !swap_model ]
                top: last_target
                expect top, "last_target must be set"
                swap_model = model [ vk: vk, w: self, samplers: map_of[ "color", top, null ] ]
            vkGetSwapchainImagesKHR[ vk.device, swapchain, ref swap_image_count, null ]
            if [ !vk_swap_images ]
                vk_swap_images = malloc[ swap_image_count * sizeof[ VkImage ] ]
            if [ !swap_renders ]
                swap_renders = array [ alloc: swap_image_count ]
            vkGetSwapchainImagesKHR[ vk.device, swapchain, ref swap_image_count, vk_swap_images ]
            swap_image_current = 0
            for [ i: 0, i < swap_image_count, i++ ]
                swap_renders.origin[i].drop[]
                swap_renders.origin[i] = target [
                    vk: vk, w: self,
                    width:         width,
                    height:        height,
                    vk_swap_image: vk_swap_images[i],
                    models:        a[ swap_model ]
                ]
            swap_renders.count = swap_image_count
            semaphore_frame = first[ swap_renders ]
            swap_render_current = swap_renders.origin[0]
        
        update_canvas[]

    public func final_target [ ] -> target
        return last[ list ]

    public func draw [ ] -> none
        for [ r: target, id: string ] in element_targets
            draw[ r ]
            sync_fence[ r ]
        for [ r: target ] in list
            draw[ r ]
            sync_fence[ r ]
        if [ swap_renders ]
            result: vkAcquireNextImageKHR[ vk.device, swapchain, UINT64_MAX,
                semaphore_frame.vk_image_available_semaphore, VK_NULL_HANDLE, ref swap_image_current ]
            if [ result == VK_ERROR_OUT_OF_DATE_KHR || result == VK_SUBOPTIMAL_KHR ]
                handle_glfw_framebuffer_size[ window, width, height ]
            el
                expect result == VK_SUCCESS, "failed to acquire swapchain image"
                swap_render_current = swap_renders.origin[swap_image_current]
                transition[ last_target.color, VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
                transition[ swap_render_current.color, VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
                draw[ swap_render_current ]
                transition[ last_target.color, VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
                presentInfo: VkPresentInfoKHR [
                    sType:              VK_STRUCTURE_TYPE_PRESENT_INFO_KHR,
                    swapchainCount:     1,
                    pSwapchains:        ref swapchain,
                    pImageIndices:      ref swap_image_current,
                    waitSemaphoreCount: 1,
                    pWaitSemaphores:    ref semaphore_frame.vk_render_finished_semaphore
                ]
                transition[ swap_render_current.color, VK_IMAGE_LAYOUT_PRESENT_SRC_KHR ]
                result = vkQueuePresentKHR[ vk.queue, presentInfo ]
                transition[ swap_render_current.color, VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
                semaphore_frame = swap_renders.origin[semaphore_frame == first[ swap_renders ]]
                if [ result != VK_ERROR_OUT_OF_DATE_KHR && result != VK_SUBOPTIMAL_KHR ]
                    expect result == VK_SUCCESS, "present"
                    sync_fence[ swap_render_current ]

    public func draw_element [ e: element ] -> none
        expect instanceof[ e, element ], "e is not an element"
        canvas_arr: sk[4] [ overlay, compose, colorize, glyph ]
        rel: e.parent ?
            rect [ x: 0, y: 0, w: e.parent.bounds.w, h: e.parent.bounds.h ] :
            rect [ x: 0, y: 0, w: width, h: height ]
        drop[ e.bounds ]
        drop[ e.text_bounds ]
        drop[ e.border_bounds ]
        drop[ e.child_bounds ]
        drop[ e.clip_bounds ]
        e.bounds        = rectangle_offset[ e.area,        rel ]
        e.text_bounds   = rectangle_offset[ e.text_area,   e.bounds ]
        e.border_bounds = rectangle_offset[ e.border_area, e.bounds ]
        e.child_bounds  = rectangle_offset[ e.child_area,  e.bounds ]
        e.clip_bounds   = rectangle_offset[ e.clip_area,   e.bounds ]
        if [ e.fill_color ]
            cv: canvas_arr[e.fill_canvas]
            b: e.bounds
            rounded_rect_to[ cv, b.x, b.y, b.w, b.h, e.fill_radius_x, e.fill_radius_y ]
            save[ cv ]
            fill_color[ cv, e.fill_color ]
            blur_radius[ cv, e.fill_blur ]
            draw_fill[ cv ]
            blur_radius[ cv, 0 ]
            restore[ cv ]
        for [ i: 0, i < 3, i++ ]
            cv: canvas_arr[i]
            save[ cv ]
            translate[ cv, e.clip_bounds.x, e.clip_bounds.y ]
            r: rect [ x: 0, y: 0, w: e.clip_bounds.w, h: e.clip_bounds.h ]
            if [ e.border_clip ]
                clip[ cv, r, e.border_radius_x, e.border_radius_y ]
        if [ e.border_color && e.border_size > 0 ]
            cv: canvas_arr[e.border_canvas]
            save[ cv ]
            stroke_size[ cv, e.border_size ]
            stroke_cap[ cv, e.border_cap ]
            stroke_join[ cv, e.border_join ]
            b: e.border_bounds
            rounded_rect_to[ cv, b.x - e.clip_bounds.x, b.y - e.clip_bounds.y,
                b.w, b.h, e.border_radius_x, e.border_radius_y ]
            stroke_color[ cv, e.border_color ]
            stroke_size[ cv, e.border_size ]
            blur_radius[ cv, e.border_blur ]
            draw_stroke[ cv ]
            blur_radius[ cv, 0.0 ]
            restore[ cv ]
        content: instanceof[ e.content, string ]
        if [ content && e.text_color ]
            cv: glyph
            save[ cv ]
            txt: e.text_bounds
            c: e.clip_bounds
            r: rect [ x: txt.x - c.x, y: txt.y - c.y, w: txt.w, h: txt.h ]
            al: vec2f [ e.text_align_x, e.text_align_y ]
            stroke_size[ cv, 0 ]
            if [ e.text_shadow_color && e.text_shadow_color.a > 0.0 ]
                fill_color[ cv, e.text_shadow_color ]
                offset: vec2f [ e.text_shadow_x, e.text_shadow_y ]
                blur_radius[ cv, 2.0 ]
                draw_text[ cv, content, r, al, offset, e.text_ellipsis ]
            fill_color[ cv, e.text_color ]
            offset: vec2f [ 0, 0 ]
            blur_radius[ cv, e.fill_blur ]
            draw_text[ cv, content, r, al, offset, e.text_ellipsis ]
            restore[ cv ]
        draw[ e, self ]
        for [ ee: element, id: string ] in e.origin
            draw_element[ self, ee ]
        for [ i: 0, i < 3, i++ ]
            cv: canvas_arr[i]
            restore[ cv ]

    public cast image
        color_size: format == Pixel.rgbaf32 ? 16 : 4
        image_size: width * height * color_size
        b: buffer [ vk: vk, size: image_size,
            u_dst: true, m_host_visible: true, m_host_coherent: true ]
        b.transfer[ a ]
        d: b.mmap[]
        result: image [
            width:   width,
            height:  height,
            format:  format,
            surface: Surface.color
        ]
        memcpy[ data[ result ], d, image_size ]
        unmap[ b ]
        return result

    func init [ ]
        if [ !format ]
            format = Pixel.rgba8
        if [ !list ]
            list = array [ alloc: 32 ]
        if [ !element_targets ]
            element_targets = map[]
        ev = event[]

        if [ !width ]
            width  = 1200
            height = 1200

        # glfw window + vulkan surface
        if [ !backbuffer ]
            glfwWindowHint[ GLFW_CLIENT_API, GLFW_NO_API ]
            window = glfwCreateWindow[ width, height,
                title ? cstring[ title ] : "trinity", null, null ]
            expect window, "Failed to create GLFW window"

            # glfw callbacks
            glfwSetWindowUserPointer[ window, handle[ a ] ]
            glfwSetKeyCallback[ window, handle_glfw_key ]
            glfwSetMouseButtonCallback[ window, handle_glfw_mouse ]
            glfwSetCursorPosCallback[ window, handle_glfw_cursor ]
            glfwSetCharCallback[ window, handle_glfw_char ]
            glfwSetFramebufferSizeCallback[ window, handle_glfw_framebuffer_size ]

            # vulkan surface
            result: glfwCreateWindowSurface[ vk.instance, window, null, ref surface ]
            expect result == VK_SUCCESS, "Failed to create Vulkan surface"

        # finish device
        vk.finish

        # surface capabilities + formats
        if [ !backbuffer ]
            surface_caps = calloc[ 1, sizeof[ VkSurfaceCapabilitiesKHR ] ]
            result: vkGetPhysicalDeviceSurfaceCapabilitiesKHR[ vk.physical_device, surface, surface_caps ]
            expect result == VK_SUCCESS, "Failed to query surface capabilities"

            # surface format
            format_count: u32 [ 0 ]
            vkGetPhysicalDeviceSurfaceFormatsKHR[ vk.physical_device, surface, ref format_count, null ]
            expect format_count > 0, "No surface formats found"
            formats: ref VkSurfaceFormatKHR [ malloc[ format_count * sizeof[ VkSurfaceFormatKHR ] ] ]
            vkGetPhysicalDeviceSurfaceFormatsKHR[ vk.physical_device, surface, ref format_count, formats ]
            surface_format = formats[0]
            for [ i: u32 0, i < format_count, i++ ]
                if [ formats[i].format == VK_FORMAT_B8G8R8A8_UNORM ]
                    surface_format = formats[i]
            free[ formats ]

            # present mode
            present_mode_count: u32 [ 0 ]
            vkGetPhysicalDeviceSurfacePresentModesKHR[
                vk.physical_device, surface, ref present_mode_count, null ]
            expect present_mode_count > 0, "No present modes found"
            present_modes: ref VkPresentModeKHR [
                malloc[ present_mode_count * sizeof[ VkPresentModeKHR ] ] ]
            vkGetPhysicalDeviceSurfacePresentModesKHR[
                vk.physical_device, surface, ref present_mode_count, present_modes ]
            present_mode = VK_PRESENT_MODE_FIFO_KHR
            for [ i: u32 0, i < present_mode_count, i++ ]
                if [ present_modes[i] == VK_PRESENT_MODE_MAILBOX_KHR ]
                    present_mode = VK_PRESENT_MODE_MAILBOX_KHR
                    break
            free[ present_modes ]

            # initial window size
            w_i: i32
            h_i: i32
            glfwGetWindowSize[ window, ref w_i, ref h_i ]
            extent.width  = u32[ w_i ]
            extent.height = u32[ h_i ]
        el
            surface_format.format     = format == Pixel_rgbaf32 ? VK_FORMAT_R32G32B32A32_SFLOAT : VK_FORMAT_R8G8B8A8_UNORM
            surface_format.colorSpace = VK_COLOR_SPACE_SRGB_NONLINEAR_KHR
            extent.width  = width
            extent.height = height

    func dealloc [ ]
        if [ !backbuffer ]
            vkDestroySwapchainKHR[ vk.device, swapchain, null ]
            vkDestroySurfaceKHR[ vk.instance, surface, null ]
            glfwDestroyWindow[ window ]

class SVG
    public w        : f32
    public h        : f32
    public rw       : f32
    public rh       : f32
    public svg_dom  : handle
    func dealloc[]

class draw_state
    public blur_radius          : f32
    public stroke_size          : f32
    public stroke_cap           : cap
    public stroke_join          : join
    public stroke_miter_limit   : f32
    public stroke_dash_offset   : f32
    public font                 : font
    public tx                   : texture
    public x                    : f32
    public y                    : f32
    public w                    : f32
    public h                    : f32
    public fill_color           : u32
    public stroke_color         : u32
    public opacity              : f32
    public func set_default [ ] -> none
        font         = hold[ font [ size: 22, uri: path 'fonts/Sofia-Sans-Condensed.ttf' ] ]
        stroke_cap   = cap_round
        stroke_join  = join_round
        stroke_size  = 0
        fill_color   = sk_color[ object[ string[ "#000" ] ] ]
        stroke_color = sk_color[ object[ string[ "#000" ] ] ]
        opacity      = 1.0

image canvas
    expect vk    : vk_context
    public tx    : texture
    public state : array draw_state
    interface func save            [ ] -> none
    interface func restore         [ ] -> none
    interface func move_to         [ f32  f32 ] -> none
    interface func line_to         [ f32  f32 ] -> none
    interface func arc_to          [ f32, f32, f32, f32, f32 ] -> none
    interface func arc             [ f32, f32, f32, f32, f32 ] -> none
    interface func rect_to         [ f32 f32 f32 f32 ] -> none
    interface func rounded_rect_to [ f32, f32, f32, f32, f32, f32 ] -> none
    interface func fill_color      [ object ] -> none
    interface func stroke_color    [ object ] -> none
    interface func clear           [ object ] -> none
    interface func set_stroke      [ stroke ] -> none
    interface func set_font        [ font ] -> none
    interface func cubic           [ f32, f32, f32, f32, f32, f32 ] -> none
    interface func quadratic       [ f32 f32 f32 f32 ] -> none
    interface func draw_fill       [ ] -> none
    interface func draw_stroke     [ ] -> none
    interface func draw_fill_preserve [ ] -> none
    interface func draw_stroke_preserve [ ] -> none
    interface func blur_radius [ f32 ] -> none
    interface func prepare [ ] -> none
    interface func set_texture [ texture ] -> none
    interface func translate [ f32  f32 ] -> none
    interface func scale [ f32 ] -> none
    interface func clip [ rect f32 f32 ] -> none
    interface func stroke_size [ f32 ] -> none
    interface func stroke_cap [ cap ] -> none
    interface func stroke_join [ join ] -> none
    interface func stroke_miter_limit [ f32 ] -> none
    interface func stroke_dash_offset [ f32 ] -> none
    resize[]

struct text_metrics
    w : f32
    h : f32
    ascent      : f32
    descent     : f32
    line_height : f32
    cap_height  : f32

# intern members resolve size once

canvas sk
    intern sk_context : ARef
    intern sk_surface : ARef
    intern sk_canvas : ARef
    intern sk_path : ARef
    intern once         : bool
    intern skia         : ref Skia
    intern vk_layout    : VkImageLayout
    public func save            [ ] -> none
    public func restore         [ ] -> none
    public func draw_svg        [ SVG rect vec2f vec2f ] -> none
    public func draw_image      [ image rect vec2f vec2f ] -> none
    public func measure         [ string ] -> text_metrics
    public func draw_text       [ string, rect, vec2f, vec2f, bool ] -> rect
    public func move_to         [ f32  f32 ]                -> none
    public func line_to         [ f32  f32 ]                -> none
    public func arc_to          [ f32, f32, f32, f32, f32 ] -> none
    public func arc             [ f32, f32, f32, f32, f32 ] -> none
    public func rect_to         [ f32 f32 f32 f32 ]         -> none
    public func rounded_rect_to [ f32, f32, f32, f32, f32, f32 ] -> none
    public func fill_color      [ object ] -> none
    public func clear           [ object ] -> none
    public func set_font        [ font ]   -> none
    public func cubic           [ f32, f32, f32, f32, f32, f32 ] -> none
    public func quadratic       [ f32 f32 f32 f32 ] -> none
    public func draw_fill       [ ] -> none
    public func draw_stroke     [ ] -> none
    public func draw_fill_preserve   [ ] -> none
    public func draw_stroke_preserve [ ] -> none
    public func blur_radius [ f32 ] -> none
    public func prepare [ ] -> none
    public func translate [ f32  f32 ] -> none
    public func scale [ f32 ] -> none
    public func clip [ rect f32 f32 ] -> none
    public func set_texture [ texture ] -> none
    public func stroke_color [ object ] -> none
    public func stroke_size [ f32 ] -> none
    public func stroke_cap [ cap ] -> none
    public func stroke_join [ join ] -> none
    public func stroke_miter_limit [ f32 ] -> none
    public func stroke_dash_offset [ f32 ] -> none
    public func opacity [ f32 ] -> none
    public func ellipsis [ string rect ARef ] -> string
    static func sync [ ] -> none
    func resize  [ i32 i32 ]
    func init    [ ]
    func dealloc [ ]
declare_class_3(sk, canvas, image)

func sk_sync_all [] -> none

# command class moved to vulkan.ag

    func dealloc [ ]
        vkFreeCommandBuffers[ vk.device, vk.command_pool, 1, ref vk ]


# texture class moved to vulkan.ag

enum shader_local
    _undefined : 0

struct vertex_member_t
    type    : Au_t
    ac      : Accessor
    size    : i64
    offset  : i64

class gpu
    public vk            : vk_context
    expect name          : cstr
    public sampler       : image
    intern tx            : texture
    public vertex_data   : object
    public index_data    : object
    public members       : ref vertex_member_t
    public member_count  : i32
    public index_size    : i32
    public index_count   : i32
    public vertex_size   : i32
    public vertex_count  : i32
    intern vertex        : buffer
    intern index         : buffer
    intern vk_image      : VkImage
    intern vk_image_view : VkImageView
    intern vk_sampler    : VkSampler
    intern vma_alloc     : VmaAllocation
    public compute       : bool
    public   func sync    [ w: window ] -> none
        # vbo/ibo maintained on init only
        if [ vertex_size && !vertex ]
            comp: compute
            vertex = buffer [ vk: vk, size: vertex_size * vertex_count,
                u_storage: comp, u_vertex: !comp, u_dst: !comp, u_shader: !comp,
                m_host_visible: true, m_host_coherent: true,
                data: vertex_data ]
            if [ index_size ]
                index = buffer [ vk: vk, size: index_size * index_count,
                    u_index: true, u_dst: true, u_shader: true,
                    m_host_visible: true, m_host_coherent: true,
                    data: index_data ]
        if [ sampler && !tx ]
            img: instanceof[ sampler, image ]
            t_tx: instanceof[ sampler, texture ]
            re:   instanceof[ sampler, target ]
            expect !re, "target given to samplers"
            if [ t_tx ]
                tx = t_tx
            el [ img && img.user ]
                tx = img.user
            el [ img && img.surface == Surface_environment ]
                tx = environment[ vk, img, vec3f [ 0.0, 1.0, 0.0 ], radians[ 90.0 ] ]
            el
                tx = texture [ vk: vk, sampler: sampler,
                    surface: img ? img.surface : Surface_color ]

    func init [ ]
        if [ vertex_size ]
            vertex_data = A_alloc[ typeid[ i8 ], vertex_size * vertex_count ]
        if [ index_size ]
            index_data = A_alloc[ typeid[ i8 ], index_size * index_count ]

    func dealloc [ ]


class pipeline
    expect vk               : vk_context
    public w                : window
    expect r                : target
    expect s                : shader
    expect name             : string
    public render_id        : i32
    public default_model    : mat4f
    public shader_reloads   : i32
    public material         : Material
    public samplers         : map
    intern resources        : array
    intern shader_uniforms  : uniforms
    intern vbo              : gpu
    intern memory           : gpu
    intern descriptor_layouts : new VkDescriptorSetLayout [ 2 ] # fixed-size descriptor arrays
    intern descriptor_sets    : new VkDescriptorSet       [ 2 ]
    intern descriptor_pool    : VkDescriptorPool
    intern bind               : VkDescriptorSet
    intern vk_render          : VkPipeline
    intern vk_compute         : VkPipeline
    intern layout             : VkPipelineLayout
    public   func rebind [ ] -> none
        drop[ resources ]
        resources = null

    public   func draw [ f: handle ] -> none
        if [ !resources ]
            bind_resources[]
        if [ shader_reload[ s, ref shader_reloads ] ]
            reassemble[]
        for [ g: gpu ] in resources
            if [ g.tx ]
                transition[ g.tx, VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
        frame: VkCommandBuffer [ f ]
        update[ shader_uniforms ]
        if [ vk_compute ]
            vkCmdBindPipeline[ frame, VK_PIPELINE_BIND_POINT_COMPUTE, vk_compute ]
            vkCmdBindDescriptorSets[ frame, VK_PIPELINE_BIND_POINT_COMPUTE,
                layout, 0, 1, ref bind, 0, null ]
            vkCmdDispatch[ frame, memory.vertex_count, 1, 1 ]
        if [ vk_render ]
            vkCmdBindPipeline[ frame, VK_PIPELINE_BIND_POINT_GRAPHICS, vk_render ]
            offsets: stack VkDeviceSize[] [ 0 ]
            vkCmdBindDescriptorSets[ frame, VK_PIPELINE_BIND_POINT_GRAPHICS,
                layout, 0, 2, descriptor_sets, 0, null ]
            vkCmdBindVertexBuffers[ frame, 0, 1, ref vbo.vertex.vk_buffer, offsets ]
            if [ vbo.index ]
                vkCmdBindIndexBuffer[ frame, vbo.index.vk_buffer, 0,
                    gpu_index_type[ vbo ] ]
                vkCmdDrawIndexed[ frame, vbo.index_count, 1, 0, 0, 0 ]
            el
                vkCmdDraw[ frame, vbo.vertex_count, 1, 0, 0 ]

    public   func bind_resources [ ] -> none
        total_samplers: 0
        sampler_binds:  0
        uniform_count:  0
        sampler_bindings: stack VkDescriptorSetLayoutBinding[32]
        uniform_bindings: stack VkDescriptorSetLayoutBinding[32]
        buffer_infos:     stack VkDescriptorBufferInfo[32]
        image_infos:      stack VkDescriptorImageInfo[64]
        sampler_counts:   stack i32[32]
        descriptor_writes: stack VkWriteDescriptorSet[32]
        resources = array [ alloc: 32 ]
        if [ vbo ]
            sync[ vbo, w ]
            push[ resources, vbo ]
        stage_flags: VK_SHADER_STAGE_VERTEX_BIT | VK_SHADER_STAGE_FRAGMENT_BIT
        shader_uniforms = uniforms [ vk: vk, s: s ]
        for [ b: buffer ] in shader_uniforms.u_buffers
            uniform_bindings[uniform_count] = VkDescriptorSetLayoutBinding [
                binding:         uniform_count,
                descriptorType:  VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER,
                descriptorCount: 1,
                stageFlags:      stage_flags
            ]
            buffer_infos[uniform_count] = VkDescriptorBufferInfo [
                buffer: b.vk_buffer,
                offset: 0,
                range:  b.size
            ]
            uniform_count++
        # walk shader schema
        shader_schema: isa[ s ]
        while [ shader_schema != typeid[ shader ] ]
            for [ i: 0, i < shader_schema.member_count, i++ ]
                mem: ref shader_schema.members[i]
                if [ mem.member_type != A_MEMBER_ATTR ]
                    continue
                enum_type:  mem.type
                enum_value: mem.id
                meta_type:  mem.args.meta_0
                expect meta_type, "meta data not set on Surface/extension"
                all: Surface_resources[ enum_type, enum_value, self ]
                expect mem.value == 0 && len[ all ] == 1 || len[ all ] == mem.value,
                    "unexpected len(samplers) for value on attrib"
                for [ res: gpu ] in all
                    expect instanceof[ res, gpu ], "expected gpu resource"
                    sync[ res, w ]
                    push[ resources, res ]
                    image_infos[total_samplers++] = VkDescriptorImageInfo [
                        sampler:     res.tx.vk_sampler,
                        imageView:   res.tx.vk_image_view,
                        imageLayout: VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL
                    ]
                sampler_bindings[sampler_binds] = VkDescriptorSetLayoutBinding [
                    binding:         sampler_binds,
                    descriptorType:  VK_DESCRIPTOR_TYPE_COMBINED_IMAGE_SAMPLER,
                    descriptorCount: len[ all ],
                    stageFlags:      stage_flags
                ]
                sampler_binds++
            shader_schema = shader_schema.parent_type
        vkCreateDescriptorSetLayout[ vk.device, VkDescriptorSetLayoutCreateInfo [
            sType:        VK_STRUCTURE_TYPE_DESCRIPTOR_SET_LAYOUT_CREATE_INFO,
            bindingCount: uniform_count,
            pBindings:    uniform_bindings
        ], null, ref descriptor_layouts[0] ]
        vkCreateDescriptorSetLayout[ vk.device, VkDescriptorSetLayoutCreateInfo [
            sType:        VK_STRUCTURE_TYPE_DESCRIPTOR_SET_LAYOUT_CREATE_INFO,
            bindingCount: sampler_binds,
            pBindings:    sampler_bindings
        ], null, ref descriptor_layouts[1] ]
        sizes: stack VkDescriptorPoolSize[2]
        desc: VkDescriptorPoolCreateInfo [
            sType:         VK_STRUCTURE_TYPE_DESCRIPTOR_POOL_CREATE_INFO,
            poolSizeCount: 0,
            pPoolSizes:    sizes,
            maxSets:       2
        ]
        if [ uniform_count ]
            sizes[desc.poolSizeCount].type = VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER
            sizes[desc.poolSizeCount++].descriptorCount = uniform_count
        if [ sampler_binds ]
            sizes[desc.poolSizeCount].type = VK_DESCRIPTOR_TYPE_COMBINED_IMAGE_SAMPLER
            sizes[desc.poolSizeCount++].descriptorCount = total_samplers
        vkCreateDescriptorPool[ vk.device, desc, null, ref descriptor_pool ]
        vkAllocateDescriptorSets[ vk.device, VkDescriptorSetAllocateInfo [
            sType:              VK_STRUCTURE_TYPE_DESCRIPTOR_SET_ALLOCATE_INFO,
            descriptorPool:     descriptor_pool,
            descriptorSetCount: 2,
            pSetLayouts:        descriptor_layouts
        ], descriptor_sets ]
        for [ i: 0, i < uniform_count, i++ ]
            descriptor_writes[i] = VkWriteDescriptorSet [
                sType:           VK_STRUCTURE_TYPE_WRITE_DESCRIPTOR_SET,
                dstSet:          descriptor_sets[0],
                dstBinding:      i,
                descriptorType:  VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER,
                descriptorCount: 1,
                pBufferInfo:     ref buffer_infos[i]
            ]
        i_image: 0
        for [ i: 0, i < sampler_binds, i++ ]
            descriptor_writes[uniform_count + i] = VkWriteDescriptorSet [
                sType:           VK_STRUCTURE_TYPE_WRITE_DESCRIPTOR_SET,
                dstSet:          descriptor_sets[1],
                dstBinding:      i,
                descriptorType:  VK_DESCRIPTOR_TYPE_COMBINED_IMAGE_SAMPLER,
                descriptorCount: sampler_bindings[i].descriptorCount,
                pImageInfo:      ref image_infos[i_image]
            ]
            i_image += sampler_bindings[i].descriptorCount
        vkUpdateDescriptorSets[ vk.device,
            uniform_count + sampler_binds, descriptor_writes, 0, null ]

    public   func reassemble [ ] -> none
        expect vbo, "no vbo or memory provided to form a compute or graphical pipeline"
        pipeline_layout_info: VkPipelineLayoutCreateInfo [
            sType:                  VK_STRUCTURE_TYPE_PIPELINE_LAYOUT_CREATE_INFO,
            setLayoutCount:         2,
            pSetLayouts:            descriptor_layouts,
            pushConstantRangeCount: 0
        ]
        result: vkCreatePipelineLayout[ vk.device, pipeline_layout_info, null, ref layout ]
        expect result == VK_SUCCESS, "Failed to create pipeline layout"
        if [ vbo ]
            binding_description: VkVertexInputBindingDescription [
                binding:   0,
                stride:    vbo.vertex_size,
                inputRate: VK_VERTEX_INPUT_RATE_VERTEX
            ]
            attr_count: 0
            attributes: calloc[ vbo.member_count, sizeof[ VkVertexInputAttributeDescription ] ]
            for [ i: 0, i < vbo.member_count, i++ ]
                mem: ref vbo.members[i]
                attributes[attr_count].binding  = 0
                attributes[attr_count].location = attr_count
                attributes[attr_count].format =
                    mem.type == typeid[ vec2f ]  ? VK_FORMAT_R32G32_SFLOAT       :
                    mem.type == typeid[ vec3f ]  ? VK_FORMAT_R32G32B32_SFLOAT    :
                    mem.type == typeid[ vec4f ]  ? VK_FORMAT_R32G32B32A32_SFLOAT :
                    mem.type == typeid[ rgba16 ] ? VK_FORMAT_R16G16B16A16_UNORM  :
                    mem.type == typeid[ rgba8 ]  ? VK_FORMAT_R8G8B8A8_UNORM     :
                    mem.type == typeid[ f32 ]    ? VK_FORMAT_R32_SFLOAT          :
                    mem.type == typeid[ i8 ]     ? VK_FORMAT_R8_SINT             :
                    mem.type == typeid[ u8 ]     ? VK_FORMAT_R8_UINT             :
                    mem.type == typeid[ i16 ]    ? VK_FORMAT_R16_SINT            :
                    mem.type == typeid[ u16 ]    ? VK_FORMAT_R16_UINT            :
                    mem.type == typeid[ u32 ]    ? VK_FORMAT_R32_UINT            :
                                                    VK_FORMAT_UNDEFINED
                f: attributes[attr_count].format
                expect f != VK_FORMAT_UNDEFINED,
                    "undefined vertex attribute for type %s", mem.type.name
                attributes[attr_count].offset = mem.offset
                attr_count++
            vertex_input_info: VkPipelineVertexInputStateCreateInfo [
                sType: VK_STRUCTURE_TYPE_PIPELINE_VERTEX_INPUT_STATE_CREATE_INFO,
                vertexBindingDescriptionCount: 1,
                pVertexBindingDescriptions:    ref binding_description,
                vertexAttributeDescriptionCount: attr_count,
                pVertexAttributeDescriptions:    attributes
            ]
            input_assembly_info: VkPipelineInputAssemblyStateCreateInfo [
                sType:    VK_STRUCTURE_TYPE_PIPELINE_INPUT_ASSEMBLY_STATE_CREATE_INFO,
                topology: VK_PRIMITIVE_TOPOLOGY_TRIANGLE_LIST
            ]
            shader_stages: stack VkPipelineShaderStageCreateInfo[4]
            n_stages: 2
            shader_stages[0] = VkPipelineShaderStageCreateInfo [
                sType:  VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO,
                stage:  VK_SHADER_STAGE_VERTEX_BIT,
                module: s.vk_vert,
                pName:  "main"
            ]
            shader_stages[1] = VkPipelineShaderStageCreateInfo [
                sType:  VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO,
                stage:  VK_SHADER_STAGE_FRAGMENT_BIT,
                module: s.vk_frag,
                pName:  "main"
            ]
            viewport_state: VkPipelineViewportStateCreateInfo [
                sType:         VK_STRUCTURE_TYPE_PIPELINE_VIEWPORT_STATE_CREATE_INFO,
                viewportCount: 1,
                pViewports:    null,
                scissorCount:  1,
                pScissors:     null
            ]
            rasterization_state: VkPipelineRasterizationStateCreateInfo [
                sType:                   VK_STRUCTURE_TYPE_PIPELINE_RASTERIZATION_STATE_CREATE_INFO,
                depthClampEnable:        VK_FALSE,
                rasterizerDiscardEnable: VK_FALSE,
                polygonMode:             VK_POLYGON_MODE_FILL,
                lineWidth:               1.0,
                cullMode:                VK_CULL_MODE_BACK_BIT,
                frontFace:               VK_FRONT_FACE_CLOCKWISE,
                depthBiasEnable:         VK_FALSE
            ]
            multisample_state: VkPipelineMultisampleStateCreateInfo [
                sType:                VK_STRUCTURE_TYPE_PIPELINE_MULTISAMPLE_STATE_CREATE_INFO,
                rasterizationSamples: VK_SAMPLE_COUNT_1_BIT,
                sampleShadingEnable:  VK_TRUE
            ]
            color_blend_attachment: VkPipelineColorBlendAttachmentState [
                blendEnable:         VK_TRUE,
                srcColorBlendFactor: VK_BLEND_FACTOR_SRC_ALPHA,
                dstColorBlendFactor: VK_BLEND_FACTOR_ONE_MINUS_SRC_ALPHA,
                colorBlendOp:        VK_BLEND_OP_ADD,
                srcAlphaBlendFactor: VK_BLEND_FACTOR_SRC_ALPHA,
                dstAlphaBlendFactor: VK_BLEND_FACTOR_ONE_MINUS_SRC_ALPHA,
                alphaBlendOp:        VK_BLEND_OP_ADD,
                colorWriteMask:      VK_COLOR_COMPONENT_R_BIT |
                                     VK_COLOR_COMPONENT_G_BIT |
                                     VK_COLOR_COMPONENT_B_BIT |
                                     VK_COLOR_COMPONENT_A_BIT
            ]
            color_blend_state: VkPipelineColorBlendStateCreateInfo [
                sType:           VK_STRUCTURE_TYPE_PIPELINE_COLOR_BLEND_STATE_CREATE_INFO,
                logicOpEnable:   VK_FALSE,
                attachmentCount: 1,
                pAttachments:    ref color_blend_attachment
            ]
            dynamic_states: stack VkDynamicState[]
                VK_DYNAMIC_STATE_VIEWPORT
                VK_DYNAMIC_STATE_SCISSOR
            dynamic_state: VkPipelineDynamicStateCreateInfo [
                sType:             VK_STRUCTURE_TYPE_PIPELINE_DYNAMIC_STATE_CREATE_INFO,
                dynamicStateCount: sizeof[ dynamic_states ] / sizeof[ dynamic_states[0] ],
                pDynamicStates:    dynamic_states
            ]
            depth_stencil: VkPipelineDepthStencilStateCreateInfo [
                sType:                 VK_STRUCTURE_TYPE_PIPELINE_DEPTH_STENCIL_STATE_CREATE_INFO,
                depthTestEnable:       VK_TRUE,
                depthWriteEnable:      VK_TRUE,
                depthCompareOp:        VK_COMPARE_OP_LESS,
                depthBoundsTestEnable: VK_FALSE,
                stencilTestEnable:     VK_FALSE
            ]
            pipeline_info: VkGraphicsPipelineCreateInfo [
                sType:               VK_STRUCTURE_TYPE_GRAPHICS_PIPELINE_CREATE_INFO,
                stageCount:          n_stages,
                pStages:             shader_stages,
                pDepthStencilState:  ref depth_stencil,
                pVertexInputState:   ref vertex_input_info,
                pInputAssemblyState: ref input_assembly_info,
                pViewportState:      ref viewport_state,
                pRasterizationState: ref rasterization_state,
                pMultisampleState:   ref multisample_state,
                pColorBlendState:    ref color_blend_state,
                pDynamicState:       ref dynamic_state,
                layout:              layout,
                renderPass:          r.vk_render_pass[render_id],
                subpass:             0,
                basePipelineHandle:  VK_NULL_HANDLE
            ]
            print "creating pipeline for %o", name
            result = vkCreateGraphicsPipelines[
                vk.device, VK_NULL_HANDLE, 1, pipeline_info, null, ref vk_render ]
            expect result == VK_SUCCESS, "pipeline creation fail"
            free[ attributes ]
        el [ s && s.vk_comp ]
            comp_info: VkComputePipelineCreateInfo [
                sType:  VK_STRUCTURE_TYPE_COMPUTE_PIPELINE_CREATE_INFO,
                layout: layout,
                stage:  VkPipelineShaderStageCreateInfo [
                    sType:  VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO,
                    stage:  VK_SHADER_STAGE_COMPUTE_BIT,
                    module: s.vk_comp,
                    pName:  "main"
                ]
            ]
            result = vkCreateComputePipelines[
                vk.device, VK_NULL_HANDLE, 1, comp_info, null, ref vk_compute ]
            expect result == VK_SUCCESS, "failed to create compute pipeline"

    func init [ ]
        bind_resources[]
        reassemble[]

    func dealloc [ ]
        vkDestroyPipelineLayout[ vk.device, layout, null ]
        if [ vk_render ]
            vkDestroyPipeline[ vk.device, vk_render, null ]
        if [ vk_compute ]
            vkDestroyPipeline[ vk.device, vk_compute, null ]

class gltf_part
    expect id : Primitive
    public s  : shader

class gltf_node
    public id    : Node
    public parts : array gltf_part [] # container-size on members

class model
    public vk               : vk_context
    public w                : window
    public r                : target
    intern transforms       : ref mat4f
    intern transform_count  : i32
    public id               : Model
    public nodes            : array
    public s                : shader
    public samplers         : map
    intern pipelines        : array
    public func rebind_model [ ] -> none
        if [ pipelines ]
            for [ p: pipeline ] in pipelines
                rebind[ p ]

    public func finish [ r_target: target, render_id: i32 ] -> none
        r = r_target
        pipelines = array [ alloc: 16 ]
        is_clear: !models || len[ models ] == 0
        if [ !samplers ]
            samplers = map [ hsize: 32 ]
        if [ !s && !is_clear ]
            s = quad_shader[ vk ]
        if [ !id && !is_clear ]
            # default quad if no model
            static gltf_quad: path
            static quad_m: Model
            if [ !gltf_quad ]
                gltf_quad = path 'models/uv-quad2.gltf'
            if [ !quad_m ]
                quad_m = read[ gltf_quad, typeid[ Model ], null ]
            id = quad_m
        if [ is_clear ]
            model_init_pipeline[ self, null, null, null ]
        el [ nodes ]
            for [ n: gltf_node ] in nodes
                for [ p: gltf_part ] in n.parts
                    model_init_pipeline[ self, n.id, p.id, p.s ? p.s : s ]
        el [ id ]
            for [ n: Node ] in id.nodes
                has_mesh: AF_query_name[ n, "mesh" ]
                if [ has_mesh ]
                    mesh: get[ id.meshes, n.mesh ]
                    for [ prim: Primitive ] in mesh.primitives
                        model_init_pipeline[ self, n, prim, s ]

    func init [ ]
        if [ !vk ]
            vk = w.vk

    func dealloc [ ]
        drop[ pipelines ]

class particle
    public pos      : vec2f
    public velocity : vec2f
    public density  : f32
    public pressure : f32

func quad_shader [ vk: vk_context ] -> UVQuad
    q: UVQuad [ vk: vk, name: 'uv-quad' ]
    q.model = mat4f_ident[]
    eye:    vec3f [ 0.0, 0.0, 2.0 ]
    center: vec3f [ 0.0, 0.0, 0.0 ]
    up:     vec3f [ 0.0, 1.0, 0.0 ]
    q.view = mat4f_look_at[ ref eye, ref center, ref up ]
    q.proj = mat4f_ortho[ -1, 1, -1, 1, 0.1, 10.0 ]
    return q

func reduce_shader [ vk: vk_context ] -> UVReduce
    q: UVReduce [ vk: vk, name: 'uv-reduce' ]
    q.model = mat4f_ident[]
    eye:    vec3f [ 0.0, 0.0, 2.0 ]
    center: vec3f [ 0.0, 0.0, 0.0 ]
    up:     vec3f [ 0.0, 1.0, 0.0 ]
    q.view = mat4f_look_at[ ref eye, ref center, ref up ]
    q.proj = mat4f_ortho[ -1, 1, -1, 1, 0.1, 10.0 ]
    return q

# --- GLFW callbacks ---

func handle_glfw_framebuffer_size [ glfw_window: ref GLFWwindow, width: i32, height: i32 ] -> none
    if [ width == 0 && height == 0 ]
        return
    w: window [ glfwGetWindowUserPointer[ glfw_window ] ]
    resize[ w, width, height ]

func handle_glfw_key [ glfw_window: ref GLFWwindow, key: i32, scan_code: i32, action: i32, mods: i32 ] -> none
    w: window [ glfwGetWindowUserPointer[ glfw_window ] ]
    if [ action == GLFW_PRESS && (key == GLFW_KEY_UP || key == GLFW_KEY_DOWN) ]
        w.debug_value += key == GLFW_KEY_UP ? 1.0 : -1.0
    clear[ w.ev ]
    w.ev.key.unicode   = key
    w.ev.key.scan_code = scan_code
    w.ev.key.state     = action == GLFW_PRESS
    w.ev.key.meta      = (mods & GLFW_MOD_SUPER) != 0
    w.ev.key.shift     = (mods & GLFW_MOD_SHIFT) != 0
    w.ev.key.alt       = (mods & GLFW_MOD_ALT)   != 0
    key_event[ w.ux, w.ev ]

func handle_glfw_scroll [ win: ref GLFWwindow, x: f64, y: f64 ] -> none
    w: window [ glfwGetWindowUserPointer[ win ] ]
    clear[ w.ev ]
    w.ev.mouse.pos.x         = w.mouse.x
    w.ev.mouse.pos.y         = w.mouse.y
    w.ev.mouse.wheel_delta.y = y
    wheel_event[ w.ux, w.ev ]

func handle_glfw_mouse [ win: ref GLFWwindow, id: i32, action: i32, mods: i32 ] -> none
    w: window [ glfwGetWindowUserPointer[ win ] ]
    clear[ w.ev ]
    w.ev.mouse.pos.x  = w.mouse.x
    w.ev.mouse.pos.y  = w.mouse.y
    w.ev.mouse.button = id - GLFW_MOUSE_BUTTON_LEFT
    w.ev.mouse.state  = action == GLFW_PRESS
    if [ w.ev.mouse.state ]
        press_event[ w.ux, w.ev ]
    el
        release_event[ w.ux, w.ev ]

func handle_glfw_char [ win: ref GLFWwindow, code_point: u32 ] -> none
    w: window [ glfwGetWindowUserPointer[ win ] ]
    expect !w.ev.key.text, "unexpected text state"
    clear[ w.ev ]
    w.ev.key.text = hold[ string[ i32[ code_point ] ] ]
    text_event[ w.ux, w.ev ]

func handle_glfw_cursor [ win: ref GLFWwindow, x: f64, y: f64 ] -> none
    w: window [ glfwGetWindowUserPointer[ win ] ]
    clear[ w.ev ]
    w.mouse.x = x
    w.mouse.y = y
    w.ev.mouse.pos.x = w.mouse.x
    w.ev.mouse.pos.y = w.mouse.y
    move_event[ w.ux, w.ev ]

# --- model pipeline init ---

func model_init_pipeline [ m: model, n: Node, prim: Primitive, s: shader ] -> none
    mdl:      m.id
    vk:       m.vk
    r:        m.r
    vbo:      gpu    [ null ]
    mdl_mat:  mat4f  [ mat4f_ident[] ]
    material: Material [ null ]
    if [ n ]
        members: ref vertex_member_t [ calloc[ 16, sizeof[ vertex_member_t ] ] ]
        name:    prim && prim.name ? prim.name : string[ 'default' ]
        indices: prim.indices
        ai:      Accessor   [ get[ mdl.accessors,  indices ] ]
        mat_id:  prim.material
        itype:   Au_t [ Accessor_member_type[ ai ] ]
        iview:   BufferView [ get[ mdl.bufferViews, ai.bufferView ] ]
        ibuffer: Buffer     [ get[ mdl.buffers,     iview.buffer ] ]
        material = mdl.materials && len[ mdl.materials ] > mat_id ?
            get[ mdl.materials, mat_id ] :
            mdl.materials ? first[ mdl.materials ] : null
        index:        0
        vertex_size:  0
        vertex_count: 0
        member_count: 0
        index_size:   itype.size
        index_count:  i32[ iview.byteLength / itype.size ]
        pairs [ prim.attributes, i ]
            a_name:   string [ i.key ]
            ac_index: i64    [ *(ref i64[ i.value ]) ]
            ac:       Accessor   [ get[ mdl.accessors,  ac_index ] ]
            bv:       BufferView [ get[ mdl.bufferViews, ac.bufferView ] ]
            b:        Buffer     [ get[ mdl.buffers, bv.buffer ] ]
            members[member_count].type   = Accessor_member_type[ ac ]
            members[member_count].ac     = ac
            members[member_count].size   = members[member_count].type.size
            members[member_count].offset = vertex_size
            vertex_size += members[member_count].type.size
            expect ac.count, "count not set on accessor"
            expect !vertex_count || ac.count == vertex_count, "invalid vbo data"
            vertex_count = ac.count
            member_count += 1
        vbo = gpu [ vk: vk, name: copy_cstr[ name.chars ],
            members: members, member_count: member_count,
            vertex_size: vertex_size, vertex_count: vertex_count,
            index_size: index_size, index_count: index_count ]
        vdata: ref i8 [ vbo.vertex_data ]
        idata: ref i8 [ vbo.index_data ]
        for [ k: 0, k < member_count, k += 1 ]
            mem: ref vertex_member_t [ ref members[k] ]
            bv:  BufferView [ get[ mdl.bufferViews, mem.ac.bufferView ] ]
            b:   Buffer     [ get[ mdl.buffers, bv.buffer ] ]
            src: ref i8     [ ref (ref i8[ data[ b.data ] ])[bv.byteOffset] ]
            stride: mem.ac.stride
            for [ j: 0, j < vertex_count, j += 1 ]
                dst:  ref i8 [ ref vdata[j * vertex_size + mem.offset] ]
                src0: ref i8 [ ref src[j * stride] ]
                memcpy[ dst, src0, mem.size ]
        i_src: ref i8 [ ref (ref i8[ data[ ibuffer.data ] ])[iview.byteOffset] ]
        memcpy[ idata, i_src, iview.byteLength ]
        if [ n.scale.x != 0 || n.scale.y != 0 || n.scale.z != 0 ]
            mdl_mat = mat4f_scale[ ref mdl_mat, ref n.scale ]
        mdl_mat = mat4f_rotate[ ref mdl_mat, ref n.rotation ]
        mdl_mat = mat4f_translate[ ref mdl_mat, ref n.translation ]
    pipe: pipeline [ vk: vk, w: m.w, name: n ? n.name : null,
        r: m.r, s: s, vbo: vbo, default_model: mdl_mat,
        material: material, samplers: m.samplers ]
    push[ m.pipelines, pipe ]

# --- mipmap generation ---

func create_mipmaps [ vk: vk_context, vk_image: VkImage, w: i32, h: i32, mips: i32, layers: i32 ] -> none
    if [ mips > 1 ]
        mipWidth:  w
        mipHeight: h
        for [ f: 0, f < layers, f += 1 ]
            transition_image_layout[ vk, vk_image,
                VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL, 0, 1, f, 1, false ]
        for [ i: u32 1, i < mips, i += 1 ]
            for [ f: 0, f < layers, f += 1 ]
                transition_image_layout[ vk, vk_image,
                    VK_IMAGE_LAYOUT_UNDEFINED,
                    VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, i, 1, f, 1, false ]
                cmd: command [ vk: vk ]
                begin[ cmd ]
                vkCmdBlitImage[ cmd.vk,
                    vk_image, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                    vk_image, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                    1, VkImageBlit [
                        srcSubresource: VkImageSubresourceLayers [
                            aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: i - 1, baseArrayLayer: f, layerCount: 1 ],
                        srcOffsets: [ VkOffset3D [ 0, 0, 0 ], VkOffset3D [ mipWidth, mipHeight, 1 ] ],
                        dstSubresource: VkImageSubresourceLayers [
                            aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: i, baseArrayLayer: f, layerCount: 1 ],
                        dstOffsets: [ VkOffset3D [ 0, 0, 0 ], VkOffset3D [ max[ 1, mipWidth / 2 ], max[ 1, mipHeight / 2 ], 1 ] ]
                    ], VK_FILTER_LINEAR ]
                submit[ cmd ]
                transition_image_layout[ vk, vk_image,
                    VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                    VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL, i, 1, f, 1, false ]
            mipWidth  = max[ 1, mipWidth / 2 ]
            mipHeight = max[ 1, mipHeight / 2 ]
        for [ f: 0, f < layers, f += 1 ]
            transition_image_layout[ vk, vk_image,
                VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL, 0, mips, f, 1, false ]
    el
        transition_image_layout[ vk, vk_image,
            VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
            VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL, 0, 1, 0, 1, false ]

# --- environment cubemap generation ---

func environment [ vk: vk_context, img: image, r_axis: vec3f, rotation: f32 ] -> texture
    if [ img.user ]
        return img.user
    size: 256
    mip_levels: 8
    cube_count: mip_levels
    w: window [ vk: vk, format: Pixel_rgbaf32, backbuffer: true, width: size, height: size ]
    resize[ w, w.extent.width, w.extent.height ]
    clone: image [ source: data[ img ], width: img.width, height: img.height,
        format: Pixel_rgbaf32, surface: Surface_color ]
    gltf_path: path 'models/env.gltf'
    mdl_data:  Model [ read[ gltf_path, typeid[ Model ], null ] ]
    e:         Env [ vk: vk, name: 'env' ]
    samplers:  map_of[ "color", clone, null ]
    m_env:     model [ vk: vk, w: w, id: mdl_data, s: e, samplers: samplers ]
    r_env:     target [ vk: vk, w: w, width: size, height: size, models: a[ m_env ] ]
    e.proj = mat4f_perspective[ radians[ 90.0 ], 1.0, 0.1, 10.0 ]
    dirs: vec3f[6]
    dirs[0] = vec3f [  1,  0,  0 ]
    dirs[1] = vec3f [ -1,  0,  0 ]
    dirs[2] = vec3f [  0,  1,  0 ]
    dirs[3] = vec3f [  0, -1,  0 ]
    dirs[4] = vec3f [  0,  0,  1 ]
    dirs[5] = vec3f [  0,  0, -1 ]
    ups: vec3f[6]
    ups[0] = vec3f [  0, -1,  0 ]
    ups[1] = vec3f [  0, -1,  0 ]
    ups[2] = vec3f [  0,  0,  1 ]
    ups[3] = vec3f [  0,  0, -1 ]
    ups[4] = vec3f [  0, -1,  0 ]
    ups[5] = vec3f [  0, -1,  0 ]
    eye: vec3f [ 0, 0, 0 ]
    vk_image:  VkImage[2]
    vma_alloc: VmaAllocation[2]
    image_info: VkImageCreateInfo [
        sType:         VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO,
        imageType:     VK_IMAGE_TYPE_2D,
        format:        w.surface_format.format,
        extent:        VkExtent3D [ w.width, w.height, 1 ],
        mipLevels:     mip_levels,
        samples:       VK_SAMPLE_COUNT_1_BIT,
        tiling:        VK_IMAGE_TILING_OPTIMAL,
        usage:         VK_IMAGE_USAGE_SAMPLED_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT | VK_IMAGE_USAGE_TRANSFER_SRC_BIT,
        flags:         VK_IMAGE_CREATE_CUBE_COMPATIBLE_BIT,
        initialLayout: VK_IMAGE_LAYOUT_UNDEFINED
    ]
    alloc_info: VmaAllocationCreateInfo [ usage: VMA_MEMORY_USAGE_AUTO_PREFER_DEVICE ]
    for [ i: 0, i < 2, i += 1 ]
        image_info.arrayLayers = i == 0 ? 6 : 6 * cube_count
        res: vmaCreateImage[ vk.allocator, image_info, alloc_info, ref vk_image[i], ref vma_alloc[i], null ]
        expect res == VK_SUCCESS, "could not create image with vmaCreateImage"
    cmd: command [ vk: vk ]
    w.list = hold[ a[ r_env ] ]
    w.last_target = last[ w.list ]
    for [ f: 0, f < 6, f += 1 ]
        e.view = mat4f_look_at[ ref eye, ref dirs[f], ref ups[f] ]
        draw[ w ]
        final: w.last_target
        transition[ final.color, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL ]
        transition_image_layout[ vk, vk_image[0],
            VK_IMAGE_LAYOUT_UNDEFINED,
            VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 0, 1, f, 1, false ]
        region: VkImageCopy [
            srcSubresource: VkImageSubresourceLayers [ aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: 0, baseArrayLayer: 0, layerCount: 1 ],
            dstSubresource: VkImageSubresourceLayers [ aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: 0, baseArrayLayer: f, layerCount: 1 ],
            extent:         VkExtent3D [ size, size, 1 ]
        ]
        begin[ cmd ]
        vkCmdCopyImage[ cmd.vk,
            final.color.vk_image, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
            vk_image[0], VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
            1, ref region ]
        submit[ cmd ]
        transition[ final.color, VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
    create_mipmaps[ vk, vk_image[0], size, size, mip_levels, 6 ]
    cube: texture [ vk: vk, vk_image: vk_image[0], surface: Surface_environment,
        vk_format: w.surface_format.format, mip_levels: mip_levels, layer_count: 6 ]
    conv_shader: Convolve [ vk: vk, name: 'conv', proj: e.proj ]
    conv_samplers: map_of[ "environment", cube, null ]
    m_conv: model [ vk: vk, w: w, id: mdl_data, s: conv_shader, samplers: conv_samplers ]
    r_conv: target [ vk: vk, w: w, width: size, height: size, models: a[ m_conv ] ]
    v: vec4f [ r_axis.x, r_axis.y, r_axis.z, radians[ 90.0 ] ]
    q: quatf [ ref v ]
    conv_shader.env = mat4f_ident[]
    conv_shader.env = mat4f_rotate[ ref conv_shader.env, ref q ]
    drop[ w.list ]
    w.list = hold[ a[ r_conv ] ]
    w.last_target = last[ w.list ]
    for [ a_i: 0, a_i < cube_count, a_i += 1 ]
        roughness: f32[ a_i ] / f32[ mip_levels - 1 ]
        conv_shader.roughness_samples = vec2f [ roughness, 1024.0 ]
        for [ f: 0, f < 6, f += 1 ]
            face_id: a_i * 6 + f
            conv_shader.view = mat4f_look_at[ ref eye, ref dirs[f], ref ups[f] ]
            final: w.last_target
            draw[ w ]
            transition[ final.color, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL ]
            transition_image_layout[ vk, vk_image[1],
                VK_IMAGE_LAYOUT_UNDEFINED,
                VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 0, 1, face_id, 1, false ]
            region: VkImageCopy [
                srcSubresource: VkImageSubresourceLayers [ aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: 0, baseArrayLayer: 0,       layerCount: 1 ],
                dstSubresource: VkImageSubresourceLayers [ aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: 0, baseArrayLayer: face_id, layerCount: 1 ],
                extent:         VkExtent3D [ size, size, 1 ]
            ]
            begin[ cmd ]
            vkCmdCopyImage[ cmd.vk,
                final.color.vk_image, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                vk_image[1], VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                1, ref region ]
            submit[ cmd ]
            for [ mi: u32 1, mi < mip_levels, mi += 1 ]
                mip_size_src: size >> (mi - 1)
                mip_size_dst: size >> mi
                transition_image_layout[ vk, vk_image[1],
                    mi == 1 ? VK_IMAGE_LAYOUT_UNDEFINED : VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                    VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL, mi - 1, 1, face_id, 1, false ]
                transition_image_layout[ vk, vk_image[1],
                    VK_IMAGE_LAYOUT_UNDEFINED,
                    VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, mi, 1, face_id, 1, false ]
                begin[ cmd ]
                vkCmdBlitImage[ cmd.vk,
                    vk_image[1], VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                    vk_image[1], VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                    1, VkImageBlit [
                        srcSubresource: VkImageSubresourceLayers [
                            aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: mi - 1, baseArrayLayer: face_id, layerCount: 1 ],
                        srcOffsets: [ VkOffset3D [ 0, 0, 0 ], VkOffset3D [ mip_size_src, mip_size_src, 1 ] ],
                        dstSubresource: VkImageSubresourceLayers [
                            aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: mi, baseArrayLayer: face_id, layerCount: 1 ],
                        dstOffsets: [ VkOffset3D [ 0, 0, 0 ], VkOffset3D [ mip_size_dst, mip_size_dst, 1 ] ]
                    ], VK_FILTER_LINEAR ]
                submit[ cmd ]
            transition[ final.color, VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
    for [ face_id: 0, face_id < 6 * cube_count, face_id += 1 ]
        for [ mi: 0, mi < mip_levels, mi += 1 ]
            transition_image_layout[ vk, vk_image[1],
                mi == mip_levels - 1 ?
                    VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL :
                    VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL,
                mi, 1, face_id, 1, false ]
    convolve: hold[ texture [ vk: vk, vk_image: vk_image[1], vma_alloc: vma_alloc[1],
        surface: Surface_environment, vk_format: w.surface_format.format,
        mip_levels: mip_levels, layer_count: 6 * cube_count ] ]
    drop[ cmd ]
    drop[ w ]
    drop[ cube ]
    drop[ clone ]
    img.user = hold[ convolve ]
    return img.user

# --- uniform helpers ---

func A_virtual_size [ m: ref type_member_t ] -> i64
    if [ m.args.meta_0 == typeid[ functional ] ]
        return 0
    type_size: i64 [ m.type.size ]
    if [ !(m.type.traits & AU_TRAIT_STRUCT || m.type.traits & AU_TRAIT_PRIMITIVE) ]
        type_size -= sizeof[ ARef ]
    return type_size

func uniform_size [ type: Au_t ] -> num
    total: num [ 0 ]
    ty: Au_t [ type ]
    while [ ty ]
        for [ m: 0, m < ty.member_count, m += 1 ]
            mem: ref type_member_t [ ref ty.members[m] ]
            inlay: mem.member_type == A_MEMBER_INLAY
            if [ mem.member_type == A_MEMBER_PROP || inlay ]
                total += A_virtual_size[ mem ]
        ty = ty.parent_type
        if [ ty == typeid[ shader ] ]
            break
    return total

func uniform_transfer [ instance: shader, data: ref u8, type: Au_t ] -> i64
    expect instanceof[ instance, shader ], "shader instance not provided"
    index: num [ 0 ]
    src: ref u8 [ instance ]
    for [ m: 0, m < type.member_count, m += 1 ]
        mem: ref type_member_t [ ref type.members[m] ]
        inlay: mem.member_type == A_MEMBER_INLAY
        if [ mem.member_type == A_MEMBER_PROP || inlay ]
            type_size: A_virtual_size[ mem ]
            if [ type_size == 0 ]
                continue
            if [ inlay || mem.type.traits & AU_TRAIT_STRUCT || mem.type.traits & AU_TRAIT_PRIMITIVE ]
                memcpy[ ref data[index], ref src[mem.offset], type_size ]
            el
                memcpy[ ref data[index], vdata[ ref object[ ref src[mem.offset] ] ], type_size ]
            index += type_size
    return index

# --- format conversion ---

func vk_format_fn [ f: Pixel, linear: bool ] -> VkFormat
    result: VkFormat [
        f == Pixel_f32     ? VK_FORMAT_R32_SFLOAT :
        f == Pixel_rgbaf32 ? VK_FORMAT_R32G32B32A32_SFLOAT :
        f == Pixel_rgbf32  ? VK_FORMAT_R32G32B32_SFLOAT :
        f == Pixel_rgba8   ? linear ? VK_FORMAT_R8G8B8A8_UNORM : VK_FORMAT_R8G8B8A8_SRGB :
        f == Pixel_rgb8    ? linear ? VK_FORMAT_R8G8B8_UNORM   : VK_FORMAT_R8G8B8_SRGB :
        f == Pixel_u8      ? VK_FORMAT_R8_UNORM : 0 ]
    expect result, "incompatible image format"
    return result

func placeholder_image [ sampler: object, size: i32, fill: ref u8, sampler_size: ref i32, format: ref Pixel ] -> none
    v_i8:    instanceof[ sampler, vector_i8 ]
    v_f32:   instanceof[ sampler, vector_f32 ]
    v_rgb8:  instanceof[ sampler, vector_rgb8 ]
    v_rgbf:  instanceof[ sampler, vector_rgbf ]
    v_rgba8: instanceof[ sampler, vector_rgba8 ]
    v_rgbaf: instanceof[ sampler, vector_rgbaf ]
    data_i8:    ref i8    [ v_i8    ? data[ v_i8 ]    : null ]
    data_f32:   ref f32   [ v_f32   ? data[ v_f32 ]   : null ]
    data_rgb8:  ref rgb8  [ v_rgb8  ? data[ v_rgb8 ]  : null ]
    data_rgbf:  ref rgbf  [ v_rgbf  ? data[ v_rgbf ]  : null ]
    data_rgba8: ref rgba8 [ v_rgba8 ? data[ v_rgba8 ] : null ]
    data_rgbaf: ref rgbaf [ v_rgbaf ? data[ v_rgbaf ] : null ]
    s: i32 [ size * size ]
    if [ data_f32 ]
        f32_fill: ref f32 [ fill ]
        for [ i: 0, i < s, i += 1 ]
            f32_fill[i] = *data_f32
        *format = Pixel_f32
        *sampler_size = s * sizeof[ f32 ]
    el [ data_i8 ]
        u8_fill: ref u8 [ fill ]
        for [ i: 0, i < s, i += 1 ]
            u8_fill[i] = *data_i8
        *format = Pixel_u8
        *sampler_size = s * sizeof[ u8 ]
    el [ data_rgbf ]
        v3_fill: ref rgbf [ fill ]
        for [ i: 0, i < s, i += 1 ]
            v3_fill[i] = *data_rgbf
        *format = Pixel_rgbf32
        *sampler_size = s * sizeof[ rgbf ]
    el [ data_rgb8 ]
        v3_fill: ref rgb8 [ fill ]
        for [ i: 0, i < s, i += 1 ]
            v3_fill[i] = *data_rgb8
        *format = Pixel_rgb8
        *sampler_size = s * sizeof[ rgb8 ]
    el [ data_rgbaf ]
        v4_fill: ref rgbaf [ fill ]
        for [ i: 0, i < s, i += 1 ]
            v4_fill[i] = *data_rgbaf
        *format = Pixel_rgbaf32
        *sampler_size = s * sizeof[ rgbaf ]
    el [ data_rgba8 ]
        v4_fill: ref rgba8 [ fill ]
        for [ i: 0, i < s, i += 1 ]
            v4_fill[i] = *data_rgba8
        *format = Pixel_rgba8
        *sampler_size = s * sizeof[ rgba8 ]
    el
        fault "sampler data required"

func image_release_buffer [ a: image ] -> object
    b: buffer [ a.res ]
    vk: vk_context [ b.vk ]
    vmaUnmapMemory[ vk.allocator, b.vma_alloc ]
    vmaDestroyBuffer[ vk.allocator, b.vk_buffer, b.vma_alloc ]
    drop[ b ]
    return null

func pixel_from_format [ f: VkFormat, channels: ref i32 ] -> Pixel
    pixel: Pixel [
        (f == VK_FORMAT_R8G8B8A8_UNORM || f == VK_FORMAT_B8G8R8A8_UNORM ||
         f == VK_FORMAT_R8G8B8A8_SRGB  || f == VK_FORMAT_B8G8R8A8_SRGB)  ? Pixel_rgba8 :
        (f == VK_FORMAT_R8G8B8_UNORM   || f == VK_FORMAT_B8G8R8_UNORM   ||
         f == VK_FORMAT_R8G8B8_SRGB    || f == VK_FORMAT_B8G8R8_SRGB)    ? Pixel_rgb8 :
        f == VK_FORMAT_R8_UNORM            ? Pixel_u8 :
        f == VK_FORMAT_R32_SFLOAT          ? Pixel_f32 :
        f == VK_FORMAT_R32G32B32A32_SFLOAT ? Pixel_rgbaf32 : 0 ]
    if [ channels ]
        switch [ pixel ]
            case Pixel_rgbaf32
                *channels = 4
            case Pixel_rgba8
                *channels = 4
            case Pixel_rgb8
                *channels = 3
            case Pixel_f32
                *channels = 1
            case Pixel_u8
                *channels = 1
            default
                *channels = 0
    return pixel

func gpu_index_type [ a: gpu ] -> VkIndexType
    return a.index_size == 1 ? VK_INDEX_TYPE_UINT8_KHR :
           a.index_size == 2 ? VK_INDEX_TYPE_UINT16     : VK_INDEX_TYPE_UINT32

func pbr_defaults [] -> pbrMetallicRoughness
    static pbr: pbrMetallicRoughness
    if [ !pbr ]
        pbr = pbrMetallicRoughness[]
        pbr.baseColorFactor            = vec4f [ 1, 0, 0, 1 ]
        pbr.metallicFactor             = 1.0
        pbr.roughnessFactor            = 1.0
        pbr.emissiveFactor             = vec3f [ 0, 0, 0 ]
        pbr.diffuseFactor              = vec4f [ 1, 1, 1, 1 ]
        pbr.specularFactor             = vec3f [ 1, 1, 1 ]
        pbr.glossinessFactor           = 1.0
        pbr.sheenColorFactor           = vec3f [ 0, 0, 0 ]
        pbr.sheenRoughnessFactor       = 0.0
        pbr.clearcoatFactor            = 0.0
        pbr.clearcoatRoughnessFactor   = 0.0
        pbr.transmissionFactor         = 0.0
        pbr.thicknessFactor            = 0.0
        pbr.attenuationColor           = vec3f [ 1, 1, 1 ]
        pbr.attenuationDistance        = 1e20
        pbr.ior                        = 1.5
        pbr.specularColorFactor        = vec3f [ 1, 1, 1 ]
        pbr.emissiveStrength           = 1.0
        pbr.iridescenceFactor          = 0.0
        pbr.iridescenceIor             = 1.3
        pbr.iridescenceThicknessMinimum = 100.0
        pbr.iridescenceThicknessMaximum = 400.0
    return pbr

func Surface_resources [ surface_enum_type: Au_t, surface_value: Surface, p: pipeline ] -> array
    res: gpu [ null ]
    vk: p.vk
    result: array [ alloc: 32 ]
    pairs [ p.samplers, i ]
        name: string [ i.key ]
        img:  image  [ i.value ]
        ev:   i32    [ *evalue[ surface_enum_type, name.chars ] ]
        tx:   texture [ instanceof[ object[ img ], texture ] ]
        re:   target  [ instanceof[ object[ img ], target ] ]
        if [ re ]
            tx = re.color
        if [ ev == surface_value ]
            expect tx || instanceof[ img, image ], "expected texture or image"
            res = gpu [ vk: vk, name: cstring[ e_str[ Surface, surface_value ] ],
                sampler: object[ tx ? object[ hold[ tx ] ] : object[ hold[ img ] ] ] ]
            push[ result, res ]
    pbr_default: pbr_defaults[]
    pbr: p.material ? p.material.pbr : pbr_default
    if [ !len[ result ] ]
        f_normal: rgbaf [ 0.5, 0.5, 1.0, 1.0 ]
        f_zero:   rgbaf [ 0.0, 0.0, 0.0, 0.0 ]
        f_one:    rgbaf [ 1.0, 1.0, 1.0, 1.0 ]
        f_color:  rgbaf [ ref pbr.baseColorFactor ]
        single:   hold[ shape_new[ 1, 0 ] ]
        switch [ surface_value ]
            case Surface_normal
                res = gpu [ vk: vk, name: "normal",      sampler: vector_rgbaf_new[ single, f_normal ] ]
            case Surface_metal
                res = gpu [ vk: vk, name: "metal",       sampler: vector_f32_new[ single, pbr.metallicFactor ] ]
            case Surface_rough
                res = gpu [ vk: vk, name: "rough",       sampler: vector_f32_new[ single, pbr.roughnessFactor ] ]
            case Surface_emission
                expect pbr.emissiveStrength / 8.0 <= 1.0, "refactor emissiveStrength"
                res = gpu [ vk: vk, name: "emission",    sampler: vector_rgbaf_new[ single, f_zero ] ]
            case Surface_height
                res = gpu [ vk: vk, name: "height",      sampler: vector_f32_new[ single, 0.5 ] ]
            case Surface_ao
                res = gpu [ vk: vk, name: "ao",          sampler: vector_f32_new[ single, 1.0 ] ]
            case Surface_ior
                res = gpu [ vk: vk, name: "ior",         sampler: vector_f32_new[ single, pbr.ior ] ]
            case Surface_color
                res = gpu [ vk: vk, name: "color",       sampler: vector_rgbaf_new[ single, f_color ] ]
            case Surface_environment
                res = gpu [ vk: vk, name: "environment", sampler: vector_rgbaf_new[ single, f_one ] ]
            default
                expect false, "Unhandled Surface enum value"
        push[ result, res ]
    return result

func rectangle_offset [ area: region, rel: rect ] -> rect
    reg: region [ null ]
    if [ !area ]
        reg = region [ 0.0 ]
        area = reg
    r: rectangle[ area, rel, null ]
    if [ reg ]
        drop[ reg ]
    return r

func sk_canvas [ a: window, ct: Canvas ] -> sk
    switch [ ct ]
        case Canvas_overlay
            return a.overlay
        case Canvas_compose
            return a.compose
        case Canvas_colorize
            return a.colorize
        case Canvas_glyph
            return a.glyph
        default
            return a.overlay

func app_render [ a: app ] -> none
    w:        a.w
    ux:       w.ux
    elements: a.ason_render
    if [ a.on_render ]
        elements = a.on_render[ a, a.w ]
    el [ !a.ason_render || modified_time[ a.ason_path ] > a.ason_modified ]
        a.ason_modified = modified_time[ a.ason_path ]
        if [ !a.app_context ]
            a.app_context = hold[ ctx [ hsize: 32 ] ]
        type: Au_t [ isa[ a ] ]
        ty: Au_t [ type ]
        while [ ty != typeid[ Au ] ]
            for [ m: num 0, m < ty.member_count, m += 1 ]
                mem: ref type_member_t [ ref ty.members[m] ]
                from: object [ A_member_object[ a, mem ] ]
                if [ !from ]
                    continue
                ctx_val: object [ get[ a.app_context, mem.sname ] ]
                if [ from && !ctx_val || compare[ from, ctx_val ] != 0 ]
                    set[ a.app_context, mem.sname, from ]
            ty = ty.parent_type
        ason_render: map [ read[ a.ason_path, typeid[ map ], a.app_context ] ]
        ty = type
        while [ ty != typeid[ Au ] ]
            for [ m: num 0, m < ty.member_count, m += 1 ]
                mem: ref type_member_t [ ref ty.members[m] ]
                if [ !(mem.member_type & A_MEMBER_PROP) ]
                    continue
                member: object [ A_member_object[ a, mem ] ]
                to:     object [ get[ a.app_context, mem.sname ] ]
                if [ (!member && to) || (!to && member) || (member && to && A_memcmp[ member, to ] != 0) ]
                    A_member_set[ a, mem, to ]
            ty = ty.parent_type
        a.ason_render = hold[ ason_render ]
        elements = a.ason_render
    if [ elements ]
        update_all[ w.ux, elements ]
    animate[ ux ]
    if [ w.compose && w.colorize && w.glyph ]
        clear[ w.compose,  string[ "#000" ] ]
        clear[ w.colorize, string[ "#000" ] ]
        clear[ w.glyph,    string[ "#000" ] ]
    clear[ w.overlay, string[ "#0000" ] ]
    draw_element[ w, ux.root ]
    sk_sync[]
    draw[ w ]

# --- globals ---

enable_validation: i32 [ 0 ]
vk_version: u32 [ VK_API_VERSION_1_2 ]
_vkCreateDebugUtilsMessengerEXT: PFN_vkCreateDebugUtilsMessengerEXT

func trinity_log [ severity: VkDebugUtilsMessageSeverityFlagBitsEXT, types: VkDebugUtilsMessageTypeFlagsEXT, callbackData: ref VkDebugUtilsMessengerCallbackDataEXT, userData: ref void ] -> VkBool32
    printf "[vulkan] %s", callbackData.pMessage
    return VK_FALSE




# ========================================================================
# SCRATCH — functions from trinity.c to convert to Silver
# ========================================================================


# ---- target (render pass / framebuffer) ----
# allocates command buffer, creates render pass with color+depth attachments,
# semaphores, fence, then calls update for framebuffer creation

# func target.init [] -> none
#     alloc command buffer from vk.command_pool
#     create render pass: color attachment (surface format) + depth (D32_SFLOAT)
#     subpass with color+depth refs
#     dependencies for layout transitions
#     create semaphores (if not backbuffer)
#     create fence (signaled)
#     if reduce: create reduce_model with reduce_shader
#     call update
#     finish all models on their render pass

# func target.update [] -> none
#     scale width/height from wscale if set
#     if color exists: resize color, depth, reduction textures
#     else: create color texture (surface format), depth (D32_SFLOAT), reduction
#     transition layouts (color attachment or shader read depending on backbuffer)
#     create framebuffers for each render pass

# func target.draw [] -> none
#     for each pass (main + reduce):
#       transition color/reduction to COLOR_ATTACHMENT_OPTIMAL
#       reset fence, reset command buffer, begin recording
#       set viewport + scissor
#       begin render pass with clear values
#       draw all models/pipelines (pass 0) or reduce model (pass 1)
#       end render pass, end command buffer
#       submit with semaphore wait/signal if swap image

# func target.sync_fence [] -> none
#     vkWaitForFences on vk_fence

# func target.dealloc [] -> none
#     destroy framebuffers, render passes, fence, semaphores


# ---- window ----
# GLFW window creation, Vulkan surface, swapchain, present mode selection

# func window.init [] -> none
#     set defaults (format rgba8, width 1200, height 1200)
#     create event object
#     if not backbuffer:
#       glfwCreateWindow, set callbacks (key, mouse, scroll, char, cursor, resize)
#       glfwCreateWindowSurface
#     call vk.attach[surface]
#     query surface capabilities, formats, present modes
#     choose B8G8R8A8_UNORM format, MAILBOX present mode
#     set extent from glfw window size

# func window.resize [width: i32, height: i32] -> none
#     vkDeviceWaitIdle
#     update all targets
#     rebind models if resized
#     query new surface capabilities
#     recreate swapchain with new dimensions
#     recreate swap images and swap renders
#     update canvas

# func window.draw [] -> none
#     if not backbuffer:
#       acquire next swap image
#       draw swap render target
#       present to queue
#       advance swap image index

# func window.dealloc [] -> none
#     destroy swapchain, surface, swap images

# func window.cast_image [] -> image
#     create transfer buffer, copy color to it, return as image

# func window.update_canvas [] -> none
#     resize or create compose/colorize/overlay/glyph skia surfaces
#     clear each with default colors


# ---- GLFW callbacks ----
# each gets window from glfwGetWindowUserPointer, fills event, dispatches to ux

# func handle_glfw_framebuffer_size [win, width, height]
#     if minimized return; call resize

# func handle_glfw_key [win, key, scan_code, action, mods]
#     fill event key fields, dispatch key_event to ux

# func handle_glfw_scroll [win, x, y]
#     fill mouse wheel_delta, dispatch wheel_event

# func handle_glfw_mouse [win, id, action, mods]
#     fill mouse button/state, dispatch press/release event

# func handle_glfw_char [win, code_point]
#     create text string, dispatch text_event

# func handle_glfw_cursor [win, x, y]
#     update mouse pos, dispatch move_event


# ---- app ----

# func app.init [] -> none
#     create vk_context
#     create style, composer
#     bind on_render or load ason_path

# func app.initialize [win: window] -> none
#     set ux.w = win, w.ux = ux
#     update_canvas, app_render, resize

# func app.run [] -> none
#     main loop: glfwPollEvents, render, present
#     cleanup on exit

# func app.dealloc [] -> none
#     cleanup


# ---- pipeline ----
# Vulkan graphics pipeline: descriptor sets, pipeline layout, shaders, vertex input

# func pipeline.init [] -> none
#     create descriptor set layout from shader uniforms
#     create pipeline layout
#     create graphics pipeline (vert/frag stages, vertex input, rasterizer, multisampling, depth, blend)
#     allocate descriptor sets

# func pipeline.draw [frame: VkCommandBuffer] -> none
#     update uniforms
#     bind pipeline, descriptor sets, vertex/index buffers
#     draw indexed or draw vertices

# func pipeline.bind_resources [] -> none
#     for each descriptor: bind uniform buffers and texture samplers
#     write descriptor sets

# func pipeline.reassemble [] -> none
#     rebuild pipeline on shader reload

# func pipeline.dealloc [] -> none
#     destroy pipeline, pipeline layout, descriptor pool/sets


# ---- model ----
# groups pipelines with vertex data, manages gltf scene binding

# func model.finish [r: target, pass_id: i32] -> none
#     init_pipeline for each gltf primitive
#     sync gpu objects
#     bind resources on all pipelines

# func model.dealloc [] -> none
#     cleanup pipelines, gpu objects

# func model.rebind [] -> none
#     rebind all pipelines


# ---- gpu (mesh object) ----
# vertex/index buffer management for draw calls

# func gpu.init [] -> none
#     create VBO from vertex_data, IBO from index_data
#     create texture from sampler if provided

# func gpu.sync [w: window] -> none
#     upload vertex/index data to GPU buffers

# func gpu.dealloc [] -> none
#     destroy VBO, IBO, texture


# ---- uniforms ----

# func uniforms.init [] -> none
#     create uniform buffers for each shader binding
#     allocate descriptor pool and sets

# func uniforms.update [] -> none
#     map each uniform buffer, memcpy shader data, unmap


# ---- shader inits ----

# func UVQuad.init [] -> none
#     model = identity, view = look_at(0,0,2), proj = ortho(-1,1,-1,1,0.1,10)

# func UVReduce.init [] -> none
#     same as UVQuad

# func UXSimple.init [] -> none
#     same as UVQuad

# func UXCompose.init [] -> none
#     same as UVQuad

# func PBR.init [] -> none
#     shader name "pbr"

# func Env.init [] -> none
#     shader name "env"


