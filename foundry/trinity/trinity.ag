        return null


class Camera
    mutable vk         : vk_context
    mutable w          : Display
    public  device     : string '/dev/video6'
    public  width      : i32    340
    public  height     : i32    340
    public  buffer_count : i32  3
    public  cpu_upload : bool   true   # CPU memcpy → staging → image (reliable).
                                       # false = import dmabuf as VkBuffer (zero-copy but NVIDIA issues).

    intern  fd         : i32    -1
    intern  cam_bufs   : ref VkBuffer        # ring of dmabuf-imported buffers (cpu_upload=false)
    intern  cam_mem    : ref VkDeviceMemory  # imported memory per buffer    (cpu_upload=false)
    intern  staging_buf: VkBuffer            # single persistent staging buffer (cpu_upload=true)
    intern  staging_mem: VkDeviceMemory
    intern  staging_ptr: ref u8              # mapped pointer into staging
    intern  mm_ptrs    : ref handle          # mmap'd CPU pointer per buffer (brightness sampling)
    intern  mm_sizes   : ref u32
    intern  cam_image  : VkImage             # GPU-aligned image target (NVIDIA demands row pad)
    intern  cam_image_mem : VkDeviceMemory
    intern  current_idx: i32    0
    intern  prev_idx   : i32   -1
    intern  prev_bright: u64    0
    intern  row_pitch  : u32    0            # bytesperline from v4l2_pix_format
    intern  dump_count : i32    0            # frames seen, for warmup delay before test dump
    intern  best_sum   : u64    0            # peak brightness seen so far
    intern  best_bytes : ref u8              # copy of brightest frame seen

    # camera output texture — latest frame is blitted into this image.
    public  image      : Texture
    public  src_rect   : rect

    func init []
        fd = open[ device.chars, O_RDWR | O_NONBLOCK ]
        expect fd >= 0, 'camera: failed to open {device}'
        printf[ "sizeof v4l2_buffer silver=%u vs kernel=88\n", sizeof[v4l2_buffer] ]

        # set pixel format: GREY at requested dimensions
        vfmt : v4l2_format [ ]
        vfmt.type                = V4L2_BUF_TYPE_VIDEO_CAPTURE
        vfmt.fmt.pix.width       = width
        vfmt.fmt.pix.height      = height
        vfmt.fmt.pix.pixelformat = V4L2_PIX_FMT_GREY
        vfmt.fmt.pix.field       = V4L2_FIELD_NONE
        # VIDIOC_S_FMT = _IOWR('V', 5, struct v4l2_format) = 0xC0D05605 on x86-64.
        # hardcoded to bypass silver-side sizeof(struct v4l2_format) vs kernel mismatch.
        err : i32 [ ioctl[ fd, 0xC0D05605, ref vfmt ] ]
        printf "%i\n", sizeof[v4l2_format]
        if [ err != 0 ]
            perror[ 'camera: VIDIOC_S_FMT' ]
        expect err == 0, 'camera: VIDIOC_S_FMT failed'
        width     = vfmt.fmt.pix.width
        height    = vfmt.fmt.pix.height
        row_pitch = vfmt.fmt.pix.bytesperline
        printf[ "camera: S_FMT ok w=%i h=%i bpl=%u sizeimage=%u\n",
            width, height, row_pitch, vfmt.fmt.pix.sizeimage ]

        # request MMAP buffers (DMA-BUF-exportable)
        req : v4l2_requestbuffers [ ]
        req.count  = buffer_count
        req.type   = V4L2_BUF_TYPE_VIDEO_CAPTURE
        req.memory = V4L2_MEMORY_MMAP
        err = ioctl[ fd, VIDIOC_REQBUFS, ref req ]
        expect err == 0, 'camera: VIDIOC_REQBUFS failed'
        buffer_count = req.count

        cam_bufs  = new VkBuffer       [ buffer_count ]
        cam_mem   = new VkDeviceMemory [ buffer_count ]
        mm_ptrs   = new handle         [ buffer_count ]
        mm_sizes  = new u32            [ buffer_count ]

        # export each v4l2 buffer as a DMA-BUF fd and import as a VkImage.
        # also mmap each buffer for CPU-side brightness sampling (for the
        # strobing-IR brightest-of-last-two logic).
        for [ i: i32 0, i < buffer_count, i += 1 ]
            qb : v4l2_buffer [ ]
            qb.type   = V4L2_BUF_TYPE_VIDEO_CAPTURE
            qb.memory = V4L2_MEMORY_MMAP
            qb.index  = i
            err = ioctl[ fd, VIDIOC_QUERYBUF, ref qb ]
            expect err == 0, 'camera: VIDIOC_QUERYBUF {i} failed'
            printf[ "camera: QUERYBUF %i -> length=%u m.offset=%u memory=%u bytesused=%u\n",
                i, qb.length, qb.m.offset, qb.memory, qb.bytesused ]

            ptr : handle mmap[ null, qb.length, PROT_READ | PROT_WRITE, MAP_SHARED, fd, qb.m.offset ]
            expect ptr != MAP_FAILED, 'camera: mmap {i} failed'
            mm_ptrs [i] = ptr
            mm_sizes[i] = qb.length

            if [ !cpu_upload ]
                exb : v4l2_exportbuffer [ ]
                exb.type  = V4L2_BUF_TYPE_VIDEO_CAPTURE
                exb.index = i
                exb.flags = O_RDWR
                err = ioctl[ fd, VIDIOC_EXPBUF, ref exb ]
                expect err == 0, 'camera: VIDIOC_EXPBUF {i} failed'
                import_dmabuf[ i, exb.fd, qb.length ]

        # queue all buffers back to the driver
        for [ i: i32 0, i < buffer_count, i += 1 ]
            qbuf : v4l2_buffer [ ]
            qbuf.type   = V4L2_BUF_TYPE_VIDEO_CAPTURE
            qbuf.memory = V4L2_MEMORY_MMAP
            qbuf.index  = i
            err = ioctl[ fd, VIDIOC_QBUF, ref qbuf ]
            expect err == 0, 'camera: VIDIOC_QBUF {i} failed'

        bt : i32 V4L2_BUF_TYPE_VIDEO_CAPTURE
        err = ioctl[ fd, VIDIOC_STREAMON, ref bt ]
        expect err == 0, 'camera: VIDIOC_STREAMON failed'

        # single GPU-aligned VkImage that each frame's buffer will be copied
        # into. whatever row padding NVIDIA demands, the image picks its own
        # layout — the copy handles conversion from tight-packed dmabuf.
        img_info : VkImageCreateInfo [
            sType:         VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO,
            imageType:     VK_IMAGE_TYPE_2D,
            format:        VK_FORMAT_R8_UNORM,
            extent:        VkExtent3D [ width, height, 1 ],
            mipLevels:     1,
            arrayLayers:   1,
            samples:       VK_SAMPLE_COUNT_1_BIT,
            tiling:        VK_IMAGE_TILING_OPTIMAL,
            usage:         VK_IMAGE_USAGE_TRANSFER_DST_BIT | VK_IMAGE_USAGE_TRANSFER_SRC_BIT | VK_IMAGE_USAGE_SAMPLED_BIT,
            sharingMode:   VK_SHARING_MODE_EXCLUSIVE,
            initialLayout: VK_IMAGE_LAYOUT_UNDEFINED
        ]
        err = vkCreateImage[ vk.device, ref img_info, null, ref cam_image ]
        expect err == 0, 'camera: vkCreateImage (cam_image) failed'
        expect cam_image, 'camera: cam_image is null after vkCreateImage'

        # allocate memory for cam_image (device-local, not imported)
        img_req : VkMemoryRequirements [ ]
        vkGetImageMemoryRequirements[ vk.device, cam_image, ref img_req ]
        img_alloc : VkMemoryAllocateInfo [
            sType:          VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO,
            allocationSize: img_req.size,
            memoryTypeIndex: 0   # first type that matches (device memory on most configs)
        ]
        # pick a memory type that matches the image's requirements
        for [ k: u32 0, k < 32, k += 1 ]
            if [ img_req.memoryTypeBits & (u32[1] << k) ]
                img_alloc.memoryTypeIndex = k
                break
        err = vkAllocateMemory[ vk.device, ref img_alloc, null, ref cam_image_mem ]
        expect err == 0, 'camera: vkAllocateMemory (cam_image) failed'
        err = vkBindImageMemory[ vk.device, cam_image, cam_image_mem, 0 ]
        expect err == 0, 'camera: vkBindImageMemory (cam_image) failed'

        # in cpu_upload mode: allocate one persistent HOST_VISIBLE|COHERENT
        # staging buffer. each frame we memcpy from the mmap'd v4l2 buffer
        # and vkCmdCopyBufferToImage into cam_image. NVIDIA's dmabuf import
        # of v4l2-system-RAM fds is silently inert, so this is the default.
        if [ cpu_upload ]
            sbuf_sz : u32 [ width * height ]
            sbci : VkBufferCreateInfo [
                sType:       VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO,
                size:        sbuf_sz,
                usage:       VK_BUFFER_USAGE_TRANSFER_SRC_BIT,
                sharingMode: VK_SHARING_MODE_EXCLUSIVE
            ]
            err = vkCreateBuffer[ vk.device, ref sbci, null, ref staging_buf ]
            expect err == 0, 'camera: vkCreateBuffer (staging) failed'

            sreq : VkMemoryRequirements [ ]
            vkGetBufferMemoryRequirements[ vk.device, staging_buf, ref sreq ]
            # pick first HOST_VISIBLE + HOST_COHERENT memory type matching buffer reqs
            s_type_idx : u32 [ 0 ]
            for [ k: u32 0, k < vk.props.memoryTypeCount, k += 1 ]
                if [ sreq.memoryTypeBits & (u32[1] << k) ]
                    flags : u32 [ vk.props.memoryTypes[k].propertyFlags ]
                    needed : u32 [ VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT | VK_MEMORY_PROPERTY_HOST_COHERENT_BIT ]
                    if [ (flags & needed) == needed ]
                        s_type_idx = k
                        break
            smai : VkMemoryAllocateInfo [
                sType:           VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO,
                allocationSize:  sreq.size,
                memoryTypeIndex: s_type_idx
            ]
            err = vkAllocateMemory[ vk.device, ref smai, null, ref staging_mem ]
            expect err == 0, 'camera: vkAllocateMemory (staging) failed'
            err = vkBindBufferMemory[ vk.device, staging_buf, staging_mem, 0 ]
            expect err == 0, 'camera: vkBindBufferMemory (staging) failed'
            err = vkMapMemory[ vk.device, staging_mem, 0, sreq.size, 0, ref staging_ptr ]
            expect err == 0, 'camera: vkMapMemory (staging) failed'

        image = Texture [ vk: vk, w: w, width: width, height: height,
            pixel_format: Pixel.u8, surface: Surface.color ]
        expect image, 'camera: image creation failed'

    # import a dma-buf fd as a VkBuffer. buffers have no row-pitch constraints
    # (unlike images on NVIDIA), so we can import the tight-packed camera data
    # directly. a single aligned VkImage receives vkCmdCopyBufferToImage per
    # frame, and the blit runs image→image.
    intern func import_dmabuf [ idx: i32, dma_fd: i32, byte_size: u32 ]
        ext : VkExternalMemoryBufferCreateInfo [ ]
        ext.sType       = VK_STRUCTURE_TYPE_EXTERNAL_MEMORY_BUFFER_CREATE_INFO
        ext.handleTypes = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT

        bci : VkBufferCreateInfo [ ]
        bci.sType       = VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO
        bci.pNext       = ref ext
        bci.size        = byte_size
        bci.usage       = VK_BUFFER_USAGE_TRANSFER_SRC_BIT
        bci.sharingMode = VK_SHARING_MODE_EXCLUSIVE

        buf : VkBuffer [ null ]
        err : i32 [ vkCreateBuffer[ vk.device, ref bci, null, ref buf ] ]
        expect err == 0, 'camera: vkCreateBuffer (dmabuf) failed'
        expect buf, 'camera: buf is null after vkCreateBuffer'

        mreq : VkMemoryRequirements [ ]
        vkGetBufferMemoryRequirements[ vk.device, buf, ref mreq ]

        fd_props : VkMemoryFdPropertiesKHR [ ]
        fd_props.sType = VK_STRUCTURE_TYPE_MEMORY_FD_PROPERTIES_KHR
        expect vk._vkGetMemoryFdPropertiesKHR, 'camera: vkGetMemoryFdPropertiesKHR not loaded'
        err = vk._vkGetMemoryFdPropertiesKHR[ vk.device,
            VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT, dma_fd, ref fd_props ]
        expect err == 0, 'camera: vkGetMemoryFdPropertiesKHR failed'

        allowed : u32 [ mreq.memoryTypeBits & fd_props.memoryTypeBits ]
        expect allowed != 0, 'camera: no memory type compatible with dmabuf fd'
        mem_type_index : u32 [ 0 ]
        for [ k: u32 0, k < 32, k += 1 ]
            if [ allowed & (u32[1] << k) ]
                mem_type_index = k
                break

        # dedicated allocation bound to the buffer — required on some drivers
        # for imported dmabuf memory.
        ded : VkMemoryDedicatedAllocateInfo [ ]
        ded.sType  = VK_STRUCTURE_TYPE_MEMORY_DEDICATED_ALLOCATE_INFO
        ded.buffer = buf

        imp : VkImportMemoryFdInfoKHR [ ]
        imp.sType      = VK_STRUCTURE_TYPE_IMPORT_MEMORY_FD_INFO_KHR
        imp.pNext      = ref ded
        imp.handleType = VK_EXTERNAL_MEMORY_HANDLE_TYPE_DMA_BUF_BIT_EXT
        imp.fd         = dma_fd

        mai : VkMemoryAllocateInfo [ ]
        mai.sType           = VK_STRUCTURE_TYPE_MEMORY_ALLOCATE_INFO
        mai.pNext           = ref imp
        mai.allocationSize  = byte_size
        mai.memoryTypeIndex = mem_type_index

        mem : VkDeviceMemory [ null ]
        err = vkAllocateMemory[ vk.device, ref mai, null, ref mem ]
        expect err == 0, 'camera: vkAllocateMemory (import fd) failed'
        err = vkBindBufferMemory[ vk.device, buf, mem, 0 ]
        expect err == 0, 'camera: vkBindBufferMemory failed'

        cam_bufs[ idx ] = buf
        cam_mem [ idx ] = mem

    # sample average brightness of a 16x16 region at the center of the
    # mmap'd buffer. cheap and enough to distinguish strobed-on vs off frames.
    intern func brightness_of [ idx: i32 ] -> u64
        ptr : ref u8 [ mm_ptrs[idx] ]
        stride : i32 [ width ]
        cx : i32 [ width  / 2 - 8 ]
        cy : i32 [ height / 2 - 8 ]
        sum : u64 [ 0 ]
        for [ yy: i32 0, yy < 16, yy += 1 ]
            row : i32 [ (cy + yy) * stride + cx ]
            for [ xx: i32 0, xx < 16, xx += 1 ]
                sum += u64[ ptr[ row + xx ] ]
        return sum

    func update []
        if [ fd < 0 ]
            return
        deq : v4l2_buffer [ ]
        deq.type   = V4L2_BUF_TYPE_VIDEO_CAPTURE
        deq.memory = V4L2_MEMORY_MMAP
        err : i32 [ ioctl[ fd, VIDIOC_DQBUF, ref deq ] ]
        if [ err != 0 ]
            return
        current_idx = deq.index
        #printf[ "DQBUF: idx=%u bytesused=%u flags=0x%x seq=%u\n",
        #    deq.index, deq.bytesused, deq.flags, deq.sequence ]

        # IR strobe sync: always blit the brighter of the latest two frames.
        # when the strobe fires, the lit frame wins; between strobes the
        # prior lit frame persists. previous buffer is held across update
        # calls so we can still read from it; the older one gets requeued.
        cur_bright : u64 [ brightness_of[ current_idx ] ]
        use_prev : bool [ prev_idx >= 0 && prev_bright > cur_bright ]
        blit_idx : i32 [ (use_prev) ? prev_idx : current_idx ]

        if [ image ]
            cmd : Command [ vk: vk ]
            cmd.begin[]

            # make host (v4l2/kernel DMA) writes to the imported dmabuf
            # visible to the GPU transfer stage. without this NVIDIA reads
            # stale/uninitialized memory in vkCmdCopyBufferToImage.
            host_bar : VkMemoryBarrier [
                sType:         VK_STRUCTURE_TYPE_MEMORY_BARRIER,
                srcAccessMask: VK_ACCESS_HOST_WRITE_BIT,
                dstAccessMask: VK_ACCESS_TRANSFER_READ_BIT
            ]
            vkCmdPipelineBarrier[ cmd.cmd,
                VK_PIPELINE_STAGE_HOST_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT,
                0, 1, ref host_bar, 0, null, 0, null ]

            # cam_image UNDEFINED → TRANSFER_DST for the buffer→image copy
            cam_barrier : VkImageMemoryBarrier [
                sType: VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER,
                oldLayout: VK_IMAGE_LAYOUT_UNDEFINED,
                newLayout: VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                srcQueueFamilyIndex: VK_QUEUE_FAMILY_IGNORED,
                dstQueueFamilyIndex: VK_QUEUE_FAMILY_IGNORED,
                image: cam_image,
                subresourceRange: VkImageSubresourceRange [
                    aspectMask: VK_IMAGE_ASPECT_COLOR_BIT,
                    levelCount: 1, layerCount: 1 ],
                srcAccessMask: 0,
                dstAccessMask: VK_ACCESS_TRANSFER_WRITE_BIT
            ]
            vkCmdPipelineBarrier[ cmd.cmd,
                VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT,
                0, 0, null, 0, null, 1, ref cam_barrier ]

            # copy dmabuf-backed buffer into the aligned GPU image (tight pack → aligned)
            copy : VkBufferImageCopy [
                bufferOffset:      0,
                bufferRowLength:   0,    # 0 = tight
                bufferImageHeight: 0,
                imageSubresource:  VkImageSubresourceLayers [
                    aspectMask:     VK_IMAGE_ASPECT_COLOR_BIT,
                    mipLevel:       0,
                    baseArrayLayer: 0,
                    layerCount:     1
                ],
                imageOffset: VkOffset3D [ 0, 0, 0 ],
                imageExtent: VkExtent3D [ width, height, 1 ]
            ]
            src_buf : VkBuffer [ (cpu_upload) ? staging_buf : cam_bufs[ blit_idx ] ]
            if [ cpu_upload ]
                src_ptr : ref u8 [ mm_ptrs[ blit_idx ] ]
                memcpy[ staging_ptr, src_ptr, width * height ]
            vkCmdCopyBufferToImage[ cmd.cmd,
                src_buf, cam_image,
                VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, ref copy ]

            # cam_image TRANSFER_DST → TRANSFER_SRC for the blit
            cam_barrier.oldLayout     = VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL
            cam_barrier.newLayout     = VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL
            cam_barrier.srcAccessMask = VK_ACCESS_TRANSFER_WRITE_BIT
            cam_barrier.dstAccessMask = VK_ACCESS_TRANSFER_READ_BIT
            vkCmdPipelineBarrier[ cmd.cmd,
                VK_PIPELINE_STAGE_TRANSFER_BIT, VK_PIPELINE_STAGE_TRANSFER_BIT,
                0, 0, null, 0, null, 1, ref cam_barrier ]

            # image: any → TRANSFER_DST before blit, back to SHADER_READ after
            image.transition_in[ cmd.cmd, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL ]

            sx0 : i32 [ i32 [ src_rect.x ] ]
            sy0 : i32 [ i32 [ src_rect.y ] ]
            sx1 : i32 [ i32 [ src_rect.x + src_rect.w ] ]
            sy1 : i32 [ i32 [ src_rect.y + src_rect.h ] ]
            blit : VkImageBlit [
                srcSubresource: VkImageSubresourceLayers [
                    aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, layerCount: 1 ],
                srcOffsets: [
                    VkOffset3D [ x: sx0, y: sy0, z: 0 ],
                    VkOffset3D [ x: sx1, y: sy1, z: 1 ] ],
                dstSubresource: VkImageSubresourceLayers [
                    aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, layerCount: 1 ],
                dstOffsets: [
                    VkOffset3D [ x: 0, y: 0, z: 0 ],
                    VkOffset3D [ x: width, y: height, z: 1 ] ]
            ]
            vkCmdBlitImage[ cmd.cmd,
                cam_image,      VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                image.vk_image, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                1, ref blit, VK_FILTER_LINEAR ]

            image.transition_in[ cmd.cmd, VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
            cmd.submit[]

        # hold current frame's buffer as prev for next round's comparison;
        # return the older prev buffer to the kernel.
        if [ prev_idx >= 0 ]
            qb : v4l2_buffer [ ]
            qb.type   = V4L2_BUF_TYPE_VIDEO_CAPTURE
            qb.memory = V4L2_MEMORY_MMAP
            qb.index  = prev_idx
            ioctl[ fd, VIDIOC_QBUF, ref qb ]
        prev_idx    = current_idx
        prev_bright = cur_bright

    func dealloc []
        if [ fd < 0 ] return
        bt : i32 V4L2_BUF_TYPE_VIDEO_CAPTURE
        ioctl[ fd, VIDIOC_STREAMOFF, ref bt ]
        for [ i: i32 0, i < buffer_count, i += 1 ]
            if [ !cpu_upload ]
                vkDestroyBuffer[ vk.device, cam_bufs[i], null ]
                vkFreeMemory   [ vk.device, cam_mem[i],  null ]
            munmap[ mm_ptrs[i], mm_sizes[i] ]
        if [ staging_buf ]
            vkUnmapMemory  [ vk.device, staging_mem ]
            vkDestroyBuffer[ vk.device, staging_buf, null ]
            vkFreeMemory   [ vk.device, staging_mem, null ]
        if [ cam_image ]
            vkDestroyImage[ vk.device, cam_image, null ]
            vkFreeMemory  [ vk.device, cam_image_mem, null ]
        close[ fd ]
        fd = -1


element CameraView
    public camera   : Camera
    public src_rect : rect
    mutable once : bool

    func draw [ w: Window ]
        if [ !camera ] return
        if [ !once ]
            camera.src_rect = src_rect
            camera.update[]
            once = true
        cv : Canvas w.screen
        cv.draw_image[ camera.image, rect [ x: 0, y: 0, w: a.bounds.w, h: a.bounds.h ] ]
        cv.paint[]
        cv.sync_fence[]
        once = false

    func render [] -> Elements
        return null

shader Basic
    public proj  : mat4f
    public model : mat4f
    public view  : mat4f
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgbaf ] ]


class IBL
    public placeholder : i32


shader PBR
    mutable pos      : vec4f
    mutable dir      : vec4f
    mutable model    : mat4f
    mutable view     : mat4f
    mutable proj     : mat4f

    attrib color        : LayoutBinding [ type:typeid[ Surface ], id:Surface.color,        count:1, format: typeid[ rgba8 ] ]
    attrib normal       : LayoutBinding [ type:typeid[ Surface ], id:Surface.normal,       count:1, format: typeid[ rgba8 ] ]
    attrib emission     : LayoutBinding [ type:typeid[ Surface ], id:Surface.emission,     count:1, format: typeid[ rgbaf ] ]
    attrib rough        : LayoutBinding [ type:typeid[ Surface ], id:Surface.rough,        count:1, format: typeid[ u8 ] ]
    attrib metal        : LayoutBinding [ type:typeid[ Surface ], id:Surface.metal,        count:1, format: typeid[ u8 ] ]
    attrib height       : LayoutBinding [ type:typeid[ Surface ], id:Surface.height,       count:1, format: typeid[ f32 ] ]
    attrib ao           : LayoutBinding [ type:typeid[ Surface ], id:Surface.ao,           count:1, format: typeid[ u8 ] ]
    attrib ior          : LayoutBinding [ type:typeid[ Surface ], id:Surface.ior,          count:1, format: typeid[ f32 ] ]
    attrib environment  : LayoutBinding [ type:typeid[ Surface ], id:Surface.environment,  count:1, format: typeid[ rgbaf ] ]

    attrib a_pos        : VertexInput    [ type:typeid[ vec3f ] ]
    attrib a_normal     : VertexInput    [ type:typeid[ vec3f ] ]
    attrib a_uv         : VertexInput    [ type:typeid[ vec2f ] ]
    attrib a_color_0    : VertexInput    [ type:typeid[ vec4f ] ]
    attrib a_color_1    : VertexInput    [ type:typeid[ vec4f ] ]
    attrib v_world_normal : VertexOutput [ type:typeid[ vec3f ] ]
    attrib v_world_pos    : VertexOutput [ type:typeid[ vec3f ] ]
    attrib v_view_pos     : VertexOutput [ type:typeid[ vec3f ] ]
    attrib v_uv           : VertexOutput [ type:typeid[ vec2f ] ]
    attrib fragColor      : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        proj  = mat4f.identity[]
        model = mat4f.identity[]
        view  = mat4f.identity[]

    func pow2 [ x: float ] -> GLSL float {
        return x * x;
    }

    func pow5 [ x: float ] -> GLSL float {
        float x2 = x * x;
        return x2 * x2 * x;
    }

    func sRGBToLinear [ srgbColor: vec3f ] -> GLSL vec3f {
        return pow(srgbColor, vec3(2.2));
    }

    func linearToSRGB [ srgbColor: vec3f ] -> GLSL vec3f {
        return pow(srgbColor, vec3(1.0/2.2));
    }

    func F_Schlick [ f0: vec3f, cos_theta: float ] -> GLSL vec3f {
        return f0 + (1.0 - f0) * pow5(1.0 - cos_theta);
    }

    func D_GGX [ roughness: float, NdotH: float ] -> GLSL float {
        float alpha    = pow2(roughness);
        float alpha_sq = pow2(alpha);
        float denom    = pow2(NdotH) * (alpha_sq - 1.0) + 1.0;
        return alpha_sq / (3.14159265359 * pow2(denom));
    }

    func G_Smith [ roughness: float, NdotV: float, NdotL: float ] -> GLSL float {
        float k    = pow2(roughness + 1.0) / 8.0;
        float G1_V = NdotV / max((NdotV * (1.0 - k) + k), 0.0001);
        float G1_L = NdotL / max((NdotL * (1.0 - k) + k), 0.0001);
        return G1_V * G1_L;
    }

    func BRDF [ L: vec3f, V: vec3f, N: vec3f, albedo: vec3f, mat_ior: float, metallic: float, roughness: float ] -> GLSL vec3f {
        roughness = max(roughness, 0.05);
        vec3  H     = normalize(L + V);
        float NdotL = max(dot(N, L), 0.0);
        float NdotV = max(dot(N, V), 0.0);
        float NdotH = max(dot(N, H), 0.0);
        float HdotV = max(dot(H, V), 0.0);
        float nonMetalF0 = pow((mat_ior - 1.0) / (mat_ior + 1.0), 2.0);
        vec3  F0       = mix(vec3(nonMetalF0), albedo, metallic);
        vec3  F        = F_Schlick(F0, HdotV);
        float D        = D_GGX(roughness, NdotH);
        float G        = G_Smith(roughness, NdotV, NdotL);
        vec3  specular = (D * F * G) / max(4.0 * NdotV * NdotL, 0.0001);
        vec3  kD       = (vec3(1.0) - F) * (1.0 - metallic);
        vec3  diffuse  = kD * albedo / 3.14159265359;
        return (diffuse + specular) * NdotL;
    }

    func perturbNormal [ N: vec3f, V: vec3f, texcoord: vec2f ] -> GLSL vec3f {
        vec3 map = texture(normal, texcoord).rgb * 2.0 - 1.0;
        vec3 q1  = dFdx(v_world_pos);
        vec3 q2  = dFdy(v_world_pos);
        vec2 st1 = dFdx(texcoord);
        vec2 st2 = dFdy(texcoord);
        vec3 T   = normalize(q1 * st2.y - q2 * st1.y);
        vec3 B   = normalize(cross(N, T));
        mat3 TBN = mat3(T, B, N);
        return normalize(TBN * map);
    }

    func parallaxMapping [ texCoords: vec2f, viewDir: vec3f ] -> GLSL vec2f {
        float height_scale = 0.04;
        float h = texture(height, texCoords).r;
        vec2  p = viewDir.xy / viewDir.z * (h * height_scale);
        return texCoords - p;
    }

    func environmentMapping [ R: vec3f, roughness: float ] -> GLSL vec3f {
        float lod   = roughness * 7.0;
        float lodf  = floor(lod);
        float lodfr = lod - lodf;
        int   mip0  = int(lodf);
        int   mip1  = min(mip0 + 1, 7);
        vec3  s0    = texture(environment, vec4(R, mip0)).rgb;
        vec3  s1    = texture(environment, vec4(R, mip1)).rgb;
        return mix(s0, s1, lodfr);
    }

    func calculatePBR [ texCoords: vec2f, worldPos: vec3f, n: vec3f, viewPos: vec3f ] -> GLSL vec4f {
        vec3 cameraPos      = ubo.pos.xyz;
        vec3 V              = normalize(cameraPos - worldPos);
        vec2 texCoordsMapped = parallaxMapping(texCoords, V);
        vec4  baseColor     = texture(color,    texCoordsMapped);
        float mat_ior       = texture(ior,      texCoordsMapped).r;
        float metallic      = texture(metal,    texCoordsMapped).r;
        float roughness     = texture(rough,    texCoordsMapped).r;
        float mat_ao        = texture(ao,       texCoordsMapped).r;
        vec3  emit          = texture(emission, texCoordsMapped).rgb;
        float intensity     = texture(emission, texCoordsMapped).a;
        vec3  rough_color   = baseColor.rgb;
        vec3  N             = perturbNormal(n, V, texCoordsMapped);
        vec3  R             = reflect(-V, N);
        vec3  envColor      = environmentMapping(R, roughness);
        vec3  ambient       = envColor * rough_color * mat_ao;
        vec3  lightDir      = normalize(vec3(1.0, 1.0, 1.0));
        vec3  lightColor    = vec3(1.0);
        vec3  Lo            = BRDF(lightDir, V, N, rough_color, mat_ior, metallic, roughness) * lightColor;
        vec3  result        = ambient + Lo + emit * intensity;
        result              = linearToSRGB(result);
        return vec4(result, baseColor.a);
    }

    func fragment [] -> GLSL none {
        fragColor = calculatePBR(v_uv, v_world_pos, normalize(v_world_normal), v_view_pos);
    }

    func vertex [] -> GLSL none {
        mat4 m         = ubo.proj * ubo.view * ubo.model;
        mat4 wm        = ubo.model;
        vec4 world_pos = wm * vec4(a_pos, 1.0);
        v_world_normal = mat3(transpose(inverse(ubo.model))) * a_normal;
        v_world_pos    = world_pos.xyz;
        v_view_pos     = inverse(ubo.view)[3].xyz;
        v_uv           = a_uv;
        gl_Position    = m * vec4(a_pos, 1.0);
    }


shader BlurV
    mutable model : mat4f
    mutable view : mat4f
    mutable proj : mat4f
    mutable reduction_scale : f32
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color,        count:1, format: typeid[ rgba8 ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func gaussian [ x: float, sigma: float ] -> GLSL float {
        const float PI = 3.14159265359;
        return exp(-(x * x) / (2.0 * sigma * sigma)) / (sqrt(2.0 * PI) * sigma);
    }

    func fragment [] -> GLSL none {
        const int   kernel_size = 15;
        const float sigma = 3.0;
        vec2  uv_coord   = v_uv;
        int   h          = textureSize(color, 0).y;
        vec2  offset     = vec2(0.0, 1.0 / float(h) * 1.0);
        float weight_sum = gaussian(0.0, sigma);
        vec4  result     = texture(color, uv_coord) * weight_sum;
        for (int i = 1; i <= kernel_size / 2; ++i) {{
            float w      = gaussian(float(i), sigma);
            vec2  shift  = offset * float(i);
            result      += texture(color, uv_coord + shift) * w;
            result      += texture(color, uv_coord - shift) * w;
            weight_sum  += 2.0 * w;
        }}
        fragColor = vec4((result / weight_sum).xyz, 1.0);
    }


shader Blur
    mutable model : mat4f
    mutable view : mat4f
    mutable proj : mat4f
    mutable reduction_scale : f32
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color,        count:1, format: typeid[ rgba8 ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func gaussian [ x: float, sigma: float ] -> GLSL float {
        const float PI = 3.14159265359;
        return exp(-(x * x) / (2.0 * sigma * sigma)) / (sqrt(2.0 * PI) * sigma);
    }

    func fragment [] -> GLSL none {
        const int   kernel_size = 15;
        const float sigma = 3.0;
        vec2  uv_coord   = v_uv;
        int   h          = textureSize(color, 0).y;
        vec2  offset     = vec2(1.0 / float(h) * ubo.reduction_scale, 0.0);
        float weight_sum = gaussian(0.0, sigma);
        vec4  result     = texture(color, uv_coord) * weight_sum;
        for (int i = 1; i <= kernel_size / 2; ++i) {{
            float w      = gaussian(float(i), sigma);
            vec2  shift  = offset * float(i);
            result      += texture(color, uv_coord + shift) * w;
            result      += texture(color, uv_coord - shift) * w;
            weight_sum  += 2.0 * w;
        }}
        fragColor = vec4((result / weight_sum).xyz, 1.0);
    }


# CanvasBlurV — samples a mipped source at a fractional LOD with a
# vertical gaussian kernel. the mip chain (populated by Canvas.blur
# via vkCmdBlitImage) provides the wide reduce+resample; this pass
# blurs vertically across the entire output at full res.
shader CanvasBlurV
    mutable model     : mat4f
    mutable view      : mat4f
    mutable proj      : mat4f
    mutable radius_uv : f32
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func gaussian [ x: float, sigma: float ] -> GLSL float {
        const float PI = 3.14159265359;
        return exp(-(x * x) / (2.0 * sigma * sigma)) / (sqrt(2.0 * PI) * sigma);
    }

    func fragment [] -> GLSL none {
        const int   kernel_size = 9;
        const float sigma       = 2.0;
        vec2  offset            = vec2(0.0, ubo.radius_uv);
        float weight_sum        = gaussian(0.0, sigma);
        vec4  result            = texture(color, v_uv) * weight_sum;
        for (int i = 1; i <= kernel_size / 2; ++i) {{
            float w      = gaussian(float(i), sigma);
            vec2  shift  = offset * float(i);
            result      += texture(color, v_uv + shift) * w;
            result      += texture(color, v_uv - shift) * w;
            weight_sum  += 2.0 * w;
        }}
        fragColor = vec4((result / weight_sum).xyz, 1.0);
    }


# CanvasBlurH — final stage. samples blur_v output at LOD 0 (full res,
# already V-blurred) and applies a horizontal gaussian. fine-tune
# kernel width comes from the fixed sigma; the mip LOD on V carried
# the wide-radius reduce.
shader CanvasBlurH
    mutable model      : mat4f
    mutable view       : mat4f
    mutable proj       : mat4f
    mutable radius_uv  : f32
    mutable mix_factor : f32
    attrib low  : LayoutBinding [ type:typeid[ BlurPair ], id:BlurPair.low,  count:1, format: typeid[ rgba8 ] ]
    attrib high : LayoutBinding [ type:typeid[ BlurPair ], id:BlurPair.high, count:1, format: typeid[ rgba8 ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func gaussian [ x: float, sigma: float ] -> GLSL float {
        const float PI = 3.14159265359;
        return exp(-(x * x) / (2.0 * sigma * sigma)) / (sqrt(2.0 * PI) * sigma);
    }

    func blur_sample [ s: sampler2D, st: vec2f, off: vec2f, sigma: f32 ] -> GLSL vec4f {
        const int kernel_size = 9;
        float weight_sum = gaussian(0.0, sigma);
        vec4  result     = texture(s, st) * weight_sum;
        for (int i = 1; i <= kernel_size / 2; ++i) {{
            float w      = gaussian(float(i), sigma);
            vec2  shift  = off * float(i);
            result      += texture(s, st + shift) * w;
            result      += texture(s, st - shift) * w;
            weight_sum  += 2.0 * w;
        }}
        return result / weight_sum;
    }

    func fragment [] -> GLSL none {
        const float sigma  = 2.0;
        vec2  offset       = vec2(ubo.radius_uv, 0.0);
        vec4  lo           = blur_sample(low,  v_uv, offset, sigma);
        vec4  hi           = blur_sample(high, v_uv, offset, sigma);
        vec4  m            = mix(lo, hi, ubo.mix_factor);
        fragColor          = vec4(m.xyz, 1.0);
    }


shader UXBackground
    mutable model        : mat4f
    mutable view         : mat4f
    mutable proj         : mat4f
    mutable low_color    : vec4f
    mutable high_color   : vec4f

    attrib background     : LayoutBinding [ type:typeid[ UXSurface ], id:UXSurface.background,     count:1, format: typeid[ rgba8 ] ]
    attrib frost          : LayoutBinding [ type:typeid[ UXSurface ], id:UXSurface.frost,          count:1, format: typeid[ rgba8 ] ]
    attrib blur           : LayoutBinding [ type:typeid[ UXSurface ], id:UXSurface.blur,           count:1, format: typeid[ rgba8 ] ]
    attrib compose        : LayoutBinding [ type:typeid[ UXSurface ], id:UXSurface.compose,        count:1, format: typeid[ rgba8 ] ]
    attrib colorize       : LayoutBinding [ type:typeid[ UXSurface ], id:UXSurface.colorize,       count:1, format: typeid[ rgba8 ] ]
    attrib overlay        : LayoutBinding [ type:typeid[ UXSurface ], id:UXSurface.overlay,        count:1, format: typeid[ rgba8 ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

    func rgb2hsv [ c: vec3f ] -> GLSL vec3f {
        vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
        vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
        vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
        float d = q.x - min(q.w, q.y);
        float e = 1.0e-10;
        return vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
    }

    func hsv2rgb [ c: vec3f ] -> GLSL vec3f {
        vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
        vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
        return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
    }

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    # 44
    func fragment [] -> GLSL none {
        vec4  comp     = texture(compose,        v_uv);
        vec4  col      = texture(colorize,       v_uv);
        vec4  over     = texture(overlay,        v_uv);
        float luminance = 1.0 - ((comp.b - 0.5020) * 2.0);
        vec3  f;
        
        if (comp.r < 0.5020) {
            f = mix(
                texture(background, v_uv).rgb,
                texture(blur,       v_uv).rgb,
                comp.r / 0.5020) * luminance;
        } else {
            f = mix(
                texture(blur,       v_uv).rgb,
                texture(frost,      v_uv).rgb,
                (comp.r - 0.5020) / (1.0 - 0.5020)) * luminance;
        }

        if (comp.g > 0.0) {
            float hue = comp.g;
            vec3  hsv = rgb2hsv(f);
            vec3  clr = vec3(comp.g, hsv.y, hsv.z);
            f = hsv2rgb(clr);
        }

        f = mix(f, over.rgb, over.a);

        fragColor = vec4(f, 1.0);
    }


class DrawState
    public blur_radius          : f32
    public stroke_size          : f32
    public stroke_cap           : Cap
    public stroke_join          : Join
    public stroke_miter_limit   : f32
    public stroke_dash_offset   : f32
    public font                 : Font
    public tx                   : Texture
    public x                    : f32
    public y                    : f32
    public w                    : f32
    public h                    : f32
    public fill_color           : vec4f
    public stroke_color         : vec4f
    public opacity              : f32

    public func set_default [ ] 
        font         = Font[ size: 22, uri: path 'fonts/Sofia-Sans-Condensed.ttf' ]
        stroke_cap   = Cap.round
        stroke_join  = Join.round
        stroke_size  = 0
        fill_color   = vec4f[0,0,0,1]
        stroke_color = vec4f[0,0,0,1]
        opacity      = 1.0


class Particle
    public pos      : vec2f
    public velocity : vec2f
    public density  : f32
    public pressure : f32


scalar sec : i64
    cast -> ns  [ a * 1000000000 ]
    cast -> ms  [ a * 1000 ]

scalar ms : i64
    cast -> sec [ a / 1000 ]
    cast -> ns  [ a * 1000000 ]

scalar ns : i64
    cast -> sec [ a / 1000000000 ]
    cast -> ms  [ a / 1000000 ]



func parse_quoted [ cursor: ref cstr, max_len: sz ] -> string
    first : cstr [ cursor[0] ]
    if [ first[0] != '"' && first[0] != '\'' ]
        return ''
    quote_ch : i8 [ first[0] ]
    cursor[0] += 1
    start : cstr [ cursor[0] ]
    s     : cstr [ start ]
    last_slash : false
    while [ s[0] != 0 ]
        if [ s[0] == '\\' ]
            last_slash = true
        el [ s[0] == quote_ch && !last_slash ]
            break
        el
            last_slash = false
        s += 1
    if [ s[0] == 0 ]
        return ''                                                                                                                   
    slen : sz [ s - start ]
    if [ max_len > 0 && slen > max_len ]                                                                                            
        return ''                            
    cursor[0] = ref s[1]
    return string [ chars: start, ref_length: slen ] 


func parse_qualifiers [ bl:StyleBlock, p: ref cstr ] -> array StyleQualifier
    expect bl, 'style-block context.. its not set!  dak not steady either'
    start : cstr   [ p[0] ]
    end   : cstr   [ null ]
    scan  : cstr   [ start ]
    qstr  : string [ null ]
    while [ scan[0] && scan[0] != '{' ]
        scan += 1
    end  = scan
    qstr = string [ chars: start, ref_length: distance[ start, scan ] ]
    if [ !qstr.count ]
        p[0] = end
        return null
    quals  : qstr.split[ ',' ]
    result : array StyleQualifier [ ]
    ops    : array string [ '!=', '>=', '<=', '>', '<', '=' ]

    for [ qs: string ] in quals
        qq : string [ qs.trim[] ]
        anchored : bool [ false ]
        if [ qq.count && qq.chars[0] == '/' ]
            anchored = true
            qq       = qq.mid[ 1, qq.count - 1 ].trim[]
        if [ !qq.count ]
            continue
        v : StyleQualifier[ bl:bl ]
        result.push[ v ]
        parent_to_child : qq.split[ '/' ]
        processed : StyleQualifier [ null ]
        for [ i: i32 parent_to_child.count - 1, i >= 0, i -= 1 ]
            q : string [ parent_to_child[i].trim[] ]
            if [ processed ]
                v.parent = StyleQualifier[ bl:bl ]
                v = v.parent
            idot : q.index_of[ '.' ]
            icol : q.index_of[ ':' ]
            tail : string [ null ]
            if [ idot >= 0 ]
                sp      : array string q.split[ '.' ]
                no_type : q.chars[0] == '.'
                v.type  = (no_type) ? 'element' : sp[0].trim[]
                sp2     : sp[ (no_type) ? 0 : 1 ].split[ ':' ]
                v.id    = sp2[0]
                if [ icol >= 0 ]
                    tail = q.mid[ icol + 1, q.count - (icol + 1) ].trim[]
            el
                if [ icol >= 0 ]
                    v.type = q.mid[ 0, icol ].trim[]
                    tail   = q.mid[ icol + 1, q.count - (icol + 1) ].trim[]
                el
                    v.type = q.trim[]
            if [ v.type ]
                v.ty = Au.find_type[ v.type.chars, null ]
                expect v.ty, 'type must exist: {v.type}'
                if [ bl.types.index_of[ v.ty ] == -1 ]
                    bl.types.push[ v.ty ]
            if [ tail ]
                is_op : false
                for [ op_name: string ] in ops
                    if [ tail.index_of[ op_name ] >= 0 ]
                        is_op = true
                        sp    : array string [ tail.split[ op_name ] ]
                        f     : string [ sp[0] ]
                        v.state = f.trim[]
                        v.oper  = op_name
                        istart : i32 [ f.count + op_name.count ]
                        v.value = tail.mid[ istart, tail.count - istart ].trim[]
                        break
                if [ !is_op ]
                    v.state = tail
            processed = v
            v.hold_members[]
        if [ anchored ]
            v.anchored = true
    p[0] = end
    return result


class CSSLine
    public indent  : i32
    public content : string


func split_css [ code: string ] -> array CSSLine
    result : array CSSLine [ ]
    n : num [ code.count ]
    i : num [ 0 ]
    while [ i < n ]
        ind : i32 [ 0 ]
        while [ i < n && (code.chars[i] == ' ' || code.chars[i] == '\t') ]
            if [ code.chars[i] == '\t' ]
                ind += 4
            el
                ind += 1
            i += 1
        if [ i >= n ]
            break
        if [ code.chars[i] == '\n' ]
            i += 1
            continue
        if [ i + 1 < n && code.chars[i] == '/' && code.chars[i + 1] == '/' ]
            while [ i < n && code.chars[i] != '\n' ]
                i += 1
            continue
        if [ i + 1 < n && code.chars[i] == '/' && code.chars[i + 1] == '*' ]
            i += 2
            while [ i + 1 < n && !(code.chars[i] == '*' && code.chars[i + 1] == '/') ]
                i += 1
            if [ i + 1 < n ]
                i += 2
            continue
        line_start : num [ i ]
        while [ i < n && code.chars[i] != '\n' ]
            i += 1
        line_len : num [ i - line_start ]
        c : string [ code.mid[ line_start, line_len ].trim[] ]
        if [ c.count ]
            result.push[ CSSLine [ indent: ind, content: c ] ]
    return result


func validate_entries [ entries: StyleEntryMap, ty: Au_t, errors: array string ]
    for [ se: StyleEntry, prop: string ] in entries
        dot  : prop.index_of[ '.' ]
        name : (dot > 0) ? prop.mid[ 0, dot ].trim[] : prop
        mem  : Au.find_member[ ty, name.chars, AU_MEMBER_VAR, 0, true ]
        if [ !mem ]
            errors.push[ string 'css: type {ty.ident} has no member {name} (from property {prop})' ]
            continue
        if [ dot > 0 ]
            sub_bl : (se.value to StyleBlock)
            if [ sub_bl && mem.meta.a ]
                validate_entries[ sub_bl.entries, mem.meta.a, errors ]


func validate_block [ bl: StyleBlock, errors: array string ]
    for [ ty: Au_t ] in bl.types
        validate_entries[ bl.entries, ty, errors ]


func parse_block_body [ bl: StyleBlock, lines: array CSSLine, first: i32, last: i32, base_indent: i32 ]
    j : i32 [ first ]
    while [ j <= last ]
        ind : i32    [ lines[j].indent  ]
        lc  : string [ lines[j].content ]
        if [ ind <= base_indent || lc == '}' ]
            j += 1
            continue
        ci : num [ lc.index_of[ ':' ] ]
        expect ci > 0, 'expected key: value'
        member  : string [ lc.mid[ 0, ci ].trim[] ]
        val_str : string [ lc.mid[ ci + 1, lc.count - (ci + 1) ].trim[] ]
        for [ k: i32 0, k < member.count, k += 1 ]
            if [ member.chars[k] == '-' ]
                member.chars[k] = '_'
        sub_end : i32 [ j ]
        while [ sub_end + 1 <= last && lines[sub_end + 1].indent > ind ]
            sub_end += 1
        if [ val_str.count == 0 && sub_end > j ]
            inner : StyleBlock [ quals:bl.quals, types:bl.types ]
            parse_block_body[ inner, lines, j + 1, sub_end, ind ]
            dot : num [ member.index_of[ '.' ] ]
            if [ dot > 0 ]
                inner.key      = member.mid[ dot + 1, member.count - dot - 1 ]
                inner.property = member.mid[ 0, dot ]
                inner.parent = bl
                bl.blocks.push[ inner ]
            el
                bl.entries[ member ] = StyleEntry [ member: member, value: inner, bl: bl ]
            j = sub_end + 1
            continue
        # indent parser: split off transition suffix (e.g. "#84a, 444ms") so
        # `:hovered { fill_color: #84a, 444ms }` populates StyleEntry.trans
        # the same way the `;`-delimited parser already does.
        ci2   : num    [ val_str.index_of[ ',' ] ]
        param : string [ (ci2 >= 0) ? val_str.mid[ ci2 + 1, val_str.count - (ci2 + 1) ].trim[] : null ]
        value : string [ (ci2 >= 0) ? val_str.mid[ 0, ci2 ].trim[] : val_str ]
        trans : (param) ? StyleTransition[ param ] : null
        bl.entries[ member ] = StyleEntry [ member: member, value: value, trans: trans, bl: bl ]
        j += 1


func is_cmt[c: symbol] -> bool [ c[0] == '/' && c[1] == '*' ]


func ws [ p_cursor: ref cstr ] -> bool
    cursor : cstr [ p_cursor[0] ]
    while [ isspace[ cursor[0] ] || is_cmt[ cursor ] ]
        while [ isspace[ cursor[0] ] ]
            cursor += 1
        if [ is_cmt[ cursor ] ]
            f : cstr [ strstr[ cursor, '*/' ] ]
            cursor = (f) ? ref f[2] : ref cursor[ strlen[ cursor ] - 1 ]
    p_cursor[0] = cursor
    return cursor != 0



func scan_to [ p_cursor: ref cstr, chars: string ] -> bool
    sl  : false
    qt  : false
    qt2 : false
    cursor : cstr [ p_cursor[0] ]
    while [ cursor && cursor[0] ]
        if [ !sl ]
            if [ cursor[0] == '"' ]
                qt = !qt
            el [ cursor[0] == '\'' ]
                qt2 = !qt2
        sl = cursor[0] == '\\'
        if [ !qt && !qt2 ]
            if [ chars.index_of[ ref cursor[0] ] >= 0 ]
                p_cursor[0] = cursor
                return true
        cursor += 1
    p_cursor[0] = null
    return false


func distance [ a:i8, b:i8 ] -> i64
    return abs[ sz[ a ] - sz[ b ] ]

    

func is_alpha2 [ c: i8 ] -> bool                                                                                                     
    return (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z')


func bounce_out [ x: f64 ] -> f64
    n1 : f64 [ 7.5625 ]
    d1 : f64 [ 2.75 ]
    if [ x < 1.0 / d1 ]
        return n1 * x * x
    el [ x < 2.0 / d1 ]
        return n1 * (x - 1.5 / d1) * x + 0.75
    el [ x < 2.5 / d1 ]
        return n1 * (x - 2.25 / d1) * x + 0.9375
    el
        return n1 * (x - 2.625 / d1) * x + 0.984375


func ux_event [ e: element, esubs: EventDispatch, ev: Event ]
    if [ !esubs.callbacks ]
        return
    ev.target = e
    esubs.invoke[ ev ]
    ev.target = null