# used with shader type to manage layout-binding
enum ShaderStage
    vertex   : 0
    fragment : 1
    compute  : 2

class LayoutBinding
    type    : Au_t
    id      : int
    count   : u32
    format  : Au_t

# storage image binding for compute shaders. emits
#   layout(<glsl_format>, set=1, binding=N) writeonly uniform image2D <name>;
# the host provides a Texture (created with VK_IMAGE_USAGE_STORAGE_BIT) via
# the same name-to-instance map used for sampler bindings.
class StorageImage
    type    : Au_t
    id      : int
    count   : u32
    format  : Au_t

# storage buffer binding for compute shaders. emits
#   layout(std430, set=1, binding=N) readonly buffer <name>_t { vec4 <name>[]; };
# host provides a Buffer (created with u_storage = true) via the samplers map.
class StorageBuffer
    type    : Au_t
    id      : int
    count   : u32
    format  : Au_t

class VertexInput
    public type : Au_t

class VertexOutput
    public type : Au_t

class FragmentInput
    public type : Au_t

class FragmentOutput
    public type : Au_t

# GLSL opaque sampler types. Silver doesn't need to know their layout;
# they exist as named types so shader function signatures can pass them through.
class sampler2D
class sampler3D
class samplerCube

class Render
    context vk                             : vk_context
    context w                              : Display
    public  id                             : i32
    mutable wscale                         : f32
    mutable width                          : i32
    mutable height                         : i32
    public  reduce                         : bool
    public  models                         : array Model
    public  clear_color                    : vec4f
    public  reduction                      : Texture
    public  color                          : Texture
    public  depth                          : Texture
    # set to true to make this Render preserve existing color attachment
    # contents (LOAD_OP_LOAD instead of LOAD_OP_CLEAR). use when this Render
    # is layering output on top of another pass that already wrote into the
    # same color texture (e.g. a text-on-canvas overlay sharing the canvas's
    # color attachment).
    public  load_existing                  : bool
    # opt IN to depth: 3D scenes that need depth testing set this to
    # true. 2D passes (blur, reduction, compose, text) leave it false
    # and skip the depth texture entirely — halving texture churn on
    # resize.
    public  use_depth                      : bool
    intern  reduce_model                   : Model
    intern  vk_command_buffer              : VkCommandBuffer
    intern  vk_swap_image                  : VkImage
    intern  vk_fence                       : VkFence
    intern  vk_semaphore                   : VkSemaphore
    intern  vk_image_available_semaphore   : VkSemaphore
    intern  vk_render_finished_semaphore   : VkSemaphore
    intern  vk_framebuffer                 : new VkFramebuffer [2]
    intern  vk_render_pass                 : new VkRenderPass  [2]
    intern  last_width                     : i32
    intern  last_height                    : i32

    public func hash[] -> u64
        return u64[handle[a]]

    public func update [ ] 
        backbuffer: !vk_swap_image
        width  = (wscale > 0) ? w.width  * wscale : width
        height = (wscale > 0) ? w.height * wscale : height

        if [ !width || !height ]
            fault "width / height or wscale not set on render Render"
            exit[ 0 ]
        
        if [ width == last_width && height == last_height ]
            return

        # wait for this Render's own in-flight frame before tearing down
        # its attachments / framebuffers. replaces the global vkDeviceWaitIdle
        # Display.resize used to do — each Render fences only its own work.
        if [ last_width > 0 && last_height > 0 ]
            sync_fence[]

        last_width  = width
        last_height = height
            
        if [ color ]
            color.resize[ width, height ]
            if [ depth ]
                depth.resize[ width, height ]
            if [ reduce ]
                reduction.resize[ width / 4, height / 4 ]
        el
            ii: i32 w.surface_format.format
            printf[ "caller vk_format is %i\n", w.surface_format.format]
            color = Texture [ vk: vk, w: w, width: width, height: height,
                vk_format: w.surface_format.format, swap: !backbuffer,
                surface: Surface.color, vk_image: vk_swap_image ]
            if [ use_depth ]
                depth = Texture [ vk: vk, w: w, width: width, height: height,
                    vk_format: VK_FORMAT_D32_SFLOAT, swap: !backbuffer ]
            if [ reduce ]
                reduction = Texture [ vk: vk, w: w, width: width / 4, height: height / 4,
                    vk_format: w.surface_format.format, swap: !backbuffer ]
        
        if [ !backbuffer ]
            color.transition[ VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
        el
            color.transition[ VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
            if [ reduce ]
                reduction.transition[ VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
        
        if [ !color.vk_image_view ]
            return
        # color-only render passes (e.g. text overlay) skip the depth view.
        has_depth : bool [ (depth) ? true : false ]
        for [ i: 0, i < 1 + reduce, i += 1 ]
            vk_view_attachments: local VkImageView [2]
            vk_view_attachments[0] = (i == 0) ? color.vk_image_view : reduction.vk_image_view
            if [ has_depth ]
                vk_view_attachments[1] = depth.vk_image_view
            info : header[ color ]
            printf[ "color.vk_image_view = %p\n", color.vk_image_view]
            n_att : i32 [ (i == 0) ? ((has_depth) ? 2 : 1) : 1 ]
            result: vkCreateFramebuffer[ vk.device, VkFramebufferCreateInfo [
                sType:           VK_STRUCTURE_TYPE_FRAMEBUFFER_CREATE_INFO,
                renderPass:      vk_render_pass[i],
                attachmentCount: n_att,
                pAttachments:    vk_view_attachments,
                width:           width  / ((i == 0) ? 1 : 4),
                height:          height / ((i == 0) ? 1 : 4),
                layers:          1
            ], null, ref vk_framebuffer[i] ]

            printf[ "ref of frame = %p\n", ref vk_framebuffer[i] ]

            expect result == VK_SUCCESS, "Failed to create framebuffer"

    public func draw [ ]
        index: u32 [ 0 ]
        for [ i: 0, i < 1 + reduce, i += 1 ]
            if [ i == 0 && bool[ color ] ]
                color.transition[ VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
            el [ i == 1 && bool[ reduction ] ]
                reduction.transition[ VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
                sync_fence[]
            
            vkResetFences[ vk.device, 1, ref vk_fence ]
            frame: VkCommandBuffer [ vk_command_buffer ]
            vkResetCommandBuffer[ frame, 0 ]
            vkBeginCommandBuffer[ frame, VkCommandBufferBeginInfo [
                sType: VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO,
                flags: VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT
            ] ]

            fw: i32 [ (i == 0) ? width : width / 4 ]
            fh: i32 [ (i == 0) ? height : height / 4 ]
            vkCmdSetViewport[ frame, 0, 1, VkViewport [
                x: 0.0, y: 0.0, width: fw, height: fh,
                minDepth: 0.0, maxDepth: 1.0
            ] ]
            vkCmdSetScissor[ frame, 0, 1, VkRect2D [
                offset: VkOffset2D [ 0, 0 ],
                extent: VkExtent2D [ fw, fh ]
            ] ]
            clear_values: local VkClearValue [2]
            #printf[ "  Render.draw iter=%d reduce=%d swap=%p clear=[%f,%f,%f,%f]\n",
            #    i, reduce, vk_swap_image,
            #    clear_color.x, clear_color.y, clear_color.z, clear_color.w ]
            clear_values[0].color.float32[0] = clear_color.x
            clear_values[0].color.float32[1] = clear_color.y
            clear_values[0].color.float32[2] = clear_color.z
            clear_values[0].color.float32[3] = clear_color.w
            clear_values[1].depthStencil.depth   = 1.0
            clear_values[1].depthStencil.stencil = 0

            # compute dispatches must be recorded OUTSIDE the render pass.
            # Pipeline.dispatch is a no-op for graphics-only pipelines, so this
            # loop is safe to run over every pipeline.
            if [ i == 0 ]
                for [ m: Model ] in models
                    for [ p: Pipeline ] in m.pipelines
                        p.dispatch[ frame ]
            el
                for [ p: Pipeline ] in reduce_model.pipelines
                    p.dispatch[ frame ]

            render_pass_info : VkRenderPassBeginInfo [
                sType:           VK_STRUCTURE_TYPE_RENDER_PASS_BEGIN_INFO,
                renderPass:      vk_render_pass[i],
                framebuffer:     vk_framebuffer[i],
                renderArea:      VkRect2D [
                    offset: VkOffset2D [ 0, 0 ],
                    extent: VkExtent2D [ fw, fh ]
                ],
                clearValueCount: 2,
                pClearValues:    clear_values
            ]
            vkCmdBeginRenderPass[
                frame, render_pass_info, VK_SUBPASS_CONTENTS_INLINE ]

            if [ i == 0 ]
                #printf[ "    Render.draw models=%i\n", models.count ]
                for [ m: Model ] in models
                    #printf[ "      model.pipelines=%i\n", m.pipelines.count ]
                    for [ p: Pipeline ] in m.pipelines
                        # must be done in trinity
                        #if [ m.transform_count && (p.s inherits PBR) ]
                        #    s: PBR [ p.s ]
                        #    s.model = p.default_model
                        #    for [ j: 0, j < m.transform_count, j += 1 ]
                        #        s.model = m.transforms[j].mul[s.model]
                        p.draw[ frame ]
            el
                for [ p: Pipeline ] in reduce_model.pipelines
                    p.draw[ frame ]

            vkCmdEndRenderPass[ frame ]
            vkEndCommandBuffer[ frame ]
            s_flags: VkPipelineStageFlags [ VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT ]
            submitInfo: VkSubmitInfo [
                sType:                VK_STRUCTURE_TYPE_SUBMIT_INFO,
                commandBufferCount:   1,
                pCommandBuffers:      ref frame,
                waitSemaphoreCount:   (vk_swap_image) ? 1 : 0,
                pWaitSemaphores:      (vk_swap_image) ? ref w.semaphore_frame.vk_image_available_semaphore : null,
                pWaitDstStageMask:    (vk_swap_image) ? ref s_flags : null,
                signalSemaphoreCount: (vk_swap_image) ? 1 : 0,
                pSignalSemaphores:    (vk_swap_image) ? ref w.semaphore_frame.vk_render_finished_semaphore : null
            ]
            vkQueueSubmit[ vk.queue, 1, ref submitInfo, vk_fence ]

    public func sync_fence [ ] 
        result: vkWaitForFences[ vk.device, 1, ref vk_fence, VK_TRUE, UINT64_MAX ]
        expect result == VK_SUCCESS, "fence wait failed"

    func dealloc [ ]
        for [ i: 0, i < 2, i += 1 ]
            vkDestroyFramebuffer[ vk.device, vk_framebuffer[i], null ]
            vkDestroyRenderPass[ vk.device, vk_render_pass[i], null ]
        
        vkDestroyFence[ vk.device, vk_fence, null ]
        vkDestroySemaphore[ vk.device, vk_image_available_semaphore, null ]
        vkDestroySemaphore[ vk.device, vk_render_finished_semaphore, null ]


    func init []
        backbuffer : !vk_swap_image

        # allocate command buffer
        cmdAllocInfo : VkCommandBufferAllocateInfo [
            sType:              VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO,
            commandPool:        vk.command_pool,
            level:              VK_COMMAND_BUFFER_LEVEL_PRIMARY,
            commandBufferCount: 1
        ]
        result : vkAllocateCommandBuffers[ vk.device, ref cmdAllocInfo, ref vk_command_buffer ]
        expect result == VK_SUCCESS, "failed to allocate command buffers"

        # create render pass
        # color loadOp/initialLayout depend on load_existing: when true the
        # render pass preserves whatever's already in the color attachment
        # (LOAD), so this Render layers on top of an earlier pass that wrote
        # into the same texture. otherwise it CLEARs as usual.
        # depth attachment is omitted entirely when no depth Texture was
        # supplied — used by color-only overlays (e.g. text on canvas).
        color_load_op  : VkAttachmentLoadOp [ (load_existing) ? VK_ATTACHMENT_LOAD_OP_LOAD : VK_ATTACHMENT_LOAD_OP_CLEAR ]
        color_init_lay : VkImageLayout      [ (load_existing) ? VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL : VK_IMAGE_LAYOUT_UNDEFINED ]
        # depth is wanted only when the caller opts in with use_depth.
        # 2D passes (blur, reduction, compose, overlay, text) leave it
        # off. update's el-branch creates color+depth together when
        # use_depth is set, so this matches what'll exist at framebuffer
        # time.
        has_depth_init : bool [ use_depth ]
        attachments : local VkAttachmentDescription [2] [
            VkAttachmentDescription [
                format:         w.surface_format.format,
                samples:        VK_SAMPLE_COUNT_1_BIT,
                loadOp:         color_load_op,
                storeOp:        VK_ATTACHMENT_STORE_OP_STORE,
                stencilLoadOp:  VK_ATTACHMENT_LOAD_OP_CLEAR,
                stencilStoreOp: VK_ATTACHMENT_STORE_OP_DONT_CARE,
                initialLayout:  color_init_lay,
                finalLayout:    VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL
            ],
            VkAttachmentDescription [
                format:         VK_FORMAT_D32_SFLOAT,
                samples:        VK_SAMPLE_COUNT_1_BIT,
                loadOp:         VK_ATTACHMENT_LOAD_OP_CLEAR,
                storeOp:        VK_ATTACHMENT_STORE_OP_STORE,
                stencilLoadOp:  VK_ATTACHMENT_LOAD_OP_DONT_CARE,
                stencilStoreOp: VK_ATTACHMENT_STORE_OP_STORE,
                initialLayout:  VK_IMAGE_LAYOUT_UNDEFINED,
                finalLayout:    VK_IMAGE_LAYOUT_DEPTH_STENCIL_ATTACHMENT_OPTIMAL
            ]
        ]

        color_attachment_ref : VkAttachmentReference [
            attachment: 0,
            layout:     VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL
        ]

        depth_attachment_ref : VkAttachmentReference [
            attachment: 1,
            layout:     VK_IMAGE_LAYOUT_DEPTH_STENCIL_ATTACHMENT_OPTIMAL
        ]

        subpass : VkSubpassDescription [
            pipelineBindPoint:       VK_PIPELINE_BIND_POINT_GRAPHICS,
            colorAttachmentCount:    1,
            pColorAttachments:       ref color_attachment_ref,
            pDepthStencilAttachment: (has_depth_init) ? ref depth_attachment_ref : null,
            pResolveAttachments:     null
        ]

        # subpass dependencies for proper image layout transitions
        dependencies : local VkSubpassDependency [2] [
            VkSubpassDependency [
                srcSubpass:      VK_SUBPASS_EXTERNAL,
                dstSubpass:      0,
                srcStageMask:    VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT,
                dstStageMask:    VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT,
                srcAccessMask:   VK_ACCESS_MEMORY_READ_BIT,
                dstAccessMask:   VK_ACCESS_COLOR_ATTACHMENT_READ_BIT | VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT,
                dependencyFlags: VK_DEPENDENCY_BY_REGION_BIT
            ],
            VkSubpassDependency [
                srcSubpass:      0,
                dstSubpass:      VK_SUBPASS_EXTERNAL,
                srcStageMask:    VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT,
                dstStageMask:    VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT,
                srcAccessMask:   VK_ACCESS_COLOR_ATTACHMENT_READ_BIT | VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT,
                dstAccessMask:   VK_ACCESS_MEMORY_READ_BIT,
                dependencyFlags: VK_DEPENDENCY_BY_REGION_BIT
            ]
        ]

        render_pass_info : VkRenderPassCreateInfo [
            sType:           VK_STRUCTURE_TYPE_RENDER_PASS_CREATE_INFO,
            attachmentCount: (has_depth_init) ? 2 : 1,
            pAttachments:    attachments,
            subpassCount:    1,
            pSubpasses:      ref subpass,
            dependencyCount: 2,
            pDependencies:   dependencies
        ]

        n_passes : i32 [ 1 + ((reduce) ? 1 : 0) ]
        for [ i: 0, i < n_passes, i += 1 ]
            if [ i == 1 ]
                render_pass_info.dependencyCount = 1
                render_pass_info.attachmentCount = 1
                subpass.pDepthStencilAttachment  = null
            result = vkCreateRenderPass[ vk.device, ref render_pass_info, null, ref vk_render_pass[i] ]
            expect result == VK_SUCCESS, "failed to create render pass"

        if [ !backbuffer ]
            semaphore_info : VkSemaphoreCreateInfo [
                sType: VK_STRUCTURE_TYPE_SEMAPHORE_CREATE_INFO
            ]
            result = vkCreateSemaphore[ vk.device, ref semaphore_info, null, ref vk_image_available_semaphore ]
            expect result == VK_SUCCESS, "failed to create image available semaphore"
            result = vkCreateSemaphore[ vk.device, ref semaphore_info, null, ref vk_render_finished_semaphore ]
            expect result == VK_SUCCESS, "failed to create render finished semaphore"

        fenceInfo : VkFenceCreateInfo [
            sType: VK_STRUCTURE_TYPE_FENCE_CREATE_INFO,
            flags: VK_FENCE_CREATE_SIGNALED_BIT
        ]
        result = vkCreateFence[ vk.device, ref fenceInfo, null, ref vk_fence ]
        expect result == VK_SUCCESS, "failed to create fence"

        if [ reduce ]
            reduce_model = Model [ vk: vk, w: w, s: vk.reduce_shader[ ] ]

        # create or resize color/depth textures and framebuffer
        update[]

        if [ reduce ]
            reduce_model.samplers = map Au [string] [ "color": color ]

        for [m:Model] in models
            m.finish[ a, 0 ]

        if [ reduce ]
            reduce_model.finish[ a, 1 ]


struct mat3f
    m : local float[3x3]


class Layout
    static defaults    : new Layout [7]
    static initialized : bool
    public layout : VkImageLayout
    public access : VkAccessFlags
    public stage  : VkPipelineStageFlags
    
    static func find [ l: VkImageLayout ] -> Layout
        if [ !initialized ]
            #defaults = new Layout [7]
            initialized = true
            defaults[0] = Layout [
                layout: VK_IMAGE_LAYOUT_UNDEFINED,
                access: 0,
                stage: VK_PIPELINE_STAGE_TOP_OF_PIPE_BIT ]
            defaults[1] = Layout [
                layout: VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                access: VK_ACCESS_TRANSFER_WRITE_BIT,
                stage: VK_PIPELINE_STAGE_TRANSFER_BIT ]
            defaults[2] = Layout [
                layout: VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                access: VK_ACCESS_TRANSFER_READ_BIT,
                stage: VK_PIPELINE_STAGE_TRANSFER_BIT ]
            defaults[3] = Layout [
                layout: VK_IMAGE_LAYOUT_GENERAL,
                access: VK_ACCESS_SHADER_READ_BIT | VK_ACCESS_SHADER_WRITE_BIT,
                stage: VK_PIPELINE_STAGE_FRAGMENT_SHADER_BIT ]
            defaults[4] = Layout [
                layout: VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL,
                access: VK_ACCESS_SHADER_READ_BIT,
                stage: VK_PIPELINE_STAGE_FRAGMENT_SHADER_BIT ]
            defaults[5] = Layout [
                layout: VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL,
                access: VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT,
                stage: VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT ]
            defaults[6] = Layout [
                layout: VK_IMAGE_LAYOUT_PRESENT_SRC_KHR,
                access: VK_ACCESS_MEMORY_READ_BIT,
                stage: VK_PIPELINE_STAGE_BOTTOM_OF_PIPE_BIT ]
        
        for [ i: 0, i < 7, i += 1 ]
            if [ defaults[i].layout == l ]
                return defaults[i]
        
        return null

    # transition image from this layout to Render layout
    intern func transition [ vk: vk_context, img: VkImage, trans_to: Layout, r: image_range ]
        #printf[ "current layout %p\n", layout ]
        cmd: Command [ vk: vk ]
        cmd.begin
        barrier: VkImageMemoryBarrier [
            sType:               VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER,
            oldLayout:           layout,
            newLayout:           trans_to.layout,
            srcQueueFamilyIndex: VK_QUEUE_FAMILY_IGNORED,
            dstQueueFamilyIndex: VK_QUEUE_FAMILY_IGNORED,
            image:               img,
            subresourceRange:    VkImageSubresourceRange [
                aspectMask:       (r.is_depth) ? VK_IMAGE_ASPECT_DEPTH_BIT : VK_IMAGE_ASPECT_COLOR_BIT,
                baseMipLevel:     r.base_mip,
                levelCount:       r.levels,
                baseArrayLayer:   r.base_layer,
                layerCount:       r.layers
            ]
        ]
        barrier.srcAccessMask = access
        barrier.dstAccessMask = trans_to.access
        vkCmdPipelineBarrier[ cmd.cmd, stage, trans_to.stage, 0, 0, null, 0, null, 1, ref barrier ]
        cmd.submit


class vk_context
    public  user                : Au
    intern  instance            : VkInstance
    intern  physical_device     : VkPhysicalDevice
    intern  device              : VkDevice
    intern  queue               : VkQueue
    intern  command_pool        : VkCommandPool
    public  queue_family_index  : i32 -1
    public  rt_support          : bool
    public  instance_exts       : array cstr [ alloc:128, unmanaged:true ]
    public  device_exts         : array cstr [ alloc:128, unmanaged:true ] # theres... too many of them.
    intern  debug               : VkDebugUtilsMessengerEXT
    intern  props               : VkPhysicalDeviceMemoryProperties
    public  allocator           : VmaAllocator
    intern  _vkCreateDebugUtilsMessengerEXT : PFN_vkCreateDebugUtilsMessengerEXT
    intern  _vkGetMemoryFdPropertiesKHR     : PFN_vkGetMemoryFdPropertiesKHR

    intern quad_m:    GltfModel
    # cached default shaders. constructing a fresh UVQuad / UVReduce per
    # caller forces shader.init → generate_shaders → reload to rewrite
    # shaders/uv-quad.{vert,frag} on disk from each instance, and the
    # composite chain builds ~5 of them back-to-back. without GDB pacing
    # them out, multiple glslangValidator child processes race on the same
    # .spv output file and one of them ends up with a null vk_vert/vk_frag.
    # one cached instance per type sidesteps the race entirely.
    intern quad_s:    Au
    intern reduce_s:  Au

    func init [ ]
        hold[]
        printf[ "instance = %p, addr = %p\n", instance, ref instance ]
        get_required_extensions[ a ]
        enable_validation: bool true
        validation_layer: symbol [ (enable_validation) ? "VK_LAYER_KHRONOS_validation" : null ]
        app_info: VkApplicationInfo [
            sType:              VK_STRUCTURE_TYPE_APPLICATION_INFO,
            pApplicationName:   "trinity",
            applicationVersion: VK_MAKE_VERSION[ 1, 0, 0 ],
            pEngineName:        "trinity",
            engineVersion:      VK_MAKE_VERSION[ 1, 0, 0 ],
            apiVersion:         VK_API_VERSION_1_2
        ]

        result: vkCreateInstance[ VkInstanceCreateInfo [
            sType:                   VK_STRUCTURE_TYPE_INSTANCE_CREATE_INFO,
            pApplicationInfo:        ref app_info,
            enabledExtensionCount:   instance_exts.count,
            ppEnabledExtensionNames: instance_exts.origin,
            enabledLayerCount:       u32[ enable_validation ],
            ppEnabledLayerNames:     ref validation_layer
        ], null, ref instance ]

        expect result == VK_SUCCESS, "failed to create Vulkan instance"

        if [ enable_validation ]
            _vkCreateDebugUtilsMessengerEXT = vkGetInstanceProcAddr[ instance, "vkCreateDebugUtilsMessengerEXT" ]
            expect _vkCreateDebugUtilsMessengerEXT, "cannot find vk debug function"

        # enumerate physical devices
        device_count: u32 0
        vkEnumeratePhysicalDevices[ instance, ref device_count, null ]
        expect device_count > 0, "failed to find GPUs with Vulkan support"
        physical_devices: local VkPhysicalDevice [ device_count ]
        vkEnumeratePhysicalDevices[ instance, ref device_count, physical_devices ]
        physical_device = physical_devices[0]

        # check device extensions
        ext_count: u32 0
        vkEnumerateDeviceExtensionProperties[ physical_device, null, ref ext_count, null ]
        expect ext_count > 0, "failed to find device extensions"
        extensions: local VkExtensionProperties [ ext_count ]
        res2 : VkResult vkEnumerateDeviceExtensionProperties[ physical_device, null, ref ext_count, extensions ]
        

        ext2 : symbol extensions[0].extensionName
        printf[ "res2 = %i, ext2 = %s\n", res2, ext2 ]
        swapchain_supported: bool false
        swapchain_ext : symbol VK_KHR_SWAPCHAIN_EXTENSION_NAME
        for [ i: u32 0, i < ext_count, i += 1 ]
            ext : extensions[i].extensionName
            device_exts.push[ ext ]
            printf [ "vk-device-extension: %s\n", ext ]
            if [ strcmp[ ext, VK_KHR_SWAPCHAIN_EXTENSION_NAME ] == 0 ]
                printf [ "supported swapchain: %s\n", ext ]
                swapchain_supported = true
        expect swapchain_supported, "VK_KHR_swapchain not supported by physical device"

        # device-level extensions required for DMA-BUF import (Camera):
        enabled_dev_exts : new symbol [ 5 ]
        enabled_dev_exts[0] = VK_KHR_SWAPCHAIN_EXTENSION_NAME
        enabled_dev_exts[1] = VK_KHR_EXTERNAL_MEMORY_EXTENSION_NAME
        enabled_dev_exts[2] = VK_KHR_EXTERNAL_MEMORY_FD_EXTENSION_NAME
        enabled_dev_exts[3] = VK_EXT_EXTERNAL_MEMORY_DMA_BUF_EXTENSION_NAME
        enabled_dev_exts[4] = VK_EXT_IMAGE_DRM_FORMAT_MODIFIER_EXTENSION_NAME

        # query device features
        buffer_addr_features: VkPhysicalDeviceBufferDeviceAddressFeatures [
            sType:               VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_BUFFER_DEVICE_ADDRESS_FEATURES,
            bufferDeviceAddress: VK_TRUE
        ]
        features2: VkPhysicalDeviceFeatures2 [
            sType: VK_STRUCTURE_TYPE_PHYSICAL_DEVICE_FEATURES_2,
            pNext: ref buffer_addr_features
        ]
        vkGetPhysicalDeviceFeatures2[ physical_device, ref features2 ]

        # create logical device
        queue_priority: f32 1.0
        result = vkCreateDevice[ physical_device, VkDeviceCreateInfo [
            sType:                   VK_STRUCTURE_TYPE_DEVICE_CREATE_INFO,
            pNext:                   ref features2,
            queueCreateInfoCount:    1,
            pQueueCreateInfos:       VkDeviceQueueCreateInfo [
                sType:               VK_STRUCTURE_TYPE_DEVICE_QUEUE_CREATE_INFO,
                queueFamilyIndex:    0,
                queueCount:          1,
                pQueuePriorities:    ref queue_priority
            ],
            enabledExtensionCount:   5,
            ppEnabledExtensionNames: enabled_dev_exts
        ], null, ref device ]
        
        expect result == VK_SUCCESS, "cannot create logical device"
        queue_family_index = -1

        # load extension function pointer for dmabuf import
        _vkGetMemoryFdPropertiesKHR = vkGetDeviceProcAddr[ device, "vkGetMemoryFdPropertiesKHR" ]

        # query memory properties for find_memory_type
        vkGetPhysicalDeviceMemoryProperties[ physical_device, ref props ]

        # create VMA allocator
        result = vmaCreateAllocator[ VmaAllocatorCreateInfo [
            physicalDevice:    physical_device,
            device:            device,
            instance:          instance,
            vulkanApiVersion:  VK_API_VERSION_1_2,
            pVulkanFunctions:  null,
            flags:             VMA_ALLOCATOR_CREATE_BUFFER_DEVICE_ADDRESS_BIT
        ], ref allocator ]
        expect result == VK_SUCCESS, "cannot create vma allocator"

        gltf_quad2: path [ 'models/uv-quad2.gltf' ]
        quad_m = gltf_quad2.load[ typeid[ GltfModel ], null ]





    func quad_shader [ ] -> UVQuad
        if [ quad_s ]
            return UVQuad[quad_s]
        q: UVQuad [ vk: a, name: 'uv-quad' ]
        q.model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        q.view = mat4f.look_at[ eye, center, up ]
        q.proj = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]
        quad_s = q
        return q

    func reduce_shader [ ] -> UVReduce
        if [ reduce_s ]
            return UVReduce[reduce_s]
        q: UVReduce [ vk: a, name: 'uv-reduce' ]
        q.model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        q.view = mat4f.look_at[ eye, center, up ]
        q.proj = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]
        reduce_s = q
        return q

    func dealloc [ ]
        vmaDestroyAllocator[ allocator ]
        vkDeviceWaitIdle[ device ]
        vkDestroyDevice[ device, null ]
        vkDestroyInstance[ instance, null ]

    func set_queue_index [ vk_surface: handle ] 
        queue_family_count: u32 0
        vkGetPhysicalDeviceQueueFamilyProperties[
            physical_device, ref queue_family_count, null ]
        expect queue_family_count > 0, "failed to find queue families"
        queue_families: new VkQueueFamilyProperties [ queue_family_count ]
        vkGetPhysicalDeviceQueueFamilyProperties[ physical_device, ref queue_family_count, queue_families ]
        
        found: false
        if [ !vk_surface ]
            queue_family_index = 0
            found = true
        el
            for [ i: u32 0, i < queue_family_count, i += 1 ]
                present_support: VkBool32 [ VK_FALSE ]
                vkGetPhysicalDeviceSurfaceSupportKHR[ physical_device, i, vk_surface, ref present_support ]
                if [ queue_families[i].queueFlags & VK_QUEUE_GRAPHICS_BIT && present_support ]
                    queue_family_index = i
                    found = true
                    break
        
        expect found, "failed to find a suitable graphics and presentation queue family"

    intern func find_memory_type [ type_filter: u32, flags: VkMemoryPropertyFlags ] -> u32
        printf[ "type_filter: %i\n", type_filter ]
        printf[ "flags: %i\n",       flags ]
        for [ i: u32 0, i < props.memoryTypeCount, i += 1 ]
            printf[ "props.memoryTypes[i].propertyFlags: %i\n", u32[props.memoryTypes[i].propertyFlags] ]
            if [ (type_filter & (1 << i)) && (props.memoryTypes[i].propertyFlags & flags) == flags ]
                printf["found index\n"]
                return i
        fault "could not find memory type"
        return 0

    func attach [ vk_surface:handle ] 
        if [ queue_family_index == -1 ]
            set_queue_index[ vk_surface ]
            vkGetDeviceQueue[ device, queue_family_index, 0, ref queue ]
            expect queue, "Failed to retrieve graphics queue"
            vk: handle[ a ]
            if [ _vkCreateDebugUtilsMessengerEXT ]
                result2: _vkCreateDebugUtilsMessengerEXT[
                    instance, # at base...
                    VkDebugUtilsMessengerCreateInfoEXT[
                        sType: VK_STRUCTURE_TYPE_DEBUG_UTILS_MESSENGER_CREATE_INFO_EXT,
                        messageSeverity: VK_DEBUG_UTILS_MESSAGE_SEVERITY_VERBOSE_BIT_EXT |
                            VK_DEBUG_UTILS_MESSAGE_SEVERITY_WARNING_BIT_EXT | VK_DEBUG_UTILS_MESSAGE_SEVERITY_ERROR_BIT_EXT,
                        messageType: VK_DEBUG_UTILS_MESSAGE_TYPE_GENERAL_BIT_EXT | VK_DEBUG_UTILS_MESSAGE_TYPE_VALIDATION_BIT_EXT |
                            VK_DEBUG_UTILS_MESSAGE_TYPE_PERFORMANCE_BIT_EXT,
                        pfnUserCallback: ref trinity_log, pUserData: vk
                    ],
                    null, ref debug
                ]
                expect result2 == VK_SUCCESS, "debug messenger" # at base... one above has 1 extra space, and the error shows... i am not sure where to look
                
            pool_info: VkCommandPoolCreateInfo [
                sType:            VK_STRUCTURE_TYPE_COMMAND_POOL_CREATE_INFO,
                queueFamilyIndex: queue_family_index,
                flags:            VK_COMMAND_POOL_CREATE_RESET_COMMAND_BUFFER_BIT
            ]
            result: vkCreateCommandPool[ device, pool_info, null, ref command_pool ]
            expect result == VK_SUCCESS, "failed to create command pool"

    intern func create_mipmaps [ vk_image: VkImage, w: i32, h: i32, mips: i32, layers: i32 ] 
        if [ mips > 1 ]
            mipWidth:  w
            mipHeight: h
            for [ f: 0, f < layers, f += 1 ]
                transition_image_layout[ vk_image,
                    VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                    VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                    0, 1, f, 1, false ]
            for [ i: u32 1, i < mips, i += 1 ]
                for [ f: 0, f < layers, f += 1 ]
                    transition_image_layout[ vk_image,
                        VK_IMAGE_LAYOUT_UNDEFINED,
                        VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                        i, 1, f, 1, false ]
                    cmd: Command [ vk: a ]
                    cmd.begin
                    vkCmdBlitImage[
                        cmd.cmd, vk_image, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                        vk_image, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1,
                        VkImageBlit [
                            srcSubresource: VkImageSubresourceLayers [
                                aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: i - 1, baseArrayLayer: f, layerCount: 1 ],
                            srcOffsets: [
                                VkOffset3D [ 0, 0, 0 ], VkOffset3D [ mipWidth, mipHeight, 1 ] ],
                            dstSubresource: VkImageSubresourceLayers [
                                aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: i, baseArrayLayer: f, layerCount: 1 ],
                            dstOffsets: [
                                VkOffset3D [ 0, 0, 0 ], VkOffset3D [ max[ 1, mipWidth / 2 ], max[ 1, mipHeight / 2 ], 1 ] ] ],
                        VK_FILTER_LINEAR ]
                    cmd.submit
                    transition_image_layout[ vk_image,
                        VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                        VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL, i, 1, f, 1, false ]
                mipWidth  = max[ 1, mipWidth / 2 ]
                mipHeight = max[ 1, mipHeight / 2 ]
            for [ f: 0, f < layers, f += 1 ]
                transition_image_layout[ vk_image,
                    VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                    VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL, 0, mips, f, 1, false ]
        el
            transition_image_layout[ vk_image,
                VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL, 0, 1, 0, 1, false ]


    # compatibility wrapper for old call sites
    intern func transition_image_layout [
            img: VkImage, old_layout: VkImageLayout, new_layout: VkImageLayout,
            baseMipLevel: i32, level_count: i32, base_array_layer: i32,
            layer_count: i32, is_depth: bool ] 
        src: Layout.find[ old_layout ]
        dst: Layout.find[ new_layout ]
        expect src && dst, "layout not found"
        r: image_range [ base_mip: baseMipLevel, levels: level_count, base_layer: base_array_layer, layers: layer_count, is_depth: is_depth ]
        src.transition[ a, img, dst, r ]


class gpu
    context vk           : vk_context
    expect name          : cstr
    public sampler       : Au
    public tx            : Texture
    public vertex_data   : ref i8
    public index_data    : ref i8
    public members       : ref vertex_member_t
    public member_count  : i32
    public index_size    : i32
    public index_count   : i32
    public vertex_size   : i32
    mutable vertex_count : i32
    intern vertex        : Buffer
    intern index         : Buffer
    intern vk_image      : VkImage
    intern vk_image_view : VkImageView
    intern vk_sampler    : VkSampler
    intern vma_alloc     : VmaAllocation
    public compute       : bool

    intern func index_type [ ] -> VkIndexType
        return (index_size == 1) ? VK_INDEX_TYPE_UINT8_KHR :
               (index_size == 2) ? VK_INDEX_TYPE_UINT16    : VK_INDEX_TYPE_UINT32
        
    func sync [ w: Display ] 
        # vbo/ibo maintained on init only
        if [ vertex_size && !vertex ]
            comp: compute
            vertex = Buffer [ vk: vk, size: vertex_size * vertex_count,
                u_storage: comp, u_vertex: !comp, u_dst: !comp, u_shader: !comp,
                m_host_visible: true, m_host_coherent: true,
                data: vertex_data ]
            if [ index_size ]
                index = Buffer [ vk: vk, size: index_size * index_count,
                    u_index: true, u_dst: true, u_shader: true,
                    m_host_visible: true, m_host_coherent: true,
                    data: index_data ]
        if [ sampler && !tx ]
            img:  sampler inherits Image
            t_tx: sampler inherits Texture
            re:   sampler inherits Render
            expect !re, "Render given to samplers"
            if [ t_tx ]
                tx = t_tx
            el [ img && img.user ]
                tx = img.user
            el [ img && img.surface == Surface.environment ]
                tx = environment[ vk, img, vec3f [ 0.0, 1.0, 0.0 ], radians[ 90.0 ] ]
                if [ img ]
                    img.user = tx
            el
                # this should handle primitive refs
                tx = Texture [ vk: vk, sampler: sampler,
                    surface: (img) ? img.surface : Surface.color ]
                if [ img ]
                    img.user = tx

    func init [ ]
        if [ vertex_size ] vertex_data = new i8 [ vertex_size * vertex_count ]
        if [ index_size ]  index_data  = new i8 [ index_size * index_count ]


class uniforms
    context vk       : vk_context
    expect s         : shader
    public u_memory  : ref u8
    public u_buffers : array Buffer [ ]

    public func update [ ] 
        for [ b: Buffer ] in u_buffers
            s.uniform_transfer[ b.data, b.user ]
            b.update[ null ]

    func init [ ]
        type_list:  array Au_t [ unmanaged: true ]
        # use the runtime type via the Au header — `typeid[ s ]` returns the
        # static declared type of the field (`shader`), not the actual subclass
        # (e.g. CanvasUI). without this we'd never iterate any subclass members.
        hdr:    Au [ Au.header[ s ] ]
        ty:     Au_t [ hdr.type ]

        while [ ty != typeid[ shader ] ]
            type_list += ty
            ty = ty.context

        type_list = type_list.reverse[]

        u_index:  0
        total_uniform: i32 [ 0 ]

        # type_list is an `array`, not a `list` — iterate with `for ... in`,
        # NOT linked-list-style `i = i.next`. The previous code used .first /
        # .next which silently produced no iterations and left u_buffers empty,
        # which made every shader's `ubo` descriptor invalid at draw time.
        for [ tn: Au_t ] in type_list
            u_size: uniform_size[ tn ]
            total_uniform += u_size

        u_memory  = new u8 [ total_uniform ]

        for [ tn: Au_t ] in type_list
            u_size: uniform_size[ tn ]
            uniform_buf: Buffer [ vk: vk, size: u_size,
                u_uniform: true, u_dst: true, m_host_visible: true, m_host_coherent: true,
                data: ref u_memory[u_index], user: tn ]
            u_buffers.push [ uniform_buf ]
            u_index += u_size

# lets declare something about how we want to use this meta-A type slot
alias RType : Au

# the GLSL type is used at design-time to give 
class GLSL : RType
    public body  : symbol
    public rtype : Au_t
    construct [ t:symbol ]
        info  : Au.header[ a ]
        body  = t
        rtype = info.meta_a

class Pipeline
    context vk              : vk_context
    context w               : Display
    expect r                : Render
    expect s                : shader
    expect name             : string
    public render_id        : i32
    public default_model    : mat4f
    public shader_reloads   : i32
    public material         : Material
    mutable samplers        : map Au[string]
    # explicit dispatch group counts for compute pipelines. when any of
    # these are > 0 they override the default of memory.vertex_count, 1, 1.
    mutable dispatch_x      : i32
    mutable dispatch_y      : i32
    mutable dispatch_z      : i32
    # set to true on pipelines whose fragment shader emits straight-alpha
    # output (rgb, a) instead of pre-multiplied (rgb*a, a). switches the
    # color blend factors from ONE → SRC_ALPHA so the result composes
    # correctly: rgb*a + dst*(1 - a). default false (premul).
    public straight_alpha   : bool
    intern resources        : array gpu
    intern storage_textures : array Texture
    intern shader_uniforms  : uniforms
    intern vbo              : gpu
    intern memory           : gpu
    intern dumped           : bool
    intern descriptor_layouts : new VkDescriptorSetLayout [ 2 ] # fixed-size descriptor arrays
    intern descriptor_sets    : new VkDescriptorSet       [ 2 ]
    intern descriptor_pool    : VkDescriptorPool
    intern image_slot         : i32 [ -1 ]
    intern bind               : VkDescriptorSet
    intern vk_render          : VkPipeline
    intern vk_compute         : VkPipeline
    intern layout             : VkPipelineLayout

    public   func rebind [ ]
        if [ resources ]
            resources = null

    public   func rebind_image [ tx: Texture ]
        if [ image_slot < 0 ] return
        tx.transition[ VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
        info : VkDescriptorImageInfo [
            sampler:     tx.vk_sampler,
            imageView:   tx.vk_image_view,
            imageLayout: VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL
        ]
        write : VkWriteDescriptorSet [
            sType:           VK_STRUCTURE_TYPE_WRITE_DESCRIPTOR_SET,
            pNext:           null,
            dstSet:          descriptor_sets[1],
            dstBinding:      image_slot,
            descriptorCount: 1,
            descriptorType:  VK_DESCRIPTOR_TYPE_COMBINED_IMAGE_SAMPLER,
            pImageInfo:      ref info
        ]
        vkUpdateDescriptorSets[ vk.device, 1, ref write, 0, null ]

    # vkCmdDispatch is illegal inside an active render pass, so the compute path
    # is split out and called by Render.draw BEFORE vkCmdBeginRenderPass. The
    # graphics path stays in `draw` and runs inside the render pass.
    public   func dispatch [ f: handle ]
        if [ !vk_compute ]
            return
        if [ !resources ]
            bind_resources[]
        if [ s.reload[ ] ]
            reassemble[]
        frame: VkCommandBuffer [ f ]
        # in-band barrier: storage images must be in GENERAL when the compute
        # shader writes them. Recording the barrier into the main command buffer
        # (rather than out-of-band) is required so the validator's per-command-
        # buffer layout tracking sees a consistent transition.
        for [ t: Texture ] in storage_textures
            t.transition_in[ f, VK_IMAGE_LAYOUT_GENERAL ]
        shader_uniforms.update[ ]
        vkCmdBindPipeline[ frame, VK_PIPELINE_BIND_POINT_COMPUTE, vk_compute ]
        # bind BOTH descriptor sets (set 0 = uniforms, set 1 = sampler/storage).
        # the original code only bound set 0 because the compute-on-vbo
        # pattern didn't have any storage bindings; the SDF compute does.
        vkCmdBindDescriptorSets[ frame, VK_PIPELINE_BIND_POINT_COMPUTE,
            layout, 0, 2, descriptor_sets, 0, null ]
        # explicit dispatch counts override the default vertex-buffer-driven
        # workgroup count from the C foundation's compute-on-vbo pattern.
        dx: i32 [ (dispatch_x > 0) ? dispatch_x : ((memory) ? memory.vertex_count : 1) ]
        dy: i32 [ (dispatch_y > 0) ? dispatch_y : 1 ]
        dz: i32 [ (dispatch_z > 0) ? dispatch_z : 1 ]
        vkCmdDispatch[ frame, dx, dy, dz ]
        # in-band barrier: now that the compute write is recorded, transition
        # storage images to SHADER_READ_ONLY_OPTIMAL so downstream graphics
        # pipelines that sample them are happy. Must happen before the render
        # pass begins (image-layout barriers are restricted inside an active
        # render pass), and recording it here keeps it ordered with the dispatch.
        for [ t: Texture ] in storage_textures
            t.transition_in[ f, VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]

    public   func draw [ f: handle ]
        if [ !vk_render ]
            return
        if [ !resources ]
            bind_resources[]
        if [ s.reload[ ] ]
            reassemble[]
        for [ g: gpu ] in resources
            if [ g.tx ]
                g.tx.transition[ VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
        frame: VkCommandBuffer [ f ]
        shader_uniforms.update[ ]
        
        vkCmdBindPipeline[ frame, VK_PIPELINE_BIND_POINT_GRAPHICS, vk_render ]
        offsets: local VkDeviceSize[ 1 ] [ 0 ]
        vkCmdBindDescriptorSets[ frame, VK_PIPELINE_BIND_POINT_GRAPHICS,
            layout, 0, 2, descriptor_sets, 0, null ]
        vkCmdBindVertexBuffers[ frame, 0, 1, ref vbo.vertex.vk_buffer, offsets ]
        if [ vbo.index ]
            vkCmdBindIndexBuffer[ frame, vbo.index.vk_buffer, 0,
                vbo.index_type[ ] ]
            #printf["draw %s idx=%i vtx=%i\n", name.chars, vbo.index_count, vbo.vertex_count]
            vkCmdDrawIndexed[ frame, vbo.index_count, 1, 0, 0, 0 ]
        el
            vkCmdDraw[ frame, vbo.vertex_count, 1, 0, 0 ]

    public   func bind_resources [ ]
        # set 0 = uniform buffers (UBOs from shader mutable fields)
        # set 1 = mixed bag of samplers + storage images + storage buffers
        # bindings within set 1 are assigned in source-order across all
        # attrib types so the binding numbers match what glsl_header emits.
        # parallel info arrays: each set 1 binding occupies the SAME slot
        # in image_infos[i] OR storage_buf_infos[i] (never both). this is
        # simpler than separate counters at the cost of array bindings
        # (count > 1) — none of our shaders use those today.
        sampler_count:         0       # for COMBINED_IMAGE_SAMPLER pool sizing
        set1_binds:            0       # binding count for set 1 (mixed types)
        uniform_count:         0
        storage_image_count:   0
        storage_buffer_count:  0
        sampler_bindings: local VkDescriptorSetLayoutBinding[32]
        uniform_bindings: local VkDescriptorSetLayoutBinding[32]
        buffer_infos:     local VkDescriptorBufferInfo[32]
        image_infos:      local VkDescriptorImageInfo[32]
        storage_buf_infos: local VkDescriptorBufferInfo[32]
        descriptor_writes: local VkWriteDescriptorSet[32]
        resources        = array gpu [ alloc: 32 ]
        storage_textures = array Texture [ alloc: 8 ]
        if [ vbo ]
            vbo.sync[ w ]
            resources.push[ vbo ]
        # storage descriptors need to be visible from the compute stage too;
        # for graphics-only shaders the COMPUTE bit is harmless.
        stage_flags: VK_SHADER_STAGE_VERTEX_BIT | VK_SHADER_STAGE_FRAGMENT_BIT | VK_SHADER_STAGE_COMPUTE_BIT
        shader_uniforms = uniforms [ vk: vk, s: s ]
        s_hdr:       Au [ Au.header[ s ] ]
        shader_type: Au_t [ s_hdr.type ]

        for [ b: Buffer ] in shader_uniforms.u_buffers
            uniform_bindings[uniform_count] = VkDescriptorSetLayoutBinding [
                binding:         uniform_count,
                descriptorType:  VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER,
                descriptorCount: 1,
                stageFlags:      stage_flags
            ]
            buffer_infos[uniform_count] = VkDescriptorBufferInfo [
                buffer: b.vk_buffer,
                offset: 0,
                range:  b.size
            ]
            uniform_count += 1

        # walk shader schema — same caveat as uniforms.init: typeid[ s ] gives
        # the declared field type `shader`, we need the runtime subclass.
        sh_hdr:        Au [ Au.header[ s ] ]
        shader_schema: Au_t [ sh_hdr.type ]
        while [ shader_schema != typeid[ shader ] ]
            for [ i: 0, i < shader_schema.members.count, i += 1 ]
                mem: Au_t [ shader_schema.members.origin[i] ]

                # ---- sampled image (LayoutBinding) ----
                if [ mem.src == typeid[ LayoutBinding ] ]
                    at : LayoutBinding s.get_property[ mem.ident ]
                    enum_type:  at.type
                    enum_value: at.id
                    meta_type:  at.format
                    expect meta_type, "meta data not set on Surface/extension"
                    all: Surface_resources[ enum_type, enum_value, meta_type, a ]
                    expect all.count == 1, "binding arrays (count > 1) not supported in this code path"
                    res: gpu [ all[0] ]
                    expect res inherits gpu, "expected gpu resource"
                    res.sync[ w ]
                    resources.push[ res ]
                    if [ strcmp[ mem.ident, 'image' ] == 0 ]
                        image_slot = set1_binds
                    image_infos[set1_binds] = VkDescriptorImageInfo [
                        sampler:     res.tx.vk_sampler,
                        imageView:   res.tx.vk_image_view,
                        imageLayout: VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL
                    ]
                    sampler_bindings[set1_binds] = VkDescriptorSetLayoutBinding [
                        binding:         set1_binds,
                        descriptorType:  VK_DESCRIPTOR_TYPE_COMBINED_IMAGE_SAMPLER,
                        descriptorCount: 1,
                        stageFlags:      stage_flags
                    ]
                    set1_binds    += 1
                    sampler_count += 1

                # ---- storage image (writeonly, for compute) ----
                el [ mem.src == typeid[ StorageImage ] ]
                    found_tx: Texture
                    for [ img: Image, name: string ] in a.samplers
                        if [ strcmp[ name.chars, mem.ident ] == 0 ]
                            tx: Texture [ img inherits Texture ]
                            if [ tx ]
                                found_tx = tx
                                break
                    expect found_tx, "no Texture provided in samplers map for storage image attrib"
                    found_tx.transition[ VK_IMAGE_LAYOUT_GENERAL ]
                    storage_textures.push[ found_tx ]
                    image_infos[set1_binds] = VkDescriptorImageInfo [
                        sampler:     null,
                        imageView:   found_tx.vk_image_view,
                        imageLayout: VK_IMAGE_LAYOUT_GENERAL
                    ]
                    sampler_bindings[set1_binds] = VkDescriptorSetLayoutBinding [
                        binding:         set1_binds,
                        descriptorType:  VK_DESCRIPTOR_TYPE_STORAGE_IMAGE,
                        descriptorCount: 1,
                        stageFlags:      stage_flags
                    ]
                    set1_binds          += 1
                    storage_image_count += 1

                # ---- storage buffer (readonly, for compute input) ----
                el [ mem.src == typeid[ StorageBuffer ] ]
                    # Buffer doesn't inherit from Image, so iterate samplers as
                    # Au to avoid an unsafe Image cast on Buffer entries.
                    found_buf: Buffer
                    for [ b2_au: Au, name: string ] in a.samplers
                        if [ strcmp[ name.chars, mem.ident ] == 0 ]
                            bb: Buffer [ b2_au inherits Buffer ]
                            if [ bb ]
                                found_buf = bb
                                break
                    expect found_buf, "no Buffer provided in samplers map for storage buffer attrib"
                    storage_buf_infos[set1_binds] = VkDescriptorBufferInfo [
                        buffer: found_buf.vk_buffer,
                        offset: 0,
                        range:  found_buf.size
                    ]
                    sampler_bindings[set1_binds] = VkDescriptorSetLayoutBinding [
                        binding:         set1_binds,
                        descriptorType:  VK_DESCRIPTOR_TYPE_STORAGE_BUFFER,
                        descriptorCount: 1,
                        stageFlags:      stage_flags
                    ]
                    set1_binds            += 1
                    storage_buffer_count  += 1

            shader_schema = shader_schema.context
        vkCreateDescriptorSetLayout[ vk.device, VkDescriptorSetLayoutCreateInfo [
            sType:        VK_STRUCTURE_TYPE_DESCRIPTOR_SET_LAYOUT_CREATE_INFO,
            bindingCount: uniform_count,
            pBindings:    uniform_bindings
        ], null, ref descriptor_layouts[0] ]
        vkCreateDescriptorSetLayout[ vk.device, VkDescriptorSetLayoutCreateInfo [
            sType:        VK_STRUCTURE_TYPE_DESCRIPTOR_SET_LAYOUT_CREATE_INFO,
            bindingCount: set1_binds,
            pBindings:    sampler_bindings
        ], null, ref descriptor_layouts[1] ]
        sizes: local VkDescriptorPoolSize[4]
        desc: VkDescriptorPoolCreateInfo [
            sType:         VK_STRUCTURE_TYPE_DESCRIPTOR_POOL_CREATE_INFO,
            poolSizeCount: 0,
            pPoolSizes:    sizes,
            maxSets:       2
        ]
        if [ uniform_count ]
            sizes[desc.poolSizeCount].type = VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER
            sizes[desc.poolSizeCount].descriptorCount = uniform_count
            desc.poolSizeCount += 1
        if [ sampler_count > 0 ]
            sizes[desc.poolSizeCount].type = VK_DESCRIPTOR_TYPE_COMBINED_IMAGE_SAMPLER
            sizes[desc.poolSizeCount].descriptorCount = sampler_count
            desc.poolSizeCount += 1
        if [ storage_image_count ]
            sizes[desc.poolSizeCount].type = VK_DESCRIPTOR_TYPE_STORAGE_IMAGE
            sizes[desc.poolSizeCount].descriptorCount = storage_image_count
            desc.poolSizeCount += 1
        if [ storage_buffer_count ]
            sizes[desc.poolSizeCount].type = VK_DESCRIPTOR_TYPE_STORAGE_BUFFER
            sizes[desc.poolSizeCount].descriptorCount = storage_buffer_count
            desc.poolSizeCount += 1
        vkCreateDescriptorPool[ vk.device, desc, null, ref descriptor_pool ]
        vkAllocateDescriptorSets[ vk.device, VkDescriptorSetAllocateInfo [
            sType:              VK_STRUCTURE_TYPE_DESCRIPTOR_SET_ALLOCATE_INFO,
            descriptorPool:     descriptor_pool,
            descriptorSetCount: 2,
            pSetLayouts:        descriptor_layouts
        ], descriptor_sets ]
        for [ i: 0, i < uniform_count, i += 1 ]
            descriptor_writes[i] = VkWriteDescriptorSet [
                sType:           VK_STRUCTURE_TYPE_WRITE_DESCRIPTOR_SET,
                dstSet:          descriptor_sets[0],
                dstBinding:      i,
                descriptorType:  VK_DESCRIPTOR_TYPE_UNIFORM_BUFFER,
                descriptorCount: 1,
                pBufferInfo:     ref buffer_infos[i]
            ]
        for [ i: 0, i < set1_binds, i += 1 ]
            dtype: VkDescriptorType [ sampler_bindings[i].descriptorType ]
            if [ dtype == VK_DESCRIPTOR_TYPE_STORAGE_BUFFER ]
                descriptor_writes[uniform_count + i] = VkWriteDescriptorSet [
                    sType:           VK_STRUCTURE_TYPE_WRITE_DESCRIPTOR_SET,
                    pNext:           null,
                    dstSet:          descriptor_sets[1],
                    dstBinding:      i,
                    dstArrayElement: 0,
                    descriptorType:  dtype,
                    descriptorCount: 1,
                    pBufferInfo:     ref storage_buf_infos[i]
                ]
            el
                descriptor_writes[uniform_count + i] = VkWriteDescriptorSet [
                    sType:           VK_STRUCTURE_TYPE_WRITE_DESCRIPTOR_SET,
                    pNext:           null,
                    dstSet:          descriptor_sets[1],
                    dstBinding:      i,
                    dstArrayElement: 0,
                    descriptorType:  dtype,
                    descriptorCount: 1,
                    pImageInfo:      ref image_infos[i]
                ]
        vkUpdateDescriptorSets[ vk.device,
            uniform_count + set1_binds, descriptor_writes, 0, null ]

    public func reassemble [ ]
        # vbo is OPTIONAL: a compute-only pipeline (no graphics) has no vbo
        # and skips the entire vertex/raster/fragment block. it still needs
        # the pipeline layout (set 0 = uniforms, set 1 = sampler/storage)
        # so descriptor sets bind correctly.
        pipeline_layout_info: VkPipelineLayoutCreateInfo [
            sType:                  VK_STRUCTURE_TYPE_PIPELINE_LAYOUT_CREATE_INFO,
            setLayoutCount:         2,
            pSetLayouts:            descriptor_layouts,
            pushConstantRangeCount: 0
        ]
        result: vkCreatePipelineLayout[ vk.device, pipeline_layout_info, null, ref layout ]
        expect result == VK_SUCCESS, "Failed to create pipeline layout"
        # If the shader is compute-only (has vk_comp but no vk_vert/vk_frag),
        # always create a compute pipeline regardless of whether the Model
        # framework saddled us with a default-quad vbo. Without this, the
        # compute model goes through the el[id] branch in Model.finish (which
        # assigns vk.quad_m as the default mesh) and ends up in the graphics
        # pipeline create path with a null vk_vert — vkCreateGraphicsPipelines
        # then fails the validator with "module is VK_NULL_HANDLE".
        is_compute_only: bool [ s && s.vk_comp != null && !s.vk_vert ]
        if [ vbo && !is_compute_only ]
            binding_description: VkVertexInputBindingDescription [
                binding:   0,
                stride:    vbo.vertex_size,
                inputRate: VK_VERTEX_INPUT_RATE_VERTEX
            ]
            attr_count: 0
            attributes: new VkVertexInputAttributeDescription [ vbo.member_count ]

            # count VertexInput attribs the shader actually consumes
            shader_input_count: 0
            ra_hdr:        Au [ Au.header[ s ] ]
            shader_schema: Au_t [ ra_hdr.type ]
            while [ shader_schema != typeid[ shader ] ]
                for [ si: 0, si < shader_schema.members.count, si += 1 ]
                    sm: Au_t [ shader_schema.members.origin[si] ]
                    if [ sm.src == typeid[ VertexInput ] ]
                        shader_input_count += 1
                shader_schema = shader_schema.context

            for [ i: 0, i < vbo.member_count, i +=1 ]
                if [ i >= shader_input_count ]
                    break
                mem: ref vbo.members[i]
                attributes[attr_count].binding  = 0
                attributes[attr_count].location = attr_count
                attributes[attr_count].format =
                    ( mem.src == typeid[ vec2f ]  ) ? VK_FORMAT_R32G32_SFLOAT       :
                    ( mem.src == typeid[ vec3f ]  ) ? VK_FORMAT_R32G32B32_SFLOAT    :
                    ( mem.src == typeid[ vec4f ]  ) ? VK_FORMAT_R32G32B32A32_SFLOAT :
                    ( mem.src == typeid[ rgba16 ] ) ? VK_FORMAT_R16G16B16A16_UNORM  :
                    ( mem.src == typeid[ rgba8 ]  ) ? VK_FORMAT_R8G8B8A8_UNORM     :
                    ( mem.src == typeid[ f32 ]    ) ? VK_FORMAT_R32_SFLOAT          :
                    ( mem.src == typeid[ i8 ]     ) ? VK_FORMAT_R8_SINT             :
                    ( mem.src == typeid[ u8 ]     ) ? VK_FORMAT_R8_UINT             :
                    ( mem.src == typeid[ i16 ]    ) ? VK_FORMAT_R16_SINT            :
                    ( mem.src == typeid[ u16 ]    ) ? VK_FORMAT_R16_UINT            :
                    ( mem.src == typeid[ u32 ]    ) ? VK_FORMAT_R32_UINT            :
                                                    VK_FORMAT_UNDEFINED
                f: attributes[attr_count].format
                expect f != VK_FORMAT_UNDEFINED, 'undefined vertex attribute for type {mem.src.ident}'
                attributes[attr_count].offset = mem.offset
                attr_count += 1
            
            vertex_input_info: VkPipelineVertexInputStateCreateInfo [
                sType: VK_STRUCTURE_TYPE_PIPELINE_VERTEX_INPUT_STATE_CREATE_INFO,
                vertexBindingDescriptionCount: 1,
                pVertexBindingDescriptions:    ref binding_description,
                vertexAttributeDescriptionCount: attr_count,
                pVertexAttributeDescriptions:    attributes
            ]
            input_assembly_info: VkPipelineInputAssemblyStateCreateInfo [
                sType:    VK_STRUCTURE_TYPE_PIPELINE_INPUT_ASSEMBLY_STATE_CREATE_INFO,
                topology: VK_PRIMITIVE_TOPOLOGY_TRIANGLE_LIST
            ]
            shader_stages: local VkPipelineShaderStageCreateInfo[4]
            n_stages: 2
            shader_stages[0] = VkPipelineShaderStageCreateInfo [
                sType:  VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO,
                stage:  VK_SHADER_STAGE_VERTEX_BIT,
                module: s.vk_vert,
                pName:  "main"
            ]
            shader_stages[1] = VkPipelineShaderStageCreateInfo [
                sType:  VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO,
                stage:  VK_SHADER_STAGE_FRAGMENT_BIT,
                module: s.vk_frag,
                pName:  "main"
            ]
            viewport_state: VkPipelineViewportStateCreateInfo [
                sType:         VK_STRUCTURE_TYPE_PIPELINE_VIEWPORT_STATE_CREATE_INFO,
                viewportCount: 1,
                pViewports:    null,
                scissorCount:  1,
                pScissors:     null
            ]
            rasterization_state: VkPipelineRasterizationStateCreateInfo [
                sType:                   VK_STRUCTURE_TYPE_PIPELINE_RASTERIZATION_STATE_CREATE_INFO,
                depthClampEnable:        VK_FALSE,
                rasterizerDiscardEnable: VK_FALSE,
                polygonMode:             VK_POLYGON_MODE_FILL,
                lineWidth:               1.0,
                cullMode:                VK_CULL_MODE_BACK_BIT,
                frontFace:               VK_FRONT_FACE_CLOCKWISE,
                depthBiasEnable:         VK_FALSE
            ]
            multisample_state: VkPipelineMultisampleStateCreateInfo [
                sType:                VK_STRUCTURE_TYPE_PIPELINE_MULTISAMPLE_STATE_CREATE_INFO,
                rasterizationSamples: VK_SAMPLE_COUNT_1_BIT,
                sampleShadingEnable:  VK_TRUE
            ]
            # blend factors depend on the fragment shader's output convention.
            # default = pre-multiplied alpha (Porter-Duff "over"):
            #   result.rgb = src.rgb + dst.rgb * (1 - src.a)
            #   result.a   = src.a   + dst.a   * (1 - src.a)
            # straight_alpha = true (text uses this) — shader emits rgb
            # un-pre-multiplied (rgb, a):
            #   result.rgb = src.rgb*src.a + dst.rgb * (1 - src.a)
            #   result.a   = src.a       + dst.a   * (1 - src.a)
            src_color_factor : VkBlendFactor [ (straight_alpha) ? VK_BLEND_FACTOR_SRC_ALPHA : VK_BLEND_FACTOR_ONE ]
            color_blend_attachment: VkPipelineColorBlendAttachmentState [
                blendEnable:         VK_TRUE,
                srcColorBlendFactor: src_color_factor,
                dstColorBlendFactor: VK_BLEND_FACTOR_ONE_MINUS_SRC_ALPHA,
                colorBlendOp:        VK_BLEND_OP_ADD,
                srcAlphaBlendFactor: VK_BLEND_FACTOR_ONE,
                dstAlphaBlendFactor: VK_BLEND_FACTOR_ONE_MINUS_SRC_ALPHA,
                alphaBlendOp:        VK_BLEND_OP_ADD,
                colorWriteMask:      VK_COLOR_COMPONENT_R_BIT |
                                     VK_COLOR_COMPONENT_G_BIT |
                                     VK_COLOR_COMPONENT_B_BIT |
                                     VK_COLOR_COMPONENT_A_BIT
            ]
            color_blend_state: VkPipelineColorBlendStateCreateInfo [
                sType:           VK_STRUCTURE_TYPE_PIPELINE_COLOR_BLEND_STATE_CREATE_INFO,
                logicOpEnable:   VK_FALSE,
                attachmentCount: 1,
                pAttachments:    ref color_blend_attachment
            ]

            dynamic_states: local VkDynamicState[2] [
                VK_DYNAMIC_STATE_VIEWPORT,
                VK_DYNAMIC_STATE_SCISSOR
            ]

            dynamic_state: VkPipelineDynamicStateCreateInfo [
                sType:             VK_STRUCTURE_TYPE_PIPELINE_DYNAMIC_STATE_CREATE_INFO,
                dynamicStateCount: sizeof[ dynamic_states ] / sizeof[ dynamic_states[0] ],
                pDynamicStates:    dynamic_states
            ]

            depth_stencil: VkPipelineDepthStencilStateCreateInfo [
                sType:                 VK_STRUCTURE_TYPE_PIPELINE_DEPTH_STENCIL_STATE_CREATE_INFO,
                depthTestEnable:       VK_TRUE,
                depthWriteEnable:      VK_TRUE,
                depthCompareOp:        VK_COMPARE_OP_LESS,
                depthBoundsTestEnable: VK_FALSE,
                stencilTestEnable:     VK_FALSE
            ]
            pipeline_info: VkGraphicsPipelineCreateInfo [
                sType:               VK_STRUCTURE_TYPE_GRAPHICS_PIPELINE_CREATE_INFO,
                stageCount:          n_stages,
                pStages:             shader_stages,
                pDepthStencilState:  ref depth_stencil,
                pVertexInputState:   ref vertex_input_info,
                pInputAssemblyState: ref input_assembly_info,
                pViewportState:      ref viewport_state,
                pRasterizationState: ref rasterization_state,
                pMultisampleState:   ref multisample_state,
                pColorBlendState:    ref color_blend_state,
                pDynamicState:       ref dynamic_state,
                layout:              layout,
                renderPass:          r.vk_render_pass[render_id],
                subpass:             0,
                basePipelineHandle:  null
            ]
            result = vkCreateGraphicsPipelines[
                vk.device, null, 1, pipeline_info, null, ref vk_render ]
            expect result == VK_SUCCESS, "pipeline creation fail"
            
        el [ s && s.vk_comp != null ]
            comp_info: VkComputePipelineCreateInfo [
                sType:  VK_STRUCTURE_TYPE_COMPUTE_PIPELINE_CREATE_INFO,
                layout: layout,
                stage:  VkPipelineShaderStageCreateInfo [
                    sType:  VK_STRUCTURE_TYPE_PIPELINE_SHADER_STAGE_CREATE_INFO,
                    stage:  VK_SHADER_STAGE_COMPUTE_BIT,
                    module: s.vk_comp,
                    pName:  "main"
                ]
            ]
            result = vkCreateComputePipelines[
                vk.device, null, 1, comp_info, null, ref vk_compute ]
            expect result == VK_SUCCESS, "failed to create compute pipeline"

    func init [ ]
        bind_resources[]
        # serialize pipeline construction against any in-flight gpu work.
        # the composite chain builds ~10 pipelines back-to-back during
        # Window.update, and without this fence the validator occasionally
        # caught modules / descriptor sets in a half-built state when the
        # process wasn't being paced by gdb.
        vkDeviceWaitIdle[ vk.device ]
        reassemble[]
        vkDeviceWaitIdle[ vk.device ]

    func dealloc [ ]
        vkDestroyPipelineLayout[ vk.device, layout, null ]
        if [ vk_render ]
            vkDestroyPipeline[ vk.device, vk_render, null ]
        if [ vk_compute ]
            vkDestroyPipeline[ vk.device, vk_compute, null ]


class gltf_part
    expect id : Primitive
    public s  : shader


class gltf_node
    public id    : Node
    public parts : array gltf_part [] # container-size on members

class Model
    context vk              : vk_context
    context w               : Display
    public r                : Render
    mutable transforms      : ref mat4f null
    mutable transform_count : i32
    public id               : GltfModel
    public nodes            : array gltf_node
    public s                : shader
    mutable samplers        : map Au[string] [ ]
    public pipelines        : array Pipeline
    # straight-alpha output (rgb, a) when true; default false = premul (rgb*a, a).
    # forwarded to every Pipeline this Model builds; toggle for shaders that
    # emit unpremultiplied alpha (e.g. cloud, text overlay).
    public straight_alpha   : bool

    public func rebind_model [ ] 
        if [ pipelines ]
            for [ p: Pipeline ] in pipelines
                p.rebind[]

    public func finish [ r_target: Render, render_id: i32 ]
        r = r_target
        pipelines = array Pipeline [ alloc: 16 ]
        is_clear: !r.models || r.models.count == 0

        if [ !s && !is_clear ]
            s = vk.quad_shader[ ]

        if [ !id && !is_clear ]
            # default quad if no Model
            id = vk.quad_m

        if [ is_clear ]
            puts 'Model.finish: branch=is_clear'
            model_init_pipeline[ a, null, null, null ]
        el [ nodes ]
            puts 'Model.finish: branch=nodes'
            for [ n: gltf_node ] in nodes
                for [ p: gltf_part ] in n.parts
                    model_init_pipeline[ a, n.id, p.id, (p.s) ? p.s : s ]
        el [ id ]
            puts 'Model.finish: branch=id'
            for [ n: Node ] in id.nodes
                has_mesh: n.AF_query_name[ "mesh" ]
                printf[ "  node has_mesh=%d\n", has_mesh ]
                if [ has_mesh ]
                    mesh: id.meshes [ n.mesh ]
                    printf[ "  mesh prims=%i\n", mesh.primitives.count ]
                    for [ prim: Primitive ] in mesh.primitives
                        model_init_pipeline[ a, n, prim, s ]
        el
            puts 'Model.finish: branch=NONE (no path matched!)'
        printf[ "Model.finish: pipelines after=%i\n", pipelines.count ]

    func init [ ]
        vk = w.vk.hold[]


struct mouse_state
    wheel_delta : vec2f
    pos         : vec2f
    button      : i32
    state       : i32

struct keyboard_state
    unicode   : u32
    scan_code : u32
    state     : i32
    meta      : bool
    shift     : bool
    alt       : bool
    text      : string


# forward declarations need resolver support
# process same way, different gen method (make_class -> make_decl)
class Event
    mutable target         : Au
    mutable mouse          : mouse_state
    mutable key            : keyboard_state
    mutable no_default     : bool
    mutable no_propagation : bool

    func prevent_default  [ ] 
        no_default = true

    func is_default [ ] -> bool
        return !no_default

    func should_propagate [ ] -> bool
        return !no_propagation

    func stop_propagation [ ] -> bool
        no_propagation = true
        return true

    func clear [ ] 
        target         = null
        key            = []
        no_default     = false
        no_propagation = false
        mouse.state    = -1
        mouse.button   = -1


alias EventCallback : lambda none [ Event ]


struct EventDispatch
    callbacks : array EventCallback

    func invoke [ ev : Event ]
        for [ event_processor : EventCallback ] in callbacks
            event_processor[ev]
    
    operator += [ call : EventCallback ]
        callbacks += call


class SVG
    public w        : f32
    public h        : f32
    public rw       : f32
    public rh       : f32
    public svg_dom  : handle



struct vertex_member_t
    src:    Au_t
    ac:     Accessor
    size:   i64
    offset: i64

# --- environment cubemap generation ---

struct image_range
    base_mip    : i32
    levels      : i32
    base_layer  : i32
    layers      : i32
    is_depth    : bool


class Command
    context vk : vk_context
    intern cmd : VkCommandBuffer

    func begin [ ] 
        vkResetCommandBuffer[ cmd, 0 ]
        vkBeginCommandBuffer[ cmd, VkCommandBufferBeginInfo [
            sType: VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO,
            flags: VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT
        ]]

    func submit [ ] 
        vkEndCommandBuffer[ cmd ]
        si: VkSubmitInfo [
            sType:              VK_STRUCTURE_TYPE_SUBMIT_INFO,
            commandBufferCount: 1,
            pCommandBuffers:    ref cmd
        ]
        vkQueueSubmit[ vk.queue, 1, si, null ]
        vkQueueWaitIdle[ vk.queue ]

    func init [ ]
        alloc_info: VkCommandBufferAllocateInfo [
            sType:              VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO,
            commandPool:        vk.command_pool,
            level:              VK_COMMAND_BUFFER_LEVEL_PRIMARY,
            commandBufferCount: 1
        ]
        vkAllocateCommandBuffers[ vk.device, alloc_info, ref cmd ]


class Buffer
    context vk              : vk_context
    expect size             : i64
    public data             : ARef
    public u_src            : bool
    public u_dst            : bool
    public u_shader         : bool
    public u_uniform        : bool
    public u_vertex         : bool
    public u_index          : bool
    public u_storage        : bool
    public m_device_local   : bool
    public m_host_visible   : bool
    public m_host_coherent  : bool
    intern user             : Au_t
    intern vma_alloc        : VmaAllocation
    intern vk_buffer        : VkBuffer

    # the use case of window must be handled by facilitating Texture as a delegate of window, with all of the info needed in there
    # in those cases trinity will internally manage that (we cannot understand what a window is in here)
    func transfer [ tx: Texture ] 
        expect tx, "expected Texture or window (with render pass run prior)"
        image:  tx.vk_image
        buf:    vk_buffer
        wi:     u32 [ tx.width ]
        hi:     u32 [ tx.height ]
        cmd:    VkCommandBuffer
        vkAllocateCommandBuffers [ vk.device, VkCommandBufferAllocateInfo [
            sType:              VK_STRUCTURE_TYPE_COMMAND_BUFFER_ALLOCATE_INFO,
            commandPool:        vk.command_pool,
            level:              VK_COMMAND_BUFFER_LEVEL_PRIMARY,
            commandBufferCount: 1 ], ref cmd ]
        vkBeginCommandBuffer [ cmd, VkCommandBufferBeginInfo [
            sType: VK_STRUCTURE_TYPE_COMMAND_BUFFER_BEGIN_INFO,
            flags: VK_COMMAND_BUFFER_USAGE_ONE_TIME_SUBMIT_BIT ] ]
        vkCmdPipelineBarrier [ cmd,
            VK_PIPELINE_STAGE_COLOR_ATTACHMENT_OUTPUT_BIT,
            VK_PIPELINE_STAGE_TRANSFER_BIT,
            0, 0, null, 0, null, 1, VkImageMemoryBarrier [
            sType:               VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER,
            srcAccessMask:       VK_ACCESS_COLOR_ATTACHMENT_WRITE_BIT,
            dstAccessMask:       VK_ACCESS_TRANSFER_READ_BIT,
            oldLayout:           VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL,
            newLayout:           VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
            image:               tx.vk_image,
            subresourceRange:    VkImageSubresourceRange [
                aspectMask:     VK_IMAGE_ASPECT_COLOR_BIT,
                baseMipLevel:   0,
                levelCount:     1,
                baseArrayLayer: 0,
                layerCount:     1 ] ] ]
        prev: VkImageLayout
        if [ tx ] # window did not do this <---- so you need a state for transfer source
            prev = tx.vk_layout
            tx.transition [ VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL ]
        vkCmdCopyImageToBuffer [ cmd, tx.vk_image, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL, buf, 1,
            VkBufferImageCopy [
                bufferOffset:      0,
                bufferRowLength:   0,
                bufferImageHeight: 0,
                imageSubresource:  VkImageSubresourceLayers [
                    aspectMask:     VK_IMAGE_ASPECT_COLOR_BIT,
                    mipLevel:       0,
                    baseArrayLayer: 0,
                    layerCount:     1 ],
                imageOffset: VkOffset3D [ x: 0, y: 0, z: 0 ],
                imageExtent: VkExtent3D [ width: wi, height: hi, depth: 1 ] ] ]
        vkEndCommandBuffer [ cmd ]
        vkQueueSubmit [ vk.queue, 1, VkSubmitInfo [
            sType:              VK_STRUCTURE_TYPE_SUBMIT_INFO,
            commandBufferCount: 1,
            pCommandBuffers:    ref cmd ], null ]
        vkQueueWaitIdle [ vk.queue ]
        vkFreeCommandBuffers [ vk.device, vk.command_pool, 1, ref cmd ]
        if [ tx ]
            tx.transition [ prev ] # same thing here -- we do not do this on window (same state as above)

    func update [ d: ARef ]
        if [ !size ]
            return
        src: d || data
        m: mmap[]
        memcpy[ m, src, size ]
        unmap[]

    func mmap [ ] -> ARef
        mapped: ARef
        result: vmaMapMemory[ vk.allocator, vma_alloc, ref mapped ]
        expect result == VK_SUCCESS, "failed to map buffer memory"
        return mapped

    func unmap [ ]
        expect vma_alloc, "expected memory"
        vmaUnmapMemory[ vk.allocator, vma_alloc ]

    func init [ ]
        usage: VkBufferUsageFlags [ 0 ]
        props: VkMemoryPropertyFlags [ 0 ]
        if [ u_uniform ]  usage |= VK_BUFFER_USAGE_UNIFORM_BUFFER_BIT
        if [ u_src ]      usage |= VK_BUFFER_USAGE_TRANSFER_SRC_BIT
        if [ u_dst ]      usage |= VK_BUFFER_USAGE_TRANSFER_DST_BIT
        if [ u_shader ]   usage |= VK_BUFFER_USAGE_SHADER_DEVICE_ADDRESS_BIT
        if [ u_storage ]  usage |= VK_BUFFER_USAGE_STORAGE_BUFFER_BIT
        if [ u_vertex ]   usage |= VK_BUFFER_USAGE_VERTEX_BUFFER_BIT
        if [ u_index ]    usage |= VK_BUFFER_USAGE_INDEX_BUFFER_BIT
        if [ m_device_local ]  props |= VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT
        if [ m_host_visible ]  props |= VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT
        if [ m_host_coherent ] props |= VK_MEMORY_PROPERTY_HOST_COHERENT_BIT
        buffer_info: VkBufferCreateInfo [
            sType:       VK_STRUCTURE_TYPE_BUFFER_CREATE_INFO,
            size:        size,
            usage:       usage,
            sharingMode: VK_SHARING_MODE_EXCLUSIVE
        ]
        alloc_info: VmaAllocationCreateInfo [
            usage: VMA_MEMORY_USAGE_AUTO
        ]
        if [ m_device_local ]
            alloc_info.preferredFlags |= VK_MEMORY_PROPERTY_DEVICE_LOCAL_BIT
        if [ m_host_visible ]
            alloc_info.requiredFlags |= VK_MEMORY_PROPERTY_HOST_VISIBLE_BIT
        if [ m_host_coherent ]
            alloc_info.requiredFlags |= VK_MEMORY_PROPERTY_HOST_COHERENT_BIT
        if [ data || m_host_visible ]
            alloc_info.flags = VMA_ALLOCATION_CREATE_MAPPED_BIT | VMA_ALLOCATION_CREATE_HOST_ACCESS_SEQUENTIAL_WRITE_BIT
        # ask VMA to fill in the persistently-mapped pointer for us
        vma_info: VmaAllocationInfo
        result: vmaCreateBuffer[ vk.allocator, buffer_info, alloc_info, ref vk_buffer, ref vma_alloc, ref vma_info ]
        expect result == VK_SUCCESS, "failed to create buffer"
        if [ data ]
            # caller-provided source data: copy in once.
            mapped: mmap[]
            memcpy[ mapped, data, size ]
            unmap[]
        el [ m_host_visible && vma_info.pMappedData ]
            # no source data but host-visible: expose VMA's persistent mapping
            # as `data` so callers can write directly without re-mapping.
            data = vma_info.pMappedData

    func dealloc [ ]
        vmaDestroyBuffer[ vk.allocator, vk_buffer, vma_alloc ]


class Texture
    context vk              : vk_context
    context w               : Display
    public pixel_format     : Pixel [ Pixel.rgba8 ]
    public sampler          : object
    public width            : i32
    public height           : i32
    public swap             : bool
    public mip_levels       : i32
    public layer_count      : i32
    public surface          : Surface
    public linear           : bool
    public is_storage       : bool   # adds VK_IMAGE_USAGE_STORAGE_BIT for compute write
    public silly_test4      : bool
    public title            : string 'default title'
    
    intern vk_layout        : VkImageLayout
    intern vk_format        : VkFormat
    intern vk_image         : VkImage
    intern vk_image_view    : VkImageView
    intern vk_sampler       : VkSampler
    intern vma_alloc        : VmaAllocation

    func resize [ w_new: i32, h_new: i32 ] -> Texture
        if [ w_new == width && h_new == height ]
            return a
        width  = w_new
        height = h_new
        # no vkDeviceWaitIdle — the owning Render's sync_fence[] (called from
        # its update[] before it reaches texture resize) already waited for
        # that Render's in-flight work. device-wide waits here compound to
        # seconds across the full composite chain.
        dealloc     [ ]
        init        [ ]
        hold_members[ ]
        return a

    cast -> Image
        channels: i32 [ 0 ]
        pixel: pixel_from_format[ vk_format, ref channels ]
        expect pixel != 0, "unsupported format for texture_cast_image"
        b: Buffer [ vk: vk, size: width * height * channels,
            u_dst: true, m_host_visible: true, m_host_coherent: true ]
        b.transfer a
        res: Image [
            width:    width,
            height:   height,
            format:   pixel,
            res_bits: b.mmap[],
            res2:     b.hold[],
            res_dealloc: ref image_release_buffer
        ]
        return res
    

    func transition [ new_layout: i32 ]
        if [ vk_layout != new_layout ]
            is_d32 : bool [ vk_format == VK_FORMAT_D32_SFLOAT ]
            vk.transition_image_layout[ vk_image, vk_layout, new_layout,
                0, mip_levels, 0, layer_count, vk_format == VK_FORMAT_D32_SFLOAT ]
            vk_layout = new_layout

    # in-band variant: records vkCmdPipelineBarrier into the given command
    # buffer rather than spinning up its own. needed when the same image must
    # flip layouts mid-frame (compute write -> graphics sample), since out-of-
    # band transitions can't be reconciled by the validator's per-command-buffer
    # layout tracking.
    
    func transition_in [ f: handle, new_layout: i32 ]
        if [ vk_layout == new_layout ]
            return
        src: Layout.find[ vk_layout ]
        dst: Layout.find[ new_layout ]
        expect src && dst, "layout not found"
        expect vk_image, "Texture.transition_in: vk_image is null (texture not initialized)"
        is_depth: bool [ vk_format == VK_FORMAT_D32_SFLOAT ]
        barrier: VkImageMemoryBarrier [
            sType:               VK_STRUCTURE_TYPE_IMAGE_MEMORY_BARRIER,
            pNext:               null,
            oldLayout:           vk_layout,
            newLayout:           new_layout,
            srcQueueFamilyIndex: VK_QUEUE_FAMILY_IGNORED,
            dstQueueFamilyIndex: VK_QUEUE_FAMILY_IGNORED,
            image:               vk_image,
            subresourceRange:    VkImageSubresourceRange [
                aspectMask:     (is_depth) ? VK_IMAGE_ASPECT_DEPTH_BIT : VK_IMAGE_ASPECT_COLOR_BIT,
                baseMipLevel:   0,
                levelCount:     mip_levels,
                baseArrayLayer: 0,
                layerCount:     layer_count
            ],
            srcAccessMask:       src.access,
            dstAccessMask:       dst.access
        ]
        cmd: VkCommandBuffer [ f ]
        vkCmdPipelineBarrier[ cmd, src.stage, dst.stage, 0, 0, null, 0, null, 1, ref barrier ]
        vk_layout = new_layout 

        
    func hex_dump [ name: symbol, data: ref u8, size: i32 ]
        printf[ "%s (%d bytes):\n", name, size ]
        for [ i: i32 0, i < size, i += 1 ]
            b: u8 data[ i ]
            printf[ "%02x ", u32[b] ]
            if [ (i + 1) % 16 == 0 ]
                printf[ "\n" ]
        if [ size % 16 != 0 ]    
            printf[ "\n" ]

    func test_vma [ ]                                                   
        allocator: VmaAllocator                                         
        result: vmaCreateAllocator[ VmaAllocatorCreateInfo [            
            physicalDevice:    vk.physical_device,                         
            device:            vk.device,                                  
            instance:          vk.instance,                                
            vulkanApiVersion:  VK_API_VERSION_1_2,                      
            pVulkanFunctions:  null,                                    
            flags: VMA_ALLOCATOR_CREATE_BUFFER_DEVICE_ADDRESS_BIT                      
        ], ref allocator ]                                            
        printf[ "vmaCreateAllocator: %d\n", result ]                    
        if [ result == VK_SUCCESS ]                                 
            vk_image0:  VkImage                                          
            vma_alloc0: VmaAllocation                                    
            result = vmaCreateImage[ allocator, VkImageCreateInfo [   
                sType:         VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO,     
                imageType:     VK_IMAGE_TYPE_2D,                      
                format:        VK_FORMAT_R8G8B8A8_UNORM,                
                extent:        VkExtent3D [ 888, 888, 1 ],            
                mipLevels:     1,                                       
                arrayLayers:   1,                                     
                samples:       VK_SAMPLE_COUNT_1_BIT,                   
                tiling:        VK_IMAGE_TILING_OPTIMAL,             
                usage:         VK_IMAGE_USAGE_SAMPLED_BIT,              
                sharingMode:   VK_SHARING_MODE_EXCLUSIVE,             
                initialLayout: VK_IMAGE_LAYOUT_UNDEFINED                
            ], VmaAllocationCreateInfo [
                usage: VMA_MEMORY_USAGE_AUTO_PREFER_DEVICE              
            ], ref vk_image0, ref vma_alloc0, null ]                      
            printf[ "vmaCreateImage: %d\n", result ]                  
            if [ result == VK_SUCCESS ]                                 
                vmaDestroyImage[ allocator, vk_image, vma_alloc ]
            vmaDestroyAllocator[ allocator ]

    # upload raw bytes into the existing vk_image. assumes the image was
    # already created at width x height with the right format. used by
    # Canvas's per-draw SDF generation to push fresh distance-field data
    # into the canvas's stable sdf_tex without recreating the texture.
    func upload [ data: ARef, byte_count: i32 ]
        expect vk, "vk_context not specified"
        expect vk_image, "vk_image not yet created"
        transition[ VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL ]
        cmd: Command [ vk: vk ]
        cmd.begin[]
        staging: Buffer [ vk: vk, size: byte_count, u_src: true,
            m_host_visible: true, m_host_coherent: true,
            data: data ]
        vkCmdCopyBufferToImage[ cmd.cmd, staging.vk_buffer, vk_image,
            VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, VkBufferImageCopy [
                bufferOffset:      0,
                bufferRowLength:   0,
                bufferImageHeight: 0,
                imageSubresource:  VkImageSubresourceLayers [
                    aspectMask:     VK_IMAGE_ASPECT_COLOR_BIT,
                    mipLevel:       0,
                    baseArrayLayer: 0,
                    layerCount:     1
                ],
                imageOffset: VkOffset3D [ 0, 0, 0 ],
                imageExtent: VkExtent3D [ width, height, 1 ]
            ]]
        cmd.submit[ ]
        vkDeviceWaitIdle[ vk.device ]
        transition[ VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]

    # upload a sub-rectangle of bytes into the existing vk_image. used by
    # the glyph atlas to drop a freshly-rasterized glyph bitmap into its
    # packed slot without re-uploading the entire atlas.
    func upload_region [ dst_x: i32, dst_y: i32, dst_w: i32, dst_h: i32, data: ARef, byte_count: i32 ]
        expect vk, "vk_context not specified"
        expect vk_image, "vk_image not yet created"
        transition[ VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL ]
        cmd: Command [ vk: vk ]
        cmd.begin[]
        staging: Buffer [ vk: vk, size: byte_count, u_src: true,
            m_host_visible: true, m_host_coherent: true,
            data: data ]
        vkCmdCopyBufferToImage[ cmd.cmd, staging.vk_buffer, vk_image,
            VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, VkBufferImageCopy [
                bufferOffset:      0,
                bufferRowLength:   0,
                bufferImageHeight: 0,
                imageSubresource:  VkImageSubresourceLayers [
                    aspectMask:     VK_IMAGE_ASPECT_COLOR_BIT,
                    mipLevel:       0,
                    baseArrayLayer: 0,
                    layerCount:     1
                ],
                imageOffset: VkOffset3D [ dst_x, dst_y, 0 ],
                imageExtent: VkExtent3D [ dst_w, dst_h, 1 ]
            ]]
        cmd.submit[ ]
        vkDeviceWaitIdle[ vk.device ]
        transition[ VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]

    func init [ ]
        expect vk, "vk_context not specified"
        fmt: i32 [ vk_format ]
        puts 'Texture.init: width={width} height={height} vk_format={fmt}'
        if [ !vk_image && !sampler && !w ]
            puts 'Texture.init: early return — no vk_image, no sampler, no w'
            return

        img :  sampler inherits Image
        ansio: 4
        sampler_size: i32 [ 0 ]
        fill: local u8[256]
        if [ !mip_levels ]
            mip_levels = 1
        if [ !layer_count ]
            layer_count = 1
        if [ !vk_format && pixel_format ]
            vk_format = vk_format_fn[ pixel_format, linear ]
        is_depth: vk_format == VK_FORMAT_D32_SFLOAT
        if [ vk_image ]
            expect vk_format, "expected format"
        el
            if [ width > 0 || img ]
                pixel_format = (img) ? img.format : pixel_format
                sampler_size = (img) ? img.byte_count[] : 0
                ansio        = (img) ? 4 : 0
                if [ img ]
                    width  = img.width
                    height = img.height
            el [ sampler ]
                width  = 4
                height = 4
                ansio  = 0
                placeholder_image[ sampler, 4, ref fill, ref sampler_size, ref pixel_format ]
                vk_format = vk_format_fn[ pixel_format, false ]
        if [ width > 0 || vk_image ]
            usage: VkImageUsageFlags [ 0 ]
            if [ is_depth ]
                usage = VK_IMAGE_USAGE_DEPTH_STENCIL_ATTACHMENT_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT
            el [ swap ]
                usage = VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT
            el
                usage = VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT |
                        VK_IMAGE_USAGE_TRANSFER_DST_BIT     |
                        VK_IMAGE_USAGE_TRANSFER_SRC_BIT     |
                        VK_IMAGE_USAGE_SAMPLED_BIT
            if [ is_storage ]
                usage |= VK_IMAGE_USAGE_STORAGE_BIT

            if [ !vk_format && pixel_format ]
                vk_format = vk_format_fn[ pixel_format, linear ]

            info : VkImageCreateInfo [
                sType:         VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO,
                imageType:     VK_IMAGE_TYPE_2D,
                format:        vk_format,
                flags:         (layer_count >= 6) ? VK_IMAGE_CREATE_CUBE_COMPATIBLE_BIT : 0,
                extent:        VkExtent3D [ width, height, 1 ],
                mipLevels:     mip_levels,
                arrayLayers:   layer_count,
                samples:       VK_SAMPLE_COUNT_1_BIT,
                tiling:        VK_IMAGE_TILING_OPTIMAL,
                usage:         usage,
                sharingMode:   VK_SHARING_MODE_EXCLUSIVE,
                initialLayout: VK_IMAGE_LAYOUT_UNDEFINED
            ]
            printf[ "sType=%d imageType=%d format=%d flags=%d\n", info.sType,
                info.imageType, info.format, info.flags ]
            printf[ "extent=%d,%d,%d mip=%d layers=%d samples=%d\n",
                info.extent.width, info.extent.height, info.extent.depth,
                info.mipLevels, info.arrayLayers, info.samples ]
            #hex_dump[ "vkImageCreateInfo", ref info, sizeof VkImageCreateInfo ]

            if [ !vk_image && vk_format ]
                alloc_info: VmaAllocationCreateInfo [
                    usage: VMA_MEMORY_USAGE_AUTO_PREFER_DEVICE
                ]
                result: vmaCreateImage[ vk.allocator, info, alloc_info, ref vk_image, ref vma_alloc, null ]
                expect result == VK_SUCCESS, 'failed to create VkImage: {i32[result]}'
                expect vk_image, 'vmaCreateImage returned success but vk_image is null'

            if [ sampler_size > 0 ]
                transition[ VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL ]
                expect !is_depth, "unexpected"
                cmd: Command [ vk: vk ]
                cmd.begin[]
                staging: Buffer [ vk: vk, size: sampler_size, u_src: true, u_shader: true,
                    m_host_visible: true, m_host_coherent: true,
                    data: (img) ? img.data : fill ]
                vkCmdCopyBufferToImage[ cmd.cmd, staging.vk_buffer, vk_image,
                    VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 1, VkBufferImageCopy [
                        bufferOffset:      0,
                        bufferRowLength:   0,
                        bufferImageHeight: 0,
                        imageSubresource:  VkImageSubresourceLayers [
                            aspectMask:     (is_depth) ? VK_IMAGE_ASPECT_DEPTH_BIT : VK_IMAGE_ASPECT_COLOR_BIT,
                            mipLevel:       0,
                            baseArrayLayer: 0,
                            layerCount:     layer_count
                        ],
                        imageOffset: VkOffset3D [ 0, 0, 0 ],
                        imageExtent: VkExtent3D [ width, height, 1 ]
                    ]]
                cmd.submit[ ]
                vkDeviceWaitIdle[ vk.device ]
                vk.create_mipmaps[ vk_image, width, height, mip_levels, layer_count ]
                vk_layout = VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL
            puts 'before view: width={width} height={height}'
            if [ !vk_image_view ]
                view_type: (layer_count >  6) ? VK_IMAGE_VIEW_TYPE_CUBE_ARRAY :
                           (layer_count == 6) ? VK_IMAGE_VIEW_TYPE_CUBE : VK_IMAGE_VIEW_TYPE_2D
                viewInfo: VkImageViewCreateInfo [
                    sType:    VK_STRUCTURE_TYPE_IMAGE_VIEW_CREATE_INFO,
                    image:    vk_image,
                    viewType: view_type,
                    format:   vk_format,
                    components: VkComponentMapping [
                        r: VK_COMPONENT_SWIZZLE_IDENTITY,
                        g: VK_COMPONENT_SWIZZLE_IDENTITY,
                        b: VK_COMPONENT_SWIZZLE_IDENTITY,
                        a: VK_COMPONENT_SWIZZLE_IDENTITY
                    ],
                    subresourceRange: VkImageSubresourceRange [
                        aspectMask:     (is_depth) ? VK_IMAGE_ASPECT_DEPTH_BIT : VK_IMAGE_ASPECT_COLOR_BIT,
                        baseMipLevel:   0,
                        levelCount:     mip_levels,
                        baseArrayLayer: 0,
                        layerCount:     layer_count
                    ]
                ]
                res: vkCreateImageView[ vk.device, viewInfo, null, ref vk_image_view ]
                expect res == VK_SUCCESS, "Failed to create VkImageView"
            if [ !vk_sampler ]
                address_mode: (layer_count >= 6) ?
                    VK_SAMPLER_ADDRESS_MODE_CLAMP_TO_EDGE : VK_SAMPLER_ADDRESS_MODE_REPEAT
                samplerInfo: VkSamplerCreateInfo [
                    sType:                   VK_STRUCTURE_TYPE_SAMPLER_CREATE_INFO,
                    magFilter:               VK_FILTER_LINEAR,
                    minFilter:               VK_FILTER_LINEAR,
                    addressModeU:            address_mode,
                    addressModeV:            address_mode,
                    addressModeW:            address_mode,
                    anisotropyEnable:        (ansio > 0) ? VK_TRUE : VK_FALSE,
                    maxAnisotropy:           ansio,
                    minLod:                  0.0,
                    maxLod:                  f32 mip_levels,
                    borderColor:             VK_BORDER_COLOR_FLOAT_OPAQUE_WHITE,
                    unnormalizedCoordinates: VK_FALSE,
                    compareEnable:           VK_FALSE,
                    compareOp:               VK_COMPARE_OP_ALWAYS,
                    mipmapMode:              VK_SAMPLER_MIPMAP_MODE_LINEAR
                ]
                r: vkCreateSampler[ vk.device, samplerInfo, null, ref vk_sampler ]
                expect r == VK_SUCCESS, "Failed to create VkSampler"

    func dealloc [ ]
        vkDestroySampler[ vk.device, vk_sampler, null ]
        vkDestroyImageView[ vk.device, vk_image_view, null ]
        # swap textures wrap a VkImage owned by the swapchain — destroying the
        # swapchain already invalidated it; we must NOT call vmaDestroyImage.
        if [ !swap ]
            vmaDestroyImage[ vk.allocator, vk_image, vma_alloc ]
        vk_layout     = VK_IMAGE_LAYOUT_UNDEFINED
        vma_alloc     = null
        vk_image      = null
        vk_image_view = null
        vk_sampler    = null


Texture Display
    intern glfw                 : handle
    public mouse                : vec2f
    intern swap_model           : Model
    public element_targets      : map   Render [string]
    mutable list                 : array Render
    intern swap_renders         : array Render
    intern vk_swap_images       : ref   VkImage
    intern vk_surface           : VkSurfaceKHR
    intern vk_swapchain         : VkSwapchainKHR
    intern surface_caps         : ref VkSurfaceCapabilitiesKHR
    intern surface_format       : VkSurfaceFormatKHR
    intern present_mode         : VkPresentModeKHR
    intern extent               : VkExtent2D
    intern swap_render_current  : Render
    intern semaphore_frame      : Render
    intern swap_image_count     : u32
    intern swap_image_current   : u32
    intern ev                   : Event
    #public on_surface          : hook -- where was this thing
    public format               : Pixel
    mutable debug_value          : f32
    public current_swap_index   : i32
    public text_event           : EventDispatch
    public move_event           : EventDispatch
    public press_event          : EventDispatch
    public key_event            : EventDispatch
    public touch_event          : EventDispatch
    public release_event        : EventDispatch
    public wheel_event          : EventDispatch
    intern resized              : bool
    # debounced resize: GLFW emits framebuffer_size continuously while dragging.
    # We don't recreate the swapchain on every callback (would hitch the frame).
    # Instead the callback stamps pending dimensions + a timestamp, and
    # Display.draw triggers resize once the user has been idle for >= debounce.
    intern pending_w            : i32
    intern pending_h            : i32
    intern last_resize_t        : f64
    intern resize_debounce_s    : f64 [ 0.188 ]
    intern in_callback_draw     : bool
    public backbuffer           : bool
    func last_render [] -> Render
        return list.last_element[]


    func update [ ] return

    func on_screen    [ ] return
    func on_compose[ ] return

    func resize [ w_new: i32, h_new: i32 ] -> Display
        width  = w_new
        height = h_new
        extent.width  = w_new
        extent.height = h_new

        for [ r: Render, id: string ] in element_targets
            r.update[ ]
            if [ resized && r.models ]
                for [ m: Model ] in r.models
                    m.rebind_model[ ]
        for [ r: Render ] in list
            r.update[ ]
            if [ resized && r.models ]
                for [ m: Model ] in r.models
                    m.rebind_model[ ]
        printf[ "last_render = %p\n", last_render[] ]
        resized = true
        if [ !backbuffer ]
            # Re-query into a stack local. The intern `surface_caps` ref field
            # only holds a raw pointer to the new'd struct from init; on later
            # resizes that allocation has been recycled and reading
            # currentTransform/minImageCount yields garbage (e.g. 0x5555),
            # which fails the validator on preTransform.
            caps: VkSurfaceCapabilitiesKHR
            vkGetPhysicalDeviceSurfaceCapabilitiesKHR[ vk.physical_device, vk_surface, ref caps ]
            if [ caps.currentExtent.width != UINT32_MAX ]
                width  = caps.currentExtent.width
                height = caps.currentExtent.height
            old_swapchain: vk_swapchain
            result: vkCreateSwapchainKHR[ vk.device, VkSwapchainCreateInfoKHR [
                sType:                 VK_STRUCTURE_TYPE_SWAPCHAIN_CREATE_INFO_KHR,
                pNext:                 null,
                surface:               vk_surface,
                minImageCount:         caps.minImageCount,
                imageFormat:           surface_format.format,
                imageColorSpace:       surface_format.colorSpace,
                imageExtent:           VkExtent2D [ width, height ],
                imageArrayLayers:      1,
                imageUsage:            VK_IMAGE_USAGE_COLOR_ATTACHMENT_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT,
                imageSharingMode:      VK_SHARING_MODE_EXCLUSIVE,
                preTransform:          caps.currentTransform,
                compositeAlpha:        VK_COMPOSITE_ALPHA_OPAQUE_BIT_KHR,
                presentMode:           present_mode,
                clipped:               VK_TRUE,
                oldSwapchain:          (old_swapchain != null) ? old_swapchain : null
            ], null, ref vk_swapchain ]
            expect result == VK_SUCCESS, "Failed to create swapchain"
            if [ old_swapchain != null ]
                vkDestroySwapchainKHR[ vk.device, old_swapchain, null ]
        
        if [ !backbuffer ]
            if [ !swap_model ]
                top: last_render[]
                expect top, "last_render must be set"
                ii:2
                samplers : map Au[string] [
                    "color": top
                ]
                swap_model = Model [ vk: vk, w: a, samplers: samplers ]

            vkGetSwapchainImagesKHR[ vk.device, vk_swapchain, ref swap_image_count, null ]
            
            if [ !vk_swap_images ]
                count : swap_image_count
                vk_swap_images = new VkImage [ count ]

            if [ !swap_renders ]
                swap_renders = array Render [ alloc: swap_image_count ]
            el
                swap_renders.clear[]
            
            vkGetSwapchainImagesKHR[ vk.device, vk_swapchain, ref swap_image_count, vk_swap_images ]
            swap_image_current = 0
            for [ i: 0, i < swap_image_count, i += 1 ]
                swap_renders += Render [
                    vk:vk,   w:a,
                    width:         width,
                    height:        height,
                    vk_swap_image: vk_swap_images[i],
                    models:        array Model [ swap_model ]
                ]
            semaphore_frame = swap_renders.first_element[]
            swap_render_current = swap_renders.origin[0]
        return a

    func final_target [ ] -> Render
        return list.last_element[]

    func draw [ ]
        # debounced swapchain recreate: only run when the user has stopped
        # dragging for at least resize_debounce_s. During the drag itself, the
        # window system stretches the existing swapchain image — this is the
        # accepted trade for not hitching every callback.
        if [ pending_w > 0 && pending_h > 0 ]
            now: f64 [ glfwGetTime[] ]
            if [ now - last_resize_t >= resize_debounce_s ]
                if [ pending_w != width || pending_h != height ]
                    resize[ pending_w, pending_h ]
                pending_w     = 0
                pending_h     = 0
                last_resize_t = 0.0
        
        for [ r: Render, id: string ] in element_targets
            r.draw*[]
            r.sync_fence*[]
        
        on_compose*[]

        for [ r: Render ] in list
            r.draw*[]
            r.sync_fence*[]
        
        on_screen*[]

        if [ swap_renders ]
            result: vkAcquireNextImageKHR[ vk.device, vk_swapchain, UINT64_MAX,
                semaphore_frame.vk_image_available_semaphore, null, ref swap_image_current ]
            if [ result == VK_ERROR_OUT_OF_DATE_KHR || result == VK_SUBOPTIMAL_KHR ]
                # swapchain is out-of-date because the surface has been resized.
                # Don't recurse through handle_glfw_framebuffer_size — it would
                # clobber any pending resize state with the (still-old) Display
                # dimensions and stop the debounce check from ever firing.
                # Skip presenting this frame; the next debounce tick will run
                # the real resize against the most recent pending dimensions.
                ii: 0
            el
                expect result == VK_SUCCESS, "failed to acquire swapchain image"
                swap_render_current = swap_renders[swap_image_current]
                last_render[].color.transition[ VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
                swap_render_current.color.transition[ VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
                #printf[ "  swap_render_current swap=%p reduce=%d clear=[%f,%f,%f,%f]\n",
                #    swap_render_current.vk_swap_image, swap_render_current.reduce,
                #    swap_render_current.clear_color.x, swap_render_current.clear_color.y,
                #    swap_render_current.clear_color.z, swap_render_current.clear_color.w ]
                swap_render_current.draw[]
                last_render[].color.transition[ VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
                presentInfo: VkPresentInfoKHR [
                    sType:              VK_STRUCTURE_TYPE_PRESENT_INFO_KHR,
                    swapchainCount:     1,
                    pSwapchains:        ref vk_swapchain,
                    pImageIndices:      ref swap_image_current,
                    waitSemaphoreCount: 1,
                    pWaitSemaphores:    ref semaphore_frame.vk_render_finished_semaphore
                ]
                swap_render_current.color.transition[ VK_IMAGE_LAYOUT_PRESENT_SRC_KHR ]
                result = vkQueuePresentKHR[ vk.queue, presentInfo ]
                swap_render_current.color.transition[ VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
                semaphore_frame = swap_renders[semaphore_frame == swap_renders.first_element[]]
                if [ result != VK_ERROR_OUT_OF_DATE_KHR && result != VK_SUBOPTIMAL_KHR ]
                    expect result == VK_SUCCESS, "present"
                    swap_render_current.sync_fence[]

                    
    cast -> Image
        color_size: (format == Pixel.rgbaf32) ? 16 : 4
        image_size: width * height * color_size
        b: Buffer [ vk: vk, size: image_size,
            u_dst: true, m_host_visible: true, m_host_coherent: true ]
        b.transfer[ a ]
        d: b.mmap[]
        result: Image [
            width:   width,
            height:  height,
            format:  format,
            surface: Surface.color
        ]
        memcpy[ result.vdata[], d, image_size ]
        b.unmap[ ]
        return result

    func init [ ]
        hold[]
        if [ !format ]
            format = Pixel.rgba8
        if [ !list ]
            list = array Render [ alloc: 32 ]
        if [ !element_targets ]
            element_targets = map Au[string][]
        ev = Event[]

        if [ !width ]
            width  = 1200
            height = 1200

        surf : handle
        # glfw window + vulkan surface
        if [ !backbuffer ]
            glfwWindowHint[ GLFW_CLIENT_API, GLFW_NO_API ]
            glfw = glfwCreateWindow[ width, height, title, null, null ]
            expect glfw, "Failed to create GLFW window"

            # glfw callbacks
            glfwSetWindowUserPointer    [ glfw, handle[ a ] ]
            glfwSetKeyCallback          [ glfw, ref handle_glfw_key ]
            glfwSetMouseButtonCallback  [ glfw, ref handle_glfw_mouse ]
            glfwSetCursorPosCallback    [ glfw, ref handle_glfw_cursor ]
            glfwSetCharCallback         [ glfw, ref handle_glfw_char ]

            glfwSetFramebufferSizeCallback [ glfw, ref handle_glfw_framebuffer_size ]

            printf["vk instance of %p\n", vk.instance]
            # vulkan surface
            result: glfwCreateWindowSurface[ vk.instance, glfw, null, ref surf ]
            expect result == VK_SUCCESS, "Failed to create Vulkan surface"

        # finish device
        vk_surface = surf
        printf[ "surface is set to %p (%p) wh = %i %i\n", surf, vk_surface, width, height ]
        vk.attach[ surf ]

        # surface capabilities + formats
        if [ !backbuffer ]
            surface_caps = new VkSurfaceCapabilitiesKHR [ 1 ]
            result: vkGetPhysicalDeviceSurfaceCapabilitiesKHR[ vk.physical_device, vk_surface, surface_caps ]
            expect result == VK_SUCCESS, "Failed to query surface capabilities"

            # surface format
            format_count: u32 [ 0 ]
            vkGetPhysicalDeviceSurfaceFormatsKHR[ vk.physical_device, vk_surface, ref format_count, null ]
            expect format_count > 0, "No surface formats found"
            formats: new VkSurfaceFormatKHR [ format_count ]
            vkGetPhysicalDeviceSurfaceFormatsKHR[ vk.physical_device, vk_surface, ref format_count, formats ]

            # use linear UNORM swap format — shader writes raw values and
            # the display reads them as-is (no automatic linear→sRGB
            # encoding on write). reverted from the SRGB pref added in
            # 9b5886b8 because going through the auto-gamma path made the
            # composite chain output too bright.
            surface_format = formats[0]
            for [ i: u32 0, i < format_count, i += 1 ]
                if [ formats[i].format == VK_FORMAT_B8G8R8A8_UNORM ]
                    surface_format = formats[i]

            # present mode
            present_mode_count: u32 [ 0 ]
            vkGetPhysicalDeviceSurfacePresentModesKHR[
                vk.physical_device, vk_surface, ref present_mode_count, null ]
            expect present_mode_count > 0, "No present modes found"
            present_modes: new VkPresentModeKHR [ present_mode_count ]
            vkGetPhysicalDeviceSurfacePresentModesKHR[
                vk.physical_device, vk_surface, ref present_mode_count, present_modes ]
            present_mode = VK_PRESENT_MODE_FIFO_KHR
            for [ i: u32 0, i < present_mode_count, i += 1 ]
                if [ present_modes[i] == VK_PRESENT_MODE_MAILBOX_KHR ]
                    present_mode = VK_PRESENT_MODE_MAILBOX_KHR
                    break

            # initial window size
            w_i: i32
            h_i: i32
            glfwGetWindowSize[ glfw, ref w_i, ref h_i ]
            extent.width  = u32[ w_i ]
            extent.height = u32[ h_i ]
        el
            surface_format.format     = (format == Pixel.rgbaf32) ? VK_FORMAT_R32G32B32A32_SFLOAT : VK_FORMAT_R8G8B8A8_UNORM
            surface_format.colorSpace = VK_COLOR_SPACE_SRGB_NONLINEAR_KHR
            extent.width  = width
            extent.height = height

    func dealloc [ ]
        if [ !backbuffer ]
            vkDestroySwapchainKHR[ vk.device, vk_swapchain, null ]
            vkDestroySurfaceKHR[ vk.instance, vk_surface, null ]
            glfwDestroyWindow[ glfw ]


alias ShaderModuleRef : ref VkShaderModule

class shader
    context vk          : vk_context
    public name         : string
    public vert         : path
    public frag         : path
    public comp         : path
    public reload_count : i32
    intern vk_vert      : VkShaderModule
    intern vk_frag      : VkShaderModule
    intern vk_comp      : VkShaderModule

    func indent [ s: symbol ] -> string
        str: string[s]
        sp : array string [ str.split["\n"] ]
        res: string[alloc:str.count * 2]
        for [line:string] in sp
            res.append["\t"]
            res.concat[line]
            res.append["\n"]
        return res

    func vertex   [] -> GLSL none {}

    func fragment [] -> GLSL none {}

    func compute  [] -> GLSL none {}

    func glsl_type_name [ t: Au_t ] -> cstr
        if [ t == typeid[ mat4f ] ]
            return "mat4"
        if [ t == typeid[ mat3f ] ]
            return "mat3"
        if [ t == typeid[ vec4f ] ]
            return "vec4"
        if [ t == typeid[ vec3f ] ]
            return "vec3"
        if [ t == typeid[ vec2f ] ]
            return "vec2"
        if [ t == typeid[ f32 ] ]
            return "float"
        if [ t == typeid[ i32 ] ]
            return "int"
        if [ t == typeid[ u32 ] ]
            return "uint"
        if [ t == typeid[ bool ] ]
            return "bool"
        if [ t == typeid[ none ] ]
            return "void"
        if [ t == typeid[ sampler2D ] ]
            return "sampler2D"
        if [ t == typeid[ sampler3D ] ]
            return "sampler3D"
        if [ t == typeid[ samplerCube ] ]
            return "samplerCube"
        return null

    func glsl_header [ stage: ShaderStage ] -> string
        type:   Au_t [ typeid[ a ] ]
        result: string [ '#version 450\n\n' ]

        # emit void main() from the stage entry point
        main_name: (stage == ShaderStage.vertex) ? "vertex" : (stage == ShaderStage.fragment) ? "fragment" : "compute"
        main_member:  Au_t [ find_member[ type, main_name, 5, 0, true ] ]
        if [ !main_member || main_member.context == typeid[shader] ]
            return null

        # local size for compute stage. fixed at 16x16 — matches the
        # canvas_sdf.comp prototype. could be made per-shader configurable
        # via a class field if other compute shaders need different sizes.
        if [ stage == ShaderStage.compute ]
            result = '{result}layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;\n\n'


        # UBO from mutable members
        ubo_name: type.ident
        result = '{result}layout(set = 0, binding = 0) uniform {ubo_name} {{\n'
        scan: Au_t [ type ]
        while [ scan != typeid[ shader ] ]
            for [ i: 0, i < scan.members.count, i += 1 ]
                mem: scan.members.origin[i]
                if [ !is_uniform_field[ mem ] ]
                    continue
                gtype: glsl_type_name[ mem.src ]
                if [ !gtype ]
                    continue
                result = '{result}    {gtype} {mem.ident};\n'
            scan = scan.context
        
        result = '{result}}} ubo;\n\n'

        # attribs: samplers, vertex i/o, fragment i/o
        binding:      i32 [ 0 ]
        vert_loc_in:  i32 [ 0 ]
        vert_loc_out: i32 [ 0 ]
        frag_loc_in:  i32 [ 0 ]
        frag_loc_out: i32 [ 0 ]
        scan = type

        while [ scan != typeid[ shader ] ]
            for [ i: 0, i < scan.members.count, i += 1 ]
                mem: Au_t[ scan.members.origin[i] ]
                if [ mem.member_type != 4 ]
                    continue
                if [ !(mem.traits & (1 << 56)) ] # AU_TRAIT_IS_ATTRIB
                    continue
                val: Au [ mem.value ]
                if [ !mem.value ]
                    continue
                
                if [ val inherits LayoutBinding ]
                    lb: LayoutBinding[val]
                    is_cube: lb.id == 9
                    stype: (is_cube) ? "samplerCube" : "sampler2D"
                    if [ lb.count > 1 ]
                        result = '{result}layout(set = 1, binding = {binding}) uniform {stype} {mem.ident}[{lb.count}];\n'
                    el
                        result = '{result}layout(set = 1, binding = {binding}) uniform {stype} {mem.ident};\n'
                    binding += 1

                el [ val inherits StorageImage ]
                    si: StorageImage[val]
                    # GLSL format qualifier from the meta type. only the formats
                    # we actually use are mapped; extend as needed.
                    img_fmt: (si.format == typeid[ f32 ]) ? "r32f" :
                             (si.format == typeid[ rgbaf ]) ? "rgba32f" : "r32f"
                    result = '{result}layout({img_fmt}, set = 1, binding = {binding}) writeonly uniform image2D {mem.ident};\n'
                    binding += 1

                el [ val inherits StorageBuffer ]
                    result = '{result}layout(std430, set = 1, binding = {binding}) readonly buffer {mem.ident}_t {{ vec4 {mem.ident}[]; }};\n'
                    binding += 1

                el [ val inherits VertexInput && stage == ShaderStage.vertex ]
                    vi: (val to VertexInput)
                    gtype: glsl_type_name[ vi.type ]
                    if [ gtype ]
                        result = '{result}layout(location = {vert_loc_in}) in {gtype} {mem.ident};\n'
                    vert_loc_in += 1

                el [ val inherits VertexOutput && stage == ShaderStage.vertex ]
                    vo: (val to VertexOutput)
                    gtype: glsl_type_name[ vo.type ]
                    if [ gtype ]
                        result = '{result}layout(location = {vert_loc_out}) out {gtype} {mem.ident};\n'
                    vert_loc_out += 1

                el [ val inherits VertexOutput && stage == ShaderStage.fragment ]
                    vo: (val to VertexOutput)
                    gtype: glsl_type_name[ vo.type ]
                    if [ gtype ]
                        result = '{result}layout(location = {frag_loc_in}) in {gtype} {mem.ident};\n'
                    frag_loc_in += 1

                el [ val inherits FragmentInput && stage == ShaderStage.fragment ]
                    fi: (val to FragmentInput)
                    gtype: glsl_type_name[ fi.type ]
                    if [ gtype ]
                        result = '{result}layout(location = {frag_loc_in}) in {gtype} {mem.ident};\n'
                    frag_loc_in += 1

                el [ val inherits FragmentOutput && stage == ShaderStage.fragment ]
                    fo: (val to FragmentOutput)
                    gtype: glsl_type_name[ fo.type ]
                    if [ gtype ]
                        result = '{result}layout(location = {frag_loc_out}) out {gtype} {mem.ident};\n'
                    frag_loc_out += 1
                
            scan = scan.context


        scan = type
        while [ scan != typeid[ shader ] ]
            for [ i: 0, i < scan.members.count, i += 1 ]
                method: Au_t [ scan.members.origin[i] ]
                if [ method.member_type != 5 ]
                    continue
                if [ !method.src || !method.meta.a ]
                    continue
                if [ strcmp[ method.ident, "fragment" ] == 0 || strcmp[ method.ident, "vertex" ] == 0 || strcmp[ method.ident, "compute" ] == 0 ]
                    continue
                rtype : Au_t [ method.meta.a ]
                ret_name: glsl_type_name[ rtype ]
                if [ !ret_name ]
                    ret_name = "void"

                # build arg list from method.args (skip first arg which is self)
                arg_str: ''
                for [ j: 1, j < method.args.count, j += 1 ]
                    arg: Au_t [ method.args.origin[j] ]
                    atype: glsl_type_name[ arg.src ]
                    if [ !atype ]
                        continue
                    if [ j > 1 ]
                        arg_str = '{arg_str}, '
                    arg_str = '{arg_str}{atype} {arg.ident}'

                # call method with defaults (null) to get body
                glsl: GLSL Au Au.method_call[ method, null ]

                #l : strlen[ glsl.body ]
                l : strlen[glsl.body]
                expect l, 'body not set on function {method.ident}'

                # emit function
                result = '{result}{ret_name} {method.ident}({arg_str}) {{\n{glsl.body}\n}}\n\n'
            
            scan = scan.context
                    
        # emit void main() from the stage entry point
        main_result: GLSL Au [ Au.method_call[ main_member, null ] ]
        if [ main_result ]
            result = '{result}void main() {{\n{main_result.body}\n}}\n'
        return result

    func generate_shaders [ ]
        type:   Au_t [ typeid[ a ] ]
        paths:  local path [3] [ vert, frag, comp ]
        stages: local i32  [3] [ 0, 1, 2 ]

        for [ i: 0, i < 3, i += 1 ]
            p: path paths[i]
            if [ !p ]
                continue
            stage: (i == 0) ? ShaderStage.vertex : (i == 1) ? ShaderStage.fragment : ShaderStage.compute
            src: glsl_header[ stage ]
            if [ !src ]
                continue
            # only write the .vert/.frag/.comp if its content has actually
            # changed. a redundant rewrite bumps mtime and forces an
            # unnecessary glslangValidator recompile (which used to race
            # between concurrent shader instances of the same type) — but
            # if we just blanket-skip on existence, the user editing the
            # GLSL inside the .ag file silently has no effect because the
            # stale on-disk shader keeps loading. compare byte-for-byte
            # and only skip when truly identical.
            should_write : bool true
            if [ p.exists[] ]
                rfp : fopen[ p, "rb" ]
                if [ rfp ]
                    fseek[ rfp, 0, SEEK_END ]
                    flen : ftell[ rfp ]
                    rewind[ rfp ]
                    sl : i64 strlen[ src.chars ]
                    if [ flen == sl ]
                        existing : malloc[ flen ]
                        fread[ existing, 1, flen, rfp ]
                        if [ memcmp[ existing, src.chars, flen ] == 0 ]
                            should_write = false
                        free[ existing ]
                    fclose[ rfp ]
            if [ !should_write ]
                continue
            cwd : path.path_cwd[]
            p.parent_dir[].make_dir[]
            fp: fopen[ p, "w" ]
            if [ !fp ]
                printf[ "failed to write shader: %s\n", p.chars ]
                continue
            fputs[ src, fp ]
            fclose[ fp ]

    func uniform_transfer [ data2: ref u8, type: Au_t ] -> i64
        instance:a
        expect instance inherits shader, "shader instance not provided"
        src: ref u8 [ instance ]
##
        if [strcmp[type.ident, "Earth"] == 0]
            fdata: ref f32 [ ref data2[0] ]
            memcpy[ fdata, ref src[84], 64 ]
            m4 : ref mat4f [ fdata ] 
            return 192
##
        index: num [ 0 ]
        
        #printf[ "uniform_transfer: type=%s members.count=%i\n",
        #    type.ident, type.members.count ]
        for [ m: 0, m < type.members.count, m += 1 ]
            mem: Au_t [ type.members.origin[m] ]
            # use the same filter as uniform_size / glsl_header so the buffer
            # layout (offsets and contents) matches the GLSL UBO declaration.
            if [ is_uniform_field[ mem ] ]
                type_size: mem.src.typesize
                if [ (mem.src.traits & (1 << 8)) || (mem.src.traits & (1 << 0)) ] # struct or primitive are both inlay
                    memcpy[ ref data2[index], ref src[mem.offset], type_size ]
                el
                    dst_ptr: (ref src[mem.offset] to ref handle)
                    memcpy[ ref data2[index], dst_ptr, type_size ] # we can also call the vdata on this one, however i dont think we'll ever want to do this in Au lol. we kinda did for a vector concept but i dont like it!
                index += type_size
        return index

    intern func reload [ ] -> bool
        paths:  array path [ vert, frag, comp ]
        values: new VkShaderModule[3] [ vk_vert, vk_frag, vk_comp ]
        found:      false
        recompiled: false
        for [ i: 0, i < 3, i += 1 ]
            shader_file: paths[i]
            if [ !shader_file ]
                continue
            input: path '{shader_file}'
            if [ !input.exists[] ]
                continue
            spv_file: path '{shader_file}.spv'
            found = true
            source_stat: struct stat
            spv_stat:    struct stat
            src_exists: stat[ input, ref source_stat ] == 0
            spv_exists: stat[ spv_file, ref spv_stat ] == 0
            ifdef [ linux ]
                make_spv: !spv_exists || source_stat.st_mtim.tv_sec > spv_stat.st_mtim.tv_sec
            ifdef [ apple ]
                make_spv: !spv_exists || source_stat.st_mtimespec.tv_sec > spv_stat.st_mtimespec.tv_sec

            if [ make_spv ]
                cmd: 'glslangValidator -V100 --target-env vulkan1.2 {shader_file} -o {spv_file}'
                puts 'compiling shader: {cmd}'
                result: system[ cmd ]
                if [ result != 0 ]
                    puts 'shader compilation failed for: {shader_file}'
                    exit[ 1 ]
                recompiled = true
            el
                if [ values[i] ]
                    continue
            fp: fopen[ spv_file.chars, "rb" ]
            if [ !fp ]
                puts 'failed to open SPIR-V file: {spv_file}'
                exit[ 1 ]
            fseek[ fp, 0, SEEK_END ]
            length: ftell[ fp ]
            rewind[ fp ]
            spirv: malloc[ length ]
            if [ !spirv ]
                fclose[ fp ]
                puts 'failed to allocate memory for SPIR-V'
                exit[ 1 ]
            fread[ spirv, 1, length, fp ]
            fclose[ fp ]
            createInfo: VkShaderModuleCreateInfo [
                sType:    VK_STRUCTURE_TYPE_SHADER_MODULE_CREATE_INFO,
                codeSize: length,
                pCode:    spirv
            ]
            mod: VkShaderModule
            vkResult: vkCreateShaderModule[ vk.device, createInfo, null, ref mod ]
            if [ vkResult != VK_SUCCESS ]
                puts 'failed to create vulkan shader module: {spv_file}'
                free[ spirv ]
                exit[ 1 ]
            values[i] = mod
            free[ spirv ]

        vk_vert = values[0]
        vk_frag = values[1]
        vk_comp = values[2]

        expect found, 'shader not found: {name}'
        return recompiled

    func init [ ]
        if [ !vk ]
            return
        if [ !name ]
            ty: typeid[ a ]
            expect ty != typeid[ shader ], "shader requires a subclass"
            name = ty.ident
        vert = 'shaders/{name}.vert'
        frag = 'shaders/{name}.frag'
        comp = 'shaders/{name}.comp'
        generate_shaders[ ]
        reload[ ]

    func dealloc [ ]
        vkDestroyShaderModule[ vk.device, vk_vert, null ]
        vkDestroyShaderModule[ vk.device, vk_frag, null ]
        vkDestroyShaderModule[ vk.device, vk_comp, null ]


shader UVQuad
    mutable model : mat4f
    mutable view  : mat4f
    mutable proj  : mat4f

    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]
    #attrib Surface [ color ] : 1, rgba8

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func fragment [] -> GLSL none {
        fragColor = texture(color, v_uv);
    }


shader UVReduce
    mutable model : mat4f
    mutable view  : mat4f
    mutable proj  : mat4f
    attrib  color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func fragment [] -> GLSL none {
        vec2 tsize = textureSize(color, 0);
        vec2 texel = 1.0 / vec2(tsize);
        vec4 sum   = vec4(0.0);
        for (int dy = -1; dy <= 2; dy++)
            for (int dx = -1; dx <= 2; dx++) {{
                vec2 offset = vec2(dx, dy) * texel;
                sum += texture(color, v_uv + offset);
            }}
        fragColor = sum * (1.0 / 16.0);
    }


shader Env
    mutable view : mat4f.identity[]
    mutable proj : mat4f.identity[]
    mutable roughness_samples : vec2f
    attrib color: LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format:typeid[ rgbaf ] ]

    attrib in_pos   : VertexInput    [ type:typeid[ vec3f ] ]
    attrib in_uv    : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv     : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib v_dir    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib outColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func vertex [] -> GLSL none {
        v_uv        = in_uv;
        v_dir       = in_pos;
        gl_Position = ubo.proj * ubo.view * vec4(in_pos, 1.0);
    }

    func fragment [] -> GLSL none {
        const float PI = 3.14159265359;
        vec3  R  = normalize(v_dir);
        vec2  eq = vec2(0.5 + atan(R.z, R.x) / (2.0  * PI),
                              acos(R.y)      /         PI);
        outColor = texture(color, eq);
    }


shader Convolve
    mutable env : mat4f
    mutable view : mat4f
    mutable proj : mat4f
    mutable roughness_samples : vec2f
    attrib environment: LayoutBinding [ type:typeid[ Surface ], id:Surface.environment, count:1, format:typeid[ rgbaf ] ]

    attrib in_pos   : VertexInput    [ type:typeid[ vec3f ] ]
    attrib in_uv    : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_dir    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib outColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func vertex [] -> GLSL none {
        vec3 direction = in_pos;
        v_dir        = (ubo.env * vec4(direction, 1.0)).xyz;
        gl_Position  = ubo.proj * ubo.view * vec4(in_pos, 1.0);
    }

    func radicalInverse_VdC [ bits: u32 ] -> GLSL float {
        bits = (bits << 16u) | (bits >> 16u);
        bits = ((bits & 0x55555555u) << 1u) | ((bits & 0xAAAAAAAAu) >> 1u);
        bits = ((bits & 0x33333333u) << 2u) | ((bits & 0xCCCCCCCCu) >> 2u);
        bits = ((bits & 0x0F0F0F0Fu) << 4u) | ((bits & 0xF0F0F0F0u) >> 4u);
        bits = ((bits & 0x00FF00FFu) << 8u) | ((bits & 0xFF00FF00u) >> 8u);
        return float(bits) * 2.3283064365386963e-10;
    }

    func sampleHammersley [ i: u32, numSamples: i32 ] -> GLSL vec2f {
        float invNumSamples = 1.0 / float(numSamples);
        return vec2(float(i) * invNumSamples, radicalInverse_VdC(i));
    }

    func sampleGGX [ u1: float, u2: float, roughness: float ] -> GLSL vec3f {
        float alpha = roughness * roughness;
        float cosTheta = sqrt((1.0 - u2) / (1.0 + (alpha*alpha - 1.0) * u2));
        float sinTheta = sqrt(1.0 - cosTheta*cosTheta);
        float phi = 6.2831853 * u1;
        return vec3(sinTheta * cos(phi), sinTheta * sin(phi), cosTheta);
    }

    func ndfGGX [ cosLh: float, roughness: float ] -> GLSL float {
        float alpha = roughness * roughness;
        float alphaSq = alpha * alpha;
        float denom = (cosLh * cosLh) * (alphaSq - 1.0) + 1.0;
        return alphaSq / (3.14159265359 * denom * denom);
    }

    func computeBasisVectors [ N: vec3f, S: vec3f, T: vec3f ] -> GLSL none {
        T = cross(N, vec3(0.0, 1.0, 0.0));
        T = mix(cross(N, vec3(1.0, 0.0, 0.0)), T, step(0.00001, dot(T, T)));
        T = normalize(T);
        S = normalize(cross(N, T));
    }

    func tangentToWorld [ v: vec3f, N: vec3f, S: vec3f, T: vec3f ] -> GLSL vec3f {
        return S * v.x + T * v.y + N * v.z;
    }

    func prefilterEnvMap [ R: vec3f, roughness: float, numSamples: i32 ] -> GLSL vec3f {
        vec3 N = R;
        vec3 Lo = N;
        vec3 S, T;
        computeBasisVectors(N, S, T);
        vec3 color = vec3(0.0);
        float weight = 0.0;
        vec2 envMapSize = vec2(textureSize(environment, 0));
        float wt = 4.0 * 3.14159265359 / (6.0 * envMapSize.x * envMapSize.y);
        for (uint i = 0; i < uint(numSamples); ++i) {{
            vec2 u = sampleHammersley(i, numSamples);
            vec3 Lh = tangentToWorld(sampleGGX(u.x, u.y, roughness), N, S, T);
            vec3 Li = 2.0 * dot(Lo, Lh) * Lh - Lo;
            float cosLi = dot(N, Li);
            if (cosLi > 0.0) {{
                float cosLh = max(dot(N, Lh), 0.0);
                float pdf = ndfGGX(cosLh, roughness) * cosLh / max(4.0 * dot(Lh, Lo), 0.001);
                float ws = 1.0 / (float(numSamples) * pdf);
                float mipLevel = clamp(0.5 * log2(ws / wt), 0.0, 7);
                color += textureLod(environment, Li, mipLevel).rgb * cosLi;
                weight += cosLi;
            }}
        }}
        return (weight > 0.00001) ? (color / weight) : vec3(0.0);
    }

    func fragment [] -> GLSL none {
        vec3  R          = normalize(v_dir);
        float roughness  = ubo.roughness_samples.x * ubo.roughness_samples.x;
        int   numSamples = int(ubo.roughness_samples.y);
        outColor = (roughness < 0.01)
            ? texture(environment, R)
            : vec4(prefilterEnvMap(R, roughness, numSamples), 1.0);
    }




# ---- draw mode enum (matches fragment shader) ----
enum DrawMode
    solid       : 0
    linear_grad : 1
    radial_grad : 2
    conic_grad  : 3
    text        : 4
    image       : 5
    sdf_path    : 6
    image_r     : 7

# ---- path command tags ----
enum path_cmd
    move    : 0
    line    : 1
    quad    : 2
    cubic   : 3
    arc     : 4
    close   : 5

# ---- gradient types ----
enum GradientType
    none    : 0
    linear  : 1
    radial  : 2
    conic   : 3

# ---- GPU shader for UI rendering ----
# members become uniforms, name maps to shaders/CanvasUI.vert/.frag

enum CanvasUISurface
    atlas: 0
    image: 1


# CanvasUISurface enum extension for storage bindings used by the SDF
# compute pipeline. these IDs are not used by the named-sampler loop in
# Surface_resources (the storage path looks them up by attrib name in the
# samplers map directly), so they only need to be unique within the enum.
enum CanvasSDFSurface
    edges:   0
    sdf_out: 1


enum BlurPair
    low:  0
    high: 1


# Compute shader that builds an SDF from a list of edges. ported from
# foundry/shaders.bak/canvas/canvas_sdf.comp with the push_constant block
# replaced by UBO mutables (silver doesn't currently support push consts)
# and the bindings expressed via Silver's StorageBuffer/StorageImage attribs.
#
# Workgroup size is 16x16. Caller must dispatch ceil(tw/16) x ceil(th/16) x 1.
shader CanvasSDFCompute
    # UBO params (was push constant in the original .comp file)
    mutable wx     : f32
    mutable wy     : f32
    mutable ww     : f32
    mutable wh     : f32
    mutable tw     : i32
    mutable th     : i32
    mutable ne     : i32
    mutable spread : f32

    # storage buffer for edges (vec4 each: x0, y0, x1, y1)
    attrib  edges    : StorageBuffer [
        type:typeid[ CanvasSDFSurface ], id: CanvasSDFSurface.edges,   count:1, format:typeid[ vec4f ]
    ]
    # storage image for SDF output (R32F)
    attrib  sdf_out  : StorageImage  [
        type:typeid[ CanvasSDFSurface ], id: CanvasSDFSurface.sdf_out, count:1, format:typeid[ f32 ]
    ]

    func compute [] -> GLSL none {
        ivec2 gid = ivec2(gl_GlobalInvocationID.xy);
        if (gid.x >= ubo.tw || gid.y >= ubo.th) return;

        float sx = ubo.ww / float(ubo.tw);
        float sy = ubo.wh / float(ubo.th);
        float px = ubo.wx + (float(gid.x) + 0.5) * sx;
        float py = ubo.wy + (float(gid.y) + 0.5) * sy;
        vec2  pt = vec2(px, py);

        // min distance to any edge
        float md = 999999.0;
        for (int i = 0; i < ubo.ne; i++) {{
            vec2 a = edges[i].xy;
            vec2 b = edges[i].zw;
            vec2 ab = b - a;
            vec2 ap = pt - a;
            float t = clamp(dot(ap, ab) / max(dot(ab, ab), 1e-12), 0.0, 1.0);
            vec2 closest = a + t * ab;
            md = min(md, length(pt - closest));
        }}

        // winding number for inside/outside
        int wn = 0;
        for (int i = 0; i < ubo.ne; i++) {{
            vec2 a = edges[i].xy;
            vec2 b = edges[i].zw;
            if (a.y <= py) {{
                if (b.y > py) {{
                    float c = (b.x - a.x) * (py - a.y) - (px - a.x) * (b.y - a.y);
                    if (c > 0.0) wn++;
                }}
            }} else {{
                if (b.y <= py) {{
                    float c = (b.x - a.x) * (py - a.y) - (px - a.x) * (b.y - a.y);
                    if (c < 0.0) wn--;
                }}
            }}
        }}

        md = min(md, ubo.spread);
        float sdf = (wn != 0) ? -md : md;

        imageStore(sdf_out, gid, vec4(sdf, 0.0, 0.0, 0.0));
    }


shader CanvasUI
    # vec4s declared first so silver's packed buffer layout matches GLSL
    # std140 alignment. vec2f viewport is last so it lands at the end
    # without upsetting the vec4 16-byte alignment of every other field.
    mutable rect       : vec4f
    mutable radii      : vec4f
    mutable fill_color : vec4f
    mutable stroke_color : vec4f
    mutable params     : vec4f     # stroke_width, opacity, blur, mode
    mutable grad0      : vec4f     # Gradient endpoints / tex rect
    mutable grad_c0    : vec4f     # Gradient stop color 0
    mutable grad_c1    : vec4f     # Gradient stop color 1
    # stroke options: (join, cap, miter_limit, reserved)
    # join values match silver's Join enum: 0=none, 1=miter (square),
    # 2=round, 3=bevel — only miter vs round affect the rect SDF outer
    # corner shape; cap and miter_limit are for path strokes (TODO).
    mutable stroke_opts : vec4f
    # 2D affine transform packed as 2 vec4s (avoid std140 mat3 padding):
    #   xform_row0 = (ma, mb, mc, md)  -- the 2x2 linear part [ma mb; mc md]
    #   xform_row1 = (tx, ty, 0, 0)    -- translation
    mutable xform_row0 : vec4f
    mutable xform_row1 : vec4f
    mutable inner_glow_color   : vec4f
    mutable inner_shadow_color : vec4f
    mutable stroke_shadow_color: vec4f
    mutable outer_glow_color   : vec4f
    mutable outer_shadow_color : vec4f
    # x = inner_glow_px, y = outer_glow_px, z = decay_k, w = inner_shadow_px
    mutable glow_params   : vec4f
    # x = outer_shadow_px, y = hue_shift (deg), z = sat_mul, w = val_mul
    mutable glow_params2  : vec4f
    # inner_ofs.xy, outer_shadow_ofs.zw — pixel offsets
    mutable glow_ofs      : vec4f
    mutable viewport      : vec2f
    mutable fill_offset   : f32
    mutable stroke_offset : f32
    attrib  atlas      : LayoutBinding [
        type:typeid[ CanvasUISurface ], id: CanvasUISurface.atlas, count:1, format:typeid[ u8 ]
    ]
    attrib  image      : LayoutBinding [
        type:typeid[ CanvasUISurface ], id: CanvasUISurface.image, count:1, format:typeid[ rgba8 ]
    ]

    attrib  a_pos      : VertexInput    [ type:typeid[ vec2f ] ]
    attrib  v_pos      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib  o_color    : FragmentOutput [ type:typeid[ vec4f ] ]

    # ---- HSV helpers (for colorize) ----
    func rgb2hsv [ c: vec3f ] -> GLSL vec3f {
        vec4 K = vec4(0.0, -1.0 / 3.0, 2.0 / 3.0, -1.0);
        vec4 p = mix(vec4(c.bg, K.wz), vec4(c.gb, K.xy), step(c.b, c.g));
        vec4 q = mix(vec4(p.xyw, c.r), vec4(c.r, p.yzx), step(p.x, c.r));
        float d = q.x - min(q.w, q.y);
        float e = 1.0e-10;
        return vec3(abs(q.z + (q.w - q.y) / (6.0 * d + e)), d / (q.x + e), q.x);
    }

    func hsv2rgb [ c: vec3f ] -> GLSL vec3f {
        vec4 K = vec4(1.0, 2.0 / 3.0, 1.0 / 3.0, 3.0);
        vec3 p = abs(fract(c.xxx + K.xyz) * 6.0 - K.www);
        return c.z * mix(K.xxx, clamp(p - K.xxx, 0.0, 1.0), c.y);
    }

    # ---- per-corner rounded rect SDF ----
    func sdf_rounded_rect [ p: vec2f, center: vec2f, half_size: vec2f, r: vec4f ] -> GLSL float {
        vec2 q = p - center;
        float cr = (q.x >= 0.0)
            ? ((q.y >= 0.0) ? r.z : r.y)
            : ((q.y >= 0.0) ? r.w : r.x);
        cr = min(cr, min(half_size.x, half_size.y));
        vec2 d = abs(q) - half_size + vec2(cr);
        return min(max(d.x, d.y), 0.0) + length(max(d, 0.0)) - cr;
    }

    # smoothed rounded-rect distance used for inner glow.
    # the standard SDF has a 45° gradient kink inside the "core rect"
    # because max(d.x, d.y) picks one axis or the other. That kink shows
    # up in the inner-glow iso-contours as a visible wedge along the
    # corner diagonals. Replacing max with a quadratic soft-max smooths
    # the iso-contours without moving the zero crossing meaningfully.
    func smax [ a: f32, b: f32, k: f32 ] -> GLSL float {
        float h = clamp(0.5 + 0.5*(b-a)/k, 0.0, 1.0);
        return mix(a, b, h) + k*h*(1.0-h);
    }

    func sdf_rounded_rect_glow [ p: vec2f, center: vec2f, half_size: vec2f, r: vec4f, soften: f32 ] -> GLSL float {
        vec2 q = p - center;
        float cr = (q.x >= 0.0)
            ? ((q.y >= 0.0) ? r.z : r.y)
            : ((q.y >= 0.0) ? r.w : r.x);
        cr = min(cr, min(half_size.x, half_size.y));
        vec2 d = abs(q) - half_size + vec2(cr);
        // soft-max for inside smoothness; scales with corner radius AND
        // the caller-provided `soften` (typically the glow pixel radius).
        // wider glow → smoother iso-contours; zero crossing stays accurate.
        float k = max(cr * 0.5, soften * 0.5);
        k = max(k, 1.0);
        return min(smax(d.x, d.y, k), 0.0) + length(max(d, 0.0)) - cr;
    }

    # ---- gradient evaluation ----
    func eval_gradient [ p: vec2f, mode: f32 ] -> GLSL vec4f {
        vec2  g0     = ubo.grad0.xy;
        vec2  g1     = ubo.grad0.zw;
        float t;
        if (mode == 1.0) {{
            vec2  d      = g1 - g0;
            float len_sq = dot(d, d);
            t = (len_sq > 0.0001) ? clamp(dot(p - g0, d) / len_sq, 0.0, 1.0) : 0.0;
        }} else if (mode == 2.0) {{
            float dist = length(p - g0);
            float span = g1.y - g1.x;
            t = (span > 0.0001) ? clamp((dist - g1.x) / span, 0.0, 1.0) : 0.0;
        }} else {{
            vec2  d     = p - g0;
            float angle = atan(d.y, d.x) - g1.x;
            if (angle < 0.0) angle += 6.2831853;
            t = clamp(angle / 6.2831853, 0.0, 1.0);
        }}
        return mix(ubo.grad_c0, ubo.grad_c1, t);
    }

    # ---- vertex shader ----
    func vertex [] -> GLSL none {
        // local-space rect (no transform yet)
        // pad = 1px AA + blur (params.z) + half stroke width (params.x)
        // + max(0, fill_offset) so outward-expanded fill stays inside the quad
        // + max(0, stroke_offset) so an outward-shifted stroke band isn't clipped.
        float pad      = 1.0 + ubo.params.z + ubo.params.x * 0.5
                             + max(ubo.fill_offset,   0.0)
                             + max(ubo.stroke_offset, 0.0);
        // extra pad for outer effects: radial glow reach + shadow reach + shadow offset magnitude.
        float ext_pad  = max(ubo.glow_params.y,
                             ubo.glow_params2.x + max(abs(ubo.glow_ofs.z),
                                                      abs(ubo.glow_ofs.w)));
        vec2  lo_local = ubo.rect.xy - vec2(pad + ext_pad);
        vec2  hi_local = ubo.rect.xy + ubo.rect.zw + vec2(pad + ext_pad);

        // 2D affine: world = mat2(ma,mc, mb,md) * local + (tx,ty)
        mat2 M = mat2(ubo.xform_row0.x, ubo.xform_row0.z,
                      ubo.xform_row0.y, ubo.xform_row0.w);
        vec2 T = ubo.xform_row1.xy;

        // transform all 4 local corners to world space, then take their AABB.
        // this is the post-transform bounding box that the rasterizer needs
        // to cover so rotated/scaled rects don't get clipped.
        vec2 c0 = M * vec2(lo_local.x, lo_local.y) + T;
        vec2 c1 = M * vec2(hi_local.x, lo_local.y) + T;
        vec2 c2 = M * vec2(lo_local.x, hi_local.y) + T;
        vec2 c3 = M * vec2(hi_local.x, hi_local.y) + T;
        vec2 lo_world = min(min(c0, c1), min(c2, c3));
        vec2 hi_world = max(max(c0, c1), max(c2, c3));

        // pick this vertex's corner of the world-space AABB.
        // a_pos comes from uv-quad2 in [-1,1]; remap to [0,1] for mix.
        vec2 t   = a_pos * 0.5 + 0.5;
        vec2 wpx = mix(lo_world, hi_world, t);
        v_pos    = wpx;
        vec2 ndc = (wpx / ubo.viewport) * 2.0 - 1.0;
        gl_Position = vec4(ndc, 0.0, 1.0);
    }

    # ---- fragment shader ----
    func fragment [] -> GLSL none {
        #o_color = vec4(0.0, 0.0, 1.0, 1.0);
        #return;

        float mode         = ubo.params.w;
        float stroke_width = ubo.params.x;
        float opacity      = ubo.params.y;
        float blur         = ubo.params.z;

        // inverse-transform v_pos (world space, from vertex stage) back to
        // local space, where ubo.rect lives. for an affine M*p + T, the
        // inverse is M^-1 * (p - T). 2x2 inverse: 1/det * [d -b; -c a].
        // guard against zero determinant (uninitialized transform) to
        // avoid NaN fragments — fall back to identity.
        mat2 M    = mat2(ubo.xform_row0.x, ubo.xform_row0.z,
                         ubo.xform_row0.y, ubo.xform_row0.w);
        vec2 T    = ubo.xform_row1.xy;
        float det = M[0].x * M[1].y - M[0].y * M[1].x;
        mat2 Minv;
        if (abs(det) < 1e-6) {{
            Minv = mat2(1.0, 0.0, 0.0, 1.0);
        }} else {{
            Minv = mat2( M[1].y, -M[0].y,
                        -M[1].x,  M[0].x) / det;
        }}
        vec2 lpos = Minv * (v_pos - T);

        vec2  center       = ubo.rect.xy + ubo.rect.zw * 0.5;
        vec2  half_size    = ubo.rect.zw * 0.5;
        float dist         = sdf_rounded_rect(lpos, center, half_size, ubo.radii);

        // text: sample glyph atlas — DEBUG: visualize UV+atlas separately.
        //   red   = uv.x (atlas UV after grad0 mapping)
        //   green = uv.y
        //   blue  = atlas sample (raw, no fill_color)
        // if you see a red/green gradient with no blue, the UVs are being
        // computed but the atlas binding is the 1x1 dummy (sampling 1.0
        // would make blue = 1.0 instead of 0.0). if it's solid (no gradient)
        // the UV calc is degenerate. if blue varies with the glyph shape,
        // the atlas IS bound and rasterized.
        if (mode == 4.0) {{
            vec2  uv = (lpos - ubo.rect.xy) / ubo.rect.zw;
            uv       = mix(ubo.grad0.xy, ubo.grad0.zw, uv);
            float a  = texture(atlas, uv).r;
            o_color  = vec4(uv.x, uv.y, a, 1.0);
            return;
        }}

        // image: sample texture, clip to rounded rect
        if (mode == 5.0) {{
            vec2 uv    = (lpos - ubo.rect.xy) / ubo.rect.zw;
            uv         = mix(ubo.grad0.xy, ubo.grad0.zw, uv);
            vec4 texel = texture(image, uv);
            float aa   = 1.0 - smoothstep(-0.5, 0.5, dist);
            o_color    = texel * aa * opacity;
            return;
        }}

        // image_r: sample R8 texture as grayscale (broadcast .r)
        if (mode == 7.0) {{
            vec2 uv  = (lpos - ubo.rect.xy) / ubo.rect.zw;
            uv       = mix(ubo.grad0.xy, ubo.grad0.zw, uv);
            float l  = texture(image, uv).r;
            float aa = 1.0 - smoothstep(-0.5, 0.5, dist);
            o_color  = vec4(l, l, l, 1.0) * aa * opacity;
            return;
        }}

        // SDF path: sample R32F distance field. raw signed distance in
        // world pixels, written either by the CPU sdf_generate path or by
        // the CanvasSDFCompute compute shader. negative = inside.
        if (mode == 6.0) {{
            vec2  uv     = (lpos - ubo.rect.xy) / ubo.rect.zw;
            uv           = mix(ubo.grad0.xy, ubo.grad0.zw, uv);
            if (uv.x < 0.0 || uv.x > 1.0 || uv.y < 0.0 || uv.y > 1.0) {{
                o_color = vec4(0.0);
                return;
            }}
            float dist_p = texture(image, uv).r;

            // screen-space AA — fwidth gives ~1 pixel either side of the
            // edge regardless of transform / zoom. blur extends it.
            float wp     = fwidth(dist_p) + blur;
            float half_w = stroke_width * 0.5;

            // fill: 1 wherever dist_p is negative (inside the shape).
            // offset biases the SDF: positive = expand outward.
            float fill_cov   = 1.0 - smoothstep(-wp, wp, dist_p - ubo.fill_offset);
            // stroke band: width stroke_width centered on the path edge
            float stroke_cov = (stroke_width > 0.0)
                ? (1.0 - smoothstep(-wp, wp, abs(dist_p - ubo.stroke_offset) - half_w))
                : 0.0;

            vec4 fill_p   = vec4(ubo.fill_color.rgb * ubo.fill_color.a * fill_cov,
                                 ubo.fill_color.a   * fill_cov);
            vec4 stroke_p = vec4(ubo.stroke_color.rgb * ubo.stroke_color.a * stroke_cov,
                                 ubo.stroke_color.a   * stroke_cov);
            float inner_px = ubo.glow_params.x;
            float outer_px = ubo.glow_params.y;
            float K        = ubo.glow_params.z;
            vec4 outer_p = vec4(0.0);
            if (outer_px > 0.0 && dist_p > 0.0) {{
                float t = clamp(dist_p / outer_px, 0.0, 1.0);
                float a = pow(1.0 - t, K) * ubo.outer_glow_color.a;
                outer_p = vec4(ubo.outer_glow_color.rgb * a, a);
            }}
            vec4 inner_p = vec4(0.0);
            if (inner_px > 0.0 && dist_p < 0.0) {{
                float t = clamp(-dist_p / inner_px, 0.0, 1.0);
                float a = pow(1.0 - t, K) * ubo.inner_glow_color.a;
                inner_p = vec4(ubo.inner_glow_color.rgb * a, a);
            }}
            vec4 shadow_p = vec4(0.0);
            float shadow_px = ubo.glow_params.w;
            if (shadow_px > 0.0 && dist_p < 0.0) {{
                float t = clamp(-dist_p / shadow_px, 0.0, 1.0);
                float a = pow(1.0 - t, K) * ubo.inner_shadow_color.a;
                shadow_p = vec4(ubo.inner_shadow_color.rgb * a, a);
            }}
            vec4 c = outer_p;
            c = fill_p   + c        * (1.0 - fill_p.a);
            c = shadow_p + c        * (1.0 - shadow_p.a);
            c = inner_p  + c        * (1.0 - inner_p.a);
            c = stroke_p + c        * (1.0 - stroke_p.a);
            o_color = c * opacity;
            if (o_color.a > 0.0 &&
                (ubo.glow_params2.y != 0.0 || ubo.glow_params2.z != 1.0 || ubo.glow_params2.w != 1.0)) {{
                vec3 _rgb = o_color.rgb / max(o_color.a, 1.0e-6);
                vec3 _hsv = rgb2hsv(_rgb);
                _hsv.x = fract(_hsv.x + ubo.glow_params2.y / 360.0);
                _hsv.y = clamp(_hsv.y * ubo.glow_params2.z, 0.0, 1.0);
                _hsv.z = _hsv.z * ubo.glow_params2.w;
                o_color.rgb = hsv2rgb(_hsv) * o_color.a;
            }}
            //float _d = fract(sin(dot(gl_FragCoord.xy, vec2(12.9898, 78.233))) * 43758.5453) * 4.0;
            //o_color.rgb += vec3((_d - 0.5) / 255.0);
            return;
        }}

        // fill: solid or gradient
        vec4 fill = (mode >= 1.0 && mode <= 3.0)
            ? eval_gradient(lpos, mode)
            : ubo.fill_color;

        // screen-space AA: fwidth(dist) is how much dist changes between
        // adjacent screen fragments, so the smoothstep range stays ~1
        // pixel on each side of the edge regardless of any transform
        // (rotation/scale/zoom). blur extends the softening beyond that
        // base width for shadow/halo effects.
        float w = fwidth(dist) + blur;

        // combined fill + stroke in one pass:
        //   fill_cov   = 1 inside the shape shrunk inward by half-stroke
        //   stroke_cov = 1 in a band of width stroke_width centered on edge
        // when stroke_width == 0 the stroke band collapses, fill_cov uses
        // dist directly, and the result is the unstroked AA fill.
        //
        // stroke_opts.x is the join enum: 1 = miter (square outer corner),
        // others = round. for miter, recompute the stroke distance using
        // chebyshev (L-inf) so iso-contours past the edge are concentric
        // squares instead of rounded rects. fill always uses the rounded
        // sdf so corner radii still work.
        float half_w = stroke_width * 0.5;
        float dist_stroke = dist;
        if (ubo.stroke_opts.x == 1.0) {{
            vec2 d_local = abs(lpos - center) - half_size;
            dist_stroke  = max(d_local.x, d_local.y);
        }}
        // fill_offset biases the SDF inward (negative = expand outward);
        // stroke_offset shifts the stroke band similarly. stroke_cov gates on
        // stroke_width > 0 — otherwise smoothstep at dist=0 yields 0.5 and
        // draws a half-alpha edge band even with zero stroke.
        float fill_cov   = 1.0 - smoothstep(-w, w, dist - ubo.fill_offset + half_w);
        float stroke_cov = (stroke_width > 0.0)
            ? (1.0 - smoothstep(-w, w, abs(dist_stroke - ubo.stroke_offset) - half_w))
            : 0.0;

        // PRE-MULTIPLIED ALPHA: rgb pre-multiplied by coverage. composing
        // through multiple stages stays correct (no double-darkening).
        // stroke renders OVER fill via Porter-Duff "over": stroke + fill * (1 - stroke.a).
        // power-curve decay: I(t) = (1-t)^K. K=1 linear, K=4 steep drop.
        // zero at t=1, and near zero long before that — e.g. K=4 → 90% point = 0.0001.
        float inner_px  = ubo.glow_params.x;
        float outer_px  = ubo.glow_params.y;
        float K         = ubo.glow_params.z;
        float shadow_px = ubo.glow_params.w;
        // bevel side classification (top+left = lit, bottom+right = dark),
        // with a smoothstep band across the 45° diagonal so corners fade.
        vec2  q_rel   = abs(lpos - center) - half_size;
        float dy_r    = lpos.y - center.y;
        float dx_r    = lpos.x - center.x;
        float band    = max(max(inner_px, shadow_px) * 0.5, 1.0);
        float horiz_w = smoothstep(-band, band, q_rel.y - q_rel.x);
        float h_lit   = (dy_r < 0.0) ? 1.0 : 0.0;
        float v_lit   = (dx_r < 0.0) ? 1.0 : 0.0;
        float lit_side = mix(v_lit, h_lit, horiz_w);

        vec4 fill_p   = vec4(fill.rgb * fill.a * fill_cov, fill.a * fill_cov);
        // stroke color is beveled: lit edges use stroke_color, dark edges use
        // stroke_shadow_color. falls back to stroke_color if shadow not set.
        vec4 stroke_c = ubo.stroke_color;
        if (ubo.stroke_shadow_color.a > 0.001) {{
            stroke_c = mix(ubo.stroke_shadow_color, ubo.stroke_color, lit_side);
        }}
        vec4 stroke_p = vec4(stroke_c.rgb * stroke_c.a * stroke_cov,
                             stroke_c.a   * stroke_cov);
        // unified outer bevel: top+left = outer_glow, bottom+right = outer_shadow.
        // same lit_side classification as inner, applied outside the shape.
        // color + fade radius both interpolate smoothly across the 45° diagonal.
        float oshadow_px = ubo.glow_params2.x;
        vec4  outer_p    = vec4(0.0);
        if ((outer_px > 0.0 || oshadow_px > 0.0) && dist > 0.0) {{
            float effective_px = mix(oshadow_px, outer_px, lit_side);
            if (effective_px > 0.0) {{
                float t     = clamp(dist / effective_px, 0.0, 1.0);
                float a     = pow(1.0 - t, K);
                vec4  tint  = mix(ubo.outer_shadow_color, ubo.outer_glow_color, lit_side);
                float alpha = a * tint.a;
                outer_p     = vec4(tint.rgb * alpha, alpha);
            }}
        }}
        // unified inner bevel pass: blend tint + fade-radius by lit_side.
        vec4 bevel_p = vec4(0.0);
        if ((inner_px > 0.0 || shadow_px > 0.0) && dist <= 0.0) {{
            float smooth_px    = max(inner_px, shadow_px);
            float dist_g       = sdf_rounded_rect_glow(lpos, center, half_size, ubo.radii, smooth_px);
            float effective_px = mix(shadow_px, inner_px, lit_side);
            if (dist_g < 0.0 && effective_px > 0.0) {{
                float t     = clamp(-dist_g / effective_px, 0.0, 1.0);
                float a     = pow(1.0 - t, K);
                vec4  tint  = mix(ubo.inner_shadow_color, ubo.inner_glow_color, lit_side);
                float alpha = a * tint.a;
                bevel_p     = vec4(tint.rgb * alpha, alpha);
            }}
        }}
        // compose (back to front): outer bevel → fill → inner bevel → stroke
        vec4 c = outer_p;
        c = fill_p   + c * (1.0 - fill_p.a);
        c = bevel_p  + c * (1.0 - bevel_p.a);
        c = stroke_p + c * (1.0 - stroke_p.a);
        o_color = c * opacity;
        if (o_color.a > 0.0 &&
            (ubo.glow_params2.y != 0.0 || ubo.glow_params2.z != 1.0 || ubo.glow_params2.w != 1.0)) {{
            vec3 _rgb = o_color.rgb / max(o_color.a, 1.0e-6);
            vec3 _hsv = rgb2hsv(_rgb);
            _hsv.x = fract(_hsv.x + ubo.glow_params2.y / 360.0);
            _hsv.y = clamp(_hsv.y * ubo.glow_params2.z, 0.0, 1.0);
            _hsv.z = _hsv.z * ubo.glow_params2.w;
            o_color.rgb = hsv2rgb(_hsv) * o_color.a;
        }}
        // 8-bit quantization dither — breaks up banding on soft gradients.
        float _d = fract(sin(dot(gl_FragCoord.xy, vec2(12.9898, 78.233))) * 43758.5453) * 8.0;
        o_color.rgb += vec3((_d - 0.5) / 255.0) * c.xyz;
        #o_color = vec4(0.0, 1.0, 0.0, 1.0);
    }


# ---- text shader: instanced/batched glyph quads in one draw call ----
# canvas owns one Pipeline using this shader, with a custom vbo holding
# 6 vertices per glyph (two triangles, no index buffer). draw_text builds
# the vbo per call and a dedicated text_render renders it via its own
# render pass over the canvas's color attachment in a single vkCmdDraw.
shader CanvasText
    mutable text_color : vec4f
    mutable viewport : vec2f
    

    attrib  atlas    : LayoutBinding [
        type:typeid[ CanvasUISurface ], id: CanvasUISurface.atlas, count:1, format: typeid[ u8 ]
    ]
    attrib  a_pos    : VertexInput    [ type:typeid[ vec2f ] ]
    attrib  a_uv     : VertexInput    [ type:typeid[ vec2f ] ]
    attrib  v_uv     : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib  o_color  : FragmentOutput [ type:typeid[ vec4f ] ]

    func vertex [] -> GLSL none {
        v_uv = a_uv;
        vec2 ndc = (a_pos / ubo.viewport) * 2.0 - 1.0;
        gl_Position = vec4(ndc.x, ndc.y, 0.0, 1.0);
    }

    func fragment [] -> GLSL none {
        // straight-alpha output. paired with a SRC_ALPHA / ONE_MINUS_SRC_ALPHA
        // blend state on the text Pipeline (straight_alpha flag) so the
        // result composes as rgb*a + dst*(1-a). this looked best in testing.
        float a = texture(atlas, v_uv).r;
        //o_color = vec4(ubo.text_color.x, ubo.text_color.y, ubo.text_color.z, a);
        o_color = vec4(ubo.text_color.rgb, ubo.text_color.a * a);
    }


# ---- path point with optional control points ----

struct PathPt
    cmd : path_cmd
    x   : f32
    y   : f32
    cx1 : f32
    cy1 : f32
    cx2 : f32
    cy2 : f32


# ---- 2d affine transform [ a b tx ; c d ty ; 0 0 1 ] ----

struct affine
    ma: f32
    mb: f32
    mc: f32
    md: f32
    tx: f32
    ty: f32

    func apply_x [ px: f32, py: f32 ] -> f32
        return ma * px + mb * py + tx

    func apply_y [ px: f32, py: f32 ] -> f32
        return mc * px + md * py + ty


    static func identity [] -> affine
        return affine [ ma: 1.0, mb: 0.0, mc: 0.0, md: 1.0, tx: 0.0, ty: 0.0 ]


    func translate [ dx: f32, dy: f32 ] -> affine
        return affine [
            ma: ma, mb: mb, mc: mc, md: md,
            tx: tx + ma * dx + mb * dy,
            ty: ty + mc * dx + md * dy
        ]


    func scale [ s: f32 ] -> affine
        return affine [
            ma: ma * s, mb: mb * s,
            mc: mc * s, md: md * s,
            tx: tx, ty: ty
        ]


    func rotate [ radians: f32 ] -> affine
        cs : cos[ radians ]
        sn : sin[ radians ]
        return affine [
            ma: ma * cs + mb * sn,
            mb: mb * cs - ma * sn,
            mc: mc * cs + md * sn,
            md: md * cs - mc * sn,
            tx: tx, ty: ty
        ]


    func multiply [ q: affine ] -> affine

        return affine [
            ma: ma * q.ma + mb * q.mc,
            mb: ma * q.mb + mb * q.md,
            mc: mc * q.ma + md * q.mc,
            md: mc * q.mb + md * q.md,
            tx: ma * q.tx + mb * q.ty + tx,
            ty: mc * q.tx + md * q.ty + ty
        ]

# ---- path class ----
# Internally journals every move/line/curve op into `points`. The Canvas
# draw path keeps a snapshot of the previous draw's `points` plus its
# computed edge list AND bounding box — on the next draw, if the ops are
# byte-for-byte identical, we skip the de Casteljau flatten + edge extract
# + storage buffer upload entirely. Invisible to the user: they keep
# calling the normal Canvas API; the cache hits whenever the geometry
# hasn't changed (e.g. a static shape rotating via the canvas affine).
class CanvasPath
    public points    : array PathPt
    public start_x   : f32
    public start_y   : f32
    public cursor_x  : f32
    public cursor_y  : f32
    public is_closed  : bool
    # cached flatten/extract result from the previous draw of this path.
    # cached_points is the snapshot of `points` that produced cached_edges.
    intern cached_points : array PathPt
    intern cached_edges  : array SDFEdge
    intern cached_bx0    : f32
    intern cached_by0    : f32
    intern cached_bw     : f32
    intern cached_bh     : f32
    intern cached_valid  : bool

    func init []
        points = array PathPt []

    func reset []
        clear points
        start_x  = 0.0
        start_y  = 0.0
        cursor_x = 0.0
        cursor_y = 0.0
        is_closed = false

    func move_to [ x: f32, y: f32 ]
        pt : PathPt [ cmd: path_cmd.move, x: x, y: y ]
        points.push[ pt ]
        start_x  = x
        start_y  = y
        cursor_x = x
        cursor_y = y
        is_closed = false

    func line_to [ x: f32, y: f32 ]
        pt : PathPt [ cmd: path_cmd.line, x: x, y: y ]
        points.push[ pt ]
        cursor_x = x
        cursor_y = y

    func quad_to [ cx: f32, cy: f32, x: f32, y: f32 ]
        pt : PathPt [ cmd: path_cmd.quad, x: x, y: y, cx1: cx, cy1: cy ]
        points.push[ pt ]
        cursor_x = x
        cursor_y = y

    func cubic_to [ c1x: f32, c1y: f32, c2x: f32, c2y: f32, x: f32, y: f32 ]
        pt : PathPt [ cmd: path_cmd.cubic, x: x, y: y, cx1: c1x, cy1: c1y, cx2: c2x, cy2: c2y ]
        points.push[ pt ]
        cursor_x = x
        cursor_y = y

    func arc_to [ x1: f32, y1: f32, x2: f32, y2: f32, radius: f32 ]
        # compute arc tangent to lines (cursor->x1,y1) and (x1,y1->x2,y2)
        dx0 : cursor_x - x1
        dy0 : cursor_y - y1
        dx1 : x2 - x1
        dy1 : y2 - y1
        len0 : sqrt[ dx0 * dx0 + dy0 * dy0 ]
        len1 : sqrt[ dx1 * dx1 + dy1 * dy1 ]
        if [ len0 < 0.001 || len1 < 0.001 ]
            line_to [ x1, y1 ]
            return

        dx0 = dx0 / len0
        dy0 = dy0 / len0
        dx1 = dx1 / len1
        dy1 = dy1 / len1

        cross : dx0 * dy1 - dy0 * dx1
        if [ abs[ cross ] < 0.001 ]
            line_to [ x1, y1 ]
            return

        # tangent length
        tl : radius / tan[acos[clamp[ dx0 * dx1 + dy0 * dy1, -1.0, 1.0]] * 0.5]

        # tangent points
        t0x : x1 + dx0 * tl
        t0y : y1 + dy0 * tl
        t1x : x1 + dx1 * tl
        t1y : y1 + dy1 * tl

        # center
        sign : f32 [ 1.0 ]
        if [ cross < 0.0 ]
            sign = -1.0
        ncx : x1 + dx0 * tl - dy0 * radius * sign
        ncy : y1 + dy0 * tl + dx0 * radius * sign

        a0 : atan2[ t0y - ncy, t0x - ncx ]
        a1 : atan2[ t1y - ncy, t1x - ncx ]

        line_to [ t0x, t0y ]
        flatten_arc [ points, ncx, ncy, radius, a0, a1 ]
        cursor_x = t1x
        cursor_y = t1y

    func add_arc [ cx: f32, cy: f32, radius: f32, start_angle: f32, end_angle: f32 ]
        sx : cx + radius * cos[ start_angle ]
        sy : cy + radius * sin[ start_angle ]
        move_to [ sx, sy ]
        flatten_arc [ points, cx, cy, radius, start_angle, end_angle ]
        ex : cx + radius * cos[ end_angle ]
        ey : cy + radius * sin[ end_angle ]
        cursor_x = ex
        cursor_y = ey

    func add_rect [ x: f32, y: f32, w: f32, h: f32 ]
        move_to [ x, y ]
        line_to [ x + w, y ]
        line_to [ x + w, y + h ]
        line_to [ x, y + h ]
        close_path

    func add_rounded_rect [ x: f32, y: f32, w: f32, h: f32, rx: f32, ry: f32 ]
        # clamp radii
        rxx : minf [ rx, w * 0.5 ]
        ryy : minf [ ry, h * 0.5 ]
        PI  : f32 [ 3.14159265 ]
        HP  : f32 [ 1.57079632 ]

        # top edge (left to right)
        move_to [ x + rxx, y ]
        line_to [ x + w - rxx, y ]
        # top-right corner
        flatten_arc [ points, x + w - rxx, y + ryy, rxx, -HP, 0.0 ]
        cursor_x = x + w
        cursor_y = y + ryy

        # right edge
        line_to [ x + w, y + h - ryy ]
        # bottom-right corner
        flatten_arc [ points, x + w - rxx, y + h - ryy, rxx, 0.0, HP ]
        cursor_x = x + w - rxx
        cursor_y = y + h

        # bottom edge (right to left)
        line_to [ x + rxx, y + h ]
        # bottom-left corner
        flatten_arc [ points, x + rxx, y + h - ryy, rxx, HP, PI ]
        cursor_x = x
        cursor_y = y + h - ryy

        # left edge
        line_to [ x, y + ryy ]
        # top-left corner
        flatten_arc [ points, x + rxx, y + ryy, rxx, PI, PI + HP ]
        cursor_x = x + rxx
        cursor_y = y

        close_path

    func close_path []
        if [ !is_closed ]
            line_to [ start_x, start_y ]
            is_closed = true

    func clear[]
        points  = array PathPt []
        start_x = 0.0
        start_y = 0.0
        is_closed = false


# gradient stop: color at a position [0..1]
struct GradientStop
    pos   : f32
    color : u32

# gradient definition
class Gradient
    public kind     : GradientType
    public stops    : array GradientStop
    # linear: start/end points
    public x0       : f32
    public y0       : f32
    public x1       : f32
    public y1       : f32
    # radial: center + radius (x0,y0 = center, x1 = inner radius, y1 = outer radius)
    # conic:  x0,y0 = center, x1 = start angle

    func init []
        stops = array GradientStop []
        kind  = GradientType.none

    func add_stop [ pos: f32, color: u32 ]
        s : GradientStop [ pos: pos, color: color ]
        stops.push[ s ]

    # sample color at position t [0..1]
    func sample [ t: f32 ] -> u32
        n : stops.count
        if [ n == 0 ]
            return 0xFF000000
        if [ n == 1 ]
            return stops[0].color

        tc : f32 [ clampf [ t, 0.0, 1.0 ] ]

        # find surrounding stops
        if [ tc <= stops[0].pos ]
            return stops[0].color
        if [ tc >= stops[n - 1].pos ]
            return stops[n - 1].color

        for [ i: i32 1, i < n, i += 1 ]
            if [ tc <= stops[i].pos ]
                s0 : GradientStop stops[i - 1]
                s1 : GradientStop stops[i]
                # lerp factor between stops
                span : f32 [ s1.pos - s0.pos ]
                if [ span < 0.0001 ]
                    return s1.color
                frac : f32 [ tc - s0.pos / span ]
                return color_lerp [ s0.color, s1.color, frac ]

        return stops[n - 1].color

    # evaluate gradient at pixel position, return t
    func eval [ px: f32, py: f32 ] -> f32
        switch [ kind ]
        case linear
            dx : x1 - x0
            dy : y1 - y0
            len_sq : dx * dx + dy * dy
            if [ len_sq < 0.0001 ]
                return 0.0
            return clamp[ (px - x0) * dx + (py - y0) * dy / len_sq, 0.0, 1.0 ]
        case radial
            dx  : px - x0
            dy  : py - y0
            d   : sqrt[ dx * dx + dy * dy ]
            # x1 = inner radius, y1 = outer radius
            span : f32[ y1 - x1 ]
            if [ span < 0.0001 ]
                return 0.0
            return clamp[ d - x1 / span, 0.0, 1.0 ]
        case conic
            dx : px - x0
            dy : py - y0
            angle : atan2[ dy, dx ] - x1
            PI2 : f32 [ 6.2831853 ]
            # normalize to [0..1]
            if [ angle < 0.0 ]
                angle += PI2
            return clamp[ angle / PI2, 0.0, 1.0 ]
        default
            return 0.0

    # sample color at pixel position
    func color_at[ px: f32, py: f32 ] -> u32
        t : eval[ px, py ]
        return sample[ t ]


# ---- SDF path rendering ----
# generates signed distance fields from arbitrary paths
# handles holes via winding number: outer contour CCW, holes CW (or vice versa)

struct SDFEdge
    x0 : f32
    y0 : f32
    x1 : f32
    y1 : f32


# ---- Canvas state entry ----
struct CanvasState
    fill_color        : vec4f
    stroke_color      : vec4f
    stroke_width      : f32
    stroke_cap        : Cap
    stroke_join       : Join
    opacity           : f32
    transform         : affine
    clip_x            : i32
    clip_y            : i32
    clip_w            : i32
    clip_h            : i32
    blur_rad          : f32
    fill_offset       : f32
    stroke_offset     : f32
    corner_radii      : vec4f
    fill_grad         : Gradient
    stroke_grad       : Gradient
    font      	      : CanvasFont
    font_size         : i32
    line_height       : f32
    inner_glow_color   : vec4f
    inner_glow_px      : f32
    inner_glow_ofs     : vec2f
    inner_shadow_color : vec4f
    inner_shadow_px    : f32
    stroke_shadow_color: vec4f
    outer_glow_color   : vec4f
    outer_glow_px      : f32
    outer_shadow_color : vec4f
    outer_shadow_px    : f32
    outer_shadow_ofs   : vec2f
    # power-curve exponent for glow alpha. larger = steeper cliff near edge
    # with a long flat tail; smaller = gentler, more visible spread.
    glow_falloff      : f32
    # HSV colorize on final output. defaults (0, 1, 1) = identity.
    hue_shift         : f32
    sat_mul           : f32
    val_mul           : f32


func sk_color [ clr: rgba ] -> vec4f
    if [ !clr ] 
        return vec4f [
            f32[ 0 ],
            f32[ 0 ],
            f32[ 0 ],
            f32[ 1 ]
        ]
    res : vec4f [
        f32[ clr.r ],
        f32[ clr.g ],
        f32[ clr.b ],
        f32[ clr.a ]
    ]
    return res


# ---- Canvas class (GPU draw-list builder) ----
Render Canvas
    public path        : CanvasPath
    mutable states     : array CanvasState
    public state_depth : i32
    mutable font       : CanvasFont
    public glyph_atlas : GlyphAtlas
    intern ui_shader     : CanvasUI
    intern sdf_tex       : Texture
    intern image_override : Texture
    public format	   : Pixel[Pixel.rgba8]
    # current 2D affine — held directly on Canvas because writing back
    # into states[state_depth-1].transform via array-of-struct field assignment
    # doesn't stick (silver returns a copy, edits the copy, drops it).
    mutable cur_xform  : affine
    mutable xform_stack : array affine
    # ---- gpu sdf compute path ----
    # toggle this to switch between CPU SDF (sdf_generate + sdf_to_r8 + upload)
    # and GPU compute SDF (CanvasSDFCompute writes directly into sdf_tex).
    public  gpu_sdf          : bool
    public  load_existing    : bool [ true ]
    intern  sdf_compute      : CanvasSDFCompute
    intern  edge_buf         : Buffer       # storage buffer holding flattened edge list
    intern  edge_buf_capacity : i32         # max edges the buffer can hold
    # ---- text rendering: own Render that layers text over canvas color ----
    # canvas builds these inline (no subclass) so the calls stay direct.
    # text_render shares the canvas's color/depth and uses LOAD_OP_LOAD so
    # the text quads composite on top of whatever the canvas just drew.
    intern  text_shader      : CanvasText
    intern  text_vbo         : gpu          # custom (vec2 pos, vec2 uv) layout
    intern  text_pipeline    : Pipeline     # bound to text_shader + text_vbo
    intern  text_model       : Model        # holds text_pipeline; lives in text_render.models
    intern  text_render      : Render       # own Render targeting canvas color
    intern  text_max_verts   : i32 [ 4096 ]
    # ---- blur cascade (built in init) ----
    # 8 reduction stages (1/2, 1/4, ..., 1/256); per-stage blur_v + blur_h.
    # Canvas.blur[radius] picks stage k = clamp(ceil(log2(radius/4)), 0, 7)
    # and runs reductions 0..k then blur_v[k] then blur_h[k].
    intern  blur_count       : i32 [ 8 ]
    intern  blur_stages      : array Render
    intern  blur_v_arr       : array Render
    intern  blur_h_arr       : array Render

    func init [ ]
        printf[ "Canvas.init: vk=%p w=%p width=%i height=%i\n", vk, w, width, height ]
        # default: transparent — canvas can be used as an overlay layer.
        # call reset[ vec4f ] to force a direct image clear (bypasses any
        # render-pass blending) when you need a hard wipe of the pixels.
        clear_color = vec4f [ 0.0, 0.0, 0.0, 0.0 ]
        cur_xform   = affine [ ma: 1.0, mb: 0.0, mc: 0.0, md: 1.0, tx: 0.0, ty: 0.0 ]
        xform_stack = array affine [ ]
        VK : vk
        ui_shader = CanvasUI [ vk: vk ]
        # R32F + STORAGE_BIT so the compute shader can imageStore distances
        # directly and the fragment shader still samples it as a texture.
        sdf_tex = Texture [ vk: vk, w: w, width: 512, height: 512,
            pixel_format: Pixel.f32, surface: Surface.color, is_storage: true ]
        # one r8 glyph atlas per canvas, bound as the `atlas` sampler the
        # CanvasUI shader's mode-4 text path samples from.
        glyph_atlas = GlyphAtlas [ vk: vk, w: w, size: 1024 ]
        # default font load — assigning to `font` here works because we're
        # inside Canvas.init (implicit self), bypassing the chained-write
        # issue with `outside.compose.font = fnt` from trinity.render.
        ft_lib_h : handle ft_init[]
        font = CanvasFont [ ft_lib: ft_lib_h, uri: 'fonts/OxygenMono-Regular.ttf', size_px: 22 ]
        #font.hold[]
        printf[ "Canvas.init: self=%p AFTER font assign, font.size_px=%i\n",
            a, (font) ? font.size_px : -1 ]
        canvas_samplers : map Au[string] [ 'image': sdf_tex, 'atlas': glyph_atlas.texture ]
        graphics_model : Model [ vk: vk, w: w, s: ui_shader, samplers: canvas_samplers ]

        # GPU SDF compute model
        sdf_compute = CanvasSDFCompute [ vk: vk ]
        edge_buf_capacity = 1024
        edge_bytes : i32 [ edge_buf_capacity * 16 ]
        edge_buf = Buffer [ vk: vk, size: edge_bytes,
            u_storage: true, m_host_visible: true, m_host_coherent: true ]
        compute_samplers : map Au[string] [ 'edges': edge_buf, 'sdf_out': sdf_tex ]
        compute_model : Model [ vk: vk, w: w, s: sdf_compute, samplers: compute_samplers ]
        # compute first, then graphics samples the result
        models = [ compute_model, graphics_model ]

        for [ m: Model ] in models
            m.finish[ a, 0 ]
            printf[ "  Canvas.init: model.pipelines.count=%i\n", m.pipelines.count ]

        # ---- text rendering: own Render layered over canvas color ----
        # by this point Render base init has already created `color`/`depth`,
        # so we hand them to a second Render that uses LOAD_OP_LOAD and
        # carries one Pipeline that draws the per-glyph quads from text_vbo.
        text_shader = CanvasText [ vk: vk ]
        # vertex layout: vec2f a_pos (offset 0) + vec2f a_uv (offset 8). 16 bytes per vertex.
        text_members : new vertex_member_t [ 2 ]
        text_members[0].src    = typeid[ vec2f ]
        text_members[0].size   = 8
        text_members[0].offset = 0
        text_members[1].src    = typeid[ vec2f ]
        text_members[1].size   = 8
        text_members[1].offset = 8
        # use explicit local i32 for vertex_size/vertex_count so the prop
        # pair gets the right type (matches model_init_pipeline pattern).
        text_vsize  : i32 [ 16 ]
        text_vcount : i32 [ text_max_verts ]
        text_mcount : i32 [ 2 ]
        text_vbo = gpu [ vk: vk, name: 'text',
            members: text_members, member_count: text_mcount,
            vertex_size: text_vsize, vertex_count: text_vcount ]
        printf[ "Canvas.init: text_vbo vertex_size=%i vertex_count=%i vertex_data=%p\n",
            text_vbo.vertex_size, text_vbo.vertex_count, ref text_vbo.vertex_data ]
        text_vbo.sync[ w ]
        # text_render is constructed BEFORE its pipeline so we have a Render
        # for the pipeline's `r` field. We pass color pre-set so this Render
        # reuses the canvas's existing color attachment instead of allocating
        # a new one. No depth — text doesn't need depth testing.
        # load_existing=true so its render pass preserves whatever the canvas
        # just drew (LOAD_OP_LOAD).
        text_render = Render [ vk: vk, w: w,
            color: a.color,
            wscale: 1.0, load_existing: true ]
        text_pipeline = Pipeline [ vk: vk, w: w, name: string 'text',
            r: text_render, s: text_shader, vbo: text_vbo,
            samplers: map Au[string] [ 'atlas': glyph_atlas.texture ],
            straight_alpha: true ]
        text_model = Model [ vk: vk, w: w, s: text_shader,
            samplers: map Au[string] [ 'atlas': glyph_atlas.texture ] ]
        text_model.pipelines = array Pipeline [ alloc: 1 ]
        text_model.pipelines.push[ text_pipeline ]
        text_model.r = text_render
        text_render.models = array Model [ text_model ]
        text_vbo.vertex_count = 0

        # ---- blur cascade: 8 stages halving each time (1/2 .. 1/256)
        blur_stages = array Render [ alloc: blur_count ]
        blur_v_arr  = array Render [ alloc: blur_count ]
        blur_h_arr  = array Render [ alloc: blur_count ]
        # pass 1: reductions + per-stage vertical blur (both at the reduced scale)
        prev_tx    : Texture [ a.color ]
        scale      : f32 [ 1.0 ]
        for [ i: i32 0, i < blur_count, i += 1 ]
            scale *= 0.5
            m_r  : Model  [ w: w, samplers: map Texture[string] [ 'color': prev_tx ] ]
            r_r  : Render [ vk: vk, w: w, wscale: scale, models: array Model [ m_r ] ]
            blur_stages.push[ r_r ]

            bv_s : CanvasBlurV [ vk: vk, name: 'canvas-blur-v' ]
            m_v  : Model  [ w: w, s: bv_s, samplers: map Texture[string] [ 'color': r_r.color ] ]
            r_v  : Render [ vk: vk, w: w, wscale: scale, models: array Model [ m_v ] ]
            blur_v_arr.push[ r_v ]

            prev_tx = r_r.color

        # pass 2: per-pair horizontal blur + mix; low=blur_v[k], high=blur_v[k+1]
        for [ i: i32 0, i < blur_count, i += 1 ]
            hi_idx : i32 [ (i + 1 < blur_count) ? i + 1 : i ]
            rv_lo  : Render [ blur_v_arr[i] ]
            rv_hi  : Render [ blur_v_arr[hi_idx] ]
            bh_s : CanvasBlurH [ vk: vk, name: 'canvas-blur-h' ]
            m_h  : Model  [ w: w, s: bh_s, samplers: map Texture[string] [ 'low': rv_lo.color, 'high': rv_hi.color ] ]
            r_h  : Render [ vk: vk, w: w, color: a.color, wscale: 1.0, models: array Model [ m_h ] ]
            blur_h_arr.push[ r_h ]

        path   = CanvasPath []
        states = array CanvasState []
        state_depth  = 0
        save[]
        defaults : CanvasState [ states[state_depth - 1] ]
        defaults.font_size = 22

    # invoke the inherited Render pipeline once all canvas state has been
    # built up. drives framebuffer/extent setup, runs the render pass, and
    # blocks until the GPU has finished writing the color attachment.
    func flush []
        #update[]
        draw[]
        sync_fence[]

    # hard-clear the canvas's color texture to a chosen color via
    # vkCmdClearColorImage. this happens OUTSIDE any render pass and
    # bypasses all blending — the pixels are directly overwritten with
    # `c` regardless of what was there before. use this when you need a
    # genuine "reset to transparent" (or any other clean state) before
    # the next frame's draws.
    func reset [ c: vec4f ]
        if [ !color || !color.vk_image ]
            return
        color.transition[ VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL ]
        cv : VkClearColorValue
        cv.float32[0] = c.x
        cv.float32[1] = c.y
        cv.float32[2] = c.z
        cv.float32[3] = c.w
        rng : VkImageSubresourceRange [
            aspectMask:     VK_IMAGE_ASPECT_COLOR_BIT,
            baseMipLevel:   0,
            levelCount:     1,
            baseArrayLayer: 0,
            layerCount:     1
        ]
        cmd : Command [ vk: vk ]
        cmd.begin[]
        vkCmdClearColorImage[ cmd.cmd, color.vk_image,
            VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, ref cv, 1, ref rng ]
        cmd.submit[]
        color.transition[ VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]

    func resize [ rw: i32, rh: i32 ] -> Canvas
        width  = rw
        height = rh
        return a


    # ---- text measurement ----

    func measure_text [ text: string ] -> TextMetrics
        ensure_font[]
        st : CanvasState states[state_depth - 1]
        n   : text.count
        w   : f32 [ 0.0 ]
        tw  : f32 [ 0.0 ]
        for [ i: i64 0, i < n, i += 1 ]
            cp : text[i]
            g  : font.get_glyph [ cp ]
            if [ g.cached ]
                tw += f32 g.advance
        # state.line_height is a multiplier (CSS-style): 1.0 = natural,
        # 1.5 = 150% of the font's intrinsic line height. 0 = unset → 1.0.
        scale : f32 [ (st.line_height > 0.0) ? st.line_height : 1.0 ]
        lh    : f32 [ font.line_height * scale ]
        return TextMetrics [
            w:           tw,
            h:           lh,
            ascent:      font.ascent,
            descent:     font.descent,
            line_height: lh,
            cap_height:  font.cap_height
        ]


    # ---- ellipsis helper ----

    func text_ellipsis [ text: string, max_w: f32 ] -> string
        tm : TextMetrics measure_text [ text ]
        if [ tm.w <= max_w ]
            return text
        n : text.count
        dots : TextMetrics measure_text [ '...' ]
        if [ dots.w >= max_w ]
            return '.'
        target : f32 [ max_w - dots.w ]
        w : f32 [ 0.0 ]
        cut : i32 [ 0 ]
        for [ i: i32 0, i < n, i += 1 ]
            cp : u32 [ text[i] ]
            g  : font.get_glyph [ cp ]
            if [ g.cached ]
                w += f32 g.advance
            if [ w > target ]
                cut = i
                return text.mid [ 0, cut ] + '...'
        return text



    # ---- state stack ----

    func current_state [] -> CanvasState
        return states[state_depth - 1]

    func hex_dump [ name: symbol, data: ref u8, size: i32 ]
        #printf[ "%s (%d bytes) data ptr = %p :\n", name, size, data ]
        for [ i: i32 0, i < size, i += 1 ]
            b: u8 data[ i ]
            printf[ "%02x ", u32[b] ]
            if [ (i + 1) % 16 == 0 ]
                printf[ "\n" ]
        if [ size % 16 != 0 ]    
            printf[ "\n" ]

    func clear [ color: rgba ]
        clr : sk_color[ color ]
        clear_color = clr
        reset[ clr ]

    func save []
        if [ state_depth == 0 ]
            st : CanvasState [
                fill_color:    vec4f[0,0,0,1],
                stroke_color:  vec4f[0,0,0,1],
                stroke_width:  0.0,
                opacity:       1.0,
                transform:     affine.identity [],
                clip_x: 0, clip_y: 0,
                clip_w: width, clip_h: height,
                blur_rad:      0.0,
                fill_offset:   0.0,
                stroke_offset: 0.0,
                corner_radii:  vec4f [ 0.0, 0.0, 0.0, 0.0 ]
            ]
            states.push[ st ]
        el
            prev : states[state_depth - 1]
            states.push[ prev ]
        # snapshot the current transform so restore[] can roll it back.
        xform_stack.push[ cur_xform ]
        state_depth += 1

    func restore []
        if [ state_depth > 1 ]
            states.pop[]
            state_depth -= 1
        if [ xform_stack.count > 0 ]
            cur_xform = xform_stack[ xform_stack.count - 1 ]
            xform_stack.pop[]

    func set_font [ fnt: CanvasFont ]
        font = fnt

    func font_size [ px: i32 ]
        states[state_depth - 1].font_size = px

    func line_height [ px: f32 ]
        states[state_depth - 1].line_height = px

    # sync the shared CanvasFont's freetype face to this canvas's current
    # font_size before any glyph/metrics call. avoids bleeding size changes
    # from one canvas into another when they share a font.
    intern func ensure_font []
        sz : i32 [ states[state_depth - 1].font_size ]
        if [ font && sz > 0 && sz != font.size_px ]
            font.set_size[ sz ]
    # ---- state setters ----

    func fill_color [ color: rgba ]
        states[state_depth - 1].fill_color = sk_color[ color ]

    func stroke_color [ color: rgba ]
        c : vec4f [ sk_color[ color ] ]
        states[state_depth - 1].stroke_color        = c
        states[state_depth - 1].stroke_shadow_color = c

    func stroke_width [ sw: f32 ]
        states[state_depth - 1].stroke_width = sw

    func inner_glow [ color: rgba, px: f32 ]
        c : vec4f [ sk_color[ color ] ]
        states[state_depth - 1].inner_glow_color   = c
        states[state_depth - 1].inner_glow_px      = px
        states[state_depth - 1].inner_shadow_color = c
        states[state_depth - 1].inner_shadow_px    = px

    func inner_glow_offset [ x: f32, y: f32 ]
        states[state_depth - 1].inner_glow_ofs = vec2f [ x, y ]

    func inner_shadow [ color: rgba, px: f32 ]
        states[state_depth - 1].inner_shadow_color = sk_color[ color ]
        states[state_depth - 1].inner_shadow_px    = px

    func stroke_shadow [ color: rgba ]
        states[state_depth - 1].stroke_shadow_color = sk_color[ color ]

    func outer_glow [ color: rgba, px: f32 ]
        states[state_depth - 1].outer_glow_color = sk_color[ color ]
        states[state_depth - 1].outer_glow_px    = px

    func outer_shadow [ color: rgba, px: f32 ]
        states[state_depth - 1].outer_shadow_color = sk_color[ color ]
        states[state_depth - 1].outer_shadow_px    = px

    func outer_shadow_offset [ x: f32, y: f32 ]
        states[state_depth - 1].outer_shadow_ofs = vec2f [ x, y ]

    func glow_falloff [ k: f32 ]
        states[state_depth - 1].glow_falloff = k

    func colorize [ hue: f32, sat: f32, val: f32 ]
        states[state_depth - 1].hue_shift = hue
        states[state_depth - 1].sat_mul   = sat
        states[state_depth - 1].val_mul   = val

    func set_stroke_size [ sw: f32 ]
        states[state_depth - 1].stroke_width = sw

    func set_stroke_cap [ c: Cap ]
        states[state_depth - 1].stroke_cap = c

    func set_stroke_join [ j: Join ]
        states[state_depth - 1].stroke_join = j

    func set_opacity [ o: f32 ]
        states[state_depth - 1].opacity = o

    func set_blur_radius [ br: f32 ]
        states[state_depth - 1].blur_rad = br

    func set_fill_gradient [ g: Gradient ]
        states[state_depth - 1].fill_grad = g

    func set_stroke_gradient [ g: Gradient ]
        states[state_depth - 1].stroke_grad = g

    func clear_fill_gradient []
        states[state_depth - 1].fill_grad = null

    func clear_stroke_gradient []
        states[state_depth - 1].stroke_grad = null

    func set_clip [ x: i32, y: i32, cw: i32, ch: i32 ]
        # intersect with parent clip
        st : CanvasState states[state_depth - 1]
        nx0 : i32 [ maxi [ x, st.clip_x ] ]
        ny0 : i32 [ maxi [ y, st.clip_y ] ]
        nx1 : i32 [ mini [ x + cw, st.clip_x + st.clip_w ] ]
        ny1 : i32 [ mini [ y + ch, st.clip_y + st.clip_h ] ]
        states[state_depth - 1].clip_x = nx0
        states[state_depth - 1].clip_y = ny0
        states[state_depth - 1].clip_w = maxi [ nx1 - nx0, 0 ]
        states[state_depth - 1].clip_h = maxi [ ny1 - ny0, 0 ]

    # ---- transform ----

    func translate [ tx: f32, ty: f32 ]
        states[state_depth - 1].transform = states[state_depth - 1].transform.translate [ tx, ty ]

    func scale [ s: f32 ]
        states[state_depth - 1].transform = states[state_depth - 1].transform.scale [ s ]

    func rotate [ radians: f32 ]
        states[state_depth - 1].transform = states[state_depth - 1].transform.rotate [ radians ]

    # ---- path building (delegate to CanvasPath) ----
    # path coords are stored in LOCAL space; the GPU vertex shader applies
    # ubo.xform per draw. that lets the same path be drawn with multiple
    # transforms without rebuilding it (and matches Web Canvas semantics).

    func move_to [ x: f32, y: f32 ]
        path.move_to [ x, y ]

    func line_to [ x: f32, y: f32 ]
        path.line_to [ x, y ]

    func quad_to [ cx: f32, cy: f32, x: f32, y: f32 ]
        path.quad_to [ cx, cy, x, y ]

    func cubic_to [ c1x: f32, c1y: f32, c2x: f32, c2y: f32, x: f32, y: f32 ]
        path.cubic_to [ c1x, c1y, c2x, c2y, x, y ]

    func arc_to [ x1: f32, y1: f32, x2: f32, y2: f32, radius: f32 ]
        st : CanvasState states[state_depth - 1]
        path.arc_to [
            st.transform.apply_x [ x1, y1 ],
            st.transform.apply_y [ x1, y1 ],
            st.transform.apply_x [ x2, y2 ],
            st.transform.apply_y [ x2, y2 ],
            radius * st.transform.ma
        ]

    func rect_to [ x: f32, y: f32, rw: f32, rh: f32 ]
        path.add_rect [ x, y, rw, rh ]

    func rounded_rect [ x: f32, y: f32, rw: f32, rh: f32, rx: f32, ry: f32 ]
        path.add_rounded_rect [ x, y, rw, rh, rx, ry ]

    func close_path []
        path.close_path[]

    func arc [ cx: f32, cy: f32, radius: f32, start_angle: f32, end_angle: f32 ]
        st : CanvasState states[state_depth - 1]
        path.add_arc [
            st.transform.apply_x [ cx, cy ],
            st.transform.apply_y [ cx, cy ],
            radius * st.transform.ma,
            start_angle, end_angle
        ]

    func draw_text [ text: string, bounds: rect, align: vec2f, offset: vec2f, overflow: Overflow ] -> rect
        if [ !font ]
            return bounds

        display : string [ (overflow == Overflow.ellipsis) ? text_ellipsis[ text, bounds.w ] : text ]
        tm  : TextMetrics [ measure_text[ display ] ]
        tx  : f32 [ bounds.x + (bounds.w - tm.w) * align.x + offset.x ]
        # cap-height-box centering — baseline sits cap_height below bounds.y at
        # align.y=0, capitals optically centered at align.y=0.5 for most UI text.
        ty  : f32 [ bounds.y + tm.cap_height + (bounds.h - tm.cap_height) * align.y + offset.y ]

        # build per-glyph quad vertices into text_vbo. 6 verts per glyph
        # (two triangles, no index buffer). vertex layout: vec2f pos, vec2f uv.
        # text_render then runs ONE render pass with ONE vkCmdDraw covering
        # the entire string regardless of glyph count.
        st : CanvasState states[state_depth - 1]
        atlas_size : f32 [ f32 glyph_atlas.size ]
        text_shader.viewport = vec2f [ f32 width, f32 height ]
        text_shader.text_color = st.fill_color
        verts : ref f32 [ text_vbo.vertex_data ]
        vi    : i32 [ 0 ]
        # text shader bakes vertex positions in viewport pixels and doesn't
        # use the canvas transform — apply the current translate here so nested
        # element translates (draw_element's cv.translate per child) land the
        # text at the right pixel instead of canvas origin.
        pen_x : f32 [ tx + st.transform.tx ]
        pen_y : f32 [ ty + st.transform.ty ]

        for [ i: i32 0, i < display.count, i += 1 ]
            cp   : u32 [ display[i] ]
            slot : GlyphAtlasSlot [ glyph_atlas.get[ font, cp ] ]
            if [ slot.cached && slot.atlas_w > 0 && slot.atlas_h > 0 ]
                if [ vi + 6 > text_max_verts ]
                    break
                x0 : f32 [ pen_x + f32 slot.bearing_x ]
                y0 : f32 [ pen_y - f32 slot.bearing_y ]
                x1 : f32 [ x0 + f32 slot.atlas_w ]
                y1 : f32 [ y0 + f32 slot.atlas_h ]
                # half-texel inset so bilinear sampling never reads past
                # the glyph's atlas slot into a neighboring glyph (the
                # vertical seams between letters were exactly that bleed).
                u0 : f32 [ (f32 slot.atlas_x                   + 0.5) / atlas_size ]
                v0 : f32 [ (f32 slot.atlas_y                   + 0.5) / atlas_size ]
                u1 : f32 [ (f32 (slot.atlas_x + slot.atlas_w)  - 0.5) / atlas_size ]
                v1 : f32 [ (f32 (slot.atlas_y + slot.atlas_h)  - 0.5) / atlas_size ]
                base : i32 [ vi * 4 ]
                # tri 0: (x0,y0) (x1,y0) (x0,y1)
                verts[ base +  0 ] = x0
                verts[ base +  1 ] = y0
                verts[ base +  2 ] = u0
                verts[ base +  3 ] = v0
                verts[ base +  4 ] = x1
                verts[ base +  5 ] = y0
                verts[ base +  6 ] = u1
                verts[ base +  7 ] = v0
                verts[ base +  8 ] = x0
                verts[ base +  9 ] = y1
                verts[ base + 10 ] = u0
                verts[ base + 11 ] = v1
                # tri 1: (x1,y0) (x1,y1) (x0,y1)
                verts[ base + 12 ] = x1
                verts[ base + 13 ] = y0
                verts[ base + 14 ] = u1
                verts[ base + 15 ] = v0
                verts[ base + 16 ] = x1
                verts[ base + 17 ] = y1
                verts[ base + 18 ] = u1
                verts[ base + 19 ] = v1
                verts[ base + 20 ] = x0
                verts[ base + 21 ] = y1
                verts[ base + 22 ] = u0
                verts[ base + 23 ] = v1
                vi += 6
            pen_x += f32 slot.advance
        text_vbo.vertex_count = vi
        if [ text_vbo.vertex && vi > 0 ]
            text_vbo.vertex.update[ text_vbo.vertex_data ]
            # text_render isn't in Display.list so nothing else refreshes its
            # framebuffer after a resize — call update here so it rebuilds
            # against the current color.vk_image_view before we draw.
            text_render.update[]
            # submit via text_render — its render pass uses LOAD_OP_LOAD on
            # canvas color so the text composites on top of whatever the
            # canvas just drew. one render pass, one vkCmdDraw, fence-waited.
            text_render.draw[]
            text_render.sync_fence[]
        #printf[ "draw_text: %i glyphs -> %i verts in text_vbo\n", display.count, vi ]
        return rect [ x: tx, y: ty - tm.ascent, w: tm.w, h: tm.h ]

    # ---- GPU draw helpers ----

    func color_to_vec4 [ c: u32 ] -> vec4f
        return vec4f [
            f32 [color_r [ c ]] / 255.0,
            f32 [color_g [ c ]] / 255.0,
            f32 [color_b [ c ]] / 255.0,
            f32 [color_a [ c ]] / 255.0
        ]

    func setup_shader [ st: CanvasState, rx: f32, ry: f32, rw: f32, rh: f32 ]
        ui_shader.viewport      = vec2f [ f32 width, f32 height ]
        ui_shader.rect          = vec4f [ rx, ry, rw, rh ]
        ui_shader.fill_color    = st.fill_color # color_to_vec4 [ st.fill_color ]
        ui_shader.stroke_color  = st.stroke_color # color_to_vec4 [ st.stroke_color ]
        ui_shader.fill_offset   = st.fill_offset
        ui_shader.stroke_offset = st.stroke_offset
        ui_shader.params        = vec4f [ st.stroke_width, st.opacity, st.blur_rad, 0.0 ]
        ui_shader.radii         = st.corner_radii
        ui_shader.grad0         = vec4f [ 0.0, 0.0, 0.0, 0.0 ]
        ui_shader.grad_c0       = vec4f [ 0.0, 0.0, 0.0, 0.0 ]
        ui_shader.grad_c1       = vec4f [ 0.0, 0.0, 0.0, 0.0 ]
        # stroke options: x = join enum (0=none,1=miter,2=round,3=bevel)
        ui_shader.stroke_opts = vec4f [ f32 i32 st.stroke_join, f32 i32 st.stroke_cap, 0.0, 0.0 ]
        # 2D affine transform packed as two vec4s for the vertex shader
        # to apply: world_px = mat2(ma,mc, mb,md) * local_px + (tx,ty)
        ui_shader.xform_row0 = vec4f [ st.transform.ma, st.transform.mb,
                                       st.transform.mc, st.transform.md ]
        ui_shader.xform_row1 = vec4f [ st.transform.tx, st.transform.ty, 0.0, 0.0 ]
        ui_shader.inner_glow_color    = st.inner_glow_color
        ui_shader.inner_shadow_color  = st.inner_shadow_color
        ui_shader.stroke_shadow_color = st.stroke_shadow_color
        ui_shader.outer_glow_color    = st.outer_glow_color
        ui_shader.outer_shadow_color  = st.outer_shadow_color
        k : f32 [ (st.glow_falloff > 0.0) ? st.glow_falloff : 6.0 ]
        ui_shader.glow_params  = vec4f [ st.inner_glow_px, st.outer_glow_px, k, st.inner_shadow_px ]
        sat : f32 [ (st.sat_mul != 0.0) ? st.sat_mul : 1.0 ]
        val : f32 [ (st.val_mul != 0.0) ? st.val_mul : 1.0 ]
        ui_shader.glow_params2 = vec4f [ st.outer_shadow_px, st.hue_shift, sat, val ]
        ui_shader.glow_ofs     = vec4f [ st.inner_glow_ofs.x, st.inner_glow_ofs.y,
                                         st.outer_shadow_ofs.x, st.outer_shadow_ofs.y ]
        # print the full UBO contents we just wrote, so we can compare
        # what silver thinks it's sending vs what the GPU actually reads.
        ##
        printf[ "setup_shader ubo:\n" ]
        printf[ "  rect       = (%f, %f, %f, %f)\n", rx, ry, rw, rh ]
        printf[ "  fill_color = (%f, %f, %f, %f)\n",
            ui_shader.fill_color.x, ui_shader.fill_color.y,
            ui_shader.fill_color.z, ui_shader.fill_color.w ]
        printf[ "  params     = (sw=%f, op=%f, blur=%f, mode=%f)\n",
            st.stroke_width, st.opacity, st.blur_rad, 0.0 ]
        printf[ "  xform_row0 = (ma=%f, mb=%f, mc=%f, md=%f)\n",
            st.transform.ma, st.transform.mb, st.transform.mc, st.transform.md ]
        printf[ "  xform_row1 = (tx=%f, ty=%f, 0, 0)\n",
            st.transform.tx, st.transform.ty ]
        printf[ "  viewport   = (%f, %f)\n", f32 width, f32 height ]
        ##

    func setup_gradient [ st: ref CanvasState ] -> f32
        if [ st.fill_grad && st.fill_grad.kind != GradientType.none ]
            g : Gradient st.fill_grad
            ui_shader.grad0 = vec4f [ g.x0, g.y0, g.x1, g.y1 ]
            n : g.stops.count
            if [ n >= 1 ]
                ui_shader.grad_c0 = color_to_vec4 [ g.stops[0].color ]
            if [ n >= 2 ]
                ui_shader.grad_c1 = color_to_vec4 [ g.stops[n - 1].color ]
            return f32 [i32[g.kind]]
        return 0.0

    # ---- drawing ----

    func fill_rect_fast [ x: f32, y: f32, rw: f32, rh: f32 ]
        expect state_depth >= 0, "no canvas state"
        st : CanvasState [ states[state_depth - 1] ]
        tx : st.transform.apply_x [ x, y ]
        ty : st.transform.apply_y [ x, y ]
        tw : rw * st.transform.ma
        th : rh * st.transform.md
        setup_shader [ st, tx, ty, tw, th ]
        mode : setup_gradient [ st ]
        ui_shader.params = vec4f [ st.stroke_width, st.opacity, st.blur_rad, mode ]
        draw[]
        
    func fill_rounded_rect_fast [ x: f32, y: f32, rw: f32, rh: f32, rx: f32, ry: f32 ]
        st : states[state_depth - 1]
        tx : st.transform.apply_x [ x, y ]
        ty : st.transform.apply_y [ x, y ]
        tw : rw * st.transform.ma
        th : rh * st.transform.md
        sr : rx * st.transform.ma
        setup_shader [ st, tx, ty, tw, th ]
        ui_shader.radii = vec4f [ sr, sr, sr, sr ]
        mode : f32 setup_gradient [ st ]
        ui_shader.params = vec4f [ st.stroke_width, st.opacity, st.blur_rad, mode ]
        draw[]

    func clip_rect [ r_x: f32, r_y: f32, r_w: f32, r_h: f32, rx: f32, ry: f32 ]
        st : states[state_depth - 1]
        tx : i32 [ i32 st.transform.apply_x [ r_x, r_y ] ]
        ty : i32 [ i32 st.transform.apply_y [ r_x, r_y ] ]
        tw : i32 [ i32 r_w * st.transform.ma ]
        th : i32 [ i32 r_h * st.transform.md ]
        set_clip [ tx, ty, tw, th ]

    func set_texture [ tx: Texture ]
        no-op

    func fill_offset [ v: f32 ]
        states[state_depth - 1].fill_offset = v

    func stroke_offset [ v: f32 ]
        states[state_depth - 1].stroke_offset = v

    func rounded [ tl: f32, tr: f32, br: f32, bl: f32 ]
        states[state_depth - 1].corner_radii = vec4f [ tl, tr, br, bl ]

    func draw_canvas [ src: Canvas, x: f32, y: f32, rw: f32, rh: f32 ]
        image_override = src.color
        path.clear[]
        path.add_rect[ x, y, rw, rh ]
        paint[]
        image_override = null

    # paint `tex` into `dst` using the full texture as source.
    func draw_image [ tex: Texture, dst: rect ]
        image_override = tex
        path.clear[]
        path.add_rect[ dst.x, dst.y, dst.w, dst.h ]
        paint[]
        image_override = null
        if [ models ]
            for [ mi: i32 0, mi < models.count, mi += 1 ]
                cmod : Model models[mi]
                if [ cmod.pipelines && cmod.pipelines.count > 0 ]
                    p : Pipeline cmod.pipelines[0]
                    p.rebind_image[ sdf_tex ]

    # blur canvas.color in place.
    # blur_reduce: quad-samples canvas.color at 1/4 size
    # blur_v:      vertical gaussian on the reduced source
    # blur_h:      horizontal gaussian, writes back to canvas.color
    func blur [ radius: f32 ]
        if [ radius < 1.0 ] return
        # smooth stage selection: k_lo = floor(log2(radius/4)),
        # frac = fractional part, mix between blur_v[k_lo] and blur_v[k_lo+1].
        lg   : f32 [ log2[ radius / 4.0 ] ]
        if [ lg < 0.0 ] lg = 0.0
        max_lg : f32 [ f32[ blur_count - 1 ] ]
        if [ lg > max_lg ] lg = max_lg
        k_lo : i32 [ i32[ lg ] ]
        k_hi : i32 [ (k_lo + 1 < blur_count) ? k_lo + 1 : k_lo ]
        frac : f32 [ lg - f32 k_lo ]

        ruv : f32 [ radius / (4.0 * f32 height) ]
        # vbv uniforms: radius_uv only
        vbv_lo : CanvasBlurV blur_v_arr[k_lo].models[0].s
        vbv_hi : CanvasBlurV blur_v_arr[k_hi].models[0].s
        vbv_lo.radius_uv = ruv
        vbv_hi.radius_uv = ruv
        vbh : CanvasBlurH blur_h_arr[k_lo].models[0].s
        vbh.radius_uv  = ruv
        vbh.mix_factor = frac

        color.transition[ VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL ]
        # always run the full cascade so both low/high are populated
        for [ i: i32 0, i <= k_hi, i += 1 ]
            s : Render blur_stages[i]
            s.update*[] s.draw*[] s.sync_fence[]
        bv_lo : Render blur_v_arr[k_lo]
        bv_lo.update*[] bv_lo.draw*[] bv_lo.sync_fence[]
        if [ k_hi != k_lo ]
            bv_hi : Render blur_v_arr[k_hi]
            bv_hi.update*[] bv_hi.draw*[] bv_hi.sync_fence[]
        color.transition[ VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
        bh : Render blur_h_arr[k_lo]
        bh.update*[] bh.draw*[] bh.sync_fence[]

    func paint []

        st   : states[state_depth - 1]
        # ---- ordered-guess cache check ----
        # if path.points byte-matches the snapshot from the previous draw,
        # the de Casteljau flatten + edge extract + bounding box are all
        # also the same — reuse them and skip the work. invisible to the
        # user: they keep calling the normal Canvas API; the cache hits
        # whenever the geometry hasn't changed (e.g. a static shape that
        # just rotates via the canvas affine transform).
        cache_hit : bool [ false ]
        pcount    : i32  [ path.points.count ]
        if [ pcount > 0 && path.cached_valid && path.cached_points
          && path.cached_points.count == pcount ]
            same : bool [ true ]
            for [ pi: i32 0, pi < pcount && same, pi += 1 ]
                a_pt : PathPt path.points[pi]
                b_pt : PathPt path.cached_points[pi]
                if [ a_pt.cmd != b_pt.cmd
                  || a_pt.x   != b_pt.x   || a_pt.y   != b_pt.y
                  || a_pt.cx1 != b_pt.cx1 || a_pt.cy1 != b_pt.cy1
                  || a_pt.cx2 != b_pt.cx2 || a_pt.cy2 != b_pt.cy2 ]
                    same = false
            cache_hit = same

        # bounding box in local-space (the GPU vertex shader transforms it)
        bx0 : f32
        by0 : f32
        bw  : f32
        bh  : f32
        edges : array SDFEdge
        n     : i32

        if [ cache_hit ]
            bx0 = path.cached_bx0
            by0 = path.cached_by0
            bw  = path.cached_bw
            bh  = path.cached_bh
            edges = path.cached_edges
            n     = edges.count
        el
            flat : path_flatten [ path, 0.25 ]
            n    = flat.count
            if [ n == 0 ]
                return
            bx0 = 999999.0
            by0 = 999999.0
            bx1 : f32 [ -999999.0 ]
            by1 : f32 [ -999999.0 ]
            for [ i: i32 0, i < n, i += 1 ]
                pt : PathPt flat[i]
                if [ pt.x < bx0 ]
                    bx0 = pt.x
                if [ pt.y < by0 ]
                    by0 = pt.y
                if [ pt.x > bx1 ]
                    bx1 = pt.x
                if [ pt.y > by1 ]
                    by1 = pt.y
            bw = bx1 - bx0
            bh = by1 - by0
            edges = sdf_extract_edges [ flat ]
            n     = edges.count
            # snapshot the path op log + flatten/extract result for the next call
            path.cached_points = array PathPt [ ]
            for [ pi: i32 0, pi < pcount, pi += 1 ]
                cp : PathPt path.points[pi]
                path.cached_points.push[ cp ]
            path.cached_edges = edges
            path.cached_bx0   = bx0
            path.cached_by0   = by0
            path.cached_bw    = bw
            path.cached_bh    = bh
            path.cached_valid = true

        if [ bw < 0.5 || bh < 0.5 ]
            return

        # path classification: a primitive axis-aligned rect produces
        # exactly 5 PathPt entries (4 corners + close = 4 edges).
        # anything else (curves, chamfers, polygons) goes through the
        # SDF-from-path generator and gets sampled by mode 6.
        if [ pcount == 5 && n == 4 ]
            # primitive rect — use the in-shader rect SDF (mode 0), or
            # mode 5 (image) if draw_canvas set image_override.
            setup_shader [ st, bx0, by0, bw, bh ]
            ui_shader.fill_color = st.fill_color
            ui_shader.grad0  = vec4f [ 0.0, 0.0, 1.0, 1.0 ]
            is_r8    : bool [ image_override && image_override.pixel_format == Pixel.u8 ]
            img_mode : f32  [ (is_r8) ? f32 DrawMode.image_r : f32 DrawMode.image ]
            mode     : f32  [ (image_override) ? img_mode : f32 DrawMode.solid ]
            ui_shader.params = vec4f [ st.stroke_width, st.opacity, st.blur_rad, mode ]
            if [ image_override && models ]
                for [ mi: i32 0, mi < models.count, mi += 1 ]
                    cmod : Model models[mi]
                    if [ cmod.pipelines && cmod.pipelines.count > 0 ]
                        p : Pipeline cmod.pipelines[0]
                        p.rebind_image[ image_override ]
        el
            # arbitrary path — GPU compute SDF. on cache miss the edge list
            # was just extracted above; on cache hit we reuse the edges that
            # are already in the storage buffer from the previous frame and
            # only need to refresh the UBO params (transform may have moved).
            sdf_w  : i32 [ 512 ]
            sdf_h  : i32 [ 512 ]
            pad    : f32 [ maxf [ 4.0, st.stroke_width * 0.5 + 4.0 ] ]
            spread : f32 [ maxf [ 8.0, st.stroke_width * 0.5 + 4.0 ] ]
            pbx : f32 [ bx0 - pad ]
            pby : f32 [ by0 - pad ]
            pbw : f32 [ bw  + pad * 2.0 ]
            pbh : f32 [ bh  + pad * 2.0 ]

            ne : i32 [ edges.count ]
            expect ne <= edge_buf_capacity, "edge buffer too small for path"
            if [ !cache_hit ]
                # pack edges into the storage buffer (4 floats per edge).
                # only on cache miss — on hit, the buffer is already valid.
                edge_data : ref f32 [ edge_buf.data ]
                for [ ei: i32 0, ei < ne, ei += 1 ]
                    e : SDFEdge edges[ei]
                    edge_data[ei * 4 + 0] = e.x0
                    edge_data[ei * 4 + 1] = e.y0
                    edge_data[ei * 4 + 2] = e.x1
                    edge_data[ei * 4 + 3] = e.y1
            # compute shader UBO params
            sdf_compute.wx     = pbx
            sdf_compute.wy     = pby
            sdf_compute.ww     = pbw
            sdf_compute.wh     = pbh
            sdf_compute.tw     = sdf_w
            sdf_compute.th     = sdf_h
            sdf_compute.ne     = ne
            sdf_compute.spread = spread
            # workgroup count: ceil(tw/16) x ceil(th/16) x 1
            wg_x : i32 [ (sdf_w + 15) / 16 ]
            wg_y : i32 [ (sdf_h + 15) / 16 ]
            cmod : Model models[0]
            cmod.pipelines[0].dispatch_x = wg_x
            cmod.pipelines[0].dispatch_y = wg_y
            cmod.pipelines[0].dispatch_z = 1

            setup_shader [ st, pbx, pby, pbw, pbh ]
            ui_shader.fill_color = st.fill_color
            ui_shader.grad0  = vec4f [ 0.0, 0.0, 1.0, 1.0 ]
            j : f32 [ st.stroke_join ]
            c : f32 [ st.stroke_cap ]
            ui_shader.stroke_opts = vec4f [ j, c, 0.0, spread ]
            ui_shader.params = vec4f [ st.stroke_width, st.opacity, st.blur_rad, DrawMode.sdf_path ]
            #printf[ "draw_fill: mode=6 (sdf_path) rect=(%f,%f %fx%f) edges=%i\n", pbx, pby, pbw, pbh, ne ]

        flush[]
        path.clear[]


# ---- text rendering with FreeType ----

struct GlyphMetrics
    advance   : f32
    bearing_x : f32
    bearing_y : f32
    glyph_w   : i32
    glyph_h   : i32


struct TextMetrics
    w           : f32
    h           : f32
    ascent      : f32
    descent     : f32
    line_height : f32
    cap_height  : f32


# glyph cache entry: pre-rendered bitmap + metrics for one codepoint at one size
struct GlyphEntry
    codepoint  : u32
    size_px    : i32
    bitmap     : ref u8
    bmp_w      : i32
    bmp_h      : i32
    bearing_x  : i32
    bearing_y  : i32
    advance    : i32
    cached      : bool


# font face wrapper around FreeType
class CanvasFont
    expect ft_lib     : handle
    expect uri        : string
    expect size_px    : i32
    intern ft_face    : FT_Face
    public ascent     : f32
    public descent    : f32
    public line_height : f32
    public cap_height : f32
    public cache      : array GlyphEntry
    public cache_size : i32

    func init []
        err  : i32 FT_New_Face [ ft_lib, uri.chars, 0, ref ft_face ]
        expect err == 0, 'failed to load font: {uri}'
        FT_Set_Pixel_Sizes [ ft_face, 0, size_px ]

        # extract metrics from face
        xscale      : i64 ft_face.size.metrics.x_scale
        yscale      : i64 ft_face.size.metrics.y_scale
        ascent      = f32 ft_face.size.metrics.ascender / 64.0
        descent     = f32 ft_face.size.metrics.descender / 64.0
        line_height = f32 ft_face.size.metrics.height / 64.0

        # approximate cap height from 'H' glyph
        gi : FT_Get_Char_Index [ ft_face, 72 ]
        if [ gi > 0 ]
            FT_Load_Glyph [ ft_face, gi, 0 ]
            cap_height = ft_face.glyph.metrics.horiBearingY / 64.0
        el
            cap_height = ascent * 0.7

        # init glyph cache (128 ascii slots to start)
        cache_size = 128
        cache = array GlyphEntry []

    func dealloc []
        # free cached bitmaps
        n : cache.count
        for [ i: i32 0, i < n, i += 1 ]
            g : GlyphEntry cache[i]
            if [ g.cached && g.bitmap ]
                free [ g.bitmap ]
        FT_Done_Face [ ft_face ]

    func set_size [ size: i32 ]
        if [ size != size_px ]
            size_px = size
            FT_Set_Pixel_Sizes [ ft_face, 0, size ]
            fm : ref FT_FaceRec_ [ ft_face ]
            ascent      = f32 fm.size.metrics.ascender / 64.0
            descent     = f32 fm.size.metrics.descender / 64.0
            line_height = f32 fm.size.metrics.height / 64.0
            # invalidate cache
            n : cache.count
            for [ i: i32 0, i < n, i += 1 ]
                g : GlyphEntry cache[i]
                if [ g.cached && g.bitmap ]
                    free [ g.bitmap ]
            cache.clear[]

    # render and cache a glyph, return its entry
    func get_glyph [ codepoint: u32 ] -> GlyphEntry
        # search cache
        n : cache.count
        for [ i: i32 0, i < n, i += 1 ]
            g : cache[i]
            if [ g.cached && g.codepoint == codepoint && g.size_px == size_px ]
                return g

        # render with freetype using FT_LOAD_DEFAULT (0) — the font's native
        # hinting gives the sharpest result. FT_LOAD_TARGET_LIGHT (0x10000)
        # is grayscale-friendlier but visibly blurrier; the bimodal-looking
        # alpha that drove me there was actually atlas bleed at slot edges,
        # not the hinting, and the gutter+inset fix took care of that.
        gi  : u32 FT_Get_Char_Index [ ft_face, codepoint ]
        err : i32 FT_Load_Glyph [ ft_face, gi, 0 ]
        if [ err != 0 ]
            return GlyphEntry [ cached: false ]

        FT_Render_Glyph [ ft_face.glyph, 0 ]

        slot : ft_face.glyph
        bw   : i32 [ slot.bitmap.width ]
        bh   : i32 [ slot.bitmap.rows ]
        printf[ "FT glyph cp=%u: %ix%i pitch=%i pixel_mode=%i\n",
            codepoint, bw, bh, slot.bitmap.pitch, slot.bitmap.pixel_mode ]

        # copy bitmap (FT reuses its internal buffer)
        bmp : ref u8 [ null ]
        if [ bw > 0 && bh > 0 ]
            sz  : i32 [ bw * bh ]
            bmp = new u8 [ sz ]
            # FT bitmap may have pitch != width, copy row by row
            for [ row: i32 0, row < bh, row += 1 ]
                src_off : i32 [ row * slot.bitmap.pitch ]
                dst_off : i32 [ row * bw ]
                memcpy [ ref bmp[ dst_off ], ref slot.bitmap.buffer[ src_off ], bw ]

        entry : GlyphEntry [
            codepoint: codepoint,
            size_px:   size_px,
            bitmap:    bmp,
            bmp_w:     bw,
            bmp_h:     bh,
            bearing_x: slot.bitmap_left,
            bearing_y: slot.bitmap_top,
            advance:   i32 slot.advance.x / 64,
            cached:    true
        ]
        cache.push[ entry ]
        return entry


# atlas slot for one glyph: where in the atlas it lives + the layout
# metrics needed to position the glyph quad relative to the pen.
struct GlyphAtlasSlot
    codepoint  : u32
    size_px    : i32
    atlas_x    : i32
    atlas_y    : i32
    atlas_w    : i32
    atlas_h    : i32
    bearing_x  : i32
    bearing_y  : i32
    advance    : i32
    cached     : bool


# r8 glyph atlas with a simple shelf packer. each font instance owns one.
# layout: rows of fixed `shelf_height` filled left to right; when the
# current shelf is full a new shelf starts below. when the atlas is full
# we currently just stop accepting new glyphs (TODO: LRU evict).
class GlyphAtlas
    public  vk          : vk_context
    public  w           : Display
    public  size        : i32       # square atlas dimension
    intern  texture     : Texture
    intern  slots       : array GlyphAtlasSlot
    intern  shelf_x     : i32
    intern  shelf_y     : i32
    intern  shelf_h     : i32
    intern  staging     : ref u8    # scratch buffer for upload (atlas-sized)

    func init []
        if [ size == 0 ]
            size = 1024
        texture = Texture [ vk: vk, w: w, width: size, height: size,
            pixel_format: Pixel.u8, surface: Surface.color ]
        slots   = array GlyphAtlasSlot []
        shelf_x = 0
        shelf_y = 0
        shelf_h = 0

    func find [ codepoint: u32, size_px: i32 ] -> GlyphAtlasSlot
        n : slots.count
        for [ i: i32 0, i < n, i += 1 ]
            s : GlyphAtlasSlot slots[i]
            if [ s.cached && s.codepoint == codepoint && s.size_px == size_px ]
                return s
        return GlyphAtlasSlot [ cached: false ]

    # rasterize-and-pack a single glyph from `font` into the atlas. on
    # cache hit the existing slot is returned without re-uploading.
    func get [ font: CanvasFont, codepoint: u32 ] -> GlyphAtlasSlot
        existing : GlyphAtlasSlot find [ codepoint, font.size_px ]
        if [ existing.cached ]
            return existing

        g : GlyphEntry font.get_glyph [ codepoint ]
        if [ !g.cached ]
            return GlyphAtlasSlot [ cached: false ]

        gw : i32 [ g.bmp_w ]
        gh : i32 [ g.bmp_h ]

        # zero-area glyphs (e.g. space) still need a slot for advance metrics
        # but no atlas pixels — record an empty rect at the current pen.
        if [ gw == 0 || gh == 0 ]
            slot : GlyphAtlasSlot [
                codepoint: codepoint, size_px: font.size_px,
                atlas_x: 0, atlas_y: 0, atlas_w: 0, atlas_h: 0,
                bearing_x: g.bearing_x, bearing_y: g.bearing_y,
                advance: g.advance, cached: true ]
            slots.push[ slot ]
            return slot

        # shelf packer with 1-pixel gutter between glyphs so bilinear
        # sampling at the edge of one slot never reads pixels from a
        # neighboring slot (the seams between letters were exactly that).
        gutter : i32 [ 1 ]
        gw_pad : i32 [ gw + gutter ]
        gh_pad : i32 [ gh + gutter ]
        if [ shelf_x + gw_pad > size ]
            shelf_y += shelf_h
            shelf_x  = 0
            shelf_h  = 0
        if [ shelf_y + gh_pad > size ]
            # atlas full — fail soft. Caller treats !cached as "skip glyph".
            return GlyphAtlasSlot [ cached: false ]
        if [ gh_pad > shelf_h ]
            shelf_h = gh_pad

        ax : i32 [ shelf_x ]
        ay : i32 [ shelf_y ]
        shelf_x += gw_pad

        # one-shot upload of just this glyph's bitmap into its packed slot.
        texture.upload_region[ ax, ay, gw, gh, g.bitmap, gw * gh ]
        printf[ "GlyphAtlas.get: uploaded cp=%u at (%i,%i) %ix%i bytes=%i\n",
            codepoint, ax, ay, gw, gh, gw * gh ]

        slot : GlyphAtlasSlot [
            codepoint: codepoint, size_px: font.size_px,
            atlas_x: ax, atlas_y: ay, atlas_w: gw, atlas_h: gh,
            bearing_x: g.bearing_x, bearing_y: g.bearing_y,
            advance: g.advance, cached: true ]
        slots.push[ slot ]
        return slot


# ---- FreeType library singleton ----

intern ft_library : handle [ null ]

# ---- color helpers ----

func color_pack [ r: u8, g: u8, b: u8, alpha: u8 ] -> u32
    return u32 alpha << 24 | u32 b << 16 | u32 g << 8 | u32 r

func color_r [ c: u32 ] -> u8 [ c 		& 0xFF ]
func color_g [ c: u32 ] -> u8 [ c >> 8  & 0xFF ]
func color_b [ c: u32 ] -> u8 [ c >> 16 & 0xFF ]
func color_a [ c: u32 ] -> u8 [ c >> 24 & 0xFF ]


# ---- clamp helpers ----

func clampf [ v: f32, lo: f32, hi: f32 ] -> f32
    if [ v < lo ]
        return lo
    if [ v > hi ]
        return hi
    return v

func clampi [ v: i32, lo: i32, hi: i32 ] -> i32
    if [ v < lo ]
        return lo
    if [ v > hi ]
        return hi
    return v

func mini [ x: i32, y: i32 ] -> i32
    if [ x < y ]
        return x
    return y

func maxi [ x: i32, y: i32 ] -> i32
    if [ x > y ]
        return x
    return y

func minf [ x: f32, y: f32 ] -> f32
    if [ x < y ]
        return x
    return y

func maxf [ x: f32, y: f32 ] -> f32
    if [ x > y ]
        return x
    return y


# ---- bezier flattening ----

# flatten quadratic bezier to line segments, appending to edges
# p0 -> p1 (control) -> p2
func flatten_quad [ pts: array PathPt, x0: f32, y0: f32, cx: f32, cy: f32, x1: f32, y1: f32, tol: f32 ]
    # flatness: deviation of control point from chord midpoint
    mx : 0.5 * (x0 + x1) - cx
    my : 0.5 * (y0 + y1) - cy
    if [ mx * mx + my * my < tol * tol ]
        pt : PathPt [ cmd: path_cmd.line, x: x1, y: y1 ]
        pts.push[ pt ]
        return

    # de Casteljau at t=0.5
    ax  : 0.5 * (x0 + cx)
    ay  : 0.5 * (y0 + cy)
    bx  : 0.5 * (cx + x1)
    by  : 0.5 * (cy + y1)
    abx : 0.5 * (ax + bx)
    aby : 0.5 * (ay + by)

    flatten_quad [ pts, x0, y0, ax, ay, abx, aby, tol ]
    flatten_quad [ pts, abx, aby, bx, by, x1, y1, tol ]


# flatten cubic bezier to line segments
# p0 -> c1 -> c2 -> p1
func flatten_cubic [ pts: array PathPt, x0: f32, y0: f32, c1x: f32, c1y: f32, c2x: f32, c2y: f32, x1: f32, y1: f32, tol: f32 ]
    # flatness test: deviation of control points from chord at t=1/3, 2/3
    dx : x1 - x0
    dy : y1 - y0
    d2 : abs[ c1x - x0 - dx * 0.333 ] + abs[ c1y - y0 - dy * 0.333 ]
    d3 : abs[ c2x - x0 - dx * 0.667 ] + abs[ c2y - y0 - dy * 0.667 ]

    if [ d2 + d3 < tol ]
        pt : PathPt [ cmd: path_cmd.line, x: x1, y: y1 ]
        pts.push[ pt ]
        return

    # de Casteljau at t=0.5 — midpoints, not weighted sums
    m01x  : 0.5 * (x0   + c1x)
    m01y  : 0.5 * (y0   + c1y)
    m12x  : 0.5 * (c1x  + c2x)
    m12y  : 0.5 * (c1y  + c2y)
    m23x  : 0.5 * (c2x  + x1)
    m23y  : 0.5 * (c2y  + y1)
    m012x : 0.5 * (m01x + m12x)
    m012y : 0.5 * (m01y + m12y)
    m123x : 0.5 * (m12x + m23x)
    m123y : 0.5 * (m12y + m23y)
    mx    : 0.5 * (m012x + m123x)
    my    : 0.5 * (m012y + m123y)

    flatten_cubic [ pts, x0, y0, m01x, m01y, m012x, m012y, mx, my, tol ]
    flatten_cubic [ pts, mx, my, m123x, m123y, m23x, m23y, x1, y1, tol ]


# flatten arc to line segments
# center cx,cy  radius r  from angle0 to angle1 (radians)
func flatten_arc [ pts: array PathPt, cx: f32, cy: f32, r: f32, angle0: f32, angle1: f32 ]
    sweep : angle1 - angle0
    if [ sweep < 0.0 ]
        sweep = sweep + 6.2831853
    steps : i32 [ ceil[ abs[ sweep ] * r * 0.5 ] ]
    if [ steps < 4 ]
        steps = 4
    if [ steps > 256 ]
        steps = 256
    dt : sweep / f32 steps
    for [ i: i32 1, i <= steps, i += 1 ]
        t  : angle0 + dt * f32 i
        px : cx + r * cos[ t ]
        py : cy + r * sin[ t ]
        pt : PathPt [ cmd: path_cmd.line, x: px, y: py ]
        pts.push[ pt ]


# flatten all curves in path, return flat line-only path
func path_flatten [ src: CanvasPath, tol: f32 ] -> array PathPt
    flat : array PathPt [ alloc: 64 ]
    n    : src.points.count
    px   : f32 [ 0.0 ]
    py   : f32 [ 0.0 ]

    for [ i: i32 0, i < n, i += 1 ]
        pt : PathPt src.points[i]
        switch [ pt.cmd ]
        case path_cmd.move
            fpt : PathPt [ cmd: path_cmd.move, x: pt.x, y: pt.y ]
            flat.push[ fpt ]
            px = pt.x
            py = pt.y
        case path_cmd.line
            fpt : PathPt [ cmd: path_cmd.line, x: pt.x, y: pt.y ]
            flat.push[ fpt ]
            px = pt.x
            py = pt.y
        case path_cmd.quad
            flatten_quad [ flat, px, py, pt.cx1, pt.cy1, pt.x, pt.y, tol ]
            px = pt.x
            py = pt.y
        case path_cmd.cubic
            flatten_cubic [ flat, px, py, pt.cx1, pt.cy1, pt.cx2, pt.cy2, pt.x, pt.y, tol ]
            px = pt.x
            py = pt.y
        case path_cmd.close
            fpt : PathPt [ cmd: path_cmd.close, x: pt.x, y: pt.y ]
            flat.push[ fpt ]
            px = pt.x
            py = pt.y
    return flat


# lerp between two packed RGBA colors
func color_lerp[ c0: u32, c1: u32, t: f32 ] -> u32
    inv : f32 [ 1.0 - t ]
    r : u8 [ u8 f32 color_r[ c0 ] * inv + f32 color_r [ c1 ] * t ]
    g : u8 [ u8 f32 color_g[ c0 ] * inv + f32 color_g [ c1 ] * t ]
    b : u8 [ u8 f32 color_b[ c0 ] * inv + f32 color_b [ c1 ] * t ]
    al: u8 [ u8 f32 color_a[ c0 ] * inv + f32 color_a [ c1 ] * t ]
    return color_pack[ r, g, b, al ]


# constructors for common gradients

func linear_gradient[ x0: f32, y0: f32, x1: f32, y1: f32 ] -> Gradient
    g : Gradient [
        kind:GradientType.linear,
        :x0,
        :y0,
        :x1,
        :y1
    ]
    return g

func radial_gradient[ cx: f32, cy: f32, inner_r: f32, outer_r: f32 ] -> Gradient
    g : Gradient [
        kind: GradientType.radial,
        x0:cx,
        y0:cy,
        x1:inner_r,
        y1:outer_r
    ]
    return g

func conic_gradient[ cx: f32, cy: f32, start_angle: f32 ] -> Gradient
    g : Gradient [
        kind: GradientType.conic,
        x0: cx,
        y0: cy,
        x1: start_angle
    ]
    return g



# extract line segments from flattened path. callers must close paths
# explicitly via line_to back to start (CanvasPath.close_path does this),
# so no closing-edge synthesis here. degenerate (zero-length) segments
# are skipped.
func sdf_extract_edges [ flat: array PathPt ] -> array SDFEdge
    edges : array SDFEdge []
    n     : flat.count
    px    : f32 [ 0.0 ]
    py    : f32 [ 0.0 ]
    have_cursor : bool [ false ]
    for [ i: i32 0, i < n, i += 1 ]
        pt : PathPt flat[i]
        if [ pt.cmd == path_cmd.move ]
            px = pt.x
            py = pt.y
            have_cursor = true
        el [ pt.cmd == path_cmd.line ]
            if [ have_cursor ]
                if [ px != pt.x || py != pt.y ]
                    e : SDFEdge [ x0: px, y0: py, x1: pt.x, y1: pt.y ]
                    edges.push[ e ]
            px = pt.x
            py = pt.y
            have_cursor = true
    return edges


# distance from point to line segment
func sdf_seg_dist [ ex0: f32, ey0: f32, ex1: f32, ey1: f32, px: f32, py: f32 ] -> f32
    dx  : ex1 - ex0
    dy  : ey1 - ey0
    len_sq : dx * dx + dy * dy
    if [ len_sq < 0.00001 ]
        ddx : px - ex0
        ddy : py - ey0
        return sqrt[ ddx * ddx + ddy * ddy ]
    t   : clampf [ ((px - ex0) * dx + (py - ey0) * dy) / len_sq, 0.0, 1.0 ]
    cx  : ex0 + t * dx
    cy  : ey0 + t * dy
    ddx : px - cx
    ddy : py - cy
    return sqrt[ ddx * ddx + ddy * ddy ]


# winding number at point (non-zero fill rule)
# positive winding = inside for CCW contours, holes wind CW and cancel
func sdf_winding [ edges: array SDFEdge, px: f32, py: f32 ] -> i32
    n  : edges.count
    wn : i32 [ 0 ]
    for [ i: i32 0, i < n, i += 1 ]
        e : SDFEdge edges[i]
        if [ e.y0 <= py ]
            if [ e.y1 > py ]
                # upward crossing: check if point is left of edge
                cross : (e.x1 - e.x0) * (py - e.y0) - (px - e.x0) * (e.y1 - e.y0)
                if [ cross > 0.0 ]
                    wn += 1
        el
            if [ e.y1 <= py ]
                # downward crossing: check if point is right of edge
                cross : (e.x1 - e.x0) * (py - e.y0) - (px - e.x0) * (e.y1 - e.y0)
                if [ cross < 0.0 ]
                    wn -= 1
    return wn


# generate signed distance field for a path (grid-accelerated)
# bx,by,bw,bh = world-space bounding box of the path
# tw,th = SDF Texture dimensions
# pad = extra world-space padding around bounds
# returns f32 array [tw*th], negative = inside, positive = outside
func sdf_generate [ flat: array PathPt, bx: f32, by: f32, bw: f32, bh: f32, tw: i32, th: i32, pad: f32 ] -> ref f32
    edges : sdf_extract_edges [ flat ]
    ne    : edges.count
    if [ ne == 0 ]
        return null

    # world bounds with padding
    wx : f32 [ bx - pad ]
    wy : f32 [ by - pad ]
    ww : f32 [ bw + pad * 2.0 ]
    wh : f32 [ bh + pad * 2.0 ]

    # grid: cells cover the SDF area, each cell holds edge indices
    # cell size ~ 8 texels worth of world space for good locality
    cell_tx : i32 [ 8 ]
    cell_ty : i32 [ 8 ]
    gw : i32 [ (tw + cell_tx - 1) / cell_tx ]
    gh : i32 [ (th + cell_ty - 1) / cell_ty ]
    gc : i32 [ gw * gh ]

    # world size per cell
    cw : f32 [ ww / f32 gw ]
    ch : f32 [ wh / f32 gh ]

    # bin edges into grid cells (CSR: count, then fill)
    grid_counts : new i32 [ gc ]
    for [ i: i32 0, i < gc, i += 1 ]
        grid_counts[i] = 0
    for [ ei: i32 0, ei < ne, ei += 1 ]
        e   : SDFEdge edges[ei]
        ex0 : min [ e.x0, e.x1 ]
        ey0 : min [ e.y0, e.y1 ]
        ex1 : max [ e.x0, e.x1 ]
        ey1 : max [ e.y0, e.y1 ]
        gx0 : clampi [ i32 (ex0 - wx) / cw - 1, 0, gw - 1 ]
        gy0 : clampi [ i32 (ey0 - wy) / ch - 1, 0, gh - 1 ]
        gx1 : clampi [ i32 (ex1 - wx) / cw + 1, 0, gw - 1 ]
        gy1 : clampi [ i32 (ey1 - wy) / ch + 1, 0, gh - 1 ]
        for [ gy: i32 gy0, gy <= gy1, gy += 1 ]
            for [ gx: i32 gx0, gx <= gx1, gx += 1 ]
                grid_counts[gy * gw + gx] += 1
    grid_offsets : new i32 [ gc + 1 ]
    grid_offsets[0] = 0
    for [ i: i32 0, i < gc, i += 1 ]
        grid_offsets[i + 1] = grid_offsets[i] + grid_counts[i]
    total_grid : grid_offsets[gc]
    grid_data : new i32 [ (total_grid > 0) ? total_grid : 1 ]
    for [ i: i32 0, i < gc, i += 1 ]
        grid_counts[i] = 0
    for [ ei: i32 0, ei < ne, ei += 1 ]
        e   : SDFEdge edges[ei]
        ex0 : min [ e.x0, e.x1 ]
        ey0 : min [ e.y0, e.y1 ]
        ex1 : max [ e.x0, e.x1 ]
        ey1 : max [ e.y0, e.y1 ]
        gx0 : clampi [ i32 (ex0 - wx) / cw - 1, 0, gw - 1 ]
        gy0 : clampi [ i32 (ey0 - wy) / ch - 1, 0, gh - 1 ]
        gx1 : clampi [ i32 (ex1 - wx) / cw + 1, 0, gw - 1 ]
        gy1 : clampi [ i32 (ey1 - wy) / ch + 1, 0, gh - 1 ]
        for [ gy: i32 gy0, gy <= gy1, gy += 1 ]
            for [ gx: i32 gx0, gx <= gx1, gx += 1 ]
                ci : gy * gw + gx
                grid_data[grid_offsets[ci] + grid_counts[ci]] = ei
                grid_counts[ci] += 1

    # texel to world mapping
    sx : ww / f32 tw
    sy : wh / f32 th

    # bin edges by row band (CSR: count, then fill)
    row_counts : new i32 [ th ]
    for [ i: i32 0, i < th, i += 1 ]
        row_counts[i] = 0
    for [ ei: i32 0, ei < ne, ei += 1 ]
        e   : SDFEdge edges[ei]
        ry0 : clampi [ i32 (min[ e.y0, e.y1 ] - wy) / sy, 0, th - 1 ]
        ry1 : clampi [ i32 (max[ e.y0, e.y1 ] - wy) / sy, 0, th - 1 ]
        for [ r: i32 ry0, r <= ry1, r += 1 ]
            row_counts[r] += 1
    # compute offsets
    row_offsets : new i32 [ th + 1 ]
    row_offsets[0] = 0
    for [ i: i32 0, i < th, i += 1 ]
        row_offsets[i + 1] = row_offsets[i] + row_counts[i]
    total_row_entries : i32 [ row_offsets[th] ]
    row_data : new i32 [ (total_row_entries > 0) ? total_row_entries : 1 ]
    # reset counts for fill pass
    for [ i: i32 0, i < th, i += 1 ]
        row_counts[i] = 0
    for [ ei: i32 0, ei < ne, ei += 1 ]
        e   : SDFEdge edges[ei]
        ry0 : clampi [ i32 (min[ e.y0, e.y1 ] - wy) / sy, 0, th - 1 ]
        ry1 : clampi [ i32 (max[ e.y0, e.y1 ] - wy) / sy, 0, th - 1 ]
        for [ r: i32 ry0, r <= ry1, r += 1 ]
            row_data[row_offsets[r] + row_counts[r]] = ei
            row_counts[r] += 1

    sz  : i32 [ tw * th ]
    sdf : new f32 [ sz ]
    spread : f32 [ 8.0 ]

    for [ y: i32 0, y < th, y += 1 ]
        py   : wy + (f32 y + 0.5) * sy
        grow : i32 [ clamp [ y / cell_ty, 0, gh - 1 ] ]
        re_off : row_offsets[y]
        nre    : row_counts[y]

        for [ x: i32 0, x < tw, x += 1 ]
            px   : wx + (f32 x + 0.5) * sx
            gcol : i32 [ clampi [ x / cell_tx, 0, gw - 1 ] ]
            cell_idx : grow * gw + gcol
            cell_off : grid_offsets[cell_idx]
            nc       : grid_counts[cell_idx]

            # min distance from ALL edges (no cell binning) — same reason
            # as the winding loop: edge counts are small enough that the
            # optimization isn't worth the bug surface.
            md : f32 [ 999999.0 ]
            for [ ei3: i32 0, ei3 < ne, ei3 += 1 ]
                e : SDFEdge edges[ei3]
                d : sdf_seg_dist [ e.x0, e.y0, e.x1, e.y1, px, py ]
                if [ d < md ]
                    md = d

            # winding number using ALL edges (no row binning). path counts
            # are tiny (5-50 edges), so the O(W*H*E) cost is fine and we
            # avoid any subtle precedence/round-off bugs in the row-bin
            # offsets that were dropping edges from the test.
            wn : i32 [ 0 ]
            for [ ei2: i32 0, ei2 < ne, ei2 += 1 ]
                e : SDFEdge edges[ei2]
                if [ e.y0 <= py ]
                    if [ e.y1 > py ]
                        cross : (e.x1 - e.x0) * (py - e.y0) - (px - e.x0) * (e.y1 - e.y0)
                        if [ cross > 0.0 ]
                            wn += 1
                el
                    if [ e.y1 <= py ]
                        cross : (e.x1 - e.x0) * (py - e.y0) - (px - e.x0) * (e.y1 - e.y0)
                        if [ cross < 0.0 ]
                            wn -= 1

            # clamp distance for texels far from edges
            if [ md > spread ]
                md = spread
            if [ wn != 0 ]
                sdf[y * tw + x] = -md
            el
                sdf[y * tw + x] = md
    return sdf


# convert f32 SDF to R8 Texture (maps [-spread..+spread] to [0..255])
func sdf_to_r8 [ sdf: ref f32, count: i32, spread: f32 ] -> ref u8
    tex : new u8 [ count ]
    inv : f32 [ 0.5 / spread ]
    for [ i: i32 0, i < count, i += 1 ]
        v : f32 [ clampf [ 0.5 - sdf[i] * inv, 0.0, 1.0 ] ]
        tex[i] = u8 [ v * 255.0 ]
    return tex

func ft_init [] -> handle
    if [ !ft_library ]
        err : i32 FT_Init_FreeType [ ref ft_library ]
        expect err == 0, 'FreeType init failed'
    return ft_library


# --- color conversion ---

func nib [ n: i8 ] -> i8
    if [ n >= '0' && n <= '9' ]
        return n - '0'
    if [ n >= 'a' && n <= 'f' ]
        return 10 + (n - 'a')
    if [ n >= 'A' && n <= 'F' ]
        return 10 + (n - 'A')
    return 0


expect func test [ vk: vk_context ] -> bool
    w: Display [ vk: vk, format: Pixel.rgba8, backbuffer: true, width: 1024, height: 1024 ]
    c: Canvas [ vk: vk, w: w, width: 1024, height: 1024 ]
    c.update[]

    # outer blob
    c.path.clear[]
    c.path.move_to[ 200.0, 200.0 ]
    c.path.cubic_to[ 400.0, 100.0, 600.0, 300.0, 800.0, 200.0 ]
    c.path.cubic_to[ 900.0, 500.0, 700.0, 700.0, 500.0, 800.0 ]
    c.path.cubic_to[ 300.0, 900.0, 100.0, 600.0, 200.0, 200.0 ]
    c.path.close_path[]

    c.save[]
    c.fill_color[ '#3366AA' ]
    c.paint[]

    # inner cutout (opposite winding)
    c.path.clear[]
    c.path.move_to[ 450.0, 350.0 ]
    c.path.cubic_to[ 550.0, 300.0, 650.0, 400.0, 600.0, 500.0 ]
    c.path.cubic_to[ 550.0, 600.0, 400.0, 550.0, 450.0, 350.0 ]
    c.path.close_path[]
    c.fill_color[ '#0000' ]
    c.paint[]
    c.restore[]

    # fetch Texture and verify
    img: Image[c.color]
    p: path 'canvas_test.png'
    p.save[ img, null ]
    puts 'wrote canvas_test.png'

    # average color across Image
    pixels: img.width * img.height
    data: ref u8 img.vdata[]
    r_sum: i64 [ 0 ]
    g_sum: i64 [ 0 ]
    b_sum: i64 [ 0 ]
    a_sum: i64 [ 0 ]
    for [ i: i32 0, i < pixels, i += 1 ]
        r_sum += data[i * 4 + 0]
        g_sum += data[i * 4 + 1]
        b_sum += data[i * 4 + 2]
        a_sum += data[i * 4 + 3]
    avg_r: r_sum / pixels
    avg_g: g_sum / pixels
    avg_b: b_sum / pixels
    avg_a: a_sum / pixels
    puts 'average color: r={avg_r} g={avg_g} b={avg_b} a={avg_a}'

    # the blob should produce non-zero color and non-zero alpha
    # transparent cutout lowers the averages but doesn't zero them
    return avg_a > 10 && (avg_r > 0 || avg_g > 0 || avg_b > 0)



abstract app media_app
    context  w     : Display*
    context  vk    : vk_context
    intern  arg   : object
    public width  : i32
    public height : i32
        
    func run [ ] -> i32
        next_second : epoch_millis[] / 1000
        frames      : 0

        while [ !glfwWindowShouldClose[ w.glfw ] ]
            glfwPollEvents[]
            second : epoch_millis[] / 1000
            if [next_second != second]
                next_second  = second
                frames = 0
            frames += 1
            render*[]

        return 0

    func render [ ]
        return
    
    func init [ ] 
        init_res : glfwInit[]
        expect init_res, "glfw init"
        if [ !glfwVulkanSupported[] ]
            fault "glfw does not support vulkan"
            glfwTerminate[]
            return
        puts 'starting vk'
        vk = vk_context[]
        printf["set vk to %p on %p\n", vk, a]

    func dealloc [ ]
        glfwTerminate[]

intern func trinity_log [severity: VkDebugUtilsMessageSeverityFlagBitsEXT, types: VkDebugUtilsMessageTypeFlagsEXT, callbackData:   ref VkDebugUtilsMessengerCallbackDataEXT, userData:       handle ] -> bool
    if [ severity >= VK_DEBUG_UTILS_MESSAGE_SEVERITY_WARNING_BIT_EXT ]
        printf[ "validator: %s", callbackData.pMessage ]
    return false


intern func image_release_buffer [ a: Image ] -> object
    b:  Buffer [ handle[ a.res2 ] ]
    vk: vk_context [ b.vk ]
    vmaUnmapMemory[ vk.allocator, b.vma_alloc ]
    vmaDestroyBuffer[ vk.allocator, b.vk_buffer, b.vma_alloc ]
    return null

func degrees[f32] -> f32
func radians[f32] -> f32

# ---- format conversion ----
intern func vk_format_fn [ f: Pixel, linear: bool ] -> VkFormat
    result: VkFormat [
        (f == Pixel.f32    ) ? VK_FORMAT_R32_SFLOAT :
        (f == Pixel.rgbaf32) ? VK_FORMAT_R32G32B32A32_SFLOAT :
        (f == Pixel.rgbf32 ) ? VK_FORMAT_R32G32B32_SFLOAT :
        (f == Pixel.rgba8  ) ? (linear) ? VK_FORMAT_R8G8B8A8_UNORM : VK_FORMAT_R8G8B8A8_SRGB :
        (f == Pixel.rgb8   ) ? (linear) ? VK_FORMAT_R8G8B8_UNORM   : VK_FORMAT_R8G8B8_SRGB :
        (f == Pixel.u8     ) ? VK_FORMAT_R8_UNORM : 0 ]
    expect result, "incompatible image format"
    return result

intern func pixel_from_format [ f: VkFormat, channels: ref i32 ] -> Pixel
    pixel: Pixel [
        (f == VK_FORMAT_R8G8B8A8_UNORM || f == VK_FORMAT_B8G8R8A8_UNORM ||
         f == VK_FORMAT_R8G8B8A8_SRGB  || f == VK_FORMAT_B8G8R8A8_SRGB)  ? Pixel.rgba8 :
        (f == VK_FORMAT_R8G8B8_UNORM   || f == VK_FORMAT_B8G8R8_UNORM   ||
         f == VK_FORMAT_R8G8B8_SRGB    || f == VK_FORMAT_B8G8R8_SRGB)    ? Pixel.rgb8 :
        (f == VK_FORMAT_R8_UNORM)            ? Pixel.u8 :
        (f == VK_FORMAT_R32_SFLOAT)          ? Pixel.f32 :
        (f == VK_FORMAT_R32G32B32A32_SFLOAT) ? Pixel.rgbaf32 : 0 ]
    if [ channels ]
        switch [ pixel ]
        case Pixel.rgbaf32
            channels = 4
        case Pixel.rgba8
            channels = 4
        case Pixel.rgb8
            channels = 3
        case Pixel.f32
            channels = 1
        case Pixel.u8
            channels = 1
        default
            channels = 0
    return pixel


    
func pbr_defaults [] -> PbrMetallicRoughness
    static pbr: PbrMetallicRoughness
    if [ !pbr ]
        pbr = PbrMetallicRoughness[]
        pbr.baseColorFactor            = vec4f [ 1, 0, 0, 1 ]
        pbr.metallicFactor             = 1.0
        pbr.roughnessFactor            = 1.0
        pbr.emissiveFactor             = vec3f [ 0, 0, 0 ]
        pbr.diffuseFactor              = vec4f [ 1, 1, 1, 1 ]
        pbr.specularFactor             = vec3f [ 1, 1, 1 ]
        pbr.glossinessFactor           = 1.0
        pbr.sheenColorFactor           = vec3f [ 0, 0, 0 ]
        pbr.sheenRoughnessFactor       = 0.0
        pbr.clearcoatFactor            = 0.0
        pbr.clearcoatRoughnessFactor   = 0.0
        pbr.transmissionFactor         = 0.0
        pbr.thicknessFactor            = 0.0
        pbr.attenuationColor           = vec3f [ 1, 1, 1 ]
        pbr.attenuationDistance        = 1e20
        pbr.ior                        = 1.5
        pbr.specularColorFactor        = vec3f [ 1, 1, 1 ]
        pbr.emissiveStrength           = 1.0
        pbr.iridescenceFactor          = 0.0
        pbr.iridescenceIor             = 1.3
        pbr.iridescenceThicknessMinimum = 100.0
        pbr.iridescenceThicknessMaximum = 400.0
    return pbr


func Surface_resources [ surface_enum_type: Au_t, surface_value: Surface, meta_type: Au_t, p: Pipeline ] -> array gpu
    res: gpu
    result: array gpu [ alloc: 32 ]

    # only resolve named samplers if the LayoutBinding is on the standard
    # Surface enum — other enums (e.g. CanvasUISurface) just need a dummy
    # binding so descriptor set creation succeeds.
    is_surface_enum: bool [ surface_enum_type == typeid[ Surface ] ]

    for [ img: Image, name: string ] in p.samplers
        ia: Au.evalue[ surface_enum_type, name ]
        tx: Texture [ img inherits Texture ]
        re: Render  [ img inherits Render ]
        if [ re ]
            tx = re.color
        if [ ia == surface_value ]
            expect tx || (img inherits Image), "expected Texture or Image"
            res = gpu [ vk: p.vk, name: Au.estring[ surface_enum_type, surface_value ],
                sampler: (tx) ? tx.hold[] : img.hold[] ]
            result.push[ res ]
    
    pbr_default: PbrMetallicRoughness [ pbr_defaults[] ]
    pbr:         PbrMetallicRoughness [ (p.material) ? p.material.pbrMetallicRoughness : pbr_default ]
    s:           shader [ p.s ]
    
    if [ !result.count ]
        f_normal: rgbaf [ 0.5, 0.5, 1.0, 1.0 ]
        f_zero:   rgbaf [ 0.0, 0.0, 0.0, 0.0 ]
        f_one:    rgbaf [ 1.0, 1.0, 1.0, 1.0 ]
        f_color:  rgbaf [
            pbr.baseColorFactor.x,
            pbr.baseColorFactor.y,
            pbr.baseColorFactor.z,
            pbr.baseColorFactor.w ]
        one:      i64 1
        single:   shape.shape_from[ 1, ref one ]
        if [ !is_surface_enum ]
            # not a Surface enum (e.g. CanvasUISurface.atlas/.image): the
            # int value of surface_value is meaningless to the Surface switch
            # below — atlas=0 would alias Surface.none, image=1 would alias
            # Surface.color, and we'd materialize the wrong PBR sampler. Bind
            # a single 1x1 dummy texture whose texel TYPE matches the
            # LayoutBinding's declared format, so the Vulkan image format
            # the gpu helper picks (via Texture's `sampler inherits ref T`
            # dispatch in placeholder_image) matches what the shader expects.
            # placeholder_image's data_i8 branch now accepts both ref i8 and
            # ref u8 — allocate the LayoutBinding's declared format directly.
            if [ meta_type == typeid[ u8 ] || meta_type == typeid[ i8 ] ]
                res = gpu [ vk: p.vk, name: "dummy_u8",
                    sampler: new u8 [ 1 ] [ u8 255 ] ]
            el [ meta_type == typeid[ rgba8 ] ]
                white_rgba8: rgba8 [ 255, 255, 255, 255 ]
                res = gpu [ vk: p.vk, name: "dummy_rgba8",
                    sampler: new rgba8 [ 1 ] [ white_rgba8 ] ]
            el [ meta_type == typeid[ f32 ] ]
                res = gpu [ vk: p.vk, name: "dummy_f32",
                    sampler: new f32 [ 1 ] [ 1.0 ] ]
            el
                res = gpu [ vk: p.vk, name: "dummy",
                    sampler: new rgbaf [ 1 ] [ f_one ] ]
        el
            switch [ surface_value ]
            case Surface.normal
                res = gpu [ vk: p.vk, name: "normal",   sampler: new rgbaf [ 1 ] [ f_normal ] ]
            case Surface.metal
                res = gpu [ vk: p.vk, name: "metal",    sampler:  new f32 [ 1 ] [ pbr.metallicFactor ] ]
            case Surface.rough
                res = gpu [ vk: p.vk, name: "rough",    sampler: new f32 [ 1 ] [ pbr.roughnessFactor ] ]
            case Surface.emission
                expect pbr.emissiveStrength / 8.0 <= 1.0, "refactor emissiveStrength"
                res = gpu [ vk: p.vk, name: "emission", sampler: new rgbaf [ single ] [ f_zero ] ]
            case Surface.height
                res = gpu [ vk: p.vk, name: "height",   sampler: new f32 [ single ] [ 0.5 ] ]
            case Surface.ao
                res = gpu [ vk: p.vk, name: "ao",       sampler: new f32 [ single ] [ 1.0 ] ]
            case Surface.ior
                res = gpu [ vk: p.vk, name: "ior",      sampler: new f32 [ single ] [ pbr.ior ] ]
            case Surface.color
                res = gpu [ vk: p.vk, name: "color",    sampler: new rgbaf [ single ] [ f_color ] ]
            case Surface.environment
                res = gpu [ vk: p.vk, name: "environment", sampler: new rgbaf [ single ] [ f_one ] ]
            default
                res = gpu [ vk: p.vk, name: "dummy",
                    sampler: new rgbaf [ single ] [ f_one ] ]
        result.push[ res ]
    return result


# --- GLFW callbacks ---
intern func handle_glfw_framebuffer_size [ glfw_window: ref GLFWwindow, width: i32, height: i32 ]
    if [ width == 0 && height == 0 ]
        return
    w: (glfwGetWindowUserPointer[ glfw_window ] to Display)
    if [ !w ]
        return
    w.pending_w     = width
    w.pending_h     = height
    w.last_resize_t = glfwGetTime[]
    if [ !w.in_callback_draw ]
        w.in_callback_draw = true
        w.draw[]
        w.in_callback_draw = false


intern func handle_glfw_key [ win: ref GLFWwindow, key: i32, scan_code: i32, action: i32, mods: i32 ] 
    w: (glfwGetWindowUserPointer[ win ] to Window)
    if [ action == GLFW_PRESS && (key == GLFW_KEY_UP || key == GLFW_KEY_DOWN) ]
        w.debug_value += (key == GLFW_KEY_UP) ? 1.0 : -1.0
    w.ev.clear[]
    w.ev.key.unicode   = key
    w.ev.key.scan_code = scan_code
    w.ev.key.state     = action == GLFW_PRESS
    w.ev.key.meta      = (mods & GLFW_MOD_SUPER) != 0
    w.ev.key.shift     = (mods & GLFW_MOD_SHIFT) != 0
    w.ev.key.alt       = (mods & GLFW_MOD_ALT)   != 0
    w.key_event[ w.ev ]


intern func handle_glfw_scroll [ win: ref GLFWwindow, x: f64, y: f64 ] 
    w: (glfwGetWindowUserPointer[ win ] to Window)
    w.ev.clear[]
    w.ev.mouse.pos.x         = w.mouse.x
    w.ev.mouse.pos.y         = w.mouse.y
    w.ev.mouse.wheel_delta.y = y
    w.wheel_event[ w.ev ]


intern func handle_glfw_mouse [ win: ref GLFWwindow, id: i32, action: i32, mods: i32 ] 
    w: (glfwGetWindowUserPointer[ win ] to Window)
    w.ev.clear[]
    w.ev.mouse.pos.x  = w.mouse.x
    w.ev.mouse.pos.y  = w.mouse.y
    w.ev.mouse.button = id - GLFW_MOUSE_BUTTON_LEFT
    w.ev.mouse.state  = action == GLFW_PRESS
    if [ w.ev.mouse.state ]
        w.press_event[ w.ev ]
    el
        w.release_event[ w.ev ]


intern func handle_glfw_char [ win: ref GLFWwindow, code_point: u32 ] 
    w: (glfwGetWindowUserPointer[ win ] to Window)
    #expect !w.ev.key.text, "unexpected text state"
    w.ev.clear[]
    w.ev.key.text = i32[ code_point ]
    w.text_event[ w.ev ]


intern func handle_glfw_cursor [ win: ref GLFWwindow, x: f64, y: f64 ] 
    w: (glfwGetWindowUserPointer[ win ] to Window)
    w.ev.clear[]
    w.mouse.x = x
    w.mouse.y = y
    w.ev.mouse.pos.x = w.mouse.x
    w.ev.mouse.pos.y = w.mouse.y
    w.move_event[ w.ev ]


func get_required_extensions [ vk: vk_context ] 
    count : u32 0
    glfw_extensions: ref symbol [ glfwGetRequiredInstanceExtensions[ ref count ] ]
    result: new symbol [ count + 4 ]
    memcpy[ result, glfw_extensions, count * sizeof[ symbol ] ]
    ifdef [ apple ]
        result[count] = "VK_KHR_portability_enumeration"
        count += 1
        result[count] = "VK_KHR_get_physical_device_properties2"
        count += 1
    ifdef [ debug ]
        result[count] = VK_EXT_DEBUG_UTILS_EXTENSION_NAME
        count += 1
    verbose: getenv[ "VERBOSE" ] != null
    for [ i: i32 0, i < count, i += 1 ]
        vk.instance_exts.push strdup[ result[i] ]
        printf "instance extension: %s\n", vk.instance_exts[i]


func model_init_pipeline [ m: Model, n: Node, prim: Primitive, s: shader ] 
    mdl:      m.id
    vk:       m.vk
    r:        m.r
    vbo:      gpu    [ null ]
    mdl_mat:  mat4f.identity[]
    material: Material [ null ]

    if [ n ]
        members: new vertex_member_t [ 16 ]
        name:    (prim && prim.name) ? prim.name : string[ 'default' ]
        indices: prim.indices
        ai:      mdl.accessors[ indices ]
        mat_id:  prim.material
        itype:   Au_t[ ai.member_type[ ] ]

        iview:   mdl.bufferViews[ ai.bufferView ]
        ibuffer: mdl.buffers[ iview.buffer ]
        material = (mdl.materials && mdl.materials.count > mat_id) ?
            mdl.materials[ mat_id ] :
            (mdl.materials) ? mdl.materials.first_element[] : null
        index:        0
        vertex_size:  0
        vertex_count: 0
        member_count: 0
        index_size:   itype.typesize
        index_count:  i32[ iview.byteLength / itype.typesize ]

        for [ value:ref i64, a_name:string ] in prim.attributes
            ac_index: value[0]
            ac:       mdl.accessors[ ac_index ]
            bv:       mdl.bufferViews[ ac.bufferView ]
            b:        mdl.buffers[ bv.buffer ]
            members[member_count].src    = ac.member_type[ ]
            members[member_count].ac     = ac
            members[member_count].size   = members[member_count].src.typesize
            members[member_count].offset = vertex_size
            vertex_size += members[member_count].src.typesize 
            expect ac.count, "count not set on accessor"
            expect !vertex_count || ac.count == vertex_count, "invalid vbo data"
            vertex_count = ac.count
            member_count += 1
        
        vbo = gpu [ vk: vk, name: name,
            members: members, member_count: member_count,
            vertex_size: vertex_size, vertex_count: vertex_count,
            index_size: index_size, index_count: index_count ]
        
        vdata: ref i8 [ vbo.vertex_data ]
        idata: ref i8 [ vbo.index_data ]

        for [ k: 0, k < member_count, k += 1 ]
            mem:        ref members[k]
            bv:         mdl.bufferViews[ mem.ac.bufferView ]
            b:          mdl.buffers[ bv.buffer ]
            src_base:   ref i8[b.data]
            src:        ref src_base[bv.byteOffset]
            stride:     mem.ac.stride

            for [ j: 0, j < vertex_count, j += 1 ]
                data_dst: ref vdata[j * vertex_size + mem.offset]
                dst:  ref i8[data_dst]
                data_src: ref src[j * stride]
                src0: ref i8[data_src]
                memcpy[ dst, src0, mem.size ]

        view:  ref i8[ibuffer.data]
        i_src: ref view [ iview.byteOffset  ]

        memcpy[ idata, i_src, iview.byteLength ]

        if [ n.scale.x != 0 || n.scale.y != 0 || n.scale.z != 0 ]
            mdl_mat = mdl_mat.scale[ n.scale ]
        
        mdl_mat = mdl_mat.rotate[ n.rotation ]
        mdl_mat = mdl_mat.translate[ n.translation ]
    
    s_type : typeid[ s ]
    pipe: Pipeline [ vk: vk, w: m.w, name: (n) ? n.name : null,
        r: m.r, s: s, vbo: vbo, default_model: mdl_mat,
        material: material, samplers: m.samplers,
        straight_alpha: m.straight_alpha ]

    m.pipelines.push[ pipe ]


func environment [ vk: vk_context, img: Image, r_axis: vec3f, rotation: f32 ] -> Texture
    ii:2
    if [ img.user ]
        return img.user
    size: 256
    mip_levels: 8
    cube_count: mip_levels
    w: Display [ vk: vk, format: Pixel.rgbaf32, backbuffer: true, width: size, height: size ]
    w.resize[ w.extent.width, w.extent.height ]
    clone2: Image [
        source: img.vdata[], width: img.width, height: img.height,
        format: Pixel.rgbaf32, surface: Surface.color ]
    gltf_path: path 'models/env.gltf'
    mdl_data:  GltfModel [ gltf_path.load[ typeid[ GltfModel ], null ] ]
    e:         Env [ vk: vk, name: 'env' ]
    samplers:  map Image[string] [ 'color': clone2 ]
    m_env:     Model [ vk: vk, w: w, id: mdl_data, s: e, samplers: samplers ]
    r_env:     Render [ vk: vk, w: w, width: size, height: size, models: [ m_env ] ]
    e.proj = mat4f.perspective[ radians[ 90.0 ], 1.0, 0.1, 10.0 ]
    dirs: local vec3f[6]
    dirs[0] = vec3f [  1,  0,  0 ]
    dirs[1] = vec3f [ -1,  0,  0 ]
    dirs[2] = vec3f [  0,  1,  0 ]
    dirs[3] = vec3f [  0, -1,  0 ]
    dirs[4] = vec3f [  0,  0,  1 ]
    dirs[5] = vec3f [  0,  0, -1 ]
    ups: local vec3f[6]
    ups[0] = vec3f [  0, -1,  0 ]
    ups[1] = vec3f [  0, -1,  0 ]
    ups[2] = vec3f [  0,  0,  1 ]
    ups[3] = vec3f [  0,  0, -1 ]
    ups[4] = vec3f [  0, -1,  0 ]
    ups[5] = vec3f [  0, -1,  0 ]
    eye: vec3f [ 0, 0, 0 ]
    vk_image:   local VkImage[2]
    vma_alloc:  local VmaAllocation[2]
    image_info: VkImageCreateInfo [
        sType:         VK_STRUCTURE_TYPE_IMAGE_CREATE_INFO,
        imageType:     VK_IMAGE_TYPE_2D,
        format:        w.surface_format.format,
        extent:        VkExtent3D [ w.width, w.height, 1 ],
        mipLevels:     mip_levels,
        samples:       VK_SAMPLE_COUNT_1_BIT,
        tiling:        VK_IMAGE_TILING_OPTIMAL,
        usage:         VK_IMAGE_USAGE_SAMPLED_BIT | VK_IMAGE_USAGE_TRANSFER_DST_BIT | VK_IMAGE_USAGE_TRANSFER_SRC_BIT,
        flags:         VK_IMAGE_CREATE_CUBE_COMPATIBLE_BIT,
        initialLayout: VK_IMAGE_LAYOUT_UNDEFINED
    ]
    alloc_info: VmaAllocationCreateInfo [ usage: VMA_MEMORY_USAGE_AUTO_PREFER_DEVICE ]
    for [ i: 0, i < 2, i += 1 ]
        image_info.arrayLayers = (i == 0) ? 6 : 6 * cube_count
        res: vmaCreateImage[ vk.allocator, image_info, alloc_info, ref vk_image[i], ref vma_alloc[i], null ]
        expect res == VK_SUCCESS, "could not create image with vmaCreateImage"
    cmd: Command [ vk: vk ]
    w.list = array Render [ r_env ]
    # last_render is now computed from list

    for [ f: 0, f < 6, f += 1 ]
        e.view = mat4f.look_at[ eye, dirs[f], ups[f] ]
        w.draw[]
        final: w.last_render[]
        final.color.transition[ VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL ]
        vki : vk_image[0]
        vk.transition_image_layout vki, VK_IMAGE_LAYOUT_UNDEFINED, VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 0, 1, f, 1, false
        region: VkImageCopy [
            srcSubresource: VkImageSubresourceLayers [ aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: 0, baseArrayLayer: 0, layerCount: 1 ],
            dstSubresource: VkImageSubresourceLayers [ aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: 0, baseArrayLayer: f, layerCount: 1 ],
            extent:         VkExtent3D [ size, size, 1 ]]
        cmd.begin[ ]
        vkCmdCopyImage[ cmd.cmd,
            final.color.vk_image, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
            vk_image[0], VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
            1, ref region ]
        cmd.submit[ ]
        final.color.transition[ VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]

    vk.create_mipmaps vk_image[0], size, size, mip_levels, 6
    cube: Texture [ vk: vk, vk_image: vk_image[0], surface: Surface.environment,
        vk_format: w.surface_format.format, mip_levels: mip_levels, layer_count: 6 ]
    conv_shader: Convolve [ vk: vk, name: 'conv', proj: e.proj ]
    conv_samplers: map Au[string] [ 'environment': cube ] # Texture, or Render? -- its going to convert
    m_conv: Model [ vk: vk, w: w, id: mdl_data, s: conv_shader, samplers: conv_samplers ]
    r_conv: Render [ vk: vk, w: w, width: size, height: size, models: [ m_conv ] ]
    v: vec4f [ r_axis.x, r_axis.y, r_axis.z, radians[ 90.0 ] ]
    q: quatf [ v ]
    conv_shader.env = mat4f.identity[]
    conv_shader.env = conv_shader.env.rotate[ q ]
    w.list = [ r_conv ]
    # last_render is now computed from list
    for [ a_i: 0, a_i < cube_count, a_i += 1 ]
        roughness: f32[ a_i ] / f32[ mip_levels - 1 ]
        conv_shader.roughness_samples = vec2f [ roughness, 1024.0 ]
        for [ f: 0, f < 6, f += 1 ]
            face_id: a_i * 6 + f
            conv_shader.view = mat4f.look_at[ eye, dirs[f], ups[f] ]
            final: w.last_render[]
            w.draw[]
            final.color.transition[ VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL ]
            vk.transition_image_layout vk_image[1],
                VK_IMAGE_LAYOUT_UNDEFINED,
                VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, 0, 1, face_id, 1, false
            region: VkImageCopy [
                srcSubresource: VkImageSubresourceLayers [ aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: 0, baseArrayLayer: 0,       layerCount: 1 ],
                dstSubresource: VkImageSubresourceLayers [ aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: 0, baseArrayLayer: face_id, layerCount: 1 ],
                extent:         VkExtent3D [ size, size, 1 ]
            ]
            cmd.begin[]
            vkCmdCopyImage[ cmd.cmd,
                final.color.vk_image, VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                vk_image[1], VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                1, ref region ]
            cmd.submit[]
            for [ mi: u32 1, mi < mip_levels, mi += 1 ]
                mip_size_src: size >> (mi - 1)
                mip_size_dst: size >> mi
                vk.transition_image_layout vk_image[1],
                    (mi == 1) ? VK_IMAGE_LAYOUT_UNDEFINED : VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                    VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL, mi - 1, 1, face_id, 1, false
                vk.transition_image_layout vk_image[1],
                    VK_IMAGE_LAYOUT_UNDEFINED,
                    VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL, mi, 1, face_id, 1, false
                cmd.begin[]
                vkCmdBlitImage[ cmd.cmd,
                    vk_image[1], VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                    vk_image[1], VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL,
                    1, VkImageBlit [
                        srcSubresource: VkImageSubresourceLayers [
                            aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: mi - 1, baseArrayLayer: face_id, layerCount: 1 ],
                        srcOffsets: [ VkOffset3D [ 0, 0, 0 ], VkOffset3D [ mip_size_src, mip_size_src, 1 ] ],
                        dstSubresource: VkImageSubresourceLayers [
                            aspectMask: VK_IMAGE_ASPECT_COLOR_BIT, mipLevel: mi, baseArrayLayer: face_id, layerCount: 1 ],
                        dstOffsets: [ VkOffset3D [ 0, 0, 0 ], VkOffset3D [ mip_size_dst, mip_size_dst, 1 ] ]
                    ], VK_FILTER_LINEAR ]
                cmd.submit[]
            final.color.transition[ VK_IMAGE_LAYOUT_COLOR_ATTACHMENT_OPTIMAL ]
    for [ face_id: 0, face_id < 6 * cube_count, face_id += 1 ]
        for [ mi: 0, mi < mip_levels, mi += 1 ]
            vk.transition_image_layout vk_image[1],
                (mi == mip_levels - 1) ?
                    VK_IMAGE_LAYOUT_TRANSFER_DST_OPTIMAL :
                    VK_IMAGE_LAYOUT_TRANSFER_SRC_OPTIMAL,
                VK_IMAGE_LAYOUT_SHADER_READ_ONLY_OPTIMAL,
                mi, 1, face_id, 1, false
    convolve: Texture [ vk: vk, vk_image: vk_image[1], vma_alloc: vma_alloc[1],
        surface: Surface.environment, vk_format: w.surface_format.format,
        mip_levels: mip_levels, layer_count: 6 * cube_count  ]
    #cmd.drop[  ]
    #w.drop[ ]
    #cube.drop[ ]
    #cllone.drop[ ]
    img.user = convolve.hold[ ]
    return img.user


func is_uniform_field [ mem: Au_t ] -> bool
    return mem.member_type == 4 && mem.access_type == (0,2,3,4) && bool[mem.src] && !(mem.traits & (1 << 56))

func uniform_size [ type: Au_t ] -> num
    total: num [ 0 ]
    ty: Au_t [ type ]
    while [ ty ]
        for [ m: 0, m < ty.members.count, m += 1 ]
            mem: Au_t [ ty.members.origin[m] ]
            if [ is_uniform_field[ mem ] ]
                total += mem.src.typesize
        ty = ty.context
        if [ ty == typeid[ shader ] ]
            break
    return total


func placeholder_image [ sampler: object, size: i32, fill: ref u8, sampler_size: ref i32, format: ref Pixel ]
    cl : typeid[sampler]
    s: i32 [ size * size ]

    if [ cl == typeid[f32] ]
        data_f32: ref f32 [ sampler ]
        f32_fill: ref f32 [ ref fill ]
        for [ i: 0, i < s, i += 1 ]
            f32_fill[i] = data_f32[0]
        format = Pixel.f32
        sampler_size = s * sizeof[ f32 ]
    el [ cl == (typeid[i8], typeid[u8]) ]
        data_i8:    ref i8    [ sampler ]
        data_u8:    ref u8    [ sampler ]
        u8_fill: ref u8 [ ref fill ]
        for [ i: 0, i < s, i += 1 ]
            u8_fill[i] = data_i8[0]
        format = Pixel.u8
        sampler_size = s * sizeof[ i8 ]
    el [ cl == typeid[rgbf] ]
        data_rgbf:  ref rgbf  [ sampler ]
        v3_fill: ref rgbf [ ref fill ]
        for [ i: 0, i < s, i += 1 ]
            v3_fill[i] = data_rgbf[0]
        format = Pixel.rgbf32
        sampler_size = s * sizeof[ rgbf ]
    el [ cl == typeid[rgb8] ]
        data_rgb8:  ref rgb8 [ sampler ]
        v3_fill: ref rgb8 [ ref fill ]
        for [ i: 0, i < s, i += 1 ]
            v3_fill[i] = data_rgb8[0]
        format = Pixel.rgb8
        sampler_size = s * sizeof[ rgb8 ]
    el [ cl == typeid[rgbaf] ]
        data_rgbaf:  ref rgbaf  [ sampler ]
        v4_fill: ref rgbaf [ ref fill ]
        for [ i: 0, i < s, i += 1 ]
            v4_fill[i] = data_rgbaf[0]
        format = Pixel.rgbaf32
        sampler_size = s * sizeof[ rgbaf ]
    el [ cl == typeid[rgba8] ]
        data_rgba8:  ref rgba8  [ sampler ]
        v4_fill: ref rgba8 [ ref fill ]
        for [ i: 0, i < s, i += 1 ]
            v4_fill[i] = data_rgba8[0]
        format = Pixel.rgba8
        sampler_size = s * sizeof[ rgba8 ]
    el
        fault "sampler data required"





# enums export to A-type
enum Ease
    linear  : 0
    quad    : 1
    cubic   : 2
    quart   : 3
    quint   : 4
    sine    : 5
    expo    : 6
    circ    : 7
    back    : 8
    elastic : 9
    bounce  : 10

enum Direction
    inward  : 0
    outward : 1
    in_out  : 2

enum Duration
    ms : 2
    ns : 1
    s  : 3

enum XAlign : f32
    undefined : 0
    left      : 0.0
    middle    : 0.5
    right     : 1.0
    width     : 2.0

enum YAlign : f32
    undefined : 0
    top       : 0.0
    middle    : 0.5
    bottom    : 1.0
    height    : 2.0

enum Overflow
    clip     : 0
    ellipsis : 1
    visible  : 2
    wrap     : 3

enum UXSurface
    background  : 0
    frost       : 1
    blur        : 2
    compose     : 3
    colorize    : 4
    overlay     : 5

enum Fill : f32
    none      : 0.00f
    blur      : 0.50f
    frost     : 1.00

enum CanvasType
    screen      : 0
    compose     : 1
    colorize    : 2

enum Pattern
    none : 0
    repeat_x : 1
    repeat_y : 2
    repeat_xy : 3

enum Clip
    none : 0
    clip : 1
    ellipsis : 2


alias Elements : map    element [ string ]
alias FRender  : lambda Elements[ Display ]

# this Au type indicates we do not have an 'init' called
ielement element
    mutable parent          : element
    mutable area            : Region
    mutable bounds          : rect
    mutable value           : object
    mutable id              : string
    mutable flags           : i64
    mutable label           : string
    mutable layers          : map Layer[string]
    mutable elements        : Elements
    mutable tags            : array string
    mutable group           : string
    mutable tab_index    : i32
    mutable scroll       : vec2f
    mutable ghost        : bool
    mutable captured     : bool
    mutable selectable   : bool
    mutable selected     : bool
    mutable disabled     : bool
    mutable hovered      : bool
    mutable pressed      : bool
    mutable focused      : bool
    # focusable = true lets the window transfer focus to this element on
    # mouse-press. containers/decorations default to false; buttons and
    # text controls opt in.
    public  focusable    : bool
    public cursor       : vec2f
    intern ux           : Window

    # input event hooks. return true to swallow; false to let the window
    # continue to the app-level handler. both element and the app get a
    # chance at each event: element first, then app_object.
    public func on_click   [ ev: Event ] -> bool  return false
    public func on_press   [ ev: Event ] -> bool  return false
    public func on_release [ ev: Event ] -> bool  return false
    public func on_hover   [ ev: Event ] -> bool  return false
    public func on_leave   [ ev: Event ] -> bool  return false
    public func on_move    [ ev: Event ] -> bool  return false
    public func on_wheel   [ ev: Event ] -> bool  return false
    public func on_key     [ ev: Event ] -> bool  return false
    public func on_char    [ ev: Event ] -> bool  return false
    intern style_avail  : map StyleEntries[string]
    #intern selections   : map
    intern transitions  : map StyleTransition[string]
    intern restyle : bool

    public func set_capture []
        ux.set_capture[ a ]

    public func release_capture []
        ux.release_capture[ a ]

    public func set_focus []
        ux.set_focus[ a ]

    public func release_focus []
        ux.release_focus[ a ]

    public func draw [ w: Window ]
        return

    public func render [ ] -> Elements
        return null

    func invalidate_element [ ]
        e : a
        if [ e && e.transitions ]
            for [ ct: StyleTransition, k: string ] in e.transitions
                ct.invalidate = true

    func remove_invalid_transitions [ ]
        e: a
        found : true
        while [ found ]
            found = false
            for [ ct:StyleTransition, k:object ] in e.transitions
                if [ ct.invalidate ]
                    e.transitions.rm[ k ]
                    found = true
                    return

    intern func animate_within [ ]
        if [ transitions ]
            cur_millis : i64 [ epoch_millis[] ]
            for [ ct: StyleTransition, k: string ] in transitions
                dur : i64 [ ct.duration.get_millis[] ]
                ms  : i64 [ cur_millis - ct.start ]
                p   : f64 [ ct.pos[ f64[ ms ] / f64[ dur ] ] ]
                if [ ct.type && ct.from && ct.to ]
                    from_t : typeid[ ct.from ]
                    mixed : ct.from.mix*[ ct.to, p ]
                    if [ ct.location ]
                        ct.location = mixed
        for [ ee: element, id: string ] in elements
            ee.animate_within[ ]


alias StyleTransitions : map StyleTransition[string]


Display Window
    
    mutable app_object          : trinity*

    public compose              : Canvas
    public colorize             : Canvas
    public overlay              : Canvas
    public glyph                : Canvas
    public screen               : Canvas

    public background           : Render

    mutable m_reduce             : Model
    mutable r_reduce             : Render
    mutable m_reduce0            : Model
    mutable r_reduce0            : Render
    mutable m_reduce1            : Model
    mutable r_reduce1            : Render
    mutable m_reduce2            : Model
    mutable r_reduce2            : Render
    mutable m_reduce3            : Model
    mutable r_reduce3            : Render
    mutable m_blur_v             : Model
    mutable r_blur_v             : Render
    mutable m_blur               : Model
    mutable r_blur               : Render
    mutable m_frost_v            : Model
    mutable r_frost_v            : Render
    mutable m_frost              : Model
    mutable r_frost              : Render
    mutable m_view               : Model
    mutable r_view               : Render

    mutable is_setup             : bool
    mutable user_compose         : bool


    intern root_styles          : map Style[string]
    public root                 : element
    mutable capture             : element
    mutable focus               : element
    mutable hovered             : element
    mutable action_pressed      : element
    mutable context_pressed     : element
    mutable restyle             : bool
    mutable mouse               : vec2f
    mutable shift               : bool
    mutable alt                 : bool
    public st                   : Style


    public func apply_args [ inst: element, e: element ] -> bool
        ty      : typeid[ e ]
        changed : false
        while [ ty != typeid[ Au ] ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                mem : Au_t ty.members.origin[m]
                if [ mem.member_type != AU_MEMBER_VAR || mem.ident == 'elements' ]
                    continue
                
                # if property not set on the newly created element, this is a default value (does not apply)
                is_set   : e.AF_get_member[mem]
                if [ !is_set ]
                    continue
                
                # when user set, these apply if different
                from_val : inst.member_object[ mem ]
                to_val   :    e.member_object[ mem ]
                if [ is_set && to_val && from_val != to_val ]
                    if [ from_val.compare[ to_val ] != 0 ]
                        inst.member_set[ mem, to_val ]
                        changed = true
                
            ty = ty.context
        return changed

    
    public func transition_or_set [ inst: element, value_holder:Au, cur:Au, member:Au_t, prop:string, best:StyleEntry ]
        # transition handling
        t  : best.trans
        ct : StyleTransition
        should_trans : false
        if [ t ]
            if [ !inst.transitions ]
                inst.transitions = StyleTransitions [ ]
            ct = inst.transitions[ prop ]
            if [ !ct ]
                ct = t.copy[]
                ct.reference = t
                should_trans = true
                inst.transitions[ prop ] = ct
            el
                should_trans = ct.reference != t
        el [ inst.transitions ]
            inst.transitions.rm[ prop ]
        
        if [ ct && should_trans ]
            ct.from     = (cur) ? cur : best.instance
            ct.to       = best.instance
            ct.type     = typeid[ best.instance ]
            ct.start    = epoch_millis[]
        el [ !ct ]
            value_holder.member_set[ member, best.instance ]
    
    
    public func apply_style [ inst: element, style_avail: map StyleEntries[string] ]
        ty      : Au_t [ typeid[ inst ] ]
        while [ ty != typeid[ Au ] ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                member : Au_t ty.members.origin[m]
                if [ member.member_type != AU_MEMBER_VAR || member.ident == 'elements' ]
                    continue
                prop    : string [ member.ident ]
                entries : style_avail [ prop ]
                if [ !entries ]
                    continue
                first : (entries[0] to StyleEntry)

                # we sometimes have to create a map for 'layers' as well as a Layer instance inside
                if [ first.bl.property && first.bl.key ]
                    member_map : Au_t
                    member_container : map Layer[string]
                    # find the layers member Au_t
                    member_map = Au.find_member [ typeid[inst], first.bl.property.chars, AU_MEMBER_VAR, 0, true ]
                    expect member_map, 'member not found on {ty.ident}: {first.bl.property}'
                    member_container = inst.member_object[ member_map ]
                    inner_inst_type : member_map.meta.a # Layer

                    # create new map if null
                    if [!member_container]
                        member_container = map Layer[string][]
                        inst.member_set[member_map, member_container]

                    for [ best : StyleEntry ] in entries

                        if [ best.bl.score[ inst, true ] == 0 ]
                            continue
                        
                        # find layer by name (key), creating a default if not found
                        layer_inst : member_container.get[best.bl.key]
                        if [!layer_inst]
                            layer_inst = Au.new_object[inner_inst_type, null, null]
                            member_container.set[best.bl.key, layer_inst]
                        
                        layer_debug : Layer [ member_container.get[best.bl.key] ]

                        layer_member : Au.find_member[ inner_inst_type, best.member, AU_MEMBER_VAR, 0, true ]
                        expect layer_member, 'member not found on {inner_inst_type.ident}: {best.member}'
                       
                        if [ !best.instance ]
                            best.instance = (best.value to layer_member.src)

                        cur : layer_inst.member_object[ layer_member ]
                        if [ !cur ]
                            cur = best.instance

                        transition_or_set[ inst, layer_inst, cur, layer_member, '{member.ident}.{best.member}', best ]
                        layer_member = layer_member

                el
                    best : st.best_match[ inst, prop, entries ]
                    if [ !best ]
                        continue

                    if [ !best.instance ]
                        best.instance = (best.value to member.src)

                    cur : inst.member_object[ member ]
                    if [ !cur ]
                        cur = best.instance

                    transition_or_set[ inst, inst, cur, member, prop, best ]
                
            ty = ty.context


    public func animate []
        if [ !root ]
            return
        invalidate[]
        root.animate_within[ ]
        remove_invalid[]

    func update_element [ parent: element, rendered: map element[string] ]
        if [!parent.elements] parent.elements = Elements[]

        # mark for umount
        for [ e:element, id:string ] in parent.elements
            e.flags |= 1

        # iterate through rendered elements
        for [ e:element, id:string ] in rendered
            instance : element* parent.elements[ id ]
            changed  : bool
            new_inst : false
            restyle  = restyle || e.restyle
            brand_new : false

            if [ instance ]
                instance.flags &= ~1
                if [ !instance.id ]
                    brand_new = true # component within element map

            if [ brand_new || !instance ]
                new_inst         = true
                restyle          = true
                instance         = (instance) ? instance : e.hold[]
                instance.id      = id
                instance.ux      = a
                instance.parent  = parent

                if [ !parent.elements ]
                    parent.elements = map element[string] [ ]

                if [ !brand_new ]
                    parent.elements[ id ] = instance

                instance.initialize[] # context can be given here
                instance.hold_members[]
                changed = true
            el [ instance.restyle ]
                instance.restyle = false
                changed = true
            el [ !restyle ]
                if [ instance inherits Button ]
                    test :  2
                    test += 2
                changed = apply_args[ instance, e ]

            if [ changed ]
                e.restyle = false
                avail  : st.compute[ instance ]
                apply_style[ instance, avail ]
                 
            inst: typeid[instance]
            irender : instance.render[]
            if [ !irender ] irender = instance.elements
            if [  irender ] update_element[ instance, irender ]

        # perform umount on elements not updated in render
        retry : true
        while [ retry ]
            retry = false
            for [ e:element, id:string ] in parent.elements
                if [ e.flags & 1 ]
                    e.flags  = 0
                    retry    = true
                    e.parent = null
                    e.drop_members[]
                    parent.elements.rm[ id ]
                    break

    public func update_all [ render: Elements ]
        restyle = false
        if [ !root ]
            root    = element [ id: string[ 'root' ] ]
            root_styles = st.compute[ root ]
            restyle = true
        if [ !restyle ]
            restyle = st.check_reload[]
        if [ restyle ]
            apply_style[ root, root_styles ]
        update_element[ root, render ]

    public func invalidate []
        if [ root ] root.invalidate_element[ ]

    public func remove_invalid []
        if [ root ] root.remove_invalid_transitions[ ]

    public func set_capture [ e: element ]
        if [ capture != e ]
            if [ capture ]
                capture.captured = false
                capture.restyle  = true
            if [ e && !e.ghost ]
                capture = e
                capture.captured = true
                capture.restyle  = true

    public func release_capture [ e: element ]
        if [ capture && capture == e ]
            capture = null

    public func set_focus [ e: element ]
        if [ focus != e ]
            if [ focus ]
                focus.focused = false
                focus.restyle = true
            if [ e && !e.ghost ]
                focus = e
                focus.focused = true
                focus.restyle = true

    public func release_focus [ e: element ]
        if [ focus && focus == e ]
            focus.focused = false
            focus.restyle = true
            focus = null

    public func find_target [ e: element, ev: Event, must: element ] -> element
        if [ !e || e.disabled || e.ghost ]
            return null
        b : rect  [ e.bounds ]
        x : f32   [ ev.mouse.pos.x ]
        y : f32   [ ev.mouse.pos.y ]
        lx : f32  [ x - b.x ]
        ly : f32  [ y - b.y ]
        if [ !must && (lx < 0.0 || ly < 0.0 || lx >= b.w || ly >= b.h) ]
            return null
        
        ev.mouse.pos.x = lx + e.scroll.x
        ev.mouse.pos.y = ly + e.scroll.y

        for [ child: element, id: string ] in e.elements
            hit : find_target[ child, ev, must ]
            t   : typeid[hit]
            if [ hit ]
                return hit
        
        ev.mouse.pos.x = x
        ev.mouse.pos.y = y
    
        return ( !must || must == e ) ? e : null

    public func text_event [ ev: Event ]
        ev.target = focus
        if [ focus && focus.on_char[ ev ] ] return
        if [ app_object && app_object.on_char[ ev ] ] return

    public func key_event [ ev: Event ]
        ev.target = focus
        if [ focus && focus.on_key[ ev ] ] return
        if [ app_object && app_object.on_key[ ev ] ] return

    # recursive bubble: from deepest element up through parents, each gets
    # a chance to consume. stops on first `true` return. after the element
    # chain, the app sees it; finally window's default handler runs (focus
    # transfer, capture, pressed/hovered bookkeeping) regardless of consume.
    public func move_event [ ev: Event ]
        f : element [ find_target[ root, ev, null ] ]
        m : element [ (capture) ? find_target[ root, ev, capture ] : f ]
        # hover / leave bubble — flip state bools and set restyle; the next
        # update_element pass picks up restyle and re-applies CSS.
        if [ hovered != f ]
            prev : element [ hovered ]
            if [ prev ]
                prev.hovered = false
                prev.restyle = true
                leave_consumed : bool [ false ]
                for [ e: element* prev, e && !leave_consumed, e = e.parent ]
                    ev.target = e
                    if [ e.on_leave[ ev ] ] leave_consumed = true
                if [ !leave_consumed && app_object ]
                    ev.target = prev
                    app_object.on_leave[ ev ]
            hovered = f
            if [ f ]
                if [ f inherits Button ]
                    test :  22
                    test += 22
                f.hovered = true
                f.restyle = true
                hover_consumed : bool [ false ]
                for [ e: element* f, e && !hover_consumed, e = e.parent ]
                    ev.target = e
                    if [ e.on_hover[ ev ] ] hover_consumed = true
                if [ !hover_consumed && app_object ]
                    ev.target = f
                    app_object.on_hover[ ev ]
        # move bubble
        if [ m ]
            move_consumed : bool [ false ]
            for [ e: element* m, e && !move_consumed, e = e.parent ]
                ev.target = e
                if [ e.on_move[ ev ] ] move_consumed = true
            if [ !move_consumed && app_object ]
                ev.target = m
                app_object.on_move[ ev ]

    public func wheel_event [ ev: Event ]
        target_el : element [ (capture) ? capture : (focus) ? focus : find_target[ root, ev, null ] ]
        consumed_w : bool [ false ]
        for [ e: element* target_el, e && !consumed_w, e = e.parent ]
            ev.target = e
            if [ e.on_wheel[ ev ] || ev.no_propagation ] consumed_w = true
        if [ !consumed_w && app_object ]
            ev.target = target_el
            app_object.on_wheel[ ev ]
        # window default: scroll focused/target element (no-op hook for now)

    public func press_event [ ev: Event ]
        release_capture[ capture ]
        f : find_target[ root, ev, null ]
        # element bubble. element* gives poly dispatch so subclasses
        # (Button, CameraView, ...) see their own on_press override.
        consumed_p : bool [ false ]
        for [ e: element* f, e && !consumed_p, e = e.parent ]
            cl : typeid[e]
            ev.target = e
            if [ e.on_press[ ev ] ] consumed_p = true
        
        au : typeid[ f ]
        # app
        if [ !consumed_p && app_object ]
            ev.target = f
            app_object.on_press[ ev ]
        # window defaults: focus transfer on left button (only focusable
        # elements get focus — buttons, text controls, etc. opt in), then
        # capture, then pressed/hovered state bookkeeping.
        if [ ev.mouse.button == 0 && f && f.focusable && !ev.no_default ]
            set_focus[ f ]
        if [ !capture ]
            set_capture[ f ]
        if [ ev.mouse.button == 0 ]
            if [ action_pressed ]
                action_pressed.restyle = true
                action_pressed.pressed = false
            if [ f ]
                f.restyle = true
                f.pressed = true
            action_pressed = f
        el [ ev.mouse.button == 1 ]
            context_pressed = f

    public func release_event [ ev: Event ]
        f : element [ find_target[ root, ev, capture ] ]
        consumed_r : bool [ false ]
        for [ e: element* f, e && !consumed_r, e = e.parent ]
            ev.target = e
            if [ e.on_release[ ev ] ] consumed_r = true
        if [ !consumed_r && app_object ]
            ev.target = f
            app_object.on_release[ ev ]
        if [ ev.mouse.button == 0 ]
            if [ action_pressed ]
                action_pressed.restyle = true
                action_pressed.pressed = false
            if [ f ]
                f.restyle = true
                f.pressed = false
            if [ f && action_pressed == f && f.hovered ]
                consumed_c : bool [ false ]
                for [ e: element* f, e && !consumed_c, e = e.parent ]
                    ev.target = e
                    if [ e.on_click[ ev ] ] consumed_c = true
                if [ !consumed_c && app_object ]
                    ev.target = f
                    app_object.on_click[ ev ]
            action_pressed  = null
            context_pressed = null
        el [ ev.mouse.button == 1 ]
            action_pressed  = null
            context_pressed = null
        if [ !action_pressed && !context_pressed ]
            release_capture[ capture ]
    
    func update [ ]

        compose = (compose || Canvas [ w:a, vk: vk, format: Pixel.rgba8, :width, :height ]).resize[ width, height ]
        compose.update[]
        compose.clear[ string[ "#888" ] ]

        # composite mode binds four canvas layers into UXBackground:
        #   compose  — main paint surface (rect/path/draw_text)
        #   colorize — hue-shift mask (UXBackground .g channel)
        #   overlay  — straight-alpha overlay layer
        #   glyph    — text glyph mask (UXBackground .x channel)
        # all four are allocated up front so the sampler set is fully
        # populated by the time m_view is built.
        colorize       = (colorize       || Canvas [ w:a, vk: vk, format: Pixel.rgba8, :width, :height ]).resize[ width, height ]
        overlay        = (overlay        || Canvas [ w:a, vk: vk, format: Pixel.rgba8, :width, :height ]).resize[ width, height ]
        glyph          = (glyph          || Canvas [ w:a, vk: vk, format: Pixel.u8,    :width, :height ]).resize[ width, height ]
        screen         = (screen         || Canvas [ w:a, vk: vk, format: Pixel.rgba8, load_existing: true, :width, :height ]).resize[ width, height ]

        colorize.update[]
        overlay .update[]
        glyph   .update[]
        screen  .update[]

        colorize.clear[ string[ "#000" ] ]
        overlay .clear[ string[ "#000" ] ]
        glyph   .clear[ string[ "#000" ] ]
        screen  .clear[ string[ "#000" ] ]

        if [ !is_setup ]
            is_setup = true
            vk: vk_context[ a.vk ]

            if [ app_object ]
                t : trinity[app_object]
                if [ t ]
                    t.load_scene*[]

            if [ !background ]
                background = Render [ vk: vk, w: a, wscale: 1.0,
                    clear_color: vec4f [ 0.05, 0.02, 0.08, 1.0 ] ]
                background.update[]
            
            m_reduce  = Model  [ w: a, samplers: map Texture[string] [ 'color': background.color ] ]
            r_reduce  = Render [ vk: vk, w: a, wscale: 1.0, models: array Model [ m_reduce ] ]

            m_reduce0 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce.color ] ]
            r_reduce0 = Render [ vk: vk, w: a, wscale: 0.5, models: array Model [ m_reduce0 ] ]

            m_reduce1 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce0.color ] ]
            r_reduce1 = Render [ vk: vk, w: a, wscale: 0.25, models: array Model [ m_reduce1 ] ]

            fbv : BlurV [ vk: vk, name: 'blur-v', reduction_scale: 4.0 ]
            m_blur_v  = Model  [ w: a, s: fbv, samplers: map Texture[string] [ 'color': r_reduce1.color ] ]
            r_blur_v  = Render [ vk: vk, w: a, wscale: 1.0, models: array Model [ m_blur_v ] ]

            fbl : Blur [ vk: vk, name: 'blur', reduction_scale: 4.0 ]
            m_blur    = Model  [ w: a, s: fbl, samplers: map Texture[string] [ 'color': r_blur_v.color ] ]
            r_blur    = Render [ vk: vk, w: a, wscale: 1.0, models: array Model [ m_blur ] ]

            m_reduce2 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce1.color ] ]
            r_reduce2 = Render [ vk: vk, w: a, wscale: 0.125, models: array Model [ m_reduce2 ] ]

            m_reduce3 = Model  [ w: a, samplers: map Texture[string] [ 'color': r_reduce2.color ] ]
            r_reduce3 = Render [ vk: vk, w: a, wscale: 0.0625, models: array Model [ m_reduce3 ] ]

            bv : BlurV [ vk: vk, name: 'blur-v', reduction_scale: 16.0 ]
            m_frost_v = Model  [ w: a,   s: bv, samplers: map Texture[string] [ 'color': r_reduce3.color ] ]
            r_frost_v = Render [ vk: vk, w: a, wscale: 1.0, models: array Model [ m_frost_v ] ]

            bl : Blur [ vk: vk, name: 'blur', reduction_scale: 16.0 ]
            m_frost   = Model  [ w: a,   s: bl, samplers: map Texture[string] [ 'color': r_frost_v.color ] ]
            r_frost   = Render [ vk: vk, w: a, wscale: 1.0, models: array Model [ m_frost ] ]

            m_view    = Model [ w: w, s: UXBackground [ vk: vk, name: 'ux' ],
                samplers: map Texture[string] [
                    'background':     background.color,
                    'frost':          r_frost.color,
                    'blur':           r_blur.color,
                    'compose':        compose.color,
                    'colorize':       colorize.color,
                    'overlay':        overlay.color
                ]
            ]

            r_view    = Render [ vk: vk, w: a,
                color: screen.color,
                wscale: 1.0, clear_color: vec4f [ 1.0, 1.0, 1.0, 1.0 ],
                models: array Model [ m_view ] ]

            ux_shader : UXBackground [ m_view.s ]
            ux_shader.low_color  = vec4f [ 0.0, 0.1, 0.2, 1.0 ]
            ux_shader.high_color = vec4f [ 1.0, 0.8, 0.8, 1.0 ]

            list = array Render [
                background, r_reduce, r_reduce0, r_reduce1, r_blur_v, r_blur,
                r_reduce2, r_reduce3, r_frost_v, r_frost,
                r_view ]



    public func resize [ w: i32, h: i32 ] -> Window
        super.resize[ w, h ]
        update[]
        return a

    mutable blur_anim : f32


    func on_compose []
        if [ !compose ] return
        
        compose.save    [ ]
        compose.clear   [ '#80a' ]
        update_all      [ app_object.on_render*[ a ] ]
        animate         [ ]
        draw_element    [ root, CanvasType.compose, null ]
        compose.paint   [ ]
        compose.sync_fence[ ]
        compose.restore [ ]
##
        compose.save[]
        compose.fill_color   [ '#808' ]
        compose.inner_glow   [ '#f04', 32 ]
        compose.inner_shadow [ '#f0a', 32 ]
        compose.outer_glow   [ '#f0c', 16 ]
        compose.outer_shadow [ '#f0c', 16 ]
        compose.rounded      [ 14.0, 14.0, 14.0, 14.0 ]
        compose.rect_to      [ 64.0, 64.0, 512.0, 512.0 ]
        compose.stroke_width [ 1.0 ]
        compose.stroke_color [ '#f00' ]
        compose.stroke_shadow[ '#f05' ]
        compose.paint[]
        compose.restore[]
##

    func on_screen []
        if [ !screen ] return

        screen.save[]
        
        app_object.on_canvas*[ screen ]

        draw_element[ root, CanvasType.screen, null ]
        ##
        screen.fill_color[ '#f00' ]
        screen.rect_to[ 64.0, 64.0, 240.0, 120.0 ]
        screen.fill_color[ "#fff" ]
        screen.font_size [ 32 ]
        screen.draw_text[
            "Aura",
            rect [ x: 128.0 + 128.0 + 24.0 + 8.0 - 0.5, y: 64.0 + 32.0 - 32.0 - 0.5, w: 64.0, h: 32.0 ],
            vec2f [ 0.5, 0.5 ],
            vec2f [ 0.0, 0.0 ],
            false ]
        ##
        screen.paint[]
        screen.sync_fence[]
        screen.restore[]

    public func draw_element [ e: element*, stage: CanvasType, last:element ]
        expect e inherits element, 'e is not an element'
        canvas_arr : new Canvas[3] [ screen, compose, colorize ]
        cv : canvas_arr[stage]
        rel : rect [ (e.parent) ?
            rect [ x: 0, y: 0, w: e.parent.bounds.w, h: e.parent.bounds.h ] :
            rect [ x: 0, y: 0, w: width, h: height ] ]

        # compute element bounds from its area
        if [ !e.area ]
            e.area = Region [ 0.0 ]
        e.bounds = e.area.rectangle[ rel, null, (last) ? last.bounds : null ]
        element_text : (e.label && e.label.count) ? e.label : null

        # compute layer bounds and draw each layer
        for [ layer: Layer, lkey: string ] in e.layers
            if [ layer.ctype != stage ]
                continue
            
            layer.bounds = (layer.area) ? layer.area.rectangle[ e.bounds, null, null ] : e.bounds
            layer.bounds.x -= e.bounds.x
            layer.bounds.y -= e.bounds.y
            
            b  : rect   [ layer.bounds ]
            rx : f32 [ 0.0 ]
            ry : f32 [ 0.0 ]
            if [ layer.radius ]
                rx = layer.radius.rx
                ry = layer.radius.ry

            if [ [ layer.fill_color && layer.fill_color.a > 0.0] || [layer.stroke_color && layer.stroke_color.a > 0.0] ]
                cv.save             [ ]
                cv.set_stroke_size  [ layer.stroke_width ]
                cv.set_stroke_cap   [ layer.stroke_cap  ]
                cv.set_stroke_join  [ layer.stroke_join ]
                cv.rect_to          [ b.x, b.y, b.w, b.h ]
                cv.rounded_rect     [ b.x, b.y, b.w, b.h, rx, ry ]
                cv.fill_color       [ layer.fill_color ]
                cv.stroke_color     [ layer.stroke_color ]
                cv.paint            [ ]
                cv.restore          [ ]

            label : string (layer.label && layer.label.count > 0) ? layer.label : null
            if [ element_text || label ]
                cv.save[]
                align  : vec2f [
                    x: (layer.label_align) ? layer.label_align.x : 0,
                    y: (layer.label_align) ? layer.label_align.y : 0 ]
                offset : vec2f  [ x: layer.label_offset.x, y: layer.label_offset.y ]
                cv.fill_color   [ layer.label_color ]
                cv.font_size    [ layer.label_size ]
                cv.line_height  [ layer.label_height ]
                cv.draw_text    [ (label) ? label : element_text, b, align, offset, layer.label_overflow ]
                cv.restore      [ ]

        e.draw*[ a ]
        last_2 : element
        for [ ee: element, id: string ] in e.elements
            cv.save[]
            if [ ee.bounds ]
                cv.translate[ ee.bounds.x, ee.bounds.y ]
            draw_element[ ee, stage, last_2 ]
            last_2 = ee
            cv.restore[]


abstract media_app trinity
    intern msaa_samples : i64
    intern istroke      : f32 0
    intern ifill        : f32 0

    public func on_canvas [ cv: Canvas ]
        return

    # input event hooks. return true to swallow; otherwise just observe.
    # ev.target is the element the event was dispatched to (null if none).
    # elements get these virtuals first (they can intercept); if the element
    # returns false or there's no target, the app sees it here.
    public func on_click   [ ev: Event ] -> bool  return false
    public func on_press   [ ev: Event ] -> bool  return false
    public func on_release [ ev: Event ] -> bool  return false
    public func on_hover   [ ev: Event ] -> bool  return false
    public func on_leave   [ ev: Event ] -> bool  return false
    public func on_move    [ ev: Event ] -> bool  return false
    public func on_wheel   [ ev: Event ] -> bool  return false
    public func on_key     [ ev: Event ] -> bool  return false
    public func on_char    [ ev: Event ] -> bool  return false

    public func on_render [ w: Window ] -> Elements
        return Elements [
            "root": element [
                elements: [
                    "one": Button[],
                    "two": Button[]
                ]
            ]
        ]

    func init[]
        no-op

    func load_scene [] return
    func update_scene [] return

         
    func run[] -> i32
        type : typeid[a]
        window : Window[ app_object: a, title:type.ident, st: Style [ a ], 
            width:(width) ?? 1488, height:(height) ?? 888 ]
        expect window.vk, "context didnt work"

        w = window
        w.update*[]
        render*[]
        w.resize[w.width, w.height]
        return super.run[]

##
    func render[]
        elements : on_render[ w ]

        if [ elements ]
            w.update_all[ elements ]

        w.animate[]
        if [ w.compose && w.colorize && w.glyph ]
            w.compose .clear [ '#000' ]
            w.colorize.clear [ '#000' ]
            w.glyph   .clear [ '#000' ]
        
        w.overlay.clear[ '#0000' ]
        w.draw_element [ w.ux.root ]
        w.draw[]
##

    mutable angle : f32

    # 22
    func render[]
        window : Window[w]
        update_scene*[]
        window.colorize .clear[ '#000'  ] #
        window.overlay  .clear[ '#0000' ] # the only one that needs an alpha layer
        window.draw[]


class LineInfo
    intern data            :  string
    intern len             :  num
    intern adv             :  array f64[]
    intern bounds          :  rect
    intern placement       :  rect

class TextSel
    public column : num
    public row    : num

class Text
    public lines   : array LineInfo

class StyleEntry
    mutable member   : string
    mutable value    : string
    mutable trans    : StyleTransition
    mutable bl       : StyleBlock
    mutable instance : object

alias StyleEntries   : array StyleEntry
alias StyleEntryMap  : map   StyleEntry [ string ]


class StyleBlock
    mutable parent  : StyleBlock
    mutable quals   : array StyleQualifier
    public entries  : StyleEntryMap
    public blocks   : array StyleBlock
    public types    : array Au_t
    mutable key     : string
    mutable property : string

    post construct [ p_sc: ref cstr ]
        sc : cstr p_sc
        ws[ ref sc ]
        expect sc[0] == '.' || is_alpha2[sc[0]], 'expected Type[.id], or .id'
        quals = parse_qualifiers[ a, ref sc ]
        sc += 1
        ws[ ref sc ]
        while [ sc[0] && sc[0] != '}' ]
            ws[ ref sc ]
            start : cstr [ sc ]
            expect scan_to[ ref sc, ';{{}}' ], 'expected member expression or qualifier'
            if [ sc[0] == '{' ]
                bl_n : StyleBlock [ ref sc ]
                blocks.push[ bl_n ]
                bl_n.parent = a
                sc = start
                expect sc[0] == '}', 'expected }}'
                sc += 1
                ws[ ref sc ]
            el [ sc[0] == ';' ]
                cur : cstr [ start ]
                expect scan_to[ ref cur, ':' ] && cur < sc, 'expected [member:]value;'
                member : string [ chars: start, ref_length: distance[ start, cur ] ]
                for [ i: i32 0, i < member.count, i += 1 ]
                    if [ member.chars[i] == '-' ]
                        member.chars[i] = '_'
                cur += 1
                ws[ ref cur ]
                vstart : cstr [ cur ]
                expect scan_to[ ref cur, ';' ], 'expected member:value[, transition];'
                vlen     : distance[ vstart, cur ]
                cb_value : string[ chars: vstart, ref_length: vlen ]
                cb_value = cb_value.trim[]
                q0       : string [ cb_value.mid[  0, 1 ] ]
                q1       : string [ cb_value.mid[ -1, 1 ] ]
                is_q     : bool [ (q0 == '"' || q0 == '\'') && q0 == q1 ]
                if [ is_q ]
                    cs : cstr [ cb_value.chars ]
                    cb_value = parse_quoted[ ref cs, cb_value.count ]
                param : string [ null ]
                value : object [ null ]
                ai    : num    [ cb_value.index_of[ '[' ] ]
                ci    : num    [ cb_value.index_of[ ',' ] ]
                if [ ci != -1 ]
                    puts 'ci'
                    ci = ci
                if [ ai != -1 && (ci == -1 || ai < ci) ]
                    ae    : num[ cb_value.index_of[ ']' ] ]
                    expect ae != -1, 'expected ] character'
                    items : cb_value.mid[ ai + 1, ae - 1 ].trim[]
                    ln    : cb_value.count - ae
                    param = cb_value.mid[ ae + 1, ln ].trim[]
                    if [ param.first[] == ',' ]
                        param = param.mid[ 1, param.count - 1 ].trim[]
                    el
                        param = null
                    sp : items.split[ ',' ]
                    value = array Au [ sp.count ]
                    v : array Au[ value ]
                    for [ raw: string ] in sp
                        v.push[ raw.trim[] ]
                el
                    param = (ci >= 0) ? cb_value.mid[ ci + 1, cb_value.count - (ci + 1) ].trim[] : null
                    value = (ci >= 0) ? cb_value.mid[ 0, ci ].trim[] : cb_value
                trans : StyleTransition [ (param) ? StyleTransition[ param ] : null ]
                if [ trans ]
                    puts 'trans'
                    trans = trans
                expect member, 'member cannot be blank'
                expect value,  'value cannot be blank'
                entries[ member ] = StyleEntry [ member: member, value: value, trans: trans, bl: a ]
                sc += 1
                ws[ ref sc ]
        expect !sc[0] || sc[0] == '}', 'expected closed-brace'
        if [ sc[0] == '}' ]
            sc += 1
        p_sc[0] = sc


    public func score [ n: element, score_state: bool ] -> f32
        best_sc : f32 [ 0.0 ]
        cur     : element [ n ]

        for [ q: StyleQualifier ] in quals
            best_this : f32 [ 0.0 ]
            while [ true ]
                ty_handle   : handle [ q.ty ]
                id_match    : bool [ q.id && q.id == cur.id ]
                id_reject   : bool [ q.id && !id_match ]
                type_match  : bool [ ty_handle && (typeid[ cur ] inherits typeid[ q.ty ]) ]
                type_reject : bool [ ty_handle && !type_match ]
                state_match : bool [ score_state && q.state ]
                if [ state_match ]
                    expect q.state.count > 0, 'null state'
                    current : Au cur.get_property[ q.state ]
                    if [ current.cast_bool[ ] ]
                        state_match = true
                    el
                        state_match = false
                    
                state_reject : bool [ score_state && q.state && !state_match ]
                if [ id_reject || type_reject || state_reject ]
                    return 0.0
                sc : f64 [ i64[ id_match ] << 1 | i64[ type_match ] | i64[ state_match ] << 2 ]
                best_this = max[ sc, best_this ]
                if [ !q.parent ]
                    if [ q.anchored && cur.parent ]
                        return 0.0
                    break
                q   = q.parent
                cur = (cur.parent) ? cur.parent : element[]
            best_sc = max[ best_sc, best_this ]
        return (best_sc > 0.0) ? 1.0 : 0.0

    func init []
        if [ !entries ] entries = StyleEntryMap    [ ]
        if [ !blocks  ] blocks  = array StyleBlock [ ]
        if [ !types   ] types   = array Au_t       [ ]


class Style
    public  css_path  : path
    public  members   : map StyleEntries[string]
    public  reloader  : watch
    public  base      : array StyleBlock
    intern  mtx       : mutex
    intern  mod_time  : i64
    intern  reloaded  : bool
    intern  loaded    : bool
    intern  visited   : array string
    intern  errors    : array string

    func cache_block [ bl: StyleBlock, depth:int ]
        for [ e: StyleEntry, k: string ] in bl.entries
            cache : members [ e.member ]
            if [ !cache ]
                cache = array StyleBlock[]
                members.set[ e.member, cache ]
            found : false
            for [ cb: StyleBlock ] in cache
                found |= cb == bl
            if [ !found ]
                cache.push[ bl ]
        
        # 
        for [ s: StyleBlock ] in bl.blocks
            if [s.property]
                cache : members [ s.property ]
                if [ !cache ]
                    cache = array StyleBlock[]
                    members[s.property] = cache
                cache.push[ s ] # we merely associate the 'layers' property for example
            el
                expect depth == 0, "incompatible css depth"
                cache_block [ s, depth + 1 ] # we want to enforce just 1 depth from root

    func applicable [ n: element, prop_name: string, result: StyleEntries ] -> bool
        blocks : members[ prop_name ]
        ty     : typeid[ n ]
        ret    : false
        result.clear[]
        for [ block: StyleBlock ] in blocks
            if [ !block.types.count || block.types.index_of[ ty ] >= 0 ]
                if [ block.key && block.property ]
                    if [ block.score[ n, false ] > 0 ]
                        for [ f:StyleEntry, name:string ] in block.entries
                            result.push[ f ]
                        ret = true
                el
                    f : block.entries[ prop_name ]
                    if [ f && block.score[ n, false ] > 0 ]
                        result.push[ f ]
                        ret = true
        return ret

    func process [ code: string ]
        if [ !base    ] base    = array StyleBlock [ ]
        if [ !visited ] visited = array string     [ ]
        if [ !errors  ] errors  = array string     [ ]
        lines : array CSSLine [ split_css[ code ] ]
        i : i32 [ 0 ]
        while [ i < lines.count ]
            content : string [ lines[i].content ]
            if [ content == '}' ]
                i += 1
                continue
            if [ content.count >= 7 && content.mid[ 0, 7 ] == '@import' ]
                rest : string [ content.mid[ 7, content.count - 7 ].trim[] ]
                expect rest.count >= 2, '@import expects quoted path'
                qt : i8 [ rest.chars[0] ]
                expect qt == '"' || qt == '\'', '@import expects quoted path'
                k : i32 [ 1 ]
                while [ k < rest.count && rest.chars[k] != qt ]
                    k += 1
                name : string [ rest.mid[ 1, k - 1 ] ]
                p    : path   'style/{name}'
                key  : string [ p ]
                if [ visited.index_of[ key ] < 0 ]
                    visited.push[ key ]
                    sub : string [ p.load[ typeid[ string ], null ] ]
                    process[ sub ]
                i += 1
                continue
            if [ content.last[] == '{' ]
                content = content.mid[ 0, content.count - 1 ].trim[]
            end_idx : i32 [ i + 1 ]
            while [ end_idx < lines.count && lines[end_idx].indent > 0 ]
                end_idx += 1
            bl : StyleBlock [ ]
            sc : cstr [ content.chars ]
            bl.quals = parse_qualifiers[ bl, ref sc ]
            parse_block_body[ bl, lines, i + 1, end_idx - 1, 0 ]
            validate_block[ bl, errors ]
            base.push[ bl ]
            i = end_idx

    func report_errors [ ]
        if [ errors && errors.count ]
            for [ msg: string ] in errors
                puts '{msg}'
            fault 'css: {errors.count} error(s)'

    func cache_members [ ]
        for [ b: StyleBlock ] in base
            cache_block[ b, 0 ]

    func best_match [ n: element, prop_name: string, entries: array StyleEntry ] -> StyleEntry
        match      : StyleEntry [ null ]
        best_score : f32 [ 0.0 ]
        for [ e: StyleEntry ] in entries
            bl : StyleBlock [ e.bl ]
            sc : f32 [ bl.score[ n, true ] ]
            if [ sc > 0.0 && sc >= best_score ]
                match      = bl.entries[ prop_name ]
                expect match, 'should have matched'
                best_score = sc
        return match

    func compute [ n: element ] -> map StyleEntries[string]
        avail : map StyleEntries[string][]
        ty    : Au_t [ typeid[ n ] ]
        expect n inherits element, 'must inherit element'
        while [ ty != typeid[ Au ] ]
            all : array StyleEntry [ ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                mem : Au_t [ ty.members.origin[m] ]
                if [ mem.member_type != AU_MEMBER_VAR || mem.access_type == 1 ] # 1 == intern!
                    continue
                name : string [ mem.ident ]
                if [ applicable[ n, name, all ] ]
                    avail[ name ] = all
                    all = array  StyleEntry[ ]
            ty = ty.context
        return avail

    func check_reload [ ] -> bool
        expect css_path, 'style not loaded with path'
        m : css_path.modified_time[ ]
        if [ mod_time != m ]
            mod_time = m
            process[ css_path.load[ typeid[ string ], null ] ]
            cache_members[]
            loaded   = true
            reloaded = true
            return true
        return false

    construct [ p: path ]
        expect p.exists, 'css path does not exist'
        style_str : string [ p.load[ typeid[ string ], null ] ]
        base      = array StyleBlock [ ]
        css_path  = p
        mod_time  = p.modified_time[ ]
        members   = map StyleEntries[string] []
        process[ style_str ]
        report_errors[]
        cache_members[]
        loaded   = true
        reloaded = true

    construct [ app_instance: trinity ]
        app_type  : typeid app_instance
        root_type : string app_type.ident
        p         : path   'style/{root_type}.css'
        construct [ p ]


struct XCoord
    x_type   : XAlign
    offset   : f32
    relative : bool
    percent  : bool
    
    construct [ sx: string ]
        f : string[sx.first[]]
        if [ isdigit[f.chars[0]]]
            offset = f.real_value[]
        el
            x_type    = XAlign[f]
            sx_offset : sx.mid[ 1, sx.count - 1 ]
            if [ sx_offset.last[] == '%' ]
                sx_offset = sx_offset.mid[ 0, sx_offset.count - 1 ]
                percent   = true
            if [ sx_offset ]
                if [ sx_offset.last[] == '+' ]
                    sx_offset = sx_offset.mid[ 0, sx_offset.count - 1 ]
                    relative  = true
            offset = sx_offset.real_value[]

    func plot [ from: f32, vto: f32, left: ref XCoord, left_val: f32, rel: rect, last: rect ] -> f32
        val : mix[ offset, offset * (vto - from), f32[percent] ]
        if [ x_type > XAlign.right ]
            expect (left.x_type <= XAlign.right), 'invalid left-operand (xcoord)'
            return left_val + val
        r : f32 [ (rel && relative) ? rel.w * relative : 0.0 ]
        if [ relative && last ]
            r += last.x + last.w
        hsz : f32 [ (vto - from) / 2.0 ]
        if [ x_type < XAlign.middle ]
            M : f32 [ f32[x_type] * 2.0 ]
            return from + hsz * M + val + r
        R : f32 [ (f32[x_type] - f32[XAlign.middle]) * 2.0 ]
        return from + ((hsz + val) * (1.0 - R)) + ((hsz * 2.0 - val) * R) + r

    func mix [ other: XCoord, f: f32 ] -> XCoord
        return XCoord [
            x_type:  XAlign[mix[ f32[x_type],   f32[other.x_type],   f ]],
            offset:         mix[     offset,        other.offset,    f ],
            percent: bool[  mix[ f32[percent],  f32[other.percent],  f ]],
            relative:bool[mix[ f32[relative], f32[other.relative], f ]]
        ]


struct YCoord
    y_type   : YAlign
    offset   : f32
    relative : bool
    percent  : bool

    construct [ sy: string ]
        f : string [ sy.first[] ]
        if [ isdigit[f.chars[0]]]
            offset = f.real_value[]
        el
            y_type    = YAlign[ f ]
            sy_offset : sy.mid[ 1, sy.count - 1 ]
            if [ sy_offset.last[] == '%' ]
                sy_offset = sy_offset.mid[ 0, sy_offset.count - 1 ]
                percent   = true
            if [ sy_offset ]
                if [ sy_offset.last[] == '+' ]
                    sy_offset = sy_offset.mid[ 0, sy_offset.count - 1 ]
                    relative  = true
            offset = sy_offset.real_value[]

    func plot [ from: f32, vto: f32, top: ref YCoord, top_val: f32, rel: rect, last: rect ] -> f32
        val : f32 [ mix[ offset, offset * (vto - from), percent ] ]
        if [ y_type > YAlign.bottom ]
            expect top.y_type <= YAlign.bottom, 'invalid top-operand (ycoord)'
            return top_val + val
        r : f32 [ (rel && relative) ? rel.h * relative : 0.0 ]
        if [ relative && last ]
            r += last.y + last.h
        hsz : f32 [ (vto - from) / 2.0 ]
        if [ y_type < YAlign.middle ]
            M : f32 [ f32[y_type] * 2.0 ]
            return from + hsz * M + val + r
        R : f32 [ (f32[y_type] - f32[YAlign.middle]) * 2.0 ]
        return from + ((hsz + val) * (1.0 - R)) + ((hsz * 2.0 - val) * R) + r

    func mix [ other: YCoord, f: f32 ] -> YCoord
        return YCoord [
            y_type:   YAlign[ mix[ f32[y_type],   f32[other.y_type],   f ] ],
            offset:           mix[ offset,         other.offset,        f ],
            percent:  bool[   mix[ f32[percent],   f32[other.percent],  f ] ],
            relative: bool[   mix[ f32[relative],  f32[other.relative], f ] ]
        ]


class Region
    public l   : XCoord
    public t   : YCoord
    public r   : XCoord
    public b   : YCoord
    public set : bool

    construct [ f: f32 ]
        l   = XCoord [ x_type: XAlign.left,   offset: f ]
        t   = YCoord [ y_type: YAlign.top,    offset: f ]
        r   = XCoord [ x_type: XAlign.right,  offset: f ]
        b   = YCoord [ y_type: YAlign.bottom, offset: f ]
        set = true

    construct [ rc: rect ]
        l   = XCoord [ x_type: XAlign.left,   offset: rc.x ]
        t   = YCoord [ y_type: YAlign.top,    offset: rc.y ]
        r   = XCoord [ x_type: XAlign.width,  offset: rc.w ]
        b   = YCoord [ y_type: YAlign.height, offset: rc.h ]
        set = true

    construct [ s: string ]
        aa : s.split[ ' ' ]
        if [ aa.count == 4 ]
            l = XCoord [ aa[0] ]
            t = YCoord [ aa[1] ]
            r = XCoord [ aa[2] ]
            b = YCoord [ aa[3] ]
        el [ aa.count == 1 ]
            l = XCoord [ aa[0] ]
            t = YCoord [ aa[0] ]
            r = XCoord [ aa[0] ]
            r.x_type = XAlign.right
            b = YCoord [ aa[0] ]
            b.y_type = YAlign.bottom
        set = true

    construct [ cs : cstr ]
        s : string[cs]
        construct [ s ]

    func rectangle [ win: rect, rel: rect, last: rect ] -> rect
        lv : l.plot[ win.x, win.x + win.w, null,  0.0, rel, last ]
        rv : r.plot[ win.x, win.x + win.w, ref l, lv,  rel, last ]
        tv : t.plot[ win.y, win.y + win.h, null,  0.0, rel, last ]
        bv : b.plot[ win.y, win.y + win.h, ref t, tv,  rel, last ]
        return rect [ x: lv, y: tv, w: rv - lv, h: bv - tv ]

    func mix [ other: Region, f: f64 ] -> Region
        reg : Region [ set: true ]
        reg.l = l.mix[ other.l, f ]
        reg.t = t.mix[ other.t, f ]
        reg.r = r.mix[ other.r, f ]
        reg.b = b.mix[ other.b, f ]
        return reg

class Scaling
    public value : vec3f

    construct [ f: vec3f ]
        value = f

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        expect sp.count == 3, 'expected x y z'
        value.x = sp[0].real_value[]
        value.y = sp[1].real_value[]
        value.z = sp[2].real_value[]

    func mix [ b: Scaling, f: f64 ] -> Scaling
        s2 : Scaling value.mix[ b.value, f ]
        return s2


class Rotation
    public axis : vec3f
    public degs : f32

    construct [ f: vec4f ]
        axis.x = f.x
        axis.y = f.y
        axis.z = f.z
        degs   = f.w

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        expect sp.count == 4, 'expected x y z Ndeg'
        f : string[ sp[3] ]
        expect f.ends_with[ 'deg' ], 'expected Ndeg'
        axis.x = sp[0].real_value[]
        axis.y = sp[1].real_value[]
        axis.z = sp[2].real_value[]
        degs   = sp[3].real_value[]

    public func mix [ b: Rotation, f: f64 ] -> Rotation
        return Rotation [
            axis: axis.mix[ b.axis, f ],
            degs: mix[ degs, b.degs, f ]
        ]


class Translation
    public value : vec3f

    construct [ f: vec3f ]
        value = f

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        expect sp.count == 3, 'expected x y z'
        value.x = sp[0].real_value[]
        value.y = sp[1].real_value[]
        value.z = sp[2].real_value[]

    public func mix [ b: Translation, f: f64 ] -> Translation
        return Translation []


class TimeCoord
    millis : i64

    construct [ s:string ]
        if [ s.ends_with['ns'] ]
            millis = s.integer_value[] / 1000000
        el [ s.ends_with['ms'] ]
            millis = s.integer_value[]
        el [ s.ends_with['sec'] ]
            millis = s.real_value[] * 1000

    construct [ s:cstr ]
        str : string[s]
        construct [ str ]
    
    construct [ nanoseconds: ns ]
        millis = i64[ nanoseconds ] / 1000000

    construct [ milliseconds: ms ]
        millis = i64[ milliseconds ]

    construct [ secs: sec ]
        millis = i64[ secs ] * 1000

    func get_millis [] -> i64
        return millis


class StyleTransition
    public easing       : Ease
    public dir          : Direction
    public duration     : TimeCoord
    intern from         : object
    intern to           : object
    intern start        : i64
    intern invalidate   : bool
    intern reference    : StyleTransition
    intern is_inlay     : bool
    intern type         : Au_t
    intern location     : ref object

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        ln : i32 [ sp.count ]
        # syntax: 500ms [ease [out]]
        dur_string : string [ sp[0] ]
        duration   = TimeCoord [ dur_string ]
        easing     = (ln > 1) ? Ease[ sp[1] ]      : Ease.linear
        dir        = (ln > 2) ? Direction[ sp[2] ]  : Direction.inward

    func pos [ tf: f64 ] -> f64
        x : f64 [ clamp[ tf, 0.0, 1.0 ] ]
        switch [ easing ]
            case linear
                return x
            case quad
                switch [ dir ]
                    case inward
                        return x * x
                    case outward
                        return 1.0 - (1.0 - x) * (1.0 - x)
                    case in_out
                        return (x < 0.5) ? 2.0 * x * x : 1.0 - pow[ -2.0 * x + 2.0, 2.0 ] / 2.0
            case cubic
                switch [ dir ]
                    case inward
                        return x * x * x
                    case outward
                        return 1.0 - pow[ 1.0 - x, 3.0 ]
                    case in_out
                        return (x < 0.5) ? 4.0 * x * x * x : 1.0 - pow[ -2.0 * x + 2.0, 3.0 ] / 2.0
            case quart
                switch [ dir ]
                    case inward
                        return x * x * x * x
                    case outward
                        return 1.0 - pow[ 1.0 - x, 4.0 ]
                    case in_out
                        return (x < 0.5) ? 8.0 * x * x * x * x : 1.0 - pow[ -2.0 * x + 2.0, 4.0 ] / 2.0
            case quint
                switch [ dir ]
                    case inward
                        return x * x * x * x * x
                    case outward
                        return 1.0 - pow[ 1.0 - x, 5.0 ]
                    case in_out
                        return (x < 0.5) ? 16.0 * x * x * x * x * x : 1.0 - pow[ -2.0 * x + 2.0, 5.0 ] / 2.0
            case sine
                PI : f64 [ 3.14159265358979323846 ]
                switch [ dir ]
                    case inward
                        return 1.0 - cos[ x * PI / 2.0 ]
                    case outward
                        return sin[ x * PI / 2.0 ]
                    case in_out
                        return -(cos[ PI * x ] - 1.0) / 2.0
            case expo
                switch [ dir ]
                    case inward
                        return (x == 0.0) ? 0.0 : pow[ 2.0, 10.0 * x - 10.0 ]
                    case outward
                        return (x == 1.0) ? 1.0 : 1.0 - pow[ 2.0, -10.0 * x ]
                    case in_out
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : (x < 0.5) ? pow[ 2.0, 20.0 * x - 10.0 ] / 2.0 : (2.0 - pow[ 2.0, -20.0 * x + 10.0 ]) / 2.0
            case circ
                switch [ dir ]
                    case inward
                        return 1.0 - sqrt[ 1.0 - pow[ x, 2.0 ] ]
                    case outward
                        return sqrt[ 1.0 - pow[ x - 1.0, 2.0 ] ]
                    case in_out
                        return (x < 0.5) ? (1.0 - sqrt[ 1.0 - pow[ 2.0 * x, 2.0 ] ]) / 2.0 : (sqrt[ 1.0 - pow[ -2.0 * x + 2.0, 2.0 ] ] + 1.0) / 2.0
            case back
                c1 : f64 [ 1.70158 ]
                c2 : f64 [ c1 * 1.525 ]
                c3 : f64 [ c1 + 1.0 ]
                switch [ dir ]
                    case inward
                        return c3 * x * x * x - c1 * x * x
                    case outward
                        return 1.0 + c3 * pow[ x - 1.0, 3.0 ] + c1 * pow[ x - 1.0, 2.0 ]
                    case in_out
                        return (x < 0.5) ? (pow[ 2.0 * x, 2.0 ] * ((c2 + 1.0) * 2.0 * x - c2)) / 2.0 : (pow[ 2.0 * x - 2.0, 2.0 ] * ((c2 + 1.0) * (x * 2.0 - 2.0) + c2) + 2.0) / 2.0
            case elastic
                PI  : f64 [ 3.14159265358979323846 ]
                c4  : f64 [ 2.0 * PI / 3.0 ]
                c5e : f64 [ 2.0 * PI / 4.5 ]
                switch [ dir ]
                    case inward
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : -pow[ 2.0, 10.0 * x - 10.0 ] * sin[ (x * 10.0 - 10.75) * c4 ]
                    case outward
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : pow[ 2.0, -10.0 * x ] * sin[ (x * 10.0 - 0.75) * c4 ] + 1.0
                    case in_out
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : (x < 0.5) ? -(pow[ 2.0, 20.0 * x - 10.0 ] * sin[ (20.0 * x - 11.125) * c5e ]) / 2.0 : (pow[ 2.0, -20.0 * x + 10.0 ] * sin[ (20.0 * x - 11.125) * c5e ]) / 2.0 + 1.0
            case bounce
                switch [ dir ]
                    case inward
                        return 1.0 - bounce_out[ 1.0 - x ]
                    case outward
                        return bounce_out[ x ]
                    case in_out
                        return (x < 0.5) ? (1.0 - bounce_out[ 1.0 - 2.0 * x ]) / 2.0 : (1.0 + bounce_out[ 2.0 * x - 1.0 ]) / 2.0
            default
                return x
        return x

    cast -> bool
        return duration.get_millis[] > 0


