extend trinity


class CSSLine
    public indent  : i32
    public content : string
    public line    : i32

# a `<Class> NAME [ params… ]` CSS definition: the captured body + its parameter names.
# cls is the Layer class it instantiates (Layer, TermLayer, …). the def name doubles as
# the layers-map id unless the use site binds it to another id (`layers.<id>: <name> […]`).
class LayerDef
    public cls    : string
    public params : array string
    public body   : array CSSLine

# one matched CSS block for the live inspector: the .css file + selector line. orbiter
# uses these to open the style source for whatever UI element was clicked.
class StyleHit
    public file : path
    public line : i32

class LineInfo
    intern data            :  string
    intern len             :  num
    intern adv             :  array f64[]
    intern bounds          :  rect
    intern placement       :  rect

class TextSel
    public column : num
    public row    : num

class Text
    public lines   : array LineInfo

class StyleEntry
    mutable member    : string
    mutable value     : string
    mutable trans     : StyleTransition
    mutable bl        : StyleBlock
    manual instance  : object
    mutable line      : i32
    # when set, `value` is the name of a field on the target element; the value
    # is re-read from inst.<binding> every frame (not converted at parse time).
    mutable binding   : string
    # resolved when a bound entry is registered on an instance:
    # container.member_set(bound_mem, inst.member_object[bound_src]) each frame.
    mutable container : Au
    mutable bound_mem : Au_t
    mutable bound_src : Au_t
    mutable filter    : f32
    manual  member_map : Au_t

    func dealloc []
        if [ instance ]
            instance.drop[]

alias StyleEntries   : array StyleEntry
alias StyleEntryMap  : map   StyleEntry [ string ]


class StyleBlock
    mutable parent  : StyleBlock
    mutable quals   : array StyleQualifier
    public entries  : StyleEntryMap
    public blocks   : array StyleBlock
    public types    : array Au_t
    mutable key       : string
    mutable property  : string
    mutable type_name : string
    # source location of this block's selector (for the live CSS inspector) — the .css
    # file it was parsed from and the 1-based line of its selector. stamped in process[].
    public  src_file  : path
    public  src_line  : i32

    post construct [ p_sc: @cstr ]
        sc : cstr p_sc
        ws[ @sc ]
        expect sc[0] == '.' || is_alpha2[sc[0]], 'expected Type[.id], or .id'
        quals = parse_qualifiers[ a, @sc ]
        sc += 1
        ws[ @sc ]
        while [ sc[0] && sc[0] != '}' ]
            ws[ @sc ]
            start : cstr [ sc ]
            expect scan_to[ @sc, ';{{}}' ], 'expected member expression or qualifier'
            if [ sc[0] == '{' ]
                bl_n : StyleBlock [ @sc ]
                blocks.push[ bl_n ]
                bl_n.parent = a
                sc = start
                expect sc[0] == '}', 'expected }}'
                sc += 1
                ws[ @sc ]
            el [ sc[0] == ';' ]
                cur : cstr [ start ]
                expect scan_to[ @cur, ':' ] && cur < sc, 'expected [member:]value;'
                member : string [ chars: start, ref_length: distance[ start, cur ] ]
                for [ i: i32 0, i < member.count, i += 1 ]
                    if [ member.chars[i] == '-' ]
                        member.chars[i] = '_'
                cur += 1
                ws[ @cur ]
                vstart : cstr [ cur ]
                expect scan_to[ @cur, ';' ], 'expected member:value[, transition];'
                vlen     : distance[ vstart, cur ]
                cb_value : string[ chars: vstart, ref_length: vlen ]
                cb_value = cb_value.trim[]
                q0       : cb_value.mid[  0, 1 ]
                q1       : cb_value.mid[ -1, 1 ]
                is_q     : bool [ (q0 == '"' || q0 == '\'') && q0 == q1 ]
                if [ is_q ]
                    cs : cstr [ cb_value.chars ]
                    cb_value = parse_quoted[ @cs, cb_value.count ]
                param : string [ null ]
                value : object [ null ]
                ai    : num    [ cb_value.index_of[ '[' ] ]
                ci    : num    [ cb_value.index_of[ ',' ] ]
                if [ ai != -1 && (ci == -1 || ai < ci) ]
                    ae    : num[ cb_value.index_of[ ']' ] ]
                    expect ae != -1, 'expected ] character'
                    items : cb_value.mid[ ai + 1, ae - 1 ].trim[]
                    ln    : cb_value.count - ae
                    param = cb_value.mid[ ae + 1, ln ].trim[]
                    if [ param.first[] == ',' ]
                        param = param.mid[ 1, param.count - 1 ].trim[]
                    el
                        param = null
                    sp : items.split[ ',' ]
                    value = array Au [ sp.count ]
                    v : array Au[ value ]
                    for [ raw: string ] in sp
                        v.push[ raw.trim[] ]
                el
                    param = (ci >= 0) ? cb_value.mid[ ci + 1, cb_value.count - (ci + 1) ].trim[] : null
                    value = (ci >= 0) ? cb_value.mid[ 0, ci ].trim[] : cb_value
                filter_val : f32 [ 0.0 ]
                if [ param && param.count >= 7 && param.mid[ 0, 7 ] == 'filter ' ]
                    filter_val = f32[ param.mid[ 7, param.count - 7 ].trim[] ]
                    param = null
                trans : StyleTransition [ (param) ? StyleTransition[ param ] : null ]
                if [ trans ]
                    puts 'trans'
                    trans = trans
                expect member, 'member cannot be blank'
                expect value,  'value cannot be blank'
                entries[ member ] = StyleEntry [ member: member, value: value, trans: trans, bl: a, filter: filter_val ]
                sc += 1
                ws[ @sc ]
        expect !sc[0] || sc[0] == '}', 'expected closed-brace'
        if [ sc[0] == '}' ]
            sc += 1
        p_sc[0] = sc


    public func score [ n: element, score_state: bool ] -> i64
        best_sc : i64 [ 0 ]
        cur     : element [ n ]
        ux      : Window [ n.ux ]

        for [ q: StyleQualifier ] in quals
            q.hold[]
            cur = n
            best_this : i64 [ 0 ]
            while [ true ]
                ty_handle   : handle [ q.ty ]
                id_match    : bool   [ q.id && q.id == cur.id ]
                id_reject   : bool   [ q.id && !id_match ]

                # when cur has no parent we are at root — check app_object type instead
                use_app    : bool [ !cur.parent && ux && ux.app_object ]
                type_match : bool [ false ]
                if [ ty_handle ]
                    io_r : Au cur.instance_of[ q.ty ]
                    if [ io_r ] type_match = true
                type_reject : bool [ ty_handle && !type_match ]

                # state pseudo-classes. q.states holds the full list (e.g.
                # :hovered:pressed). ALL states must be truthy on this element
                # for the selector to match. the q.oper path (state OP value)
                # still uses the single q.state since op-mode takes one state.
                state_match : bool [ score_state && q.state ]
                if [ state_match ]
                    expect q.state.count > 0, 'null state'
                    if [ use_app && type_match ]
                        state_val : ux.app_object.get_property[ q.state ]
                        state_match = state_val && Au.cast_bool [ state_val ]
                    el [ use_app ]
                        state_match = false
                    el [ q.oper || !q.states || q.states.count <= 1 ]
                        current : Au cur.get_property[ q.state ]
                        state_match = current && current.cast_bool[ ]
                    el
                        all_match : bool [ true ]
                        for [ s : string ] in q.states
                            if [ s.count == 0 ]
                                continue
                            scurrent : Au cur.get_property[ s ]
                            if [ !scurrent || !scurrent.cast_bool[ ] ]
                                all_match = false
                                break
                        state_match = all_match

                state_reject : bool [ score_state && q.state && !state_match ]
                if [ id_reject || type_reject || state_reject ]
                    q.drop[]
                    return 0.0
                sc : i64[ id_match ] << 1 | i64[ type_match ] | i64[ state_match ] << 2
                best_this = max[ sc, best_this ]
                if [ !q.parent ]
                    if [ q.anchored && cur.parent ]
                        q.drop[]
                        return 0.0
                    break
                q   = q.parent
                cur = (cur.parent) ? cur.parent : cur
            q.drop[]
            best_sc = max[ best_sc, best_this ]
        return best_sc

    func init []
        if [ !entries ] entries = StyleEntryMap    [ ]
        if [ !blocks  ] blocks  = array StyleBlock [ ]
        if [ !types   ] types   = array Au_t       [ ]


class Style
    public  css_path  : path
    # live inspector cycle state: repeated cmd+clicks on the SAME element step through its
    # array of matched blocks (a different element resets). lives here (not on Window — adding
    # Window instance members breaks orbiter's import of trinity at vk.ag:1095).
    mutable inspect_el  : element
    mutable inspect_idx : i32
    public  members   : map StyleEntries[string]
    public  reloader  : watch
    public  base      : array StyleBlock
    intern  mtx       : mutex
    intern  mod_time  : i64
    intern  reloaded  : bool
    intern  loaded    : bool
    intern  visited   : array string
    intern  errors    : array string

    func cache_block [ bl: StyleBlock, depth:int ]
        for [ e: StyleEntry, k: string ] in bl.entries
            cache : members [ e.member ]
            if [ !cache ]
                cache = array StyleBlock[]
                members.set[ e.member, cache ]
            found : false
            for [ cb: StyleBlock ] in cache
                found |= cb == bl
            if [ !found ]
                cache.push[ bl ]
        
        # 
        for [ s: StyleBlock ] in bl.blocks
            if [s.property]
                cache : members [ s.property ]
                if [ !cache ]
                    cache = array StyleBlock[]
                    members[s.property] = cache
                cache.push[ s ] # we merely associate the 'layers' property for example
            el
                expect depth == 0, "incompatible css depth"
                cache_block [ s, depth + 1 ] # we want to enforce just 1 depth from root

    func applicable [ n: element, prop_name: string, result: StyleEntries ] -> bool
        blocks : members[ prop_name ]
        ty     : typeid[ n ]
        ret    : false
        result.clear[]
        for [ block: StyleBlock ] reverse in blocks
            type_ok : bool [ !block.types.count ]
            for [ bt: Au_t ] in block.types
                if [ n.instance_of[ bt ] ]
                    type_ok = true
                    break
                if [ !type_ok && n.ux && n.ux.app_object ]
                    check : typeid[ n.ux.app_object ]
                    while [ check && check != typeid[ Au ] ]
                        if [ check == bt ] type_ok = true
                        check = check.context
                if [ type_ok ] break
            if [ type_ok ]
                if [ block.key && block.property ]
                    if [ block.score[ n, false ] > 0 ]
                        for [ f:StyleEntry, name:string ] in block.entries
                            result.push[ f ]
                        ret = true
                el
                    f : block.entries[ prop_name ]
                    if [ f && block.score[ n, false ] > 0 ]
                        result.push[ f ]
                        ret = true

        return ret

    # LIVE CSS INSPECTOR: the rules whose FULL selector matches this element (so a shell
    # button never picks up Editor's Option rules — context must match, not just the leaf
    # type). most-specific first, so cmd+click lands on the button's own rule and cycling
    # walks its remaining rules (base + :hover/:selected variants). each as {file, line}.
    func element_style_blocks [ n: element ] -> array StyleHit
        matched : array StyleBlock [ ]
        for [ block: StyleBlock ] in base
            if [ block.score[ n, false ] > 0 ]
                matched.push[ block ]
        # most-specific directly-matching rule first (highest selector score)
        i : i32 [ 0 ]
        while [ i < matched.count ]
            bestj : i32 [ i ]
            j : i32 [ i + 1 ]
            while [ j < matched.count ]
                if [ matched[j].score[ n, false ] > matched[bestj].score[ n, false ] ]
                    bestj = j
                j += 1
            if [ bestj != i ]
                tmp : matched[i]
                matched[i]     = matched[bestj]
                matched[bestj] = tmp
            i += 1
        hits : array StyleHit [ ]
        for [ b: StyleBlock ] in matched
            hits.push[ StyleHit [ file: b.src_file, line: b.src_line ] ]
        return hits

    # substring replace (no word-boundary needed: the markers are `$name`, unambiguous).
    func css_replace [ s: string, from: string, to: string ] -> string
        if [ !s || !from || from.count == 0 ] return s
        out : string [ '' ]
        i : i32 [ 0 ]
        n : i32 [ s.count ]
        fn : i32 [ from.count ]
        while [ i < n ]
            if [ i + fn <= n && s.mid[ i, fn ] == from ]
                out = out + to
                i += fn
            el
                out = out + s.mid[ i, 1 ]
                i += 1
        return out

    # parse `name [ a, b, c ]` → [name, a, b, c] (trimmed). no brackets → [name].
    func call_parse [ s: string ] -> array string
        out : array string [ ]
        pa  : num [ s.index_of[ '[' ] ]
        if [ pa < 0 ]
            out.push[ s.trim[] ]
            return out
        out.push[ s.mid[ 0, pa ].trim[] ]
        pb : num [ s.index_of[ ']' ] ]
        if [ pb < 0 ] pb = s.count
        inner : s.mid[ pa + 1, pb - pa - 1 ].trim[]
        if [ inner.count > 0 ]
            for [ r: string ] in inner.split[ ',' ]
                out.push[ r.trim[] ]
        return out

    # is `lc` a composition use of a plain Layer def? a use is a bare `name` or
    # `name [ args ]` line — a property/pseudo line always carries ':' before any
    # '[', a use never does.
    func layer_use [ defs: map LayerDef[string], lc: string ] -> array string
        if [ lc.count == 0 ] return null
        c0 : i8 [ lc.chars[0] ]
        alpha : bool [ (c0 >= 'a' && c0 <= 'z') || (c0 >= 'A' && c0 <= 'Z') || c0 == '_' ]
        if [ !alpha ] return null
        ci : num [ lc.index_of[ ':' ] ]
        bi : num [ lc.index_of[ '[' ] ]
        if [ ci >= 0 && (bi < 0 || ci < bi) ] return null
        call : array string [ call_parse[ lc ] ]
        if [ !defs[ call[0] ] ] return null
        return call

    func layer_subst [ d: LayerDef, call: array string, txt: string ] -> string
        res : txt
        for [ pi: i32 0, pi < d.params.count, pi += 1 ]
            v : string [ (pi + 1 < call.count) ? call[pi + 1] : '' ]
            res = css_replace[ res, '$' + d.params[pi], v ]
        return res

    # instantiate a def at a use site: base props emitted at `at`; the def's `:state`
    # sections hoist into `states` as nested pseudo-state sections re-opening the same
    # `hdr` — same layer id across states, so prop transitions animate. states == null
    # (use inside a state section) drops the def's own state sections.
    func layer_splice [ hdr: string, d: LayerDef, call: array string, at: i32, out: array CSSLine, states: array CSSLine ]
        in_st : bool [ false ]
        for [ bl: CSSLine ] in d.body
            txt : layer_subst[ d, call, bl.content ]
            is_hdr : bool [ bl.indent == 0 && txt.count > 0 && txt.chars[0] == ':' ]
            if [ is_hdr ]
                in_st = true
                if [ states != null ]
                    states.push[ CSSLine [ indent: 0, content: txt, line: bl.line ] ]
                    states.push[ CSSLine [ indent: 1, content: hdr, line: bl.line ] ]
                continue
            if [ in_st ]
                if [ states != null ]
                    states.push[ CSSLine [ indent: bl.indent + 2, content: txt, line: bl.line ] ]
                continue
            out.push[ CSSLine [ indent: at + bl.indent, content: txt, line: bl.line ] ]

    # CSS Layers: `<Class> NAME [ p1, p2 ]` (indent 0) captures the indented block under
    # it — layer props plus `:state` sections (at the def's own indent or body indent) —
    # with `$p1`/`$p2` placeholders. <Class> is Layer or any Layer subclass. inside an
    # element block:
    #   layers.<id> [ v1, v2 ]           instantiates the def named by the id
    #   layers.<id>: <def> [ v1, v2 ]    binds any def to the id
    # expanding to the internal `layers.<id>:` block with args substituted; the def's
    # `:state` sections hoist to nested pseudo-state sections after the block. a bare
    # `<def> [ args ]` inside another def's body splices its props flat (composition).
    # a pure pre-parse pass. the old `layers.<id>:` prop-block form is an error.
    func expand_layers [ lines: array CSSLine, src: path ] -> array CSSLine
        defs : map LayerDef [ string ] [ ]
        stripped : array CSSLine [ ]
        i : i32 [ 0 ]
        while [ i < lines.count ]
            lc : string [ lines[i].content ]
            cls : string
            hdr : array string
            if [ lines[i].indent == 0 && lc.index_of[ '[' ] > 0 && lc.count > 0 && lc.last[] != '{' ]
                sp0 : num [ lc.index_of[ ' ' ] ]
                if [ sp0 > 0 ]
                    t0 : lc.mid[ 0, sp0 ]
                    c00 : i8 [ t0.chars[0] ]
                    ok0 : bool [ c00 >= 'A' && c00 <= 'Z' && t0.index_of[ '.' ] < 0 &&
                                 t0.index_of[ ':' ] < 0 && t0.index_of[ '/' ] < 0 ]
                    if [ ok0 ]
                        rest0 : lc.mid[ sp0 + 1, lc.count - sp0 - 1 ].trim[]
                        c01 : i8 [ 0 ]
                        if [ rest0.count > 0 ] c01 = rest0.chars[0]
                        alpha1 : bool [ (c01 >= 'a' && c01 <= 'z') || (c01 >= 'A' && c01 <= 'Z') || c01 == '_' ]
                        if [ alpha1 && rest0.index_of[ ':' ] < 0 ]
                            cls = t0
                            hdr = call_parse[ rest0 ]
            if [ cls ]
                nm   : hdr[0]
                d    : LayerDef [ cls: cls, params: array string [ ], body: array CSSLine [ ] ]
                for [ k: i32 1, k < hdr.count, k += 1 ]
                    d.params.push[ hdr[k] ]
                di   : i32 [ lines[i].indent ]
                base_in : i32 [ -1 ]
                j : i32 [ i + 1 ]
                # def body: indented lines, plus `:state` sections at the def's own indent
                while [ j < lines.count ]
                    blc0 : string [ lines[j].content ]
                    st0  : bool [ lines[j].indent == di && blc0.count > 0 && blc0.chars[0] == ':' ]
                    if [ lines[j].indent <= di && !st0 ]
                        break
                    if [ base_in < 0 && !st0 ] base_in = lines[j].indent
                    rel : i32    [ (base_in < 0) ? 0 : lines[j].indent - base_in ]
                    if [ rel < 0 ] rel = 0
                    blc : string [ lines[j].content ]
                    if [ blc.count >= 7 && blc.mid[ 0, 7 ] == 'layers.' ]
                        errors.push[ '{src}:{lines[j].line}: layers inside a Layer are not allowed' ]
                    cuse : layer_use[ defs, blc ]
                    if [ cuse ]
                        du : defs[ cuse[0] ]
                        for [ cl2: CSSLine ] in du.body
                            d.body.push[ CSSLine [ indent: rel + cl2.indent,
                                content: layer_subst[ du, cuse, cl2.content ], line: cl2.line ] ]
                    el
                        d.body.push[ CSSLine [ indent: rel, content: blc, line: lines[j].line ] ]
                    j += 1
                defs[ nm ] = d
                i = j
                continue
            stripped.push[ lines[i] ]
            i += 1
        # instantiate uses inside element blocks; generated `:state` sections for a block
        # flush before the next selector so they chain onto its existing state sections.
        out      : array CSSLine [ ]
        pending  : array CSSLine [ ]
        in_state : bool [ false ]
        k2 : i32 [ 0 ]
        while [ k2 < stripped.count ]
            cl  : stripped[k2]
            lc2 : cl.content
            if [ cl.indent == 0 ]
                is_st : bool [ lc2.count > 0 && lc2.chars[0] == ':' ]
                if [ !is_st && pending.count > 0 ]
                    for [ pl: CSSLine ] in pending
                        out.push[ pl ]
                    pending = array CSSLine [ ]
                in_state = is_st
                out.push[ cl ]
                k2 += 1
                continue
            if [ lc2.count >= 7 && lc2.mid[ 0, 7 ] == 'layers.' ]
                rest : lc2.mid[ 7, lc2.count - 7 ].trim[]
                ci2 : num [ rest.index_of[ ':' ] ]
                bi2 : num [ rest.index_of[ '[' ] ]
                if [ bi2 > 0 && (ci2 < 0 || bi2 < ci2) ]
                    # layers.<id> [ args ] — def named by the id
                    call2 : array string [ call_parse[ rest ] ]
                    d2 : defs[ call2[0] ]
                    if [ !d2 ]
                        errors.push[ '{src}:{cl.line}: unknown Layer `{call2[0]}`' ]
                        k2 += 1
                        continue
                    hdr2 : (d2.cls == 'Layer') ? ('layers.' + call2[0] + ':') : ('layers.' + call2[0] + ': ' + d2.cls)
                    out.push[ CSSLine [ indent: cl.indent, content: hdr2, line: cl.line ] ]
                    if [ in_state ]
                        layer_splice[ hdr2, d2, call2, cl.indent + 1, out, null ]
                    el
                        layer_splice[ hdr2, d2, call2, cl.indent + 1, out, pending ]
                    k2 += 1
                    continue
                typed : bool [ false ]
                if [ ci2 > 0 ]
                    nm2 : rest.mid[ 0, ci2 ].trim[]
                    rc  : rest.mid[ ci2 + 1, rest.count - ci2 - 1 ].trim[]
                    cA  : i8 [ 0 ]
                    if [ rc.count > 0 ] cA = rc.chars[0]
                    alphaA : bool [ (cA >= 'a' && cA <= 'z') || (cA >= 'A' && cA <= 'Z') || cA == '_' ]
                    if [ alphaA && rc.index_of[ '[' ] > 0 ]
                        # layers.<id>: <def> [ args ] — bind any def to the id
                        callc : array string [ call_parse[ rc ] ]
                        d3 : defs[ callc[0] ]
                        if [ !d3 ]
                            errors.push[ '{src}:{cl.line}: unknown Layer `{callc[0]}`' ]
                            k2 += 1
                            continue
                        call3 : array string [ ]
                        call3.push[ nm2 ]
                        for [ ka: i32 1, ka < callc.count, ka += 1 ]
                            call3.push[ callc[ka] ]
                        hdr3 : (d3.cls == 'Layer') ? ('layers.' + nm2 + ':') : ('layers.' + nm2 + ': ' + d3.cls)
                        out.push[ CSSLine [ indent: cl.indent, content: hdr3, line: cl.line ] ]
                        if [ in_state ]
                            layer_splice[ hdr3, d3, call3, cl.indent + 1, out, null ]
                        el
                            layer_splice[ hdr3, d3, call3, cl.indent + 1, out, pending ]
                        typed = true
                if [ !typed ]
                    errors.push[ '{src}:{cl.line}: instantiate layers with `layers.<id> [ args ]` or `layers.<id>: <def> [ args ]`' ]
            el
                out.push[ cl ]
            k2 += 1
        for [ pl: CSSLine ] in pending
            out.push[ pl ]
        return out

    func process [ code: string, src: path ]
        if [ !base    ] base    = array StyleBlock [ ]
        if [ !visited ] visited = array string     [ ]
        if [ !errors  ] errors  = array string     [ ]
        lines : array CSSLine [ expand_layers[ split_css[ code ], src ] ]
        i : i32 [ 0 ]
        while [ i < lines.count ]
            content : string [ lines[i].content ]
            if [ content == '}' ]
                i += 1
                continue
            if [ content.count >= 7 && content.mid[ 0, 7 ] == '@import' ]
                rest : content.mid[ 7, content.count - 7 ].trim[]
                expect rest.count >= 2, '@import expects quoted path'
                qt : i8 [ rest.chars[0] ]
                expect qt == '"' || qt == '\'', '@import expects quoted path'
                k : i32 [ 1 ]
                while [ k < rest.count && rest.chars[k] != qt ]
                    k += 1
                name : rest.mid[ 1, k - 1 ]
                p    : path   'style/{name}'
                key  : string [ p ]
                if [ visited.index_of[ key ] < 0 ]
                    visited.push[ key ]
                    sub : p.load[ typeid[ string ], null ]
                    process[ sub, p ]
                i += 1
                continue
            if [ content.last[] == '{' ]
                content = content.mid[ 0, content.count - 1 ].trim[]
            end_idx : i32 [ i + 1 ]
            while [ end_idx < lines.count && lines[end_idx].indent > 0 ]
                end_idx += 1
            bl : StyleBlock [ ]
            sc : cstr [ content.chars ]
            bl.quals = parse_qualifiers[ bl, @sc ]
            parse_block_body[ bl, lines, i + 1, end_idx - 1, 0 ]
            bl.src_file = src
            bl.src_line = lines[i].line
            validate_block[ bl, errors ]
            base.push[ bl ]
            # nested pseudo-state sections: an indent-0 line beginning with ':'
            # inside the same braces (e.g. a bare `:focused`) expands into a
            # separate `<selector><state>` block. lets states be written inline
            # under their selector instead of as a repeated top-level rule.
            while [ end_idx < lines.count && lines[end_idx].indent == 0 ]
                state_line : string [ lines[end_idx].content ]
                if [ !state_line.count || state_line.chars[0] != ':' ]
                    break
                if [ state_line.last[] == '{' ]
                    state_line = state_line.mid[ 0, state_line.count - 1 ].trim[]
                state_sel  : content + state_line
                body_start : i32 [ end_idx + 1 ]
                body_end   : i32 [ body_start ]
                while [ body_end < lines.count && lines[body_end].indent > 0 ]
                    body_end += 1
                sbl : StyleBlock [ ]
                ssc : cstr [ state_sel.chars ]
                sbl.quals = parse_qualifiers[ sbl, @ssc ]
                parse_block_body[ sbl, lines, body_start, body_end - 1, 0 ]
                sbl.src_file = src
                sbl.src_line = lines[end_idx].line
                validate_block[ sbl, errors ]
                base.push[ sbl ]
                end_idx = body_end
            i = end_idx

    func report_errors [ ]
        if [ errors && errors.count ]
            for [ msg: string ] in errors
                puts '{msg}'
            fault 'css: {errors.count} error(s)'

    func cache_members [ ]
        for [ b: StyleBlock ] in base
            cache_block[ b, 0 ]

    # the best match is the first match
    func best_match [ n: element, prop_name: string, entries: array StyleEntry ] -> StyleEntry
        match      : StyleEntry [ null ]
        for [ e: StyleEntry ] in entries
            bl : StyleBlock [ e.bl ]
            sc : bl.score[ n, true ]
            if [ sc > 0 ]
                match      = bl.entries[ prop_name ]
                expect match, 'should have matched'
                break

        return match

    func compute [ n: element ] -> map StyleEntries[string]
        avail : map StyleEntries[string][]
        ty    : typeid[ n ]
        expect n inherits element, 'must inherit element'
        while [ ty != typeid[ Au ] ]
            all : array StyleEntry [ ]
            for [ m: i32 0, m < ty.members.count, m += 1 ]
                mem : ty.members.origin[m]
                if [ mem.member_type != AU_MEMBER_VAR || mem.access_type == 1 ] # 1 == intern!
                    continue
                name : string [ mem.ident ]
                if [ applicable[ n, name, all ] ]
                    avail[ name ] = all
                    all = array  StyleEntry[ ]
            ty = ty.context
        return avail

    # non-consuming mtime poll: true when the css file changed on disk but
    # check_reload hasn't applied it yet. lets the idle render loop open its
    # frame gate so a live css edit repaints without waiting for a mouse event.
    public func pending_reload [ ] -> bool
        if [ !css_path ] return false
        return mod_time != css_path.modified_time[ ]

    func check_reload [ ] -> bool
        expect css_path, 'style not loaded with path'
        m : css_path.modified_time[ ]
        if [ mod_time != m ]
            mod_time = m
            base    = array StyleBlock [ ]
            visited = array string     [ ]
            errors  = array string     [ ]
            members = map StyleEntries[string] []
            process[ css_path.load[ typeid[ string ], null ], css_path ]
            cache_members[]
            loaded   = true
            reloaded = true
            return true
        return false

    construct [ p: path ]
        expect p.exists, 'css path does not exist'
        style_str : p.load[ typeid[ string ], null ]
        base      = array StyleBlock [ ]
        css_path  = p
        mod_time  = p.modified_time[ ]
        members   = map StyleEntries[string] []
        process[ style_str, p ]
        report_errors[]
        cache_members[]
        loaded   = true
        reloaded = true

    construct [ app_instance: element ]
        app_type  : typeid app_instance
        root_type : string app_type.ident
        p         : path   'style/{root_type}.css'
        construct [ p ]


# a coord bound to an app-object variable: `r[varname:default]`. axis records
# which edge (XAlign/YAlign value); varname is the public field on the app object
# the coord reads each layout; dflt is the fallback used before/without that field.
# this is the primitive that replaces vsplit/hsplit controls — two coords binding
# the same varname share one app value, so their seam is implicitly draggable.
class BindCoord
    public axis    : i32
    public varname : string
    public dflt    : f32
    # px clamp relative to the touched sides: min (near side) / max (far side).
    # seam drag clamps to [min,max]; reaching max snaps to the collapsed value.
    public min       : f32
    public max       : f32
    public has_range : bool
    # eased display position (filtered toward the goal var) + state. lives here,
    # not on the app — bind_value filters it each frame; `moving` is true on any
    # frame it changed (incl. the snap frame) so draw_element repaints + animates.
    public active      : f32
    public has_active  : bool
    public moving      : bool
    # true once the eased value has settled at least once. until then (the load
    # warm-up, while the font/fc is still stabilizing) the display is set DIRECTLY
    # rather than eased, so the seam appears already at its snapped position instead
    # of visibly easing into it after the first paint.
    public warmed      : bool

struct XCoord
    x_type   : XAlign
    offset   : f32
    relative : bool
    percent  : bool
    pixel    : bool
    # `wc` = width from content. paired with a right anchor (e.g. r5px), the
    # element is offset left by its computed width; with a left anchor it grows
    # rightward. resolved in the layout pass.
    content  : bool
    # a percent coord may carry a trailing +/- offset: `50%-2` (2 units) or `50%-2px`
    # (2 px) — position at the percent, then nudge. pct_off is added on top of the percent.
    pct_off       : f32
    pct_off_pixel : bool

    construct [ sx: string ]
        # first char as a STRING (mid), not string[unichar] — that ctr faults
        f : string [ (sx.count > 0) ? sx.mid[ 0, 1 ] : '' ]
        if [ f.chars[ 0 ] == '-' || isdigit[ f.chars[ 0 ] ] ]
            sx_r : string [ sx ]
            if [ sx_r.last[] == 'x' && sx_r.count >= 2 ]
                if [ sx_r.chars[ sx_r.count - 2 ] == 'p' ]
                    sx_r  = sx_r.mid[ 0, sx_r.count - 2 ]
                    pixel = true
            offset = sx_r.real_value[]
        el
            x_type    = XAlign[ f ]
            sx_offset : sx.mid[ 1, sx.count - 1 ]
            # bound coord `@varname=default` — offset is the default; the BindCoord
            # itself lives on the Region (a class), never in this value struct.
            if [ sx_offset.count >= 1 && sx_offset.chars[0] == '@' ]
                inner : string sx_offset.mid[ 1, sx_offset.count - 1 ]
                parts : inner.split[ '=' ]
                offset = (parts.count > 1) ? parts[1].real_value[] : 0.0
            el
                # `wc` — content width (a 'c' after the width marker)
                if [ x_type == XAlign.width && sx_offset.count > 0 && sx_offset.chars[0] == 'c' ]
                    content   = true
                    sx_offset = sx_offset.mid[ 1, sx_offset.count - 1 ]
                if [ sx_offset.last[] == 'x' && sx_offset.count >= 2 ]
                    if [ sx_offset.chars[ sx_offset.count - 2 ] == 'p' ]
                        sx_offset = sx_offset.mid[ 0, sx_offset.count - 2 ]
                        pixel     = true
                # percent, optionally with a trailing +/- offset: `50%`, `50%-2` (units),
                # `50%-2px` (px — the px suffix above set `pixel`, which the offset adopts).
                pct_at : i32 [ sx_offset.index_of[ '%' ] ]
                if [ pct_at >= 0 ]
                    percent = true
                    offset  = sx_offset.mid[ 0, pct_at ].real_value[] / 100.0
                    off_str : sx_offset.mid[ pct_at + 1, sx_offset.count - pct_at - 1 ]
                    if [ off_str.count > 0 && off_str.chars[0] == '+' ]
                        off_str = off_str.mid[ 1, off_str.count - 1 ]
                    if [ off_str.count > 0 ]
                        pct_off       = off_str.real_value[]
                        pct_off_pixel = pixel
                el
                    if [ sx_offset && sx_offset.last[] == '+' ]
                        sx_offset = sx_offset.mid[ 0, sx_offset.count - 1 ]
                        relative  = true
                    offset = sx_offset.real_value[]

    func plot [ from: f32, vto: f32, left: @XCoord, left_val: f32, rel: rect, last: rect, fc: f32, console: bool ] -> f32
        fc_m : f32 [ (fc > 0.0 && !pixel) ? fc : 1.0 ]
        off  : f32 [ offset ]
        # console grid: px has no sub-line resolution — a px coord > 16 (≈ one line)
        # collapses to 1 unit (1 cell), anything smaller rounds away to 0.
        if [ console && pixel ]
            off  = (offset > 16.0) ? 1.0 : 0.0
            fc_m = fc
        val  : f32 [ mix[ off * fc_m, offset * (vto - from), f32[percent] ] ]
        # a percent coord may carry a +/- nudge (`50%-2` = 50% minus 2 units; `-2px` = px)
        if [ percent && pct_off != 0.0 ]
            val += pct_off * ((pct_off_pixel) ? 1.0 : ((fc > 0.0) ? fc : 1.0))
        if [ x_type > XAlign.right ]
            expect (left.x_type <= XAlign.right), 'invalid left-operand (xcoord)'
            return left_val + val
        r : f32 [ (rel && relative) ? rel.w * relative : 0.0 ]
        # left-flow only: `l<gap>+` advances past the previous sibling's right
        # edge. a right-anchored relative coord (`r<gap>+`, right-flow) must NOT
        # take this — its stacking is resolved post-sizing in layout_element,
        # and adding last's extent here lands the element past the parent edge.
        if [ relative && last && x_type == XAlign.left ]
            r += last.x + last.w
        hsz : f32 [ (vto - from) / 2.0 ]
        if [ x_type < XAlign.middle ]
            M : f32 [ f32[x_type] * 2.0 ]
            return from + hsz * M + val + r
        R : f32 [ (f32[x_type] - f32[XAlign.middle]) * 2.0 ]
        return from + ((hsz + val) * (1.0 - R)) + ((hsz * 2.0 - val) * R) + r

    func mix [ other: XCoord, f: f32 ] -> XCoord
        return XCoord [
            x_type:  XAlign[mix[ f32[x_type],   f32[other.x_type],   f ]],
            offset:         mix[     offset,        other.offset,    f ],
            percent: bool[  mix[ f32[percent],  f32[other.percent],  f ]],
            relative:bool[mix[ f32[relative], f32[other.relative], f ]],
            pixel:   other.pixel,
            content: other.content,
            pct_off:        mix[ pct_off, other.pct_off, f ],
            pct_off_pixel: other.pct_off_pixel
        ]


struct YCoord
    y_type   : YAlign
    offset   : f32
    relative : bool
    percent  : bool
    pixel    : bool
    # `hc` = height from content (offset up by computed height when bottom-anchored)
    content  : bool
    # `50%-2` (units) / `50%-2px` (px): percent position plus a trailing +/- nudge.
    pct_off       : f32
    pct_off_pixel : bool

    construct [ sy: string ]
        # first char as a STRING (mid), not string[unichar] — that ctr faults
        f : string [ (sy.count > 0) ? sy.mid[ 0, 1 ] : '' ]
        if [ f.chars[0] == '-' || isdigit[f.chars[0]]]
            sy_r : string [ sy ]
            if [ sy_r.last[] == 'x' && sy_r.count >= 2 ]
                if [ sy_r.chars[ sy_r.count - 2 ] == 'p' ]
                    sy_r  = sy_r.mid[ 0, sy_r.count - 2 ]
                    pixel = true
            offset = sy_r.real_value[]
        el
            y_type    = YAlign[ f ]
            sy_offset : sy.mid[ 1, sy.count - 1 ]
            # bound coord `@varname=default` — offset is the default; the BindCoord
            # itself lives on the Region (a class), never in this value struct.
            if [ sy_offset.count >= 1 && sy_offset.chars[0] == '@' ]
                inner : string sy_offset.mid[ 1, sy_offset.count - 1 ]
                parts : inner.split[ '=' ]
                offset = (parts.count > 1) ? parts[1].real_value[] : 0.0
            el
                # `hc` — content height (a 'c' after the height marker)
                if [ y_type == YAlign.height && sy_offset.count > 0 && sy_offset.chars[0] == 'c' ]
                    content   = true
                    sy_offset = sy_offset.mid[ 1, sy_offset.count - 1 ]
                if [ sy_offset.last[] == 'x' && sy_offset.count >= 2 ]
                    if [ sy_offset.chars[ sy_offset.count - 2 ] == 'p' ]
                        sy_offset = sy_offset.mid[ 0, sy_offset.count - 2 ]
                        pixel     = true
                # percent + optional trailing +/- offset: `50%`, `50%-2` (units), `50%-2px`.
                pct_at : i32 [ sy_offset.index_of[ '%' ] ]
                if [ pct_at >= 0 ]
                    percent = true
                    offset  = sy_offset.mid[ 0, pct_at ].real_value[] / 100.0
                    off_str : sy_offset.mid[ pct_at + 1, sy_offset.count - pct_at - 1 ]
                    if [ off_str.count > 0 && off_str.chars[0] == '+' ]
                        off_str = off_str.mid[ 1, off_str.count - 1 ]
                    if [ off_str.count > 0 ]
                        pct_off       = off_str.real_value[]
                        pct_off_pixel = pixel
                el
                    if [ sy_offset && sy_offset.last[] == '+' ]
                        sy_offset = sy_offset.mid[ 0, sy_offset.count - 1 ]
                        relative  = true
                    offset = sy_offset.real_value[]

    func plot [ from: f32, vto: f32, top: @YCoord, top_val: f32, rel: rect, last: rect, fc: f32, console: bool ] -> f32
        fc_m : f32 [ (fc > 0.0 && !pixel) ? fc : 1.0 ]
        off  : f32 [ offset ]
        # console grid: px has no sub-line resolution — a px coord > 16 (≈ one line)
        # collapses to 1 unit (1 cell), anything smaller rounds away to 0.
        if [ console && pixel ]
            off  = (offset > 16.0) ? 1.0 : 0.0
            fc_m = fc
        val  : f32 [ mix[ off * fc_m, offset * (vto - from), percent ] ]
        if [ percent && pct_off != 0.0 ]
            val += pct_off * ((pct_off_pixel) ? 1.0 : ((fc > 0.0) ? fc : 1.0))
        if [ y_type > YAlign.bottom ]
            expect top.y_type <= YAlign.bottom, 'invalid top-operand (ycoord)'
            return top_val + val
        r : f32 [ (rel && relative) ? rel.h * relative : 0.0 ]
        # top-flow only — mirror of the x-axis rule: bottom-anchored relative
        # coords resolve their stacking post-sizing in layout_element.
        if [ relative && last && y_type == YAlign.top ]
            r += last.y + last.h
        hsz : f32 [ (vto - from) / 2.0 ]
        if [ y_type < YAlign.middle ]
            M : f32 [ f32[y_type] * 2.0 ]
            return from + hsz * M + val + r
        R : f32 [ (f32[y_type] - f32[YAlign.middle]) * 2.0 ]
        return from + ((hsz + val) * (1.0 - R)) + ((hsz * 2.0 - val) * R) + r

    func mix [ other: YCoord, f: f32 ] -> YCoord
        return YCoord [
            y_type:   YAlign[ mix[ f32[y_type],   f32[other.y_type],   f ] ],
            offset:           mix[ offset,         other.offset,        f ],
            percent:  bool[   mix[ f32[percent],   f32[other.percent],  f ] ],
            relative: bool[   mix[ f32[relative],  f32[other.relative], f ] ],
            pixel:    other.pixel,
            content:  other.content,
            pct_off:          mix[ pct_off,        other.pct_off,       f ],
            pct_off_pixel: other.pct_off_pixel
        ]


# parse `<axis>[varname:default]` into a BindCoord, else null. lives on the Region
# (a class) so the value coord structs stay free of managed refs.
func coord_bind [ tok: string, axis: i32 ] -> BindCoord
    if [ !tok || tok.count < 3 ] return null
    if [ tok.chars[1] != '@' ] return null
    # syntax: b@<var>=<default>|<min>|<max>  (min/max px, relative to the sides).
    inner  : string tok.mid[ 2, tok.count - 2 ]
    parts  : inner.split[ '|' ]        # <var>=<default> | <min> | <max>
    vparts : parts[0].split[ '=' ]     # <var> , <default>
    dv : f32 [ (vparts.count > 1) ? vparts[1].real_value[] : 0.0 ]
    mn : f32 [ (parts.count > 1)  ? parts[1].real_value[]  : 0.0 ]
    mx : f32 [ (parts.count > 2)  ? parts[2].real_value[]  : 0.0 ]
    return BindCoord [ axis: axis, varname: vparts[0], dflt: dv,
        min: mn, max: mx, has_range: parts.count > 2 ]

class Region
    public l   : XCoord
    public t   : YCoord
    public r   : XCoord
    public b   : YCoord
    # bound edges (null unless `<axis>[var:default]`); on the class, not the structs
    public bind_l : BindCoord
    public bind_t : BindCoord
    public bind_r : BindCoord
    public bind_b : BindCoord
    public set : bool
    # 'hw' in the height slot: height tracks the computed width (a square).
    public square : bool

    construct [ f: f32 ]
        l   = XCoord [ x_type: XAlign.left,   offset: f ]
        t   = YCoord [ y_type: YAlign.top,    offset: f ]
        r   = XCoord [ x_type: XAlign.right,  offset: f ]
        b   = YCoord [ y_type: YAlign.bottom, offset: f ]
        set = true

    construct [ rc: rect ]
        l   = XCoord [ x_type: XAlign.left,   offset: rc.x ]
        t   = YCoord [ y_type: YAlign.top,    offset: rc.y ]
        r   = XCoord [ x_type: XAlign.width,  offset: rc.w ]
        b   = YCoord [ y_type: YAlign.height, offset: rc.h ]
        set = true

    construct [ s: string ]
        aa : s.split[ ' ' ]
        if [ aa.count == 4 ]
            l = XCoord [ aa[0] ]
            t = YCoord [ aa[1] ]
            r = XCoord [ aa[2] ]
            bind_l = coord_bind[ aa[0], i32[ XAlign.left ] ]
            bind_t = coord_bind[ aa[1], i32[ YAlign.top ] ]
            bind_r = coord_bind[ aa[2], i32[ XAlign.right ] ]
            # 'hw' in the height slot → height tracks the computed width (square)
            if [ aa[3] == 'hw' ]
                square = true
                b = YCoord [ y_type: YAlign.height, offset: 0.0 ]
            el
                b = YCoord [ aa[3] ]
                bind_b = coord_bind[ aa[3], i32[ YAlign.bottom ] ]
        el [ aa.count == 1 ]
            l = XCoord [ aa[0] ]
            t = YCoord [ aa[0] ]
            r = XCoord [ aa[0] ]
            r.x_type = XAlign.right
            b = YCoord [ aa[0] ]
            b.y_type = YAlign.bottom
        set = true

    construct [ cs : cstr ]
        s : string[cs]
        construct [ s ]

    # sx/sy: the container's spacing — the gap BETWEEN flowed siblings
    # ([b1][gap][b2]); applies only when a `+` coord follows a previous
    # sibling, never at the edges.
    func rectangle [ win: rect, rel: rect, last: rect, fc: f32, console: bool, sx: f32, sy: f32 ] -> rect
        # right-anchored placement with a width slot ALWAYS includes the
        # element's own width: x = cursor - inset - width. `r<gap>+` flows the
        # cursor from the previous sibling's left edge; static `r<inset>`
        # anchors the parent's right edge.
        if [ l.x_type == XAlign.right && r.x_type > XAlign.right ]
            gfc : f32 [ (fc > 0.0 && !l.pixel) ? fc : 1.0 ]
            gap : f32 [ l.offset * ((l.pixel) ? 1.0 : gfc) ]
            wfc : f32 [ (fc > 0.0 && !r.pixel) ? fc : 1.0 ]
            wv  : f32 [ r.offset * ((r.pixel) ? 1.0 : wfc) ]
            cur : f32 [ (l.relative && last) ? (last.x - sx) : (win.x + win.w - sx) ]
            tv2 : f32 [ t.plot[ win.y, win.y + win.h, null, 0.0, rel, last, fc, console ] ]
            if [ t.y_type == YAlign.top ] tv2 += sy
            bv2 : b.plot[ win.y, win.y + win.h, @t, tv2, rel, last, fc, console ]
            rx2 : f32 [ round[ cur - gap - wv ] ]
            return rect [ x: rx2, y: round[ tv2 ], w: round[ wv ], h: round[ bv2 ] - round[ tv2 ] ]
        lv : f32 [ l.plot[ win.x, win.x + win.w, null,  0.0, rel, last, fc, console ] ]
        rv : f32 [ r.plot[ win.x, win.x + win.w, @l, lv,  rel, last, fc, console ] ]
        tv : f32 [ t.plot[ win.y, win.y + win.h, null,  0.0, rel, last, fc, console ] ]
        # anchored edges respect the container's spacing: left/top anchors
        # inset inward, exact right anchors pull in; flow gets it as the gap
        if [ l.x_type == XAlign.left  ] lv += sx
        if [ r.x_type == XAlign.right ] rv -= sx
        if [ t.y_type == YAlign.top   ] tv += sy
        rx : f32 [ round[ lv ] ]
        ry : f32 [ round[ tv ] ]
        ww : f32 [ round[ rv ] - rx ]
        # square: height = computed width
        if [ square ]
            return rect [ x: rx, y: ry, w: ww, h: ww ]
        bv : f32 [ b.plot[ win.y, win.y + win.h, @t, tv,  rel, last, fc, console ] ]
        if [ b.y_type == YAlign.bottom ] bv -= sy
        return rect [ x: rx, y: ry, w: ww, h: round[ bv ] - ry ]

    func mix [ other: Region, f: f64 ] -> Region
        reg : Region [ set: true ]
        reg.l = l.mix[ other.l, f ]
        reg.t = t.mix[ other.t, f ]
        reg.r = r.mix[ other.r, f ]
        reg.b = b.mix[ other.b, f ]
        reg.square = square || other.square
        return reg

class Scaling
    public value : vec3f

    construct [ f: vec3f ]
        value = f

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        expect sp.count == 3, 'expected x y z'
        value.x = sp[0].real_value[]
        value.y = sp[1].real_value[]
        value.z = sp[2].real_value[]

    func mix [ b: Scaling, f: f64 ] -> Scaling
        s2 : Scaling value.mix[ b.value, f ]
        return s2


class Rotation
    public axis : vec3f
    public degs : f32

    construct [ f: vec4f ]
        axis.x = f.x
        axis.y = f.y
        axis.z = f.z
        degs   = f.w

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        expect sp.count == 4, 'expected x y z Ndeg'
        f  : sp[3]
        expect f.ends_with[ 'deg' ], 'expected Ndeg'
        axis.x = sp[0].real_value[]
        axis.y = sp[1].real_value[]
        axis.z = sp[2].real_value[]
        degs   = sp[3].real_value[]

    public func mix [ b: Rotation, f: f64 ] -> Rotation
        ft : f32 [ f ]
        return Rotation [
            axis: vec3f [
                x: axis.x + (b.axis.x - axis.x) * ft,
                y: axis.y + (b.axis.y - axis.y) * ft,
                z: axis.z + (b.axis.z - axis.z) * ft ],
            degs: degs + (b.degs - degs) * ft
        ]


class Translation
    public value : vec3f

    construct [ f: vec3f ]
        value = f

    construct [ s: string ]
        sp : array string [ s.split[ ' ' ] ]
        expect sp.count == 3, 'expected x y z'
        value.x = sp[0].real_value[]
        value.y = sp[1].real_value[]
        value.z = sp[2].real_value[]

    public func mix [ b: Translation, f: f64 ] -> Translation
        return Translation []


class TimeCoord
    millis : i64

    construct [ s:string ]
        if [ s.ends_with['ns'] ]
            millis = s.integer_value[] / 1000000
        el [ s.ends_with['ms'] ]
            millis = s.integer_value[]
        el [ s.ends_with['sec'] ]
            millis = s.real_value[] * 1000

    construct [ s:cstr ]
        str : string[s]
        construct [ str ]
    
    construct [ nanoseconds: ns ]
        millis = i64[ nanoseconds ] / 1000000

    construct [ milliseconds: ms ]
        millis = i64[ milliseconds ]

    construct [ secs: sec ]
        millis = i64[ secs ] * 1000

    func get_millis [] -> i64
        return millis


class StyleTransition
    public easing       : Ease
    public dir          : Direction
    public duration     : TimeCoord
    manual from         : object
    manual to           : object
    intern dbg_val      : string
    intern start        : i64
    intern invalidate   : bool
    intern reference    : StyleTransition
    intern is_inlay     : bool
    intern type         : Au_t
    intern member       : Au_t
    intern container    : Au
    
    construct [ s: string ]
        sp : s.split[ ' ' ]
        ln : i32 [ sp.count ]
        # syntax: 500ms [ease [out]]
        dur_string : sp[0] 
        duration   = TimeCoord [ dur_string ]
        easing     = (ln > 1) ? Ease[      sp[1] ] :      Ease.linear
        dir        = (ln > 2) ? Direction[ sp[2] ] : Direction.inward

    func pos [ tf: f64 ] -> f64
        x : f64 [ clamp[ tf, 0.0, 1.0 ] ]
        switch [ easing ]
            case linear
                return x
            case quad
                switch [ dir ]
                    case inward
                        return x * x
                    case outward
                        return 1.0 - (1.0 - x) * (1.0 - x)
                    case in_out
                        return (x < 0.5) ? 2.0 * x * x : 1.0 - pow[ -2.0 * x + 2.0, 2.0 ] / 2.0
            case cubic
                switch [ dir ]
                    case inward
                        return x * x * x
                    case outward
                        return 1.0 - pow[ 1.0 - x, 3.0 ]
                    case in_out
                        return (x < 0.5) ? 4.0 * x * x * x : 1.0 - pow[ -2.0 * x + 2.0, 3.0 ] / 2.0
            case quart
                switch [ dir ]
                    case inward
                        return x * x * x * x
                    case outward
                        return 1.0 - pow[ 1.0 - x, 4.0 ]
                    case in_out
                        return (x < 0.5) ? 8.0 * x * x * x * x : 1.0 - pow[ -2.0 * x + 2.0, 4.0 ] / 2.0
            case quint
                switch [ dir ]
                    case inward
                        return x * x * x * x * x
                    case outward
                        return 1.0 - pow[ 1.0 - x, 5.0 ]
                    case in_out
                        return (x < 0.5) ? 16.0 * x * x * x * x * x : 1.0 - pow[ -2.0 * x + 2.0, 5.0 ] / 2.0
            case sine
                PI : f64 [ 3.14159265358979323846 ]
                switch [ dir ]
                    case inward
                        return 1.0 - cos[ x * PI / 2.0 ]
                    case outward
                        return sin[ x * PI / 2.0 ]
                    case in_out
                        return -(cos[ PI * x ] - 1.0) / 2.0
            case expo
                switch [ dir ]
                    case inward
                        return (x == 0.0) ? 0.0 : pow[ 2.0, 10.0 * x - 10.0 ]
                    case outward
                        return (x == 1.0) ? 1.0 : 1.0 - pow[ 2.0, -10.0 * x ]
                    case in_out
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : (x < 0.5) ? pow[ 2.0, 20.0 * x - 10.0 ] / 2.0 : (2.0 - pow[ 2.0, -20.0 * x + 10.0 ]) / 2.0
            case circ
                switch [ dir ]
                    case inward
                        return 1.0 - sqrt[ 1.0 - pow[ x, 2.0 ] ]
                    case outward
                        return sqrt[ 1.0 - pow[ x - 1.0, 2.0 ] ]
                    case in_out
                        return (x < 0.5) ? (1.0 - sqrt[ 1.0 - pow[ 2.0 * x, 2.0 ] ]) / 2.0 : (sqrt[ 1.0 - pow[ -2.0 * x + 2.0, 2.0 ] ] + 1.0) / 2.0
            case back
                c1 : f64 [ 1.70158 ]
                c2 : f64 [ c1 * 1.525 ]
                c3 : f64 [ c1 + 1.0 ]
                switch [ dir ]
                    case inward
                        return c3 * x * x * x - c1 * x * x
                    case outward
                        return 1.0 + c3 * pow[ x - 1.0, 3.0 ] + c1 * pow[ x - 1.0, 2.0 ]
                    case in_out
                        return (x < 0.5) ? (pow[ 2.0 * x, 2.0 ] * ((c2 + 1.0) * 2.0 * x - c2)) / 2.0 : (pow[ 2.0 * x - 2.0, 2.0 ] * ((c2 + 1.0) * (x * 2.0 - 2.0) + c2) + 2.0) / 2.0
            case elastic
                PI  : f64 [ 3.14159265358979323846 ]
                c4  : f64 [ 2.0 * PI / 3.0 ]
                c5e : f64 [ 2.0 * PI / 4.5 ]
                switch [ dir ]
                    case inward
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : -pow[ 2.0, 10.0 * x - 10.0 ] * sin[ (x * 10.0 - 10.75) * c4 ]
                    case outward
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : pow[ 2.0, -10.0 * x ] * sin[ (x * 10.0 - 0.75) * c4 ] + 1.0
                    case in_out
                        return (x == 0.0) ? 0.0 : (x == 1.0) ? 1.0 : (x < 0.5) ? -(pow[ 2.0, 20.0 * x - 10.0 ] * sin[ (20.0 * x - 11.125) * c5e ]) / 2.0 : (pow[ 2.0, -20.0 * x + 10.0 ] * sin[ (20.0 * x - 11.125) * c5e ]) / 2.0 + 1.0
            case bounce
                switch [ dir ]
                    case inward
                        return 1.0 - bounce_out[ 1.0 - x ]
                    case outward
                        return bounce_out[ x ]
                    case in_out
                        return (x < 0.5) ? (1.0 - bounce_out[ 1.0 - 2.0 * x ]) / 2.0 : (1.0 + bounce_out[ 2.0 * x - 1.0 ]) / 2.0
            default
                return x
        return x

    cast -> bool
        return duration.get_millis[] > 0


class StyleQualifier
    intern ty        : Au_t
    expect  bl       : StyleBlock
    mutable type     : string
    mutable id       : string
    mutable state    : string             # first state (kept for op path: state OP value)
    mutable states   : array string       # all states when no op, e.g. :hovered:pressed
    mutable oper     : string
    mutable value    : string
    mutable parent   : StyleQualifier
    mutable anchored : bool


class StyleSelection
    public from : handle
    public to : handle
    public start : i64
    public end : i64
    public entry : StyleEntry

##
class arg
    public name     : string
    public value    : object
    public offset   : i32
    public is_inlay : bool
##

class Mixable
    public func mix [ b:Mixable, f:f64 ] -> Mixable
        return Mixable[]


Mixable Shadow
    public blur     : f32
    public color    : rgba
    public offset   : vec2f

    # CSS-friendly constructors. format: "<color>" | "<color> <ox> <oy>" |
    # "<color> <ox> <oy> <blur>".
    construct [ s: string ]
        aa : s.split[ ' ' ]
        if [ aa.count >= 1 ]
            color = rgba[ aa[0] ]
        if [ aa.count >= 3 ]
            offset = vec2f [ aa[1].real_value[], aa[2].real_value[] ]
        if [ aa.count >= 4 ]
            blur = f32 aa[3].real_value[]

Mixable Glow
    public blur     : f32
    public color    : rgba

    construct [ s: string ]
        aa : s.split[ ' ' ]
        if [ aa.count >= 1 ]
            color = rgba[ aa[0] ]
        if [ aa.count >= 2 ]
            blur = f32 aa[1].real_value[]

# only for background elements
Mixable Transform
    public offset   : vec2f
    public scale    : vec2f
    public Rotation : f32

Mixable Align
    public x        : XAlign
    public y        : YAlign


func parse_css_px [ s: string ] -> f32
    t : s.trim[]
    if [ t.ends_with[ 'px' ] ]
        t = t.mid[ 0, t.count - 2 ]
    return f32 t.real_value[]

Mixable Radius
    public tl : f32
    public tr : f32
    public br : f32
    public bl : f32

    construct [ f: f32 ]
        tl = f
        tr = f
        br = f
        bl = f
    construct [ f: string ]
        sp : f.split[' ']
        if [ sp.count == 1 ]
            tl = parse_css_px[ sp[0] ]
            tr = tl
            br = tl
            bl = tl
        el [ sp.count == 2 ]
            tl = parse_css_px[ sp[0] ]
            tr = tl
            br = parse_css_px[ sp[1] ]
            bl = br
        el
            tl = parse_css_px[ sp[0] ]
            tr = parse_css_px[ sp[1] ]
            br = parse_css_px[ sp[2] ]
            bl = parse_css_px[ sp[3] ]

Mixable Sides
    public top    : f32
    public right  : f32
    public bottom : f32
    public left   : f32

    construct [ f: f32 ]
        top = f
        right = f
        bottom = f
        left = f
    construct [ f: string ]
        sp : f.split[' ']
        if [ sp.count == 1 ]
            top    = parse_css_px[ sp[0] ]
            right  = top
            bottom = top
            left   = top
        el [ sp.count == 2 ]
            top    = parse_css_px[ sp[0] ]
            bottom = top
            right  = parse_css_px[ sp[1] ]
            left   = right
        el
            top    = parse_css_px[ sp[0] ]
            right  = parse_css_px[ sp[1] ]
            bottom = parse_css_px[ sp[2] ]
            left   = parse_css_px[ sp[3] ]


func parse_quoted [ cursor: @cstr, max_len: sz ] -> string
    first : cstr [ cursor[0] ]
    if [ first[0] != '"' && first[0] != '\'' ]
        return ''
    quote_ch : i8 [ first[0] ]
    cursor[0] += 1
    start : cstr [ cursor[0] ]
    s     : cstr [ start ]
    last_slash : false
    while [ s[0] != 0 ]
        if [ s[0] == '\\' ]
            last_slash = true
        el [ s[0] == quote_ch && !last_slash ]
            break
        el
            last_slash = false
        s += 1
    if [ s[0] == 0 ]
        return ''                                                                                                                   
    slen : sz [ s - start ]
    if [ max_len > 0 && slen > max_len ]                                                                                            
        return ''                            
    cursor[0] = @s[1]
    return string [ chars: start, ref_length: slen ] 


func parse_qualifiers [ bl:StyleBlock, p: @cstr ] -> array StyleQualifier
    expect bl, 'style-block context.. its not set!  dak not steady either'
    start : cstr   [ p[0] ]
    end   : cstr   [ null ]
    scan  : cstr   [ start ]
    qstr  : string [ null ]
    while [ scan[0] && scan[0] != '{' ]
        scan += 1
    end  = scan
    ref_len : distance[ start, scan ]
    qstr = string [ chars: start, ref_length: ref_len ]
    if [ !qstr.count ]
        p[0] = end
        return null
    quals  : qstr.split[ ',' ]
    result : array StyleQualifier [ ]
    ops    : array string [ '!=', '>=', '<=', '>', '<', '=' ]

    for [ qs: string ] in quals
        qq : qs.trim[]
        anchored : bool [ false ]
        if [ qq.count && qq.chars[0] == '/' ]
            anchored = true
            qq       = qq.mid[ 1, qq.count - 1 ].trim[]
        if [ !qq.count ]
            continue
        v : StyleQualifier[ bl:bl ]
        v.hold[]
        result.push[ v ]
        parent_to_child : qq.split[ '/' ]
        processed : StyleQualifier [ null ]
        for [ i: i32 parent_to_child.count - 1, i >= 0, i -= 1 ]
            q : parent_to_child[i].trim[]
            if [ processed ]
                v.parent = StyleQualifier[ bl:bl ]
                v.parent.hold[]
                v = v.parent
            idot : q.index_of[ '.' ]
            icol : q.index_of[ ':' ]
            tail : string [ null ]
            if [ idot >= 0 ]
                sp      : array string q.split[ '.' ]
                no_type : q.chars[0] == '.'
                v.type  = (no_type) ? 'element' : sp[0].trim[]
                sp2     : sp[ (no_type) ? 0 : 1 ].split[ ':' ]
                v.id    = sp2[0]
                if [ icol >= 0 ]
                    tail = q.mid[ icol + 1, q.count - (icol + 1) ].trim[]
            el
                if [ icol >= 0 ]
                    v.type = q.mid[ 0, icol ].trim[]
                    tail   = q.mid[ icol + 1, q.count - (icol + 1) ].trim[]
                el
                    v.type = q.trim[]
            if [ v.type ]
                v.ty = Au.find_type[ v.type.chars, null ]
                expect v.ty, 'type must exist: {v.type}'
                if [ !processed && bl.types.index_of[ v.ty ] == -1 ]
                    bl.types.push[ v.ty ]
            if [ tail ]
                is_op : false
                for [ op_name: string ] in ops
                    if [ tail.index_of[ op_name ] >= 0 ]
                        is_op = true
                        sp    : array string [ tail.split[ op_name ] ]
                        f     : sp[0]
                        v.state = f.trim[]
                        v.oper  = op_name
                        istart : i32 [ f.count + op_name.count ]
                        v.value = tail.mid[ istart, tail.count - istart ].trim[]
                        break
                if [ !is_op ]
                    # tail may contain multiple states joined by '&' — e.g.
                    # ':hovered&pressed'. all states listed must be truthy
                    # on the element for the selector to match. full boolean
                    # expression trees (|, !, parens) come later.
                    v.states = tail.split[ '&' ]
                    for [ k: i64 0, k < v.states.count, k += 1 ]
                        s : v.states[k]
                        v.states[k] = s.trim[]
                    v.state = v.states[0]
            processed = v
            v.hold_members[]
        if [ anchored ]
            v.anchored = true
    p[0] = end
    result.hold[]
    return result


func split_css [ code: string ] -> array CSSLine
    result : array CSSLine [ ]
    n      : num [ code.count ]
    i      : num [ 0 ]
    ln     : i32 [ 1 ]
    while [ i < n ]
        ind : i32 [ 0 ]
        while [ i < n && (code.chars[i] == ' ' || code.chars[i] == '\t') ]
            if [ code.chars[i] == '\t' ]
                ind += 4
            el
                ind += 1
            i += 1
        if [ i >= n ]
            break
        if [ code.chars[i] == '\n' ]
            i  += 1
            ln += 1
            continue
        # '#' at the START of a line (after the leading whitespace consumed above) is a
        # comment — skip the line. a '#' mid-line is a hex color (e.g. label_color: #fff)
        # and is untouched, since we only test the line's first non-space char here.
        if [ code.chars[i] == '#' ]
            while [ i < n && code.chars[i] != '\n' ]
                i += 1
            continue
        if [ i + 1 < n && code.chars[i] == '/' && code.chars[i + 1] == '/' ]
            while [ i < n && code.chars[i] != '\n' ]
                i += 1
            continue
        if [ i + 1 < n && code.chars[i] == '/' && code.chars[i + 1] == '*' ]
            i += 2
            while [ i + 1 < n && !(code.chars[i] == '*' && code.chars[i + 1] == '/') ]
                if [ code.chars[i] == '\n' ]
                    ln += 1
                i += 1
            if [ i + 1 < n ]
                i += 2
            continue
        line_start : num [ i ]
        cur_line   : i32 [ ln ]
        while [ i < n && code.chars[i] != '\n' ]
            i += 1
        line_len : num [ i - line_start ]
        c : code.mid[ line_start, line_len ].trim[]
        if [ c.count ]
            result.push[ CSSLine [ indent: ind, content: c, line: cur_line ] ]
    return result


func validate_entries [ entries: StyleEntryMap, ty: Au_t, errors: array string ]
    for [ se: StyleEntry, prop: string ] in entries
        dot  : prop.index_of[ '.' ]
        name : (dot > 0) ? prop.mid[ 0, dot ].trim[] : prop
        mem  : Au.find_member[ ty, name.chars, AU_MEMBER_VAR, 0, true ]
        if [ !mem ]
            errors.push[ string 'css: type {ty.ident} has no member {name} (from property {prop})' ]
            continue
        if [ dot > 0 ]
            sub_bl : (se.value to StyleBlock)
            if [ sub_bl && mem.meta.a ]
                validate_entries[ sub_bl.entries, mem.meta.a, errors ]


func validate_block [ bl: StyleBlock, errors: array string ]
    for [ ty: Au_t ] in bl.types
        validate_entries[ bl.entries, ty, errors ]


func parse_block_body [ bl: StyleBlock, lines: array CSSLine, first: i32, last: i32, base_indent: i32 ]
    j : i32 [ first ]
    while [ j <= last ]
        ind : i32    [ lines[j].indent  ]
        lc  : string [ lines[j].content ]
        if [ ind <= base_indent || lc == '}' ]
            j += 1
            continue
        ci : num [ lc.index_of[ ':' ] ]
        ln : i32 [ lines[j].line ]
        expect ci > 0, 'css line {ln}: expected key: value — got `{lc}`'
        member  : lc.mid[ 0, ci ].trim[]
        val_str : lc.mid[ ci + 1, lc.count - (ci + 1) ].trim[]
        for [ k: i32 0, k < member.count, k += 1 ]
            if [ member.chars[k] == '-' ]
                member.chars[k] = '_'
        sub_end : i32 [ j ]
        while [ sub_end + 1 <= last && lines[sub_end + 1].indent > ind ]
            sub_end += 1
        dot_pos : num  [ member.index_of[ '.' ] ]
        is_type : bool [ dot_pos > 0 && val_str.count > 0 && val_str.chars[0] >= 'A' && val_str.chars[0] <= 'Z' ]
        if [ (val_str.count == 0 && sub_end > j) || is_type ]
            inner : StyleBlock [ quals:bl.quals, types:bl.types ]
            if [ sub_end > j ]
                parse_block_body[ inner, lines, j + 1, sub_end, ind ]
            if [ dot_pos > 0 ]
                inner.key      = member.mid[ dot_pos + 1, member.count - dot_pos - 1 ]
                inner.property = member.mid[ 0, dot_pos ]
                inner.parent = bl
                if [ is_type ]
                    inner.type_name = val_str
                bl.blocks.push[ inner ]
            el
                bl.entries[ member ] = StyleEntry [ member: member, value: inner, bl: bl, line: lines[j].line ]
            j = sub_end + 1
            continue
        bi      : num    [ val_str.index_of[ '[' ] ]
        cm      : num    [ val_str.index_of[ ',' ] ]
        param   : string [ null ]
        value   : object [ null ]
        value_s : string [ null ]
        if [ bi != -1 && (cm == -1 || bi < cm) ]
            be : num [ val_str.index_of[ ']' ] ]
            expect be != -1, 'expected ] character'
            items : val_str.mid[ bi + 1, be - 1 ].trim[]
            rl    : val_str.count - be
            param = val_str.mid[ be + 1, rl ].trim[]
            if [ param.first[] == ',' ]
                param = param.mid[ 1, param.count - 1 ].trim[]
            el
                param = null
            sp : items.split[ ',' ]
            value = array string [ sp.count ]
            v : array string [ value ]
            for [ raw: string ] in sp
                s  : raw.trim[]
                if [ s.count >= 2 ]
                    q0 : s.mid[  0, 1 ]
                    q1 : s.mid[ -1, 1 ]
                    if [ (q0 == '"' || q0 == '\'') && q0 == q1 ]
                        s = s.mid[ 1, s.count - 2 ]
                v.push[ s ]
        el
            param   = (cm >= 0) ? val_str.mid[ cm + 1, val_str.count - (cm + 1) ].trim[] : null
            value_s = (cm >= 0) ? val_str.mid[ 0, cm ].trim[] : val_str
            if [ value_s && value_s.count >= 2 ]
                q0 : value_s.mid[  0, 1 ]
                q1 : value_s.mid[ -1, 1 ]
                if [ (q0 == '"' || q0 == '\'') && q0 == q1 ]
                    value_s = value_s.mid[ 1, value_s.count - 2 ]
            value   = value_s
        filter_val : f32 [ 0.0 ]
        if [ param && param.count >= 7 && param.mid[ 0, 7 ] == 'filter ' ]
            filter_val = f32[ param.mid[ 7, param.count - 7 ].trim[] ]
            param = null
        trans : (param) ? StyleTransition[ param ] : null
        is_bind : bool [ value_s && value_s.count >= 2 && value_s.chars[0] == '{' && value_s.chars[value_s.count - 1] == '}' ]
        bname   : string [ (is_bind) ? value_s.mid[ 1, value_s.count - 2 ].trim[] : null ]
        se : StyleEntry [ member: member, value: value, trans: trans, bl: bl, line: lines[j].line, binding: bname, filter: filter_val ]
        bl.entries[ member ] = se
        j += 1


func is_cmt[c: symbol] -> bool [ c[0] == '/' && c[1] == '*' ]


func ws [ p_cursor: @cstr ] -> bool
    cursor : cstr [ p_cursor[0] ]
    while [ isspace[ cursor[0] ] || is_cmt[ cursor ] ]
        while [ isspace[ cursor[0] ] ]
            cursor += 1
        if [ is_cmt[ cursor ] ]
            f : cstr [ strstr[ cursor, '*/' ] ]
            cursor = (f) ? @f[2] : @cursor[ strlen[ cursor ] - 1 ]
    p_cursor[0] = cursor
    return cursor != 0



func scan_to [ p_cursor: @cstr, chars: string ] -> bool
    sl  : false
    qt  : false
    qt2 : false
    cursor : cstr [ p_cursor[0] ]
    while [ cursor && cursor[0] ]
        if [ !sl ]
            if [ cursor[0] == '"' ]
                qt = !qt
            el [ cursor[0] == '\'' ]
                qt2 = !qt2
        sl = cursor[0] == '\\'
        if [ !qt && !qt2 ]
            if [ chars.index_of[ @cursor[0] ] >= 0 ]
                p_cursor[0] = cursor
                return true
        cursor += 1
    p_cursor[0] = null
    return false


func distance [ a:cstr, b:cstr ] -> i64
    aa  : sz[ a ]
    bb  : sz[ b ]
    val : abs [ aa - bb ]
    return val
    

func is_alpha2 [ c: i8 ] -> bool                                                                                                     
    return (c >= 'A' && c <= 'Z') || (c >= 'a' && c <= 'z')


func bounce_out [ x: f64 ] -> f64
    n1 : f64 [ 7.5625 ]
    d1 : f64 [ 2.75 ]
    if [ x < 1.0 / d1 ]
        return n1 * x * x
    el [ x < 2.0 / d1 ]
        return n1 * (x - 1.5 / d1) * x + 0.75
    el [ x < 2.5 / d1 ]
        return n1 * (x - 2.25 / d1) * x + 0.9375
    el
        return n1 * (x - 2.625 / d1) * x + 0.984375

func nib [ n: i8 ] -> i8
    if [ n >= '0' && n <= '9' ]
        return n - '0'
    if [ n >= 'a' && n <= 'f' ]
        return 10 + (n - 'a')
    if [ n >= 'A' && n <= 'F' ]
        return 10 + (n - 'A')
    return 0