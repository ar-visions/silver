extend trinity

# enums export to A-type
enum Ease
    linear  : 0
    quad    : 1
    cubic   : 2
    quart   : 3
    quint   : 4
    sine    : 5
    expo    : 6
    circ    : 7
    back    : 8
    elastic : 9
    bounce  : 10

enum Direction
    inward  : 0
    outward : 1
    in_out  : 2

enum Duration
    ms : 2
    ns : 1
    s  : 3

enum XAlign : f32
    undefined : 0
    left      : 0.0
    middle    : 0.5
    right     : 1.0
    width     : 2.0

enum YAlign : f32
    undefined : 0
    top       : 0.0
    middle    : 0.5
    bottom    : 1.0
    height    : 2.0

enum Overflow
    clip     : 0
    ellipsis : 1
    visible  : 2
    wrap     : 3

enum UXSurface
    background  : 0
    frost       : 1
    blur        : 2
    compose     : 3

enum Fill : f32
    none      : 0.00f
    blur      : 0.50f
    frost     : 1.00

enum CanvasType
    screen      : 0
    compose     : 1

enum Pattern
    none : 0
    repeat_x : 1
    repeat_y : 2
    repeat_xy : 3

enum Clip
    none : 0
    clip : 1
    ellipsis : 2


alias Elements : map    element [ string ]
alias FRender  : lambda Elements[ Display ]

# this Au type indicates we do not have an 'init' called
ielement element
    context vk              : vk_context
    context ux              : Window
    mutable parent          : element
    mutable area            : Region
    mutable bounds          : rect
    mutable value           : object
    mutable id              : string
    mutable flags           : i64
    mutable label           : string
    public  label2          : string
    mutable layers          : map Layer[string]
    mutable shaders         : map shader[string]
    #mutable bindings        : map ModelBind[string]
    mutable elements        : Elements
    mutable tags            : array string
    mutable group           : string
    mutable tab_index       : i32
    mutable scroll          : vec2f
    mutable content_h       : f32
    public  scroll_speed    : f32
    # per-element 2D transform. scale default (1,1), rotate in radians,
    # transform_origin normalized to element bounds (0.5,0.5 = center).
    # all three are transitionable via CSS just like colors.
    mutable scaling         : vec2f
    mutable rotation        : f32
    mutable transform_origin : vec2f
    mutable ghost           : bool
    mutable captured        : bool
    mutable disabled        : bool
    mutable hovered         : bool
    mutable pressed         : bool
    mutable focused         : bool
    mutable first           : bool
    mutable last            : bool
    mutable odd             : bool
    mutable even            : bool
    public  focusable       : bool
    public cursor           : vec2f
    mutable maps_populated  : bool

    # input event hooks. return true to swallow; false to let the window
    # continue to the app-level handler. both element and the app get a
    # chance at each event: element first, then app_object.
    public func on_click   [ ev: Event ] return
    public func on_press   [ ev: Event ] return
    public func on_release [ ev: Event ] return
    public func on_hover   [ ev: Event ] return
    public func on_leave   [ ev: Event ] return
    public func on_move    [ ev: Event ] return
    public func on_wheel [ ev: Event ]
        if [ content_h <= 0.0 ] return
        speed  : f32 [ (scroll_speed > 0.0) ? scroll_speed : 40.0 ]
        scroll.y += f32[ ev.mouse.wheel_delta.y ] * speed * -1.0
        if [ scroll.y < 0.0 ] scroll.y = 0.0
        max_sc : f32 [ content_h - bounds.h ]
        if [ max_sc > 0.0 && scroll.y > max_sc ] scroll.y = max_sc
        pristine = false
    public func on_key     [ ev: Event ] return
    public func on_char    [ ev: Event ] return
    intern style_avail  : map StyleEntries[string]
    #intern selections   : map
    intern transitions  : map StyleTransition[string]
    intern restyle       : bool
    mutable volatile     : bool
    intern cache_canvas  : Canvas
    intern cache_w       : i32
    intern cache_h       : i32
    intern cache_ox      : i32
    intern cache_oy      : i32
    mutable pristine     : bool [ false ]
    mutable needs_frame  : bool
    mutable fc           : f32

    public func set_capture []
        ux.set_capture[ a ]

    public func release_capture []
        ux.release_capture[ a ]

    public func set_focus []
        ux.set_focus[ a ]

    public func release_focus []
        ux.release_focus[ a ]

    public func draw [ w: Window ]
        return

    public func render [ ] -> Elements
        return null

    func invalidate_transitions [ ]
        for [ ct:StyleTransition, k:string ] in transitions
            ct.invalidate = true
        
        for [ e:element, k:string ] in elements
            e.invalidate_transitions[]

    func remove_invalid_transitions [ ]
        iterate : true
        del : false
        while [ iterate ]
            iterate = false
            for [ ct:StyleTransition, k:string ] in transitions
                if [ ct.invalidate ]
                    if [ ct.from ] ct.from.drop[]
                    if [ ct.to   ] ct.to.drop[]
                    transitions.rm[ k ]
                    iterate = true
                    del = true
                    break
            
        for [ e:element, k:string ] in elements
            e.remove_invalid_transitions[]


    intern func animate_within [ ]
        if [ transitions ]
            cur_millis : i64 [ epoch_millis[] ]
            for [ ct: StyleTransition, k: string ] in transitions
                dur : i64 [ ct.duration.get_millis[] ]
                ms  : i64 [ cur_millis - ct.start ]
                p   : f64 [ ct.pos[ f64[ ms ] / f64[ dur ] ] ]
                if [ ct.type && ct.from && ct.to ]
                    from_t : typeid[ ct.from ]
                    if [ (from_t.traits & (1 << 8)) != 0 ]
                        dst : ct.container.member_ref[ ct.member ]
                        #Au.mix_structs[ from_t, dst, ct.from, ct.to, p ]
                    el [ ct.from inherits collective ]
                        fa  : array Rotation ct.from
                        ta  : array Rotation ct.to
                        if [ fa && ta ]
                            n   : i32 [ (fa.count < ta.count) ? fa.count : ta.count ]
                            res : array Rotation []
                            for [ i: i32 0, i < n, i += 1 ]
                                res.push[ fa[i].mix[ ta[i], p ] ]
                            ct.container.member_set[ ct.member, res ]
                    el
                        mixed : ct.from.mix*[ ct.to, p ]
                        ct.container.member_set[ ct.member, mixed ]

        if [ volatile ]
            restyle = true

        for [ ee: element, id: string ] in elements
            ee.animate_within[ ]


alias StyleTransitions : map StyleTransition[string]


struct MouseState
    wheel_delta : vec2f
    pos         : vec2f
    button      : i32
    state       : i32

struct KeyboardState
    unicode   : u32
    scan_code : u32
    state     : i32
    meta      : bool
    shift     : bool
    alt       : bool
    ctrl      : bool
    text      : string


enum Blend
    normal:   0
    multiply: 1
    screen:   2
    overlay:  3
    add:      4


class Layer
    context parent             : element
    public ctype               : CanvasType
    public test2               : bool
    public area                : Region
    mutable bounds             : rect
    public radius              : Radius

    public fill_color               : rgba
    public fill_color_pos           : vec2f
    public fill_gradient            : GradientType
    public fill_gradient_color      : rgba
    public fill_gradient_radius     : f32
    public fill_gradient_radius_y   : f32
    public fill_gradient_angle      : f32
    public fill_offset         : f32
    public fill_shadow         : Shadow
    public fill_glow           : Glow
    public inner_glow          : Glow

    public stroke_gradient          : GradientType
    public stroke_gradient_color    : rgba
    public stroke_gradient_radius   : f32
    public stroke_gradient_radius_y : f32
    public stroke_gradient_angle    : f32
    public stroke_color             : rgba
    public stroke_color_pos         : vec2f
    public stroke_width             : Sides
    public stroke_offset            : f32
    public stroke_shadow            : Shadow
    public stroke_glow              : Glow
    public stroke_cap               : Cap
    public stroke_join              : Join
    public stroke_miter             : f32
    public stroke_dash              : array f32
    public stroke_dash_offset       : f32

    public label               : string
    public label_color         : rgba
    public label_color_pos     : vec2f
    public label_gradient          : rgba
    public label_gradient_radius   : f32
    public label_gradient_degrees  : f32
    public label_gradient_mirror   : bool
    public label_shadow        : rgba
    public label_shadow_offset : vec2f
    public label_shadow_blur   : f32
    public label_glow          : Glow
    public label_size          : f32   [ 22.0 ]
    public label_height        : f32 [ 1.0 ]
    public label_align         : vec2f [ x: 0.5, y: 0.5 ]
    public label_offset        : vec2f
    public label_overflow      : Overflow [ Overflow.ellipsis ]
    public label_font          : string
    mutable label_font_cache   : CanvasFont

    public font                : Font
    public image_svg           : SVGModel
    public image_scale         : f32 [ 1.0 ]
    public image_source        : Image
    public image_align         : Align
    public image_tranform      : Transform
    public image_repeat        : Pattern

    public background_gradient : Gradient
    public background_radius   : f32
    public background_origin   : vec2f
    public background_to       : vec2f

    public blend               : Blend
    public transform           : Transform
    public overflow            : Clip
    public clip                : bool
    public unclip              : bool
    public opacity             : f32

    public blur_x           : f32
    public blur_y           : f32
    intern blur_canvas      : Canvas
    intern blur_dirty       : bool
    intern blur_bw          : i32
    intern blur_bh          : i32

    func draw [ cv: Canvas ]
        return


# forward declarations need resolver support
# process same way, different gen method (make_class -> make_decl)
class Event
    mutable target         : element
    mutable mouse          : MouseState
    mutable key            : KeyboardState
    mutable no_default     : bool
    mutable no_propagation : bool

    func prevent_default  [ ] 
        no_default = true

    func is_default [ ] -> bool
        return !no_default

    func should_propagate [ ] -> bool
        return !no_propagation

    func stop_propagation [ ] -> bool
        no_propagation = true
        return true

    func clear [ ] 
        target         = null
        key            = []
        no_default     = false
        no_propagation = false
        mouse.state    = -1
        mouse.button   = -1


alias EventCallback : lambda none [ Event ]

struct EventDispatch
    callbacks : array EventCallback

    func invoke [ ev : Event ]
        for [ event_processor : EventCallback ] in callbacks
            event_processor[ev]
    
    operator += [ call : EventCallback ]
        callbacks += call


func filter_n[ current:f32, goal:f32, amount:f32, rate:f32 ] -> f32
    decay : pow[ 1.0f - amount, rate ]
    if [ goal != 0.0f ]
        return current + ((goal - current) * (1.0f - decay))
    el
        return current * decay