extend trinity

# enums export to A-type
enum Ease
    linear  : 0
    quad    : 1
    cubic   : 2
    quart   : 3
    quint   : 4
    sine    : 5
    expo    : 6
    circ    : 7
    back    : 8
    elastic : 9
    bounce  : 10

enum Direction
    inward  : 0
    outward : 1
    in_out  : 2

enum Duration
    ms : 2
    ns : 1
    s  : 3

enum XAlign : f32
    undefined : 0
    left      : 0.0
    middle    : 0.5
    right     : 1.0
    width     : 2.0

enum YAlign : f32
    undefined : 0
    top       : 0.0
    middle    : 0.5
    bottom    : 1.0
    height    : 2.0

enum Overflow
    clip     : 0
    ellipsis : 1
    visible  : 2
    wrap     : 3

enum UXSurface
    background  : 0
    frost       : 1
    blur        : 2
    compose     : 3

enum Fill : f32
    none      : 0.00f
    blur      : 0.50f
    frost     : 1.00

enum CanvasType
    screen      : 0
    compose     : 1

enum Pattern
    none : 0
    repeat_x : 1
    repeat_y : 2
    repeat_xy : 3

enum Clip
    none : 0
    clip : 1
    ellipsis : 2


alias Elements : map    element [ string ]
alias FRender  : lambda Elements[ Display ]

# this Au type indicates we do not have an 'init' called
ielement element
    context vk              : vk_context
    context ux              : Window
    mutable parent          : element
    mutable area            : Region
    mutable bounds          : rect
    mutable value           : object
    mutable id              : string
    mutable flags           : i64
    intern  initialized     : bool
    mutable label           : string
    # editable text buffer — SEPARATE storage from `label`. `label` is the
    # app-set display string; when a layer is editable, the user types into
    # `edit`, never over `label`. label renders as a dim placeholder while
    # `edit` is empty.
    mutable edit            : string
    # styleable state: true while the editable buffer holds text (vs the placeholder
    # label). CSS targets it with `:has_value` — e.g. ghost the label until entered.
    public  has_value       : bool
    public  label2          : string
    # --screenshot <file> on any app: dump the frame + exit (adopted by trinity)
    public  screenshot      : path
    # --shot-frame N: frame index the screenshot captures at
    public  shot_frame      : i32 [ 60 ]
    # --attach <sock>: render offscreen and share the frame with orbiter over
    # an AF_UNIX socket instead of opening a window (adopted by trinity)
    public  attach          : path
    mutable layers          : map Layer[string]
    mutable shaders         : map shader  [string]
    #mutable bindings        : map ModelBind[string]
    mutable elements        : Elements
    mutable tags            : array string
    mutable group           : string
    mutable tab_index       : i32
    mutable scroll          : vec2f
    mutable content_h       : f32
    public  scroll_speed    : f32
    # per-element 2D transform. scale default (1,1), rotate in radians,
    # transform_origin normalized to element bounds (0.5,0.5 = center).
    # all three are transitionable via CSS just like colors.
    mutable scaling         : vec2f
    mutable rotation        : f32
    mutable transform_origin : vec2f
    public  ghost           : bool
    # fully hidden: not painted and not hit-tested (layout still computes).
    public  hide            : bool
    mutable captured        : bool
    public  disable         : bool
    # console rendering: draw a box-drawing border around this element and inset
    # its children by 1 cell on every side. off by default, so structural/layout
    # wrappers stay borderless — only opted-in elements get a frame.
    public  bordering       : bool
    # topmost children paint LAST (drawn over their siblings) and are hit-tested
    # FIRST (they get the event before siblings underneath them). use for
    # floating controls that overlap a full-area sibling, e.g. a toggle button
    # sitting on top of an editor view.
    public  topmost         : bool
    mutable hovered         : bool
    mutable pressed         : bool
    mutable focused         : bool
    mutable first           : bool
    mutable last            : bool
    mutable middle          : bool
    mutable odd             : bool
    mutable even            : bool
    public  focusable       : bool
    public cursor_pos       : vec2f
    # a fixed child: not part of the parent's scrolled content, so find_target must
    # hit-test it in UNSCROLLED local space (don't fold the parent's scroll into it).
    public  no_scroll       : bool
    mutable maps_populated  : bool
    mutable sel_col         : i32 [ -1 ]
    mutable anchor_col      : i32 [ 0 ]
    mutable text_dragging   : bool

    # input event hooks. return true to swallow; false to let the window
    # continue to the app-level handler. both element and the app get a
    # chance at each event: element first, then app_object.
    public func on_click   [ ev: Event ] return
    public func on_press   [ ev: Event ] return
    public func on_release [ ev: Event ] return
    public func on_hover   [ ev: Event ] return
    public func on_leave   [ ev: Event ] return
    public func on_move    [ ev: Event ] return
    public func on_wheel [ ev: Event ]
        if [ content_h <= 0.0 ] return
        speed  : f32 [ (scroll_speed > 0.0) ? scroll_speed : 40.0 ]
        scroll.y += f32[ ev.mouse.wheel_delta.y ] * speed * -1.0
        if [ scroll.y < 0.0 ] scroll.y = 0.0
        max_sc : f32 [ content_h - bounds.h ]
        if [ max_sc > 0.0 && scroll.y > max_sc ] scroll.y = max_sc
        pristine = false
        ux.will_animate = true
    public func on_key     [ ev: Event ] return
    public func on_char    [ ev: Event ] return
    public func on_drop    [ ev: Event ] return
    # live inspector: cmd+click hands the app element the matched style blocks
    # ({file,line}) for the clicked element; cmd+shift+click hands its
    # DECLARATION site. no-op base.
    public func on_inspect [ hits: array StyleHit ] return
    # screen canvas hook: called on the app element before the tree paints
    public func on_canvas  [ cv: Canvas ] return
    # like on_canvas, but AFTER the element tree paints — overlays
    public func on_overlay [ cv: Canvas ] return
    intern style_avail  : map StyleEntries[string]
    #intern selections   : map
    intern transitions  : map StyleTransition[string]

    intern restyle       : bool
    mutable volatile     : bool
    # ALWAYS redraw, never cache: for elements whose content changes every
    # frame regardless of style state (emulators, video, live views).
    # `volatile` looks similar but is OWNED BY THE STYLE ENGINE (active
    # transitions/EMA) and is cleared when styles settle — do not hijack it.
    public  animated     : bool
    intern cache_canvas  : Canvas
    intern cache_w       : i32
    intern cache_h       : i32
    intern cache_ox      : i32
    intern cache_oy      : i32
    # edge fade mask: when any mask_glow component > 0, the cache blit is
    # modulated by a grayscale mask canvas (white center, black edges via a
    # black per-edge inner glow). mask_glow = (top, right, bottom, left) px.
    # built lazily at the blit, rebuilt on cache resize.
    intern mask_canvas   : Canvas
    intern mask_w        : i32
    intern mask_h        : i32
    public mask_glow     : vec4f
    # the glow the mask was last built with — rebuild the mask when it changes (not
    # just on resize), so a fade that turns on/off (e.g. on horizontal scroll) shows.
    intern mask_bg       : vec4f
    # px on the left kept fully opaque after the fade is built (e.g. a fixed gutter):
    # the left fade originates just right of it. 0 = no kept strip.
    public mask_keep_l   : f32
    # inset (top, right, bottom, left) px: shrinks the masked rect so the fade
    # starts inset from each edge. region outside the inset stays fully masked
    # (e.g. content scrolling under a titlebar). 0 = fade from the edge.
    public mask_inset    : vec4f
    mutable pristine     : bool [ false ]
    mutable needs_frame  : bool
    mutable fc           : f32
    public  transparency : f32

    public func set_capture []
        ux.set_capture[ a ]

    public func release_capture []
        ux.release_capture[ a ]

    public func set_focus []
        ux.set_focus[ a ]

    public func release_focus []
        ux.release_focus[ a ]

    public func draw [ w: Window ]
        return

    # teardown hook: called for the whole live tree at app destroy (hot-reload
    # boundary or exit) BEFORE the window drops — while this module's code is
    # still mapped. elements that own threads or external state (emulators,
    # audio) stop them here; dealloc order is not deterministic enough for
    # thread teardown.
    public func on_unload [ ]
        return

    func unload_tree [ ]
        on_unload*[]
        for [ ee: element, k: string ] in elements
            ee.unload_tree[]

    public func render [ ] -> Elements
        return null

    # console (terminal) render hook: an element that paints text content (an
    # editor, a console log) overrides these so the box-drawing render path can
    # stamp its rows. console_line_count[] is the number of text rows available;
    # console_line[vr] returns the text for visual row vr (null/'' = blank). the
    # default is a non-text element (count 0), so structural elements draw nothing.
    public func console_line_count [] -> i32
        return 0

    public func console_line [ vr: i32 ] -> string
        return null

    func invalidate_transitions [ ]
        for [ ct:StyleTransition, k:string ] in transitions
            ct.invalidate = true
        
        for [ e:element, k:string ] in elements
            e.invalidate_transitions[]

    func remove_invalid_transitions [ ]
        iterate : true
        del : false
        while [ iterate ]
            iterate = false
            for [ ct:StyleTransition, k:string ] in transitions
                if [ ct.invalidate ]
                    if [ ct.from ] ct.from.drop[]
                    if [ ct.to   ] ct.to.drop[]
                    transitions.rm[ k ]
                    iterate = true
                    del = true
                    break
            
        for [ e:element, k:string ] in elements
            e.remove_invalid_transitions[]


    intern func animate_within [ ]
        if [ transitions ]
            cur_millis : i64 [ epoch_millis[] ]
            for [ ct: StyleTransition, k: string ] in transitions
                dur : i64 [ ct.duration.get_millis[] ]
                ms  : i64 [ cur_millis - ct.start ]
                p   : f64 [ ct.pos[ f64[ ms ] / f64[ dur ] ] ]
                if [ ct.type && ct.from && ct.to ]
                    from_t : typeid[ ct.from ]
                    if [ (from_t.traits & (1 << 8)) != 0 ]
                        dst : ct.container.member_ref[ ct.member ]
                        #Au.mix_structs[ from_t, dst, ct.from, ct.to, p ]
                    el [ ct.from inherits collective ]
                        fa  : array Rotation ct.from
                        ta  : array Rotation ct.to
                        if [ fa && ta ]
                            n   : i32 [ (fa.count < ta.count) ? fa.count : ta.count ]
                            res : array Rotation []
                            for [ i: i32 0, i < n, i += 1 ]
                                r : fa[i]
                                res.push[ r.mix[ ta[i], p ] ]
                            ct.container.member_set[ ct.member, res ]
                    el
                        mixed : ct.from.mix*[ ct.to, p ]
                        ct.container.member_set[ ct.member, mixed ]

        if [ volatile ]
            restyle = true

        for [ ee: element, id: string ] in elements
            ee.animate_within[ ]

    public func is_animating [] -> bool
        if [ volatile ] return true
        if [ transitions ]
            cur_millis : i64 [ epoch_millis[] ]
            for [ ct: StyleTransition, k: string ] in transitions
                if [ ct.duration ]
                    dur : i64 [ ct.duration.get_millis[] ]
                    ms  : i64 [ cur_millis - ct.start ]
                    if [ ms < dur ] return true
        for [ ee: element, id: string ] in elements
            if [ ee.is_animating[] ] return true
        return false

    #mutable selected     : bool


alias StyleTransitions : map StyleTransition[string]


struct MouseState
    wheel_delta : vec2f
    pos         : vec2f
    button      : i32
    state       : i32
    double_click : bool

struct KeyboardState
    unicode   : u32
    scan_code : u32
    state     : i32
    meta      : bool
    shift     : bool
    alt       : bool
    ctrl      : bool
    text      : string


enum Blend
    normal:   0
    multiply: 1
    screen:   2
    overlay:  3
    add:      4


class Layer
    context parent             : element
    public ctype               : CanvasType
    # overlay layers (e.g. a scrollbar) draw on the parent canvas AFTER the
    # element's cache is composited, so an element edge mask doesn't affect
    # them — the mask stays scoped to the content layers in the cache.
    public overlay             : bool
    public test2               : bool
    public area                : Region
    mutable bounds             : rect
    public radius              : Radius

    public fill_color               : rgba
    public fill_color_pos           : vec2f
    public fill_gradient            : GradientType
    public fill_gradient_color      : rgba
    public fill_gradient_radius     : f32
    public fill_gradient_radius_y   : f32
    public fill_gradient_angle      : f32
    public fill_offset         : f32
    public fill_shadow         : Shadow
    public fill_glow           : Glow
    public inner_glow          : Glow

    public stroke_gradient          : GradientType
    public stroke_gradient_color    : rgba
    public stroke_gradient_radius   : f32
    public stroke_gradient_radius_y : f32
    public stroke_gradient_angle    : f32
    public stroke_color             : rgba
    public stroke_color_pos         : vec2f
    public stroke_width             : Sides
    public stroke_offset            : f32
    public stroke_shadow            : Shadow
    public stroke_glow              : Glow
    public stroke_cap               : Cap
    public stroke_join              : Join
    public stroke_miter             : f32
    public stroke_dash              : array f32
    public stroke_dash_offset       : f32

    public label               : string
    public label_color         : rgba
    public label_color_pos     : vec2f
    public label_gradient          : rgba
    public label_gradient_radius   : f32
    public label_gradient_degrees  : f32
    public label_gradient_mirror   : bool
    public label_shadow        : rgba
    public label_shadow_offset : vec2f
    public label_shadow_blur   : f32
    public label_glow          : Glow
    public label_size          : f32   [ 22.0 ]
    public label_height        : f32 [ 1.0 ]
    public label_align         : vec2f [ x: 0.5, y: 0.5 ]
    public label_offset        : vec2f
    public label_overflow      : Overflow [ Overflow.ellipsis ]
    public label_font          : string
    mutable label_font_cache   : CanvasFont

    public font                : Font
    public image_svg           : SVGModel
    public image_scale         : f32 [ 1.0 ]
    public image_source        : Image
    public image_align         : Align
    public image_tranform      : Transform
    public image_repeat        : Pattern

    public background_gradient : Gradient
    public background_radius   : f32
    public background_origin   : vec2f
    public background_to       : vec2f

    public blend               : Blend
    public transform           : Transform
    public overflow            : Clip
    public clip                : bool
    public unclip              : bool
    public opacity             : f32
    public hide                : bool

    public blur_x           : f32
    public blur_y           : f32
    intern blur_canvas      : Canvas
    intern blur_dirty       : bool
    intern blur_bw          : i32
    intern blur_bh          : i32

    public  editable    : bool
    mutable lh_cache    : f32  [ 0.0 ]
    mutable cw_cache    : f32  [ 0.0 ]

    func hit_col [ ev: Event ] -> i32
        cw    : f32 [ (cw_cache > 0.0) ? cw_cache : 8.0 ]
        text  : string [ (parent.edit) ? parent.edit : '' ]
        rel_x : f32 [ ev.mouse.pos.x - bounds.x ]
        return clamp[ i32[ round[ rel_x / cw ] ], 0, text.count ]

    func on_press [ ev: Event ]
        if [ parent.sel_col < 0 ] parent.sel_col = 0
        c : i32 [ hit_col[ ev ] ]
        if [ !ev.key.shift ]
            parent.anchor_col = c
            parent.sel_col    = c
        el
            parent.sel_col = c
        parent.text_dragging = true
        parent.set_capture[]
        parent.set_focus[]
        parent.pristine = false

    func on_move [ ev: Event ]
        if [ !parent.text_dragging ] return
        parent.sel_col = hit_col[ ev ]
        parent.pristine = false

    func on_release [ ev: Event ]
        parent.text_dragging = false
        parent.release_capture[]

    func delete_selection [ text: string ] -> bool
        sc : i32 [ (parent.sel_col < parent.anchor_col) ? parent.sel_col : parent.anchor_col ]
        ec : i32 [ (parent.sel_col < parent.anchor_col) ? parent.anchor_col : parent.sel_col ]
        if [ sc == ec ] return false
        parent.edit    = text.mid[ 0, sc ] + text.mid[ ec, text.count - ec ]
        parent.sel_col    = sc
        parent.anchor_col = sc
        return true

    func on_char [ ev: Event ]
        if [ parent.sel_col < 0 ] parent.sel_col = 0
        text : string [ (parent.edit) ? parent.edit : '' ]
        delete_selection[ text ]
        text = (parent.edit) ? parent.edit : ''
        col  : i32 [ parent.sel_col ]
        parent.edit = text.mid[ 0, col ] + ev.key.text + text.mid[ col, text.count - col ]
        parent.sel_col += ev.key.text.count
        parent.anchor_col = parent.sel_col
        parent.pristine = false

    func on_key [ ev: Event ]
        if [ !ev.key.state ] return
        if [ parent.sel_col < 0 ] parent.sel_col = 0
        text : string [ (parent.edit) ? parent.edit : '' ]
        col  : i32 [ parent.sel_col ]
        key  : i32 [ ev.key.unicode ]
        if [ key == 259 ]
            if [ !delete_selection[ text ] ]
                if [ col > 0 ]
                    parent.edit = text.mid[ 0, col - 1 ] + text.mid[ col, text.count - col ]
                    parent.sel_col -= 1
            parent.anchor_col = parent.sel_col
        el [ key == 263 ]
            if [ parent.sel_col != parent.anchor_col && !ev.key.shift ]
                sc : i32 [ (parent.sel_col < parent.anchor_col) ? parent.sel_col : parent.anchor_col ]
                parent.sel_col    = sc
                parent.anchor_col = sc
            el [ col > 0 ]
                parent.sel_col -= 1
                if [ !ev.key.shift ] parent.anchor_col = parent.sel_col
        el [ key == 262 ]
            if [ parent.sel_col != parent.anchor_col && !ev.key.shift ]
                ec : i32 [ (parent.sel_col > parent.anchor_col) ? parent.sel_col : parent.anchor_col ]
                parent.sel_col    = ec
                parent.anchor_col = ec
            el [ col < text.count ]
                parent.sel_col += 1
                if [ !ev.key.shift ] parent.anchor_col = parent.sel_col
        el [ key == 256 ]
            parent.edit = ''
            parent.sel_col = 0
            parent.anchor_col = 0
        parent.pristine = false

    func draw [ cv: Canvas ]
        if [ !editable || !cv ] return
        # set the size first: measure_text/draw_text call ensure_font, which
        # otherwise reloads the default font at the canvas's state size (22) and
        # clobbers any set_font below.
        cv.font_size[ i32[label_size] ]
        if [ label_font && label_font.count > 0 ]
            if [ !label_font_cache ]
                label_font_cache = CanvasFont [ ft_lib: cv.ft_lib, uri: label_font, size_px: i32[label_size] ]
            cv.set_font[ label_font_cache ]
        el
            # load the default font NOW. font_size only sets the size; the font is loaded
            # lazily by measure_text/draw_text — which are below the guard. on a fresh canvas
            # (an editable element with no other text, e.g. an empty find/replace field) cv.font
            # would still be null here and the draw would bail before ever loading it.
            cv.ensure_font[]
        if [ !cv.font ] return
        # the editable buffer is separate storage; the label is shown as a dim
        # placeholder ONLY while actively focused with nothing typed yet. with
        # text, or once focus is lost, the label/text renders at full brightness
        # (so a just-cleared, unfocused title is bright, not stuck dim). the
        # caret/selection only ever ride the edit buffer, never the label.
        etext    : string [ (parent.edit) ? parent.edit : '' ]
        has_edit : bool   [ etext.count > 0 ]
        disp     : string [ (has_edit) ? etext : ((parent.label) ? parent.label : '') ]
        tm    : cv.measure_text[ disp ]
        cw_tm : cv.measure_text[ 'x' ]
        lh_cache = cv.get_line_height[]
        cw_cache = cw_tm.w

        ax    : f32 [ label_align.x ]
        ay    : f32 [ label_align.y ]
        ox    : f32 [ label_offset.x ]
        oy    : f32 [ label_offset.y ]
        fh    : f32 [ tm.ascent - tm.descent ]
        x0    : f32 [ bounds.x + (bounds.w - tm.w) * ax + ox ]
        y0    : f32 [ bounds.y + tm.ascent + (bounds.h - fh) * ay + oy ]
        cw    : f32 [ cw_tm.w ]

        col : i32 [ (parent.sel_col >= 0) ? parent.sel_col : 0 ]
        anc : i32 [ parent.anchor_col ]
        sc  : i32 [ (col < anc) ? col : anc ]
        ec  : i32 [ (col < anc) ? anc : col ]

        if [ has_edit && sc != ec ]
            cv.fill_color[ '#264f78' ]
            cv.stroke_width[ 0.0 ]
            cv.rect_to[ x0 + f32[sc] * cw, y0 - tm.ascent + 2.0, f32[ec - sc] * cw, fh - 4.0 ]
            cv.paint[]

        # single tone: the label_color from CSS. gray for the placeholder, white once
        # the field has a value (driven by the :has_value state, not a built-in alpha).
        cv.fill_color[ label_color ]
        cv.draw_text[ disp, bounds, vec2f [ ax, ay ], vec2f [ ox, oy ], Overflow.visible, null ]
        cv.paint[]

        if [ parent.focused && parent.sel_col >= 0 ]
            prefix : string [ (has_edit) ? etext.mid[ 0, col ] : '' ]
            m  : cv.measure_text[ prefix ]
            cx : f32 [ x0 + m.w ]
            cv.fill_color[ '#fff' ]
            cv.stroke_width[ 0.0 ]
            cv.rect_to[ cx, y0 - tm.ascent + 2.0, 2.0, fh - 4.0 ]
            cv.paint[]


# forward declarations need resolver support
# process same way, different gen method (make_class -> make_decl)
class Event
    mutable target         : element
    # the element the event hit (find_target result); target walks the bubble
    mutable origin         : element
    mutable mouse          : MouseState
    mutable key            : KeyboardState
    mutable no_default     : bool
    mutable no_propagation : bool

    func prevent_default  [ ] 
        no_default = true

    func is_default [ ] -> bool
        return !no_default

    func should_propagate [ ] -> bool
        return !no_propagation

    func stop_propagation [ ] -> bool
        no_propagation = true
        return true

    func clear [ ]
        target         = null
        origin         = null
        key            = []
        no_default     = false
        no_propagation = false
        mouse.state    = -1
        mouse.button   = -1
        mouse.double_click = false


alias EventCallback : lambda none [ Event ]

struct EventDispatch
    callbacks : array EventCallback

    func invoke [ ev : Event ]
        for [ event_processor : EventCallback ] in callbacks
            event_processor[ev]
    
    operator += [ call : EventCallback ]
        callbacks += call


func filter_n[ current:f32, goal:f32, amount:f32, rate:f32 ] -> f32
    decay : pow[ 1.0f - amount, rate ]
    if [ goal != 0.0f ]
        return current + ((goal - current) * (1.0f - decay))
    el
        return current * decay