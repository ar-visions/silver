extend trinity


struct vertex_member_t
    src:    Au_t
    ac:     Accessor
    size:   i64
    offset: i64

alias ShaderModuleRef : ref VkShaderModule

class shader
    context vk          : vk_context
    public name         : string
    public vert         : path
    public frag         : path
    public comp         : path
    public reload_count : i32

    # used by elements which make shader instances central to drawing order
    public model_id     : string
    public env_id       : string
    public groups       : array string
    public materials    : array string # this is one or the other
    public transparent  : bool
    public texture      : string
    public mip_levels   : i32
    
    intern vk_vert      : VkShaderModule
    intern vk_frag      : VkShaderModule
    intern vk_comp      : VkShaderModule
    intern ctx          : array Au_t

    func context_chain [] -> array Au_t
        if [!ctx]
            r: array Au_t []
            f: typeid [ a ]
            while [ f && f != typeid[ shader ] ]
                r.push[f]
                f = f.context
            ctx = r.reverse[]
        return ctx

    func indent [ s: symbol ] -> string
        str: string[s]
        sp : str.split["\n"]
        res: string[alloc:str.count * 2]
        for [line:string] in sp
            res.append["\t"]
            res.concat[line]
            res.append["\n"]
        return res

    func vertex   [] -> GLSL none {}

    func fragment [] -> GLSL none {}

    func compute  [] -> GLSL none {}

    func set_frame [ model_mat: mat4f, view_mat: mat4f, proj_mat: mat4f, ep: vec4f, t: f32 ]
        return

    func glsl_type_name [ t: Au_t ] -> cstr
        if [ t == typeid[ mat4f ] ]
            return "mat4"
        if [ t == typeid[ mat3f ] ]
            return "mat3"
        if [ t == typeid[ vec4f ] ]
            return "vec4"
        if [ t == typeid[ vec3f ] ]
            return "vec3"
        if [ t == typeid[ vec2f ] ]
            return "vec2"
        if [ t == typeid[ f32 ] ]
            return "float"
        if [ t == typeid[ i32 ] ]
            return "int"
        if [ t == typeid[ u32 ] ]
            return "uint"
        if [ t == typeid[ bool ] ]
            return "bool"
        if [ t == typeid[ none ] ]
            return "void"
        if [ t == typeid[ sampler2D ] ]
            return "sampler2D"
        if [ t == typeid[ sampler3D ] ]
            return "sampler3D"
        if [ t == typeid[ samplerCube ] ]
            return "samplerCube"
        return null

    func glsl_header [ stage: ShaderStage ] -> string
        type:   typeid[ a ]
        result: string [ '#version 450\n\n' ]

        # emit void main() from the stage entry point
        main_name: (stage == ShaderStage.vertex) ? "vertex" : (stage == ShaderStage.fragment) ? "fragment" : "compute"
        main_member:  find_member[ type, main_name, 5, 0, true ]
        if [ !main_member || main_member.context == typeid[shader] ]
            return null

        # local size for compute stage. fixed at 16x16 — matches the
        # canvas_sdf.comp prototype. could be made per-shader configurable
        # via a class field if other compute shaders need different sizes.
        if [ stage == ShaderStage.compute ]
            result = '{result}layout(local_size_x = 16, local_size_y = 16, local_size_z = 1) in;\n\n'


        # UBO from mutable members — emit base-first to match C struct layout
        ubo_name: type.ident
        result = '{result}layout(set = 0, binding = 0) uniform {ubo_name} {{\n'
        chain: context_chain[]
        for [ sc:Au_t ] in chain
            for [ mem:Au_t ] in sc.members
                if [ !is_uniform_field[ mem ] ]
                    continue
                gtype: glsl_type_name[ mem.src ]
                if [ !gtype ]
                    continue
                result = '{result}    {gtype} {mem.ident};\n'

        result = '{result}}} ubo;\n\n'

        # attribs: samplers, vertex i/o, fragment i/o
        binding:      i32 [ 0 ]
        vert_loc_in:  i32 [ 0 ]
        vert_loc_out: i32 [ 0 ]
        frag_loc_in:  i32 [ 0 ]
        frag_loc_out: i32 [ 0 ]

        for [ scan : Au_t ] in chain
            for [ mem:Au_t ] in scan.members
                if [ mem.member_type != 4 ]
                    continue
                if [ !(mem.traits & (1 << 56)) ] # AU_TRAIT_IS_ATTRIB
                    continue
                val: Au [ mem.value ]
                if [ !mem.value ]
                    continue
                
                if [ val inherits LayoutBinding ]
                    lb: LayoutBinding[val]
                    is_cube: lb.id == 9
                    stype: (is_cube) ? "samplerCube" : "sampler2D"
                    if [ lb.count > 1 ]
                        result = '{result}layout(set = 1, binding = {binding}) uniform {stype} {mem.ident}[{lb.count}];\n'
                    el
                        result = '{result}layout(set = 1, binding = {binding}) uniform {stype} {mem.ident};\n'
                    binding += 1

                el [ val inherits StorageImage ]
                    si: StorageImage[val]
                    # GLSL format qualifier from the meta type. only the formats
                    # we actually use are mapped; extend as needed.
                    img_fmt: (si.format == typeid[ f32 ]) ? "r32f" :
                             (si.format == typeid[ rgbaf ]) ? "rgba32f" : "r32f"
                    result = '{result}layout({img_fmt}, set = 1, binding = {binding}) writeonly uniform image2D {mem.ident};\n'
                    binding += 1

                el [ val inherits StorageBuffer ]
                    result = '{result}layout(std430, set = 1, binding = {binding}) readonly buffer {mem.ident}_t {{ vec4 {mem.ident}[]; }};\n'
                    binding += 1

                el [ val inherits VertexInput && stage == ShaderStage.vertex ]
                    vi: (val to VertexInput)
                    gtype: glsl_type_name[ vi.type ]
                    if [ gtype ]
                        result = '{result}layout(location = {vert_loc_in}) in {gtype} {mem.ident};\n'
                    vert_loc_in += 1

                el [ val inherits VertexOutput && stage == ShaderStage.vertex ]
                    vo: (val to VertexOutput)
                    gtype: glsl_type_name[ vo.type ]
                    if [ gtype ]
                        result = '{result}layout(location = {vert_loc_out}) out {gtype} {mem.ident};\n'
                    vert_loc_out += 1

                el [ val inherits VertexOutput && stage == ShaderStage.fragment ]
                    vo: (val to VertexOutput)
                    gtype: glsl_type_name[ vo.type ]
                    if [ gtype ]
                        result = '{result}layout(location = {frag_loc_in}) in {gtype} {mem.ident};\n'
                    frag_loc_in += 1

                el [ val inherits FragmentInput && stage == ShaderStage.fragment ]
                    fi: (val to FragmentInput)
                    gtype: glsl_type_name[ fi.type ]
                    if [ gtype ]
                        result = '{result}layout(location = {frag_loc_in}) in {gtype} {mem.ident};\n'
                    frag_loc_in += 1

                el [ val inherits FragmentOutput && stage == ShaderStage.fragment ]
                    fo: (val to FragmentOutput)
                    gtype: glsl_type_name[ fo.type ]
                    if [ gtype ]
                        result = '{result}layout(location = {frag_loc_out}) out {gtype} {mem.ident};\n'
                    frag_loc_out += 1


        # for methods, its preferrable to go top down since we may handle overrides easier
        scan : type
        while [ scan != typeid[ shader ] ]
            for [ i: 0, i < scan.members.count, i += 1 ]
                method: Au_t [ scan.members.origin[i] ]
                if [ method.member_type != 5 ]
                    continue
                if [ !method.src || !method.meta.a ]
                    continue
                if [ strcmp[ method.ident, "fragment" ] == 0 || strcmp[ method.ident, "vertex" ] == 0 || strcmp[ method.ident, "compute" ] == 0 ]
                    continue
                rtype : Au_t [ method.meta.a ]
                ret_name: glsl_type_name[ rtype ]
                if [ !ret_name ]
                    ret_name = "void"

                # build arg list from method.args (skip first arg which is self)
                arg_str: ''
                for [ j: 1, j < method.args.count, j += 1 ]
                    arg: Au_t [ method.args.origin[j] ]
                    atype: glsl_type_name[ arg.src ]
                    if [ !atype ]
                        continue
                    if [ j > 1 ]
                        arg_str = '{arg_str}, '
                    arg_str = '{arg_str}{atype} {arg.ident}'

                glsl: GLSL Au.method_call[ method, null ]
                if [ stage == ShaderStage.vertex && glsl inherits FragGLSL ]
                    continue
                if [ stage == ShaderStage.fragment && glsl inherits VertGLSL ]
                    continue

                #l : strlen[ glsl.body ]
                l : strlen[glsl.body]
                expect l, 'body not set on function {method.ident}'

                # emit function
                result = '{result}{ret_name} {method.ident}({arg_str}) {{\n{glsl.body}\n}}\n\n'
            
            scan = scan.context
                    
        # emit void main() from the stage entry point
        main_result: GLSL Au [ Au.method_call[ main_member, null ] ]
        if [ main_result ]
            result = '{result}void main() {{\n{main_result.body}\n}}\n'
        return result

    func generate_shaders [ ]
        type:   typeid[ a ]
        paths:  local path [3] [ vert, frag, comp ]
        stages: local i32  [3] [ 0, 1, 2 ]

        for [ i: 0, i < 3, i += 1 ]
            p: path paths[i]
            if [ !p ]
                continue
            stage: (i == 0) ? ShaderStage.vertex : (i == 1) ? ShaderStage.fragment : ShaderStage.compute
            src: glsl_header[ stage ]
            if [ !src ]
                continue
            
            # only write the .vert/.frag/.comp if its content has actually
            # changed. a redundant rewrite bumps mtime and forces an
            # unnecessary glslangValidator recompile (which used to race
            # between concurrent shader instances of the same type) — but
            # if we just blanket-skip on existence, the user editing the
            # GLSL inside the .ag file silently has no effect because the
            # stale on-disk shader keeps loading. compare byte-for-byte
            # and only skip when truly identical.

            should_write : bool true
            if [ p.exists[] ]
                rfp : fopen[ p, "rb" ]
                if [ rfp ]
                    fseek[ rfp, 0, SEEK_END ]
                    flen : ftell[ rfp ]
                    rewind[ rfp ]
                    sl : i64 strlen[ src.chars ]
                    if [ flen == sl ]
                        existing : malloc[ flen ]
                        fread[ existing, 1, flen, rfp ]
                        if [ memcmp[ existing, src.chars, flen ] == 0 ]
                            should_write = false
                        free[ existing ]
                    fclose[ rfp ]
            if [ !should_write ]
                continue
            cwd : path.path_cwd[]
            p.parent_dir[].make_dir[]
            fp: fopen[ p, "w" ]
            if [ !fp ]
                printf[ "failed to write shader: %s\n", p.chars ]
                continue
            fputs[ src, fp ]
            fclose[ fp ]

    func uniform_transfer [ data2: ref u8, type: Au_t ] -> i64
        instance:a
        expect instance inherits shader, "shader instance not provided"
        src: ref u8 [ instance ]
##
        if [strcmp[type.ident, "Earth"] == 0]
            fdata: ref f32 [ ref data2[0] ]
            memcpy[ fdata, ref src[84], 64 ]
            m4 : ref mat4f [ fdata ] 
            return 192
##
        index: num [ 0 ]
        ty2: Au_t [ type ]
        classes : context_chain[]
        for [ ty2: Au_t ] in classes
            for [ m: 0, m < ty2.members.count, m += 1 ]
                mem: Au_t [ ty2.members.origin[m] ]
                if [ is_uniform_field[ mem ] ]
                    type_size: mem.src.typesize
                    if [ (mem.src.traits & (1 << 8)) || (mem.src.traits & (1 << 0)) ]
                        memcpy[ ref data2[index], ref src[mem.offset], type_size ]
                    el
                        dst_ptr: (ref src[mem.offset] to ref handle)
                        memcpy[ ref data2[index], dst_ptr, type_size ]
                    index += type_size

        return index

    intern func reload [ ] -> bool
        paths:  array path [ vert, frag, comp ]
        values: new VkShaderModule[3] [ vk_vert, vk_frag, vk_comp ]
        values.hold[]
        found:      false
        recompiled: false
        for [ i: 0, i < 3, i += 1 ]
            shader_file: paths[i]
            if [ !shader_file ]
                continue
            input: path '{shader_file}'
            if [ !input.exists[] ]
                continue
            if [ strstr[ shader_file.chars, "Earth" ]]
                shader_file = shader_file
            spv_file: path '{shader_file}.spv'
            found = true
            source_stat: struct stat
            spv_stat:    struct stat
            src_exists: stat[ input, ref source_stat ] == 0
            spv_exists: stat[ spv_file, ref spv_stat ] == 0
            #make_spv: false -- this is needed now, and thats wrong
            ifdef [ linux ]
                make_spv : !spv_exists || source_stat.st_mtim.tv_sec > spv_stat.st_mtim.tv_sec
            ifdef [ apple ]
                make_spv : !spv_exists || source_stat.st_mtimespec.tv_sec > spv_stat.st_mtimespec.tv_sec

            if [ make_spv ]
                # use the vendored glslangValidator by absolute path (no PATH dependence);
                # fall back to PATH only if the vendored binary isn't present.
                glsl: path '{path.path_startup[]}/platform/native/bin/glslangValidator'
                glsl_bin: (glsl.exists[]) ? '{glsl}' : 'glslangValidator'
                cmd: '{glsl_bin} -V100 --target-env vulkan1.2 {shader_file} -o {spv_file}'
                puts 'compiling shader: {cmd}'
                result: system[ cmd ]
                if [ result != 0 ]
                    puts 'shader compilation failed for: {shader_file}'
                    exit[ 1 ]
                recompiled = true
            el
                if [ values[i] ]
                    continue
            fp: fopen[ spv_file.chars, "rb" ]
            if [ !fp ]
                puts 'failed to open SPIR-V file: {spv_file}'
                exit[ 1 ]
            fseek[ fp, 0, SEEK_END ]
            length: ftell[ fp ]
            rewind[ fp ]
            spirv: malloc[ length ]
            if [ !spirv ]
                fclose[ fp ]
                puts 'failed to allocate memory for SPIR-V'
                exit[ 1 ]
            fread[ spirv, 1, length, fp ]
            fclose[ fp ]
            createInfo: VkShaderModuleCreateInfo [
                sType:    VK_STRUCTURE_TYPE_SHADER_MODULE_CREATE_INFO,
                codeSize: length,
                pCode:    spirv
            ]
            mod: VkShaderModule
            vkResult: vkCreateShaderModule[ vk.device, createInfo, null, ref mod ]
            if [ vkResult != VK_SUCCESS ]
                puts 'failed to create vulkan shader module: {spv_file}'
                free[ spirv ]
                exit[ 1 ]
            values[i] = mod
            free[ spirv ]

        vk_vert = values[0]
        vk_frag = values[1]
        vk_comp = values[2]

        expect found, 'shader not found: {name}'
        return recompiled

    func init [ ]
        if [ !vk ]
            return
        if [ !name ]
            ty: typeid[ a ]
            expect ty != typeid[ shader ], "shader requires a subclass"
            name = ty.ident
        vert = 'shaders/{name}.vert'
        frag = 'shaders/{name}.frag'
        comp = 'shaders/{name}.comp'
        if [ !vk.shader_cache ]
            vk.shader_cache = store[]
            vk.shader_cache.hold[]
            
        cached: shader [ vk.shader_cache.get[ typeid[ a ] ] ]
        if [ cached ]
            vk_vert = cached.vk_vert
            vk_frag = cached.vk_frag
            vk_comp = cached.vk_comp
            return
        generate_shaders[ ]
        reload[ ]
        vk.shader_cache.set[ typeid[ a ], a ]

    func dealloc [ ]
        # default-constructed shader instances (e.g. shader-codegen reflection args
        # built via method_call's missing-arg path) never got a vk context, so they
        # have no shader modules and nothing to free. guard the null vk deref.
        if [ !vk ] return
        cached: shader [ vk.shader_cache.get[ typeid[ a ] ] ]
        if [ cached != a ]
            return
        vkDestroyShaderModule[ vk.device, vk_vert, null ]
        vkDestroyShaderModule[ vk.device, vk_frag, null ]
        vkDestroyShaderModule[ vk.device, vk_comp, null ]


shader ModelViewProject
    mutable model   : mat4f
    mutable view    : mat4f
    mutable proj    : mat4f
    mutable time    : f32

ModelViewProject UVQuad
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]
    #attrib Surface [ color ] : 1, rgba8

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func fragment [] -> GLSL none {
        fragColor = texture(color, v_uv);
    }


ModelViewProject UVReduce
    attrib  color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func fragment [] -> GLSL none {
        vec2 tsize = textureSize(color, 0);
        vec2 texel = 1.0 / vec2(tsize);
        vec4 sum   = vec4(0.0);
        for (int dy = 0; dy <= 3; dy++)
            for (int dx = 0; dx <= 3; dx++) {{
                vec2 offset = (vec2(dx, dy) - 1.5) * texel;
                sum += texture(color, v_uv + offset);
            }}
        vec4 avg  = sum * (1.0 / 16.0);
        fragColor = vec4((avg.rgb + avg.rgb * avg.a) / 2.0, avg.a);
    }


# SNES Mode 7 affine layer, rendered on the GPU as a textured fullscreen quad.
# 'src' = the unpacked 1024x1024 (128x128 tiles * 8px) Mode-7 plane, palette
# already applied (alpha 0 = transparent pixel). 'mat' = a 256x1 rgba32f texture
# whose texel y holds that scanline's precomputed affine { originX, originY, a, c }
# (exactly what ppu_m7_line computes on the CPU). The fragment shader does the
# per-pixel affine + samples the plane; bracketing-scanline coefficient lerp gives
# a smooth horizon the discrete CPU/hardware path can't. See project_asnes_mode7_vulkan.
enum Mode7Surface
    src : 0
    mat : 1

ModelViewProject Mode7
    mutable params : vec4f          # x=hflip, y=vflip, z=repeat-mode(0/1 wrap,2 transp,3 char0), w=0

    attrib src : LayoutBinding [ type:typeid[ Mode7Surface ], id:Mode7Surface.src, count:1, format: typeid[ rgba8 ] ]
    attrib mat : LayoutBinding [ type:typeid[ Mode7Surface ], id:Mode7Surface.mat, count:1, format: typeid[ rgbaf ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func fragment [] -> GLSL none {
        float sy = v_uv.y * 224.0;                       // SNES scanline (continuous)
        float sx = v_uv.x * 256.0;                       // pixel within the line
        if (ubo.params.x > 0.5) sx = 255.0 - sx;         // hflip
        // per-scanline affine coeffs, lerped between bracketing scanlines
        float y0 = floor(sy);
        float fy = sy - y0;
        int   iy = int(y0);
        vec4  m0 = texelFetch(mat, ivec2(iy,                  0), 0);   // {originX, originY, a, c}
        vec4  m1 = texelFetch(mat, ivec2(min(iy + 1, 223),   0), 0);
        vec4  m  = mix(m0, m1, fy);
        float px = (m.x + m.z * sx) / 256.0;             // plane pixelX
        float py = (m.y + m.w * sx) / 256.0;             // plane pixelY
        int   rep = int(ubo.params.z + 0.5);
        bool  oob = (px < 0.0 || px >= 1024.0 || py < 0.0 || py >= 1024.0);
        if (rep == 2 && oob) { fragColor = vec4(0.0); return; }
        vec2 raw = vec2(px, py) / 1024.0;
        vec2 ddx = dFdx(raw);
        vec2 ddy = dFdy(raw);
        vec2 uv2 = fract(raw);
        fragColor = textureGrad(src, uv2, ddx, ddy);
        // per-scanline color math on the plane (reference hardware CGADSUB on BG1
        // gated by the HDMA'd color window): row 1 = {wh0,wh1,wh2,wh3}, row 2 =
        // {flags, coldata r,g,b}. This is how the distance fog AND the craft
        // shadow (an ellipse traced per line in WH0/WH1) darken the plane.
        vec4 f1 = mix(texelFetch(mat, ivec2(iy, 1), 0), texelFetch(mat, ivec2(min(iy + 1, 223), 1), 0), 0.0);
        vec4 f2 = texelFetch(mat, ivec2(iy, 2), 0);
        int flags = int(f2.x + 0.5);
        int region = (flags >> 6) & 3;
        if (region != 3) {
            float wx = v_uv.x * 256.0;             // window applies to SCREEN x (pre-hflip)
            bool in1 = (wx >= f1.x && wx <= f1.y + 1.0);
            bool in2 = (wx >= f1.z && wx <= f1.w + 1.0);
            if ((flags & 2) != 0) in1 = !in1;
            if ((flags & 8) != 0) in2 = !in2;
            bool w1en = (flags & 1) != 0;
            bool w2en = (flags & 4) != 0;
            int lgc = (flags >> 4) & 3;
            bool w = false;
            if (w1en && !w2en) w = in1;
            else if (!w1en && w2en) w = in2;
            else if (w1en && w2en) w = (lgc == 0) ? (in1 || in2) : (lgc == 1) ? (in1 && in2) : (lgc == 2) ? (in1 != in2) : (in1 == in2);
            bool apply = (region == 0) || (region == 1 && w) || (region == 2 && !w);
            if (apply) {
                vec3 cold = f2.yzw / 31.0;
                vec3 c = ((flags & 256) != 0) ? fragColor.rgb - cold : fragColor.rgb + cold;
                if ((flags & 512) != 0) c *= 0.5;
                fragColor.rgb = clamp(c, 0.0, 1.0);
            }
        }
    }


# Super Eagle 2x pixel-art upscaler as a post-effect pass.
#
#   SuperEagle algorithm: Copyright (C) 2002-2007 The DOSBox Team — License: GNU GPL
#   GET_RESULT logic:     Copyright (c) 1999-2001 Derek Liauw Kie Fa — License: GNU GPL
#   GLSL adaptation by guest(r) (2007); ported from libretro/glsl-shaders
#   (eagle/shaders/supereagle.glsl). Re-expressed in trinity's shader form here.
#   This file therefore includes GPL-licensed work — keep this notice.
#
# Alpha runs through the same pattern selection as color, so sprite-edge coverage is
# diagonal-smoothed and composites over whatever sits beneath (e.g. the Mode-7 plane);
# transparent texels borrow the nearest opaque neighbor's rgb so no black fringes are
# blended in. Bind the 256x224 framebuffer as 'color'.
ModelViewProject SuperEagle
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func se_reduce [ c: vec4f ] -> GLSL float {
        return dot(c, vec4(65536.0, 255.0, 1.0, 16777216.0));
    }

    func se_result [ a: f32, b: f32, c: f32, d: f32 ] -> GLSL float {
        float x = 0.0; float y = 0.0; float r = 0.0;
        if (a == c) x += 1.0; else if (b == c) y += 1.0;
        if (a == d) x += 1.0; else if (b == d) y += 1.0;
        if (x <= 1.0) r += 1.0;
        if (y <= 1.0) r -= 1.0;
        return r;
    }

    func fragment [] -> GLSL none {
        ivec2 ts = textureSize(color, 0);
        ivec2 P  = ivec2(v_uv * vec2(ts));
        vec2  fp = fract(v_uv * vec2(ts));

        vec4 Cc = texelFetch(color, clamp(P, ivec2(0), ts - 1), 0);
        vec4 t5 = texelFetch(color, clamp(P + ivec2( 1, 0), ivec2(0), ts - 1), 0);
        vec4 t7 = texelFetch(color, clamp(P + ivec2( 0, 1), ivec2(0), ts - 1), 0);
        vec4 t8 = texelFetch(color, clamp(P + ivec2( 1, 1), ivec2(0), ts - 1), 0);
        // a transparent texel carries no color: borrow rgb from the nearest opaque
        // neighbor so the pattern blends never pull black fringes over the Mode-7
        // plane beneath; the alpha channel keeps the true coverage and is shaped
        // by the same pattern selection as the color (diagonal-smoothed edge mask)
        vec3 rgb4 = Cc.rgb;
        if (Cc.a < 0.5) rgb4 = t5.a >= 0.5 ? t5.rgb : (t7.a >= 0.5 ? t7.rgb : (t8.a >= 0.5 ? t8.rgb : Cc.rgb));
        vec4 C4 = vec4(rgb4, Cc.a);
        vec4 C5 = vec4(t5.a < 0.5 ? rgb4 : t5.rgb, t5.a);
        vec4 C7 = vec4(t7.a < 0.5 ? rgb4 : t7.rgb, t7.a);
        vec4 C8 = vec4(t8.a < 0.5 ? rgb4 : t8.rgb, t8.a);
        vec4 t;
        t = texelFetch(color, clamp(P + ivec2(-1, 0), ivec2(0), ts - 1), 0); float c1 = se_reduce(vec4(t.a < 0.5 ? rgb4 : t.rgb, t.a));
        t = texelFetch(color, clamp(P + ivec2( 1,-1), ivec2(0), ts - 1), 0); float c2 = se_reduce(vec4(t.a < 0.5 ? rgb4 : t.rgb, t.a));
        float c3 = c1;
        float c4 = se_reduce(C4);
        float c5 = se_reduce(C5);
        t = texelFetch(color, clamp(P + ivec2(-1, 1), ivec2(0), ts - 1), 0); float c6 = se_reduce(vec4(t.a < 0.5 ? rgb4 : t.rgb, t.a));
        float c7 = se_reduce(C7);
        float c8 = se_reduce(C8);
        t = texelFetch(color, clamp(P + ivec2( 0, 2), ivec2(0), ts - 1), 0); float d1 = se_reduce(vec4(t.a < 0.5 ? rgb4 : t.rgb, t.a));
        t = texelFetch(color, clamp(P + ivec2( 1, 2), ivec2(0), ts - 1), 0); float d2 = se_reduce(vec4(t.a < 0.5 ? rgb4 : t.rgb, t.a));
        t = texelFetch(color, clamp(P + ivec2( 2, 0), ivec2(0), ts - 1), 0); float d4 = se_reduce(vec4(t.a < 0.5 ? rgb4 : t.rgb, t.a));
        t = texelFetch(color, clamp(P + ivec2( 2, 1), ivec2(0), ts - 1), 0); float d5 = se_reduce(vec4(t.a < 0.5 ? rgb4 : t.rgb, t.a));

        vec4 p00; vec4 p10; vec4 p01; vec4 p11;

        if (c4 != c8) {
            if (c7 == c5) {
                p01 = p10 = C7;
                if ((c6 == c7) || (c5 == c2)) p00 = 0.25*(3.0*C7+C4); else p00 = 0.5*(C4+C5);
                if ((c5 == d4) || (c7 == d1)) p11 = 0.25*(3.0*C7+C8); else p11 = 0.5*(C7+C8);
            } else {
                p11 = 0.125*(6.0*C8+C7+C5);
                p00 = 0.125*(6.0*C4+C7+C5);
                p10 = 0.125*(6.0*C7+C4+C8);
                p01 = 0.125*(6.0*C5+C4+C8);
            }
        } else {
            if (c7 != c5) {
                p11 = p00 = C4;
                if ((c1 == c4) || (c8 == d5)) p01 = 0.25*(3.0*C4+C5); else p01 = 0.5*(C4+C5);
                if ((c8 == d2) || (c3 == c4)) p10 = 0.25*(3.0*C4+C7); else p10 = 0.5*(C7+C8);
            } else {
                float r = 0.0;
                r += se_result(c5,c4,c6,d1);
                r += se_result(c5,c4,c3,c1);
                r += se_result(c5,c4,d2,d5);
                r += se_result(c5,c4,c2,d4);
                if (r > 0.0)      { p01 = p10 = C7; p00 = p11 = 0.5*(C4+C5); }
                else if (r < 0.0) { p11 = p00 = C4; p01 = p10 = 0.5*(C4+C5); }
                else              { p11 = p00 = C4; p01 = p10 = C7; }
            }
        }

        vec4 outc = (fp.x < 0.5) ? (fp.y < 0.5 ? p00 : p10) : (fp.y < 0.5 ? p01 : p11);
        fragColor = vec4(outc.rgb * outc.a, outc.a);   // pass composites premultiplied (ONE / ONE_MINUS_SRC_ALPHA): partial-coverage edges must not add unweighted color
    }


# Sharp-bilinear pixel scaler. Nearest-neighbor squares with a transition
# exactly one DESTINATION pixel wide at each texel boundary: hard pixel-art
# edges that stay stable under sub-pixel motion (no crawl or shimmer), at any
# scale factor including non-integer, evaluated at the output resolution.
# Source must be sampled LINEAR — the transition rides the hw bilinear.
ModelViewProject PixelSharp
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func fragment [] -> GLSL none {
        vec2 ts = vec2(textureSize(color, 0));
        vec2 p  = v_uv * ts - 0.5;
        vec2 ip = floor(p);
        vec2 fp = p - ip;
        vec2 w  = max(fwidth(p), vec2(1e-5));
        vec2 f  = clamp((fp - 0.5) / w + 0.5, 0.0, 1.0);
        vec2 suv = (ip + 0.5 + f) / ts;
        vec4 c = texture(color, suv);
        fragColor = vec4(c.rgb * c.a, c.a);   // premultiplied like the SE pass
    }


# Continuous pixel-art edge reconstruction ("vector look"). EPX/Scale2x
# corner rules (public-domain algorithm) evaluated per DESTINATION pixel:
# where a corner rule fires, the texel is cut by the ideal 45-degree line and
# the output pixel takes the side it falls on, with a one-dest-pixel AA band.
# Diagonals render as exact straight edges at ANY scale — no 2x lattice.
# generic character/prop PBR (gltf metallic-roughness), tuned for HUMANS:
# standard GGX for clothes/props plus a light SUBSURFACE term (wrap diffuse +
# warm back-transmission) that reads as skin and fades out with metalness.
# samples the material textures model_init_pipeline binds (color / mr /
# normal), each on its material-declared UV set (uv_map: x=color y=mr
# z=normal — value 0/1/2 selects TEXCOORD_0/1/2).
ModelViewProject HumanPBR
    mutable eye    : vec4f
    mutable uv_map : vec4f
    mutable sss    : f32

    attrib color  : LayoutBinding [ type:typeid[ Surface ], id:Surface.color,  count:1, format: typeid[ rgba8 ] ]
    attrib normal : LayoutBinding [ type:typeid[ Surface ], id:Surface.normal, count:1, format: typeid[ rgba8 ] ]
    attrib rough  : LayoutBinding [ type:typeid[ Surface ], id:Surface.rough,  count:1, format: typeid[ rgba8 ] ]

    attrib a_pos     : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_normal  : VertexInput [ type:typeid[ vec3f ] ]
    attrib a_uv      : VertexInput [ type:typeid[ vec2f ] ]
    attrib a_tangent : VertexInput [ type:typeid[ vec4f ] ]
    attrib a_uv1     : VertexInput [ type:typeid[ vec2f ] ]
    attrib a_uv2     : VertexInput [ type:typeid[ vec2f ] ]

    attrib v_world_pos : VertexOutput [ type:typeid[ vec3f ] ]
    attrib v_normal    : VertexOutput [ type:typeid[ vec3f ] ]
    attrib v_uv        : VertexOutput [ type:typeid[ vec2f ] ]
    attrib v_uv1       : VertexOutput [ type:typeid[ vec2f ] ]
    attrib v_uv2       : VertexOutput [ type:typeid[ vec2f ] ]

    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        view  = mat4f.identity[]
        proj  = mat4f.identity[]
        sss   = 0.5

    func pow2 [ x: float ] -> GLSL float {
        return x * x;
    }

    func pow5 [ x: float ] -> GLSL float {
        float x2 = x * x;
        return x2 * x2 * x;
    }

    func sRGBToLinear [ c: vec3f ] -> GLSL vec3f {
        return pow(c, vec3(2.2));
    }

    func linearToSRGB [ c: vec3f ] -> GLSL vec3f {
        return pow(c, vec3(1.0/2.2));
    }

    func F_Schlick [ f0: vec3f, cos_theta: float ] -> GLSL vec3f {
        return f0 + (1.0 - f0) * pow5(1.0 - cos_theta);
    }

    func D_GGX [ roughness: float, NdotH: float ] -> GLSL float {
        float alpha    = pow2(roughness);
        float alpha_sq = pow2(alpha);
        float denom    = pow2(NdotH) * (alpha_sq - 1.0) + 1.0;
        return alpha_sq / (3.14159265359 * pow2(denom));
    }

    func G_Smith [ roughness: float, NdotV: float, NdotL: float ] -> GLSL float {
        float k    = pow2(roughness + 1.0) / 8.0;
        float G1_V = NdotV / max((NdotV * (1.0 - k) + k), 0.0001);
        float G1_L = NdotL / max((NdotL * (1.0 - k) + k), 0.0001);
        return G1_V * G1_L;
    }

    func BRDF [ L: vec3f, V: vec3f, N: vec3f, albedo: vec3f, metallic: float, roughness: float ] -> GLSL vec3f {
        roughness = max(roughness, 0.05);
        vec3  H     = normalize(L + V);
        float NdotL = max(dot(N, L), 0.0);
        float NdotV = max(dot(N, V), 0.0);
        float NdotH = max(dot(N, H), 0.0);
        float HdotV = max(dot(H, V), 0.0);
        vec3  F0       = mix(vec3(0.04), albedo, metallic);
        vec3  F        = F_Schlick(F0, HdotV);
        float D        = D_GGX(roughness, NdotH);
        float G        = G_Smith(roughness, NdotV, NdotL);
        vec3  specular = (D * F * G) / max(4.0 * NdotV * NdotL, 0.0001);
        vec3  kD       = (vec3(1.0) - F) * (1.0 - metallic);
        vec3  diffuse  = kD * albedo / 3.14159265359;
        return (diffuse + specular) * NdotL;
    }

    func perturbNormal [ N: vec3f, texcoord: vec2f ] -> FragGLSL vec3f {
        vec3  map = texture(normal, texcoord).rgb * 2.0 - 1.0;
        if (dot(map.xy, map.xy) < 0.001) return N;
        vec3  q1  = dFdx(v_world_pos);
        vec3  q2  = dFdy(v_world_pos);
        vec2  st1 = dFdx(texcoord);
        vec2  st2 = dFdy(texcoord);
        float det = st1.x * st2.y - st2.x * st1.y;
        if (abs(det) < 1e-5) return N;
        float inv = 1.0 / det;
        vec3  T   = normalize((q1 * st2.y - q2 * st1.y) * inv);
        T         = normalize(T - dot(T, N) * N);
        vec3  B   = normalize(cross(N, T));
        mat3  TBN = mat3(T, B, N);
        return normalize(TBN * map);
    }

    func ACESFilm [ x: vec3f ] -> GLSL vec3f {
        float a = 2.51; float b = 0.03; float c = 2.43; float d = 0.59; float e = 0.14;
        return clamp((x*(a*x+b))/(x*(c*x+d)+e), 0.0, 1.0);
    }

    func uv_pick [ sel: float ] -> FragGLSL vec2f {
        if (sel > 1.5) return v_uv2;
        if (sel > 0.5) return v_uv1;
        return v_uv;
    }

    func vertex [] -> GLSL none {
        vec4 wp     = ubo.model * vec4(a_pos, 1.0);
        v_world_pos = wp.xyz;
        v_normal    = mat3(ubo.model) * a_normal;
        v_uv        = a_uv;
        v_uv1       = a_uv1;
        v_uv2       = a_uv2;
        gl_Position = ubo.proj * ubo.view * wp;
    }

    func fragment [] -> GLSL none {
        vec2  uv_c   = uv_pick(ubo.uv_map.x);
        vec2  uv_m   = uv_pick(ubo.uv_map.y);
        vec2  uv_n   = uv_pick(ubo.uv_map.z);
        vec4  base   = texture(color, uv_c);
        vec3  albedo = sRGBToLinear(base.rgb);
        vec3  mrs    = texture(rough, uv_m).rgb;
        float rgh    = clamp(mrs.g, 0.045, 1.0);
        float metal  = clamp(mrs.b, 0.0, 1.0);
        vec3  V      = normalize(ubo.eye.xyz - v_world_pos);
        vec3  N      = perturbNormal(normalize(v_normal), uv_n);
        vec3  L1     = normalize(vec3( 0.45, 0.85,  0.55));
        vec3  L2     = normalize(vec3(-0.55, 0.15, -0.65));
        vec3  col    = BRDF(L1, V, N, albedo, metal, rgh) * vec3(1.00, 0.98, 0.95) * 2.4
                     + BRDF(L2, V, N, albedo, metal, rgh) * vec3(0.55, 0.65, 0.85) * 0.7;
        // subsurface: wrap the key light past the terminator and add a warm
        // back-transmission — reads as skin, fades with metalness so cloth
        // and props stay plain PBR
        float ndl  = dot(N, L1);
        float wrap = clamp((ndl + 0.55) / 1.55, 0.0, 1.0) * clamp(1.0 - ndl, 0.0, 1.0);
        float back = pow(clamp(1.0 - ndl, 0.0, 1.0), 2.2)
                   * pow(clamp(dot(V, -L1) * 0.5 + 0.5, 0.0, 1.0), 1.5);
        vec3  sssc = albedo * vec3(1.00, 0.36, 0.24);
        col += ubo.sss * (1.0 - metal) * (wrap * 0.30 + back * 0.55) * sssc;
        col += albedo * 0.14;
        col  = ACESFilm(col);
        fragColor = vec4(linearToSRGB(col), base.a);
    }


ModelViewProject VectorScale
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
    attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        eye:    vec3f [ 0.0, 0.0, 2.0 ]
        center: vec3f [ 0.0, 0.0, 0.0 ]
        up:     vec3f [ 0.0, 1.0, 0.0 ]
        view  = mat4f.look_at[ eye, center, up ]
        proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

    func vertex [] -> GLSL none {
        v_uv        = uv;
        gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
    }

    func vs_eq [ a: vec4f, b: vec4f ] -> GLSL float {
        return (distance(a, b) < 0.02) ? 1.0 : 0.0;
    }

    func fragment [] -> GLSL none {
        ivec2 ts = textureSize(color, 0);
        vec2 pt = v_uv * vec2(ts);
        ivec2 ip = ivec2(floor(pt));
        vec2 fp = fract(pt);
        ivec2 mx = ts - 1;
        vec4 E = texelFetch(color, clamp(ip,                ivec2(0), mx), 0);
        vec4 U = texelFetch(color, clamp(ip + ivec2( 0,-1), ivec2(0), mx), 0);
        vec4 D = texelFetch(color, clamp(ip + ivec2( 0, 1), ivec2(0), mx), 0);
        vec4 L = texelFetch(color, clamp(ip + ivec2(-1, 0), ivec2(0), mx), 0);
        vec4 R = texelFetch(color, clamp(ip + ivec2( 1, 0), ivec2(0), mx), 0);
        float ud = vs_eq(U, D);
        float lr = vs_eq(L, R);
        vec4 c = E;
        // one-destination-pixel AA width in texel units
        float w = max(fwidth(pt.x + pt.y), 1e-5);
        // each corner: neighbors agree, opposing sides differ, and the
        // corner color differs from the center -> cut at the 45-degree line
        if (vs_eq(L, U) > 0.5 && lr < 0.5 && ud < 0.5 && vs_eq(L, E) < 0.5) {
            float d = fp.x + fp.y;                     // line x+y = 0.5
            c = mix(L, c, clamp((d - 0.5) / w + 0.5, 0.0, 1.0));
        }
        if (vs_eq(R, U) > 0.5 && lr < 0.5 && ud < 0.5 && vs_eq(R, E) < 0.5) {
            float d = (1.0 - fp.x) + fp.y;
            c = mix(R, c, clamp((d - 0.5) / w + 0.5, 0.0, 1.0));
        }
        if (vs_eq(L, D) > 0.5 && lr < 0.5 && ud < 0.5 && vs_eq(L, E) < 0.5) {
            float d = fp.x + (1.0 - fp.y);
            c = mix(L, c, clamp((d - 0.5) / w + 0.5, 0.0, 1.0));
        }
        if (vs_eq(R, D) > 0.5 && lr < 0.5 && ud < 0.5 && vs_eq(R, E) < 0.5) {
            float d = (1.0 - fp.x) + (1.0 - fp.y);
            c = mix(R, c, clamp((d - 0.5) / w + 0.5, 0.0, 1.0));
        }
        fragColor = vec4(c.rgb * c.a, c.a);   // premultiplied compositing
    }


shader Env
    mutable view : mat4f.identity[]
    mutable proj : mat4f.identity[]
    mutable roughness_samples : vec2f
    attrib color: LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format:typeid[ rgbaf ] ]

    attrib in_pos   : VertexInput    [ type:typeid[ vec3f ] ]
    attrib in_uv    : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_uv     : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib v_dir    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib outColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func vertex [] -> GLSL none {
        v_uv        = in_uv;
        v_dir       = in_pos;
        gl_Position = ubo.proj * ubo.view * vec4(in_pos, 1.0);
    }

    func fragment [] -> GLSL none {
        const float PI = 3.14159265359;
        vec3  R  = normalize(v_dir);
        vec2  eq = vec2(0.5 + atan(R.z, R.x) / (2.0 * PI),
                              acos(R.y)       /        PI);
        outColor = vec4(texture(color, eq).rgb, 1.0);
    }


shader Convolve
    mutable env : mat4f
    mutable view : mat4f
    mutable proj : mat4f
    mutable roughness_samples : vec2f
    attrib environment: LayoutBinding [ type:typeid[ Surface ], id:Surface.environment, count:1, format:typeid[ rgbaf ] ]

    attrib in_pos   : VertexInput    [ type:typeid[ vec3f ] ]
    attrib in_uv    : VertexInput    [ type:typeid[ vec2f ] ]
    attrib v_dir    : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib outColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func vertex [] -> GLSL none {
        vec3 direction = in_pos;
        v_dir        = (ubo.env * vec4(direction, 1.0)).xyz;
        gl_Position  = ubo.proj * ubo.view * vec4(in_pos, 1.0);
    }

    func radicalInverse_VdC [ bits: u32 ] -> GLSL float {
        bits = (bits << 16u) | (bits >> 16u);
        bits = ((bits & 0x55555555u) << 1u) | ((bits & 0xAAAAAAAAu) >> 1u);
        bits = ((bits & 0x33333333u) << 2u) | ((bits & 0xCCCCCCCCu) >> 2u);
        bits = ((bits & 0x0F0F0F0Fu) << 4u) | ((bits & 0xF0F0F0F0u) >> 4u);
        bits = ((bits & 0x00FF00FFu) << 8u) | ((bits & 0xFF00FF00u) >> 8u);
        return float(bits) * 2.3283064365386963e-10;
    }

    func sampleHammersley [ i: u32, numSamples: i32 ] -> GLSL vec2f {
        float invNumSamples = 1.0 / float(numSamples);
        return vec2(float(i) * invNumSamples, radicalInverse_VdC(i));
    }

    func sampleGGX [ u1: float, u2: float, roughness: float ] -> GLSL vec3f {
        float alpha = roughness * roughness;
        float cosTheta = sqrt((1.0 - u2) / (1.0 + (alpha*alpha - 1.0) * u2));
        float sinTheta = sqrt(1.0 - cosTheta*cosTheta);
        float phi = 6.2831853 * u1;
        return vec3(sinTheta * cos(phi), sinTheta * sin(phi), cosTheta);
    }

    func ndfGGX [ cosLh: float, roughness: float ] -> GLSL float {
        float alpha = roughness * roughness;
        float alphaSq = alpha * alpha;
        float denom = (cosLh * cosLh) * (alphaSq - 1.0) + 1.0;
        return alphaSq / (3.14159265359 * denom * denom);
    }

    func prefilterEnvMap [ R: vec3f, roughness: float, numSamples: i32 ] -> GLSL vec3f {
        vec3  N  = R;
        vec3  Lo = N;
        vec3  T  = normalize(cross(N, abs(N.y) < 0.999 ? vec3(0.0, 1.0, 0.0) : vec3(1.0, 0.0, 0.0)));
        vec3  S  = normalize(cross(N, T));
        vec3  color  = vec3(0.0);
        float weight = 0.0;
        vec2  envMapSize = vec2(textureSize(environment, 0));
        float wt = 4.0 * 3.14159265359 / (6.0 * envMapSize.x * envMapSize.y);
        for (uint i = 0; i < uint(numSamples); ++i) {{
            vec2 u  = sampleHammersley(i, numSamples);
            vec3 h  = sampleGGX(u.x, u.y, roughness);
            vec3 Lh = S * h.x + T * h.y + N * h.z;
            vec3 Li = 2.0 * dot(Lo, Lh) * Lh - Lo;
            float cosLi = dot(N, Li);
            if (cosLi > 0.0) {{
                float cosLh = max(dot(N, Lh), 0.0);
                float pdf = ndfGGX(cosLh, roughness) * cosLh / max(4.0 * dot(Lh, Lo), 0.001);
                float ws = 1.0 / (float(numSamples) * pdf);
                float mipLevel = clamp(0.5 * log2(ws / wt), 0.0, 7);
                color += textureLod(environment, Li, mipLevel).rgb * cosLi;
                weight += cosLi;
            }}
        }}
        return (weight > 0.00001) ? (color / weight) : vec3(0.0);
    }

    func fragment [] -> GLSL none {
        vec3  R          = normalize(v_dir);
        float roughness  = ubo.roughness_samples.x;
        int   numSamples = int(ubo.roughness_samples.y);
        outColor = (roughness < 0.01)
            ? texture(environment, R)
            : vec4(prefilterEnvMap(R, roughness, numSamples), 1.0);
    }



ModelViewProject Basic
