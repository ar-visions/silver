import vec
import img
import trinity
import <stdio.h>

trinity hyperspace
    mutable active : string
    mutable fullscreen : bool

    func init []
        width  : 1280
        height : 800
        active = 'capture-look'

    mutable cam0 : Camera
    mutable cam1 : Camera


    public func on_canvas [ cv: Canvas ]
        if [!fullscreen] return
        return

    public func on_key [ ev: Event ]
        if [ ev.key.state && ev.key.unicode == 256 && fullscreen ]   # GLFW_KEY_ESCAPE
            fullscreen = false
            ev.stop_propagation[]

    public func on_click [ ev: Event ]
        e : (ev.target to element)
        if [ !e ] return
        if [ e.id == 'record-looks'     ]
            puts 'record looks'
        el [ e.id == 'annotate-targets' ]
            puts 'annotate targets'
        el [ e.id == 'train'            ]
            puts 'train'
        el [ e.id == 'testbed'          ]
            puts 'testbed'
        
        ev.stop_propagation[]

    # we need a kind of dataset selector
    # when we train, we'll train with multiple datasets
    public func on_render [ w: Window ] -> Elements
        if [ !cam0 ]
            cam0 = Camera [ vk: w.vk, w: w, device: '/dev/video6', width: 340, height: 340 ]
        if [ !cam1 ]
            cam1 = Camera [ vk: w.vk, w: w, device: '/dev/video2', width: 340, height: 340 ]
        if [ fullscreen ] return null
        return Elements [
            "toolbar": Toolbar [
                elements: Elements [
                    "record-looks":     Button [ label: 'record looks' ],
                    "annotate-targets": Button [ label: 'annotate targets' ],
                    "train":            Button [ label: 'train' ],
                    "testbed":          Button [ label: 'testbed' ]
                ]
            ],
            "camera0": CameraView [ camera: cam0 ],
            "camera1": CameraView [ camera: cam1 ]
        ]
