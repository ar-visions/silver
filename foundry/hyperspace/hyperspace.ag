import vec
import img
import trinity
import <stdio.h>

trinity hyperspace
    intern active     : string
    intern fullscreen : bool

    func init []
        width      = 1280
        height     = 800
        background = 'Background'
        title      = 'hyperspace'
        active     = 'record-looks'

    public func on_canvas [ cv: Canvas ]
        if [ !fullscreen ]
            super.on_canvas[ cv ]
            return

    public func on_key [ ev: Event ]
        if [ ev.key.state && ev.key.unicode == 256 && fullscreen ]
            fullscreen = false
            w.set_fullscreen*[ false ]
            ev.stop_propagation[]

    public func on_click [ ev: Event ]
        e : (ev.target to element)
        if [ !e ] return
        if [ e.id == 'record-looks' ]
            fullscreen = true
            w.set_fullscreen*[ true ]
        el [ e.id == 'annotate-targets' ]
            puts 'annotate targets'
        el [ e.id == 'train' ]
            puts 'train'
        el [ e.id == 'testbed' ]
            puts 'testbed'
        ev.stop_propagation[]

    public func on_render [ w: Window ] -> Elements
        if [ fullscreen ]
            return null
        return Elements [
            "toolbar": Toolbar [
                elements: Elements [
                    "record-looks":     Button [ label: 'record looks'     ],
                    "annotate-targets": Button [ label: 'annotate targets' ],
                    "train":            Button [ label: 'train'            ],
                    "testbed":          Button [ label: 'testbed'          ]
                ]
            ]
        ]
