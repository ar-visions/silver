import vec
import img
import trinity
import <stdio.h>

# an empty window — no app content at all. everything visible is trinity's own
# chrome (the UX generics tab), which is the point: it isolates the framework's
# menu button so a change to it can be seen on its own.
# dictation: the app does NOT record. the dictate toggle broadcasts on the app
# bus and crashman (the supervisor shell) owns the mic and the LLM connection.
Background ExperimentBackground
    func init[]
        color = rgba[ '#645a5f' ]

element experiment : trinity
    public width      : i32    [ 480 ]
    public height     : i32    [ 560 ]
    public background : string [ 'ExperimentBackground' ]
    public title      : string [ 'experiment' ]
    # the framework shade — the only thing this window shows
    public ux_generics : bool [ true ]
    # reflected into the shade: a public rgba becomes a color wheel row
    public tint        : rgba [ '#e0508c' ]

    public func render [] -> Elements
        return Elements [ ]
