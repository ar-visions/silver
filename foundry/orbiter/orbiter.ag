# one editor tab: title, text, and (for a .ag source) its run band + console.
# area is assigned per instance from the split seams; bg is the pane fill.
element EditorView
    public selected   : bool
    public pane_index : i32
    area : Region { l0 t0 r0 b0 }
    bg   : Layer [ fill_color: rgba [ '#140d2a' ] ]

    # this pane's Editor child (the text), or null before the first tree
    func text_of [] -> Editor
        if [ !elements ] return null
        te : element elements[ 'text' ]
        if [ !te || !(te inherits Editor) ] return null
        return Editor te

    public func render [] -> Elements
        orb : cast orbiter [ ux.app_object ]
        if [ !orb ] return null
        pi  : i32 [ pane_index ]
        w   : Window ux

        # a console tab is an ordinary tab — the session is the Editor's content,
        # hosted by a ConsoleView, so it keeps the standard title bar below.
        psess : string (pi < orb.pane_console.count) ? orb.pane_console[pi] : ''
        is_con : bool [ psess && psess.count > 0 ]

        slot : i32  [ (pi < orb.editor_slots.count) ? orb.editor_slots[pi] : -1 ]
        p    : path (slot >= 0 && slot < orb.open_files.count) ? orb.open_files[slot] : null

        # active debug session locks editing → keyboard drives the debugger
        dbgr    : dbg orb.active_debugger[]
        running : bool [ (dbgr) ? true : false ]
        ed_live : Editor text_of[]
        armed   : bool [ ed_live->edit_armed ]
        locked  : bool [ running && !armed ]
        dbg_open  : bool [ ed_live->dbg_open ]
        searchable : bool [ orb.search_pane[] == id ]
        findbar_on : bool [ orb.findbar_open && orb.findbar_pane == id ]
        menu_open  : bool [ searchable && (orb.find_showing || orb.nav_showing) ]
        is_res     : bool [ (ed_live && ed_live.rview) ? true : false ]
        # a paused emulator publishes a machine-context dump once — type it
        # into the AI agent console so the user can ask about the live state
        if [ is_res ]
            cfeed : ed_live.rview.context_feed*[]
            if [ cfeed ] orb.feed_agent[ cfeed ]
        # this pane's title has focus (typed-in finder state). the title is OUR
        # child now, so the parent to match is this tab — not the Editor.
        tfoc : bool [ false ]
        if [ w && w.focus ]
            if [ w.focus.id == 'title' && w.focus.parent == a ] tfoc = true

        els : Elements []
        ttl : Elements orb.title_nav[ p, null, false, w, locked, dbg_open, menu_open,
            is_res, ed_live->rview, findbar_on, tfoc ]
        # a console tab gets the agent feed buttons: 'context' copies the live
        # emulator's machine dump into the prompt, 'screen' attaches a screenshot.
        if [ is_con ]
            ttl['ctx_copy'] = LabelButton [ label: 'context', manual_mode: true ]
            ttl['ctx_shot'] = LabelButton [ label: 'screen',  manual_mode: true ]
        # the title is the console's template name ('{name}#{seq}' → name), else
        # the filename. the open findbar owns the span, so blank it under one.
        tl : string [ (p) ? p.filename[] : 'Open' ]
        if [ is_con ]
            tl = psess
            phx : i32 [ tl.index_of[ '#' ] ]
            if [ phx > 0 ] tl = tl.mid[ 0, phx ]
        if [ findbar_on ] tl = ''
        els['title'] = EditorTitle [
            area: Region { l0 t0 r0 h1.3 }
            selected: !p
            focusable: true
            spacing_x: 0.2
            spacing_y: 0.2
            edit: orb.find_text
            label: tl
            no_scroll: true
            elements: ttl
        ]

        # a silver source gets a run band, so the text stops at the band seam.
        # a console tab never does — the session already fills the pane.
        app_running : bool [ (ed_live && ed_live.run_view) ? true : false ]
        run_ok : bool [ app_running && !is_con ]
        if [ !run_ok && p && !is_con ]
            fnm : p.filename[]
            if [ fnm.count >= 3 && fnm.mid[ fnm.count - 3, 3 ].compare[ '.ag' ] == 0 ] run_ok = true
        # the title is a fixed-height band; the text always starts just below it
        tarea : Region
        tarea = (run_ok) ? Region { l0 t1.3 r0 b@ed_split=8|44|44 } : Region { l0 t1.3 r0 b0 }

        # the content slot: whichever element claims this tab. a console session IS
        # an element (Console), so it needs no host — it goes straight in. it sits
        # BELOW the title and above the band, so its bounds are its whole viewport.
        if [ is_con ]
            orb.ensure_console[ psess ]
            els['text'] = Console [
                area: tarea
                session_id: psess, sessions: orb.ed_sessions, feed: null,
                launch: orb.agent_cmd[ psess ], animated: true ]
            return els

        els['text'] = Editor [
            area: tarea
            src: p
            breakpoints: orb.breakpoints, code_font_size: orb.code_font_size,
            nav: orb.nav_panes[ pi ], pane_index: pi,
            debug_running: running, debugger: dbgr, debug_vars: orb.debug_vars,
            expanded: findbar_on, replacing: (findbar_on && orb.replace_open),
            show_hits: (searchable) ? (orb.find_showing || orb.nav_showing) : false,
            single_line: (orb.nav_showing && orb.browse_single),
            header_size: orb.browse_header_size, dir_size: orb.browse_dir_size,
            nav_list: (searchable) ? orb.nav_showing : false, dock_rows: orb.nav_dock_rows,
            grid_mode: (searchable) ? (orb.nav_showing && orb.grid_mode) : false,
            hits: orb.find_hits,
            find_query: (searchable && findbar_on) ? orb.findbar_text : '' ]

        # the run band + console, INSIDE this tab
        if [ run_ok ]
            emod : string [ (p) ? p.filename[] : 'app' ]
            di2  : i32    [ emod.index_of[ '.' ] ]
            if [ di2 > 0 ] emod = emod.mid[ 0, di2 ]
            if [ !orb.ed_sessions ] orb.ed_sessions = map ConsoleSession [string] [ ]
            fels : Elements []
            fels['run'] = LButton [ icon: (app_running) ? 'stop' : 'play', selected: app_running, manual_mode: true ]
            if [ orb.err_file && orb.err_line > 0 ]
                fels['error'] = Option [ label: 'error {orb.err_line}', manual_mode: true ]
            fels['instruments'] = RButton [ icon: 'gear', selected: orb.show_instruments, manual_mode: true ]
            cf2 : Elements []
            # compact right-aligned filter chip — must NOT cover the terminal,
            # or clicks focus it and typing lands in its edit instead of the shell
            cf2['console_filter'] = element [ area: Region { r8px t4px w6 h32px }, label: emod, focusable: true, no_scroll: true ]
            runcmd : string [ (ed_live && ed_live.run_view) ? ed_live.run_view.cmd : null ]
            bels : Elements []
            bels['tools']   = ToolsHeader [ spacing_x: 0.2, spacing_y: 0.2, topmost: true, elements: fels ]
            bels['console'] = RunConsole [ session_id: 'ed:{emod}', sessions: orb.ed_sessions,
                feed: null, run_line: runcmd, animated: true, elements: cf2 ]
            els['band'] = RunBand [ elements: bels ]
        return els

# editor title bar. `selected` = the "New"/finder state (no file open): shows
# the magnify and left-aligns the (typed) text. with a file open it's centered
# and the magnify is hidden. clicking it focuses → editable.
# the dedicated title component: quiet glow band + the editable face. its
# look lives HERE as declared layers — the title is orbiter's, not a style's.
element EditorTitle
    public selected : bool
    area  : Region { l0 t0 r0 h1.3 }
    tbar  : Layer [ fill_color: rgba [ '#2480' ], inner_glow: Glow [ '#8af2 26' ],
        stroke_width: 0.5, stroke_color: rgba [ '#fff2' ] ]
    tface : Layer [ label_color: rgba [ '#fff' ], label_size: 19, editable: true,
        label_align: vec2f [ x: 0.0, y: 0.5 ], label_offset: vec2f [ x: 84.0, y: 0.0 ] ]
    tfoc  : Layer [ states: State.focused, label_color: rgba [ '#ffff' ], label_size: 19, editable: true,
        label_align: vec2f [ x: 0.0, y: 0.5 ], label_offset: vec2f [ x: 84.0, y: 0.0 ] ]
    tdiv  : Layer [ fill_color: rgba [ '#fff2' ], area: Region { l0 b0 r0 h1px } ]

# orbiter's own nav icon button (the title-bar +/- chips): look declared here,
# no stylesheet — a transparent chip with a faint glow that lights blue on hover
# THE nav button — every chip in every title and toolbar. a toggle is not a
# class: `selected`/`manual_mode` are properties (Option). icon by name;
# right-flows by default, a construction may anchor it anywhere with `area`.

Option NavButton
    quiet  : Layer [ fill_color: rgba [ '#216' ], radius: Radius [ '8' ], inner_glow: Glow [ '#ccf2 16' ] ]
    hover  : Layer [ states: State.hovered,  fill_color: rgba [ '#327' ],    radius: Radius [ '8' ], inner_glow: Glow [ '#ccf6 20' ] ]
    press  : Layer [ states: State.pressed,  fill_color: rgba [ '#438' ],    radius: Radius [ '8' ], inner_glow: Glow [ '#ccf8 22' ] ]
    active : Layer [ states: State.selected, fill_color: rgba [ '#c8641e' ],  radius: Radius [ '8' ], inner_glow: Glow [ '#ffae5ea2 18' ] ]

# a NavButton that renders its label instead of an icon; right-flows
# wider than the icon chips
NavButton LabelButton
    area   : Region { r0+ t0 w2.2 h0.9 }
    tlabel : Layer [ label_color: rgba [ '#fffa' ], label_size: 14,
        label_align: vec2f [ x: 0.5, y: 0.5 ] ]

# direction is the class: R flows right-to-left, L flows left-to-right
NavButton RButton
    area : Region { r0+ t0 w1.15 h0.9 }

NavButton LButton
    area : Region { l0+ t0 w1.15 h0.9 }

# findbar scope: filename or cross-file glob, left of the chips.
# read-only label on transparent until find-in-files (selected)
# turns it into the editable quiet chip
element PatternField
    public selected : bool
    area : Region { r0+ t0 w7 h0.9 }
    body : Layer [ states: State.selected, fill_color: rgba [ '#216' ], radius: Radius [ '8' ] ]
    face : Layer [ label_color: rgba [ '#fff' ], label_size: 19, editable: true,
        label_align: vec2f [ x: 0.0, y: 0.5 ], label_offset: vec2f [ x: 12.0, y: 0.0 ] ]

# findbar query input: sits where the title label normally is
element FindField
    area : Region { l2.7 t0 r20 b0 }
    face : Layer [ label_color: rgba [ '#fff6' ], label_size: 19, editable: true,
        label_align: vec2f [ x: 0.0, y: 0.5 ], label_offset: vec2f [ x: 0.0, y: 0.0 ] ]
    foc  : Layer [ states: State.focused, label_color: rgba [ '#ffff' ], label_size: 19, editable: true,
        label_align: vec2f [ x: 0.0, y: 0.5 ], label_offset: vec2f [ x: 0.0, y: 0.0 ] ]

# findbar replace input: right-flow slot before 'All'
element ReplaceField
    area : Region { r0+ t0 w6 h0.9 }
    face : Layer [ label_color: rgba [ '#fff6' ], label_size: 14, editable: true,
        label_align: vec2f [ x: 0.0, y: 0.5 ], label_offset: vec2f [ x: 10.0, y: 0.0 ] ]
    foc  : Layer [ states: State.focused, label_color: rgba [ '#ffff' ], label_size: 14, editable: true,
        label_align: vec2f [ x: 0.0, y: 0.5 ], label_offset: vec2f [ x: 10.0, y: 0.0 ] ]

# orbiter's standard button: the gradient pill body at 8px radius with the
# inner glow — quiet indigo, blue-lit on hover, ember when selected.
Button PillButton
    area   : Region { l6+px t3px w3 h1 }
    body   : Layer [ fill_color: rgba [ '#114' ], fill_gradient: GradientType.linear,
        fill_gradient_color: rgba [ '#315f' ], fill_gradient_angle: 90.0,
        inner_glow: Glow [ '#ccf2 16' ], radius: Radius [ '8' ],
        stroke_width: 0.5, stroke_color: rgba [ '#fff2' ] ]
    hover  : Layer [
            states:                 State.hovered,
            fill_color:             rgba [ '#216' ],
            fill_gradient:          GradientType.linear,
            fill_gradient_color:    rgba [ '#327f' ],
            fill_gradient_angle:    90.0,
            inner_glow:             Glow [ '#ccf4 16' ],
            radius:                 Radius [ '8' ]
        ]
    active : Layer [
            states:                 State.selected,
            fill_color:             rgba [ '#c8641e' ],
            fill_gradient:          GradientType.linear,
            fill_gradient_color:    rgba [ '#425f' ],
            fill_gradient_angle:    90.0,
            inner_glow:             Glow [ '#ffae5ea2 18' ],
            radius:                 Radius [ '8' ]
        ]
    face   : Layer [ label_color: rgba [ '#fff' ], label_size: 14,
        label_align: vec2f [ x: 0.5, y: 0.5 ] ]

# the pane's bottom run band. the draggable @ed_split seam is a CLASS default:
# the Region persists on the instance across frames, so the seam's ease and
# snap state (BindCoord active/warmed) survives — a per-frame Region resets it.
element RunBand
    area : Region { l0 b@ed_split=8|44|44 r0 b0 }

# the run band's console: fills the band under the header, terminal content
# inset 8px all around — no 44px title inset (the ToolsHeader is the title).
Console RunConsole
    area    : Region { l0 t1.3 r0 b0 }
    content : TermLayer [ area: Region { 8px }, label_height: 1.0, label_size: 16 ]


# the run band's header strip: the same title-bar look the editor title wears,
# capping the module console group.
Group ToolsHeader
    area : Region { l0 t0 r0 h1.3 }
    hbar : Layer [ fill_color: rgba [ '#2480' ], inner_glow: Glow [ '#8af2 26' ],
        stroke_width: 0.5, stroke_color: rgba [ '#fff2' ] ]
    hdiv : Layer [ fill_color: rgba [ '#fff2' ], area: Region { l0 b0px r0 h1px } ]

# left-column tab for a project: a running-process context (process, shell
# output, lldb). `state` drives the side status light color.
Option  ProjectTab
    public state : string

#proto compiler ... this is in effect what we are doing, and if we 'wanted' to we could register this for enumeration at runtime
#      func compiler [ module: string ]

func au_space_clear[] -> none

# resident set size as a fraction of total physical RAM (0..1), 0 if unknown.
# used as a runaway-leak guard so the app bails out before it locks the machine.
func au_mem_fraction[] -> f32

# deferred live-reload: au_live_set_defer turns it ON (host stages source changes instead
# of auto-reloading, sets pending=1, and waits). au_live_get_pending → a change is staged;
# au_live_request_apply → tell the host to recompile + hot-swap now.
func au_live_set_defer[ on: i32 ] -> none
func au_live_get_pending[]   -> i32
func au_live_request_apply[] -> none

# redirect stdout/stderr into a pipe (returns a non-blocking read fd); au_stdout_orig
# is a dup of the real stdout so --log can tee captured output back to the terminal.
func au_capture_stdout[] -> i32
func au_stdout_orig[] -> i32

# per-workspace UI/session state, persisted to <os-cache>/orbiter/states.agi as a
# map keyed by the workspace (startup) path. starts with the open tabs; more fields
# (active pane, splits, scroll positions, etc.) get added here over time.
class orbiter_state
    public tabs        : array path
    # the file shown in each editor pane, in pane order ('-' = an empty pane). restores
    # the actual editor layout, not just the flat set of open files.
    public panes       : array path
    # pinned dock files (shown at the top of the file list), restored on next launch.
    public docked      : array path
    # breakpoints for this workspace — same "source:line" -> condition map orbiter
    # keeps live (empty condition = plain breakpoint).
    public breakpoints : map string [string]
    # the selected project/target name, restored on next launch.
    public target      : string

class FmtWatch
    public proj  : string
    # the .ag file we handed the language server — it drives the build/analyze
    public file  : path
    public pid   : i32 [ 0 ]
    public fd    : i32 [ -1 ]
    public map   : string
    public mtime : i64 [ 0 ]
    # mtime of OUR source the last time we spawned — a change here (and only
    # here) re-runs this one watcher, never the whole set.
    public src_mtime : i64 [ 0 ]
    # printed the "starting" line to the console yet (deferred until the console exists)
    public announced : bool
    # kicked the initial build yet — deferred until AFTER the existing cache is loaded (prime),
    # so colors appear instantly from the last build and we never read a half-written file.
    public kicked    : bool
    # epoch micros when this watch was registered; the initial build waits ~1s past this so the
    # cache loads and colors render first, uncontended by the compile.
    public start_us  : i64 [ 0 ]

# the supervised app's live picture-in-picture: the front texture of the
# app's shared surface, imported by trinity (ide_pump). click = fold back.
element OrbitApp
    animated  : true
    focusable : true

    public func draw [ w: Window ]
        if [ w.draw_stage != CanvasType.screen ] return
        cv : Canvas w.screen
        if [ !w.app_tex0 || !w.app_tex_have ] return
        fr : i32 [ host_tex_front[ host_slot[], 0 ] ]
        if [ fr < 0 ] return
        atx : (fr == 0) ? w.app_tex0 : w.app_tex1
        aw : i32 [ atx.width ]
        ah : i32 [ atx.height ]
        if [ aw <= 0 || ah <= 0 ] return
        ar : f32 [ f32[ aw ] / f32[ ah ] ]
        fw : f32 [ bounds.w ]
        fh : f32 [ fw / ar ]
        if [ fh > bounds.h ]
            fh = bounds.h
            fw = fh * ar
        cv.draw_image[ atx, rect [
            x: (bounds.w - fw) * 0.5, y: (bounds.h - fh) * 0.5, w: fw, h: fh ] ]

    # clicking the live picture folds the window back to the app
    func on_press [ ev: Event ]
        host_post[ 1, i32[ HM.close ], 0, 0, 0 ]
        ev.stop_propagation[]

element orbiter : trinity # implements compiler
    public width         : i32    [ 1888 ]
    public height        : i32    [ 888 ]
    public background    : string [ 'Background' ]
    # orbiter edits its OWN dependencies — self-reload is insane, so opt out
    public live_reload   : bool   [ true ]
    public startup_path  : path
    # `orbiter <file>` — the document to open, orbiter's default (positional)
    # argument. a directory roots the browser there instead.
    default resource     : string
    # --log <path>: tee all stdout/puts to this file (truncated on start) WHILE still
    # printing to the console, so a running session's diagnostics can be read back from
    # disk. cap_fd = the pipe au_capture_stdout drains; log_fd = the open log file.
    public log           : string
    intern tee_started   : bool
    intern cap_fd        : i32 [ -1 ]
    intern log_fd        : i32 [ -1 ]
    intern avg_fps       : f32
    intern target_names  : array string
    intern target_roots  : array path
    intern target_srcs   : array path
    # projects loaded from orbiter.agi (the source of truth). orbiter.agi sets
    # this map directly on the orbiter instance via parse_agi; target_names/roots/
    # srcs are derived from it (sync_targets) so the rest of the app keeps using
    # the flat arrays. cleared + reloaded whenever orbiter.agi changes.
    public projects      : map Project [string]
    # console instances from orbiter.agi (shells / AI agents), keyed by name —
    # the templates the nav list offers when picking a console into a tab.
    public consoles      : map ConsoleInstance [string]
    # live console sessions, keyed by session id. a tab's console reuses one
    # session across renders instead of restarting its shell.
    intern ed_sessions   : map ConsoleSession [string]
    # screenshot counter — unique /tmp names within a session so the agent
    # never sees a stale image under a reused path
    intern shot_n        : i32
    # supervised-shell state (SILVER_ISOLATE_APP set): orbiter is the shell —
    # crash verdicts, dictation, and the app agent all land here
    intern orbit_app      : string
    # the agent tab's session id ('' = shell mode off)
    intern orbit_sid      : string
    # app context rides the FIRST message to the agent, exactly once
    intern orbit_ctx      : string
    intern orbit_ctx_sent : bool
    # the crash verdict has been typed into the agent session
    intern orbit_reported : bool
    # delayed follow-up Enter: the TUI can swallow a mid-redraw \r
    intern orbit_enter_at : i32
    # utterances already voiced (speak markers persist on screen)
    intern orbit_spoken   : array string
    # mic capture running / final transcription winding down
    intern orbit_cap_on   : bool
    intern orbit_flushing : bool
    # last dictate command (edge-detect) via on_host
    intern orbit_dstate   : i32 [ -1 ]
    # attached app's pid — once it dies this shell must exit
    intern orbit_app_pid  : i32 [ 0 ]
    # literal {{ / }} built from bytes for the speak-marker protocol
    intern orbit_oc       : string
    intern orbit_cc       : string
    # per-workspace session state (open tabs + future props), keyed by workspace
    # path. loaded from / saved to <os-cache>/orbiter/states.agi via parse_agi.
    public states        : map orbiter_state [string]
    # live debug sessions, keyed by project name. each is a `dbg` (our LLDB SB-API
    # driver) launched on the project's product; its on_* callbacks land on the
    # handlers below (on_stdout/on_break/...).
    intern debuggers     : map dbg [string]
    # the inspected variables for the Fields panel — locals read at the last break
    # (read_locals only works while paused), cached here and cleared on continue/exit.
    intern debug_vars         : array
    # last seen breakpoint-map size — a change (toggle in an Editor's gutter) means the
    # session state is dirty, so on_render re-saves. count catches add/remove.
    intern last_bp_count      : i32 [ -1 ]
    # orbiter.agi reload: polled once a second from on_render. settings_mtime is
    # the file mtime we last loaded; settings_check_ms throttles the stat to ~1Hz.
    intern settings_mtime    : i64
    intern settings_check_ms : i64
    public open_files       : array path
    # the dock: files pinned to the TOP of the file list (shown above the browse tree).
    # one unified dock for all panes (not per-side). persisted in the session.
    public docked           : array path
    # number of find_hits rows occupied by the pinned dock — the editor draws a
    # separator line after them, dividing the dock from the browse results.
    intern nav_dock_rows    : i32
    # the editor split: one entry per visible editor pane, each an index into
    # open_files (-1 = empty 'Open' finder pane). up to 4. the + / - title buttons
    # push/remove entries; the render builds one Editor per slot. active_pane is the
    # focused pane index (where opens/finder land).
    public editor_slots     : array i32
    # per-pane console session: '' = file editor, else this pane IS that console
    intern pane_console     : array string
    # each nav pick instances a FRESH session ('{name}#{seq}') — never shared
    intern console_seq      : i32
    # pane whose finder should focus once its Editor exists (console → nav list)
    intern pending_finder   : i32 [ -1 ]
    # `orbiter <module>`: start that pane's app once its Editor exists
    intern pending_run      : i32 [ -1 ]
    # findbar just opened: focus its find input once it exists (next frame)
    intern pending_findfocus : bool
    # files the last find-in-files run scanned (for the empty-result row)
    intern find_scanned : i32
    # the last area string applied to each pane instance — areas assign only on
    # change so the instance's Region (and its seam bind state) persists
    intern pane_area_cur    : array string
    public active_pane      : i32
    # per-pane navigation history (Cmd/Ctrl+Left/Right). runtime-only — never serialized
    # (save_states writes only tabs/target/breakpoints), so it starts empty each session.
    # one Navigate per pane (pane0..3) so back/forward stay on the same editor side; owned
    # here (not on the per-frame-throwaway Editor) and injected into each pane every frame.
    intern nav_panes        : array Navigate
    # the split seams between panes, as absolute x-positions in layout units from the
    # editor area's left edge. pane i's right edge = split{i+1}; adjacent panes share
    # the var on their touching edges so the seam is draggable (trinity seam model).
    # the last pane's trailing split is pinned to the area width each frame so it
    # fills; internal seams persist user drags. redistributed equally on add/remove.
    public split1           : f32 [ 50.0 ]
    public split2           : f32 [ 100.0 ]
    public split3           : f32 [ 150.0 ]
    # the per-pane run band's draggable top seam (b@ed_split), in units
    public ed_split         : f32 [ 8.0 ]
    # instruments panel (callstack + app view) covers the console when on
    public show_instruments : bool
    # last pane count we redistributed for — when editor_slots.count changes we reset
    # the seams to an equal division.
    intern last_ecount      : i32
    public active_idx       : i32
    public config_side      : i32
    public active_panel  : string
    public editor_panel  : string
    public active_target : string
    # one `silver <proj> -w --format <map>` language-server instance per silver project,
    # keyed by project name. kept in sync with the .agi project set (fmt_sync), never tied
    # to the active tab or the render loop.
    intern fmt_watch  : map FmtWatch [string]
    # an empty editor pane (no file) shows the Avatar in its elemental state; this
    # toggles the Avatar view via the pane's titlebar hide/show option.
    public show_avatar   : bool [ true ]
    # the avatar peeks in the bottom-right corner; clicking it expands to a full-size
    # interactive area, clicking again collapses back to the peek.
    public avatar_expanded : bool
    # the avatar's GPU pipeline currently SIGSEGVs (env-texture view not ready at bind);
    # OFF until that's fixed so orbiter still launches. flip true to render the avatar.
    public avatar_enabled  : bool
    # the stack sub-column (callstack + fields) inside each editor, on a draggable
    # the SHARED width of the dbg sub-column seam (draggable via @stack_w in CSS).
    # on/off is per-editor (Editor.dbg_open builds it); this is just how wide it is
    # when shown — non-zero so a freshly-opened panel has width. drag adjusts it.
    public stack_w       : f32 [ 15.0 ]
    public stack_w_user  : f32 [ 15.0 ]
    public filter_text   : string
    # finder search text typed into an editor title (magnify) when it has no file
    public find_text     : string
    # in-editor find/replace bar (toggled by the title magnify). findbar_open is the
    # expand state — held on the app (the Editor element is rebuilt each frame so it
    # can't keep the flag), fed into the Editor via its `expanded` prop. findbar_text
    # is the Find query, replace_text the Replace query. kept separate from find_text
    # (the file finder) so typing here doesn't trigger the finder's pin list.
    public findbar_open  : bool
    # which pane's magnify opened the findbar ('pane'/'pane_right') — so the bar
    # stays on that editor and focus moving to the other title doesn't pull it over.
    public findbar_pane  : string
    public findbar_text  : string
    # the query that produced the current find_hits — so a second Enter on the same
    # phrase advances to the next match instead of re-running the search. find_last_scope
    # mirrors the scope field (pattern_text) at run time: if EITHER changes, Enter is a
    # NEW search, not a next-match step.
    intern find_last_query : string
    intern find_last_scope : string
    public replace_text  : string
    # file-pattern (glob) that scopes find-in-files — the right cell of the
    # Replace row.
    public pattern_text  : string
    # find/replace scope, a radio pair in the right column: true = the current
    # file only ('In-File' on the Find row); false = files matching the pattern
    # ('Files' on the Replace row).
    public find_in_file  : bool
    # the 'Replace' nav button is a toggle: off = just the Find row; on = exposes the
    # replace input + the 'All' (replace-all) button. drives the Editor's :replacing state.
    public replace_open  : bool
    # find-in-files results: find_showing makes the editor pane render find_hits
    # (file-title headers + matched lines) instead of file content. fed to the
    # Editor each frame via props.
    public find_showing  : bool
    # the tab/navigate file list reuses the SAME find_hits header rendering (each file
    # a 2-slot title: filename bright + dir dimmed). nav_showing turns that on for the
    # search pane independently of find_showing, so the two never clobber each other.
    public nav_showing   : bool
    public find_hits     : array FindHit
    # directories the finder searches (default: the project path). users add more.
    public search_dirs   : array path
    # flat index of every file path under search_dirs (built once, filtered in
    # memory per keystroke). find_results is the editor finder's current match set.
    public file_index    : list string
    # cap on indexed files — the walk stops here so a huge tree can't run away.
    # settable from orbiter.agi (`max_search: …`).
    public max_search    : i32 [ 400000 ]
    # index nested git repositories (external/vendored deps) at all? true = index them
    # last, false = skip entirely. settable from orbiter.agi (`search_external: false`).
    public search_external : bool [ true ]
    public find_results  : list string
    # tracks whether the finder was active last frame, so we run_search on the
    # transition (open → show the dock as lines; close → restore the file).
    intern was_finder    : bool
    # double-click detection on find-result rows: timestamp + row of the last press,
    # so a second press on the same match row within the window opens it at its line.
    intern last_hit_row      : i32 [ -1 ]
    # the pane id the finder last targeted ('pane'/'pane_right'), so focus moving
    # between panes re-runs the search into the newly-focused one.
    intern was_search_pane : string
    # set true by the inotify watch thread when anything under search_dirs
    # changes. the next search rebuilds file_index lazily on the main thread.
    public index_dirty   : bool
    # set when a project switch re-rooted the index with a live query — once the new
    # index finishes building, re-run the search so results reflect the new project.
    intern index_research : bool
    # same signal, for the syntax formatter: a source file changed, so the format
    # map(s) are stale — fmt_poll re-invokes `silver <proj> --format` to refresh them.
    # one async worker thread builds the index off the UI thread
    intern index_task    : async
    # guards file_index: search reads while the worker fills
    intern index_lock    : mutex
    # main thread raises this to stop a running worker early
    intern index_cancel  : bool
    intern index_building : bool
    # one inotify watch per search dir; keeps file_index fresh (like vscode's
    # file watcher) instead of a once-per-session walk.
    intern index_watches : array watch
    public compile_log   : list string
    # last build-error location (ctrl/cmd+E and the console error pill return here)
    intern err_file      : path
    intern err_line      : i32
    public nav_root      : path
    # browse list density: false = the 2-slot double header (name over dir), true = a
    # compact single-line row at the primary code font. Tab toggles it.
    public browse_single : bool
    # show/hide the pinned dock at the top of the browse list — toggled from the editor
    # nav so the results can be maximized. (eventual home of a thumbnail grid.)
    public show_pins     : bool [ true ]
    # render the index as a thumbnail grid instead of the row list (same find_hits data).
    public grid_mode     : bool
    # the (larger) font size used for the NAME line of the two-line double-header rows.
    # single-line uses the primary code font; double-line's name is bigger.
    public browse_header_size : i32 [ 18 ]
    # the dir (second) line font of a double header — smaller than the name, sized
    # between the single-line primary font and the name line.
    public browse_dir_size : i32 [ 16 ]
    # breakpoints are app-global, keyed by "source:line" -> condition string
    # (empty = plain breakpoint, non-empty = conditional). the same map is
    # handed to every Editor so they all share one set.
    public breakpoints   : map string[string]
    # code font size (px) for editors. canvas default is large (~22); this is
    # the single place to tune it. line-number labels render smaller still.
    # settable from orbiter.agi (`code_font_size: …`).
    public code_font_size : i32 [ 19 ]
    # tabs are our own children ('pane0'..'pane3'); pane_at[i] reaches their text.

    func init []
        # turn ON deferred live-reload: silver-host stages source changes and signals us
        # instead of auto-reloading, so the 'reload' chip appears and WE apply on click.
        # the user passes nothing — orbiter drives this via the au_live_* host channel.
        au_live_set_defer[ 1 ]
        # create the shared breakpoint set first so it always exists before any
        # Editor is built and handed a reference to it.
        breakpoints    = map string[string] []

        # targets come from orbiter.agi (parsed into the projects map, then
        # flattened into target_names/roots/srcs). load_settings populates them.
        target_names   = array string []
        target_roots   = array path []
        target_srcs    = array path []
        load_settings[]
        # no files open at start — files open from the FileList (main on click,
        # right pane on shift+click)
        open_files     = array path []
        docked         = array path []
        # a few default pins so the column has content to look at
        active_idx     = -1
        # one editor pane to start, empty (the 'Open' finder)
        editor_slots   = array i32 [-1]
        pane_console   = array string ['']
        pane_area_cur  = array string []
        active_pane    = 0
        nav_panes      = array Navigate []
        for [ i: i32 0, i < 8, i += 1 ]
            nav_panes += Navigate []
        active_panel   = 'files'
        editor_panel   = 'editor'
        active_target  = 'silver'
        # reopen last session's tabs / breakpoints / selected-project (no-op on first
        # run). MUST come after the defaults above — esp. active_target = 'silver' —
        # so the restored selection isn't immediately clobbered.
        restore_session[]
        # browse + search are rooted at the (restored) active project, not always the
        # first one — project_root[] resolves it (silver's root for the system target).
        nav_root       = project_root[]
        # supervised shell? the host publishes the app name in the environment
        ae : getenv[ 'SILVER_ISOLATE_APP' ]
        if [ ae ]
            orbit_app = string [ ae ]
            orbit_app.hold[]
            ob : local i8 [ 3 ]
            ob[0] = 123
            ob[1] = 123
            ob[2] = 0
            orbit_oc = string [ @ob[0] ]
            orbit_oc.hold[]
            cb : local i8 [ 3 ]
            cb[0] = 125
            cb[1] = 125
            cb[2] = 0
            orbit_cc = string [ @cb[0] ]
            orbit_cc.hold[]
            # the supervised app is the default resource — its source opens
            if [ !resource || resource.count == 0 ] resource = orbit_app
        # `orbiter <file>`: a directory roots the browser there, a file opens in
        # pane 0. AFTER restore_session so the argument wins over the session.
        dbg_start : bool [ false ]
        if [ resource && resource.count > 0 ]
            # user inputs are always normalized to an ABSOLUTE path. cwd is the
            # app's share bundle (cd_share), so a relative arg is against the
            # LAUNCH dir; an absolute one is taken as-is.
            rp : path '{startup_path}/{resource}'
            if [ resource.chars[0] == 47 ] rp = path '{resource}'
            if [ rp.exists[] ]
                if [ rp.is_dir[] ]
                    nav_root = rp
                el
                    ri : i32 [ file_slot[ rp ] ]
                    if [ editor_slots.count == 0 ] editor_slots += -1
                    editor_slots[0] = ri
                    active_pane = 0
                    active_idx  = ri
            el
                # not a path — try it as a MODULE name (foundry/<n>/<n>.ag).
                # opening its main source and selecting it as the target; the
                # debugger launches on its built binary at the end of init.
                mp : path '{startup_path}/foundry/{resource}/{resource}.ag'
                if [ mp.exists[] ]
                    mi : i32 [ file_slot[ mp ] ]
                    if [ editor_slots.count == 0 ] editor_slots += -1
                    editor_slots[0] = mi
                    active_pane   = 0
                    active_idx    = mi
                    active_target = resource
                    nav_root      = path '{startup_path}/foundry/{resource}'
                    # run it IN-PANE (AppView --attach) once the Editor exists —
                    # init is before the tree is built. NOT start_debug: that
                    # execs the product standalone and opens its own window.
                    pending_run   = 0
                el
                    # no source anywhere — a BUILT app by name alone: open the
                    # binary itself (the default hex resource) and debug it.
                    bp : path '{startup_path}/install/build/{resource}'
                    if [ bp.exists[] ]
                        bi : i32 [ file_slot[ bp ] ]
                        if [ editor_slots.count == 0 ] editor_slots += -1
                        editor_slots[0] = bi
                        active_pane   = 0
                        active_idx    = bi
                        active_target = resource
                        dbg_start     = true
                    el
                        puts 'orbiter: no such resource {resource}'
        if [ orbit_app ]
            # the shell never auto-runs the app — relaunch is deliberate
            pending_run = -1
            # the app agent: claude in its own pane, right of the source
            orbit_sid = 'agent:{orbit_app}'
            orbit_sid.hold[]
            pi9 : i32 [ editor_slots.count ]
            editor_slots += -1
            while [ pane_console.count <= pi9 ]
                pane_console += ''
            pane_console[pi9] = orbit_sid
            if [ !ed_sessions ] ed_sessions = map ConsoleSession [string] [ ]
            ns9 : ConsoleSession []
            ns9.name = orbit_sid
            ns9.launch_cmd = 'claude --model sonnet --dangerously-skip-permissions'
            ed_sessions[orbit_sid] = ns9
            ns9.start[]
            active_pane = 0
        filter_text    = ''
        find_text      = ''
        findbar_open   = false
        findbar_text   = ''
        replace_text   = ''
        pattern_text   = ''
        find_in_file   = true
        find_showing   = false
        find_hits      = array FindHit []
        # index/search is rooted at the active project (matches nav_root above)
        search_dirs    = array path []
        search_dirs   += project_root[]
        file_index     = list string []
        find_results   = list string []
        index_dirty    = false
        index_watches  = array watch []
        index_lock     = mutex [ ]
        start_watching[]
        # kick off the index build on its worker thread
        start_index[]
        compile_log    = list string []
        # staleness + recompile-before-load is owned by silver-host now (it checks
        # every watched source against the product and rebuilds only what changed).
        # the old in-app check_stale[] recompiled silver/hyperspace on every startup
        # and broke on the 'silver' target (a C compiler, not a silver module — it
        # resolved to /silver.ag). left here disabled rather than removed.
        # check_stale[]
        ensure_user_config[]
        # `orbiter <app>`: launch the debugger on the named app right away
        if [ dbg_start ] start_debug[ resource ]
        # silver-host owns compiling (subprocess); we don't register as the compiler
        # — we only want its build output routed into our log (system console).
        #au_set_compiler[a]

    func ensure_user_config []
        home : string [ getenv[ 'HOME' ] ]
        if [ !home || home.count == 0 ] return
        xdg  : string [ getenv[ 'XDG_CONFIG_HOME' ] ]
        base : string (xdg && xdg.count > 0) ? xdg : '{home}/.config'
        dir  : path '{base}/orbiter'
        dir.make_dir[]
        cfg  : path '{base}/orbiter/orbiter.config'
        #if [ !cfg.exists[] ]
        #    cfg.save[ '# orbiter user config\n' ]
 
    # orbiter.agi lives in the startup cwd. startup_path is captured in trinity.run[]
    # before cwd changes to the share — but init runs first, so lazy-init it here.
    func agi_path [] -> path
        if [ !startup_path ] startup_path = path.path_startup[]
        p : path '{startup_path}/orbiter.agi'
        if [ p.exists[] ] return p
        # launched from a dir with no orbiter.agi (e.g. the app's own share dir,
        # …/platform/native/share/orbiter): walk up to the nearest ancestor that
        # holds one — the checkout root — and rebase startup_path there so the
        # .agi's relative project roots resolve against that checkout.
        d : path startup_path
        for [ i: i32 0, i < 6, i += 1 ]
            d = d.parent_dir[]
            if [ !d ] return p
            p2 : path '{d}/orbiter.agi'
            if [ p2.exists[] ]
                startup_path = d
                return p2
        return p

    # resolve a project path (root/cwd/file) from orbiter.agi against the actual
    # launch directory Au captured at startup. an absolute path passes through; a
    # relative path (or '.'/empty) is rebased onto startup_path so the SAME .agi
    # works from any checkout location — no hardcoded '/src/silver'. this is how
    # orbiter.agi references "our silver locally": the silver project root is '.',
    # which resolves to the directory orbiter.agi was found in.
    func resolve_local [ p: path ] -> path
        if [ !startup_path ] startup_path = path.path_startup[]
        if [ !p ] return path '{startup_path}'
        s : string '{p}'
        if [ s.count == 0 || s == '.' ] return path '{startup_path}'
        if [ s[0] == '/' ] return p
        return path '{startup_path}/{s}'

    # OS-specific per-user cache dir for orbiter (created on demand). app state that
    # is convenience-only (recoverable, not user content) belongs here, NOT in the
    # workspace. linux: $XDG_CACHE_HOME or ~/.cache ; mac: ~/Library/Caches ;
    # windows: %LOCALAPPDATA%. (apple/linux/windows are compile-time platform consts.)
    # workspace state is persistent, not disposable — storage, not cache
    func cache_dir [] -> path
        return path.path_storage[ 'orbiter' ]

    # the single states file holding every workspace's orbiter_state.
    func states_path [] -> path
        d : cache_dir[]
        if [ !d ] return null
        d.make_dir[]
        return path '{d}/states.agi'

    # the current workspace key — the startup path (where orbiter.agi lives).
    func workspace_key [] -> string
        if [ !startup_path ] startup_path = path.path_startup[]
        return string '{startup_path}'

    # read states.agi → parse_agi sets the `states` map directly on this instance.
    func load_states []
        sp : states_path[]
        if [ !sp || !sp.exists[] ] return
        txt : string [ sp.load[ typeid[string], null ] ]
        if [ !txt || txt.count == 0 ] return
        Au.parse_agi[ null, txt.chars, a ]

    # serialize the `states` map back to states.agi (agi: map of quoted workspace
    # keys → orbiter_state blocks; tabs is a whitespace-delimited path array).
    func save_states []
        sp : states_path[]
        if [ !sp || !states ] return
        out : string 'states:\n'
        for [ st: orbiter_state, ws: string ] in states
            out = out + '\t\'{ws}\': orbiter_state\n'
            line : string '\t\ttabs:'
            if [ st.tabs ]
                for [ t: path ] in st.tabs
                    line = line + ' {t}'
            out = out + line + '\n'
            pline : string '\t\tpanes:'
            if [ st.panes ]
                for [ t: path ] in st.panes
                    pline = pline + ' {t}'
            out = out + pline + '\n'
            dline : string '\t\tdocked:'
            if [ st.docked ]
                for [ t: path ] in st.docked
                    dline = dline + ' {t}'
            out = out + dline + '\n'
            if [ st.target && st.target.count > 0 ]
                out = out + '\t\ttarget: \'{st.target}\'\n'
            # breakpoints as a nested map: '<source:line>': '<condition>'
            if [ st.breakpoints && st.breakpoints.count > 0 ]
                out = out + '\t\tbreakpoints:\n'
                for [ cond: string, key: string ] in st.breakpoints
                    out = out + '\t\t\t\'{key}\': \'{cond}\'\n'
        sp.save[ out, null ]

    # capture the current open tabs into states[workspace] and persist.
    func save_session []
        ws : workspace_key[]
        if [ !ws || ws.count == 0 ] return
        if [ !states ]
			states = map orbiter_state [string] []
        st : orbiter_state states[ws]
        if [ !st ]
            st = orbiter_state []
            states[ws] = st
        tabs : array path []
        for [ i: i32 0, i < open_files.count, i += 1 ]
            if [ open_files[i] ] tabs.push[ open_files[i] ]
        st.tabs        = tabs
        # the per-pane layout: the file each pane shows, in pane order. empty panes are
        # simply skipped — there's nothing to restore for them.
        panes : array path []
        for [ i: i32 0, i < editor_slots.count, i += 1 ]
            slot : i32 [ editor_slots[i] ]
            if [ slot >= 0 && slot < open_files.count && open_files[slot] ]
                panes.push[ open_files[slot] ]
        st.panes       = panes
        st.docked      = docked
        # the live breakpoint map is workspace-scoped — snapshot it into the state.
        st.breakpoints = breakpoints
        st.target      = active_target
        save_states[]

    # on startup: load all states, then reopen the tabs saved for this workspace.
    func restore_session []
        load_states[]
        ws : workspace_key[]
        if [ !states || !ws ] return
        st : orbiter_state states[ws]
        if [ !st ] return
        # reopen tabs (populates the open_files pool)
        if [ st.tabs ]
            for [ i: i32 0, i < st.tabs.count, i += 1 ]
                p : path st.tabs[i]
                if [ p ] file_slot[ p ]
        # restore the pinned dock
        if [ st.docked && st.docked.count > 0 ]
            docked = array path []
            for [ i: i32 0, i < st.docked.count, i += 1 ]
                p : path st.docked[i]
                if [ p ] docked += p
        # restore the per-pane layout: each saved pane's file into its own slot
        if [ st.panes && st.panes.count > 0 ]
            editor_slots = array i32 []
            for [ i: i32 0, i < st.panes.count, i += 1 ]
                p : path st.panes[i]
                if [ p ] editor_slots += file_slot[ p ]
            if [ editor_slots.count == 0 ] editor_slots += -1
            active_pane = 0

        el [ st.tabs && open_files.count > 0 && editor_slots.count > 0 ]
            editor_slots[0] = 0

        # restore breakpoints into the live (shared) map so editors pick them up
        if [ st.breakpoints && breakpoints ]
            for [ cond: string, key: string ] in st.breakpoints
                breakpoints[key] = cond
            last_bp_count = breakpoints.count
        # restore the selected project
        if [ st.target && st.target.count > 0 ]
            active_target = st.target
        # the open tabs ARE the restored session (above) — they're workspace state, not
        # project state, so we do NOT override them with a project's default file set.

    # read orbiter.agi and let parse_agi set members directly on this orbiter
    # instance (`a`) — chiefly the `projects` map. we clear projects first so a
    # reload is a clean rebuild (no stale entries lingering), then reparse and
    # flatten projects into the flat target arrays the UI already uses.
    func load_settings []
        sp  : agi_path[]
        puts 'load_settings: startup_path={startup_path} -> agi={sp}'
        txt : string [ sp.load[ typeid[string], null ] ]
        if [ !txt || txt.count == 0 ]
            puts 'load_settings: no/empty file at {sp}'
            return
        settings_mtime = sp.modified_time[]
        if [ projects ] projects.clear[]
        Au.parse_agi[ null, txt.chars, a ]
        # rebase project roots/cwds onto the launch dir so relative .agi paths
        # (e.g. silver root '.') resolve to this local checkout, not a hardcoded path.
        if [ projects ]
            for [ p: Project, name: string ] in projects
                p.root = resolve_local[ p.root ]
                if [ p.cwd ] p.cwd = resolve_local[ p.cwd ]
        sync_targets[]
        # (language servers are driven by the open .ag files now, synced from the
        # once-a-second poll — not from the project load.)
        if [ projects ]
            puts 'loaded {projects.count} projects:'
            for [ p: Project, name: string ] in projects
                puts '  {name}: root={p.root}'
                if [ p.deps ]
                    for [ d: token ] in p.deps
                        puts '    dep: {d.chars}'
        el
            puts 'loaded 0 projects (projects is null)'

    # flatten the projects map (source of truth) into the flat target_names/
    # target_roots/target_srcs arrays the tabs, search and nav code consume.
    func sync_targets []
        target_names = array string []
        target_roots = array path []
        target_srcs  = array path []
        if [ !projects ]
            return
        for [ p: Project, name: string ] in projects
            target_names += name
            target_roots += p.root
            target_srcs  += p.root

    func check_stale []
        for [ i: i32 0, i < target_names.count, i += 1 ]
            name    : string target_names[i]
            src     : path   target_srcs[i]
            product : path  '{startup_path}/install/build/{name}'
            if [ !product.exists[] ]
                compile_log.push[ 'stale (no product): {name}' ]
                compile[ name ]
                continue
            product_mtime : i64 [ product.modified_time[] ]
            src_mtime     : i64 [ 0 ]
            src.latest_modified[ @src_mtime ]
            if [ src_mtime > product_mtime ]
                compile_log.push[ 'stale (source newer): {name}' ]
                compile[ name ]

    func compile_fn [ w: Au ]
        m: string w  
        i: silver [ component: true, module: m ]  

    func compile [ mod: string ]
        active_target = 'system'
        compile_log.push[ 'compiling {mod}...' ]
        i: silver [ component: true, verbose:true, module: mod ]
        au_space_clear[]
        compile_log.push[ 'done: {mod}' ]

    # ---- per-file format watchers (language server), one per open .ag file ----------
    func fmt_stop [ key: string ]
        if [ !fmt_watch ] return
        fw : FmtWatch fmt_watch[ key ]
        if [ !fw ] return
        if [ fw.fd >= 0 ] close[ fw.fd ]
        fmt_watch.rm[ key ]

    func fmt_stop_all []
        if [ !fmt_watch ] return
        for [ fw: FmtWatch, name: string ] in fmt_watch
            if [ fw.fd >= 0 ] close[ fw.fd ]
        fmt_watch = map FmtWatch [string] []

    # start a `silver <proj> -w --format <map>` watcher for one silver project. exec'd
    # through bash so the arg string matches the terminal; exec makes silver the pty leader
    # (clean SIGHUP on close).
    # (re)run the one-shot `silver <proj> --format <map>` for a watch entry. --format
    # writes the syntax map and needs nothing else (no build; NO -w watch mode — that
    # segfaults). called once at start and again whenever a source file changes.
    func fmt_spawn [ fw: FmtWatch ]
        if [ !fw ] return
        # startup_path may not be captured yet when this first runs at load; without it the
        # command becomes `cd  && exec ./platform/...` → cd to $HOME → binary not found (127).
        if [ !startup_path ] startup_path = path.path_startup[]
        # close a prior generation's pty fd before re-spawning (regen).
        if [ fw.fd >= 0 ]
            close[ fw.fd ]
            fw.fd = -1
        # --build (compile only): emit the syntax map as a byproduct and EXIT. without it,
        # bare `silver <proj>` also RUNS the app — spawning a windowed orbiter that never
        # returns and never cleanly hands us the map.
        # unset IMPORT: a login shell sets IMPORT=.../sdk/native, pointing the build at the
        # INSTALLED (stale) Au headers — which fail to compile and yield a partial map.
        # clearing it uses the dev tree (platform/native), matching the running binary.
        # a plain --build now writes the syntax cache as a byproduct to its standard path
        # (<install>/syntax/<proj>.f) — no --format flag. redirect stdout+stderr to a log so a
        # compile error / crash is captured (a partial cache is itself the not-compiled signal).
        cmd : 'cd {startup_path} && unset IMPORT && exec ./install/bin/silver --build {fw.file} > /tmp/orbiter-fmt-{fw.proj}.log 2>&1'
        fd  : i32 [ -1 ]
        pid : i32 [ forkpty[ @fd, null, null, null ] ]
        if [ pid == 0 ]
            # the flag + command MUST be passed as cstr (.chars) — a bare '-c' literal reaches
            # execl as an Au string object, not char*, so bash reads garbage and drops into an
            # idle interactive shell (no command runs). same pattern as ConsoleSession.start.
            dashc : string '-c'
            execl[ '/bin/bash', 'bash', dashc.chars, cmd.chars, null ]
            _exit[ 1 ]
        el [ pid > 0 ]
            fw.pid = pid
            fw.fd  = fd
            fcntl[ fd, F_SETFL, O_NONBLOCK ]

    # resolve an open .ag file to the MAIN file of the module it belongs to. silver
    # keeps a module at <dir>/<dir>.ag with sibling .ag files as extensions, so the
    # module main is <dir>/<dirname>.ag — building it colors every file in the module
    # (extension files can't build standalone). a loose .ag with no match builds itself.
    func fmt_main [ f: path ] -> path
        dir  : path f.parent_dir[]
        modn : string dir.filename[]
        m    : path '{dir}/{modn}.ag'
        if [ m.exists[] ] return m
        return f

    func fmt_start [ f: path ]
        if [ !f ] return
        if [ !startup_path ] startup_path = path.path_startup[]
        if [ !fmt_watch ] fmt_watch = map FmtWatch [string] []
        k : string '{f}'
        if [ fmt_watch[ k ] ] return
        # module stem = filename without .ag — silver writes the syntax cache to
        # <install>/syntax/<stem>.f whether given the name or the .ag file, so read it
        # there. the build is NOT kicked here: fmt_poll loads the existing cache first
        # (instant colors), then kicks it once. priming leads, the compile trails.
        fn   : string f.filename[]
        stem : string fn
        di   : i32 [ fn.rindex_of[ '.' ] ]
        if [ di > 0 ] stem = fn.mid[ 0, di ]
        fw : FmtWatch [ proj: stem, file: f, map: '{startup_path}/install/syntax/{stem}.f', start_us: epoch_micros[] ]
        fmt_watch[ k ] = fw

    # keep the running language servers in sync with the .ag files we have open: we
    # hand silver each open .ag file (no project list — the files ARE the input) and
    # it decides what to do with it. one watcher per open .ag file, keyed by its path;
    # start one for any not yet tracked, drop any whose file is no longer open.
    # a language service runs for what we are VIEWING, not for everything that
    # happens to be open — a tab's mere presence is not a reason to compile it.
    func fmt_sync []
        if [ !fmt_watch ] fmt_watch = map FmtWatch [string] []
        if [ !open_files ] return
        live : map bool [string] []
        for [ i: i32 0, i < editor_slots.count, i += 1 ]
            slot : i32 [ editor_slots[i] ]
            if [ slot < 0 || slot >= open_files.count ] continue
            f : path open_files[slot]
            if [ !f ] continue
            fn : string f.filename[]
            if [ fn.count < 3 ] continue
            if [ fn.mid[ fn.count - 3, 3 ].compare[ '.ag' ] != 0 ] continue
            # resolve to the module's MAIN file so extension files build via their
            # parent (they can't build standalone) and siblings share one watcher.
            main : path fmt_main[ f ]
            k : string '{main}'
            live[k] = true
            if [ !fmt_watch[ k ] ] fmt_start[ main ]
        stale : array string []
        for [ fw: FmtWatch, k: string ] in fmt_watch
            if [ !live[ k ] ] stale += k
        for [ i: i32 0, i < stale.count, i += 1 ]
            fmt_stop[ stale[i] ]

    # drain each watcher's pty (so it can't block) and, when its map's mtime advances, reload
    # it into the editor panes. NOT called from render.
    func fmt_poll []
        if [ !fmt_watch ] return
        # a source file changed (flagged by the watch thread) → regenerate every map.
        # cheap: --format just tokenizes, no build. debounced to one regen per change.
        # per-source: re-run ONLY the watcher whose own .ag actually changed, and
        # only once it has already kicked (a pending first build isn't a change).
        for [ fw: FmtWatch, name: string ] in fmt_watch
            if [ fw.kicked && fw.pid == 0 && fw.file ]
                sm : i64 [ fw.file.modified_time[] ]
                if [ fw.src_mtime > 0 && sm > fw.src_mtime ]
                    fw.src_mtime = sm
                    fmt_spawn[ fw ]
                el [ fw.src_mtime == 0 ]
                    fw.src_mtime = sm
        for [ fw: FmtWatch, name: string ] in fmt_watch
            if [ !fw.announced ]
                puts 'syntax: {name} language service starting...'
                fw.announced = true
            if [ fw.fd >= 0 ]
                dbuf : local i8 [256]
                for [ j: i32 0, j < 64, j += 1 ]
                    nr : i32 [ read[ fw.fd, @dbuf[0], 256 ] ]
                    if [ nr <= 0 ] break
            # reap the one-shot --format child without blocking; when it returns, report
            # its exit code so we KNOW it finished (not just that it started).
            if [ fw.pid > 0 ]
                st : i32 [ 0 ]
                r  : i32 [ waitpid[ fw.pid, @st, WNOHANG ] ]
                if [ r == fw.pid ]
                    code : i32 [ (st >> 8) & 0xFF ]
                    sig  : i32 [ st & 0x7F ]
                    if [ sig != 0 ]
                        puts 'syntax: {name} CRASHED (signal {sig}) — see /tmp/orbiter-fmt-{name}.log'
                    el [ code != 0 ]
                        puts 'syntax: {name} build FAILED (code {code}) — see /tmp/orbiter-fmt-{name}.log'
                        # jump the editor to silver's first emitted error location
                        jump_to_error[ '/tmp/orbiter-fmt-{name}.log' ]
                    el
                        puts 'syntax: {name} language service finished'
                    fw.pid = 0
            if [ fw.map && fw.map.count > 0 ]
                mp : path fw.map
                if [ mp.exists[] ]
                    m : mp.modified_time[]
                    # apply PER EDITOR, every frame, to any pane behind the current map mtime.
                    # this is not a one-shot: a pane created after the map loaded (or a fresh
                    # map) is picked up on the next poll — no race between the load and pane
                    # creation. load_format only runs on a real mismatch, so it's cheap idle.
                    applied : bool [ false ]
                    for [ i: i32 0, i < editor_slots.count, i += 1 ]
                        ed : Editor pane_at[ i ]
                        if [ ed && ed.fmt_mtime < m ]
                            ed.load_format[ fw.map ]
                            ed.fmt_mtime = m
                            # the new colors change the pane's content → invalidate its cached
                            # canvas so it re-renders, and wake the render loop. without this the
                            # coloring only appeared after a hover happened to dirty the pane.
                            ed.pristine = false
                            applied = true
                    if [ applied ]
                        win : ux
                        if [ win ] win.will_animate = true
                        if [ m > fw.mtime ]
                            fw.mtime = m
            # priming: the existing cache (if any) was loaded above — instant colors from the
            # last build. kick the refresh build once, ~1s later, so the colors paint first and
            # the compile doesn't contend with that initial render.
            if [ !fw.kicked && epoch_micros[] - fw.start_us >= 1000000 ]
                fmt_spawn[ fw ]
                fw.kicked = true

    # the current debug callstack (placeholder frames until lldb GetFrames() is
    # wired through the running session).
    func debug_frames [] -> array Frame
        fr : array Frame [ alloc: 8 ]
        fr.push[ Frame [ func_name: 'main',         file: path '{startup_path}/src/silver.c', line: 8870 ] ]
        fr.push[ Frame [ func_name: 'silver_build', file: path '{startup_path}/src/silver.c', line: 5281 ] ]
        fr.push[ Frame [ func_name: 'aether_emit',  file: path '{startup_path}/src/aether.c', line: 8610 ] ]
        return fr

    # the launch command for a console tab: its instance's `run` tokens joined
    # ('' for shells) — what the session must exec whenever it is created.
    func agent_cmd [ sid: string ] -> string
        # instanced ids are '{name}#{seq}' — the template is keyed by name alone
        base : string sid
        hx : i32 [ (sid) ? sid.index_of[ '#' ] : -1 ]
        if [ hx > 0 ] base = sid.mid[ 0, hx ]
        ci : ConsoleInstance (consoles && base) ? consoles[base] : null
        cmd_str : string ''
        if [ ci && ci.run ]
            for [ c: token ] in ci.run
                cmd_str = (cmd_str.count > 0) ? cmd_str + ' ' + c.chars : c.chars
        return cmd_str

    # create-or-get a session in the per-tab map. an agent instance ALWAYS launches
    # with its `run` — a bare shell here is how an agent tab silently degrades.
    func ensure_console [ sid: string ] -> ConsoleSession
        if [ !sid || sid.count == 0 ] return null
        if [ !ed_sessions ] ed_sessions = map ConsoleSession [string] [ ]
        s : ConsoleSession ed_sessions[sid]
        if [ s ] return s
        s = ConsoleSession []
        s.name       = sid
        s.launch_cmd = agent_cmd[ sid ]
        ed_sessions[sid] = s
        s.start[]
        return s

    # type `text` into the first AI agent console (non-shell instance), launching
    # its session on first use. wrapped in bracketed paste so multi-line context
    # lands as ONE prompt block — nothing auto-submits.
    func feed_agent [ text: string ] -> none
        if [ !consoles ] return
        sid : string ''
        for [ ci: ConsoleInstance, cname: string ] in consoles
            if [ sid.count == 0 && ci.kind != 'shell' ]
                sid = cname
        if [ sid.count == 0 ] return
        s : ConsoleSession ensure_console[ sid ]
        if [ !s ] return
        s.send_esc[ '[200~' ]
        s.write_input[ text ]
        s.send_esc[ '[201~' ]

    # the supervised-app agent session (shell mode only)
    func orbit_session [] -> ConsoleSession
        if [ !orbit_sid || orbit_sid.count == 0 ] return null
        if [ !ed_sessions ] return null
        return ed_sessions[orbit_sid]

    # ask the host to relaunch the app (env is the channel); it comes
    # back WINDOWED — orbiter keeps its window and keeps supervising
    public func orbit_relaunch []
        k : string 'SILVER_ISOLATE_RESTART'
        v : string '1'
        setenv[ k.chars, v.chars, 1 ]

    # fold the overlay (attach mode) — the app keeps orbiter running
    public func orbit_close []
        host_post[ 1, i32[ HM.close ], 0, 0, 0 ]

    # compose a message for the agent: the app context prepended exactly
    # once, the frozen screenshot + element tree on every message
    func orbit_send [ body: string ]
        s6 : ConsoleSession orbit_session[]
        if [ !s6 ]
            puts 'orbit_send: NO session'
            return
        m6 : string body
        if [ !orbit_ctx_sent && orbit_ctx && orbit_ctx.count > 0 ]
            orbit_ctx_sent = true
            m6 = ((body && body.count > 0) ? '{orbit_ctx} {body}' : orbit_ctx)
        if [ !m6 || m6.count == 0 ] return
        ss : string ''
        se : getenv[ 'SILVER_ISOLATE_SESSION' ]
        if [ se ] ss = string [ se ]
        shot : path '/tmp/silver-app-{ss}.png'
        tree : path '/tmp/silver-app-{ss}.agi'
        if [ shot.exists[] ] m6 = 'app screenshot: {shot}  {m6}'
        if [ tree.exists[] ] m6 = 'element tree: {tree}  {m6}'
        s6.write_input[ '{m6}\r' ]
        # a second Enter lands shortly after — no-op if the first submitted
        orbit_enter_at = 120

    # HM.dictate from the app: 0 idle, 1 recording, 2 cancel. orbiter owns
    # the mic; the live confirm goes back on ring 1 (button turns blue).
    public func on_host [ mt: i32, wp: i32, lp: i32, xp: i32 ]
        if [ mt != 1 ] return
        s : i32 [ wp ]
        if [ s == orbit_dstate ] return
        puts 'orbiter on_host dictate: {orbit_dstate} -> {s}'
        orbit_dstate = s
        if [ s == 1 ]
            rc : dictation_start[]
            if [ rc == 0 ]
                orbit_cap_on = true
                host_live_set[ 1 ]
        el [ s == 2 ]
            dictation_cancel[]
            orbit_cap_on   = false
            orbit_flushing = false
            host_live_set[ 0 ]
        el
            if [ orbit_cap_on ]
                dictation_stop[]
                orbit_cap_on   = false
                orbit_flushing = true
            host_live_set[ 0 ]

    # feed the whisper gpu encoder from the SCREEN canvas while capturing
    public func draw [ w: Window ]
        if [ w.draw_stage != CanvasType.screen ] return
        if [ orbit_cap_on ] dictation_gpu[ Canvas w.screen ]

    # per-frame shell duties: orphan exit, mic feed, deferred Enter, the
    # crash verdict, spoken markers, and the dictation take submit
    func orbit_frame [ w: Window ]
        # attached and our app is gone → orphan. exit so we stop writing
        # the shared shm frame (a fresh shell owns the live app now).
        if [ attach ]
            if [ orbit_app_pid == 0 ]
                orbit_app_pid = -1
                pe : getenv[ 'SILVER_ISOLATE_APP_PID' ]
                if [ pe ]
                    ps : string [ pe ]
                    orbit_app_pid = i32[ ps.integer_value[] ]
            if [ orbit_app_pid > 0 && host_pid_alive[ orbit_app_pid ] == 0 ] exit[ 0 ]
        # render every frame so the WndProc pump keeps running
        w.will_animate = true
        if [ orbit_cap_on ] dictation_poll[]
        # the app context waits for the agent's first message (see orbit_send);
        # built here, not init — `attach` isn't resolved until the tree is up
        if [ !orbit_ctx ]
            sv : getenv[ 'SILVER' ]
            sroot : string ((sv) ? string [ sv ] : string '{startup_path}')
            vox : string 'every single reply must end with one line of the exact form speak {orbit_oc} one short spoken sentence {orbit_cc} — that line is synthesized aloud to the user; never omit it. the user speaks by voice and their words arrive wrapped user {orbit_oc} like this {orbit_cc}.'
            prm : string 'the app {orbit_app} runs under orbiter. its source is {sroot}/foundry/{orbit_app}/{orbit_app}.ag. when it crashes the report is typed here — investigate and help fix it.'
            if [ attach ]
                prm = 'the user switched to orbiter from the running app {orbit_app}. its source is {sroot}/foundry/{orbit_app}/{orbit_app}.ag — assist with the app live; if it faults, the crash report is typed here.'
            orbit_ctx = '{prm} {vox}'
            orbit_ctx.hold[]
        # the deferred submit Enter (see orbit_send)
        if [ orbit_enter_at > 0 ]
            orbit_enter_at -= 1
            if [ orbit_enter_at == 0 ]
                s7 : ConsoleSession orbit_session[]
                if [ s7 ] s7.write_input[ '\r' ]
        # voice the agent's speak markers, once each (they persist on screen)
        s2 : ConsoleSession orbit_session[]
        if [ s2 ]
            if [ !orbit_spoken ]
                orbit_spoken = array string [ ]
                orbit_spoken.hold[]
            mk : string 'speak {orbit_oc}'
            nl : i32 [ s2.line_count[] ]
            lo : i32 [ (nl > 60) ? nl - 60 : 0 ]
            for [ li: i32 lo, li < nl, li += 1 ]
                ln2 : string s2.line_get[ li ]
                if [ !ln2 || ln2.count == 0 ] continue
                a2 : i32 [ ln2.index_of[ mk ] ]
                if [ a2 < 0 ] continue
                st2  : i32 [ a2 + i32[ mk.count ] ]
                rest : string ln2.mid[ st2, ln2.count - st2 ]
                b2 : i32 [ rest.index_of[ orbit_cc ] ]
                if [ b2 <= 0 ] continue
                ut : string rest.mid[ 0, b2 ]
                if [ !ut || ut.count == 0 ] continue
                # the prompt's own example echoes on screen — never say it
                if [ ut == ' one short spoken sentence ' ] continue
                dup : bool [ false ]
                for [ sp2: string ] in orbit_spoken
                    if [ sp2 == ut ]
                        dup = true
                        break
                if [ dup ] continue
                orbit_spoken.push[ ut ]
                td2 : string '/src/silver/models/kokoro-en'
                if [ tts_init[ td2.chars ] == 0 ]
                    tts_say[ ut.chars, 8, 1.0 ]
        # the take submits when the user STOPS: wind down the final
        # transcription, then the whole session goes over as ONE message
        if [ orbit_flushing ]
            if [ dictation_flush[] ]
                orbit_flushing = false
                dt : dictation_take[]
                if [ dt && dt.count > 0 ]
                    puts 'orbiter: submitting take "{dt}"'
                    orbit_send[ 'user {orbit_oc} {dt} {orbit_cc}' ]
        # type the verdict into the live session, once, when the child dies;
        # a relaunch clears the status → re-arm for the next crash
        st : getenv[ 'SILVER_ISOLATE_STATUS' ]
        if [ st && !orbit_reported ]
            orbit_reported = true
            orbit_send[ 'the app crashed: {st} — investigate.' ]
            td : string '/src/silver/models/kokoro-en'
            if [ tts_init[ td.chars ] == 0 ]
                sp : string 'the app crashed with {st}.'
                tts_say[ sp.chars, 8, 1.0 ]
        el [ !st ]
            orbit_reported = false

    # the console title's context button: ask the live emulator pane for a
    # machine-state dump (focused pane first, else the first resource pane);
    # the emu thread publishes it and the pane_for drain types it into the agent.
    func request_context [] -> none
        done : bool [ false ]
        ed : Editor pane_at[ active_pane ]
        if [ ed && ed.rview ] done = ed.rview.context_request*[]
        for [ i: i32 0, i < editor_slots.count, i += 1 ]
            if [ ! done ]
                ed2 : Editor pane_at[ i ]
                if [ ed2 && ed2.rview ] done = ed2.rview.context_request*[]

    # the console title's screen button: read back the window's composed frame
    # (screen canvas — everything orbiter just presented), write it as a PNG,
    # and return the path. feeding that path to the agent is the same motion
    # as dragging an image into its terminal.
    func snap_window [ w: Window ] -> string
        if [ !w || !w.screen ] return null
        tex : Texture w.screen.color
        if [ !tex ] return null
        sz : i32 [ tex.width * tex.height * 4 ]
        b : Buffer [ vk: tex.vk, size: sz,
            u_dst: true, m_host_visible: true, m_host_coherent: true ]
        b.transfer[ tex ]
        shot : Image [ width: tex.width, height: tex.height, format: Pixel.rgba8 ]
        memcpy[ shot.vdata[], b.mmap[], sz ]
        b.unmap[]
        shot_n += 1
        fn : string '/tmp/orbiter_shot_{getpid[]}_{shot_n}.png'
        shot.png[ path fn ]
        return fn

    # build/run a project node by name: process its deps FIRST (a dep is just
    # another node — same function, recursively), then run this node's build
    # tokens. there is NO silver-vs-other distinction — every node is just its
    # build command(s) (e.g. test4's build is `silver test4`), written into the
    # node's own shell session so it runs in that project's terminal.
    func run_node [ name: string ] -> none
        if [ !projects ] return
        p : Project projects[name]
        if [ !p ] return
        if [ p.deps ]
            for [ d: token ] in p.deps
                run_node[ d.chars ]
        if [ !p.build || p.build.count == 0 ] return
        cmd_str : string ''
        for [ c: token ] in p.build
            cmd_str = (cmd_str.count > 0) ? cmd_str + ' ' + c.chars : c.chars
        cmd : string 'cd "{p.root}" && {cmd_str}'
        # the build runs in this project's own session; a runnable node then launches
        # under our dbg (LLDB SB API), NOT a shell process — its stdout/stderr stream
        # back through dbg's on_stdout/on_stderr callbacks, and stops hit on_break.
        s : ConsoleSession ensure_console[ name ]
        if [ !s ] return
        s.pending = cmd
        has_run : bool [ p.run && p.run.count > 0 ]
        if [ has_run ]
            start_debug[ name ]

    # launch a dbg (LLDB SB-API) session on a project's product. auto_start runs the
    # binary immediately; its callbacks land on the on_* handlers below. NOTE: the
    # build above is async in the shell, so the product must already exist for this
    # launch to be current.
    func start_debug [ name: string ] -> none
        p : Project (projects) ? projects[name] : null
        # the launchable binary: explicit product, else <startup>/install/build/<run>
        # (silver builds an app to install/build/<name>; run carries the binary name).
        loc : path (p) ? p.product : null
        if [ !loc && p && p.run && p.run.count > 0 ]
            rb : string p.run[0].chars
            ps : string '{startup_path}/install/build/{rb}'
            loc = path [ ps.chars ]
        # no project node — an app named alone still debugs its built binary
        if [ !loc ]
            ps2 : string '{startup_path}/install/build/{name}'
            l2  : path [ ps2.chars ]
            if [ l2.exists[] ] loc = l2
        if [ !loc ]
            puts 'start_debug {name}: no binary to launch'
            return
        # the inferior's stdout/stderr drain into this session on render
        ensure_console[ name ]
        puts 'start_debug {name}: launching {loc}'
        if [ !debuggers ] debuggers = map dbg [string] []
        # auto_start:false so breakpoints install into the target BEFORE the inferior
        # runs — otherwise the process would blow past them. then launch.
        d : dbg [ location: loc, target: a, auto_start: false ]
        debuggers[name] = d
        sync_breakpoints[ d ]
        d.start[]

    # install every app-global breakpoint into a dbg session's target. keys are
    # "absolute/source:line" — split on the LAST ':' (linux paths have no ':'), the
    # value is the condition (empty = plain). the for yields value-then-key.
    func sync_breakpoints [ d: dbg ]
        if [ !breakpoints || !d ] return
        for [ cond: string, key: string ] in breakpoints
            idx : i32 [ key.rindex_of[ ':' ] ]
            if [ idx <= 0 ] continue
            bsrc : string key.mid[ 0, idx ]
            blin : i32 [ key.mid[ idx + 1, key.count - idx - 1 ].real_value[] ]
            if [ blin <= 0 ] continue
            d.set_breakpoint[ path [ bsrc ], u32[ blin ], 0 ]

    # dbg callbacks. Au_binding builds the target method name as <self_type>_<name>
    # = dbg_on_stdout/... (self_type is `dbg`, no id), so the handlers carry that
    # dbg_ prefix.
    # inert: the inferior's stdout/stderr are now drained on the main/render thread
    # in on_render (cons.feed_fd off the dbg PTY masters) into the project's own
    # console session — NOT pushed through a dbg io-thread callback (that raced the
    # renderer and printed to orbiter's own stdout). kept only so the binding resolves.
    func dbg_on_stdout [ buf: iobuffer ] -> Au
        return null
    func dbg_on_stderr [ buf: iobuffer ] -> Au
        return null
    func dbg_on_break [ cur: cursor ] -> Au
        if [ !cur ] return null
        puts 'dbg break {cur.source}:{cur.line}'
        apply_break[ cur ]
        return null

    # open the break's source in the first editor pane (pane0 always exists from init),
    # select its line, follow it with the scroll, and read the paused frame's locals.
    # called straight from the dbg break/crash callbacks.
    func apply_break [ cur: cursor ]
        if [ !cur ] return
        src : path cur.source
        ln  : i32  [ cur.line ]
        if [ src ]
            open_in_pane[ src, 0 ]
            ed : Editor pane_at[ 0 ]
            if [ ed ]
                # stop_line drives the white ">" arrow / current-line glow.
                sl : i32 [ (ln > 0) ? ln - 1 : 0 ]
                ed.stop_line = sl
                # the exact stop column → its own marker, separate from the edit
                # selection. silver emits the DWARF column as a 0-based char index.
                ed.stop_col  = i32[ cur.column ]
                # do NOT move the edit caret on a step — only the stop marker moves;
                # scroll to follow the stop line only when it's outside the visible band.
                lh  : f32 [ (ed.lh_cache > 0.0) ? ed.lh_cache : 22.0 ]
                vh  : f32 [ (ed.bounds) ? ed.bounds.h : 600.0 ]
                top : f32 [ f32[sl] * lh ]
                if [ top < ed.scroll.y || top + lh > ed.scroll.y + vh ]
                    ed.scroll.y = top - vh * 0.4
                    if [ ed.scroll.y < 0.0 ] ed.scroll.y = 0.0
                    ed.scroll_target = ed.scroll.y
                # a fresh stop → back into active mode (keyboard drives the debugger).
                ed.edit_armed = false
                ed.pristine  = false
        # we're paused here → read this frame's locals for the Fields panel.
        dv : active_debugger[]
        if [ dv ] debug_vars = dv.read_locals[]
        win : ux
        win.will_animate = true

    # clear the debugger's stop-line marker on every pane (called when the inferior
    # continues, stops, exits or crashes — there's no live execution point anymore).
    func clear_stop_lines []
        for [ i: i32 0, i < editor_slots.count, i += 1 ]
            ed : Editor pane_at[ i ]
            if [ ed ]
                ed.stop_line  = -1
                ed.stop_col   = -1
                # session ended → re-lock editing so the next run starts in the
                # active (keyboard-drives-debugger) state, not left armed for edit.
                ed.edit_armed = false
                ed.pristine   = false
        # no live frame anymore → drop the inspected variables.
        debug_vars = null
    func dbg_on_exit [ e: exited ] -> Au
        clear_stop_lines[]
        es : ConsoleSession (ed_sessions) ? ed_sessions[ active_target ] : null
        de : dbg (debuggers) ? debuggers[ active_target ] : null
        if [ es ]
            # pull the final flush (fds still open until stop/dealloc) before the notice
            if [ de ]
                es.feed_fd[ de.fifo_fd_out ]
                es.feed_fd[ de.fifo_fd_err ]
            code : e->code
            es.print_text[ '\r\n[process exited, code {code}]\r\n' ]
            win : ux
            if [ win ] win.will_animate = true
        return null
    func dbg_on_crash [ cur: cursor ] -> Au
        if [ cur ] puts 'dbg crash {cur.source}:{cur.line}'
        # a crash IS an execution point — open + mark it the same as a break stop.
        if [ cur ] apply_break[ cur ]
        return null

    # map a path to its slot in open_files, registering it if not yet present.
    # (renamed from file_index — that name is the search-index prop; silver is
    # like swift, a func can't shadow a prop.)
    func file_slot [ p: path ] -> i32
        for [ i: i32 0, i < open_files.count, i += 1 ]
            if [ open_files[i] == p ] return i
        open_files.push[ p ]
        return open_files.count - 1

    # is this file pinned in the (unified) dock?
    func is_docked [ p: path ] -> bool
        if [ !p || !docked ] return false
        for [ i: i32 0, i < docked.count, i += 1 ]
            if [ docked[i] == p ] return true
        return false

    # toggle a file's pin in the dock (persist + refresh the list so it moves to/from
    # the pinned section at the top).
    func toggle_dock [ p: path ]
        if [ !p ] return
        if [ !docked ] docked = array path []
        found : bool false
        for [ i: i32 0, i < docked.count, i += 1 ]
            if [ docked[i] == p ]
                docked.remove[ i ]
                found = true
                break
        if [ !found ] docked.push[ p ]
        save_session[]
        run_search[]

    # build the editor-title nav (git + dock toggle) for a pane. the git button
    # the tab controls are split: '-' (undock/remove) on the left of the title,
    # always present with a file open; '+' (dock/add) on the right with magnify/menu.
    # the live debug session for the active target, or null if none is running.
    func active_debugger [] -> dbg
        if [ !debuggers ] return null
        d : dbg debuggers[ active_target ]
        # `active` = session alive (paused or running); `running` is false while
        # paused, so it would wrongly unlock the editor exactly at a breakpoint.
        return (d && d.active) ? d : null

    func title_nav [ p: path, grp: array path, has_diff: bool, win: Window, dbg_locked: bool, dbg_open: bool, menu_open: bool, is_resource: bool, rv: ResourceView, fb_on: bool, tfoc: bool ] -> Elements
        hasfile  : bool [ p && p.exists[] ]
        els : Elements []
        # left title chips, in order: [x] always leads when engaged;
        # [f] alternates find-in-file(s) vs the filename finder.
        browse_open : bool [ menu_open && nav_showing ]
        engaged : bool [ browse_open || fb_on || tfoc ]
        if [ engaged ]
            els['title_close'] = LButton [ icon: 'close', manual_mode: true ]
        if [ engaged && !is_resource ]
            els['magnify'] = LButton [ icon: 'magnify', selected: fb_on, manual_mode: true ]

        # the right-flow run, in one unbroken block. a right-flow chip only chains
        # off a RIGHT-anchored previous sibling — a left-anchored one between them
        # restarts the run at the container edge, stacking chips on top of each
        # other. so every right-flowing chip is emitted here, contiguously.
        # the tab's own buttons lead: same slot on every pane, whatever it holds.
        # actions, not toggles — without manual_mode an Option latches its own
        # selected state on click and stays lit (NavButton paints that orange).
        if [ editor_slots.count < 4 ]
            els['dock'] = RButton [ icon: 'expand2', manual_mode: true ]
        if [ editor_slots.count > 1 ]
            els['undock'] = RButton [ icon: 'collapse2', manual_mode: true ]

        # pins/grid toggles belong to the browse index only — right after the
        # tab buttons, so the folder sits left of the +/- pair.
        if [ menu_open && nav_showing && docked && docked.count > 0 ]
            els['pins'] = RButton [ icon: (show_pins) ? 'side_on' : 'side_off', selected: show_pins, manual_mode: true ]
        if [ menu_open && nav_showing ]
            els['grid'] = RButton [ icon: 'files', selected: grid_mode, manual_mode: true ]

        # the active (non-edit) state indicator: shown while the pane is debug-locked;
        # clicking it re-arms editing. the keyboard otherwise drives the debugger.
        if [ dbg_locked ]
            els['active'] = LabelButton [ label: 'active', manual_mode: true ]

        # then whatever the open view contributes (an emulator's game/assembly/tiles,
        # a console's context/screen).
        if [ rv ]
            vel : Elements rv.title_elements*[]
            if [ vel ]
                for [ ve: element, vk: string ] in vel
                    els[vk] = ve

        if [ fb_on ]
            els['replace_btn'] = LabelButton [ label: 'Replace', selected: replace_open, manual_mode: true ]
            if [ replace_open ]
                els['replace'] = ReplaceField [ label: 'replace', edit: replace_text, focusable: true ]
                els['replace_all_action'] = LabelButton [ label: 'All', manual_mode: true ]
        # pattern joins the right flow AFTER the chips → sits left of them all
        if [ fb_on ]
            els['pattern'] = PatternField [
                label: (hasfile) ? p.filename[] : 'Files',
                edit: (find_in_file) ? '' : pattern_text,
                selected: !find_in_file,
                focusable: !find_in_file,
                read_only: find_in_file,
                elements: [
                    'find_in_files': RButton [ icon: 'find_in_files', selected: !find_in_file, manual_mode: true ]
                ]
            ]
            els['find'] = FindField [ label: 'Find', edit: findbar_text, focusable: true ]
        return els


    # build the docked-tab strip for a group: one tab per docked file, the
    # active file selected. ids are prefix+index so the click handler can map
    # back to the path. rendered inline in the editor title when not editing.
    func dock_tabs [ grp: array path, prefix: string, active: path, win: Window ] -> Elements
        els : Elements []
        for [ i: i32 0, i < grp.count, i += 1 ]
            p   : path   grp[i]
            tid : string '{prefix}{i}'
            els[tid] = Option [ label: p.filename[], selected: active && p == active ]
        return els

    # restart the index build; if one is running, cancel + mark dirty
    func start_index []
        if [ index_building ]
            index_cancel = true
            index_dirty  = true
            return
        file_index   = list string []
        index_dirty  = false
        dirs : array path []
        for [ d: path ] in search_dirs
            if [ d ] dirs.push[ d ]
        if [ dirs.count == 0 ] return
        index_cancel   = false
        index_building = true
        work : array [ ]
        work.push[ dirs ]
        index_task     = async [ target: a, work_fn: @index_work, work: work ]

    # worker thread: walk the search roots, filling file_index under lock
    func index_work [ dirs: array path ] -> none
        stack : array path []
        repos : array path []
        for [ r: path ] in dirs
            stack.push[ r ]
        cap : i32 [ (max_search > 0) ? max_search : 400000 ]
        while [ !index_cancel ]
            if [ stack.count == 0 ]
                # main tree exhausted → fold in the deferred repositories
                if [ repos.count == 0 ] break
                for [ rp: path ] in repos
                    stack.push[ rp ]
                repos = array path []
            n : i32 [ stack.count - 1 ]
            # hold across remove[]: remove drops the array's ref, and `d` is a
            # borrow — without the hold the path frees before d.ls[] runs.
            d : path hold[ stack[n] ]
            stack.remove[ n ]
            entries : array [ d.ls[ null, false ] ]
            drop[ d ]
            if [ entries ]
                found : array path []
                for [ i: i32 0, i < entries.count, i += 1 ]
                    e : path entries[i]
                    if [ e.is_dir[] ]
                        # skip vendored deps and git internals — checkout alone is
                        # ~235k files and buries foundry/src under the index cap.
                        dn : string e.filename[]
                        if [ dn == 'checkout' || dn == '.git' ]
                            continue
                        # a nested git repo (has .git): index it deferred to the end when
                        # search_external is on, otherwise skip it entirely.
                        gp : path '{e}/.git'
                        if [ gp.exists[] ]
                            if [ search_external ]
                                repos.push[ e ]
                        el
                            stack.push[ e ]
                    el
                        found.push[ e ]
                if [ found.count > 0 ]
                    index_lock.lock[]
                    for [ f: path ] in found
                        file_index.push[ f ]
                    over : bool [ file_index.count >= cap ]
                    index_lock.unlock[]
                    if [ over ] break
        index_lock.lock[]
        index_building = false
        index_lock.unlock[]

    # spawn one inotify watch per search dir. the watch runs on its own pthread
    # (Au.watch) and fires on_index_change when anything under the dir changes.
    func start_watching []
        for [ d: path ] in search_dirs
            iw : watch [ res: d, callback: @on_index_change, argument: a ]
            iw.start[]
            index_watches += iw

    # re-root the file index + its inotify watch onto the SELECTED project's root, so
    # the search service stays in sync with the active project. called on tab change.
    func reroot_index []
        r : path project_root[]
        if [ !r ] return
        # already rooted there → nothing to do
        if [ search_dirs && search_dirs.count == 1 ]
            s0 : string '{search_dirs[0]}'
            rs : string '{r}'
            if [ s0.compare[ rs ] == 0 ] return
        # stop the old root's watch, then re-point everything at the new root
        if [ index_watches ]
            for [ iw: watch ] in index_watches
                iw.pause[]
        index_watches = array watch []
        search_dirs   = array path []
        search_dirs  += r
        start_index[]
        start_watching[]
        # if a query is live, the just-cleared index is empty — re-run the search once
        # the new project's index has rebuilt (render re-runs it when the build ends).
        if [ find_text && find_text.count > 0 ] index_research = true

    # called FROM the watch thread — keep it trivial. just flag the index stale;
    # the rebuild happens on the main thread in the next run_search.
    func on_index_change [ changed: Au ] -> none
        # ONLY the file index. this fires for every write under the search dirs
        # — including the build outputs the language service itself produces —
        # so driving fmt from here is a feedback loop: build writes, watch fires,
        # every watcher respawns, writes again. fmt_poll checks source mtimes.
        index_dirty = true

    # reload safety: each watch thread holds a raw callback (on_index_change) into
    # THIS module's code. before the .so unloads they must be stopped, else a file
    # event after dlclose fires a dangling pointer (crash in watch_runner). pause[]
    # joins each thread synchronously, independent of refcount/auto_free timing.
    public func on_unload [ ]
        # a live reload dlcloses this module — a debug session left running would
        # orphan its lldb inferior AND leave stale vtables on the dbg objects. stop
        # and drop them all here while vtables are still valid (start_debug recreates
        # the map lazily after the reload).
        if [ debuggers ]
            for [ d: dbg, name: string ] in debuggers
                if [ d && d.active ] d.stop[]
            debuggers = null
        if [ index_watches ]
            for [ iw: watch ] in index_watches
                iw.pause[ ]
        # index worker holds a raw work_fn into this module too —
        # cancel it and join (drop) before the .so unloads
        index_cancel = true
        index_task   = null
        super.on_unload[ ]

    # index_search is the SERVICE: filter the cached file_index by `query` and RETURN
    # the ranked matches. it owns no display state and touches no shared query field,
    # so the editor finder and the FileList can each call it with their own query.
    func index_search [ query: string ] -> list string
        out : list string []
        # if a change is pending and we're idle, restart the incremental build; this
        # just filters what's there (instant) — never walks the tree on a keystroke.
        if [ index_dirty && !index_building ]
            start_index[]
        # rank by right-distance: how far the right-most occurrence sits from the END
        # of the path. 0 = match at the very end (most relevant). clamp into last tier.
        tiers   : i32 [ 32 ]
        matches : array string []
        dists   : array i32 []
        if [ query && query.count > 0 ]
            ql : i32 [ query.count ]
            index_lock.lock[]
            for [ s: string ] in file_index
                ridx : i32 [ s.rindex_of[ query ] ]
                if [ ridx >= 0 ]
                    d : i32 [ s.count - (ridx + ql) ]
                    if [ d > tiers ] d = tiers
                    matches.push[ s ]
                    dists.push[ d ]
                    if [ matches.count >= 500 ] break
            index_lock.unlock[]
            for [ d: i32 0, d <= tiers, d += 1 ]
                for [ i: i32 0, i < matches.count, i += 1 ]
                    if [ dists[i] == d ]
                        out.push[ matches[i] ]
        return out

    # find-in-files: build find_hits from findbar_text, scoped by find_in_file
    # (current file) vs Files (file_index filtered by pattern_text). each matching
    # file gets a header row then one row per matched source line.
    func run_find_in_files []
        find_hits = array FindHit []
        q : string findbar_text
        find_last_query = q
        # snapshot the scope this run used, so a scope change (e.g. clearing **.ag back to
        # this file) makes the next Enter a fresh search rather than stepping stale results.
        find_last_scope = (pattern_text) ? pattern_text : ''
        if [ !q || q.count == 0 ]
            find_showing = false
            return
        a_slot : i32 [ (active_pane >= 0 && active_pane < editor_slots.count) ? editor_slots[active_pane] : -1 ]
        p : path (a_slot >= 0 && a_slot < open_files.count) ? open_files[a_slot] : null
        # the find_in_files toggle drives it: lit (find_in_file) → search THIS file; off →
        # walk the foundry tree (the glob in pattern_text still filters which files).
        scan_current : bool [ find_in_file && p ]
        if [ scan_current ]
            # in-file = Notepad-style: the editor stays AS-IS (no filtered list) and the
            # matches highlight in place via find_query (live, per keystroke). so there's no
            # hits view to show — leave find_showing off and let the highlight do the work.
            find_showing = false
            return
        # Files mode (or In-File with no open file): walk the foundry tree and render the
        # filtered occurrence list.
        root : path '{startup_path}/foundry'
        find_scanned = 0
        walk_find[ root, q ]
        if [ find_hits.count == 0 ]
            find_hits.push[ FindHit [ is_header: true, text: 'No results in {find_scanned} files', dir: 'within foundry/', file: null ] ]
            find_hits.push[ FindHit [ is_header: true, text: '', file: null ] ]
        find_showing = true
        # a fresh result set → clear the results-pane selection so the next Enter
        # ("next match") starts at the first occurrence, not wherever it last sat.
        sp : string search_pane[]
        for [ i: i32 0, i < editor_slots.count, i += 1 ]
            e : Editor pane_at[ i ]
            if [ e && sp == 'pane{i}' ]
                e.sel_line    = -1
                e.anchor_line = -1

    # advance the selection to the next match row in the results pane (wrapping past
    # the file-title headers), and scroll it into view. used when Enter is pressed and
    # the results are already up for the current phrase — step through occurrences.
    func next_match []
        sp : string search_pane[]
        ed : Editor null
        for [ i: i32 0, i < editor_slots.count, i += 1 ]
            e : Editor pane_at[ i ]
            if [ e && sp == 'pane{i}' ] ed = e
        if [ !ed ] ed = pane_at[ 0 ]
        if [ !ed || !find_hits || find_hits.count == 0 ] return
        q  : string findbar_text
        qn : i32 [ q->count ]
        if [ qn == 0 ] return
        n  : i32 [ find_hits.count ]
        cl : i32 [ ed.sel_line ]
        cc : i32 [ ed.sel_col ]
        # 1) another occurrence on the CURRENT row, after the active one
        if [ cl >= 0 && cl < n && !find_hits[ cl ].is_header ]
            ln : string find_hits[ cl ].text
            st : i32 [ cc + 1 ]
            if [ st < 0 ] st = 0
            if [ st <= ln.count - qn ]
                rem : string ln.mid[ st, ln.count - st ]
                rel : i32 [ rem.index_of[ q ] ]
                if [ rel >= 0 ]
                    reveal_match[ ed, cl, st + rel ]
                    return
        # 2) otherwise the first occurrence of the next match row (wrapping)
        r : i32 [ cl ]
        for [ step: i32 0, step < n, step += 1 ]
            r = r + 1
            if [ r >= n ] r = 0
            h : FindHit find_hits[ r ]
            if [ h && !h.is_header ]
                ln  : string h.text
                rel : i32 [ ln.index_of[ q ] ]
                if [ rel >= 0 ]
                    reveal_match[ ed, r, rel ]
                    return

    # IN-FILE find (Notepad-style): step the selection to the next occurrence of the find
    # text in the active pane's own file (the editor stays as-is; the active match gets the
    # yellow fill via sel_line/sel_col, the rest stay outlined). searches from just after the
    # current selection, wrapping once.
    func find_file_next []
        sp : string search_pane[]
        ed : Editor null
        for [ i: i32 0, i < editor_slots.count, i += 1 ]
            e : Editor pane_at[ i ]
            if [ e && sp == 'pane{i}' ] ed = e
        if [ !ed ] ed = pane_at[ active_pane ]
        if [ !ed ] return
        q : string findbar_text
        qn : i32 [ q->count ]
        if [ qn == 0 ] return
        n : i32 [ ed.line_count[] ]
        if [ n <= 0 ] return
        sr : i32 [ (ed.sel_line >= 0) ? ed.sel_line : 0 ]
        sc : i32 [ (ed.sel_col  >= 0) ? ed.sel_col  : -1 ]
        for [ step: i32 0, step <= n, step += 1 ]
            row   : i32 [ (sr + step) % n ]
            ln    : string ed.line_get[ row ]
            start : i32 [ (step == 0) ? (sc + 1) : 0 ]
            if [ start < 0 ] start = 0
            if [ start <= ln.count - qn ]
                rem : string ln.mid[ start, ln.count - start ]
                rel : i32 [ rem.index_of[ q ] ]
                if [ rel >= 0 ]
                    reveal_match[ ed, row, start + rel ]
                    return

    # place the caret on a specific match (row + column) and scroll the row into view.
    func reveal_match [ ed: Editor, row: i32, col: i32 ]
        ed.sel_line    = row
        ed.sel_col     = col
        ed.anchor_line = row
        ed.anchor_col  = col
        lh : f32 [ (ed.lh_cache > 0.0) ? ed.lh_cache : 22.0 ]
        # the text is its own element now — its bounds ARE the viewport
        vh : f32 [ (ed.bounds) ? ed.bounds.h : 600.0 ]
        top : f32 [ f32[ row ] * lh ]
        # only scroll when the line is actually cut off (above the top, or its bottom
        # past the viewport) — no margin, so a fully-visible line near the bottom edge
        # doesn't trigger a scroll just because a sliver of the next line shows below it.
        if [ top < ed.scroll.y || top + lh > ed.scroll.y + vh ]
            ed.scroll.y = top - vh * 0.4
            if [ ed.scroll.y < 0.0 ] ed.scroll.y = 0.0
            ed.scroll_target = ed.scroll.y
        # horizontal: default to the line start (base); when the match wouldn't fit
        # from there, scroll right only as far as needed so the match END plus a 4-char
        # pad sits at the right edge — minimal travel, never further than required.
        if [ row >= 0 && row < ed.line_count[] ]
            ln  : string ed.line_get[ row ]
            cw  : f32 [ (ed.cw_cache > 0.0) ? ed.cw_cache : 8.0 ]
            qn  : i32 [ findbar_text->count ]
            mex : f32 [ f32[ ed.vis_col[ ln, col + qn ] ] * cw ]
            vw  : f32 [ ((ed.bounds) ? ed.bounds.w : 800.0) - ed.gutter_w ]
            pad : f32 [ cw * 4.0 ]
            if [ mex + pad > vw ]
                ed.scroll.x = mex + pad - vw
            el
                ed.scroll.x = 0.0
            if [ ed.scroll.x < 0.0 ] ed.scroll.x = 0.0
        ed.pristine = false
        win : ux
        if [ win ] win.will_animate = true

    # glob matcher for the find-in-files pattern, matched against a file's full path:
    #   *   any run of chars except '/'
    #   **  any run including '/' (any directory depth)
    #   ?   any single char except '/'
    # a leading ** absorbs the absolute prefix, so `**/*/a.*` matches
    # <anything>/<one-dir>/a.<ext>. recursive with backtracking on * / **.
    func glob_at [ pat: string, pi0: i32, str: string, si0: i32 ] -> bool
        pi : i32 [ pi0 ]
        si : i32 [ si0 ]
        pn : i32 [ pat.count ]
        sn : i32 [ str.count ]
        while [ pi < pn ]
            pc : i32 [ pat[ pi ] ]
            if [ pc == 42 ]                              # '*'
                if [ pi + 1 < pn && pat[ pi + 1 ] == 42 ]   # '**' — cross '/'
                    np : i32 [ pi + 2 ]
                    if [ np < pn && pat[ np ] == 47 ] np = np + 1
                    for [ k: i32 si, k <= sn, k += 1 ]
                        if [ glob_at[ pat, np, str, k ] ] return true
                    return false
                el                                          # single '*' — stop at '/'
                    np : i32 [ pi + 1 ]
                    for [ k: i32 si, k <= sn, k += 1 ]
                        if [ glob_at[ pat, np, str, k ] ] return true
                        if [ k < sn && str[ k ] == 47 ] return false
                    return false
            el [ pc == 63 ]                             # '?'
                if [ si >= sn || str[ si ] == 47 ] return false
                pi = pi + 1
                si = si + 1
            el
                if [ si >= sn || str[ si ] != pc ] return false
                pi = pi + 1
                si = si + 1
        return si >= sn

    func glob_match [ pat: string, str: string ] -> bool
        return glob_at[ pat, 0, str, 0 ]

    # a glob with no '/' matches the FILENAME ('*.ag'); one with '/'
    # matches the path relative to the launch dir ('foundry/*/x.ag')
    func glob_pass [ e: path ] -> bool
        if [ !pattern_text || pattern_text.count == 0 ] return true
        if [ pattern_text.index_of[ '/' ] < 0 ]
            return glob_match[ pattern_text, e.filename[] ]
        es : string '{e}'
        sp : string '{startup_path}'
        if [ sp.count > 0 && es.index_of[ sp ] == 0 ]
            es = es.mid[ sp.count, es.count - sp.count ]
            if [ es.count > 0 && es[0] == '/' ] es = es.mid[ 1, es.count - 1 ]
        return glob_match[ pattern_text, es ]

    # recursively walk `dir`, scanning each file's content for `q`. when a find pattern
    # is set, only files whose path matches the glob are scanned (dirs are still walked).
    func walk_find [ dir: path, q: string ]
        entries : array [ dir.ls[ null, false ] ]
        if [ !entries ] return
        for [ i: i32 0, i < entries.count, i += 1 ]
            e : path entries[i]
            if [ e.is_dir[] ]
                walk_find[ e, q ]
            el [ glob_pass[ e ] ]
                find_scanned += 1
                scan_file_hits[ e, q ]

    # scan one file for substring `q`, appending a header (once) + a row per
    # matched line (with its 1-based source line number) to find_hits.
    func scan_file_hits [ p: path, q: string ]
        if [ !p || !p.exists[] ] return
        content : string [ p.load[ typeid[string], null ] ]
        if [ !content ] return
        parts : array string [ content.split["\n"] ]
        header_added : bool [ false ]
        for [ i: i32 0, i < parts.count, i += 1 ]
            ln : string parts[i]
            if [ ln.index_of[ q ] >= 0 ]
                if [ !header_added ]
                    # a file title occupies 2 uniform row-slots (so every row stays
                    # one line-height tall and the editor's cursor math is untouched).
                    # the first slot carries the filename (bright) + its directory
                    # (dimmed), drawn spanning both; the second is an empty continuation.
                    fn  : string p.filename[]
                    drs : string '{p.directory[]}'
                    sp  : string '{startup_path}'
                    # show the directory relative to the launch dir when it's under it
                    if [ sp.count > 0 && drs.index_of[ sp ] == 0 ]
                        drs = drs.mid[ sp.count, drs.count - sp.count ]
                        if [ drs.count > 0 && drs[0] == '/' ] drs = drs.mid[ 1, drs.count - 1 ]
                    find_hits.push[ FindHit [ is_header: true, text: fn, dir: drs, file: p ] ]
                    find_hits.push[ FindHit [ is_header: true, text: '', file: p ] ]
                    header_added = true
                find_hits.push[ FindHit [ is_header: false, text: ln, file: p, line: i + 1 ] ]

    # which editor pane the finder targets: the one whose title is focused, else the
    # first pane. (search results render only in this pane; the other keeps its file.)
    func search_pane [] -> string
        win : ux
        if [ win && win.focus && win.focus.id == 'title' ]
            # the title is the TAB's child now (sibling of the content), so the
            # pane id lives on the EditorView above it — not on the Editor.
            for [ e: element* win.focus, e, e = e.parent ]
                if [ e inherits EditorView ] return e.id
        return 'pane0'

    # set one pane to the search list (if it's the active search pane) or restore its
    # own file (the file at `slot`), so the search never leaves a stale copy in a
    # non-search pane.
    func apply_pane [ ed: Editor, is_search: bool, slot: i32 ]
        if [ !ed ] return
        was_search : bool [ ed.finder_list ]
        # entering finder: stash the file's scroll (the browse list reuses scroll.y) and
        # start the list at the top.
        if [ is_search && !was_search ]
            ed.saved_scroll  = ed.scroll.y
            ed.scroll.y      = 0.0
            ed.scroll_target = 0.0
        ed.finder_list = is_search
        if [ is_search ]
            # the focused search pane shows the navigate list (dock + matches)
            ed.lines = find_results
        el [ slot >= 0 && slot < open_files.count ]
            # any other pane with a file open: restore its content
            ed.src = open_files[slot]
            ed.load_file[]
            # leaving finder → put the file back where it was scrolled.
            if [ was_search ]
                ed.scroll.y      = ed.saved_scroll
                ed.scroll_target = ed.saved_scroll
        el
            # a non-search, file-less pane is blank — NOT a copy of the dock
            ed.lines = list string []
        ed.pristine = false

    # maintain the split seams (split1/2/3 = absolute x-positions in units) for `n`
    # panes. on a pane-count change, divide the editor area equally; every frame, pin
    # the last visible pane's trailing seam to the area width so it fills (except at
    # the 4-pane cap, where pane3 is r0 and split3 is a real internal seam), then keep
    # the seams ordered with a minimum pane width so a drag can't invert them.
    func layout_splits [ n: i32 ]
        # editor area width in PANE units. the panes' bound coords resolve in each
        # pane's own fc against the EditorView's width (tick_binds: rel_w =
        # parent.bounds.w, fcv = e.fc), so ew must be computed from the SAME pair —
        # a Group and an Editor don't share fc, so editor_group.fc would be wrong.
        # fall back until the first pane is laid out (self-corrects next frame).
        ew : f32 [ 100.0 ]
        have_ew : bool [ false ]
        # the tab itself carries the fc the seam coords resolve against.
        # elements is null until the first tree is built — self-corrects next frame.
        p0 : element (elements) ? elements['pane0'] : null
        if [ p0 && p0.fc > 0.0 && p0.parent && p0.parent.bounds && p0.parent.bounds.w > 0.0 ]
            ew = p0.parent.bounds.w / p0.fc
            have_ew = true
        # equal division whenever the pane count changes — but only once the editor
        # area width is real. on the count-change frame the new pane isn't laid out
        # yet (ew is the 100.0 fallback), so seating the seams then squashes the last
        # pane (~80/20); defer until have_ew so the division lands on the true width.
        if [ n != last_ecount && have_ew ]
            last_ecount = n
            if [ n >= 2 ] split1 = ew * 1.0 / f32[ n ]
            if [ n >= 3 ] split2 = ew * 2.0 / f32[ n ]
            if [ n >= 4 ] split3 = ew * 3.0 / f32[ n ]
        # pin the trailing seam so the last pane fills the area (cap of 4 uses r0)
        if [ n == 1 ]
            split1 = ew
        el [ n == 2 ]
            split2 = ew
        el [ n == 3 ]
            split3 = ew
        # keep seams ordered with a minimum pane width so a drag can't invert them or
        # push the last pane off the area. clamp internal seams below the trailing wall
        # (right-to-left), then enforce the minimum gaps left-to-right.
        minw : f32 [ 6.0 ]
        if [ n == 4 ]
            if [ split3 > ew - minw ] split3 = ew - minw
            if [ split2 > split3 - minw ] split2 = split3 - minw
            if [ split1 > split2 - minw ] split1 = split2 - minw
        el [ n == 3 ]
            if [ split2 > split3 - minw ] split2 = split3 - minw
            if [ split1 > split2 - minw ] split1 = split2 - minw
        el [ n == 2 ]
            if [ split1 > split2 - minw ] split1 = split2 - minw
        if [ split1 < minw ] split1 = minw
        if [ split2 < split1 + minw ] split2 = split1 + minw
        if [ split3 < split2 + minw ] split3 = split2 + minw
        # DIAG: pane ids + computed bounds from the previous frame, to confirm the
        # per-pane CSS area rules are matching (remove once the split layout is confirmed).
        ##
        puts 'layout_splits n={n} ew={ew} s1={split1} s2={split2} s3={split3}'
        for [ i: i32 0, i < n, i += 1 ]
            pe : Editor pane_at[ i ]
            if [ pe && pe.bounds ]
                puts '  pane{i}: id={pe.id} x={pe.bounds.x} w={pe.bounds.w} fc={pe.fc}'
            el [ pe ]
                puts '  pane{i}: id={pe.id} <no bounds>'
            el
                puts '  pane{i}: <null>'
        ##

    # the split-tiled area for tab index i: tabs share seam vars on touching
    # edges (pane0.r == pane1.l == split1) so each boundary is one draggable seam.
    func pane_area [ pi: i32 ] -> string
        if [ pi == 0 ] return 'l0 t0 l@split1=50|0|0 b0'
        if [ pi == 1 ] return 'l@split1=50|0|0 t0 l@split2=100|0|0 b0'
        if [ pi == 2 ] return 'l@split2=100|0|0 t0 l@split3=150|0|0 b0'
        return 'l@split3=150|0|0 t0 r0 b0'

    # the i-th tab's title. it is the TAB's child (sibling of the content), so it
    # is never reached through the Editor.
    func title_at [ i: i32 ] -> element
        if [ !elements ] return null
        pv : element elements[ 'pane{i}' ]
        if [ !pv || !pv.elements ] return null
        return pv.elements[ 'title' ]

    # the i-th tab's text child. tabs are keyed 'pane0'..'pane3'.
    func pane_at [ i: i32 ] -> Editor
        if [ !elements ] return null
        pv : element elements[ 'pane{i}' ]
        if [ !pv ] return null
        # a pure-console pane's 'text' is a Console — the `to` cast is unchecked,
        # so every `Editor pane_at[i]` would read garbage off it. gate it.
        te : element pv.elements[ 'text' ]
        if [ !te || !(te inherits Editor) ] return null
        return Editor te

    # push a file as a 2-slot title (filename bright + directory dimmed). show_dir
    # adds the dir on the right (relative to the launch dir) — on for the flat filtered
    # search, off in browse mode where every entry shares nav_root.
    func push_file_hit [ p: path, show_dir: bool ]
        fn  : string p.filename[]
        drs : string ''
        # the dock/results combine items across projects, so show the full absolute
        # directory (project root + path) — a launch-relative path would be ambiguous.
        if [ show_dir ]
            drs = '{p.directory[]}'
        find_hits.push[ FindHit [ is_header: true, text: fn, dir: drs, file: p ] ]
        # single-line mode is one slot per entry; the double header adds a continuation.
        if [ !browse_single ]
            find_hits.push[ FindHit [ is_header: true, text: '', file: p ] ]

    # the selected project's root path (browse navigation is bounded to it). the
    # settings/system target is rooted at silver's launch dir.
    # orbiter is rooted at the directory it was launched in — a plain set of edit
    # pages over that tree. no orbiter.agi project/target drives the root anymore.
    func project_root [] -> path
        if [ !startup_path ] startup_path = path.path_startup[]
        return path '{startup_path}'

    # push a directory as a 2-slot title link. `label` lets the up entry read '..'.
    func push_dir_hit [ p: path, label: string ]
        find_hits.push[ FindHit [ is_header: true, is_dir: true, text: label, dir: '', file: p ] ]
        if [ !browse_single ]
            find_hits.push[ FindHit [ is_header: true, is_dir: true, text: '', file: p ] ]

    # the navigate list: with a query it's the ranked file-index search; with no query
    # it BROWSES nav_root (the project root by default) — folders first as links that
    # navigate in, then files. rendered through the find_hits header path; find_results
    # keeps a flat one-path-per-row list for Enter-opens-first.
    func run_search []
        win : ux
        sp     : string search_pane[]
        active : bool [ (find_text && find_text.count > 0) || (win && win.focus && win.focus.id == 'title') ]
        # only (re)build the navigate hits while the list is actually shown — otherwise
        # leave find_hits alone so a live find-in-files result set isn't clobbered.
        if [ active ]
            combined : list string []
            find_hits = array FindHit []
            nav_dock_rows = 0
            if [ find_text && find_text.count > 0 ]
                # FILTERED: ranked index search across the whole project (files only)====.
                matches : list string [ index_search[ find_text ] ]
                for [ i: i32 0, i < matches.count, i += 1 ]
                    p : path '{matches.value_by_index[ i ]}'
                    push_file_hit[ p, true ]
                    combined.push[ '{p}' ]
            el
                # orbiter.agi consoles first — at the very top, above pins.
                if [ consoles ]
                    for [ ci: ConsoleInstance, sk: string ] in consoles
                        # synthetic file satisfies the nav render; click routes on
                        # session. label the continuation slot 'console' so it isn't
                        # a blank row under each session in the 2-slot list.
                        sfp : path 'session:{sk}'
                        find_hits.push[ FindHit [ is_header: true, session: sk, text: sk, dir: 'console', file: sfp ] ]
                        if [ !browse_single ]
                            find_hits.push[ FindHit [ is_header: true, session: sk, text: '', dir: 'console', file: sfp ] ]
                # pinned dock entries first — at the top of the browse list, unless the
                # pins toggle hid them (to maximize the results view).
                if [ docked && show_pins ]
                    for [ i: i32 0, i < docked.count, i += 1 ]
                        dp : path docked[i]
                        if [ dp ]
                            push_file_hit[ dp, true ]
                            combined.push[ '{dp}' ]
                    nav_dock_rows = find_hits.count
                    # single-line mode reserves a blank row between the dock and the
                    # results so the divider sits on its own line (drawn at its y middle).
                    if [ browse_single && nav_dock_rows > 0 ]
                        find_hits.push[ FindHit [ is_header: true, is_spacer: true, text: '' ] ]
                # BROWSE: list nav_root — a parent '..' link, then folders, then files
                if [ !nav_root ] nav_root = target_roots[0]
                if [ nav_root ]
                    # '..' only while we're BELOW the selected project root — never above it
                    pr  : path   project_root[]
                    nrs : string '{nav_root}'
                    prs : string '{pr}'
                    if [ pr && nrs.compare[ prs ] != 0 ]
                        up : path nav_root.directory[]
                        if [ up ]
                            push_dir_hit[ up, '..' ]
                            combined.push[ '{up}' ]
                    entries : array [ nav_root.ls[ null, false ] ]
                    if [ entries ]
                        for [ i: i32 0, i < entries.count, i += 1 ]
                            e : path entries[i]
                            if [ e.is_dir[] ]
                                dn : string e.filename[]
                                if [ dn == '.git' || dn == 'checkout' ] continue
                                push_dir_hit[ e, e.filename[] ]
                                combined.push[ '{e}' ]
                        for [ i: i32 0, i < entries.count, i += 1 ]
                            e : path entries[i]
                            if [ !e.is_dir[] ]
                                push_file_hit[ e, grid_mode ]
                                combined.push[ '{e}' ]
            find_results = combined
        nav_showing = active && find_hits && find_hits.count > 0
        for [ i: i32 0, i < editor_slots.count, i += 1 ]
            pid : 'pane{i}'
            ed  : Editor pane_at[ i ]
            apply_pane[ ed, active && (sp == pid), editor_slots[i] ]

    # if a pane is currently presenting the file listing, keep it presented and
    # re-rooted after a project switch: re-focus that pane's title (so the finder
    # stays active) and rebuild against the new nav_root. called on tab change.
    func rekeep_listing []
        if [ !nav_showing ] return
        sp : string search_pane[]
        for [ i: i32 0, i < editor_slots.count, i += 1 ]
            if [ sp == 'pane{i}' ]
                te : element title_at[ i ]
                if [ te ] te.set_focus[]
        run_search[]

    func open_file [ p: path ]
        open_in_pane[ p, active_pane ]

    # open a file into a specific pane index (used by finder-row clicks)
    func open_in_pane [ p: path, pi: i32 ]
        # leave a nav bookmark at the spot we're jumping FROM, so cmd+left returns here
        # after a finder/result open. (the destination is preserved by nav_walk's save_top.)
        if [ pi >= 0 && pi < editor_slots.count && pi < nav_panes.count ]
            cur : Editor pane_at[ pi ]
            if [ cur && cur.src ]
                nav_panes[ pi ].record[ pi, '{cur.src.absolute[]}', cur.sel_line, cur.sel_col, cur.scroll.y ]
        idx : i32 [ file_slot[ p ] ]
        if [ pi >= 0 && pi < editor_slots.count ]
            editor_slots[pi] = idx
            # opening a FILE here → this pane is no longer a console session
            if [ pi < pane_console.count ] pane_console[pi] = ''
            active_pane = pi
        active_idx = idx
        exit_finder[]
        # the open-tab set changed → persist this workspace's session.
        save_session[]

    # a Console link click (path:line:col) — open in editor pane 0 and reveal.
    public func open_at [ fp: path, lno: i32, col: i32 ] -> bool
        open_in_pane[ fp, 0 ]
        ed : Editor pane_at[ 0 ]
        if [ ed ]
            sl : i32 [ (lno > 0) ? lno - 1 : 0 ]
            ed.sel_line = sl
            ed.sel_col  = col
            # collapse the selection onto the caret — without resetting the anchor the
            # editor draws a range from the previous anchor to this new caret.
            ed.anchor_line = sl
            ed.anchor_col  = col
            lh  : f32 [ (ed.lh_cache > 0.0) ? ed.lh_cache : 22.0 ]
            vh  : f32 [ (ed.bounds) ? ed.bounds.h : 600.0 ]
            top : f32 [ f32[ sl ] * lh ]
            if [ top < ed.scroll.y || top + lh > ed.scroll.y + vh ]
                ed.scroll.y = top - vh * 0.4
                if [ ed.scroll.y < 0.0 ] ed.scroll.y = 0.0
                # pin the animation target too — otherwise the scroll animator lerps
                # scroll.y back to the stale scroll_target (the old caret location).
                ed.scroll_target = ed.scroll.y
            ed.pristine = false
        return true

    # open a file into a pane AND jump to a specific 1-based line — used by a find
    # result double-click. closes the find bar/results, then selects + reveals the line
    # (same reveal math as the ':<n>' goto and the debugger break).
    # scan silver's build log for its first `<file>.ag:<line>:<col>` error and
    # open that file at the line — the next thing to fix, shown in-editor
    func jump_to_error [ logpath: string ]
        lp : path '{logpath}'
        if [ !lp.exists[] ] return
        content : string lp.load[ typeid[string], null ]
        if [ !content || content.count == 0 ] return
        ai : i32 [ content.index_of[ '.ag:' ] ]
        if [ ai < 0 ] return
        # walk back to the path start (stop at space/newline/escape/paren/bracket)
        ps : i32 [ ai ]
        while [ ps > 0 ]
            c : i32 [ (i32 content.chars[ ps - 1 ]) & 255 ]
            if [ c == 32 || c == 10 || c == 13 || c == 27 || c == 40 || c == 41 || c == 91 ] break
            ps -= 1
        fp : string content.mid[ ps, ai + 3 - ps ]
        # line digits after '.ag:'
        li : i32 [ ai + 4 ]
        ls : ''
        while [ li < content.count ]
            c : i32 [ (i32 content.chars[ li ]) & 255 ]
            if [ c < 48 || c > 57 ] break
            ls = '{ls}{content.mid[ li, 1 ]}'
            li += 1
        if [ ls.count == 0 ] return
        ln : i32 [ atoi[ ls.chars ] ]
        err_file = path '{fp}'
        err_file.hold[]
        err_line = ln
        open_at_line[ err_file, active_pane, ln ]

    # ctrl/cmd+E and the console error pill: re-open the last build error
    func goto_error []
        if [ !err_file || err_line <= 0 ] return
        open_at_line[ err_file, active_pane, err_line ]

    func open_at_line [ p: path, pi: i32, to_line: i32 ]
        findbar_open = false
        find_showing = false
        open_in_pane[ p, pi ]
        ed : Editor pane_at[ pi ]
        if [ !ed ] return
        sl : i32 [ (to_line > 0) ? to_line - 1 : 0 ]
        ed.sel_line    = sl
        ed.sel_col     = 0
        ed.anchor_line = sl
        ed.anchor_col  = 0
        lh : f32 [ (ed.lh_cache > 0.0) ? ed.lh_cache : 22.0 ]
        vh : f32 [ (ed.bounds) ? ed.bounds.h : 600.0 ]
        tp : f32 [ f32[ sl ] * lh ]
        if [ tp < ed.scroll.y || tp + lh > ed.scroll.y + vh ]
            ed.scroll.y      = tp - vh * 0.4
            if [ ed.scroll.y < 0.0 ] ed.scroll.y = 0.0
            ed.scroll_target = ed.scroll.y
        # this IS the intended position — keep the finder-restore from undoing it.
        ed.saved_scroll = ed.scroll.y
        ed.pristine = false

    # opening the bar / moving focus changes a CSS state (:expanded, :focused) and the
    # finder transition — none of which paint until the next input event. force a restyle
    # + an animate frame so the change shows immediately instead of stalling.
    func force_update []
        win : ux
        if [ win ]
            win.restyle      = true
            win.will_animate = true

    # fully leave any find/finder state back to plain editing: close the find bar, hide
    # results, drop the typed query, and release focus from WHATEVER finder field holds it
    # (findbar rows or the title) — exit_finder alone only releases the title, which is how
    # we kept trapping ourselves. esc routes here from anywhere.
    func exit_find_mode []
        findbar_open = false
        find_showing = false
        find_text    = ''
        find_results = list string []
        win : ux
        if [ win && win.focus ]
            win.focus.edit = ''
            win.release_focus[ win.focus ]
        force_update[]

    # ctrl/cmd+F: open the find-in-files bar on the active pane and focus its Find input.
    func open_find []
        findbar_open = true
        findbar_pane = 'pane{active_pane}'
        ed : Editor pane_at[ active_pane ]
        # pre-fill Find with the editor's current selection (first line), Notepad-style — so
        # selecting a word/phrase then Ctrl+F searches it immediately.
        if [ ed ]
            sel : ed.selected_text[]
            if [ sel && sel.count > 0 ]
                nl : i32 [ sel.index_of[ '\n' ] ]
                findbar_text = (nl >= 0) ? sel.mid[ 0, nl ] : sel
        te : element title_at[ active_pane ]
        if [ !te ] return
        fe : element te.elements['find']
        if [ fe ]
            # a focused field shows its OWN edit buffer (the binding doesn't re-sync into a
            # focused field), so mirror the query in directly + drop the caret at the end.
            fe.edit       = findbar_text
            fe.sel_col    = findbar_text->count
            fe.anchor_col = fe.sel_col
            fe.set_focus[]
        force_update[]

    # ctrl/cmd+G: focus the active pane's title — the editor file-index / browse search.
    func focus_finder []
        te : element title_at[ active_pane ]
        if [ te ] te.set_focus[]
        force_update[]

    # leave finder/edit mode: clear the typed query and drop focus from the
    # editor title so it returns to showing the (centered) filename, not an
    # editable field.
    func exit_finder []
        find_text    = ''
        find_results = list string []
        win : ux
        if [ !win ] return
        if [ win.focus && win.focus.id == 'title' ]
            # clear the live edit buffer too — release_focus only drops focus, so without
            # this the typed text (e.g. ':5') lingers in the title after we navigate.
            win.focus.edit = ''
            win.release_focus[ win.focus ]

    func set_active [ idx: i32 ]
        active_idx = idx

    func sync_tabs []
        win : ux
        tb  : element win.root.elements['toolbar']
        if [ !tb ] return
        nav : element tb.elements['source_nav']
        if [ !nav ] return
        # project tabs select by active_target (keys are the project names)
        for [ i: i32 0, i < target_names.count, i += 1 ]
            name : string target_names[i]
            op   : Option nav.elements[name]
            if [ op ] op.selected = active_target == name && active_panel != 'config'
        sys : Option nav.elements['system']
        if [ sys ] sys.selected = active_target == 'system' && active_panel != 'config'
        cfg : Option nav.elements['config']
        if [ cfg ] cfg.selected = active_panel == 'config'
        win.restyle = true

    func sync_active []
        win : ux
        if [ win ] win.restyle = true

    public func pad[ n:i32 ] -> string
        str : local char[256]
        sprintf[str, "%04i", n]
        return str

    # live inspector: trinity hands us {file,line} hits for a cmd-clicked element — the
    # matching CSS blocks (cmd+click) or the element's declaration site (cmd+shift+click,
    # element_mode). either way, open the source so orbiter inspects its own UI.
    public func on_inspect [ hits: array StyleHit ]
        if [ !hits || hits.count == 0 ] return
        h : StyleHit hits[ 0 ]
        if [ h.file ] open_at_line[ h.file, active_pane, h.line ]

    func on_press [ ev: Event ]
        if [ !ev.target ] return
        puts 'on_press: target={ev.target.id}'
        for [ e: element* ev.target, e, e = e.parent ]
            if [ e inherits FileList ]
                fl : FileList e
                if [ fl.pending_open ]
                    if [ ev.key.shift && editor_slots.count > 1 ]
                        si : i32 [ (active_pane + 1 < editor_slots.count) ? active_pane + 1 : 0 ]
                        open_in_pane[ fl.pending_open, si ]
                    el
                        open_file[ fl.pending_open ]
                    fl.pending_open = null
                    return
            # a console pane's title bar opens the SAME nav list every pane has:
            # flip the pane back to its editor slot and focus its finder title
            # (the Editor only exists next frame — pending_finder defers it).
            if [ e inherits Console ]
                co  : Console e
                cid : string co.id
                if [ ev.target.id == 'console_filter' && cid && cid.count > 4 && cid.mid[ 0, 4 ].compare[ 'pane' ] == 0 ]
                    ppi : i32 [ cid.mid[ 4, cid.count - 4 ].real_value[] ]
                    if [ ppi < editor_slots.count && ppi < pane_console.count ]
                        pane_console[ppi] = ''
                        active_pane    = ppi
                        pending_finder = ppi
                        ev.no_default  = true
                        force_update[]
                        return
            # clicking a result row while searching opens it (works whether or
            # not a file is already open in the pane — driven by an active query,
            # not by the pane being empty)
            if [ e inherits Editor ]
                ed : Editor e
                # finder active (dock and/or results shown as lines): clicking a code
                # ROW opens it — but a click on the title bar focuses the finder, so
                # exclude it (otherwise focusing the finder immediately opens a row).
                if [ ev.target == e && (was_finder || find_showing) && ed.sel_line >= 0 && ed.sel_line < find_hits.count ]
                    h : FindHit find_hits[ ed.sel_line ]
                    # the dock divider's blank spacer row is not actionable — consume the
                    # click so the popup stays open instead of closing on the default.
                    if [ h && h.is_spacer ]
                        ev.no_default = true
                        return
                    if [ h && h.session && h.session.count > 0 ]
                        # the CLICKED pane becomes that console (not active_pane —
                        # you can pick a session in a pane that isn't active). the
                        # pane index comes from the Editor whose nav was clicked.
                        cpi : i32 [ ed.pane_index ]
                        while [ pane_console.count <= cpi ]
                            pane_console += ''
                        # every pick instances a FRESH session — a shared instance
                        # would give every pane the same view state
                        console_seq += 1
                        sid : string '{h.session}#{console_seq}'
                        pane_console[cpi] = sid
                        active_pane = cpi
                        if [ !ed_sessions ] ed_sessions = map ConsoleSession [string] [ ]
                        ns : ConsoleSession []
                        ns.name = sid
                        ns.launch_cmd = agent_cmd[ sid ]
                        ed_sessions[sid] = ns
                        ns.start[]
                        exit_find_mode[]
                        ev.no_default = true
                        if [ ev.target ] ev.target.ux.restyle = true
                        return
                    if [ h && h.is_dir && h.file ]
                        # a folder link → navigate INTO it: rebuild the browse list rooted
                        # there, with the selection cleared so it starts at the top. KEEP
                        # the finder open by re-focusing the title (the list shows only
                        # while the title is focused) and suppress the default focus
                        # transfer that would otherwise close it.
                        nav_root  = h.file
                        # reset selection + scroll so the new folder starts clean at top.
                        # also clear hover — without a mouse move the stale row index can
                        # point past the new (shorter) list and highlight an empty row.
                        ed.sel_line      = -1
                        ed.anchor_line   = -1
                        ed.hover_line    = -1
                        ed.scroll.y      = 0.0
                        ed.scroll_target = 0.0
                        run_search[]
                        te : element title_at[ ed.pane_index ]
                        if [ te ] te.set_focus[]
                        ev.no_default = true
                        if [ ev.target ] ev.target.ux.restyle = true
                    el [ h && !h.is_header && h.line > 0 && h.file ]
                        # a find-in-files MATCH row: double-click jumps INTO the file at
                        # that line and closes find; a single click just selects/previews
                        # (so you can scan matches without losing the results).
                        pi  : i32 [ ed.pane_index ]
                        # basic double-click event (time+distance gate in the window layer);
                        # plus app logic: it must be the SAME result row.
                        dbl : bool [ ev.mouse.double_click && last_hit_row == ed.sel_line ]
                        last_hit_row = ed.sel_line
                        if [ dbl ] open_at_line[ h.file, pi, h.line ]
                        ev.no_default = true
                    el [ h && h.file ]
                        # browse file link / result filename header → open the file
                        open_in_pane[ h.file, ed.pane_index ]
                    return
        # avatar pane titlebar toggle: hide/show the 3D avatar view
        if [ ev.target.id == 'avatar_hide' ]
            show_avatar = !show_avatar
            # rebuild the tree so the avatar pane re-renders with/without the view.
            if [ ev.target ] ev.target.ux.restyle = true
            return
        # avatar peek: click toggles between the corner peek and the full-size area.
        if [ ev.target.id == 'avatar' ]
            avatar_expanded = !avatar_expanded
            if [ ev.target ] ev.target.ux.restyle = true
            ev.no_default = true
            force_update[]
            return
        # play: build/run the active project node (processes its deps first)
        # deferred live-reload 'reload' chip: tell the host to recompile + hot-swap now.
        if [ ev.target.id == 'reload_ready' ]
            au_live_request_apply[]
            ev.no_default = true
            return
        if [ ev.target.id == 'error' ]
            goto_error[]
            ev.no_default = true
            return
        if [ ev.target.id == 'play' ]
            dl : dbg (debuggers) ? debuggers[ active_target ] : null
            if [ dl && dl.active ]
                dl.stop[]
                clear_stop_lines[]
            el
                pn : Project (projects) ? projects[ active_target ] : null
                if [ pn ]
                    run_node[ active_target ]
                el
                    # no build node — debug the built binary by name alone
                    start_debug[ active_target ]
            ev.no_default = true
            return
        if [ ev.target.id == 'instruments' ]
            show_instruments = !show_instruments
            if [ ev.target ] ev.target.ux.restyle = true
            return
        puts 'on_press: {ev.target.id}'
        for [ i: i32 0, i < open_files.count, i += 1 ]
            key : string 'tab_{i}'
            if [ ev.target.id == key ]
                rel_x    : f32 [ ev.mouse.pos.x - ev.target.bounds.x ]
                in_right : bool [ rel_x > ev.target.bounds.w - 14.0 ]
                active_panel = 'editor'
                # shift / right-edge click opens into a secondary pane; plain click
                # replaces the active pane's file.
                if [ (ev.key.shift || in_right) && editor_slots.count > 1 ]
                    si : i32 [ (active_pane + 1 < editor_slots.count) ? active_pane + 1 : 0 ]
                    editor_slots[si] = i
                    active_pane = si
                el
                    editor_slots[active_pane] = i
                set_active[ i ]
                sync_tabs[]
                return
        
        if [ ev.target.id == 'git' ]
            editor_panel = (editor_panel == ev.target.id) ? 'editor' : ev.target.id
            if [ ev.target ] ev.target.ux.restyle = true
            return
        
        # back: the borderless arrow left of the title text — closes the finder popup.
        if [ ev.target.id == 'back' ]
            exit_finder[]
            ev.no_default = true
            if [ ev.target ] ev.target.ux.restyle = true
            return
        
        # pins: show/hide the pinned dock in the browse list (maximize the results).
        # rekeep_listing re-focuses the search title + re-runs the search, so the index
        # stays open; no_default stops the click from closing the popup.
        if [ ev.target.id == 'pins' ]
            show_pins = !show_pins
            rekeep_listing[]
            ev.no_default = true
            force_update[]
            return
        
        # play/stop: toggle the focused pane between source and a live AppView of
        # its module (the app runs in its own process, sharing frames).
        if [ ev.target.id == 'run' ]
            # the run button sits in the BAND, a sibling of the text — so the
            # walk finds the tab, and the Editor comes from the tab's index.
            for [ e: element* ev.target, e, e = e.parent ]
                if [ e inherits EditorView ]
                    ev2 : EditorView e
                    ed : Editor pane_at[ ev2.pane_index ]
                    if [ ed ] ed.toggle_app_run[]
                    break
            if [ ev.target ] ev.target.ux.restyle = true
            ev.no_default = true
            return

        # grid: list ↔ thumbnail grid for the index (same data, different layout).
        if [ ev.target.id == 'grid' ]
            grid_mode = !grid_mode
            rekeep_listing[]
            ev.no_default = true
            force_update[]
            return
        
        # magnify: toggle the find/replace bar. it belongs to the pane whose magnify
        # was clicked (findbar_pane), so moving focus to the other title doesn't drag
        # the open bar onto it.
        # title [x]: leave the finder/nav entirely (same as Escape)
        if [ ev.target.id == 'title_close' ]
            exit_finder[]
            findbar_open = false
            ev.no_default = true
            if [ ev.target ] ev.target.ux.restyle = true
            force_update[]
            return

        if [ ev.target.id == 'magnify' ]
            findbar_open = !findbar_open
            if [ findbar_open ] pending_findfocus = true
            # the magnify sits in the TITLE, whose parent is the tab — not the Editor
            for [ e: element* ev.target, e, e = e.parent ]
                if [ e inherits EditorView ]
                    findbar_pane = e.id
                    break
            # closing the bar hides the results
            if [ !findbar_open ] find_showing = false
            if [ ev.target ] ev.target.ux.restyle = true
            return
        
        # replace_btn: toggle the replace input + 'All' button into the bar. opening it
        # focuses the input (like open_find does for Find) so it's immediately editable —
        # seed the caret to the end of the live buffer so the cursor shows on first focus.
        if [ ev.target.id == 'replace_btn' ]
            replace_open = !replace_open
            if [ replace_open && ev.target.parent ]
                re : element ev.target.parent.elements['replace']
                if [ re ]
                    re.sel_col    = re.edit->count
                    re.anchor_col = re.sel_col
                    re.set_focus[]
            if [ ev.target ] ev.target.ux.restyle = true
            ev.no_default = true
            force_update[]
            return
        
        # close_find: the X inside the scope field — closes the find/replace bar.
        if [ ev.target.id == 'close_find' ]
            findbar_open = false
            find_showing = false
            if [ ev.target ] ev.target.ux.restyle = true
            ev.no_default = true
            force_update[]
            return
        
        # replace input: a plain editable element isn't reliably focused by the default
        # focusable path here, so focus it explicitly on click (seed the caret to the end).
        if [ ev.target.id == 'replace' ]
            puts 'replace press: focusable={(ev.target.focusable) ? 1 : 0}'
            ev.target.sel_col    = ev.target.edit->count
            ev.target.anchor_col = ev.target.sel_col
            ev.target.set_focus[]
            force_update[]
            return
        
        # find_in_files: toggle the search scope. lit (the toggle, selected: !find_in_file)
        # = files mode → the scope becomes an editable glob; off = Notepad-style in-file find
        # where the scope is just the static filename. entering files mode focuses the scope
        # so the user can type the pattern right away.
        if [ ev.target.id == 'find_in_files' ]
            find_in_file = !find_in_file
            # the scope keeps TWO separate stores: the live edit buffer (pe.edit, what the
            # field shows) and pattern_text (the persistent glob). apply_args never copies
            # `edit`, so the buffer is set explicitly here when the mode flips.
            pe : element ev.target.parent
            if [ pe ]
                if [ find_in_file ]
                    # back to in-file: clear the buffer so the field shows the static
                    # filename label again; pattern_text is preserved for next time.
                    pe.edit       = ''
                    pe.sel_col    = 0
                    pe.anchor_col = 0
                    pe.release_focus[]
                el
                    # files: load the saved glob into the buffer and focus for editing.
                    pe.edit       = pattern_text
                    pe.sel_col    = pattern_text->count
                    pe.anchor_col = pe.sel_col
                    pe.set_focus[]
            run_find_in_files[]
            ev.no_default = true
            force_update[]
            return
        
        # the scope field (id 'pattern') is now a plain editable — a click just focuses it
        # for typing a glob; no toggle. typing + Enter re-runs the search (on_key).
        # mid action buttons — run find / replace (logic TBD)
        if [ ev.target.id == 'replace_all_action' ]
            return
        
        # + / - manage which editors exist (the editors render from editor_slots):
        # '+' (dock) appends a new empty pane up to the 4-pane cap; '-' (undock)
        # removes the editor whose title the button is on.
        if [ ev.target.id == 'dock' ]
            puts 'on_press: DOCK handler reached'
            if [ editor_slots.count < 4 ]
                editor_slots += -1
                pane_console  += ''
                active_pane = editor_slots.count - 1
            save_session[]
            if [ ev.target ] ev.target.ux.restyle = true
            return
        if [ ev.target.id == 'undock' ]
            puts 'on_press: UNDOCK handler reached'
            # find THIS pane by id (Editor OR Console) — a console pane is not an
            # Editor, so the old `inherits Editor` walk missed it entirely.
            for [ e: element* ev.target, e, e = e.parent ]
                if [ e.id && e.id.count >= 5 && e.id.mid[ 0, 4 ] == 'pane' ]
                    pi : i32 [ e.id.mid[ 4, e.id.count - 4 ].real_value[] ]
                    if [ editor_slots.count > 1 && pi >= 0 && pi < editor_slots.count ]
                        editor_slots.remove[ pi ]
                        if [ pi < pane_console.count ] pane_console.remove[ pi ]
                        if [ active_pane >= editor_slots.count ] active_pane = editor_slots.count - 1
                    break
            #sync_editor[]
            save_session[]
            if [ ev.target ] ev.target.ux.restyle = true
            return
        # console-title buttons: 'context' asks the live emulator pane for a
        # machine dump (typed into the agent when it lands); 'screen' captures
        # the whole orbiter window and hands the agent the PNG path — the same
        # thing dragging an image into its terminal does.
        if [ ev.target.id == 'ctx_copy' ]
            request_context[]
            if [ ev.target ] ev.target.ux.restyle = true
            return
        if [ ev.target.id == 'ctx_shot' ]
            fn : string snap_window[ ev.target.ux ]
            if [ fn ] feed_agent[ fn + ' ' ]
            if [ ev.target ] ev.target.ux.restyle = true
            return
        # the 'active' state button: drop this editor out of debug-lock into edit mode.
        if [ ev.target.id == 'active' ]
            # a title chip: the tab is the ancestor, the Editor is its child
            for [ e: element* ev.target, e, e = e.parent ]
                if [ e inherits EditorView ]
                    av : EditorView e
                    ed : Editor pane_at[ av.pane_index ]
                    if [ ed ] ed.edit_armed = true
                    break
            if [ ev.target ] ev.target.ux.restyle = true
            return
        # clicking a pin (pin{i}) inside an editor opens that docked file
        tid : string ev.target.id
        if [ ev.target.id == 'config' ]
            rel_x    : f32 [ ev.mouse.pos.x - ev.target.bounds.x ]
            in_right : bool [ rel_x > ev.target.bounds.w - 14.0 ]
            if [ ev.key.shift || in_right ]
                config_side = (config_side == 1) ? 0 : 1
            el
                active_panel = 'config'
            sync_tabs[]
            return
        if [ ev.target inherits Option ]
            oid : string ev.target.id
            # switching the project changes the build/run/console target and the browse
            # root — but NOT the open editors. tabs are workspace state, so cycling
            # projects never blends or overrides what's open.
            if [ oid == 'system' ]
                active_target = 'system'
                # settings target browses silver's root (the launch dir, where
                # orbiter.agi lives) — so the file index shows that tree.
                nav_root = path '{startup_path}'
                reroot_index[]
                rekeep_listing[]
                sync_active[]
                save_session[]
                ev.no_default = true
            el
                matched : bool false
                for [ i: i32 0, i < target_names.count, i += 1 ]
                    if [ target_names[i] == oid ]
                        active_target = oid
                        nav_root      = target_roots[i]
                        matched       = true
                if [ !matched ]
                    active_panel = oid
                if [ matched ]
                    reroot_index[]
                    rekeep_listing[]
                    sync_active[]
                    save_session[]
                    ev.no_default = true
            if [ ev.target ] ev.target.ux.restyle = true
            return

    func on_char [ ev: Event ]
        if [ !ev.target ] return
        if [ ev.target.id == 'filter' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                filter_text = filter_text + ev.key.text
                # apply_args doesn't propagate custom public fields per-frame, so set
                # the query straight on the FileList instance and rebuild. the FileList
                # runs its own local substring search over its folder.
                fl : FileList ev.target.parent.elements['files']
                if [ fl ]
                    fl.find_text = filter_text
                    fl.last_find = filter_text
                    fl.build_visible[]
                    fl.pristine  = false
                # a keystroke doesn't set the render gate on its own — request a frame
                # so the FileList repaints with the new results as you type.
                uxw : Window ev.target.ux
                if [ uxw ] uxw.will_animate = true
        # typing into the find/replace bar rows (each its own query)
        if [ ev.target.id == 'find' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                findbar_text = findbar_text + ev.key.text
                ev.target.pristine = false
                uxw : Window ev.target.ux
                if [ uxw ] uxw.will_animate = true
        if [ ev.target.id == 'replace' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                replace_text = replace_text + ev.key.text
                ev.target.pristine = false
                uxw : Window ev.target.ux
                if [ uxw ] uxw.will_animate = true
        if [ ev.target.id == 'pattern' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                pattern_text = pattern_text + ev.key.text
                ev.target.pristine = false
                uxw : Window ev.target.ux
                if [ uxw ] uxw.will_animate = true
        # typing into an editor's title (the finder/magnify control)
        if [ ev.target.id == 'title' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                find_text = find_text + ev.key.text
                ev.target.pristine = false
                run_search[]

    
    func on_key [ ev: Event ]
        if [ !ev.target ] return
        # global shortcuts (work from any focus): ctrl/cmd+F opens find-in-files and
        # focuses the Find input; ctrl/cmd+G focuses the editor index / file search.
        if [ ev.key.state && (ev.key.ctrl || ev.key.meta) ]
            kc : i32 [ i32[ ev.key.unicode ] ]
            if [ kc == 70 ]    # 'F'
                open_find[]
                ev.no_default = true
                return
            if [ kc == 71 ]    # 'G'
                focus_finder[]
                ev.no_default = true
                return
        # global Escape: from anywhere, if any find/finder state is up, drop back to
        # editing (so we never get trapped in the bar / finder regardless of focus).
        if [ ev.key.state && i32[ ev.key.unicode ] == 256 && (findbar_open || find_showing || nav_showing) ]
            exit_find_mode[]
            ev.no_default = true
            return

        if [ ev.target.id == 'filter' ]
            if [ !ev.key.state ] return
            k : i32 [ i32 ev.key.unicode ]
            changed : false
            if [ k == 259 ]    # Key.Backspace
                if [ filter_text && filter_text.count > 0 ]
                    filter_text = filter_text.mid[ 0, filter_text.count - 1 ]
                    changed = true
            el [ k == 256 ]    # Key.Escape
                filter_text = ''
                changed = true
            if [ changed ]
                fl : FileList ev.target.parent.elements['files']
                if [ fl ]
                    fl.find_text = filter_text
                    fl.last_find = filter_text
                    fl.build_visible[]
                    fl.pristine  = false
                uxw : Window ev.target.ux
                if [ uxw ] uxw.will_animate = true

        # find/replace bar rows: backspace trims, escape collapses the bar
        if [ ev.target.id == 'find' || ev.target.id == 'replace' || ev.target.id == 'pattern' ]
            if [ !ev.key.state ] return
            k : i32 [ i32 ev.key.unicode ]
            if [ k == 259 ]    # Key.Backspace
                if [ ev.target.id == 'find' ]
                    if [ findbar_text && findbar_text.count > 0 ]
                        findbar_text = findbar_text.mid[ 0, findbar_text.count - 1 ]
                el [ ev.target.id == 'replace' ]
                    if [ replace_text && replace_text.count > 0 ]
                        replace_text = replace_text.mid[ 0, replace_text.count - 1 ]
                el
                    if [ pattern_text && pattern_text.count > 0 ]
                        pattern_text = pattern_text.mid[ 0, pattern_text.count - 1 ]
            el [ k == 257 ]    # Key.Enter
                in_file : bool [ find_in_file ]
                if [ in_file ]
                    # Notepad-style: Enter steps to the next occurrence in THIS file (the
                    # yellow active-match follows the selection); no filtered list.
                    find_last_query = findbar_text
                    find_last_scope = ''
                    find_file_next[]
                el
                    # files mode: first Enter runs the search; a repeat on the SAME phrase +
                    # scope steps to the next result row. a changed scope is a fresh search.
                    cur_scope  : string [ (pattern_text)    ? pattern_text    : '' ]
                    last_scope : string [ (find_last_scope) ? find_last_scope : '' ]
                    scope_same : bool [ cur_scope.compare[ last_scope ] == 0 ]
                    same : bool [ scope_same && find_showing && find_hits && find_hits.count > 0 && find_last_query && findbar_text && find_last_query.compare[ findbar_text ] == 0 ]
                    if [ same ]
                        next_match[]
                    el
                        run_find_in_files[]
                if [ ev.target.ux ] ev.target.ux.restyle = true
            el [ k == 256 ]    # Key.Escape
                # escape collapses the bar and hides the results
                findbar_open = false
                find_showing = false
                ev.target.ux.restyle = true
            ev.target.pristine = false
            uxw : Window ev.target.ux
            if [ uxw ] uxw.will_animate = true

        # finder title: backspace trims, enter opens the typed file
        if [ ev.target.id == 'title' ]
            if [ !ev.key.state ] return
            k : i32 [ i32 ev.key.unicode ]
            if [ k == 259 ]    # Key.Backspace
                if [ find_text && find_text.count > 0 ]
                    find_text = find_text.mid[ 0, find_text.count - 1 ]
                    ev.target.pristine = false
                    run_search[]
            el [ k == 257 ]    # Key.Enter
                # ':<n>' jumps the current editor to line n; otherwise enter opens the
                # first matching result.
                handled : bool false
                if [ find_text && find_text.count > 1 && find_text[0] == ':' ]
                    num : string find_text.mid[ 1, find_text.count - 1 ]
                    if [ num.is_numeric[] ]
                        ed : Editor pane_at[ active_pane ]
                        if [ ed ]
                            # bookmark where we were before the goto so cmd+left returns.
                            if [ ed.nav && ed.src ]
                                ed.nav.record[ active_pane, '{ed.src.absolute[]}', ed.sel_line, ed.sel_col, ed.scroll.y ]
                            sl : i32 [ i32[ num.integer_value[] ] ]
                            sl = (sl > 0) ? sl - 1 : 0
                            ed.sel_line    = sl
                            ed.sel_col     = 0
                            ed.anchor_line = sl
                            ed.anchor_col  = 0
                            # reveal the line (centered-ish), pinning scroll_target
                            lh : f32 [ (ed.lh_cache > 0.0) ? ed.lh_cache : 22.0 ]
                            vh : f32 [ (ed.bounds) ? ed.bounds.h : 600.0 ]
                            tp : f32 [ f32[ sl ] * lh ]
                            if [ tp < ed.scroll.y || tp + lh > ed.scroll.y + vh ]
                                ed.scroll.y      = tp - vh * 0.4
                                if [ ed.scroll.y < 0.0 ] ed.scroll.y = 0.0
                                ed.scroll_target = ed.scroll.y
                            # the goto IS the intended position — don't let the finder-exit
                            # scroll-restore override it.
                            ed.saved_scroll = ed.scroll.y
                            ed.pristine = false
                        exit_finder[]
                        if [ ev.target.ux ] ev.target.ux.restyle = true
                        handled = true
                if [ !handled && find_results && find_results.count > 0 ]
                    first_s    : string find_results.value_by_index[ 0 ]
                    first_path : path [ first_s.chars ]
                    open_file[ first_path ]
            el [ k == 258 ]    # Key.Tab — toggle single-line / double-header density
                browse_single = !browse_single
                ev.target.pristine = false
                run_search[]
                if [ ev.target.ux ] ev.target.ux.restyle = true
            el [ k == 256 ]    # Key.Escape
                # esc: leave the finder entirely — drop the query AND release focus
                # so the title goes non-editable (as if clicked away); exit_finder
                # clears the query + results and releases title focus, and the finder
                # transition in on_render restores the pane's file.
                exit_finder[]
                ev.target.pristine = false
                if [ ev.target.ux ] ev.target.ux.restyle = true
    
    public func render [] -> Elements
        w : ux

        # supervised shell: crash verdicts, mic, voice — see orbit_frame
        if [ orbit_app ] orbit_frame[ w ]

        # runaway-leak guard: if our RSS passes 20% of physical RAM, quit before
        # the leak thrashes the machine into a solid lock. cheap (/proc read).
        if [ au_mem_fraction[] > 0.20 ]
            puts 'orbiter: memory exceeded 20% of system RAM — quitting '
            exit[ 1 ]

        # a project switch re-rooted the index with a live query — once the rebuild has
        # finished, re-run the search so the results reflect the newly selected project
        # (as if the query box was re-entered against the new index).
        if [ index_research && !index_building ]
            index_research = false
            run_search[]

        # a breakpoint was toggled in an Editor gutter (count changed) → persist.
        bpc : i32 [ breakpoints->count ]
        if [ last_bp_count >= 0 && bpc != last_bp_count ]
            save_session[]
        last_bp_count = bpc
        # a console pane flipped back to its editor last frame (title-bar nav):
        # focus the finder title once the Editor exists so the nav list opens.
        if [ pending_finder >= 0 ]
            fte : element title_at[ pending_finder ]
            if [ fte ]
                fte.set_focus[]
                pending_finder = -1
        # `orbiter <module>` — start its app in-pane once the Editor exists
        if [ pending_run >= 0 ]
            red : Editor pane_at[ pending_run ]
            if [ red ]
                if [ !red.run_view ] red.toggle_app_run[]
                pending_run = -1
        # findbar opened by [f]: its fields mount a frame later — move focus
        # onto the find input so typing lands in findbar_text, not find_text
        if [ pending_findfocus ]
            if [ !findbar_open ]
                pending_findfocus = false
            el [ findbar_pane && findbar_pane.count > 4 ]
                fpi : i32 [ findbar_pane.mid[ 4, findbar_pane.count - 4 ].real_value[] ]
                fte2 : element title_at[ fpi ]
                if [ fte2 && fte2.elements ]
                    ffe : element fte2.elements['find']
                    if [ ffe ]
                        ffe.set_focus[]
                        pending_findfocus = false
        # finder transitions: rebuild the navigate list when the title gains focus
        # (show the dock as lines) or loses it (restore the file), AND when focus
        # moves to a different pane's title (so the results follow to that pane).
        fin_now : bool   [ (w.focus && w.focus.id == 'title') || (find_text && find_text.count > 0) ]
        sp_now  : string search_pane[]
        if [ fin_now != was_finder || sp_now != was_search_pane ]
            run_search[]
        was_finder      = fin_now
        was_search_pane = sp_now
        # poll orbiter.agi once a second; reload projects if its mtime changed.
        now_ms : i64 [ Au.epoch_millis[] ]
        if [ now_ms - settings_check_ms >= 1000 ]
            settings_check_ms = now_ms
            sp : agi_path[]
            mt : i64 [ sp.modified_time[] ]
            if [ mt != settings_mtime ]
                load_settings[]
            # pick up newly opened / closed .ag files, then reload any watcher map
            # whose mtime advanced (i.e. the watcher just iterated).
            fmt_sync[]
            fmt_poll[]

        # dispatch each pane's pending run command (once per AppView). lives here,
        # not in a paint callback: a collapsed bottom console never paints, so a
        # paint-hosted dispatch (the old TermLayer run_line path) never fires.
        for [ pi2: i32 0, pi2 < editor_slots.count, pi2 += 1 ]
            edp : Editor pane_at[ pi2 ]
            if [ !edp || !edp.run_view || !edp.run_view.cmd ] continue
            if [ edp.run_view.dispatched ] continue
            edp.run_view.dispatched = true
            efn : string edp.src.filename[]
            edi : i32 [ efn.index_of[ '.' ] ]
            if [ edi > 0 ] efn = efn.mid[ 0, edi ]
            esid : string 'ed:{efn}'
            if [ !ed_sessions ] ed_sessions = map ConsoleSession [string] [ ]
            es : ConsoleSession ed_sessions[esid]
            if [ !es ]
                es = ConsoleSession []
                es.name = esid
                ed_sessions[esid] = es
            puts 'run: dispatch {esid}: {edp.run_view.cmd}'
            es.launch_cmd = ''
            es.restart[]
            es.pending = edp.run_view.cmd
        # drain the per-editor consoles' shells (build + app output). ed_sessions is
        # the app's own map — no tree walk — and a live pty keeps the frame loop awake
        # so the animated console repaints the output as it streams in.
        if [ ed_sessions ]
            for [ s: ConsoleSession, k: string ] in ed_sessions
                if [ s.pty_fd >= 0 ]
                    w.will_animate = true
                    s.read_output[]
        # debug inferiors don't run in a bash pty — their stdout/stderr come back on
        # the dbg PTY masters. drain them here (main thread) into the matching
        # project's session, so a stepped `puts` lands where its build ran.
        if [ debuggers && ed_sessions ]
            for [ d: dbg, dn: string ] in debuggers
                if [ !d || !d.active ] continue
                ds : ConsoleSession ed_sessions[ dn ]
                if [ !ds ] continue
                w.will_animate = true
                ds.feed_fd[ d.fifo_fd_out ]
                ds.feed_fd[ d.fifo_fd_err ]

        # one tab per split slot, tiled left-to-right between the split seams
        # (split1/2/3, absolute x in units).
        if [ editor_slots.count == 0 ] editor_slots += -1
        ecount : i32 [ editor_slots.count ]
        if [ ecount < 1 ] ecount = 1
        layout_splits[ ecount ]
        sp : string search_pane[]
        # the ed: sessions the nav lists live in ed_sessions (same map the pane's
        # own bottom console uses) — a pure-console pane must use THAT map
        if [ !ed_sessions ] ed_sessions = map ConsoleSession [string] [ ]
        editor_els : Elements []
        for [ i: i32 0, i < editor_slots.count, i += 1 ]
            pid  : 'pane{i}'
            editor_els[pid] = EditorView [ pane_index: i, selected: (sp == pid) ]
            # areas live ON the instances, set only when they change — the Region
            # persists across frames so its seam binds keep their eased motion
            want : pane_area[ i ]
            pin  : element (elements) ? elements[pid] : null
            if [ pin && (i >= pane_area_cur.count || pane_area_cur[i] != want) ]
                while [ pane_area_cur.count <= i ]
                    pane_area_cur += ''
                pane_area_cur[i] = want
                pin.area = Region [ want.chars ]
                pin.area.hold[]
        # the orbiter avatar peeks in the bottom-right corner. the real 3D Avatar still
        # SIGSEGVs (env-texture vk_image_view not ready at bind), so for now this is a plain
        # topmost placeholder element so the spot/size is visible.
        editor_els['avatar'] = Avatar [ expanded: avatar_expanded, topmost: true, hide: true ]

        # supervised shell: the app's live picture-in-picture, lower right.
        # clicking it folds the window back to the app.
        if [ orbit_app && attach ]
            editor_els['orbitapp'] = OrbitApp [ topmost: true, area: Region { r1 b1 w20 h12 } ]

        # the tabs ARE the window — each owns its title, text, toolbar and console.
        return editor_els

    public func on_canvas [ cv: Canvas ]
        super.on_canvas[ cv ]
        cv.sync_fence[ ]