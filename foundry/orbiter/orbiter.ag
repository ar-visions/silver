export 0.8.8

import vec
import img
import gltf
import trinity

import <stdio.h>
    -lm
import <stdlib.h>
import Earth
import Avatar
import Editor
import Console
import FileList

Control DebugPanel

trinity orbiter
    func init []
        width  = 1888
        height = 888
        background = 'Background'
    
    public func on_render [ w: Window ] -> Elements
        return Elements [
            ##
            "toolbar":  Toolbar [],
            "right":    Toolbar [
                elements: Elements [
                    "files": FileList [],
                    "debug": DebugPanel []
                ]
            ],
            "editor-group": Group [
                elements: Elements [
                    "title":   element [ label: 'silver.c' ]
                    "editor":  Editor [ src: path '/src/silver/src/silver.c' ]
                ]
            ],
            "console": Console [],
            ##
            "avatar": Avatar []
        ]

    public func on_canvas [ cv: Canvas ]
        super.on_canvas[ cv ]
        cv.sync_fence[ ]
