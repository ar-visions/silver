export 0.8.8

import vec
import img
import gltf
import trinity
import silver

import <stdio.h>
    -lm
import <stdlib.h>
import Earth
import Avatar
import Editor
import Console
import FileList

Option  DebugPanel
Option  CallStack
Control Tabs
Control Instances

enum ConsoleKind
    shell : 0
    lldb  : 1

#proto compiler ... this is in effect what we are doing, and if we 'wanted' to we could register this for enumeration at runtime
#      func compiler [ module: string ]

trinity orbiter # implements compiler
    intern avg_fps    : f32
    public open_files  : array path
    public active_idx  : i32
    public active_panel   : string
    public active_target  : string
    public active_console : ConsoleKind
    public filter_text    : string
 
    func init []
        width          = 1888
        height         = 888
        background     = 'Background'
        open_files     = array path []
        open_files    += path '/src/silver/src/silver.c'
        open_files    += path '/src/silver/src/aether.c'
        open_files    += path '/src/silver/src/Au.c'
        active_idx     = 0 
        active_panel   = 'files'
        active_target  = 'silver'
        active_console = ConsoleKind.shell
        filter_text    = ''
        au_set_compiler[a]
 
    func compile_fn [ w: Au ]
        m: string w  
        i: silver [ component: true, module: m ]  

    func compile [ mod: string ]
        puts 'try to compile {mod}'
        #i: silver [ component: true, verbose:true, module: mod ]  
        au_spawn[ ref compile_fn, a, mod ]

    func open_file [ p: path ]
        for [ i: i32 0, i < open_files.count, i += 1 ]
            if [ open_files[i] == p ]
                active_idx = i
                return
        open_files.push[ p ]
        active_idx = open_files.count - 1

    func set_active [ idx: i32 ]
        active_idx = idx

    public func pad[ n:i32 ] -> string
        str : local char[256]
        sprintf[str, "%04i", n]
        return str

    func on_click [ ev: Event ]
        if [ !ev.target ] return
        if [ ev.target inherits Option ]
            id : string ev.target.id
            if [ id == 'silver' || id == 'hyperspace' || id == 'orbiter' ]
                active_target = id
            el [ id == 'shell' ]
                active_console = ConsoleKind.shell
            el [ id == 'lldb' ]
                active_console = ConsoleKind.lldb
            el
                active_panel = id
            return
        for [ i: i32 0, i < open_files.count, i += 1 ]
            key : string 'tab_{i}'
            if [ ev.target.id == key ]
                set_active[ i ]
                return

    func on_press [ ev: Event ]
        for [ e: element* ev.target, e, e = e.parent ]
            if [ e inherits FileList ]
                fl : FileList e
                if [ fl.pending_open ]
                    open_file[ fl.pending_open ]
                    fl.pending_open = null
                    return

    func on_char [ ev: Event ]
        if [ !ev.target ] return
        puts 'on_char target={ev.target.id} text={ev.key.text}'
        if [ ev.target.id == 'filter' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                filter_text = filter_text + ev.key.text
                puts 'filter: {filter_text}'
                fl : FileList ev.target.parent.elements["files"]
                if [ fl ] fl.pristine = false

    
    func on_key [ ev: Event ]
        if [ !ev.target ] return

        if [ ev.target.id == 'filter' ]
            if [ !ev.key.state ] return
            k : i32 [ i32 ev.key.unicode ]
            fl : FileList ev.target.parent.elements["files"]
            if [ k == 259 ]
                if [ filter_text && filter_text.count > 0 ]
                    filter_text = filter_text.mid[ 0, filter_text.count - 1 ]
                    if [ fl ] fl.pristine = false
            el [ k == 256 ]
                filter_text = ''
                if [ fl ] fl.pristine = false

    public func on_render [ w: Window ] -> Elements
        fps : f32 [ w.frame_factor * 60.0 ]
        avg_fps = (avg_fps > 0.0) ? avg_fps * 0.95 + fps * 0.05 : fps
        w.set_title[ 'orbiter 444 | {pad[i32[avg_fps]]} fps' ]
    
        active_path : path (open_files.count > 0) ? open_files[active_idx] : null
        active_name : string (active_path) ? active_path.filename[] : string[]
       
        source_nav : Elements []
        for [ i: i32 0, i < open_files.count, i += 1 ]
            p   : path   open_files[i]
            key : string 'tab_{i}'
            source_nav[key] = Button [ label: p.filename[] ]

        targets : Elements []
        targets['silver']     = Option [ label: 'silver',     selected: active_target == 'silver'     ]
        targets['hyperspace'] = Option [ label: 'hyperspace', selected: active_target == 'hyperspace' ]
        targets['orbiter']    = Option [ label: 'orbiter',    selected: active_target == 'orbiter'    ]

        consoles : Elements []
        consoles['shell'] = Option [ label: 'shell', selected: active_console == ConsoleKind.shell ]
        consoles['lldb']  = Option [ label: 'lldb',  selected: active_console == ConsoleKind.lldb  ]
        
        return Elements [
            "toolbar":  Toolbar [
                elements: 
                    Elements [
                        'source_nav': Tabs[ elements: source_nav ]
                    ]
            ],
            "right":    Toolbar [
                elements: Elements [
                    "filter":       element    [ label: filter_text ]
                    "files":        FileList   [ selected: active_panel == 'files', filter: (active_panel == 'files') ? filter_text : '' ]
                    "callstack":    CallStack  [ selected: active_panel == 'callstack' ]
                    "debug":        DebugPanel [ selected: active_panel == 'debug' ]
                    "debug2":       CallStack  [ selected: active_panel == 'debug' ]
                ]
            ],
            "editor-group": Group [
                elements: Elements [
                    "title":        element [ label: active_name ]
                    "editor":       Editor  [ src: active_path ]
                ]
            ],
            "instances": Instances [
                elements: Elements [
                    "consoles":     Tabs [ elements: consoles ]
                    "targets":      Tabs [ elements: targets  ]
                    "actions":      Tabs [ elements: Elements [ "play": Button [] ] ]
                    "console":      Console [ session_id: active_target ]
                ]
            ]
            #"avatar": Avatar []
        ]

    public func on_canvas [ cv: Canvas ]
        super.on_canvas[ cv ]
        cv.sync_fence[ ]
