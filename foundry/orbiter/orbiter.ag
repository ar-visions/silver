element EditorView
    public selected : bool

# editor title bar. `selected` = the "New"/finder state (no file open): shows
# the magnify and left-aligns the (typed) text. with a file open it's centered
# and the magnify is hidden. clicking it focuses → editable.
element EditorTitle
    public selected : bool

Option  DebugPanel
Option  CallStack
# left-column tab for a project: a running-process context (process, shell
# output, lldb). `state` drives the side status light color.
Option  ProjectTab
    public state : string
Control Tabs
Control Instances
    public selected : bool
    # full-width (right toolbar hidden) — drives the :wide style so the console
    # spans the whole window instead of leaving a gap where the toolbar was.
    public wide     : bool

#proto compiler ... this is in effect what we are doing, and if we 'wanted' to we could register this for enumeration at runtime
#      func compiler [ module: string ]

func au_space_clear[] -> none

# resident set size as a fraction of total physical RAM (0..1), 0 if unknown.
# used as a runaway-leak guard so the app bails out before it locks the machine.
func au_mem_fraction[] -> f32

# redirect our stdout/stderr into a pipe so we can show our own printf/puts in
# the system console. returns the non-blocking read fd; au_stdout_orig is a dup
# of the real stdout so drain_stdout can tee output back to the terminal.
func au_capture_stdout[] -> i32
func au_stdout_orig[]    -> i32

trinity orbiter # implements compiler
    intern avg_fps       : f32
    intern target_names  : array string
    intern target_roots  : array path
    intern target_srcs   : array path
    public open_files       : array path
    # files that have a docked tab, per pane group (the +/- in the editor title
    # nav). an opened file is a preview until docked; docking pins a tab in that
    # group. left and right panes keep separate docked lists.
    public docked_left      : array path
    public docked_right     : array path
    # cached git-diff state per pane, refreshed when a file opens (not per frame)
    # so the git button's enabled state never forks git during render.
    intern left_diff        : bool
    intern right_diff       : bool
    public active_idx       : i32
    public left_idx         : i32
    public right_idx        : i32
    public config_side      : i32
    public active_panel  : string
    public editor_panel  : string
    public active_target : string
    public active_console: string
    public show_console  : bool
    # live elements, auto-bound by id — reference them directly, no tree walk.
    public instances     : Instances
    public console       : Console
    # bound layout var: editor-group bottom (= console top) seam, draggable
    public console_h     : f32 [ 6.9 ]
    # companion the seam maintains: last open (non-snapped) console height. the
    # toggle restores this when re-opening so a collapse doesn't lose the size.
    public console_h_user: f32 [ 6.9 ]
    # bound layout var: right-panel left seam (= editor/console right edge),
    # draggable. right_w_user is the seam's last open (non-snapped) width.
    public right_w       : f32 [ 10.0 ]
    public right_w_user  : f32 [ 10.0 ]
    # toggles the right-side file-list panel (the >| button in the editor group)
    public show_right    : bool [ true ]
    public filter_text   : string
    # finder search text typed into an editor title (magnify) when it has no file
    public find_text     : string
    # in-editor find/replace bar (toggled by the title magnify). findbar_open is the
    # expand state — held on the app (the Editor element is rebuilt each frame so it
    # can't keep the flag), fed into the Editor via its `expanded` prop. findbar_text
    # is the Find query, replace_text the Replace query. kept separate from find_text
    # (the file finder) so typing here doesn't trigger the finder's pin list.
    public findbar_open  : bool
    public findbar_text  : string
    public replace_text  : string
    # file-pattern (glob) that scopes find-in-files — the right cell of the
    # Replace row.
    public pattern_text  : string
    # find/replace scope, a radio pair in the right column: true = the current
    # file only ('In-File' on the Find row); false = files matching the pattern
    # ('Files' on the Replace row).
    public find_in_file  : bool
    # directories the finder searches (default: the project path). users add more.
    public search_dirs   : array path
    # flat index of every file path under search_dirs (built once, filtered in
    # memory per keystroke). find_results is the editor finder's current match set.
    public file_index    : list string
    public find_results  : list string
    # set true by the inotify watch thread when anything under search_dirs
    # changes. the next search rebuilds file_index lazily on the main thread.
    public index_dirty   : bool
    # incremental index build: a work queue of directories still to walk (with
    # their depths), drained a chunk per frame so the build never blocks the UI
    # and results grow progressively. building stays true until the queue drains.
    intern index_queue   : array path
    intern index_building : bool
    # one inotify watch per search dir; keeps file_index fresh (like vscode's
    # file watcher) instead of a once-per-session walk.
    intern index_watches : array watch
    public compile_log   : list string
    public stdout_log    : list string
    public nav_root      : path
    # breakpoints are app-global, keyed by "source:line" -> condition string
    # (empty = plain breakpoint, non-empty = conditional). the same map is
    # handed to every Editor so they all share one set.
    public breakpoints   : map string[string]
    # code font size (px) for editors. canvas default is large (~22); this is
    # the single place to tune it. line-number labels render smaller still.
    public code_font_size : i32
    intern booted        : bool
    intern stdout_rfd    : i32 [ -1 ]
    intern stdout_orig   : i32 [ -1 ]
    # route stdout into the in-app system console. false = leave stdout alone so
    # all prints go straight to the terminal (debugging). flip to true to re-enable.
    intern capture_stdout : bool [ false ]
    intern stdout_line   : string
 
    func init []
        width          = 1888
        height         = 888
        background     = 'Background'
        # create the shared breakpoint set first so it always exists before any
        # Editor is built and handed a reference to it.
        breakpoints    = map string[string] []
        code_font_size = 19    # ~70% of the large canvas default

        # targets defined once here
        target_names   = array string []
        target_roots   = array path []
        target_srcs    = array path []
        target_names  += 'silver'
        target_roots  += path '/src/silver'
        target_srcs   += path '/src/silver/src'
        target_names  += 'hyperspace'
        target_roots  += path '/src/silver/foundry/hyperspace'
        target_srcs   += path '/src/silver/foundry/hyperspace'
        # no files open at start — files open from the FileList (main on click,
        # right pane on shift+click)
        open_files     = array path []
        docked_left    = array path []
        docked_right   = array path []
        # a few default pins so the column has content to look at
        docked_left   += path '/src/silver/LICENSE'
        docked_left   += path '/src/silver/Makefile'
        docked_left   += path '/src/silver/README.md'
        docked_left   += path '/src/silver/CLAUDE.md'
        active_idx     = -1
        left_idx       = -1
        right_idx      = -1
        active_panel   = 'files'
        editor_panel   = 'editor'
        active_target  = 'silver'
        nav_root       = target_roots[0]
        active_console = 'shell'
        show_console   = true
        show_right     = true
        filter_text    = ''
        find_text      = ''
        findbar_open   = false
        findbar_text   = ''
        replace_text   = ''
        pattern_text   = ''
        find_in_file   = true
        # default search dir is the project path; users can append more
        search_dirs    = array path []
        search_dirs   += target_roots[0]
        file_index     = list string []
        find_results   = list string []
        index_dirty    = false
        index_watches  = array watch []
        start_watching[]
        # kick off the incremental index build (runs a chunk per frame)
        start_index[]
        compile_log    = list string []
        stdout_log     = list string []
        # seed one at silver.c:4 to have something to look at (empty condition
        # = a plain breakpoint; a non-empty string would be a conditional one)
        bp_src : open_files[0]
        breakpoints['{bp_src}:4'] = string[]
        stdout_line    = ''
        # capture is deferred to the first on_render so load-time prints don't get
        # routed into a console that isn't initialized/updating yet.
        printf[ "orbiter: stdout capture active (rfd=%i orig=%i)\n", stdout_rfd, stdout_orig ]
        check_stale[]
        ensure_user_config[]
        #au_set_compiler[a]

    func ensure_user_config []
        home : string [ getenv[ 'HOME' ] ]
        if [ !home || home.count == 0 ] return
        xdg  : string [ getenv[ 'XDG_CONFIG_HOME' ] ]
        base : string (xdg && xdg.count > 0) ? xdg : '{home}/.config'
        dir  : path '{base}/orbiter'
        dir.make_dir[]
        cfg  : path '{base}/orbiter/orbiter.config'
        #if [ !cfg.exists[] ]
        #    cfg.save[ '# orbiter user config\n' ]
 
    func check_stale []
        for [ i: i32 0, i < target_names.count, i += 1 ]
            name    : string target_names[i]
            src     : path   target_srcs[i]
            product : path  '/src/silver/platform/native/debug/{name}'
            if [ !product.exists[] ]
                compile_log.push[ 'stale (no product): {name}' ]
                compile[ name ]
                continue
            product_mtime : i64 [ product.modified_time[] ]
            src_mtime     : i64 [ 0 ]
            src.latest_modified[ ref src_mtime ]
            if [ src_mtime > product_mtime ]
                compile_log.push[ 'stale (source newer): {name}' ]
                compile[ name ]

    func drain_stdout []
        if [ stdout_rfd < 0 ] return
        buf : local i8 [2]
        buf[1] = 0
        for [ i: i32 0, i < 4096, i += 1 ]
            nr : i32 [ read[ stdout_rfd, ref buf[0], 1 ] ]
            if [ nr <= 0 ] break
            # silent tee to the real terminal so output still shows there too
            if [ stdout_orig >= 0 ] write[ stdout_orig, ref buf[0], 1 ]
            if [ i32[buf[0]] == 10 ]
                stdout_log.push[ stdout_line ]
                stdout_line = ''
            el
                stdout_line = stdout_line + string[ ref buf[0] ]

    func compile_fn [ w: Au ]
        m: string w  
        i: silver [ component: true, module: m ]  

    func compile [ mod: string ]
        active_target = 'system'
        compile_log.push[ 'compiling {mod}...' ]
        i: silver [ component: true, verbose:true, module: mod ]
        au_space_clear[]
        compile_log.push[ 'done: {mod}' ]
        #au_spawn[ ref compile_fn, a, mod ]

    # map a path to its slot in open_files, registering it if not yet present.
    # (renamed from file_index — that name is the search-index prop; silver is
    # like swift, a func can't shadow a prop.)
    func file_slot [ p: path ] -> i32
        for [ i: i32 0, i < open_files.count, i += 1 ]
            if [ open_files[i] == p ] return i
        open_files.push[ p ]
        return open_files.count - 1

    # is this file docked in the given group?
    func is_docked [ p: path, grp: array path ] -> bool
        if [ !p || !grp ] return false
        for [ i: i32 0, i < grp.count, i += 1 ]
            if [ grp[i] == p ] return true
        return false

    # dock a file into a group: add its tab (duplicate-checked)
    func dock [ p: path, grp: array path ]
        if [ !p || !grp || is_docked[ p, grp ] ] return
        grp.push[ p ]

    # undock a file from a group: remove its tab
    func undock [ p: path, grp: array path ]
        if [ !p || !grp ] return
        for [ i: i32 0, i < grp.count, i += 1 ]
            if [ grp[i] == p ]
                grp.remove[ i ]
                return

    # shell out to git for a file and report whether it has a diff. only called
    # when a file is opened — never during render, so the per-frame path stays
    # fork-free; callers cache the result in left_diff / right_diff.
    # diff --name-only against HEAD scopes the work to the one file and skips the
    # whole-worktree untracked scan that makes `status` cost ~0.5s in this repo
    # (it vendors checkout/llvm-project).
    func git_diff [ p: path ] -> bool
        if [ !p ] return false
        dir : path p.directory[]
        cmd : command 'git -C "{dir}" diff --no-ext-diff --name-only HEAD -- "{p}" 2>/dev/null'
        out : string cmd.run[ false ]
        return out && out.count > 0

    # build the editor-title nav (git + dock toggle) for a pane. the git button
    # only appears for a real on-disk source and is enabled only when git sees a
    # diff. the dock button is a single toggle: '-' (undock) when the file is
    # already docked, '+' (dock) when it isn't. a new/unsaved file shows neither.
    func title_nav [ p: path, grp: array path, has_diff: bool, win: Window ] -> Elements
        nav : Elements []
        # git icon only when the find/replace bar is closed — while it's open the
        # nav floats over the Find row, so show just the magnify there.
        if [ p && p.exists[] && !findbar_open ]
            nav['git'] = Option [ selected: editor_panel == 'git', disable: !has_diff ]
        # the magnify is the find/replace toggle, pinned rightmost (always present).
        # selected while the bar is open so it stays lit with the hover glow.
        nav['magnify'] = Option [ selected: findbar_open ]
        # the two find/replace input rows live in the title and stay hidden (h0)
        # until the title gets :expanded, when CSS gives them edge-to-edge areas.
        # nav declared last so it paints on top of the edge-to-edge Find row and
        # wins the click (reverse hit-test favors the later-declared sibling) —
        # keeps the magnify clickable to toggle the bar off, no topmost needed.
        hasfile  : bool [ p && p.exists[] ]
        # Files is the active scope whenever there's no file to search In-File.
        files_sel : bool [ !hasfile || !find_in_file ]
        els : Elements []
        # dock/undock (tab remove/add) toggle to the LEFT of the title label, in
        # regular title mode only (hidden while the find/replace bar is open).
        if [ hasfile && !findbar_open ]
            if [ is_docked[ p, grp ] ]
                els['undock'] = Option [ selected: false ]
            el
                els['dock'] = Option [ selected: false ]
        els['find']    = element [ label: 'Find',    edit: findbar_text ]
        els['replace'] = element [ label: 'Replace', edit: replace_text ]
        els['pattern'] = Option  [ label: 'Files', edit: pattern_text, selected: files_sel ]
        # In-File is only an option when a file is actually open.
        if [ hasfile ]
            els['infile'] = Option [ label: p.filename[], selected: find_in_file ]
        # nav topmost so the magnify paints in front of the In-File filename cell
        # (they share the upper-right corner) and still wins the click.
        els['nav'] = element [ topmost: true, elements: nav ]
        return els

    # build the docked-tab strip for a group: one tab per docked file, the
    # active file selected. ids are prefix+index so the click handler can map
    # back to the path. rendered inline in the editor title when not editing.
    func dock_tabs [ grp: array path, prefix: string, active: path, win: Window ] -> Elements
        els : Elements []
        for [ i: i32 0, i < grp.count, i += 1 ]
            p  : path   grp[i]
            id : string '{prefix}{i}'
            els[id] = Option [ label: p.filename[], selected: active && p == active ]
        return els

    # (re)start the incremental index build: clear the index and seed the work
    # queue with the search dirs. index_step[] drains it over subsequent frames.
    func start_index []
        file_index   = list string []
        index_queue  = array path []
        for [ d: path ] in search_dirs
            index_queue.push[ d ]
        index_building = true
        index_dirty    = false

    # one frame's worth of indexing: pop directories off the queue (DFS) under a
    # time budget, pushing files into file_index and subdirs back onto the queue.
    # results grow progressively; the UI never blocks for more than the budget.
    # the file cap bounds runaway trees (no depth limit needed).
    func index_step []
        if [ !index_building ] return
        t0 : i64 [ epoch_micros[] ]
        while [ index_queue.count > 0 ]
            n : i32 [ index_queue.count - 1 ]
            # hold across remove[]: remove drops the array's ref, and `d` is a
            # borrow — without the hold the path frees before d.ls[] runs.
            d : path hold[ index_queue[n] ]
            index_queue.remove[ n ]
            entries : array [ d.ls[ null, false ] ]
            drop[ d ]
            if [ entries ]
                for [ i: i32 0, i < entries.count, i += 1 ]
                    e : path entries[i]
                    if [ e.is_dir[] ]
                        index_queue.push[ e ]
                    el
                        file_index.push[ e ]
            if [ file_index.count >= 100000 ]
                index_building = false
                return
            if [ epoch_micros[] - t0 > 4000 ] break
        if [ index_queue.count == 0 ]
            index_building = false

    # spawn one inotify watch per search dir. the watch runs on its own pthread
    # (Au.watch) and fires on_index_change when anything under the dir changes.
    func start_watching []
        for [ d: path ] in search_dirs
            iw : watch [ res: d, callback: ref on_index_change, argument: a ]
            iw.start[]
            index_watches += iw

    # called FROM the watch thread — keep it trivial. just flag the index stale;
    # the rebuild happens on the main thread in the next run_search.
    func on_index_change [ changed: Au ] -> none
        index_dirty = true

    # reload safety: each watch thread holds a raw callback (on_index_change) into
    # THIS module's code. before the .so unloads they must be stopped, else a file
    # event after dlclose fires a dangling pointer (crash in watch_runner). pause[]
    # joins each thread synchronously, independent of refcount/auto_free timing.
    func destroy [ ]
        if [ index_watches ]
            for [ iw: watch ] in index_watches
                iw.pause[ ]
        super.destroy[ ]

    # index_search is the SERVICE: filter the cached file_index by `query` and RETURN
    # the ranked matches. it owns no display state and touches no shared query field,
    # so the editor finder and the FileList can each call it with their own query.
    func index_search [ query: string ] -> list string
        out : list string []
        # if a change is pending and we're idle, restart the incremental build; this
        # just filters what's there (instant) — never walks the tree on a keystroke.
        if [ index_dirty && !index_building ]
            start_index[]
        # rank by right-distance: how far the right-most occurrence sits from the END
        # of the path. 0 = match at the very end (most relevant). clamp into last tier.
        tiers   : i32 [ 32 ]
        matches : array string []
        dists   : array i32 []
        if [ query && query.count > 0 ]
            ql : i32 [ query.count ]
            for [ s: string ] in file_index
                ridx : i32 [ s.rindex_of[ query ] ]
                if [ ridx >= 0 ]
                    d : i32 [ s.count - (ridx + ql) ]
                    if [ d > tiers ] d = tiers
                    matches.push[ s ]
                    dists.push[ d ]
                    if [ matches.count >= 500 ] break
            for [ d: i32 0, d <= tiers, d += 1 ]
                for [ i: i32 0, i < matches.count, i += 1 ]
                    if [ dists[i] == d ]
                        out.push[ matches[i] ]
        return out

    # the editor finder: run the search service, then DISPLAY the results in the
    # editor pane. (the FileList calls index_search directly and renders them itself.)
    func run_search []
        find_results = index_search[ find_text ]
        win : cast Window [ w ]
        if [ !win ] return
        grp : element win.root.elements['editor-group']
        if [ !grp ] return
        eds : element grp.elements['editors']
        ed  : Editor (eds) ? eds.elements['pane'] : null
        if [ ed ]
            if [ find_text && find_text.count > 0 ]
                # actively searching — show the matches over whatever is open
                # (no longer gated on the pane having no file)
                ed.lines = find_results
                ed.pristine = false
            el [ ed.src ]
                # query cleared but a file is open — restore the file content
                ed.load_file[]
                ed.pristine = false
            el
                # finder pane, no file, no query — empty list
                ed.lines = find_results
                ed.pristine = false

    # open in the main (left) pane
    func open_file [ p: path ]
        idx : i32 [ file_slot[ p ] ]
        left_idx   = idx
        active_idx = idx
        left_diff  = git_diff[ p ]
        exit_finder[]
        sync_editor[]

    # open in the right pane (split view)
    func open_file_right [ p: path ]
        right_idx  = file_slot[ p ]
        right_diff = git_diff[ p ]
        exit_finder[]
        sync_editor[]

    # leave finder/edit mode: clear the typed query and drop focus from the
    # editor title so it returns to showing the (centered) filename, not an
    # editable field.
    func exit_finder []
        find_text    = ''
        find_results = list string []
        win : cast Window [ w ]
        if [ !win ] return
        if [ win.focus && win.focus.id == 'title' ]
            win.release_focus[ win.focus ]

    func set_active [ idx: i32 ]
        active_idx = idx

    func sync_tabs []
        win : cast Window [ w ]
        tb  : element win.root.elements['toolbar']
        if [ !tb ] return
        nav : element tb.elements['source_nav']
        if [ !nav ] return
        # project tabs select by active_target (keys are the project names)
        for [ i: i32 0, i < target_names.count, i += 1 ]
            name : string target_names[i]
            op   : Option nav.elements[name]
            if [ op ] op.selected = active_target == name && active_panel != 'config'
        sys : Option nav.elements['system']
        if [ sys ] sys.selected = active_target == 'system' && active_panel != 'config'
        cfg : Option nav.elements['config']
        if [ cfg ] cfg.selected = active_panel == 'config'
        win.restyle = true

    func sync_editor []
        win : cast Window [ w ]
        if [ !win ] return
        grp : element win.root.elements['editor-group']
        if [ !grp ] return
        eds : element grp.elements['editors']
        if [ left_idx >= 0 && left_idx < open_files.count ]
            p  : path open_files[left_idx]
            ed : Editor (eds) ? eds.elements['pane'] : null
            if [ ed ]
                ed.src = p
                ed.load_file[]
                ed.pristine = false
        if [ right_idx >= 0 && right_idx < open_files.count ]
            p  : path open_files[right_idx]
            er : Editor (eds) ? eds.elements['pane-right'] : null
            if [ er ]
                er.src = p
                er.load_file[]
                er.pristine = false

    func sync_active []
        # the console's session_id/feed come from the Console[] template in
        # on_render (applied to the instance) — not set here, and never pristine /
        # set_focus from a sync/render path.
        if [ instances ]
            acts : element instances.elements[ 'actions' ]
            if [ acts ]
                play_el : element acts.elements[ 'play' ]
                if [ play_el ] play_el.disable = (active_target == 'system')
        win : cast Window [ w ]
        if [ win ] win.restyle = true

    public func pad[ n:i32 ] -> string
        str : local char[256]
        sprintf[str, "%04i", n]
        return str

    func on_press [ ev: Event ]
        if [ !ev.target ] return
        for [ e: element* ev.target, e, e = e.parent ]
            if [ e inherits FileList ]
                fl : FileList e
                if [ fl.pending_open ]
                    if [ ev.key.shift ]
                        open_file_right[ fl.pending_open ]
                    el
                        open_file[ fl.pending_open ]
                    fl.pending_open = null
                    sync_editor[]
                    return
            # clicking a result row while searching opens it (works whether or
            # not a file is already open in the pane — driven by an active query,
            # not by the pane being empty)
            if [ e inherits Editor ]
                ed : Editor e
                if [ find_text && find_text.count > 0 && ed.sel_line >= 0 && ed.sel_line < find_results.count ]
                    hit_path : path find_results.value_by_index[ ed.sel_line ]
                    open_file[ hit_path ]
                    return
        # >| toggle hides/shows the right file-list panel
        if [ ev.target.id == 'toggle_side' ]
            # the seam (right_w) is the single source of truth; show_right is
            # derived from it in on_render, so clicking and drag-snapping stay in
            # sync. collapse to 0, or restore the last dragged width.
            if [ right_w > 0.5 ]
                right_w = 0.0
            el
                right_w = right_w_user
            # Instances is a Control, not an Option, so apply_args won't sync its
            # custom `wide` flag — set it directly so the console spans full width
            # (no gap) when the right toolbar is hidden.
            ux      : Window ev.target.ux
            inst_el : Instances ux.root.elements[ 'instances' ]
            if [ inst_el ] inst_el.wide = right_w <= 0.5
            if [ ev.target ] ev.target.ux.restyle = true
            return
        puts 'on_press: {ev.target.id}'
        for [ i: i32 0, i < open_files.count, i += 1 ]
            key : string 'tab_{i}'
            if [ ev.target.id == key ]
                rel_x    : f32 [ ev.mouse.pos.x - ev.target.bounds.x ]
                in_right : bool [ rel_x > ev.target.bounds.w - 14.0 ]
                puts 'tab press: shift={ev.key.shift} in_right={in_right} rel_x={rel_x} w={ev.target.bounds.w}'
                if [ ev.key.shift || in_right ]
                    active_panel = 'editor'
                    if [ left_idx == i ]
                        left_idx  = right_idx
                        right_idx = i
                    el
                        right_idx = i
                    set_active[ i ]
                    sync_editor[]
                el
                    active_panel = 'editor'
                    if [ right_idx == i ]
                        right_idx = left_idx
                        left_idx  = i
                    el
                        left_idx = i
                    set_active[ i ]
                    sync_editor[]
                sync_tabs[]
                return
        if [ ev.target.id == 'git' ]
            editor_panel = (editor_panel == ev.target.id) ? 'editor' : ev.target.id
            if [ ev.target ] ev.target.ux.restyle = true
            return
        # magnify: toggle the find/replace bar (shared app state, fed to the Editor
        # via its `expanded` prop each frame).
        if [ ev.target.id == 'magnify' ]
            findbar_open = !findbar_open
            if [ ev.target ] ev.target.ux.restyle = true
            return
        # scope radio pair: In-File (current file) vs Files (pattern)
        if [ ev.target.id == 'infile' ]
            find_in_file = true
            if [ ev.target ] ev.target.ux.restyle = true
            return
        if [ ev.target.id == 'pattern' ]
            find_in_file = false
            if [ ev.target ] ev.target.ux.restyle = true
            return
        # one toggle button rendered as either + (dock, id 'dock') or - (undock,
        # id 'undock') depending on whether this file is already in the group.
        # the tab goes into the group for the pane the button lives in.
        if [ ev.target.id == 'dock' || ev.target.id == 'undock' ]
            for [ e: element* ev.target, e, e = e.parent ]
                if [ e inherits Editor ]
                    ed : Editor e
                    if [ ed.src ]
                        grp : array path (ed.id == 'pane-right') ? docked_right : docked_left
                        if [ ev.target.id == 'dock' ] dock[ ed.src, grp ]
                        el                            undock[ ed.src, grp ]
                    break
            if [ ev.target ] ev.target.ux.restyle = true
            return
        # clicking a pin (pin{i}) inside an editor opens that docked file from
        # the pane's own list (left vs right)
        tid : string ev.target.id
        if [ tid.count > 3 && tid.mid[ 0, 3 ] == 'pin' ]
            i : i32 [ tid.mid[ 3, tid.count - 3 ].real_value[] ]
            for [ e: element* ev.target, e, e = e.parent ]
                if [ e inherits Editor ]
                    ed : Editor e
                    if [ ed.id == 'pane-right' ]
                        if [ i >= 0 && i < docked_right.count ] open_file_right[ docked_right[i] ]
                    el
                        if [ i >= 0 && i < docked_left.count ] open_file[ docked_left[i] ]
                    break
            if [ ev.target ] ev.target.ux.restyle = true
            return
        if [ ev.target.id == 'config' ]
            rel_x    : f32 [ ev.mouse.pos.x - ev.target.bounds.x ]
            in_right : bool [ rel_x > ev.target.bounds.w - 14.0 ]
            if [ ev.key.shift || in_right ]
                config_side = (config_side == 1) ? 0 : 1
            el
                active_panel = 'config'
            sync_tabs[]
            return
        if [ ev.target inherits Option ]
            id : string ev.target.id
            if [ id == 'system' ]
                active_target = 'system'
                sync_active[]
                ev.no_default = true
            el [ id == 'shell' || id == 'lldb' ]
                active_console = (active_console == id) ? '' : id
                show_console   = active_console.count > 0
                # console seam toggle: off collapses to the style minimum (layout
                # floors a 0 request so the bar still paints); on restores the last
                # open position the seam recorded in console_h_user.
                if [ !show_console ]
                    console_h = 0.0
                el
                    console_h = console_h_user
                puts 'show_console: {show_console}'
                ux      : Window ev.target.ux
                inst_el : Instances ux.root.elements[ 'instances' ]
                if [ inst_el ]
                    inst_el.selected = show_console
            el
                matched : bool false
                for [ i: i32 0, i < target_names.count, i += 1 ]
                    if [ target_names[i] == id ]
                        active_target = id
                        nav_root      = target_roots[i]
                        matched       = true
                if [ !matched ]
                    active_panel = id
                if [ matched ]
                    sync_active[]
                    ev.no_default = true
            if [ ev.target ] ev.target.ux.restyle = true
            return

    func on_char [ ev: Event ]
        if [ !ev.target ] return
        if [ ev.target.id == 'filter' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                filter_text = filter_text + ev.key.text
                # apply_args doesn't propagate custom public fields per-frame, so set
                # the query straight on the FileList instance and rebuild. the FileList
                # runs its own local substring search over its folder.
                fl : FileList ev.target.parent.elements['files']
                if [ fl ]
                    fl.find_text = filter_text
                    fl.last_find = filter_text
                    fl.build_visible[]
                    fl.pristine  = false
                # a keystroke doesn't set the render gate on its own — request a frame
                # so the FileList repaints with the new results as you type.
                ux : Window ev.target.ux
                if [ ux ] ux.will_animate = true
        # typing into the find/replace bar rows (each its own query)
        if [ ev.target.id == 'find' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                findbar_text = findbar_text + ev.key.text
                ev.target.pristine = false
                ux : Window ev.target.ux
                if [ ux ] ux.will_animate = true
        if [ ev.target.id == 'replace' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                replace_text = replace_text + ev.key.text
                ev.target.pristine = false
                ux : Window ev.target.ux
                if [ ux ] ux.will_animate = true
        if [ ev.target.id == 'pattern' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                pattern_text = pattern_text + ev.key.text
                ev.target.pristine = false
                ux : Window ev.target.ux
                if [ ux ] ux.will_animate = true
        # typing into an editor's title (the finder/magnify control)
        if [ ev.target.id == 'title' ]
            if [ ev.key.text && ev.key.text.count > 0 ]
                find_text = find_text + ev.key.text
                ev.target.pristine = false
                run_search[]

    
    func on_key [ ev: Event ]
        if [ !ev.target ] return
 
        if [ ev.target.id == 'filter' ]
            if [ !ev.key.state ] return
            k : i32 [ i32 ev.key.unicode ]
            changed : false
            if [ k == 259 ]
                if [ filter_text && filter_text.count > 0 ]
                    filter_text = filter_text.mid[ 0, filter_text.count - 1 ]
                    changed = true
            el [ k == 256 ]
                filter_text = ''
                changed = true
            if [ changed ]
                fl : FileList ev.target.parent.elements['files']
                if [ fl ]
                    fl.find_text = filter_text
                    fl.last_find = filter_text
                    fl.build_visible[]
                    fl.pristine  = false
                ux : Window ev.target.ux
                if [ ux ] ux.will_animate = true

        # find/replace bar rows: backspace trims, escape collapses the bar
        if [ ev.target.id == 'find' || ev.target.id == 'replace' || ev.target.id == 'pattern' ]
            if [ !ev.key.state ] return
            k : i32 [ i32 ev.key.unicode ]
            if [ k == 259 ]
                if [ ev.target.id == 'find' ]
                    if [ findbar_text && findbar_text.count > 0 ]
                        findbar_text = findbar_text.mid[ 0, findbar_text.count - 1 ]
                el [ ev.target.id == 'replace' ]
                    if [ replace_text && replace_text.count > 0 ]
                        replace_text = replace_text.mid[ 0, replace_text.count - 1 ]
                el
                    if [ pattern_text && pattern_text.count > 0 ]
                        pattern_text = pattern_text.mid[ 0, pattern_text.count - 1 ]
            el [ k == 256 ]
                # escape collapses the bar
                findbar_open = false
                ev.target.ux.restyle = true
            ev.target.pristine = false
            ux : Window ev.target.ux
            if [ ux ] ux.will_animate = true

        # finder title: backspace trims, enter opens the typed file
        if [ ev.target.id == 'title' ]
            if [ !ev.key.state ] return
            k : i32 [ i32 ev.key.unicode ]
            if [ k == 259 ]
                if [ find_text && find_text.count > 0 ]
                    find_text = find_text.mid[ 0, find_text.count - 1 ]
                    ev.target.pristine = false
                    run_search[]
            el [ k == 257 ]
                # enter opens the first matching result
                if [ find_results && find_results.count > 0 ]
                    first_path : path find_results.value_by_index[ 0 ]
                    open_file[ first_path ]
            el [ k == 256 ]
                # esc: drop the query and restore the pane — run_search with an
                # empty query reloads the file (or empties the pane if none)
                find_text = ''
                ev.target.pristine = false
                run_search[]

    public func on_render [ w: Window ] -> Elements
        # runaway-leak guard: if our RSS passes 20% of physical RAM, quit before
        # the leak thrashes the machine into a solid lock. cheap (/proc read).
        if [ au_mem_fraction[] > 0.20 ]
            puts 'orbiter: memory exceeded 20% of system RAM — quitting '
            exit[ 1 ]
        
        # skip the first frame (styles/Regions parse during it) so its prints hit
        # the terminal; capture from the second frame on, once the console is live.
        if [ capture_stdout ]
            if [ !booted ]
                booted = true
            el [ stdout_rfd < 0 ]
                stdout_rfd  = au_capture_stdout[]
                stdout_orig = au_stdout_orig[]
            drain_stdout[]
        index_step[]
        #avg_fps = (avg_fps > 0.0) ? avg_fps * 0.95 + fps * 0.05 : fps
        w.set_title[ 'orbiter' ]

        show_right = right_w > 0.5

        if [ show_console && console ]
            cs : console.session[]
            if [ cs ]
                if [ cs.pty_fd >= 0 ]
                    w.will_animate = true
                    cs.dirty = false
                    cs.read_output[]
                    if [ cs.dirty ] console.pristine = false
                el [ console.feed ]
                    fc : i32 [ console.feed.count ]
                    if [ fc != cs.last_feed_count ]
                        cs.last_feed_count = fc
                        console.pristine   = false
                        w.will_animate     = true

        left_path           : path (left_idx >= 0 && left_idx < open_files.count) ? open_files[left_idx] : null
        right_path          : path (right_idx >= 0 && right_idx < open_files.count) ? open_files[right_idx] : null
        active_name         : string (left_path) ? left_path.filename[] : string[]

        source_nav : Elements []
        # the system (menu) tab now lives in the project tab list, leftmost
        source_nav['system'] = Option [ selected: active_target == 'system' ]
        for [ i: i32 0, i < target_names.count, i += 1 ]
            name : string target_names[i]
            source_nav[name] = ProjectTab [ label: name, selected: active_target == name ]

        # the in-editor pin list + 144px content inset appear while editing the
        # title (focused — even before a letter is typed) or a query is active.
        searching  : bool [ (w.focus && w.focus.id == 'title') || (find_text && find_text.count > 0) ]

        # the main pane is always present and fills the group. with no file it's
        # a finder (file search results); with a file it's the editor. when
        # searching, a vertical pin list renders inside the editor's right 144px.
        editor_els : Elements []
        pane_els : Elements []
        pane_els['title'] = EditorTitle [
            selected: !left_path
            edit: find_text
            label: (left_path) ? left_path.filename[] : 'Finder'
            elements: title_nav[ left_path, docked_left, left_diff, w ]
        ]
        if [ searching ]
            pane_els['pins'] = element [ elements: dock_tabs[ docked_left, 'pin', left_path, w ] ]
        editor_els['pane'] = Editor [ src: left_path, breakpoints: breakpoints, code_font_size: code_font_size, expanded: findbar_open, elements: pane_els ]

        if [ right_idx >= 0 && right_idx < open_files.count ]
            pr_els : Elements []
            pr_els['title'] = EditorTitle [
                selected: !right_path
                edit: find_text
                label: (right_path) ? right_path.filename[] : 'Finder'
                elements: title_nav[ right_path, docked_right, right_diff, w ]
            ]
            if [ searching ]
                pr_els['pins'] = element [ elements: dock_tabs[ docked_right, 'pin', right_path, w ] ]
            editor_els['pane-right'] = Editor [ src: right_path, breakpoints: breakpoints, code_font_size: code_font_size, expanded: findbar_open, elements: pr_els ]

        egroup_els : Elements []
        egroup_els['editors'] = EditorView [ selected: left_idx >= 0 && right_idx >= 0, elements: editor_els ]

        return Elements [
            "toggle_side":  Option [ selected: !show_right, topmost: true ]
            "right":        Toolbar [
                # no transparency hide — the right_w seam collapses this to
                # bounds.w 0 when toggled off, which the draw skip already hides.
                elements: Elements [
                    "title": element [
                        elements: Elements [
                            "nav": element [
                                elements: Elements [
                                    "files":     Option [ selected: active_panel == 'files' ]
                                    "callstack": Option [ selected: active_panel == 'callstack' ]
                                    "debug":     Option [ selected: active_panel == 'debug' ]
                                    "agent":     Option [ selected: active_panel == 'agent' ]
                                ]
                            ]
                        ]
                    ]
                    # only the active panel is shown AND hit-tested. non-active
                    # panels are made fully transparent so find_target skips them
                    # (they overlap the same area; otherwise the last-painted one
                    # captures every click under reverse hit-testing).
                    "files":        FileList   [ selected: active_panel == 'files', transparency: (active_panel == 'files')     ? 0.0 : 1.0, find_text: filter_text, root: nav_root ]
                    "callstack":    CallStack  [ selected: active_panel == 'callstack', transparency: (active_panel == 'callstack') ? 0.0 : 1.0 ]
                    "debug":        DebugPanel [ selected: active_panel == 'debug', transparency: (active_panel == 'debug')     ? 0.0 : 1.0 ]
                    "agent":        Option     [ selected: active_panel == 'agent', transparency: (active_panel == 'agent')     ? 0.0 : 1.0 ]
                    # 1-unit filter input pinned to the bottom of the navigator
                    "filter":       element    [ label: 'filter', edit: filter_text ]
                ]
            ],
            "editor-group": Group [
                # right edge follows the right_w seam (→ r0/full when the panel is
                # toggled off), so no selected-based fill override is needed; this
                # also keeps the console_h seam live while the right panel is hidden.
                # elements (editors + optional pin column) built above in egroup_els.
                elements: egroup_els
            ],

            "instances": Instances [ elements: Elements [
                'source_nav': Tabs [ elements: source_nav ]
                'tools':      Tabs [ elements: Elements [
                    'play': Button [ disable: active_target == 'system' ]
                ] ]
                'consoles':   Tabs [ elements: Elements [
                    'shell': Option [ label: 'shell', selected: active_console == 'shell', toggle: true ]
                    'lldb': Option [ label: 'lldb',  selected: active_console == 'lldb',  disable:active_target == 'system', toggle: true ]
                ] ]
                'console':    Console [ session_id: active_target, feed: (active_target == 'system') ? stdout_log : null ]
            ], selected: show_console, wide: !show_right ]
        ]
 
        #"avatar":       Avatar     [ transparency: (active_panel == 'debug') ? 0.0 : 1.0 ]

    public func on_canvas [ cv: Canvas ]
        super.on_canvas[ cv ]
        cv.sync_fence[ ]

