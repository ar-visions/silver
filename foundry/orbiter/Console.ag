extend orbiter


ifdef [ apple ]
    import <util.h>     # forkpty/openpty live in util.h on macOS
        -lutil
ifdef [ linux ]
    import <pty.h>
        -lutil
import <unistd.h>
import <fcntl.h>
import <sys/ioctl.h>

# one terminal cell: a Unicode codepoint plus its pen. fg/bg are packed 0xRRGGBB
# (-1 = terminal default); attr bits: 1 bold, 2 underline, 4 inverse, 8 dim.
struct TermCell
    ch   : i32 [ 32 ]
    fg   : i32 [ -1 ]
    bg   : i32 [ -1 ]
    attr : i32 [ 0 ]

class ConsoleSession
    mutable pty_fd     : i32 [ -1 ]
    mutable pid        : i32 [ 0  ]
    # the session key (project node name); used as the shell prompt label.
    mutable name       : string
    # agent launch command (claude/gemini): when set, start[] execs it directly
    # instead of an interactive shell, so the console shows only the agent's output
    # with no prompt/echo line. shells leave this empty and get an interactive bash.
    mutable launch_cmd : string
    # a command queued to send once the shell is ready (first output arrives, i.e.
    # bash is in raw mode) — avoids the cooked-mode double echo of an early write.
    mutable pending    : string
    mutable esc_state  : i32 [ 0  ]
    mutable esc_n0     : i32 [ 0  ]
    mutable esc_n1     : i32 [ 0  ]
    mutable esc_n2     : i32 [ 0  ]
    mutable esc_np     : i32 [ 0  ]
    mutable cur_save_x : i32 [ 0  ]
    mutable cur_save_y : i32 [ 0  ]
    mutable cx         : i32 [ 0  ]
    mutable cy         : i32 [ 0  ]
    mutable cols       : i32 [ 80 ]
    mutable rows       : i32 [ 24 ]
    mutable screen      : new TermCell [ 2048 * 2048 ]
    mutable scrollback : list string
    # color/attr for each scrollback line, kept in parallel with `scrollback` so the
    # history renders with its original colors (not a flat monochrome string). cells
    # are stored contiguously; sb_off[i] is line i's start index into sb_cells.
    mutable sb_cells   : array TermCell
    mutable sb_off     : array i32
    # scratch row used to render a scrollback line: sb_cells stores boxed TermCell
    # objects (array push), so it can't be read as a flat ref TermCell — we copy a
    # line into this contiguous buffer and feed that to the shared draw_cells.
    mutable sb_scratch : new TermCell [ 2048 ]
    mutable scroll     : f32 [ 0.0 ]
    # wheel delta accumulates here in LINE units; we only move the view when a whole
    # line is crossed, so a mac trackpad's stream of tiny fractional deltas doesn't
    # fire a redraw per pixel (the laggy "hammering"). sub-line motion just buffers.
    mutable wheel_accum : f32 [ 0.0 ]
    # index of the top visible line at the last console repaint. scroll only forces a
    # repaint when this changes — a drag that hasn't crossed a line boundary leaves the
    # rendered content identical, so we skip it.
    mutable first_line  : i32 [ -2147483647 ]
    # set when pty output actually changes the screen; lets the console stay
    # cached (pristine) and skip its full text re-render on idle frames.
    mutable dirty      : bool
    # last feed line count (system console) — detects new lines without a redraw.
    mutable last_feed_count : i32 [ -1 ]
    mutable read_calls : i32 [ 0 ]
    # line/col text selection over the line model (same as the Editor). sel_line
    # -1 = no selection. lh/cw cached from draw for the mouse→cell mapping.
    mutable sel_line    : i32 [ -1 ]
    mutable sel_col     : i32 [ 0 ]
    mutable anchor_line : i32 [ 0 ]
    mutable anchor_col  : i32 [ 0 ]
    mutable dragging        : bool
    mutable scroll_dragging : bool
    mutable lh_cache    : f32
    mutable cw_cache    : f32
    # hovered file:line link span: content-space line + [link_c0, link_c1) columns.
    # hover_link_line -1 = nothing hovered. set in on_move when the mouse sits on a
    # path:number token; the draw underlines that span so it reads as a link.
    mutable hover_link_line : i32 [ -1 ]
    mutable link_c0     : i32 [ 0 ]
    mutable link_c1     : i32 [ 0 ]
    # per-scrollback-line render cache. each VISIBLE line is rasterized into a pooled
    # canvas once (keyed by line index) then blitted every frame; slots are recycled
    # as lines scroll off, so the pool stays at the visible-line count — never the
    # scrollback depth. cache_cw/cache_lh invalidate the whole pool on font/reflow.
    mutable sb_lines    : array TermLineCache
    # live-grid row cache, indexed by row. live rows mutate, so each slot also stores
    # a content hash — an unchanged row blits, only a changed row re-rasterizes. this
    # is what keeps an idle/streaming TUI (claude) from re-drawing every row per frame.
    mutable live_lines  : array TermLineCache
    mutable cache_cw    : f32 [ -1.0 ]
    mutable cache_lh    : f32 [ -1.0 ]
    # incrementing draw-frame id; live_slot marks the slots it touched this frame so
    # the next miss can recycle a slot whose content is no longer on screen.
    mutable frame_id    : i32 [ 0 ]
    # true while a run (lldb) is live in this session — drives the play↔stop button.
    mutable running     : bool
    # armed after a run command is sent; the next return to our shell prompt means
    # the run ended (quit/errored) → clear running.
    mutable run_armed   : bool
    # the user scrolled away from the bottom (wheel/page/drag) → suspend cursor
    # auto-follow until they return to the bottom. max_scroll cached from draw.
    mutable user_scrolled : bool
    mutable max_scroll  : f32
    # epoch micros of the last resize — scroll_up won't feed scrollback within ~200ms of
    # it, so an app's resize-redraw scrolls don't leak its frame into history.
    mutable last_resize_us : i64 [ 0 ]

    # --- full VT/xterm emulator state (to host TUIs like claude code) ---
    # `screen` is the one live grid. while a full-screen TUI borrows it (alt screen),
    # the normal grid is stashed here and restored on exit.
    mutable alt_bak     : new TermCell [ 2048 * 2048 ]
    mutable in_alt      : bool
    # DECSTBM scroll region (inclusive rows); LF/IND/RI scroll within it.
    mutable scroll_top  : i32 [ 0  ]
    mutable scroll_bot  : i32 [ 23 ]
    # current pen (applied to every glyph written). packed rgb or -1 = default.
    mutable pen_fg      : i32 [ -1 ]
    mutable pen_bg      : i32 [ -1 ]
    mutable pen_attr    : i32 [ 0  ]
    mutable cursor_visible  : bool [ true ]
    mutable bracketed_paste : bool
    # DECCKM: when set (ESC[?1h), arrows/Home/End are sent as SS3 (ESC O A) not CSI
    # (ESC [ A). TUIs like claude code enable this; without it menu nav doesn't work.
    mutable app_cursor      : bool
    mutable alt_save_x  : i32 [ 0 ]
    mutable alt_save_y  : i32 [ 0 ]
    # UTF-8 decode accumulator (ground state, multibyte lead → continuation).
    mutable utf_need    : i32 [ 0 ]
    mutable utf_cp      : i32 [ 0 ]
    # CSI parameter collection: a fixed array of numeric params, a count, the
    # current index being typed, and the private-intro byte ('?'/'>'/'!') if any.
    mutable esc_priv    : i32 [ 0 ]
    mutable esc_pv      : array i32
    mutable esc_pc      : i32 [ 0 ]
    mutable esc_pi      : i32 [ 0 ]

    func init []
        scrollback  = list string []
        sb_cells    = array TermCell []
        sb_off      = array i32 []
        # screen is pre-allocated once (2048x2048 max) at construct; resize never
        # reallocates. only the rows*cols region in use is initialized.
        init_cells[ screen, rows * cols ]
        scroll_bot = rows - 1
        esc_pv     = array i32 []
        for [ i: i32 0, i < 16, i += 1 ]
            esc_pv.push[ 0 ]

    func start []
        if [ pty_fd >= 0 ] return
        pid = forkpty[ @pty_fd, null, null, null ]
        if [ pid == 0 ]
            setenv[ 'TERM', 'xterm-256color', 1 ]
            # we emulate 24-bit SGR (38;2;r;g;b) — advertise it so TUIs use true color
            setenv[ 'COLORTERM', 'truecolor', 1 ]
            if [ launch_cmd && launch_cmd.count > 0 ]
                # agent session (claude/gemini): exec the command directly via a
                # non-interactive shell — no PS1 prompt and no command echo, so the
                # console shows ONLY the agent's output (no "name> cmd" line eating a row).
                # pass the flag + command as cstr (.chars) — bare literals reach execl as
                # Au string objects, not char*, and bash reads garbage from them.
                dashc : string '-c'
                ec    : string 'exec {launch_cmd}'
                execl[ '/bin/bash', 'bash', dashc.chars, ec.chars, null ]
            el
                # prompt = the project node's label; --norc so bash keeps our PS1
                lbl : string (name && name.count > 0) ? name : 'sh'
                setenv[ 'PS1', '{lbl}> ', 1 ]
                norc : string '--norc'
                execl[ '/bin/bash', 'bash', norc.chars, null ]
            _exit[ 1 ]
        el [ pid < 0 ]
            puts 'ConsoleSession.start[{name}]: forkpty FAILED (pid={pid})'
        el
            # silenced: console render mode writes the UI to stdout, so a stray line
            # here scrolls the frame.
            #puts 'ConsoleSession.start[{name}]: pty_fd={pty_fd} pid={pid}'
            fcntl[ pty_fd, F_SETFL, O_NONBLOCK ]

    # fresh session: close the old shell (pty close → SIGHUP → bash exits), clear
    # the buffer, then start a new bash. used when a run is (re)launched.
    func restart []
        if [ pty_fd >= 0 ]
            close[ pty_fd ]
        pty_fd     = -1
        pid        = 0
        cx         = 0
        cy         = 0
        scroll     = 0.0
        esc_state  = 0
        clear_screen[]
        scrollback = list string []
        sb_cells   = array TermCell []
        sb_off     = array i32 []
        dirty      = true
        run_armed  = false
        start[]

    # blank one cell (flat index) to a space carrying the current background, so an
    # erase inside a colored region keeps that region's color (apps rely on this).
    func bl_cell [ i: i32 ]
        screen[i].ch   = 32
        screen[i].fg   = -1
        screen[i].bg   = pen_bg
        screen[i].attr = 0

    # copy cell src→dst (flat indices) within the active screen.
    func cp_cell [ dst: i32, src: i32 ]
        screen[dst].ch   = screen[src].ch
        screen[dst].fg   = screen[src].fg
        screen[dst].bg   = screen[src].bg
        screen[dst].attr = screen[src].attr

    # copy n cells src→dst (whole-buffer blit) — used to stash/restore the normal
    # screen when a full-screen TUI takes over the alt screen.
    func blit_cells [ dst: @TermCell, src: @TermCell, n: i32 ]
        for [ i: i32 0, i < n, i += 1 ]
            dst[i].ch   = src[i].ch
            dst[i].fg   = src[i].fg
            dst[i].bg   = src[i].bg
            dst[i].attr = src[i].attr

    # initialize a freshly-allocated buffer to blank, transparent cells (bg = -1 so
    # untouched cells draw nothing and the console's own background shows through).
    func init_cells [ buf: @TermCell, n: i32 ]
        for [ i: i32 0, i < n, i += 1 ]
            buf[i].ch   = 32
            buf[i].fg   = -1
            buf[i].bg   = -1
            buf[i].attr = 0

    func clear_screen []
        for [ i: i32 0, i < rows * cols, i += 1 ]
            screen[i].ch   = 32
            screen[i].fg   = -1
            screen[i].bg   = pen_bg
            screen[i].attr = 0
        cx = 0
        cy = 0

    # resolve an xterm-256 palette index to packed 0xRRGGBB.
    func pal256 [ n: i32 ] -> i32
        if [ n < 16 ]
            base : array i32 [ 0x000000, 0xcd0000, 0x00cd00, 0xcdcd00,
                               0x0000ee, 0xcd00cd, 0x00cdcd, 0xe5e5e5,
                               0x7f7f7f, 0xff0000, 0x00ff00, 0xffff00,
                               0x5c5cff, 0xff00ff, 0x00ffff, 0xffffff ]
            return base[ n ]
        if [ n < 232 ]
            i : i32 [ n - 16 ]
            r : i32 [ i / 36 ]
            g : i32 [ (i / 6) % 6 ]
            b : i32 [ i % 6 ]
            rv : i32 [ (r == 0) ? 0 : 55 + r * 40 ]
            gv : i32 [ (g == 0) ? 0 : 55 + g * 40 ]
            bv : i32 [ (b == 0) ? 0 : 55 + b * 40 ]
            return (rv << 16) | (gv << 8) | bv
        l : i32 [ (n - 232) * 10 + 8 ]
        return (l << 16) | (l << 8) | l

    # encode the codepoints of cells[off+c0 .. off+c1) into a UTF-8 string. works on
    # any TermCell buffer (the live screen or the scrollback color store).
    func cells_text [ cells: @TermCell, off: i32, c0: i32, c1: i32 ] -> string
        buf : local i8 [ (c1 - c0) * 4 + 1 ]
        bi  : i32 [ 0 ]
        for [ c: i32 c0, c < c1, c += 1 ]
            cp : i32 [ cells[off + c].ch ]
            if [ cp < 32 ] cp = 32
            if [ cp < 128 ]
                buf[bi] = i8[ cp ]
                bi += 1
            el [ cp < 2048 ]
                buf[bi]   = i8[ 192 | (cp >> 6) ]
                buf[bi+1] = i8[ 128 | (cp & 63) ]
                bi += 2
            el [ cp < 65536 ]
                buf[bi]   = i8[ 224 | (cp >> 12) ]
                buf[bi+1] = i8[ 128 | ((cp >> 6) & 63) ]
                buf[bi+2] = i8[ 128 | (cp & 63) ]
                bi += 3
            el
                buf[bi]   = i8[ 240 | (cp >> 18) ]
                buf[bi+1] = i8[ 128 | ((cp >> 12) & 63) ]
                buf[bi+2] = i8[ 128 | ((cp >> 6) & 63) ]
                buf[bi+3] = i8[ 128 | (cp & 63) ]
                bi += 4
        buf[bi] = 0
        return string[ @buf[0] ]

    # encode the codepoints of cells [c0,c1) on screen row r into a UTF-8 string.
    func cell_text [ r: i32, c0: i32, c1: i32 ] -> string
        return cells_text[ screen, r * cols, c0, c1 ]

    func cell_fg   [ r: i32, c: i32 ] -> i32   return screen[r * cols + c].fg
    func cell_bg   [ r: i32, c: i32 ] -> i32   return screen[r * cols + c].bg
    func cell_attr [ r: i32, c: i32 ] -> i32   return screen[r * cols + c].attr

    # scrollback line geometry: start index + cell length for line `li`.
    func sb_line_off [ li: i32 ] -> i32   return sb_off[ li ]
    func sb_line_len [ li: i32 ] -> i32
        nx : i32 [ (li + 1 < sb_off.count) ? sb_off[ li + 1 ] : sb_cells.count ]
        return nx - sb_off[ li ]

    # copy scrollback line `li`'s boxed cells into the contiguous scratch row and
    # return it, so the shared draw_cells (which wants a flat ref TermCell) can render
    # it. off into the result is always 0; len is sb_line_len[ li ].
    func sb_line_buf [ li: i32 ] -> @TermCell
        off : i32 [ sb_off[ li ] ]
        len : i32 [ sb_line_len[ li ] ]
        for [ c: i32 0, c < len && c < 2048, c += 1 ]
            sb_scratch[c].ch   = sb_cells[ off + c ].ch
            sb_scratch[c].fg   = sb_cells[ off + c ].fg
            sb_scratch[c].bg   = sb_cells[ off + c ].bg
            sb_scratch[c].attr = sb_cells[ off + c ].attr
        return sb_scratch

    func row_to_string [ r: i32 ] -> string
        return cell_text[ r, 0, cols ]

    # drawable width of live row `r`: 1 + the last column that ISN'T a fully-default cell
    # (space, default fg/bg, no attr). trailing default padding is trimmed so a line caches
    # at its content width — but a COLORED space (bg set, e.g. claude's footer bar) counts
    # as drawable, so the bar isn't trimmed away.
    func row_drawable [ r: i32 ] -> i32
        base : i32 [ r * cols ]
        for [ c: i32 cols - 1, c >= 0, c -= 1 ]
            i : i32 [ base + c ]
            if [ !(screen[i].ch == 32 && screen[i].fg == -1 && screen[i].bg == -1 && screen[i].attr == 0) ]
                return c + 1
        return 0

    # highest grid row that has any non-blank cell. used for content height so the
    # scrollable region reaches the app's bottom rows (input box / footer hints below
    # the cursor), instead of stopping at the cursor row. a cell counts as used if it
    # has a glyph OR a non-default background — TUI status bars (claude-code's "bypass
    # permissions" footer) are colored SPACES, which a char-only test would skip,
    # leaving the bar one line below the scrollable bottom and hidden.
    func last_row [] -> i32
        for [ r: i32 rows - 1, r >= 0, r -= 1 ]
            for [ c: i32 0, c < cols, c += 1 ]
                ch : i32 [ screen[r * cols + c].ch ]
                bg : i32 [ screen[r * cols + c].bg ]
                if [ (ch != 32 && ch != 0) || bg >= 0 ]
                    return r
        return 0

    # line model — the displayed content as one list of lines (scrollback then the
    # live screen rows). lets the console reuse the Editor's line/col selection.
    func line_count [] -> i32
        return scrollback.count + rows

    func line_get [ i: i32 ] -> string
        sc : i32 [ scrollback.count ]
        if [ i < sc ] return scrollback.value_by_index[ i ]
        return row_to_string[ i - sc ]

    # true when the cursor sits on our own shell prompt ('<name>> ') — i.e. bash is
    # idle, no foreground command running. used to detect a run ending/erroring.
    func at_prompt [] -> bool
        if [ cy < 0 || cy >= rows ] return false
        lbl : string (name && name.count > 0) ? name : 'sh'
        p   : string '{lbl}> '
        row : string row_to_string[ cy ]
        if [ row.index_of[ p ] != 0 ] return false
        # idle only when the cursor sits right after the prompt (nothing typed/echoed
        # after it — a command-echo line also starts with the prompt but has cx past it).
        return cx <= p.count

    # the currently-selected text over the line model (anchor→cursor), lines joined
    # with newlines. empty when there is no selection.
    func selection_text [] -> string
        if [ sel_line < 0 ] return ''
        before : bool [ anchor_line < sel_line || (anchor_line == sel_line && anchor_col <= sel_col) ]
        sl : i32 [ (before) ? anchor_line : sel_line ]
        sc : i32 [ (before) ? anchor_col  : sel_col ]
        el2 : i32 [ (before) ? sel_line : anchor_line ]
        ec : i32 [ (before) ? sel_col  : anchor_col ]
        out : string ''
        for [ li: i32 sl, li <= el2, li += 1 ]
            row : string line_get[ li ]
            a : i32 [ clamp[ (li == sl) ? sc : 0,         0, row.count ] ]
            b : i32 [ clamp[ (li == el2) ? ec : row.count, 0, row.count ] ]
            if [ b > a ] out = out + row.mid[ a, b - a ]
            if [ li < el2 ] out = out + '\n'
        return out

    # scroll the region up one line. only the normal buffer with a top-anchored
    # region feeds scrollback (the alt screen and inner regions never do).
    func scroll_up []
        # scrollback captures a line ONLY when the default region (full screen) scrolls
        # during genuine output. a resize shrinks the pty, the app's frame overflows and
        # its redraw scrolls — but that's rewriting existing lines, not new output, so it
        # must not feed history (it would leave a ghost copy of the frame above the live
        # one). suppress the feed for a moment after any resize; steady-state scrolls feed.
        quiet : bool [ (epoch_micros[] - last_resize_us) > 200000 ]
        if [ !in_alt && scroll_top == 0 && scroll_bot == rows - 1 && quiet ]
            scrollback.push[ row_to_string[ scroll_top ] ]
            # capture the line's color/attr cells in parallel (sb_off marks its start)
            sb_off.push[ sb_cells.count ]
            # store only the DRAWABLE cells — trailing default padding never accumulates in
            # history (smaller sb_cells, narrower cached canvas). sb_line_len = this count.
            dl   : i32 [ row_drawable[ scroll_top ] ]
            srow : i32 [ scroll_top * cols ]
            for [ c: i32 0, c < dl, c += 1 ]
                sb_cells.push[ TermCell [ ch: screen[srow + c].ch, fg: screen[srow + c].fg, bg: screen[srow + c].bg, attr: screen[srow + c].attr ] ]
        for [ r: i32 scroll_top, r < scroll_bot, r += 1 ]
            for [ c: i32 0, c < cols, c += 1 ]
                cp_cell[ r * cols + c, (r + 1) * cols + c ]
        for [ c: i32 0, c < cols, c += 1 ]
            bl_cell[ scroll_bot * cols + c ]

    # scroll the region down one line (RI at the top / IL).
    func scroll_down []
        for [ r: i32 scroll_bot, r > scroll_top, r -= 1 ]
            for [ c: i32 0, c < cols, c += 1 ]
                cp_cell[ r * cols + c, (r - 1) * cols + c ]
        for [ c: i32 0, c < cols, c += 1 ]
            bl_cell[ scroll_top * cols + c ]

    func insert_lines [ n: i32 ]
        if [ cy < scroll_top || cy > scroll_bot ] return
        for [ r: i32 scroll_bot, r >= cy + n, r -= 1 ]
            for [ c: i32 0, c < cols, c += 1 ]
                cp_cell[ r * cols + c, (r - n) * cols + c ]
        for [ r: i32 cy, r < cy + n && r <= scroll_bot, r += 1 ]
            for [ c: i32 0, c < cols, c += 1 ]
                bl_cell[ r * cols + c ]

    func delete_lines [ n: i32 ]
        if [ cy < scroll_top || cy > scroll_bot ] return
        for [ r: i32 cy, r <= scroll_bot - n, r += 1 ]
            for [ c: i32 0, c < cols, c += 1 ]
                cp_cell[ r * cols + c, (r + n) * cols + c ]
        for [ r: i32 scroll_bot - n + 1, r <= scroll_bot, r += 1 ]
            for [ c: i32 0, c < cols, c += 1 ]
                bl_cell[ r * cols + c ]

    func insert_chars [ n: i32 ]
        for [ c: i32 cols - 1, c >= cx + n, c -= 1 ]
            cp_cell[ cy * cols + c, cy * cols + (c - n) ]
        for [ c: i32 cx, c < cx + n && c < cols, c += 1 ]
            bl_cell[ cy * cols + c ]

    func delete_chars [ n: i32 ]
        for [ c: i32 cx, c < cols - n, c += 1 ]
            cp_cell[ cy * cols + c, cy * cols + (c + n) ]
        for [ c: i32 cols - n, c < cols, c += 1 ]
            bl_cell[ cy * cols + c ]

    func erase_chars [ n: i32 ]
        for [ c: i32 cx, c < cx + n && c < cols, c += 1 ]
            bl_cell[ cy * cols + c ]

    # write a glyph at the cursor under the current pen, wrapping at the right edge.
    func put_char [ cp: i32 ]
        if [ cx >= cols ]
            cx = 0
            if [ cy == scroll_bot ]
                scroll_up[]
            el [ cy < rows - 1 ]
                cy += 1
        i : i32 [ cy * cols + cx ]
        screen[i].ch   = cp
        screen[i].fg   = pen_fg
        screen[i].bg   = pen_bg
        screen[i].attr = pen_attr
        cx += 1

    func erase_display [ m: i32 ]
        if [ m == 0 ]
            for [ i: i32 cx, i < cols, i += 1 ]
                bl_cell[ cy * cols + i ]
            for [ r: i32 cy + 1, r < rows, r += 1 ]
                for [ j: i32 0, j < cols, j += 1 ]
                    bl_cell[ r * cols + j ]
        el [ m == 1 ]
            for [ r: i32 0, r < cy, r += 1 ]
                for [ j: i32 0, j < cols, j += 1 ]
                    bl_cell[ r * cols + j ]
            for [ i: i32 0, i <= cx, i += 1 ]
                bl_cell[ cy * cols + i ]
        el [ m == 3 ]
            # ED(3) = erase saved lines (scrollback) only; the grid is untouched. apps
            # send ESC[3J on a full repaint to drop history — without honoring it the old
            # rows stay in scrollback and re-render (duplicated banners on resize).
            scrollback = list string []
            sb_cells   = array TermCell []
            sb_off     = array i32 []
        el
            for [ i: i32 0, i < rows * cols, i += 1 ]
                bl_cell[ i ]

    func erase_line [ m: i32 ]
        if [ m == 0 ]
            for [ i: i32 cx, i < cols, i += 1 ]
                bl_cell[ cy * cols + i ]
        el [ m == 1 ]
            for [ i: i32 0, i <= cx, i += 1 ]
                bl_cell[ cy * cols + i ]
        el
            for [ i: i32 0, i < cols, i += 1 ]
                bl_cell[ cy * cols + i ]

    # SGR: walk the params, updating the pen (colors + attributes).
    func sgr []
        if [ esc_pc == 0 ]
            pen_fg   = -1
            pen_bg   = -1
            pen_attr = 0
            return
        i : i32 [ 0 ]
        while [ i < esc_pc ]
            v : i32 [ esc_pv[i] ]
            if [ v == 0 ]
                pen_fg   = -1
                pen_bg   = -1
                pen_attr = 0
            el [ v == 1 ]
                pen_attr = pen_attr | 1
            el [ v == 2 ]
                pen_attr = pen_attr | 8
            el [ v == 4 ]
                pen_attr = pen_attr | 2
            el [ v == 7 ]
                pen_attr = pen_attr | 4
            el [ v == 22 ]
                pen_attr = pen_attr & (~9)
            el [ v == 24 ]
                pen_attr = pen_attr & (~2)
            el [ v == 27 ]
                pen_attr = pen_attr & (~4)
            el [ v >= 30 && v <= 37 ]
                pen_fg = pal256[ v - 30 ]
            el [ v == 38 ]
                if [ i + 2 < esc_pc && esc_pv[i + 1] == 5 ]
                    pen_fg = pal256[ esc_pv[i + 2] ]
                    i += 2
                el [ i + 4 < esc_pc && esc_pv[i + 1] == 2 ]
                    pen_fg = (esc_pv[i + 2] << 16) | (esc_pv[i + 3] << 8) | esc_pv[i + 4]
                    i += 4
            el [ v == 39 ]
                pen_fg = -1
            el [ v >= 40 && v <= 47 ]
                pen_bg = pal256[ v - 40 ]
            el [ v == 48 ]
                if [ i + 2 < esc_pc && esc_pv[i + 1] == 5 ]
                    pen_bg = pal256[ esc_pv[i + 2] ]
                    i += 2
                el [ i + 4 < esc_pc && esc_pv[i + 1] == 2 ]
                    pen_bg = (esc_pv[i + 2] << 16) | (esc_pv[i + 3] << 8) | esc_pv[i + 4]
                    i += 4
            el [ v == 49 ]
                pen_bg = -1
            el [ v >= 90 && v <= 97 ]
                pen_fg = pal256[ v - 90 + 8 ]
            el [ v >= 100 && v <= 107 ]
                pen_bg = pal256[ v - 100 + 8 ]
            i += 1

    # enter the alternate screen buffer (full-screen TUIs): save cursor, swap to the
    # alt buffer and clear it. leave_alt swaps back and restores the cursor.
    func enter_alt []
        if [ in_alt ] return
        alt_save_x = cx
        alt_save_y = cy
        # stash the normal grid; the TUI gets a cleared screen
        blit_cells[ alt_bak, screen, rows * cols ]
        in_alt     = true
        pen_fg     = -1
        pen_bg     = -1
        pen_attr   = 0
        scroll_top = 0
        scroll_bot = rows - 1
        clear_screen[]

    func leave_alt []
        if [ !in_alt ] return
        # restore the stashed normal grid
        blit_cells[ screen, alt_bak, rows * cols ]
        in_alt     = false
        cx         = alt_save_x
        cy         = alt_save_y
        scroll_top = 0
        scroll_bot = rows - 1

    func set_mode [ on: bool ]
        if [ esc_priv == 63 ]
            m : i32 [ (esc_pc > 0) ? esc_pv[0] : 0 ]
            if [ m == 1 ]
                app_cursor = on
            el [ m == 25 ]
                cursor_visible = on
            el [ m == 1049 || m == 47 || m == 1047 ]
                if [ on ]
                    enter_alt[]
                el
                    leave_alt[]
            el [ m == 2004 ]
                bracketed_paste = on

    # RIS — full reset to a clean main screen.
    func reset_all []
        if [ in_alt ] leave_alt[]
        pen_fg     = -1
        pen_bg     = -1
        pen_attr   = 0
        scroll_top = 0
        scroll_bot = rows - 1
        app_cursor = false
        scrollback = list string []
        sb_cells   = array TermCell []
        sb_off     = array i32 []
        clear_screen[]

    # dispatch a completed CSI sequence by its final byte.
    func dispatch_csi [ c: i32 ]
        p0 : i32 [ (esc_pc > 0) ? esc_pv[0] : 0 ]
        p1 : i32 [ (esc_pc > 1) ? esc_pv[1] : 0 ]
        n  : i32 [ (p0 > 0) ? p0 : 1 ]
        if [ c == 65 ]
            cy = clamp[ cy - n, 0, rows - 1 ]
        el [ c == 66 ]
            cy = clamp[ cy + n, 0, rows - 1 ]
        el [ c == 67 ]
            cx = clamp[ cx + n, 0, cols - 1 ]
        el [ c == 68 ]
            cx = clamp[ cx - n, 0, cols - 1 ]
        el [ c == 69 ]
            cy = clamp[ cy + n, 0, rows - 1 ]
            cx = 0
        el [ c == 70 ]
            cy = clamp[ cy - n, 0, rows - 1 ]
            cx = 0
        el [ c == 71 || c == 96 ]
            cx = clamp[ p0 - 1, 0, cols - 1 ]
        el [ c == 72 || c == 102 ]
            cy = clamp[ ((p0 > 0) ? p0 - 1 : 0), 0, rows - 1 ]
            cx = clamp[ ((p1 > 0) ? p1 - 1 : 0), 0, cols - 1 ]
        el [ c == 100 ]
            cy = clamp[ ((p0 > 0) ? p0 - 1 : 0), 0, rows - 1 ]
        el [ c == 74 ]
            erase_display[ p0 ]
        el [ c == 75 ]
            erase_line[ p0 ]
        el [ c == 76 ]
            insert_lines[ n ]
        el [ c == 77 ]
            delete_lines[ n ]
        el [ c == 80 ]
            delete_chars[ n ]
        el [ c == 64 ]
            insert_chars[ n ]
        el [ c == 88 ]
            erase_chars[ n ]
        el [ c == 83 ]
            for [ k: i32 0, k < n, k += 1 ]
                scroll_up[]
        el [ c == 84 ]
            for [ k: i32 0, k < n, k += 1 ]
                scroll_down[]
        el [ c == 114 ]
            t : i32 [ (p0 > 0) ? p0 - 1 : 0 ]
            b : i32 [ (p1 > 0) ? p1 - 1 : rows - 1 ]
            if [ t < 0 ] t = 0
            if [ b > rows - 1 ] b = rows - 1
            if [ t < b ]
                scroll_top = t
                scroll_bot = b
                cx = 0
                cy = scroll_top
        el [ c == 109 ]
            sgr[]
        el [ c == 104 ]
            set_mode[ true ]
        el [ c == 108 ]
            set_mode[ false ]
        el [ c == 115 ]
            cur_save_x = cx
            cur_save_y = cy
        el [ c == 117 ]
            cx = cur_save_x
            cy = cur_save_y
        el [ c == 110 ]
            if [ p0 == 6 ]
                send_esc[ '[{cy + 1};{cx + 1}R' ]
            el [ p0 == 5 ]
                send_esc[ '[0n' ]
        el [ c == 99 ]
            send_esc[ '[?1;2c' ]

    func process_byte [ c: i32 ]
        # UTF-8 continuation bytes assemble the pending codepoint.
        if [ utf_need > 0 ]
            if [ c >= 128 && c < 192 ]
                utf_cp = (utf_cp << 6) | (c & 63)
                utf_need -= 1
                if [ utf_need == 0 ] put_char[ utf_cp ]
                return
            utf_need = 0

        if [ esc_state == 1 ]
            esc_state = 0
            if [ c == 91 ]
                esc_state = 2
                esc_priv  = 0
                esc_pc    = 1
                esc_pi    = 0
                esc_pv[0] = 0
            el [ c == 93 ]
                esc_state = 4
            el [ c == 40 || c == 41 || c == 42 || c == 43 ]
                esc_state = 6
            el [ c == 99 ]
                reset_all[]
            el [ c == 55 ]
                cur_save_x = cx
                cur_save_y = cy
            el [ c == 56 ]
                cx = cur_save_x
                cy = cur_save_y
            el [ c == 77 ]
                if [ cy == scroll_top ]
                    scroll_down[]
                el [ cy > 0 ]
                    cy -= 1
            el [ c == 68 ]
                if [ cy == scroll_bot ]
                    scroll_up[]
                el [ cy < rows - 1 ]
                    cy += 1
            el [ c == 69 ]
                cx = 0
                if [ cy == scroll_bot ]
                    scroll_up[]
                el [ cy < rows - 1 ]
                    cy += 1
            return

        if [ esc_state == 2 ]
            if [ c >= 48 && c <= 57 ]
                esc_pv[esc_pi] = esc_pv[esc_pi] * 10 + (c - 48)
                return
            if [ c == 59 ]
                esc_pi += 1
                if [ esc_pi < 16 ]
                    esc_pv[esc_pi] = 0
                    esc_pc = esc_pi + 1
                el
                    esc_pi = 15
                return
            if [ c == 63 || c == 62 || c == 33 ]
                esc_priv = c
                return
            if [ c == 32 || c == 34 || c == 36 || c == 39 ]
                return
            esc_state = 0
            dispatch_csi[ c ]
            return

        if [ esc_state == 4 ]
            if [ c == 7 ]
                esc_state = 0
            el [ c == 27 ]
                esc_state = 5
            return
        if [ esc_state == 5 ]
            esc_state = (c == 92) ? 0 : 4
            return
        if [ esc_state == 6 ]
            esc_state = 0
            return

        if [ c == 27 ]
            esc_state = 1
        el [ c == 13 ]
            cx = 0
        el [ c == 10 ]
            if [ cy == scroll_bot ]
                scroll_up[]
            el [ cy < rows - 1 ]
                cy += 1
        el [ c == 8 ]
            if [ cx > 0 ] cx -= 1
        el [ c == 9 ]
            cx = (cx / 8 + 1) * 8
            if [ cx >= cols ] cx = cols - 1
        el [ c == 7 ]
            return
        el [ c >= 32 && c < 127 ]
            put_char[ c ]
        el [ c >= 240 ]
            utf_need = 3
            utf_cp   = c & 7
        el [ c >= 224 ]
            utf_need = 2
            utf_cp   = c & 15
        el [ c >= 192 ]
            utf_need = 1
            utf_cp   = c & 31

    # resize the grid to (nr, nc) within the pre-allocated 2048x2048 buffer — no
    # reallocation. the row stride changes with cols, so old cells land at stale
    # offsets: blank the grid and let the child repaint on SIGWINCH (no copy).
    func resize [ nr_in: i32, nc_in: i32 ]
        nr : i32 [ (nr_in < 1) ? 1 : nr_in ]
        nc : i32 [ (nc_in < 1) ? 1 : nc_in ]
        if [ nr > 2048 ] nr = 2048
        if [ nc > 2048 ] nc = 2048
        if [ nr == rows && nc == cols ] return
        # mark the resize time — scroll_up suppresses scrollback feeding for a moment
        # after, so the app's resize-redraw scrolls don't leak its frame into history.
        last_resize_us = epoch_micros[]
        orows : i32 [ rows ]
        ocols : i32 [ cols ]
        cols = nc
        rows = nr
        # preserve existing content across a resize. only a stride (cols) change makes the
        # r*cols+c offsets invalid, so only then re-blank the whole grid. a height-only
        # change keeps the rows where they are (the app may NOT repaint a taller window —
        # it's just more space — so blanking everything would lose the text until the next
        # repaint); only blank rows newly brought into view.
        if [ ocols != nc ]
            # a stride (cols) change shifts every r*cols+c offset, so the grid can't be
            # reinterpreted in place. snapshot the old visible region, blank the new grid,
            # then write the snapshot back at the new stride — PRESERVING on-screen history.
            # (blanking and waiting for the child to repaint lost everything above the
            # prompt: readline only redraws its own line on SIGWINCH, not the lines above.)
            cc : i32 [ (ocols < nc) ? ocols : nc ]
            cr : i32 [ (orows < nr) ? orows : nr ]
            tmp : array TermCell [ ]
            for [ i: i32 0, i < cr * cc, i += 1 ]
                tmp.push[ TermCell [ ] ]
            for [ r: i32 0, r < cr, r += 1 ]
                for [ c: i32 0, c < cc, c += 1 ]
                    s : i32 [ r * ocols + c ]
                    d : i32 [ r * cc + c ]
                    tmp[d].ch   = screen[s].ch
                    tmp[d].fg   = screen[s].fg
                    tmp[d].bg   = screen[s].bg
                    tmp[d].attr = screen[s].attr
            init_cells[ screen, rows * cols ]
            for [ r: i32 0, r < cr, r += 1 ]
                for [ c: i32 0, c < cc, c += 1 ]
                    s : i32 [ r * cc + c ]
                    d : i32 [ r * nc + c ]
                    screen[d].ch   = tmp[s].ch
                    screen[d].fg   = tmp[s].fg
                    screen[d].bg   = tmp[s].bg
                    screen[d].attr = tmp[s].attr
        el [ nr > orows ]
            init_cells[ @screen[ orows * cols ], (nr - orows) * cols ]
        # NOTE: do NOT flush the per-line cache here. it's keyed by content-hash and sized
        # by each line's own drawable width — neither depends on rows. a cols change reflows
        # the cells (new hashes → natural miss); a height-only resize keeps the lines valid.
        # flushing on every resize made an animating pane re-rasterize all lines per frame.
        scroll_top = 0
        scroll_bot = rows - 1
        if [ cx >= cols ] cx = cols - 1
        if [ cy >= rows ] cy = rows - 1
        ws : local u16 [ 4 ]
        ws[0] = u16[ rows ]
        ws[1] = u16[ cols ]
        ws[2] = 0
        ws[3] = 0
        if [ pty_fd >= 0 ]
            ioctl[ pty_fd, TIOCSWINSZ, @ws[0] ]
        dirty = true

    func read_output []
        if [ pty_fd < 0 ] return
        read_calls += 1
        buf : local i8 [ 2 ]
        buf[1] = 0
        got : string ''
        for [ i: i32 0, i < 4096, i += 1 ]
            nr : i32 [ read[ pty_fd, @buf[0], 1 ] ]
            if [ nr <= 0 ] break
            dirty = true
            got = got + string[ @buf[0] ]
            process_byte[ (i32 buf[0]) & 255 ]
        # a run that's returned to our shell prompt has ended (lldb quit, or the
        # build/run errored and bash bounced back) → clear running so the button
        # reverts to play. checked BEFORE flushing a pending command, whose own
        # initial prompt would otherwise read as a return.
        if [ run_armed && at_prompt[] ]
            running   = false
            run_armed = false
        # shell is ready once it has emitted (its prompt) — now in raw mode, so
        # sending the queued command echoes exactly once via readline.
        if [ got.count > 0 && pending && pending.count > 0 ]
            write_input[ pending + '\r' ]
            pending = ''
            if [ running ] run_armed = true

    # drain bytes from an external fd (a debug inferior's PTY master, owned by dbg)
    # straight into the terminal emulator. same byte pump as read_output but for a
    # session whose output comes from lldb rather than our bash — so no prompt /
    # run-armed bookkeeping. called on the main (render) thread, so the screen and
    # scrollback stay single-threaded.
    func feed_fd [ fd: i32 ]
        if [ fd < 0 ] return
        buf : local i8 [ 2 ]
        buf[1] = 0
        for [ i: i32 0, i < 4096, i += 1 ]
            nr : i32 [ read[ fd, @buf[0], 1 ] ]
            if [ nr <= 0 ] break
            dirty = true
            process_byte[ (i32 buf[0]) & 255 ]

    # push a host-generated message (e.g. "[process exited]") through the emulator,
    # as if the inferior had printed it. ascii only; main-thread caller.
    func print_text [ s: string ]
        if [ !s ] return
        for [ i: i32 0, i < s.count, i += 1 ]
            process_byte[ (i32 s.chars[i]) & 255 ]
        dirty = true

    func write_input [ data: string ]
        if [ pty_fd < 0 ] return
        write[ pty_fd, data.chars, data.count ]

    # write ESC followed by `tail` to the pty. built from an explicit 0x1b byte + the
    # plain tail so we sidestep the lexer treating '\x1b[...' as a hex char literal
    # (which collapses 'ESC [ Z' to the single byte 0x1b). tail carries no \x escapes.
    func send_esc [ tail: string ]
        if [ pty_fd < 0 ] return
        n : i32 [ tail->count ]
        buf : local i8 [ n + 2 ]
        buf[0] = i8[ 27 ]
        for [ i: i32 0, i < n, i += 1 ]
            buf[i + 1] = tail.chars[i]
        write[ pty_fd, @buf[0], n + 1 ]


# one pooled render of a single scrollback line. `li` is the scrollback index it
# currently holds (-1 = free for reuse). scrollback content is immutable per index,
# so a cached line stays valid until it scrolls out of view and its slot is recycled.
class TermLineCache
    mutable canvas : Canvas
    mutable li     : i32 [ -1 ]
    # content hash of the row this canvas holds. scrollback lines are immutable so li
    # alone keys them. LIVE grid rows are content-addressed by hash: a row blits the
    # canvas holding its content from ANYWHERE in the pool, so a scrolled grid reuses
    # last frame's renders (only genuinely new content rasterizes). -1 = never rendered.
    mutable hash   : i64 [ -1 ]
    # last draw frame this slot was used (for live rows) — lets us reclaim slots whose
    # content scrolled off (frame != current) without disturbing still-visible ones.
    mutable frame  : i32 [ -1 ]

Layer TermLayer
    func draw [ cv: Canvas ]
        con : cast Console [ parent ]
        if [ !con ] return
        s : ConsoleSession con.session[]
        if [ !s ] return
        # (run dispatch moved to the app's per-frame loop in orbiter.ag — a
        # collapsed console never paints, so it can't live here.)
        if [ label_size > 0.0 ] cv.font_size[ i32[label_size] ]
        # integer line height: rows sit on a fixed pixel grid so scrolling steps by
        # whole lines and lines never jiggle relative to each other (fractional lh
        # would round consecutive rows to alternating 18/19px gaps). standard console.
        lh : f32 [ round[ cv.get_line_height[] * ((label_height > 0.0) ? label_height : 1.0) ] ]
        if [ lh < 1.0 ] lh = 1.0
        x0 : f32 [ bounds.x ]
        y0 : f32 [ bounds.y ]

        flt     : string con.filter[]
        has_flt : bool [ flt && flt.count > 0 ]

        if [ s.pty_fd < 0 ]
            if [ !con.feed ] return
            n      : i32 [ con.feed.count ]
            max_s  : f32 [ maxf[ f32[n] * lh - bounds.h, 0.0 ] ]
            # filtered lines render consecutively from the top (no bottom-anchor scroll).
            dr     : i32 [ 0 ]
            for [ li: i32 0, li < n, li += 1 ]
                ln : string con.feed.value_by_index[ li ]
                if [ has_flt && ln.index_of[ flt ] < 0 ] continue
                y : f32 [ y0 + f32[dr] * lh - ((has_flt) ? 0.0 : max_s) ]
                dr += 1
                if [ y + lh < bounds.y ] continue
                if [ y > bounds.y + bounds.h ] break
                cv.fill_color[ '#ccc' ]
                cv.draw_text[ ln,
                    rect [ x: x0, y: y, w: bounds.w, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            cv.paint[]
            return

        # output is drained off the render path (orbiter.on_render) so this draw
        # only runs when the screen actually changed; no per-frame forcing here.
        cw       : f32 [ cv.measure_text[ 'x' ].w ]
        sc_count : i32 [ s.scrollback.count ]

        # match the emulator grid to the pane so the child app lays out to the real
        # size (and gets a SIGWINCH on changes). guarded so it only reallocs on change.
        if [ cw > 0.0 && lh > 0.0 ]
            dcols : i32 [ i32[ bounds.w / cw ] ]
            drows : i32 [ i32[ bounds.h / lh ] ]
            if [ dcols >= 2 && drows >= 2 && (dcols != s.cols || drows != s.rows) ]
                s.resize[ drows, dcols ]

        # filtered view: only lines (scrollback + live grid) containing the filter,
        # rendered consecutively from the top. no scroll/cursor while filtering.
        if [ has_flt ]
            dr : i32 [ 0 ]
            for [ li: i32 0, li < sc_count, li += 1 ]
                ln : string s.scrollback.value_by_index[ li ]
                if [ ln.index_of[ flt ] < 0 ] continue
                y : f32 [ y0 + f32[dr] * lh ]
                dr += 1
                if [ y + lh < bounds.y ] continue
                if [ y > bounds.y + bounds.h ] break
                cv.fill_color[ '#fff' ]
                cv.draw_text[ ln, rect [ x: x0, y: y, w: bounds.w, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            for [ r: i32 0, r < s.rows, r += 1 ]
                ln : string s.row_to_string[ r ]
                if [ ln.index_of[ flt ] < 0 ] continue
                y : f32 [ y0 + f32[dr] * lh ]
                dr += 1
                if [ y + lh < bounds.y ] continue
                if [ y > bounds.y + bounds.h ] break
                cv.fill_color[ '#fff' ]
                cv.draw_text[ ln, rect [ x: x0, y: y, w: bounds.w, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            cv.paint[]
            return

        # the alt screen is standalone (no scrollback above it). base = the rows of
        # scrollback shown above the live grid (0 on the alt buffer).
        base     : i32 [ (s.in_alt) ? 0 : sc_count ]
        # the live screen is ALWAYS `rows` lines — a real terminal's screen is fixed
        # height, so a blanked line is still a line. counting only non-blank rows would
        # shrink the content when an app erases its bottom line (footer), resizing the
        # scrollbar and shifting the whole view. the grid is sized to the pane, so this
        # is exactly scrollback + one viewport.
        total_h  : f32 [ f32[base + s.rows] * lh ]
        max_s    : f32 [ maxf[ total_h - bounds.h, 0.0 ] ]

        s.max_scroll = max_s
        # auto-follow: stick to the bottom of the content (so the app's last rows —
        # input box, footer — are visible), NOT just the cursor. suspended while
        # dragging the thumb or after the user scrolled up to read history.
        if [ !s.scroll_dragging && !s.user_scrolled ]
            s.scroll = max_s
        if [ s.scroll < 0.0 ]
            s.scroll = 0.0
        if [ s.scroll > max_s ]
            s.scroll = max_s
        # back at the bottom → resume auto-follow
        if [ s.scroll >= max_s - 1.0 ]
            s.user_scrolled = false

        # record the top visible line for this paint — set_scroll compares against it
        # so a scroll that doesn't change the first line skips the repaint entirely.
        s.first_line  = (lh > 0.0) ? i32[ round[ s.scroll / lh ] ] : 0

        # cache metrics for the mouse→cell mapping; feed content_h/scroll.y to the
        # shared ScrollLayer (it reads them off the element).
        s.lh_cache    = lh
        s.cw_cache    = cw
        con.content_h = total_h
        con.scroll.y  = s.scroll

        # clip to the content bounds so a partially-scrolled top/bottom row doesn't
        # bleed above into the title bar (or below the pane). the shaders honor crop.
        # crop is WORLD-space px: transform offset + local bounds (the embedded
        # console sits deep in the pane tree, so local != world here).
        wtx : f32 [ cv.transform_tx[] ]
        wty : f32 [ cv.transform_ty[] ]
        cv.set_crop[ wtx + bounds.x, wty + bounds.y, wtx + bounds.x + bounds.w, wty + bounds.y + bounds.h ]

        # selection highlight behind the text — shared render with the editor.
        cv.draw_selection[ x0, y0, lh, cw, s.scroll, bounds.y, bounds.w, bounds.h,
            s.anchor_line, s.anchor_col, s.sel_line, s.sel_col, rgba['#264f78'] ]

        # per-line cache: each visible line rasterizes ONCE into a content-width canvas
        # keyed by its drawable cells, then composites every frame. an unchanged line just
        # composites (these batch into the one open main render pass — no per-line submit);
        # only a CHANGED line re-rasterizes, the lone path that pays the text_vbo cost. a
        # cw/lh change (font/reflow) isn't in the hash, so flush the pool when it changes.
        fs : i32 [ (label_size > 0.0) ? i32[label_size] : 0 ]
        s.frame_id   += 1
        if [ !s.sb_lines ]   s.sb_lines   = array TermLineCache [ alloc: 64 ]
        if [ !s.live_lines ] s.live_lines = array TermLineCache [ alloc: 64 ]
        if [ cw != s.cache_cw || lh != s.cache_lh ]
            for [ slc: TermLineCache ] in s.sb_lines
                slc.li = -1
            for [ slc: TermLineCache ] in s.live_lines
                slc.li   = -1
                slc.hash = -1
            s.cache_cw = cw
            s.cache_lh = lh

        if [ !s.in_alt && sc_count > 0 ]
            # visible scrollback range from the scroll offset — O(visible), not O(history).
            last_li : i32 [ sc_count - 1 ]
            vlo : i32 [ clamp[ i32[ (s.scroll - lh) / lh ], 0, last_li ] ]
            vhi : i32 [ clamp[ i32[ (s.scroll + bounds.h) / lh ] + 1, 0, last_li ] ]
            # recycle slots whose line scrolled out of view (pool stays at the visible count)
            for [ slc: TermLineCache ] in s.sb_lines
                if [ slc.li >= 0 && (slc.li < vlo || slc.li > vhi) ]
                    slc.li = -1
            for [ li: i32 vlo, li <= vhi, li += 1 ]
                y : f32 [ y0 + f32[li] * lh - s.scroll ]
                if [ y + lh < bounds.y ] continue
                if [ y > bounds.y + bounds.h ] break
                slc : sb_slot[ cv, s, li, fs, lh, cw ]
                if [ slc && slc.canvas ]
                    cv.draw_canvas[ slc.canvas, x0, round[ y ], f32[ slc.canvas.content_w ], lh ]

        for [ r: i32 0, r < s.rows, r += 1 ]
            y : f32 [ y0 + f32[base + r] * lh - s.scroll ]
            if [ y + lh < bounds.y ] continue
            if [ y > bounds.y + bounds.h ] break
            lvc : live_slot[ cv, s, r, fs, lh, cw ]
            if [ lvc && lvc.canvas ]
                cv.draw_canvas[ lvc.canvas, x0, round[ y ], f32[ lvc.canvas.content_w ], lh ]

        # underline the hovered path:line token (set in on_move) so it reads as a link.
        # drawn after the line blits so it sits on top, in the same content-space y as
        # the rows (line index → y0 + line*lh - scroll, valid for scrollback + live).
        if [ s.hover_link_line >= 0 ]
            uy : f32 [ y0 + f32[ s.hover_link_line ] * lh - s.scroll ]
            if [ uy + lh > bounds.y && uy < bounds.y + bounds.h ]
                ux0 : f32 [ x0 + f32[ s.link_c0 ] * cw ]
                uw  : f32 [ f32[ s.link_c1 - s.link_c0 ] * cw ]
                cv.fill_color[ '#6cb6ff' ]
                cv.stroke_width[ 0.0 ]
                cv.rect_to[ ux0, round[ uy + lh - 2.0 ], uw, 1.0 ]

        cv.paint[]
        if [ s.cursor_visible ]
            cur_px : f32 [ x0 + f32[s.cx] * cw ]
            cur_py : f32 [ y0 + f32[base + s.cy] * lh - s.scroll ]
            cv.fill_color [ '#ffffff99' ]
            cv.stroke_width[ 0.0 ]
            cv.rect_to     [ cur_px, cur_py, cw, lh ]
            cv.paint[]
        cv.clear_crop[]

    # one screen row rendered as colored runs: consecutive cells sharing fg/bg/attr
    # draw as a single text span (and a bg rect when the bg isn't the default).
    # render n cells from `cells` starting at `off` as colored runs (consecutive cells
    # sharing fg/bg/attr draw as one text span, with a bg rect when bg isn't default).
    # used by both the live grid (screen) and the scrollback color store.
    func draw_cells [ cv: Canvas, s: ConsoleSession, cells: @TermCell, off: i32, n: i32, x0: f32, y: f32, lh: f32, cw: f32 ]
        if [ n <= 0 ] return
        c : i32 [ 0 ]
        while [ c < n ]
            fg : i32 [ cells[off + c].fg ]
            bg : i32 [ cells[off + c].bg ]
            at : i32 [ cells[off + c].attr ]
            c2 : i32 [ c + 1 ]
            while [ c2 < n && cells[off + c2].fg == fg && cells[off + c2].bg == bg && cells[off + c2].attr == at ]
                c2 += 1
            inv : bool [ (at & 4) != 0 ]
            rfg : i32 [ (inv) ? ((bg < 0) ? 0x000000 : bg) : ((fg < 0) ? 0xdddddd : fg) ]
            rbg : i32 [ (inv) ? ((fg < 0) ? 0xdddddd : fg) : bg ]
            rx : f32 [ x0 + f32[c] * cw ]
            rw : f32 [ f32[c2 - c] * cw ]
            if [ rbg >= 0 ]
                cv.fill_color[ col_of[ rbg ] ]
                cv.stroke_width[ 0.0 ]
                cv.rect_to[ rx, y, rw, lh ]
                cv.paint[]
            # skip the text pass for an all-space run — it draws nothing but still
            # builds the string + runs the whole glyph/draw_text pipeline.
            blank : bool [ true ]
            for [ ci: i32 c, ci < c2 && blank, ci += 1 ]
                if [ cells[off + ci].ch != 32 ] blank = false
            if [ !blank ]
                txt : string s.cells_text[ cells, off, c, c2 ]
                cv.fill_color[ col_of[ rfg ] ]
                cv.draw_text[ txt, rect [ x: rx, y: y, w: rw + cw, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            c = c2

    func draw_row [ cv: Canvas, s: ConsoleSession, r: i32, x0: f32, y: f32, lh: f32, cw: f32 ]
        draw_cells[ cv, s, s.screen, r * s.cols, s.cols, x0, y, lh, cw ]

    # return the pooled render for scrollback line `li`: a cache hit returns the
    # existing slot (caller just blits it); a miss claims a free/grown slot and
    # rasterizes the line's cells into it at local origin. recycled slots (li=-1)
    # are reused so the pool never exceeds the on-screen line count.
    func sb_slot [ cv: Canvas, s: ConsoleSession, li: i32, fs: i32, lh: f32, cw: f32 ] -> TermLineCache
        # empty line: no slot, no canvas, no raster — the caller draws nothing.
        if [ s.sb_line_len[ li ] <= 0 ] return null
        for [ slc: TermLineCache ] in s.sb_lines
            if [ slc.li == li ] return slc
        use : TermLineCache [ null ]
        for [ slc: TermLineCache ] in s.sb_lines
            if [ slc.li < 0 ]
                use = slc
                break
        if [ !use ]
            use = TermLineCache [ ]
            s.sb_lines.push[ use ]
        len  : i32 [ s.sb_line_len[ li ] ]
        cw_i : i32 [ i32[ ceil[ f32[len] * cw + cw ] ] ]
        if [ cw_i < 1 ] cw_i = 1
        lh_i : i32 [ i32[ ceil[ lh ] ] + 1 ]
        if [ !use.canvas ]
            use.canvas = Canvas [ vk: cv.vk, w: cv.w, format: Pixel.rgba8, width: cw_i, height: lh_i, load_existing: true ]
            use.canvas.update[]
        el [ use.canvas.content_w != cw_i || use.canvas.content_h != lh_i ]
            use.canvas.resize[ cw_i, lh_i ]
        use.canvas.reset[ vec4f [ 0.0, 0.0, 0.0, 0.0 ] ]
        if [ fs > 0 ] use.canvas.font_size[ fs ]
        draw_cells[ use.canvas, s, s.sb_line_buf[ li ], 0, len, 0.0, 0.0, lh, cw ]
        use.canvas.paint[]
        use.li = li
        return use

    # content hash of live grid row `r` — ch/fg/bg/attr of every cell. compared per
    # frame so an unchanged row blits its cached canvas instead of re-rasterizing.
    func row_hash [ s: ConsoleSession, r: i32, n: i32 ] -> i64
        h    : i64 [ i64[ n ] ]
        base : i32 [ r * s.cols ]
        for [ c: i32 0, c < n, c += 1 ]
            idx : i32 [ base + c ]
            h = h * 131 + i64[ s.screen[ idx ].ch ]
            h = h * 131 + i64[ s.screen[ idx ].fg ]
            h = h * 131 + i64[ s.screen[ idx ].bg ]
            h = h * 131 + i64[ s.screen[ idx ].attr ]
        return h

    # content-addressed render of LIVE grid row `r`. a hit = any pooled canvas already
    # holding this exact content (hash), no matter which row rendered it — so when the
    # grid scrolls, last frame's line canvases are reused (blitted) and only genuinely
    # new content rasterizes. a miss recycles a slot whose content scrolled off (frame
    # != current) or grows the pool.
    func live_slot [ cv: Canvas, s: ConsoleSession, r: i32, fs: i32, lh: f32, cw: f32 ] -> TermLineCache
        # trim trailing default cells: cache keyed on the DRAWABLE content only, so lines
        # differing only in padding share a canvas, and the canvas is content-width.
        dl : i32 [ s.row_drawable[ r ] ]
        if [ dl <= 0 ] return null
        h : i64 [ row_hash[ s, r, dl ] ]
        for [ slot: TermLineCache ] in s.live_lines
            if [ slot.canvas && slot.hash == h ]
                slot.frame = s.frame_id
                return slot
        use : TermLineCache [ null ]
        for [ slot: TermLineCache ] in s.live_lines
            if [ slot.frame != s.frame_id ]
                use = slot
                break
        if [ !use ]
            use = TermLineCache [ ]
            s.live_lines.push[ use ]
        cw_i : i32 [ i32[ ceil[ f32[dl] * cw + cw ] ] ]
        if [ cw_i < 1 ] cw_i = 1
        lh_i : i32 [ i32[ ceil[ lh ] ] + 1 ]
        if [ !use.canvas ]
            use.canvas = Canvas [ vk: cv.vk, w: cv.w, format: Pixel.rgba8, width: cw_i, height: lh_i, load_existing: true ]
            use.canvas.update[]
        el [ use.canvas.content_w != cw_i || use.canvas.content_h != lh_i ]
            use.canvas.resize[ cw_i, lh_i ]
        use.canvas.reset[ vec4f [ 0.0, 0.0, 0.0, 0.0 ] ]
        if [ fs > 0 ] use.canvas.font_size[ fs ]
        draw_cells[ use.canvas, s, s.screen, r * s.cols, dl, 0.0, 0.0, lh, cw ]
        use.canvas.paint[]
        use.hash  = h
        use.frame = s.frame_id
        return use

    # packed 0xRRGGBB → rgba (components 0..1).
    func col_of [ v: i32 ] -> rgba
        return rgba [ r: f32[(v >> 16) & 255] / 255.0, g: f32[(v >> 8) & 255] / 255.0, b: f32[v & 255] / 255.0, a: 1.0 ]


Control Console
    focusable  : true
    public  session_id : string
    public  feed       : list string
    public  sessions   : map ConsoleSession[string]
    # command to exec when THIS console's session is lazily created (an agent
    # like claude). empty = interactive shell. without it, an agent tab whose
    # session materializes here (first frame, reload) degrades to a bare shell.
    public  launch     : string
    # a shell command line to run in this console's session (the editor's module
    # build+run). set declaratively by the editor each frame; dispatched once
    # when it changes — no owner reaches into the element tree to push it.
    public  run_line   : string
    mutable last_run   : string

    func session [] -> ConsoleSession
        sid : string (session_id && session_id.count > 0) ? session_id : 'default'
        s   : ConsoleSession sessions[sid]
        if [ !s ]
            s = ConsoleSession []
            s.name = sid
            if [ launch && launch.count > 0 ] s.launch_cmd = launch
            if [ sid != 'system' ]
                puts 'session[]: creating + starting "{sid}" (launch="{launch}")'
                s.start[]
            sessions[sid] = s
        return s

    # the live line filter for this console: the editable title child's typed text.
    # null/empty = show everything. used by TermLayer to drop non-matching lines.
    func filter [] -> string
        if [ !elements ] return null
        t : element elements['console_filter']
        if [ !t ] return null
        return t.edit

    func init []
        if [ !sessions ] sessions = map ConsoleSession[string] []

    # launch an AI agent (claude/gemini) in a named session: exec the command
    # directly (no interactive shell, no prompt/echo line) so the console shows only
    # the agent's output. fresh session → create + start; existing → restart with it.
    func launch_agent [ sid: string, cmd: string ]
        s : ConsoleSession sessions[sid]
        if [ s ]
            s.launch_cmd = cmd
            s.restart[]
        el
            s = ConsoleSession []
            s.name = sid
            s.launch_cmd = cmd
            sessions[sid] = s
            s.start[]

    # run a command line in a named session's shell (create + start if needed) so
    # it executes in that project's own terminal and streams output to the console.
    func dispatch [ sid: string, ln: string ]
        s : ConsoleSession sessions[sid]
        if [ !s ]
            s = ConsoleSession []
            s.name = sid
            sessions[sid] = s
        # build/run commands run in an interactive shell (prompt bounce-back drives the
        # run-armed state) — clear any agent launch_cmd so restart doesn't re-exec it.
        s.launch_cmd = ''
        s.restart[]
        s.pending = ln

    # per-instance run (lldb) state, used by the play↔stop button.
    func is_running [ sid: string ] -> bool
        s : ConsoleSession sessions[sid]
        return s->running

    func set_running [ sid: string, r: bool ]
        s : ConsoleSession sessions[sid]
        if [ s ] s.running = r

    # stop a running session: restart its shell (kills lldb/the process) and clear.
    func stop [ sid: string ]
        s : ConsoleSession sessions[sid]
        if [ !s ] return
        s.restart[]
        s.running = false

    # xterm modifier parameter: 1 + shift(1) + alt(2) + ctrl(4). 1 = no modifiers.
    func keymod [ ev: Event ] -> i32
        m : i32 [ 1 ]
        if [ ev.key.shift ] m += 1
        if [ ev.key.alt ]   m += 2
        if [ ev.key.ctrl ]  m += 4
        return m

    # cursor / Home / End ('A'..'D','H','F'): modified → CSI 1;mod L; otherwise SS3
    # (ESC O L) when the app set DECCKM, else plain CSI (ESC [ L). app-cursor mode is
    # what makes arrow-key menu navigation work in TUIs like claude code.
    func send_cursor [ s: ConsoleSession, ev: Event, letter: string ]
        m : i32 [ keymod[ ev ] ]
        if [ m > 1 ]
            s.send_esc[ '[1;{m}{letter}' ]
        el [ s.app_cursor ]
            s.send_esc[ 'O{letter}' ]
        el
            s.send_esc[ '[{letter}' ]

    # Insert/Delete/Page/etc: ESC [ n ~   (modified → ESC [ n ; mod ~)
    func send_tilde [ s: ConsoleSession, ev: Event, n: i32 ]
        m : i32 [ keymod[ ev ] ]
        if [ m > 1 ]
            s.send_esc[ '[{n};{m}~' ]
        el
            s.send_esc[ '[{n}~' ]

    # function keys. F1-F4 = SS3 (ESC O P..S); F5-F12 = CSI n ~. modified forms add
    # the ;mod parameter.
    func send_fkey [ s: ConsoleSession, ev: Event, k: i32 ]
        m : i32 [ keymod[ ev ] ]
        if [ k <= 293 ]
            letter : string [ (k == 290) ? 'P' : ((k == 291) ? 'Q' : ((k == 292) ? 'R' : 'S')) ]
            if [ m > 1 ]
                s.send_esc[ '[1;{m}{letter}' ]
            el
                s.send_esc[ 'O{letter}' ]
        el
            # F5=15 F6=17 F7=18 F8=19 F9=20 F10=21 F11=23 F12=24
            n : i32 [ 15 ]
            if [ k == 295 ]
                n = 17
            el [ k == 296 ]
                n = 18
            el [ k == 297 ]
                n = 19
            el [ k == 298 ]
                n = 20
            el [ k == 299 ]
                n = 21
            el [ k == 300 ]
                n = 23
            el [ k == 301 ]
                n = 24
            send_tilde[ s, ev, n ]

    func on_char [ ev: Event ]
        s : ConsoleSession session[]
        # Alt+<char> is sent as ESC then the char (meta prefix), like a real terminal.
        if [ ev.key.alt && ev.key.text && ev.key.text.count > 0 ]
            s.send_esc[ ev.key.text ]
        el
            s.write_input[ ev.key.text ]

    # a dropped file path. wrap it in bracketed-paste markers (ESC[200~ … ESC[201~)
    # when the app has paste mode on, so claude/gemini recognize it as a paste (and
    # ingest an image path as [Image #N]) rather than treating it as typed text.
    func on_drop [ ev: Event ]
        s : ConsoleSession session[]
        if [ !ev.key.text || ev.key.text.count == 0 ] return
        if [ s.bracketed_paste ]
            s.send_esc[ '[200~' ]
            s.write_input[ ev.key.text ]
            s.send_esc[ '[201~' ]
        el
            s.write_input[ ev.key.text ]

    func on_key [ ev: Event ]
        if [ !ev.key.state ] return
        s : ConsoleSession session[]
        k : i32 [ i32 ev.key.unicode ]
        # page up / down on the NORMAL buffer scroll OUR view (scrollback). on the alt
        # screen (or modified) they fall through and are forwarded to the app.
        if [ (k == 266 || k == 267) && !s.in_alt ]
            lh  : f32 [ (s.lh_cache > 0.0) ? s.lh_cache : 22.0 ]
            ele : Layer (layers) ? layers[ 'content' ] : null
            vh  : f32 [ (ele && ele.bounds) ? ele.bounds.h : f32[s.rows] * lh ]
            page : f32 [ vh - lh ]
            scroll_by[ s, (k == 266) ? -page : page ]
            return
        if [ k == 257 ]                       # Enter
            s.write_input[ '\r' ]
        el [ k == 258 ]                       # Tab / Shift-Tab (back-tab = CSI Z)
            if [ ev.key.shift ]
                s.send_esc[ '[Z' ]
            el
                s.write_input[ '\t' ]
        el [ k == 256 ]                       # Escape
            s.send_esc[ '' ]
        el [ k == 259 ]                       # Backspace (Ctrl → ^H, else DEL)
            s.write_input[ (ev.key.ctrl) ? '\x08' : '\x7f' ]
        el [ k == 265 ]                       # Up
            send_cursor[ s, ev, 'A' ]
        el [ k == 264 ]                       # Down
            send_cursor[ s, ev, 'B' ]
        el [ k == 262 ]                       # Right
            send_cursor[ s, ev, 'C' ]
        el [ k == 263 ]                       # Left
            send_cursor[ s, ev, 'D' ]
        el [ k == 268 ]                       # Home
            send_cursor[ s, ev, 'H' ]
        el [ k == 269 ]                       # End
            send_cursor[ s, ev, 'F' ]
        el [ k == 260 ]                       # Insert
            send_tilde[ s, ev, 2 ]
        el [ k == 261 ]                       # Delete
            send_tilde[ s, ev, 3 ]
        el [ k == 266 ]                       # PageUp  (alt screen / modified)
            send_tilde[ s, ev, 5 ]
        el [ k == 267 ]                       # PageDown
            send_tilde[ s, ev, 6 ]
        el [ k >= 290 && k <= 301 ]           # F1..F12
            send_fkey[ s, ev, k ]
        el [ ev.key.ctrl && k >= 64 && k <= 95 ]
            b : i8 [ i8[k - 64] ]
            write[ s.pty_fd, @b, 1 ]

    # map a mouse position to a (line, col) in the line model and set the cursor —
    # mirrors EditorLayer.place_cursor over the console's line_count/line_get.
    func place_cursor [ ev: Event ]
        s : ConsoleSession session[]
        if [ !s ] return
        ele : Layer (layers) ? layers[ 'content' ] : null
        if [ !ele || !ele.bounds ] return
        if [ s.line_count[] <= 0 ]
            s.sel_line = -1
            return
        lh : f32 [ (s.lh_cache > 0.0) ? s.lh_cache : 22.0 ]
        cw : f32 [ (s.cw_cache > 0.0) ? s.cw_cache : 8.0 ]
        # find_target already folds the element's scroll.y into mouse.pos.y (we set
        # con.scroll.y = s.scroll for the ScrollLayer), so it's already in content
        # space — do NOT add s.scroll again or the line is off by the scroll amount.
        rel_y : f32 [ ev.mouse.pos.y - ele.bounds.y ]
        rel_x : f32 [ ev.mouse.pos.x - ele.bounds.x ]
        ln : i32 [ clamp[ rel_y / lh, 0, s.line_count[] - 1 ] ]
        cl : i32 [ clamp[ i32[ round[ rel_x / cw ] ], 0, s.line_get[ ln ].count ] ]
        s.sel_line = ln
        s.sel_col  = cl

    # is char i of txt whitespace (word boundary for link detection)
    func is_ws [ txt: string, i: i32 ] -> bool
        c : string txt.mid[ i, 1 ]
        return c == ' ' || c == '	'

    # if (line,col) sits on a `path:line(:col)` token, set s.link_c0/c1 to the token's
    # [a, b) column span and return true. the path must look like a file (has / or .)
    # and carry a numeric line after the colon. shared by the click (open) and the
    # hover (underline) paths so both agree on exactly what counts as a link.
    func detect_link [ ln: i32, col: i32 ] -> bool
        s : ConsoleSession session[]
        if [ !s ] return false
        txt : string s.line_get[ ln ]
        n : i32 [ txt.count ]
        if [ n <= 0 || col < 0 || col > n ] return false
        # non-space run [a, b) around the column
        a : i32 [ (col < n) ? col : n - 1 ]
        while [ a > 0 && !is_ws[ txt, a - 1 ] ]
            a -= 1
        b : i32 col
        while [ b < n && !is_ws[ txt, b ] ]
            b += 1
        if [ b <= a ] return false
        word  : string txt.mid[ a, b - a ]
        parts : array string word.split[ ':' ]
        if [ parts.count < 2 ] return false
        fp : string parts[ 0 ]
        # must look like a path (has / or .) with a numeric line after the colon
        if [ fp.count == 0 || !parts[ 1 ].is_numeric[] ] return false
        if [ fp.index_of[ '/' ] < 0 && fp.index_of[ '.' ] < 0 ] return false
        s.link_c0 = a
        s.link_c1 = b
        return true

    # if the (line,col) sits on a `path:line(:col)` token in the output, open that
    # file at that line in editor pane 0 (mirrors apply_break) and return true.
    func open_link_at [ ln: i32, col: i32 ] -> bool
        s : ConsoleSession session[]
        if [ !s ] return false
        if [ !detect_link[ ln, col ] ] return false
        txt   : string s.line_get[ ln ]
        word  : string txt.mid[ s.link_c0, s.link_c1 - s.link_c0 ]
        parts : array string word.split[ ':' ]
        fp : string parts[ 0 ]
        lno : i32 [ i32[ parts[ 1 ].integer_value[] ] ]
        # ux is the Window; the app (orbiter) is ux.app_object. casting ux itself to
        # orbiter reinterprets a Window as an orbiter → garbage self → SIGBUS.
        if [ !ux || !ux.app_object ] return false
        orb : cast orbiter [ ux.app_object ]
        if [ !orb ] return false
        orb.open_in_pane[ path '{fp}', 0 ]
        ed : Editor orb.pane_at[ 0 ]
        if [ ed ]
            sl : i32 [ (lno > 0) ? lno - 1 : 0 ]
            sc : i32 [ (parts.count > 2 && parts[ 2 ].is_numeric[]) ? i32[ parts[ 2 ].integer_value[] ] : 0 ]
            ed.sel_line = sl
            ed.sel_col  = sc
            # collapse the selection onto the caret — without resetting the anchor the
            # editor draws a range from the previous anchor to this new caret.
            ed.anchor_line = sl
            ed.anchor_col  = sc
            lh  : f32 [ (ed.lh_cache > 0.0) ? ed.lh_cache : 22.0 ]
            vh  : f32 [ (ed.bounds) ? ed.bounds.h : 600.0 ]
            top : f32 [ f32[ sl ] * lh ]
            if [ top < ed.scroll.y || top + lh > ed.scroll.y + vh ]
                ed.scroll.y = top - vh * 0.4
                if [ ed.scroll.y < 0.0 ] ed.scroll.y = 0.0
                # pin the animation target too — otherwise the scroll animator lerps
                # scroll.y back to the stale scroll_target (the old caret location).
                ed.scroll_target = ed.scroll.y
            ed.pristine = false
        return true

    func on_press [ ev: Event ]
        s : ConsoleSession session[]
        if [ !s ] return
        # take keyboard focus so key_event/text_event (both dispatch to `focus`) route
        # here — without this, nothing reaches the terminal's on_key/on_char.
        set_focus[]
        # right-click copies the current selection to the clipboard (before any
        # left-click would replace it). does not disturb the selection.
        if [ ev.mouse.button == 1 ]
            txt : string s.selection_text[]
            if [ txt.count > 0 && ux ] ux.set_clipboard[ txt ]
            s.sel_line = -1        # void the selection once copied
            pristine = false
            return
        ele : Layer (layers) ? layers[ 'content' ] : null
        if [ !ele || !ele.bounds ] return
        rel_x : f32 [ ev.mouse.pos.x - ele.bounds.x ]
        sb : ScrollLayer (layers) ? (layers[ 'scrollbar' ] to ScrollLayer) : null
        grab : f32 [ (sb && sb.thumb_w > 0.0) ? sb.thumb_w * 2.0 + 8.0 : 16.0 ]
        if [ sb && sb.scroll_max > 0.0 && rel_x > ele.bounds.w - grab ]
            # subtract scroll.y (the element scroll find_target folds in, constant
            # within a frame) — NOT s.scroll, which we mutate per drag event.
            my : f32 [ ev.mouse.pos.y - ele.bounds.y - scroll.y ]
            sb.grab_at[ my ]
            sy : f32 [ sb.drag_to[ my ] ]
            if [ sy >= 0.0 ]
                # snap to the line grid and repaint only on a line change (set_scroll);
                # a sub-line drag updates the thumb but leaves the console untouched.
                s.scroll_dragging = true
                sb.active         = true
                set_scroll[ s, sy ]
            return
        place_cursor[ ev ]
        # clicking a file:line token opens it in the editor instead of selecting.
        # mark the event consumed so it doesn't reach app_object.on_press, which
        # would re-route the click to the editor and scroll/select there.
        if [ open_link_at[ s.sel_line, s.sel_col ] ]
            s.sel_line = -1
            pristine    = false
            ev.no_propagation = true
            ev.no_default     = true
            return
        if [ !ev.key.shift ]
            s.anchor_line = s.sel_line
            s.anchor_col  = s.sel_col
        s.dragging = true
        pristine = false

    func on_move [ ev: Event ]
        s : ConsoleSession session[]
        if [ !s ] return
        ele : Layer (layers) ? layers[ 'content' ] : null
        if [ s.scroll_dragging && ele && ele.bounds ]
            sb : ScrollLayer (layers) ? (layers[ 'scrollbar' ] to ScrollLayer) : null
            if [ sb ]
                sy : f32 [ sb.drag_to[ ev.mouse.pos.y - ele.bounds.y - scroll.y ] ]
                # set_scroll snaps to the line grid and only repaints when the top
                # line changes — so dragging the thumb within a line is free, and the
                # physical scroll moves only on whole-line boundaries.
                if [ sy >= 0.0 ] set_scroll[ s, sy ]
            return
        if [ s.dragging ]
            place_cursor[ ev ]
            pristine = false
            return
        # not dragging: underline a path:line token sitting under the cursor so it
        # reads as a clickable link. mirrors place_cursor's mouse→(line,col) mapping
        # but never touches the selection.
        if [ !ele || !ele.bounds || s.line_count[] <= 0 ] return
        lh : f32 [ (s.lh_cache > 0.0) ? s.lh_cache : 22.0 ]
        cw : f32 [ (s.cw_cache > 0.0) ? s.cw_cache : 8.0 ]
        rel_y : f32 [ ev.mouse.pos.y - ele.bounds.y ]
        rel_x : f32 [ ev.mouse.pos.x - ele.bounds.x ]
        hln : i32 [ clamp[ rel_y / lh, 0, s.line_count[] - 1 ] ]
        hcl : i32 [ clamp[ i32[ round[ rel_x / cw ] ], 0, s.line_get[ hln ].count ] ]
        prev_line : i32 [ s.hover_link_line ]
        prev_c0   : i32 [ s.link_c0 ]
        hit : bool [ detect_link[ hln, hcl ] ]
        new_line : i32 [ (hit) ? hln : -1 ]
        if [ new_line != prev_line || (hit && s.link_c0 != prev_c0) ]
            s.hover_link_line = new_line
            pristine = false

    func on_release [ ev: Event ]
        s : ConsoleSession session[]
        if [ !s ] return
        s.dragging        = false
        s.scroll_dragging = false
        sb : ScrollLayer (layers) ? (layers[ 'scrollbar' ] to ScrollLayer) : null
        if [ sb ]
            sb.active = false
            ux.will_animate = true

    # cursor left the console (hover moved to another element) — drop any link
    # underline so it doesn't linger. bubbled from the content layer up to here.
    func on_leave [ ev: Event ]
        s : ConsoleSession session[]
        if [ s && s.hover_link_line >= 0 ]
            s.hover_link_line = -1
            pristine = false

    # scroll the view by line, set the user-scrolled lock so output doesn't yank it.
    # apply an absolute scroll target: snap to the whole-line grid, clamp, and force a
    # console repaint ONLY when the top visible line index changes. a drag that stays
    # within a line snaps to the same value and the rendered content is identical, so
    # nothing repaints. the draw owns s.first_line (set to the actual top line drawn).
    func set_scroll [ s: ConsoleSession, target: f32 ]
        lh : f32 [ (s.lh_cache > 0.0) ? s.lh_cache : 22.0 ]
        ns : f32 [ target ]
        if [ lh > 0.0 ] ns = round[ ns / lh ] * lh
        if [ ns < 0.0 ] ns = 0.0
        if [ ns > s.max_scroll ] ns = s.max_scroll
        s.scroll = ns
        # find_target folds scroll.y — sync NOW, not at next draw
        scroll.y = ns
        s.user_scrolled = ns < s.max_scroll - 1.0
        fl : i32 [ (lh > 0.0) ? i32[ round[ ns / lh ] ] : 0 ]
        if [ fl != s.first_line ]
            pristine = false
            ux.will_animate = true

    func scroll_by [ s: ConsoleSession, dy: f32 ]
        set_scroll[ s, s.scroll + dy ]

    func on_wheel [ ev: Event ]
        s : ConsoleSession session[]
        if [ !s ] return
        lh : f32 [ (s.lh_cache > 0.0) ? s.lh_cache : 22.0 ]
        # accumulate in lines (3 lines per wheel unit); only move on whole-line steps
        # so a trackpad's fractional momentum deltas buffer instead of firing a redraw
        # per event. the remainder carries to the next event.
        s.wheel_accum = s.wheel_accum - ev.mouse.wheel_delta.y * 3.0
        lines : i32 [ i32[ s.wheel_accum ] ]
        if [ lines != 0 ]
            s.wheel_accum = s.wheel_accum - f32[ lines ]
            scroll_by[ s, f32[ lines ] * lh ]


Layer CompileLayer
    func draw [ cv: Canvas ]
        con : cast CompileConsole [ parent ]
        if [ !con ] return
        if [ !con.log ] return
        if [ label_size > 0.0 ] cv.font_size[ i32[label_size] ]
        lh   : f32 [ round[ cv.get_line_height[] * ((label_height > 0.0) ? label_height : 1.0) ] ]
        x0   : f32 [ bounds.x ]
        y0   : f32 [ bounds.y ]
        n    : i32 [ con.log.count ]
        for [ i: i32 0, i < n, i += 1 ]
            y : f32 [ y0 + f32[i] * lh ]
            if [ y + lh < bounds.y ] continue
            if [ y > bounds.y + bounds.h ] break
            cv.fill_color[ '#ccc' ]
            cv.draw_text[ con.log.value_by_index[i],
                rect [ x:x0, y:y, w:bounds.w, h:lh ],
                vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
        cv.paint[]


Control CompileConsole
    public selected : bool
    public log : list string
    func init []
        log = list string []