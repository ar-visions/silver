extend orbiter

import <string.h>

class FileNode
    public p        : path
    public depth    : i32
    public is_dir   : bool
    public open     : bool
    public children : array FileNode

    func load_children []
        if [ children ] return
        children = array FileNode [ alloc: 32 ]
        entries : array [ p.ls[null, false] ]
        if [ !entries ] return
        for [ i: i32 0, i < entries.count, i += 1 ]
            e : path entries[i]
            if [ e.is_dir[] ]
                children.push[ FileNode [ p: e, depth: depth + 1, is_dir: true ] ]
        for [ i: i32 0, i < entries.count, i += 1 ]
            e : path entries[i]
            if [ !e.is_dir[] ]
                children.push[ FileNode [ p: e, depth: depth + 1, is_dir: false ] ]

# one cached row, keyed by what it currently shows. the icon+text are rasterized
# into `canvas` once; while `key` matches we just re-blit it. pooled per on-screen
# row (not per file), so memory is bounded by visible lines.
class LineCache
    mutable canvas : Canvas
    mutable key    : string

Layer FileLayer
    public  expand_svg    : string
    public  collapse_svg  : string
    public  indent_width  : f32
    public  icon_col      : f32
    public  icon_text_gap : f32
    public  expand_offset   : vec2f
    public  collapse_offset : vec2f
    public  sel_color     : string
    public  sel_border_color : string
    public  sel_radius    : f32
    public  sel_pad_r     : f32
    public  sel_oy        : f32
    public  dir_color     : string
    public  file_color    : string
    public  row_spacing   : f32

    func draw [ cv: Canvas ]
        fl : FileList[ parent ]
        if [ !fl || !fl.visible ] return
        if [ fl.find_text != fl.last_find ]
            fl.last_find = fl.find_text
            fl.build_visible[]
        if [ !fl.expand_icon ]
            fl.expand_icon   = SVGModel [ path expand_svg ]
            fl.collapse_icon = SVGModel [ path collapse_svg ]
        cv.font_size[ i32[label_size] ]
        lh   : f32 [ cv.get_line_height[] * ((row_spacing > 0.0) ? row_spacing : 1.0) ]
        fl.row_height  = lh
        fl.content_y   = bounds.y
        fl.content_h   = f32[ fl.visible.count ] * lh
        fl.view_h      = bounds.h
        fl.scroll_speed = lh
        x0   : f32 [ bounds.x ]
        y0   : f32 [ bounds.y ]

        clip_y0 : f32 [ bounds.y ]
        clip_y1 : f32 [ bounds.y + bounds.h ]
        wtx : f32 [ cv.transform_tx[] ]
        wty : f32 [ cv.transform_ty[] ]
        cv.set_crop[ wtx + bounds.x, wty + clip_y0, wtx + bounds.x + bounds.w, wty + clip_y1 ]

        # one cached canvas per ON-SCREEN row (slot pool, bounded by visible lines).
        # a row's icon+text is rasterized into its slot ONCE and re-rendered only when
        # the label/icon that slot shows changes (scroll brings a new line, filter,
        # expand). every other repaint (resize, idle) just blits the cached row — no
        # glyph work, no per-row text submit. the selection highlight stays on the
        # main canvas so selecting/hovering a row never invalidates a slot.
        if [ !fl.line_cache ] fl.line_cache = array LineCache [ alloc: 64 ]
        lh_i : i32 [ ceil[ lh ] ]
        slot : i32 [ 0 ]

        for [ i: i32 0, i < fl.visible.count, i += 1 ]
            n : FileNode fl.visible[i]
            y : f32 [ y0 + f32[i] * lh - fl.scroll.y ]
            if [ y + lh < clip_y0 ] continue
            if [ y > clip_y1 ] break

            # selection highlight — drawn on the MAIN canvas (not the line cache), so
            # selection state never dirties a cached row.
            if [ i == fl.sel && y >= clip_y0 ]
                r : f32 [ (sel_radius > 0.0) ? sel_radius : 0.0 ]
                cv.save[]
                cv.rounded[ r, r, r, r ]
                cv.fill_color[ sel_color ]
                if [ parent.focused && sel_border_color ]
                    cv.stroke_width[ 1.0 ]
                    cv.stroke_color[ sel_border_color ]
                el
                    cv.stroke_width[ 0.0 ]
                pr : f32 [ (sel_pad_r > 0.0) ? sel_pad_r : 2.0 ]
                cv.rect_to[ x0 + 1.5, y + sel_oy + 0.5, bounds.w - 2.0 - pr, lh - 1.0 ]
                cv.paint[]
                cv.restore[]

            # row geometry, measured from the row's left edge (line-cache local x=0
            # corresponds to x0). the cache is sized to the icon+text content, NOT the
            # row width, so a horizontal resize never re-renders a row.
            fname : n.p.filename[]
            xl_l  : f32 [ 5.0 ]
            ix_l  : f32 [ xl_l + icon_col + icon_text_gap + f32[n.depth] * indent_width ]
            tm    : cv.measure_text[ fname ]
            cw_i  : i32 [ ceil[ ix_l + tm.w + 2.0 ] ]
            if [ cw_i < 1 ] cw_i = 1
            key   : '{fname}|{n.is_dir}|{n.open}|{n.depth}|{cw_i}'

            if [ slot >= fl.line_cache.count ] fl.line_cache.push[ LineCache [] ]
            slc : LineCache fl.line_cache[slot]

            if [ !slc.canvas || slc.key != key ]
                if [ !slc.canvas ]
                    slc.canvas = Canvas [ vk: cv.vk, w: cv.w, format: Pixel.rgba8, width: cw_i, height: lh_i, load_existing: true ]
                    slc.canvas.update[]
                el [ slc.canvas.content_w != cw_i || slc.canvas.content_h != lh_i ]
                    slc.canvas.resize[ cw_i, lh_i ]
                slc.canvas.reset[ vec4f [ 0.0, 0.0, 0.0, 0.0 ] ]
                slc.canvas.font_size[ i32[label_size] ]
                if [ n.is_dir ]
                    icon : SVGModel [ (n.open) ? fl.collapse_icon : fl.expand_icon ]
                    iox  : f32 [ (n.open) ? collapse_offset.x : expand_offset.x ]
                    ioy  : f32 [ (n.open) ? collapse_offset.y : expand_offset.y ]
                    pad  : f32 [ (lh - 11.0) * 0.5 ]
                    slc.canvas.draw_svg[ icon, round[ xl_l + f32[n.depth] * indent_width + iox ], round[ pad + ioy ], 11.0, 11.0 ]
                slc.canvas.fill_color[ (n.is_dir) ? dir_color : file_color ]
                slc.canvas.draw_text[ fname,
                    rect [ x: ix_l, y: 0.0, w: tm.w + 2.0, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]
                slc.key = key

            # blit at integer pixels — fractional positions sample the cached row at
            # sub-pixel offsets and blur the (already crisp) text/icon.
            cv.draw_canvas[ slc.canvas, round[ x0 ], round[ y ], f32[ cw_i ], f32[ lh_i ] ]
            slot += 1

        cv.clear_crop[]

NodeList FileList
    public  root           : path
    public  pending_open   : path
    # this FileList's own substring search. find_text is the live query (set by the
    # navigator's filter handler); build_visible walks root recursively for matches.
    public  find_text      : string
    mutable last_find      : string
    mutable root_node      : FileNode
    mutable visible        : array FileNode
    # per-on-screen-row render cache (see LineCache). bounded by visible lines.
    mutable line_cache     : array LineCache
    # sel / row_height / content_y / view_h are inherited from NodeList.
    mutable expand_icon    : SVGModel
    mutable collapse_icon  : SVGModel

    # row count for the NodeList base (scroll/select math) — the visible tree rows.
    func row_count [] -> i32
        if [ !visible ] return 0
        return visible.count

    func on_key [ ev: Event ]
        if [ !ev.key.state || !visible || visible.count == 0 ] return
        key : i32 [ ev.key.unicode ]
        if [ key == 265 ]    # Key.Up
            if [ sel > 0 ]
                sel -= 1
                scroll_to_sel[]
                pristine = false
        el [ key == 264 ]    # Key.Down
            if [ sel < visible.count - 1 ]
                sel += 1
                scroll_to_sel[]
                pristine = false
        el [ key == 262 ]    # Key.Right
            if [ sel >= 0 && sel < visible.count ]
                n : FileNode visible[sel]
                if [ n.is_dir && !n.open ]
                    close_all[ root_node, n ]
                    n.load_children[]
                    n.open = true
                    build_visible[]
                    for [ j: i32 0, j < visible.count, j += 1 ]
                        if [ visible[j] == n ]
                            sel = j
                            break
                    scroll_to_sel[]
                    pristine = false
        el [ key == 263 ]    # Key.Left
            if [ sel >= 0 && sel < visible.count ]
                n : FileNode visible[sel]
                if [ n.is_dir && n.open ]
                    n.open = false
                    build_visible[]
                    for [ j: i32 0, j < visible.count, j += 1 ]
                        if [ visible[j] == n ]
                            sel = j
                            break
                    scroll_to_sel[]
                    pristine = false
        el [ key == 257 || key == 32 ]    # Key.Enter / Key.Space
            if [ sel >= 0 ]
                select[ sel ]

    func init []
        if [ !root ] root = path.path_startup[]
        root_node = FileNode [ p: root, depth: -1, is_dir: true ]
        root_node.load_children[]
        build_visible[]

    func build_visible []
        visible = array FileNode [ alloc: 128 ]
        walk[ root_node ]
        if [ find_text && find_text.count > 0 ]
            filtered : array FileNode [ alloc: 128 ]
            for [ n: FileNode ] in visible
                if [ n.p.filename[].index_of[ find_text ] >= 0 ]
                    filtered.push[ n ]
            visible = filtered

    func walk [ node: FileNode ]
        if [ !node.children ] return
        for [ i: i32 0, i < node.children.count, i += 1 ]
            child : node.children[i]
            visible.push[ child ]
            if [ child.open ]
                walk[ child ]

    func select [ idx: i32 ]
        sel = idx
        if [ idx < 0 || !visible || idx >= visible.count ] return
        n : FileNode visible[idx]
        if [ n.is_dir ]
            if [ n.open ]
                n.open = false
            el
                close_all[ root_node, n ]
                n.load_children[]
                n.open = true
            build_visible[]
            for [ j: i32 0, j < visible.count, j += 1 ]
                if [ visible[j] == n ]
                    sel = j
                    break
        if [ !n.is_dir ]
            pending_open = n.p
        item_y : f32 [ f32[sel] * row_height ]
        vh     : f32 [ (view_h > 0.0) ? view_h : content_h ]
        if [ item_y < scroll.y ]
            scroll.y = item_y
        el [ item_y + row_height > scroll.y + vh ]
            scroll.y = item_y + row_height - vh
        pristine = false

    func close_all [ node: FileNode, keep: FileNode ]
        if [ !node.children ] return
        for [ i: i32 0, i < node.children.count, i += 1 ]
            child : node.children[i]
            if [ child != keep && child.open && !is_ancestor[ child, keep ] ]
                child.open = false
            close_all[ child, keep ]

    func is_ancestor [ node: FileNode, target: FileNode ] -> bool
        if [ !node.children ] return false
        for [ child:FileNode ] in node.children
            if [ child == target ] return true
            if [ is_ancestor[ child, target ] ] return true
        return false

    func render [] -> Elements
        return null
