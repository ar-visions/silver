extend orbiter

import <string.h>

class FileNode
    public p        : path
    public depth    : i32
    public is_dir   : bool
    public open     : bool
    public children : array FileNode

    func load_children []
        if [ children ] return
        children = array FileNode [ alloc: 32 ]
        entries : array [ p.ls[null, false] ]
        if [ !entries ] return
        for [ i: i32 0, i < entries.count, i += 1 ]
            e : path entries[i]
            if [ e.is_dir[] ]
                children.push[ FileNode [ p: e, depth: depth + 1, is_dir: true ] ]
        for [ i: i32 0, i < entries.count, i += 1 ]
            e : path entries[i]
            if [ !e.is_dir[] ]
                children.push[ FileNode [ p: e, depth: depth + 1, is_dir: false ] ]

Layer FileLayer
    public  expand_svg    : string
    public  collapse_svg  : string
    public  indent_width  : f32
    public  icon_col      : f32
    public  icon_text_gap : f32
    public  expand_offset   : vec2f
    public  collapse_offset : vec2f
    public  sel_color     : string
    public  sel_border_color : string
    public  sel_radius    : f32
    public  sel_pad_r     : f32
    public  sel_oy        : f32
    public  dir_color     : string
    public  file_color    : string
    public  row_spacing   : f32

    func draw [ cv: Canvas ]
        fl : FileList[ parent ]
        if [ !fl || !fl.visible ] return
        #puts 'FileLayer.draw filter={fl.filter} last={fl.last_filter}'
        if [ fl.filter && fl.filter != fl.last_filter ]
            fl.last_filter = fl.filter
            fl.build_visible[]
        if [ !fl.expand_icon ]
            fl.expand_icon   = SVGModel [ path expand_svg ]
            fl.collapse_icon = SVGModel [ path collapse_svg ]
        cv.font_size[ i32[label_size] ]
        # fonts are lazy — load it at this size now, else cv.font is null and
        # draw_text bails (blank rows). also makes line_height below valid.
        cv.ensure_font[]
        lh   : f32 [ ((cv.font) ? cv.font.line_height : 20.0) * ((row_spacing > 0.0) ? row_spacing : 1.0) ]
        fl.row_height  = lh
        fl.content_y   = bounds.y
        fl.content_h   = f32[ fl.visible.count ] * lh
        fl.view_h      = bounds.h
        fl.scroll_speed = lh
        x0   : f32 [ bounds.x ]
        y0   : f32 [ bounds.y ]

        clip_y0 : f32 [ bounds.y ]
        clip_y1 : f32 [ bounds.y + bounds.h ]
        wtx : f32 [ cv.transform_tx[] ]
        wty : f32 [ cv.transform_ty[] ]
        cv.set_crop[ wtx + bounds.x, wty + clip_y0, wtx + bounds.x + bounds.w, wty + clip_y1 ]

        for [ i: i32 0, i < fl.visible.count, i += 1 ]
            n : FileNode fl.visible[i]
            y : f32 [ y0 + f32[i] * lh - fl.scroll.y ]
            if [ y + lh < clip_y0 ] continue
            if [ y > clip_y1 ] break

            if [ i == fl.sel && y >= clip_y0 ]
                r : f32 [ (sel_radius > 0.0) ? sel_radius : 0.0 ]
                cv.save[]
                cv.rounded[ r, r, r, r ]
                cv.fill_color[ sel_color ]
                if [ parent.focused && sel_border_color ]
                    cv.stroke_width[ 1.0 ]
                    cv.stroke_color[ sel_border_color ]
                el
                    cv.stroke_width[ 0.0 ]
                pr : f32 [ (sel_pad_r > 0.0) ? sel_pad_r : 2.0 ]
                cv.rect_to[ x0 + 1.5, y + sel_oy + 0.5, bounds.w - 2.0 - pr, lh - 1.0 ]
                cv.paint[]
                cv.restore[]

            xl : f32 [ x0 + 5.0 ]
            ix : f32 [ xl + icon_col + icon_text_gap + f32[n.depth] * indent_width ]
            if [ n.is_dir && y >= clip_y0 ]
                icon : SVGModel [ (n.open) ? fl.collapse_icon : fl.expand_icon ]
                ox   : f32 [ (n.open) ? collapse_offset.x : expand_offset.x ]
                oy   : f32 [ (n.open) ? collapse_offset.y : expand_offset.y ]
                pad  : f32 [ (lh - 11.0) * 0.5 ]
                cv.draw_svg[ icon, round[ xl + f32[n.depth] * indent_width + ox ], round[ y + pad + oy ], 11.0, 11.0 ]

            cv.fill_color[ (n.is_dir) ? dir_color : file_color ]
            cv.draw_text[ n.p.filename[],
                rect [ x: ix, y: y, w: bounds.w - (ix - x0), h: lh ],
                vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]

        cv.paint[]
        cv.clear_crop[]

Option FileList
    public  root           : path
    public  pending_open   : path
    public  filter         : string
    mutable last_filter    : string
    mutable root_node      : FileNode
    mutable visible        : array FileNode
    mutable sel            : i32      [ -1 ]
    mutable row_height     : f32      [ 20.0 ]
    mutable content_y      : f32      [ 0.0 ]
    mutable view_h         : f32      [ 0.0 ]
    mutable expand_icon    : SVGModel
    mutable collapse_icon  : SVGModel

    func on_press [ ev: Event ]
        rel_y : f32 [ ev.mouse.pos.y - content_y ]
        if [ rel_y < 0.0 ] return
        idx   : i32 [ i32[ rel_y / row_height ] ]
        select[ idx ]

    func on_wheel [ ev: Event ]
        if [ content_h <= 0.0 ] return
        vh     : f32 [ (view_h > 0.0) ? view_h : bounds.h ]
        speed  : f32 [ (scroll_speed > 0.0) ? scroll_speed : 40.0 ]
        scroll.y += f32[ ev.mouse.wheel_delta.y ] * speed * -1.0
        if [ scroll.y < 0.0 ] scroll.y = 0.0
        max_sc : f32 [ content_h - vh ]
        if [ max_sc > 0.0 && scroll.y > max_sc ] scroll.y = max_sc
        pristine = false
        ux.will_animate = true

    func scroll_to_sel []
        if [ sel < 0 || !visible || visible.count == 0 ] return
        item_y : f32 [ f32[sel] * row_height ]
        vh     : f32 [ (view_h > 0.0) ? view_h : content_h ]
        if [ item_y < scroll.y ]
            scroll.y = item_y
        el [ item_y + row_height > scroll.y + vh ]
            scroll.y = item_y + row_height - vh

    func on_key [ ev: Event ]
        if [ !ev.key.state || !visible || visible.count == 0 ] return
        key : i32 [ ev.key.unicode ]
        if [ key == 265 ]
            if [ sel > 0 ]
                sel -= 1
                scroll_to_sel[]
                pristine = false
        el [ key == 264 ]
            if [ sel < visible.count - 1 ]
                sel += 1
                scroll_to_sel[]
                pristine = false
        el [ key == 262 ]
            if [ sel >= 0 && sel < visible.count ]
                n : FileNode visible[sel]
                if [ n.is_dir && !n.open ]
                    close_all[ root_node, n ]
                    n.load_children[]
                    n.open = true
                    build_visible[]
                    for [ j: i32 0, j < visible.count, j += 1 ]
                        if [ visible[j] == n ]
                            sel = j
                            break
                    scroll_to_sel[]
                    pristine = false
        el [ key == 263 ]
            if [ sel >= 0 && sel < visible.count ]
                n : FileNode visible[sel]
                if [ n.is_dir && n.open ]
                    n.open = false
                    build_visible[]
                    for [ j: i32 0, j < visible.count, j += 1 ]
                        if [ visible[j] == n ]
                            sel = j
                            break
                    scroll_to_sel[]
                    pristine = false
        el [ key == 257 || key == 32 ]
            if [ sel >= 0 ]
                select[ sel ]

    func init []
        if [ !root ] root = path '/src/silver'
        root_node = FileNode [ p: root, depth: -1, is_dir: true ]
        root_node.load_children[]
        build_visible[]

    func build_visible []
        visible = array FileNode [ alloc: 128 ]
        walk[ root_node ]

    func walk [ node: FileNode ]
        searching : bool [ filter && filter.count > 0 ]
        if [ !node.children ]
            if [ searching && node.is_dir ] node.load_children[]
        if [ !node.children ] return
        for [ i: i32 0, i < node.children.count, i += 1 ]
            child : node.children[i]
            if [ searching ]
                if [ child.is_dir ]
                    walk[ child ]
                el
                    fname : child.p.filename[]
                    if [ strstr[ fname.chars, filter.chars ] ]
                        visible.push[ child ]
            el
                visible.push[ child ]
                if [ child.open ]
                    walk[ child ]

    func select [ idx: i32 ]
        sel = idx
        if [ idx < 0 || !visible || idx >= visible.count ] return
        n : FileNode visible[idx]
        if [ n.is_dir ]
            if [ n.open ]
                n.open = false
            el
                close_all[ root_node, n ]
                n.load_children[]
                n.open = true
            build_visible[]
            for [ j: i32 0, j < visible.count, j += 1 ]
                if [ visible[j] == n ]
                    sel = j
                    break
        if [ !n.is_dir ]
            pending_open = n.p
        item_y : f32 [ f32[sel] * row_height ]
        vh     : f32 [ (view_h > 0.0) ? view_h : content_h ]
        if [ item_y < scroll.y ]
            scroll.y = item_y
        el [ item_y + row_height > scroll.y + vh ]
            scroll.y = item_y + row_height - vh
        pristine = false

    func close_all [ node: FileNode, keep: FileNode ]
        if [ !node.children ] return
        for [ i: i32 0, i < node.children.count, i += 1 ]
            child : node.children[i]
            if [ child != keep && child.open && !is_ancestor[ child, keep ] ]
                child.open = false
            close_all[ child, keep ]

    func is_ancestor [ node: FileNode, target: FileNode ] -> bool
        if [ !node.children ] return false
        for [ child:FileNode ] in node.children
            if [ child == target ] return true
            if [ is_ancestor[ child, target ] ] return true
        return false

    func render [] -> Elements
        return null
