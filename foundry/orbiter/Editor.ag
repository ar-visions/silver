extend orbiter

class FileBuf
    public lines : list string
    public mtime : i64 [ 0 ] # test
	
    # per-file undo history (keyed by URI via file_cache, same as `lines`). hist is the
    # linked list of EditAction delta groups; hist_i the cursor = number of groups applied
    # (groups before it are undoable, groups from it on are the redo future).
    public hist       : list EditAction
    public hist_i     : i32 [ 0 ]
    # the line model's theme-resolved coloring, built by load_format[] from silver's --format
    # map. `regions` is a FLAT, line-sorted `array ColorRegion` (each carries its own line);
    # `reg_off[L]` indexes the first region whose line >= L, so a line's spans are the slice
    # [reg_off[L], reg_off[L+1]). flat + typed member so element access resolves to ColorRegion
    # (a local array loses its element meta). stale-tolerant: a structural edit clears both
    # (fmt_invalidate) and the next map reload rebuilds them.
    public regions    : array ColorRegion
    public reg_off    : array i32

# one row in the find-in-files results view. a header row is a file title (drawn
# 2 code-rows tall, larger, centered); a non-header row is a matched line of code
# carrying its source line number. `file` is the source path (on every row so a
# match row knows what to open).
class FindHit
    public is_header : bool
    public text      : string
    # header rows only: the file's directory (shown dimmed after the filename).
    public dir       : string
    # header rows in the browse list: this entry is a directory — rendered as a link,
    # and clicking it navigates INTO the folder rather than opening a file.
    public is_dir    : bool
    # a blank reserved row (single-line dock divider) — renders nothing, no hover/glow.
    public is_spacer : bool
    public file      : path
    public line      : i32

# one row in the flattened editor view: either a base code line (src >= 0, var null)
# or a virtual debug field row (src = -1, var = the field node, depth = indent level).
# the flat list IS the line model when a debug tree is expanded, so selection / clicking
# / copy all work over it for free.
class VRow
    public src   : i32 [ -1 ]
    public var   : variable
    public depth : i32 [ 0 ]

# a single primitive line change within an edit group. kind: 0=replace line `at` (before
# → after), 1=insert `after` as line `at`, 2=remove line `at` (was `before`). undo applies
# the inverse; redo applies forward. stored as deltas so memory is O(edit), not O(file).
class LineOp
    public at     : i32 [ 0 ]
    public kind   : i32 [ 0 ]
    public before : string
    public after  : string

# one undo step (a coalesced logical edit: a typing run, a run of Enters, …). holds only
# the line ops it changed plus the caret before/after — NOT a copy of the whole buffer.
# consecutive replaces of the same line collapse into one op, so typing a 100-char line is
# one op (orig→final), not 100 snapshots.
class EditAction
    public ops : array LineOp
    public sl0 : i32 [ 0 ]   # caret line/col before the group
    public sc0 : i32 [ 0 ]
    public sl1 : i32 [ 0 ]   # caret line/col after the group
    public sc1 : i32 [ 0 ]

# one themed color span on a line: model column `col`, `len` chars, drawn in `color`.
# produced by reformat[] from a silver --format token (its Syntax kind run through the
# theme). the token text itself never contains tabs, so it draws as a literal substring;
# its x is measured from the tab-expanded display prefix up to `col`.
class ColorRegion
    public line  : i32 [ 0 ]
    public col   : i32 [ 0 ]
    public len   : i32 [ 0 ]
    public color : rgba

# one rasterized code line: its own QUANTIZED canvas (width rounded to a 64px grid, high-
# water → reuse never reallocs), content-addressed by a hash of the line's text + colors.
# strong ownership; created once, recycled. a scrolled/unchanged line is a hit → just blit.
class EdLineCache
    mutable canvas : Canvas
    mutable hash   : i64 [ -1 ]
    mutable frame  : i32 [ -1 ]

# ---- resource views ----------------------------------------------------------------
# a class-based presentation for a NON-text resource opened in an editor pane. orbiter
# picks a subclass by file format and the editor delegates its content draw to it. this
# is the extension point for hosting any foundry product in a pane (images, audio, gltf
# …) — so orbiter doubles as a live test-bench for the whole foundry. to add a format:
# define a ResourceView subclass and one line in resource_view_for[].
# base presentation view. each foundry-backed format is a SUBCLASS that declares the
# file extensions it claims via the `extensions` static; at load orbiter enumerates the
# subclasses and binds ext → view. the editor owns one and delegates its content draw.
class ResourceView
    mutable src    : path
    mutable loaded : bool
    # the file extensions this view claims (e.g. [ '.png', '.exr' ]). base claims none.
    func extensions [] -> array string
        return array string [ ]
    # draw into the pane's content bounds each frame. lazy-loads on first call — load_file
    # runs with no Canvas, but GPU/host resources need vk + window from cv. (no-op base.)
    func render [ cv: Canvas, bounds: rect ]
        return
    # drop held resources when the pane switches away or closes. (no-op base.)
    func release []
        return
    # produce a small GPU texture preview of `src` for the grid/thumbnail (aspect kept,
    # max side ~256). the FORMAT module owns this — orbiter just blits what it returns.
    # (no-op base → files with no preview fall back to a file icon.)
    func thumbnail [ cv: Canvas ] -> Texture
        return null

# image viewer: decodes via the img product, blits the texture fit-to-pane (centered).
ResourceView ImageView
    mutable tex : Texture
    mutable iw  : f32
    mutable ih  : f32
    func extensions [] -> array string
        return array string [ '.png', '.exr' ]
    # decode src, downscale so the longest side is <= 256 (aspect preserved), and hand back
    # a UNORM (linear:true) texture — same raw-passthrough path the full-pane view uses.
    func thumbnail [ cv: Canvas ] -> Texture
        if [ !src ] return null
        im : Image [ '{src}' ]
        if [ im.width <= 0 || im.height <= 0 ] return null
        mx : i32 [ (im.width > im.height) ? im.width : im.height ]
        if [ mx > 256 ]
            sc : f32 [ 256.0 / f32[ mx ] ]
            tw : i32 [ i32[ f32[ im.width ] * sc ] ]
            th : i32 [ i32[ f32[ im.height ] * sc ] ]
            if [ tw < 1 ] tw = 1
            if [ th < 1 ] th = 1
            im = im.resize[ tw, th ]
        return Texture [ vk: cv.vk, w: cv.w, sampler: im, width: im.width, height: im.height, linear: true ]

    func render [ cv: Canvas, bounds: rect ]
        if [ !loaded ]
            loaded = true
            if [ src ]
                im : Image [ '{src}' ]
                iw = f32[ im.width ]
                ih = f32[ im.height ]
                if [ im.width > 0 && im.height > 0 ]
                    # linear:true → VK_FORMAT_R8G8B8A8_UNORM: pass the sRGB png bytes
                    # through RAW to the (raw, no-re-encode) UNORM swapchain, so the sRGB
                    # display shows them unchanged — same path the UI's sRGB hex colors
                    # take. sampling as sRGB here degammas to linear and renders dark.
                    tex = Texture [ vk: cv.vk, w: cv.w, sampler: im, width: im.width, height: im.height, linear: true ]
        if [ !tex || iw <= 0.0 || ih <= 0.0 ] return
        sc : f32 [ minf[ bounds.w / iw, bounds.h / ih ] ]
        if [ sc > 1.0 ] sc = 1.0
        dw : f32 [ iw * sc ]
        dh : f32 [ ih * sc ]
        dx : f32 [ bounds.x + (bounds.w - dw) * 0.5 ]
        dy : f32 [ bounds.y + (bounds.h - dh) * 0.5 ]
        cv.draw_image[ tex, rect [ x: dx, y: dy, w: dw, h: dh ] ]

    func release []
        tex = null
        loaded = false

Layer EditorLayer
    mutable sel_color      : rgba
    mutable line_color     : rgba
    # browse/results header row background (the rounded pill behind each item) — CSS
    # property `item_color`. falls back to a default when unset.
    mutable item_color     : rgba
    # active-line glow (css-colored): used for the tab-explorer mouse-over row AND the
    # debugger's current stop line. a warm gradient row + inner glow + text color.
    mutable hl_fill        : rgba
    mutable hl_grad        : rgba
    mutable hl_glow        : rgba
    mutable hl_text        : rgba

    # draw one warm highlighted row: gradient fill (hl_fill→hl_grad, vertical) + inner
    # glow (hl_glow), rounded. save/restore so the gradient/glow don't leak to later draws.
    func glow_row [ cv: Canvas, rx: f32, ry: f32, rw: f32, rh: f32 ]
        cv.save[ ]
        cv.rounded[ 6.0, 6.0, 6.0, 6.0 ]
        cv.stroke_width[ 0.0 ]
        cv.fill_color[ hl_fill ]
        if [ hl_grad ]
            cv.fill_grad[ hl_grad ]
            cv.fill_color_pos[ rx, ry ]
            cv.fill_grad_pos[ rx, ry + rh ]
        if [ hl_glow ] cv.inner_glow[ hl_glow, 14.0 ]
        cv.rect_to[ rx, ry, rw, rh ]
        cv.paint[ ]
        cv.restore[ ]

    func on_move [ ev: Event ]
        editor : Editor[ parent ]
        if [ !editor || !editor.dragging ] return
        lh    : f32 [ (editor.lh_cache > 0.0) ? editor.lh_cache : 22.0 ]
        cw    : f32 [ (editor.cw_cache > 0.0) ? editor.cw_cache : 8.0 ]
        rel_y : f32 [ ev.mouse.pos.y ]
        rel_x : f32 [ ev.mouse.pos.x ]
        raw   : i32 [ clamp[ rel_y / lh, 0, editor.line_count[] - 1 ] ]
        ln    : i32 [ editor.snap_row[ raw ] ]
        vx    : f32 [ round[ (rel_x - editor.row_indent[ ln ] + editor.scroll.x) / cw ] ]
        cl    : i32 [ editor.model_col[ editor.line_get[ ln ], i32[ vx ] ] ]
        editor.sel_line = ln
        editor.sel_col  = cl
        editor.pristine = false

    # content hash of a code line: text bytes + each color region (col/len/rgb). identical
    # content → identical hash → the cached canvas is reused (scroll fast path).
    func code_hash [ editor: Editor, msl: i32, ln: string ] -> i64
        h : i64 [ 1469598103934665603 ]
        for [ i: i32 0, i < ln.count, i += 1 ]
            h = (h ^ i64[ ln[i] ]) * 1099511628211
        nrg : i32 [ editor.line_reg_count[ msl ] ]
        for [ ri: i32 0, ri < nrg, ri += 1 ]
            cr : ColorRegion editor.line_reg[ msl, ri ]
            h = (h ^ i64[ cr.col ]) * 1099511628211
            h = (h ^ i64[ cr.len ]) * 1099511628211
            h = (h ^ i64[ i32[ cr.color.r * 255.0 ] + i32[ cr.color.g * 255.0 ] * 256 + i32[ cr.color.b * 255.0 ] * 65536 ]) * 1099511628211
        return h

    # cached canvas holding a code line's rasterized text. content-addressed: a pooled canvas
    # with the same hash is reused with NO work (scroll/unchanged → blit). a miss recycles a
    # slot not used this frame (reusing its QUANTIZED canvas — resize within capacity is free,
    # no realloc) or grows the pool, then rasterizes once with monospace column-math x.
    func code_slot [ cv: Canvas, editor: Editor, msl: i32, ln: string, cmt_c: rgba, lh: f32, cw: f32, code_fs: i32 ] -> EdLineCache
        ll : i32 [ ln.count ]
        if [ ll == 0 ] return null
        if [ !editor.code_lines ] editor.code_lines = array EdLineCache [ alloc: 64 ]
        h : i64 [ code_hash[ editor, msl, ln ] ]
        for [ slot: EdLineCache ] in editor.code_lines
            if [ slot.canvas && slot.hash == h ]
                slot.frame = editor.cl_frame
                return slot
        use : EdLineCache [ null ]
        for [ slot: EdLineCache ] in editor.code_lines
            if [ slot.frame != editor.cl_frame ]
                use = slot
                break
        if [ !use ]
            use = EdLineCache [ ]
            editor.code_lines.push[ use ]
        disp : editor.display_of[ ln ]
        cw_i : i32 [ i32[ ceil[ f32[ disp.count ] * cw + cw ] ] ]
        if [ cw_i < 1 ] cw_i = 1
        lh_i : i32 [ i32[ ceil[ lh ] ] + 1 ]
        if [ !use.canvas ]
            use.canvas = Canvas [ vk: cv.vk, w: cv.w, format: Pixel.rgba8, width: cw_i, height: lh_i, load_existing: true, quantize: true ]
            use.canvas.update[]
        el [ use.canvas.content_w != cw_i || use.canvas.content_h != lh_i ]
            use.canvas.resize[ cw_i, lh_i ]
        lc : use.canvas
        lc.reset[ vec4f [ 0.0, 0.0, 0.0, 0.0 ] ]
        if [ code_fs > 0 ] lc.font_size[ code_fs ]
        editor.text_lines_frame += 1
        editor.text_lines_total += 1
        rw  : f32 [ f32[ cw_i ] ]
        # in list / results mode (tab explorer, navigate list, or find-in-files) the
        # rows aren't this editor's loaded source — find-in-files matches come from
        # OTHER files, so the loaded color-map regions don't apply. skip them and render
        # the row plain rather than miscoloring with the current file's map.
        nrg : i32 [ (editor.finder_list || editor.show_nav || editor.show_hits) ? 0 : editor.line_reg_count[ msl ] ]
        if [ nrg == 0 ]
            tc : rgba['#fff']
            for [ k: i32 0, k < ll, k += 1 ]
                if [ ln[k] == 35 ]
                    tc = cmt_c
                    break
            lc.fill_color[ tc ]
            lc.draw_text[ disp, rect [ x: 0.0, y: 0.0, w: rw, h: lh ],
                vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
        el
            col : i32 [ 0 ]
            for [ ri: i32 0, ri < nrg, ri += 1 ]
                cr : ColorRegion editor.line_reg[ msl, ri ]
                c0 : i32 [ cr.col ]
                if [ c0 < 0 ] c0 = 0
                if [ c0 > ll ] c0 = ll
                sl : i32 [ cr.len ]
                if [ c0 + sl > ll ] sl = ll - c0
                if [ c0 > col ]
                    gx : f32[ editor.display_of[ ln.mid[ 0, col ] ].count ] * cw
                    lc.fill_color[ rgba['#fff'] ]
                    lc.draw_text[ editor.display_of[ ln.mid[ col, c0 - col ] ],
                        rect [ x: gx, y: 0.0, w: rw, h: lh ],
                        vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
                    col = c0
                if [ sl > 0 ]
                    tx : f32[ editor.display_of[ ln.mid[ 0, c0 ] ].count ] * cw
                    lc.fill_color[ cr.color ]
                    lc.draw_text[ ln.mid[ c0, sl ],
                        rect [ x: tx, y: 0.0, w: rw, h: lh ],
                        vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
                    col = c0 + sl
            if [ col < ll ]
                gc : rgba['#fff']
                for [ k: i32 col, k < ll, k += 1 ]
                    if [ ln[k] == 35 ]
                        gc = cmt_c
                        break
                ex : f32 [ f32[ editor.display_of[ ln.mid[ 0, col ] ].count ] * cw ]
                lc.fill_color[ gc ]
                lc.draw_text[ editor.display_of[ ln.mid[ col, ll - col ] ],
                    rect [ x: ex, y: 0.0, w: rw, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
        lc.paint[ ]
        use.hash  = h
        use.frame = editor.cl_frame
        return use

    # combined content hash of a vertical band of `bands` flat rows starting at `bs`. seeded
    # by the band's absolute start (so two bands never alias to one slot) and the font size
    # (so zoom invalidates). header/var/empty rows fold a sentinel — they aren't rastered
    # into the band (drawn live), but a change in row layout must still bust the band.
    func band_hash [ editor: Editor, bs: i32, bands: i32, code_fs: i32 ] -> i64
        h : i64 [ i64[ bs ] * 1099511628211 + i64[ code_fs ] ]
        for [ k: i32 0, k < bands, k += 1 ]
            li : i32 [ bs + k ]
            if [ li >= editor.line_count[] ] break
            if [ editor.row_header[ li ] || editor.row_var[ li ] ]
                h = (h ^ 1) * 1099511628211
                continue
            ln : editor.line_get[ li ]
            if [ ln.count == 0 ]
                h = (h ^ 2) * 1099511628211
                continue
            h = (h ^ code_hash[ editor, editor.row_src[ li ], ln ]) * 1099511628211
        return h

    # raster a vertical BAND of `bands` flat rows (plain code lines only — headers/var/empty
    # rows are skipped, left transparent, and drawn live by the content loop) into ONE
    # canvas, content-addressed by band_hash. this collapses N tiny per-line render targets
    # into a few large ones, which a tiled GPU (Metal via MoltenVK) handles far more cheaply.
    func code_band [ cv: Canvas, editor: Editor, bs: i32, bands: i32, cmt_c: rgba, lh: f32, cw: f32, code_fs: i32 ] -> EdLineCache
        if [ !editor.code_lines ] editor.code_lines = array EdLineCache [ alloc: 16 ]
        h    : i64 [ band_hash[ editor, bs, bands, code_fs ] ]
        # width = widest code row in the band; height spans all `bands` rows.
        maxw     : i32 [ 1 ]
        has_code : bool [ false ]
        for [ k: i32 0, k < bands, k += 1 ]
            li : i32 [ bs + k ]
            if [ li >= editor.line_count[] ] break
            if [ editor.row_header[ li ] || editor.row_var[ li ] ] continue
            ln : editor.line_get[ li ]
            if [ ln.count == 0 ] continue
            has_code = true
            cwi : i32 [ i32[ ceil[ f32[ editor.display_of[ ln ].count ] * cw + cw ] ] ]
            if [ cwi > maxw ] maxw = cwi
        if [ !has_code ] return null
        lc_h : i32 [ i32[ ceil[ f32[ bands ] * lh ] ] + 1 ]
        # cache hit → reuse, just tick the frame
        for [ slot: EdLineCache ] in editor.code_lines
            if [ slot.canvas && slot.hash == h ]
                slot.frame = editor.cl_frame
                return slot
        # recycle a slot not used this frame (genuinely off-screen band), else grow
        use : EdLineCache [ null ]
        for [ slot: EdLineCache ] in editor.code_lines
            if [ slot.frame != editor.cl_frame ]
                use = slot
                break
        if [ !use ]
            use = EdLineCache [ ]
            editor.code_lines.push[ use ]
        if [ !use.canvas ]
            use.canvas = Canvas [ vk: cv.vk, w: cv.w, format: Pixel.rgba8, width: maxw, height: lc_h, load_existing: true, quantize: true ]
            use.canvas.update[]
        el [ use.canvas.content_w != maxw || use.canvas.content_h != lc_h ]
            use.canvas.resize[ maxw, lc_h ]
        lc : use.canvas
        lc.reset[ vec4f [ 0.0, 0.0, 0.0, 0.0 ] ]
        if [ code_fs > 0 ] lc.font_size[ code_fs ]
        rw : f32 [ f32[ maxw ] ]
        for [ k: i32 0, k < bands, k += 1 ]
            li : i32 [ bs + k ]
            if [ li >= editor.line_count[] ] break
            if [ editor.row_header[ li ] || editor.row_var[ li ] ] continue
            ln : editor.line_get[ li ]
            ll : i32 [ ln.count ]
            if [ ll == 0 ] continue
            editor.text_lines_frame += 1
            editor.text_lines_total += 1
            yk   : f32 [ f32[ k ] * lh ]
            msl  : i32 [ editor.row_src[ li ] ]
            disp : editor.display_of[ ln ]
            nrg  : i32 [ (editor.finder_list || editor.show_nav || editor.show_hits) ? 0 : editor.line_reg_count[ msl ] ]
            if [ nrg == 0 ]
                tc : rgba['#fff']
                for [ kk: i32 0, kk < ll, kk += 1 ]
                    if [ ln[kk] == 35 ]
                        tc = cmt_c
                        break
                lc.fill_color[ tc ]
                lc.draw_text[ disp, rect [ x: 0.0, y: yk, w: rw, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            el
                col : i32 [ 0 ]
                for [ ri: i32 0, ri < nrg, ri += 1 ]
                    cr : ColorRegion editor.line_reg[ msl, ri ]
                    c0 : i32 [ cr.col ]
                    if [ c0 < 0 ] c0 = 0
                    if [ c0 > ll ] c0 = ll
                    sl : i32 [ cr.len ]
                    if [ c0 + sl > ll ] sl = ll - c0
                    if [ c0 > col ]
                        gx : f32 [ f32[ editor.display_of[ ln.mid[ 0, col ] ].count ] * cw ]
                        lc.fill_color[ rgba['#fff'] ]
                        lc.draw_text[ editor.display_of[ ln.mid[ col, c0 - col ] ],
                            rect [ x: gx, y: yk, w: rw, h: lh ],
                            vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
                        col = c0
                    if [ sl > 0 ]
                        tx : f32 [ f32[ editor.display_of[ ln.mid[ 0, c0 ] ].count ] * cw ]
                        lc.fill_color[ cr.color ]
                        lc.draw_text[ ln.mid[ c0, sl ],
                            rect [ x: tx, y: yk, w: rw, h: lh ],
                            vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
                        col = c0 + sl
                if [ col < ll ]
                    gc : rgba['#fff']
                    for [ kk: i32 col, kk < ll, kk += 1 ]
                        if [ ln[kk] == 35 ]
                            gc = cmt_c
                            break
                    ex : f32 [ f32[ editor.display_of[ ln.mid[ 0, col ] ].count ] * cw ]
                    lc.fill_color[ gc ]
                    lc.draw_text[ editor.display_of[ ln.mid[ col, ll - col ] ],
                        rect [ x: ex, y: yk, w: rw, h: lh ],
                        vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
        lc.paint[ ]
        use.hash  = h
        use.frame = editor.cl_frame
        return use

    func draw [ cv: Canvas ]
        editor : Editor[ parent ]
        if [ !editor ] return
        # a non-text resource (image/…) renders through its ResourceView, not as code —
        # but NOT while this pane is showing the finder/browse list (show_hits), so the
        # title still brings up the file index over an image pane. render* = poly dispatch
        # to the subclass (plain render[] would call the no-op base).
        if [ editor.rview && !editor.show_hits ]
            editor.rview.render*[ cv, bounds ]
            return
        if [ !editor.lines ] return
        # find-in-files results, propagated to this instance via apply_args
        showing : bool [ editor.show_hits ]
        # results open with NO selection — nothing is selected until a row is clicked
        if [ showing && !editor.was_showing ]
            editor.sel_line = -1
        editor.was_showing = showing
        hits    : array FindHit [ editor.hits ]
        # code font size from orbiter's setting (canvas default is large). set it
        # before measuring so line_height / char width track the chosen size.
        code_fs : i32 [ (editor.code_font_size > 0) ? editor.code_font_size : 15 ]
        cv.font_size[ code_fs ]
        cw_tm   : cv.measure_text[ 'x' ]
        # integer row height: the font line height is fractional (e.g. 32.5), so with a
        # fractional lh, round(y0 + li*lh - scroll.y) rounds adjacent rows differently as
        # scroll eases — gaps flip 32/33px and rows wiggle. snapping lh to a whole pixel
        # makes the row grid uniform (round distributes: round(a + li*lh) = round(a) +
        # li*lh), so every row shares one base offset. lh_cache (hit-testing) inherits it.
        lh      : f32 [ round[ cv.get_line_height[] * ((label_height > 0.0) ? label_height : 1.0) ] ]
        # find/replace bar open: the findbar now REPLACES the single title row in place
        # (same 44px height as the normal title), so the content no longer needs to shift
        # down — the old +44px offset left a blank line above the code.
        # gutter width = digit count of the last line number * char width + pad.
        # the code content is pushed right by this width.
        ndigits : i32 [ 1 ]
        ncount  : i32 [ editor.line_count[] ]
        while [ ncount >= 10 ]
            ncount  = ncount / 10
            ndigits += 1
        # always reserve room for 10000 lines (5 digits) so the gutter width — and the code
        # origin / mask keep-strip that key off it — stay stable instead of auto-sizing.
        if [ ndigits < 5 ] ndigits = 5
        gut_w   : f32 [ f32[ ndigits ] * cw_tm.w + 16.0 ]
        editor.gutter_w = gut_w
        # x0 is the code-text origin; subtract scroll.x for horizontal scroll (the
        # gutter uses bounds.x, so it stays fixed). clamp scroll.x >= 0.
        if [ editor.scroll.x < 0.0 ] editor.scroll.x = 0.0
        x0      : f32 [ bounds.x + gut_w - editor.scroll.x ]
        y0      : f32 [ bounds.y ]
        # inset the content on the right so code/text never draws under the right-
        # side overlays: the pin list (144px while searching) and the stack sub-
        # column (its actual rendered width while open). take the wider — the pins
        # draw in front of the sub-column when both are present.
        dbg_el  : element editor.elements['dbg']
        din     : f32 [ 0.0 ]
        if [ dbg_el && dbg_el.bounds ]
            din = dbg_el.bounds.w
        pin_in  : f32 [ (editor.elements['pins']) ? 144.0 : 0.0 ]
        rin     : f32 [ maxf[ pin_in, din ] ]
        # edge text fades via the element's grayscale mask: the rightmost 1/8 always
        # fades (long lines dissolve), and on horizontal scroll the left fade turns on,
        # originating at the gutter's right edge (max there) so off-screen-left code
        # dissolves to alpha — same look as the right. vec4 = (top, right, bottom, left).
        # grid (thumbnail) view shows whole cells edge-to-edge — the code edge-fade mask
        # would dim the outer thumbnails, so turn it off entirely in grid mode.
        if [ editor.grid_mode ]
            parent.mask_glow   = vec4f [ 0.0, 0.0, 0.0, 0.0 ]
            parent.mask_keep_l = 0.0
            parent.mask_inset  = vec4f [ 0.0, 0.0, 0.0, 0.0 ]
        el
            left_fade : f32 [ (editor.scroll.x > 0.0) ? bounds.w / 8.0 : 0.0 ]
            # top fade: one line, ONLY when scrolled down (there's hidden code above) — at the
            # very top of the file there's nothing to dissolve into, so no top fade.
            top_fade  : f32 [ (editor.scroll.y > 0.0) ? lh : 0.0 ]
            # bottom fade (3 line-heights) — same grayscale-mask gradient as the right/left
            # edges, so the console can sit clear OVER the editor and the code dissolves into
            # it instead of butting against a hard edge. vec4 = (top, right, bottom, left).
            parent.mask_glow = vec4f [ top_fade, bounds.w / 8.0, lh * 3.0, left_fade ]
            # keep the line-number gutter fully opaque; the left fade starts just past it.
            parent.mask_keep_l = gut_w
            # start the top fade at the bottom of the title bar so code scrolls
            # cleanly under it; fall back to 70px if the title isn't laid out yet.
            title_bottom : f32 [ 70.0 ]
            te : element parent.elements['title']
            if [ te && te.bounds ]
                title_bottom = te.bounds.y + te.bounds.h
            # left inset = gut_w so the left fade originates at the gutter edge, not x=0.
            parent.mask_inset = vec4f [ title_bottom, 0.0, 0.0, gut_w ]
        editor.lh_cache  = lh
        editor.cw_cache  = cw_tm.w
        editor.text_lines_frame = 0
        # per-line cache: tick the frame; flush all slots when font metrics change (size/zoom).
        editor.cl_frame += 1
        if [ editor.cl_cw != cw_tm.w || editor.cl_lh != lh ]
            if [ editor.code_lines ]
                for [ slot: EdLineCache ] in editor.code_lines
                    slot.hash = -1
            editor.cl_cw = cw_tm.w
            editor.cl_lh = lh
        # rebuild the flat row model (base code lines + spliced-in expanded debug
        # field rows) once per frame, before any layout/draw consults line_count.
        editor.rebuild_flat[]
        # every visual row (incl. the 2 file-title slots and any expanded field rows)
        # is one line-height tall; line_count already folds the expanded rows in.
        # grid view lays the index entries out as square cells; its content height is
        # rows-of-cells. compute the layout here so the scroll clamp below uses it.
        grid_cw    : f32 [ 140.0 ]            # cell slot width
        grid_ch    : f32 [ 178.0 ]            # cell slot height (square thumb + 2-line label)
        grid_cols  : i32 [ 1 ]
        grid_pins  : i32 [ 0 ]                # pinned-dock cell count
        grid_res   : i32 [ 0 ]               # result cell count
        if [ editor.grid_mode && editor.hits ]
            gavail : f32 [ bounds.w - rin - 8.0 ]
            grid_cols = i32[ gavail / grid_cw ]
            if [ grid_cols < 1 ] grid_cols = 1
            for [ li: i32 0, li < editor.hits.count, li += 1 ]
                h : FindHit editor.hits[ li ]
                if [ !h || !h.is_header || !h.file || h.is_spacer ] continue
                if [ editor.row_cont[ li ] ] continue
                if [ li < editor.dock_rows ] grid_pins += 1
                el                            grid_res += 1
        # pins fill the top rows; then a one-line-height break (separator), then results.
        grid_resoff : f32 [ 0.0 ]
        if [ editor.grid_mode ]
            pin_rows : i32 [ (grid_pins + grid_cols - 1) / grid_cols ]
            res_rows : i32 [ (grid_res  + grid_cols - 1) / grid_cols ]
            if [ grid_pins > 0 ] grid_resoff = f32[ pin_rows ] * grid_ch + lh
            editor.content_h = grid_resoff + f32[ res_rows ] * grid_ch
            editor.g_cols    = grid_cols
            editor.g_pins    = grid_pins
            editor.g_resoff  = grid_resoff
        el
            # 2 line-heights of bottom padding: lets the scroll go just past the last
            # line so it isn't flush at the bottom edge. no rows live there, so the
            # gutter shows no numbers for the padding.
            editor.content_h = f32[ editor.line_count[] ] * lh + lh * 2.0
        editor.scroll_speed = (editor.grid_mode) ? grid_ch : lh

        # clamp scroll to [0, content - viewport] every frame so it can't go
        # negative (above the top) or past the end of the content.
        max_scroll : f32 [ editor.content_h - bounds.h ]
        if [ max_scroll < 0.0 ] max_scroll = 0.0
        # fold this frame's accumulated raw wheel delta into the target (speed applied here,
        # once, with the current line height) and clear it.
        if [ editor.pending_wheel != 0.0 ]
            editor.scroll_target = editor.scroll_target - editor.pending_wheel * lh * 0.375
            editor.pending_wheel = 0.0
        if [ editor.scroll_target < 0.0 ] editor.scroll_target = 0.0
        if [ editor.scroll_target > max_scroll ] editor.scroll_target = max_scroll
        # ease scroll.y toward the target each frame → smooth, frame-paced scrolling. when a
        # direct setter (drag, cursor-follow) moved scroll.y, the target was synced to it, so
        # this is a no-op then. keep requesting frames while there's distance left to cover.
        sdy : f32 [ editor.scroll_target - editor.scroll.y ]
        if [ (sdy > 0.5) || (sdy < 0.0 - 0.5) ]
            editor.scroll.y = editor.scroll.y + sdy * 0.35
            # the glide changes scroll.y, so the pane must redraw next frame. needs_frame is
            # the flag that survives the post-draw `pristine = true` (trinity keeps the element
            # dirty when it's set), so the ease keeps running on its own instead of stalling
            # until a hover. also wake the render loop.
            parent.needs_frame = true
            if [ editor.ux ] editor.ux.will_animate = true
        el
            editor.scroll.y = editor.scroll_target
        if [ editor.scroll.y < 0.0 ] editor.scroll.y = 0.0
        if [ editor.scroll.y > max_scroll ] editor.scroll.y = max_scroll

        # clip scrolled text to the editor bounds (world-space px = transform
        # offset + local bounds). same crop data the shaders read for shapes.
        wtx : f32 [ cv.transform_tx[] ]
        wty : f32 [ cv.transform_ty[] ]
        cv.set_crop[ wtx + bounds.x, wty + bounds.y,
            wtx + bounds.x + bounds.w - rin, wty + bounds.y + bounds.h ]

        # ---- grid view: the index entries tiled as cells — thumbnail on top, two labels
        # (name over dir) under it; cells separated by a margin; rounded selection box ----
        if [ editor.grid_mode && editor.hits ]
            gm    : f32 [ 8.0 ]                 # margin inside each cell slot
            gth   : f32 [ grid_cw - gm * 2.0 ]  # square thumbnail size
            pin_i : i32 [ 0 ]
            res_i : i32 [ 0 ]
            # separator line in the break gap between the pinned cells and the results.
            if [ grid_pins > 0 ]
                pr : i32 [ (grid_pins + grid_cols - 1) / grid_cols ]
                sy : f32 [ y0 + f32[ pr ] * grid_ch + lh * 0.5 - editor.scroll.y ]
                if [ sy >= bounds.y && sy <= bounds.y + bounds.h ]
                    cv.fill_color  [ rgba['#ffffff30'] ]
                    cv.stroke_width[ 0.0 ]
                    cv.rect_to     [ bounds.x + 8.0, round[ sy ], bounds.w - rin - 16.0, 1.0 ]
                    cv.paint       [ ]
            for [ li: i32 0, li < editor.hits.count, li += 1 ]
                h : FindHit editor.hits[ li ]
                if [ !h || !h.is_header || !h.file || h.is_spacer ] continue
                if [ editor.row_cont[ li ] ] continue
                is_pin : bool [ li < editor.dock_rows ]
                gidx : i32 [ (is_pin) ? pin_i : res_i ]
                col  : i32 [ gidx % grid_cols ]
                grow : i32 [ gidx / grid_cols ]
                if [ is_pin ] pin_i += 1
                el            res_i += 1
                cx : f32 [ bounds.x + 4.0 + f32[ col ] * grid_cw ]
                cy : f32 [ ((is_pin) ? (y0 + f32[ grow ] * grid_ch) : (y0 + grid_resoff + f32[ grow ] * grid_ch)) - editor.scroll.y ]
                if [ cy + grid_ch < bounds.y || cy > bounds.y + bounds.h ] continue
                # selection / hover box — inset by half the margin so cells stay separated
                if [ li == editor.sel_line || li == editor.hover_line ]
                    cv.fill_color  [ rgba['#6cb6ff22'] ]
                    cv.stroke_color[ rgba['#6cb6ffcc'] ]
                    cv.stroke_width[ 1.0 ]
                    cv.rounded_rect[ cx + gm * 0.5, cy + gm * 0.5, grid_cw - gm, grid_ch - gm, 8.0, 8.0, 8.0, 8.0 ]
                    cv.paint       [ ]
                    cv.stroke_width[ 0.0 ]
                # thumbnail (image) or folder/file icon at the top of the cell
                ix : f32 [ cx + gm ]
                iy : f32 [ cy + gm ]
                tex : editor.thumb_for[ h.file, cv ]
                if [ tex ]
                    # aspect-fit the square: scale so the LONGER side meets the square (no
                    # stretch, no crop), and center the result within the cell.
                    tw  : f32 [ f32[ tex.width ] ]
                    th  : f32 [ f32[ tex.height ] ]
                    csc : f32 [ (tw > 0.0 && th > 0.0) ? minf[ gth / tw, gth / th ] : 1.0 ]
                    dw  : f32 [ tw * csc ]
                    dh  : f32 [ th * csc ]
                    dx  : f32 [ ix + (gth - dw) * 0.5 ]
                    dy  : f32 [ iy + (gth - dh) * 0.5 ]
                    cv.draw_image[ tex, rect [ x: dx, y: dy, w: dw, h: dh ] ]
                el
                    if [ !editor.folder_icon ]
                        ffp : path 'images/folder.svg'
                        if [ ffp.exists[] ] editor.folder_icon = SVGModel [ ffp ]
                    if [ !editor.file_icon ]
                        ffp2 : path 'images/file.svg'
                        if [ ffp2.exists[] ] editor.file_icon = SVGModel [ ffp2 ]
                    ico : SVGModel [ (h.is_dir) ? editor.folder_icon : editor.file_icon ]
                    if [ ico ]
                        hsz : f32 [ gth * 0.5 ]
                        cv.draw_svg[ ico, ix + gth * 0.25, iy + gth * 0.25, hsz, hsz ]
                # one label under the thumbnail: the name (like a folder cell)
                ty : f32 [ cy + gm + gth + 2.0 ]
                cv.font_size[ code_fs ]
                cv.fill_color[ (h.is_dir) ? rgba['#6cb6ff'] : rgba['#fff'] ]
                cv.draw_text[ h.text, rect [ x: cx + gm, y: ty, w: grid_cw - gm * 2.0, h: 16.0 ],
                    vec2f [ 0.5, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.ellipsis, null ]
            cv.clear_crop[ ]
            return

        # active-line glow: in the tab explorer it's the mouse-over row; otherwise it's
        # the debugger's current stop line. drawn behind the gutter/code so numbers and
        # text sit on top. its text is recolored to hl_text in the content loop.
        # mouse-over highlight while navigating a list (tab explorer or find results);
        # otherwise the debugger's current stop line.
        in_list : bool [ editor.finder_list || showing ]
        # stop_line is a base source line; map it to its visual flat row so the glow,
        # text recolor, and gutter marker land on the right row when the tree is open.
        stop_vrow : i32 [ editor.vis_row[ editor.stop_line ] ]
        hl_line : i32 [ (in_list) ? editor.hover_line : stop_vrow ]
        if [ hl_line >= 0 && hl_line < editor.line_count[] && hl_fill && !editor.row_spacer[ hl_line ] ]
            # a file-title header spans 2 row slots — snap to its first slot and make
            # the glow cover both, so the whole title highlights as one band instead of
            # only the half the cursor happens to be over.
            gl : i32 [ hl_line ]
            gh : f32 [ lh - 2.0 ]
            if [ editor.row_header[ gl ] ]
                if [ editor.row_cont[ gl ] ] gl = gl - 1
                # single-line headers are one slot; double headers span two.
                gh = (editor.single_line) ? lh - 2.0 : lh * 2.0 - 2.0
            hy : f32 [ y0 + f32[ gl ] * lh - editor.scroll.y ]
            if [ hy + gh >= bounds.y && hy <= bounds.y + bounds.h ]
                glow_row[ cv, bounds.x + 1.0, hy + 1.0, bounds.w - rin - 2.0, gh ]

        # ---- gutter: per-line flat cells, line numbers, hover + breakpoint ----
        # breakpoint colors the entire line (full width) behind the code; the
        # flat cell + right-aligned number sit in the gutter column on the left.
        cv.stroke_width[ 0.0 ]
        # line-number labels render 30% smaller than the code font, then 1px smaller
        num_fs  : i32 [ i32[ f32[ code_fs ] * 0.7 ] - 1 ]
        cv.font_size[ num_fs ]
        for [ li: i32 0, li < editor.line_count[], li += 1 ]
            # file-title slots get no gutter (number / cell / breakpoint); the title
            # itself is drawn in the content loop below.
            if [ editor.row_header[ li ] ] continue
            # virtual debug field rows get no gutter cell / number / breakpoint.
            if [ editor.row_var[ li ] ] continue
            # snap the row-top to the integer pixel grid — the cached text blits at
            # round[y], so the gutter/breakpoint/selection decorations must round too,
            # else they slide sub-pixel against the snapped text as scroll.y eases.
            yg : f32 [ round[ y0 + f32[li] * lh - editor.scroll.y ] ]
            if [ yg + lh < bounds.y ] continue
            if [ yg > bounds.y + bounds.h ] break
            # each row keys its breakpoint + line number off its own source: in
            # results mode that's the match's origin file + line, else this editor's
            # base source line (which, with the tree open, differs from the visual row).
            bsl  : i32  [ editor.row_src[ li ] ]
            rnum : i32  [ (showing && hits) ? hits[li].line : bsl + 1 ]
            # breakpoints are a file-editing concept — never washed in results view
            if [ !showing ]
                bp : editor.breakpoints['{editor.src}:{bsl + 1}']
                if [ bp != null ]
                    cv.fill_color[ editor.bp_color[ bp ] ]
                    cv.rect_to[ bounds.x, yg, bounds.w - rin - 1.0, lh ]
                    cv.paint[ ]
            # current/selected-line background — painted here in the gutter stage (BEHIND
            # the code) exactly like the breakpoint band, so the code sits on top and the
            # color shows through, and it's masked at the edges the same way.
            if [ editor.sel_line >= 0 && editor.sel_line < editor.line_count[] ]
                a_ln : i32 [ clamp[ editor.anchor_line, 0, editor.line_count[] - 1 ] ]
                s_ln : i32 [ editor.sel_line ]
                lo   : i32 [ (a_ln < s_ln) ? a_ln : s_ln ]
                hi   : i32 [ (a_ln < s_ln) ? s_ln : a_ln ]
                if [ li >= lo && li <= hi ]
                    cv.fill_color[ (line_color) ? line_color : rgba['#ffffff18'] ]
                    # in results the selected row is a single match — draw it as a rounded
                    # 6px pill. normal editing keeps the full-width square current-line band.
                    if [ showing ]
                        cv.rounded_rect[
							bounds.x + 1.0, yg + 1.0, 
							bounds.w - rin - 3.0, 
							lh - 2.0, 3.0, 3.0, 3.0, 3.0 ]
                    el
                        cv.rect_to[ bounds.x, yg, bounds.w - rin - 1.0, lh ]
                    cv.paint[ ]
            cv.fill_color[ rgba['#ffffff08'] ]
            cv.rect_to[ bounds.x + 2.0, yg + 1.0, gut_w - 4.0, lh - 2.0 ]
            cv.paint[ ]
            # the debugger's current stop line (active break): a white border around the
            # entire colored line, plus a small filled white ">" arrow at the left edge
            # (x 0 → 6px), centered. drawn over the gutter cell so both stay visible.
            if [ !showing && stop_vrow == li ]
                mid : f32 [ yg + lh * 0.5 ]
                cv.save[ ]
                # white outline around the whole line — rounded to match the glow_row
                # highlight (same 6px radius + 1px inset).
                cv.rounded[ 6.0, 6.0, 6.0, 6.0 ]
                cv.fill_color[ rgba['#00000000'] ]
                cv.stroke_color[ rgba['#ff44'] ]
                cv.stroke_width[ 1.0 ]
                cv.rect_to[ bounds.x + 1.0, yg + 1.0, bounds.w - rin - 2.0, lh - 2.0 ]
                cv.paint[ ]
                cv.stroke_width[ 0.0 ]
                cv.rounded[ 0.0, 0.0, 0.0, 0.0 ]
                # execution marker: a sideways "house" (flat back + pointed front) — a
                # rectangular body that tapers to a point at the code. sits past the
                # line-number column, tip at the gutter/code boundary.
                cv.fill_color[ rgba['#ffffff'] ]
                gtip : f32 [ bounds.x + gut_w + 12.0 ]
                cv.move_to[ gtip - 11.0, mid - 6.0 ]
                cv.line_to[ gtip - 6.0,  mid - 6.0 ]
                cv.line_to[ gtip,        mid ]
                cv.line_to[ gtip - 6.0,  mid + 6.0 ]
                cv.line_to[ gtip - 11.0, mid + 6.0 ]
                cv.close_path[ ]
                cv.paint[ ]
                # the exact stop column lldb reported — a thin gold caret in the code
                # (separate from the edit selection), marking where execution paused.
                if [ editor.stop_col >= 0 ]
                    cx : f32 [ x0 + f32[editor.stop_col] * cw_tm.w ]
                    cv.fill_color[ rgba['#ffcc33'] ]
                    cv.rect_to[ cx, yg + 1.0, 2.0, lh - 2.0 ]
                    cv.paint[ ]
                cv.restore[ ]
            # only when the gutter itself is hovered does the close icon take it
            # over, so the line number is suppressed just then (icon drawn below).
            if [ !(showing && editor.hover_gutter && editor.hover_line == li) ]
                cv.fill_color[ rgba['#ffffff80'] ]
                cv.draw_text[ '{rnum}',
                    rect [ x: bounds.x, y: yg, w: gut_w - 6.0, h: lh ],
                    vec2f [ 1.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]

        # restore the code font before drawing line content
        cv.font_size[ code_fs ]
        # when horizontally scrolled, tighten the crop so code shifted left doesn't
        # draw over the (stationary) line-number gutter. the gutter loop above already
        # drew under the wider editor-bounds crop.
        if [ editor.scroll.x > 0.0 ]
            cv.set_crop[ wtx + bounds.x + gut_w, wty + bounds.y,
                wtx + bounds.x + bounds.w - rin, wty + bounds.y + bounds.h ]
        # band mode: composite code rows into vertical tiles and blit a handful of large
        # render targets instead of one tiny RT per line. reserve the visible bands' slots
        # first (so a top-band miss can't recycle a slot a lower visible band still needs),
        # then ensure/blit each. the content loop below skips its per-line code blit.
        if [ editor.band_rows != 1 ]
            br : i32 [ (editor.band_rows >= 2) ? editor.band_rows : 8 ]
            fr : i32 [ i32[ editor.scroll.y / lh ] ]
            lr : i32 [ i32[ (editor.scroll.y + bounds.h) / lh ] ]
            if [ fr < 0 ] fr = 0
            fb : i32 [ fr / br ]
            lb : i32 [ lr / br ]
            cmt_b : rgba['#7a8290']
            if [ editor.code_lines ]
                for [ b: i32 fb, b <= lb, b += 1 ]
                    bs : i32 [ b * br ]
                    if [ bs >= editor.line_count[] ] break
                    bh : i64 [ band_hash[ editor, bs, br, code_fs ] ]
                    for [ slot: EdLineCache ] in editor.code_lines
                        if [ slot.canvas && slot.hash == bh ]
                            slot.frame = editor.cl_frame
                            break
            for [ b: i32 fb, b <= lb, b += 1 ]
                bs : i32 [ b * br ]
                if [ bs >= editor.line_count[] ] break
                bnd : EdLineCache code_band[ cv, editor, bs, br, cmt_b, lh, cw_tm.w, code_fs ]
                if [ bnd && bnd.canvas ]
                    by : f32 [ y0 + f32[ bs ] * lh - editor.scroll.y ]
                    cv.draw_canvas[ bnd.canvas, x0, round[ by ], f32[ bnd.canvas.content_w ], f32[ br ] * lh ]
            cv.paint[ ]
        # RESERVE pass (per-line path): mark every visible CACHED line's slot as used THIS
        # frame before any miss rasters. without this, a top-of-screen miss (scroll-up)
        # recycles a slot still needed by a line below → cascade (all lines re-raster).
        el [ editor.code_lines ]
            for [ rli: i32 0, rli < editor.line_count[], rli += 1 ]
                ry : f32 [ y0 + f32[rli] * lh - editor.scroll.y ]
                if [ ry + lh < bounds.y ] continue
                if [ ry > bounds.y + bounds.h ] break
                if [ editor.row_header[ rli ] ] continue
                if [ editor.row_var[ rli ] ] continue
                rln : editor.line_get[ rli ]
                if [ rln.count == 0 ] continue
                rhash : i64 [ code_hash[ editor, editor.row_src[ rli ], rln ] ]
                for [ slot: EdLineCache ] in editor.code_lines
                    if [ slot.canvas && slot.hash == rhash ]
                        slot.frame = editor.cl_frame
                        break
        for [ li: i32 0, li < editor.line_count[], li += 1 ]
            # integral row-top: text (cached blit) and its in-row decorations share one
            # snapped y, so nothing slides sub-pixel against anything else while scrolling.
            y : f32 [ round[ y0 + f32[li] * lh - editor.scroll.y ] ]
            if [ editor.row_header[ li ] ]
                # single-line: one slot, primary font. double: two slots = two small
                # lines (name over dir). draws once on the first slot, spanning its rows.
                if [ editor.row_cont[ li ] ] continue
                # the dock divider's reserved blank row renders nothing (line drawn elsewhere).
                if [ editor.row_spacer[ li ] ] continue
                single : bool [ editor.single_line ]
                rh : f32 [ (single) ? lh : lh * 2.0 ]
                if [ y + rh < bounds.y ] continue
                if [ y > bounds.y + bounds.h ] break
                # distinct background: inset 4px, 12px rounded, blended at 0.5 alpha
                cv.save[ ]
                cv.rounded[ 12.0, 12.0, 12.0, 12.0 ]
                cv.fill_color[ (item_color) ? item_color : rgba['#2b3a5580'] ]
                cv.rect_to[ bounds.x + 2.0, y + 2.0, bounds.w - rin - 4.0, rh - 4.0 ]
                cv.paint[ ]
                cv.restore[ ]
                fhh : FindHit (editor.hits && li < editor.hits.count) ? editor.hits[ li ] : null
                fnm : string (fhh) ? fhh.text : editor.line_get[ li ]
                fdr : string (fhh) ? fhh.dir : ''
                fis_dir : bool [ (fhh) ? fhh.is_dir : false ]
                # a directory row is a blue link with a trailing slash; files stay white.
                if [ fis_dir && fnm.count > 0 ] fnm = '{fnm}/'
                # icon to the left, vertically centered over the row. only load the SVG if
                # it exists — constructing SVGModel on a missing path crashes. text shifts
                # right only when an icon actually drew.
                if [ !editor.folder_icon ]
                    ffp : path 'images/folder.svg'
                    if [ ffp.exists[] ] editor.folder_icon = SVGModel [ ffp ]
                if [ !editor.file_icon ]
                    ffp2 : path 'images/file.svg'
                    if [ ffp2.exists[] ] editor.file_icon = SVGModel [ ffp2 ]
                imdl : SVGModel [ (fis_dir) ? editor.folder_icon : editor.file_icon ]
                tx0  : f32 [ x0 ]
                if [ imdl ]
                    isz : f32 [ round[ lh * ((single) ? 0.7 : 1.0) ] ]
                    iy  : f32 [ round[ y + (rh - isz) * 0.5 ] ]
                    cv.draw_svg[ imdl, x0, iy, isz, isz ]
                    tx0 = x0 + isz + 8.0
                if [ single ]
                    # one line at the primary code font; dir trails dimmed on the right
                    cv.font_size[ code_fs ]
                    cv.fill_color[ (fis_dir) ? rgba['#6cb6ff'] : rgba['#fff'] ]
                    cv.draw_text[ fnm, rect [ x: tx0, y: y, w: bounds.w - rin - tx0, h: rh ],
                        vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]
                    if [ fdr.count > 0 ]
                        # anchor the dir at a fixed ~50% column so rows line up instead of
                        # staggering after the filename; push past it only when a name is
                        # long enough to reach the column.
                        fnw : f32 [ cv.measure_text[ fnm ].w ]
                        col : f32 [ bounds.x + bounds.w * 0.5 ]
                        end : f32 [ tx0 + fnw + cw_tm.w * 2.0 ]
                        dx  : f32 [ (end > col) ? end : col ]
                        cv.fill_color[ rgba['#ffffff66'] ]
                        cv.draw_text[ fdr, rect [ x: dx, y: y, w: bounds.x + bounds.w - rin - dx, h: rh ],
                            vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]
                el
                    # two small-font lines: name on the top slot, dir on the bottom slot.
                    # with no dir (browse list) the name centers across BOTH slots so it
                    # isn't stuck at the top with empty space below.
                    hfs : i32 [ (editor.header_size > 0) ? editor.header_size : code_fs ]
                    cv.font_size[ hfs ]
                    nmh : f32 [ (fdr.count > 0) ? lh : rh ]
                    cv.fill_color[ (fis_dir) ? rgba['#6cb6ff'] : rgba['#fff'] ]
                    cv.draw_text[ fnm, rect [ x: tx0, y: y, w: bounds.w - rin - tx0, h: nmh ],
                        vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]
                    if [ fdr.count > 0 ]
                        dfs : i32 [ (editor.dir_size > 0) ? editor.dir_size : hfs ]
                        cv.font_size[ dfs ]
                        cv.fill_color[ rgba['#ffffff66'] ]
                        cv.draw_text[ fdr, rect [ x: tx0, y: y + lh, w: bounds.w - rin - tx0, h: lh ],
                            vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]
                cv.font_size[ code_fs ]
                # gutter icon, shown on hover. browse/navigate list → a PIN toggle
                # (expand.svg); find-in-files results → the remove-match close icon.
                # the +1 slot only counts in the 2-slot (double) layout, so single-line
                # rows don't light the icon on the row above.
                hov : bool [ editor.hover_gutter && (editor.hover_line == li || (!editor.single_line && editor.hover_line == li + 1)) ]
                if [ hov ]
                    ico : SVGModel [ null ]
                    if [ editor.nav_list ]
                        if [ !editor.pin_icon ]
                            editor.pin_icon = SVGModel [ path 'images/expand.svg' ]
                        ico = editor.pin_icon
                    el
                        if [ !editor.close_icon ]
                            editor.close_icon = SVGModel [ path 'images/close.svg' ]
                        ico = editor.close_icon
                    if [ ico ]
                        hisz : f32 [ round[ lh * 0.5 ] ]
                        hiox : f32 [ round[ bounds.x + (gut_w - hisz) * 0.5 ] ]
                        hioy : f32 [ round[ y + (rh - hisz) * 0.5 ] ]
                        cv.draw_svg[ ico, hiox, hioy, hisz, hisz ]
                        cv.paint[ ]
                continue
            if [ y + lh < bounds.y ] continue
            if [ y > bounds.y + bounds.h ] break
            ln    : editor.line_get[ li ]
            rvd   : variable editor.row_var[ li ]
            if [ rvd ]
                # virtual debug field row (# name = value) — indented by tree depth,
                # rendered in ghost-comment green so it reads as inline annotation. a
                # field that is itself an object/string gets a [+]/[-] so the nested
                # tree is discoverable (clicking the row toggles it).
                dpx : f32 [ x0 + editor.row_indent[ li ] ]
                vtg : string [ (editor.var_expandable[ rvd ]) ? ((rvd.expanded) ? '  [-]' : '  [+]') : '' ]
                cv.fill_color[ rgba['#6a9955cc'] ]
                cv.draw_text[ '{ln}{vtg}',
                    rect [ x: dpx, y: y, w: bounds.x + bounds.w - rin - dpx, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]
                continue
            # band mode already blitted this code row as part of its tile (above); only the
            # per-line path composites here. per-line cache: a scrolled/unchanged line is a
            # hash HIT → just composite its cached canvas (no raster); a changed line rasters.
            if [ editor.band_rows == 1 ]
                cmt_c : rgba['#7a8290']
                msl   : i32 [ editor.row_src[ li ] ]
                slc   : code_slot[ cv, editor, msl, ln, cmt_c, lh, cw_tm.w, code_fs ]
                if [ slc && slc.canvas ]
                    cv.draw_canvas[ slc.canvas, x0, round[ y ], f32[ slc.canvas.content_w ], lh ]
        if [ editor.text_lines_frame > 0 ]
            puts 'TEXT RASTER: {editor.text_lines_frame} lines this frame ({editor.text_lines_total} total)'
        cv.paint[ ]

        # separator line dividing the pinned dock (top rows) from the browse results
        if [ editor.nav_list && editor.dock_rows > 0 && editor.dock_rows < editor.line_count[] ]
            sy : f32 [ y0 + f32[ editor.dock_rows ] * lh - editor.scroll.y ]
            # single-line mode reserves its own row for the divider — center it on that
            # row's y. double mode draws it on the boundary between the two row blocks.
            if [ editor.single_line ] sy = sy + lh * 0.5
            if [ sy >= bounds.y && sy <= bounds.y + bounds.h ]
                cv.fill_color[ rgba['#ffffff30'] ]
                cv.stroke_width[ 0.0 ]
                cv.rect_to[ bounds.x + 6.0, round[ sy ], bounds.w - rin - 12.0, 1.0 ]
                cv.paint[ ]

        # ---- debug-active: inline ghost value annotations (# name = value) ----
        # the collapsed summary at each variable's decl line (the future + expansion
        # title). own pass so it gets its own comment color/paint, after the code.
        if [ !showing && editor.debug_vars ]
            cv.font_size[ code_fs ]
            cv.fill_color[ rgba['#6a9955cc'] ]
            for [ li: i32 0, li < editor.line_count[], li += 1 ]
                if [ editor.row_header[ li ] ] continue
                if [ editor.row_var[ li ] ] continue   # virtual field rows drawn already
                bsl : i32 [ editor.row_src[ li ] ]
                if [ bsl < 0 ] continue
                bk  : i32 [ editor.base_var_at[ bsl ] ]
                if [ bk < 0 ] continue
                bv   : variable editor.debug_vars[ bk ]
                summ : editor.var_summary[ bv ]
                if [ !summ || summ.count == 0 ] continue
                ya : f32 [ y0 + f32[li] * lh - editor.scroll.y ]
                if [ ya + lh < bounds.y ] continue
                if [ ya > bounds.y + bounds.h ] break
                # expandable objects get a [+]/[-] toggle after the summary
                tog : (editor.var_expandable[ bv ]) ? ((bv.expanded) ? '  [-]' : '  [+]') : ''
                ln2 : editor.line_get[ li ]
                aw  : f32 [ cv.measure_text[ ln2 ].w ]
                ax  : f32 [ x0 + aw + 24.0 ]
                # mouse-over an expandable annotation → a soft green glow behind it.
                if [ editor.hover_ann == li ]
                    cv.save[ ]
                    cv.rounded[ 5.0, 5.0, 5.0, 5.0 ]
                    cv.stroke_width[ 0.0 ]
                    cv.fill_color[ rgba['#2f7a4a44'] ]
                    cv.inner_glow[ rgba['#5fd08abb'], 10.0 ]
                    cv.rect_to[ ax - 8.0, ya + 2.0, bounds.x + bounds.w - rin - ax + 4.0, lh - 4.0 ]
                    cv.paint[ ]
                    cv.restore[ ]
                    cv.fill_color[ rgba['#6a9955cc'] ]
                cv.draw_text[ '# {summ}{tog}',
                    rect [ x: ax, y: ya, w: bounds.x + bounds.w - rin - ax, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]
            cv.paint[ ]

        # outline the matched query substring on each visible line. works in BOTH modes:
        # the find-in-files results list AND the normal editor (in-file find = the file shown
        # as-is with every occurrence highlighted in place). measured against the actual glyph
        # advances so tabs/indent line up.
        if [ editor.find_query && editor.find_query.count > 0 ]
            for [ li: i32 0, li < editor.line_count[], li += 1 ]
                if [ editor.row_header[ li ] ] continue
                y : f32 [ y0 + f32[li] * lh - editor.scroll.y ]
                if [ y + lh < bounds.y ] continue
                if [ y > bounds.y + bounds.h ] break
                ln : editor.line_get[ li ]
                qn : i32 [ editor.find_query.count ]
                # outline EVERY occurrence on the row, not just the first: slice past each
                # match and keep searching the remainder (tracking an absolute index so
                # the measured prefix is from the start of the line).
                base : i32 [ 0 ]
                while [ base <= ln.count - qn ]
                    rem : string ln.mid[ base, ln.count - base ]
                    rel : i32 [ rem.index_of[ editor.find_query ] ]
                    if [ rel < 0 ] break
                    mpos : i32 [ base + rel ]
                    # measure the DISPLAY text (tabs expanded) — the row is drawn via
                    # display_of, so measuring the raw line puts the box a few px short
                    # per tab that precedes the match.
                    pre : f32 [ cv.measure_text[ editor.display_of[ ln.mid[ 0, mpos ] ] ].w ]
                    mw  : f32 [ cv.measure_text[ editor.display_of[ ln.mid[ mpos, qn ] ] ].w ]
                    mx  : f32 [ x0 + pre - 1.0 ]
                    # the ACTIVE occurrence (the one Enter stepped to: sel_line + sel_col)
                    # gets a solid white fill with dark text; the rest are outlined.
                    if [ li == editor.sel_line && mpos == editor.sel_col ]
                        cv.fill_color   [ rgba['#ffcc66'] ]
                        cv.stroke_width [ 0.0 ]
                        cv.rounded_rect [ mx, y + 2.0, mw + 2.0, lh - 4.0, 3.0, 3.0, 3.0, 3.0 ]
                        cv.paint        [ ]
                        cv.fill_color   [ rgba['#101418'] ]
                        cv.draw_text    [ editor.display_of[ ln.mid[ mpos, qn ] ],
                            rect [ x: x0 + pre, y: y, w: mw + 2.0, h: lh ],
                            vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
                        cv.paint        [ ]
                    el
                        # non-active occurrences: outlined in the same blue as the editor's
                        # token-click occurrence highlight (the active one keeps the yellow).
                        cv.fill_color   [ rgba['#0000'] ]
                        cv.stroke_color [ rgba['#6cb6ffaa'] ]
                        cv.stroke_width [ 1.0 ]
                        cv.rounded_rect [ mx, y + 2.0, mw + 2.0, lh - 4.0, 3.0, 3.0, 3.0, 3.0 ]
                        cv.paint        [ ]
                    base = mpos + qn
            cv.stroke_width[ 0.0 ]

        # editing mode: outline every whole-word occurrence of the identifier under the
        # cursor — same outline treatment as the find query, distinct color. results mode
        # is skipped (it already outlines the find query).
        if [ !showing ]
            tok : editor.cursor_token[]
            if [ tok && tok.count > 0 ]
                tn : i32 [ tok.count ]
                for [ li: i32 0, li < editor.line_count[], li += 1 ]
                    if [ editor.row_header[ li ] ] continue
                    y : f32 [ round[ y0 + f32[li] * lh - editor.scroll.y ] ]
                    if [ y + lh < bounds.y ] continue
                    if [ y > bounds.y + bounds.h ] break
                    ln : editor.line_get[ li ]
                    base : i32 [ 0 ]
                    while [ base <= ln.count - tn ]
                        rem : string ln.mid[ base, ln.count - base ]
                        rel : i32 [ rem.index_of[ tok ] ]
                        if [ rel < 0 ] break
                        mpos : i32 [ base + rel ]
                        # whole-word only: neighbors must not be identifier chars
                        bok : bool [ mpos == 0 || !editor.word_char[ i32[ ln[mpos - 1] ] ] ]
                        aok : bool [ mpos + tn >= ln.count || !editor.word_char[ i32[ ln[mpos + tn] ] ] ]
                        if [ bok && aok ]
                            pre : f32 [ cv.measure_text[ editor.display_of[ ln.mid[ 0, mpos ] ] ].w ]
                            mw  : f32 [ cv.measure_text[ editor.display_of[ ln.mid[ mpos, tn ] ] ].w ]
                            mx  : f32 [ x0 + pre - 1.0 ]
                            cv.fill_color   [ rgba['#0000'] ]
                            cv.stroke_color [ rgba['#6cb6ffaa'] ]
                            cv.stroke_width [ 1.0 ]
                            cv.rounded_rect [ mx, y + 2.0, mw + 2.0, lh - 4.0, 3.0, 3.0, 3.0, 3.0 ]
                            cv.paint        [ ]
                        base = mpos + tn
            cv.stroke_width[ 0.0 ]

        # results: the hovered match row shows the close icon in the gutter (left),
        # centered over the suppressed line number. clicking the gutter removes the
        # row (see on_press). drawn on top, after the content paint.
        if [ showing && hits && editor.hover_gutter && editor.hover_line >= 0 && !editor.row_header[ editor.hover_line ] ]
            hy : f32 [ y0 + f32[ editor.hover_line ] * lh - editor.scroll.y ]
            if [ hy + lh >= bounds.y && hy <= bounds.y + bounds.h ]
                if [ !editor.close_icon ]
                    editor.close_icon = SVGModel [ path 'images/close.svg' ]
                isz : f32 [ round[ lh * 0.5 ] ]
                iox : f32 [ round[ bounds.x + (gut_w - isz) * 0.5 ] ]
                ioy : f32 [ round[ hy + (lh - isz) * 0.5 ] ]
                cv.draw_svg[ editor.close_icon, iox, ioy, isz, isz ]
                cv.paint[ ]

        # crop stays set to the editor bounds: the selection rects, their
        # text, and the cursor below all clip to it. cleared at draw end.
        # guard against a stale cursor/anchor past the end (e.g. after removing all
        # results) so the caret + selection loops never index out of bounds.
        if [ editor.sel_line >= editor.line_count[] ] editor.sel_line = -1
        if [ editor.sel_line >= 0 && editor.anchor_line >= editor.line_count[] ]
            editor.anchor_line = editor.line_count[] - 1
        if [ editor.sel_line >= 0 ]
            cv.save[ ]
            cv.stroke_width[ 0.0 ]
            al          : i32 [ editor.anchor_line ]
            ac          : i32 [ editor.anchor_col ]
            sl          : i32 [ editor.sel_line ]
            sc          : i32 [ editor.sel_col ]
            before      : bool [ al < sl || (al == sl && ac <= sc) ]
            start_line  : i32 [ (before) ? al : sl ]
            start_col   : i32 [ (before) ? ac : sc ]
            end_line    : i32 [ (before) ? sl : al ]
            end_col     : i32 [ (before) ? sc : ac ]
            cw          : f32 [ cw_tm.w ]
            has_sel : bool [ start_line != end_line || start_col != end_col ]

            scrolled : bool [ editor.scroll.y != editor.last_scroll_y ]
            editor.last_scroll_y = editor.scroll.y
            # a resize (window or dbg-seam) changes the editor's content width — the
            # selection goal jumps, so snap it (no easing) instead of filtering.
            resized  : bool [ (bounds.w - rin) != editor.last_view_w ]
            editor.last_view_w = bounds.w - rin
            if [ editor.last_sel_line != sl || editor.last_sel_col != ac || editor.last_before != before ]
                editor.last_sel_line = sl
                editor.last_sel_col  = ac
                editor.last_before   = before
                editor.filter_rect = null
                editor.filter_next = false

            # the base selected-line band(s) are painted earlier, in the gutter stage
            # (behind the code) — see the current-line band there. here we only draw the
            # rounded selection highlight in front of the text (masked).
            sel_col_val  : rgba [ (sel_color)  ? sel_color  : rgba['#264f78'] ]

            if [ has_sel ]
                cv.save[ ]
                cv.rounded[ 6.0, 6.0, 6.0, 6.0 ]
                pad : 2
                for [ li: i32 start_line, li <= end_line, li += 1 ]
                    y_row  : f32 [ y0 + f32[li] * lh - editor.scroll.y ]
                    if [ y_row + lh < bounds.y || y_row > bounds.y + bounds.h ] continue
                    is_sl  : bool [ li == start_line ]
                    is_el  : bool [ li == end_line ]
                    lnv    : editor.line_get[ li ]
                    dnv    : editor.display_of[ lnv ]
                    col_x0 : f32 [ (is_sl) ? cv.measure_text[ dnv.mid[ 0, editor.vis_col[ lnv, start_col ] ] ].w : 0.0 ]
                    col_x1 : f32 [ (is_el) ? cv.measure_text[ dnv.mid[ 0, editor.vis_col[ lnv, end_col ] ] ].w : bounds.w - gut_w - rin ]
                    bx     : f32 [ x0 + editor.row_indent[ li ] ]
                    rx     : f32 [ bx + col_x0 ]
                    rw     : f32 [ col_x1 - col_x0 ]

                    rr : rect [ x:rx + pad, y:y_row + pad,
                        w:rw - pad * 2, h:lh - pad * 2 ]
                    if [ editor.last_sel_line == li ]
                        if [ scrolled || resized ]
                            editor.filter_rect = null
                        if [ editor.filter_rect ]
                            # ease the selection rect toward its goal with the
                            # shared frame-rate-aware filter; snap to the goal once
                            # within tolerance so it settles cleanly and stops
                            # requesting frames.
                            gx  : f32 [ rr.x ]
                            gy  : f32 [ rr.y ]
                            gw  : f32 [ rr.w ]
                            gh  : f32 [ rr.h ]
                            amt : f32 [ 0.25 ]
                            rt  : f32 [ editor.ux.frame_factor ]
                            rr.x = filter_n[ editor.filter_rect.x, gx, amt, rt ]
                            rr.y = filter_n[ editor.filter_rect.y, gy, amt, rt ]
                            rr.w = filter_n[ editor.filter_rect.w, gw, amt, rt ]
                            rr.h = filter_n[ editor.filter_rect.h, gh, amt, rt ]
                            tol : f32 [ 0.5 ]
                            if [ abs[ gx - rr.x ] < tol && abs[ gy - rr.y ] < tol && abs[ gw - rr.w ] < tol && abs[ gh - rr.h ] < tol ]
                                rr.x = gx
                                rr.y = gy
                                rr.w = gw
                                rr.h = gh
                            el
                                editor.ux.will_animate = true
                                editor.needs_frame     = true

                        editor.filter_rect = rr
                        editor.filter_next = true

                    cv.fill_color  [ sel_col_val ]
                    cv.stroke_color[ rgba['#fff1'] ]
                    cv.stroke_width[ 0.5 ]
                    cv.rect_to     [ rr.x, rr.y - 0.5, rr.w, rr.h + 1 ]
                    cv.paint       [ ]
                    cv.stroke_width[ 0.0 ]
                cv.restore[ ]

                tx : f32 [ cv.transform_tx[] ]
                ty : f32 [ cv.transform_ty[] ]
                for [ li: i32 start_line, li <= end_line, li += 1 ]
                    y_row  : f32 [ y0 + f32[li] * lh - editor.scroll.y ]
                    if [ y_row + lh < bounds.y || y_row > bounds.y + bounds.h ] continue
                    is_sl  : bool [ li == start_line ]
                    is_el  : bool [ li == end_line ]
                    lnv    : editor.line_get[ li ]
                    dnv    : editor.display_of[ lnv ]
                    col_x0 : f32 [ (is_sl) ? cv.measure_text[ dnv.mid[ 0, editor.vis_col[ lnv, start_col ] ] ].w : 0.0 ]
                    col_x1 : f32 [ (is_el) ? cv.measure_text[ dnv.mid[ 0, editor.vis_col[ lnv, end_col ] ] ].w : bounds.w - gut_w - rin ]
                    bx     : f32 [ x0 + editor.row_indent[ li ] ]
                    rx     : f32 [ bx + col_x0 ]
                    rw     : f32 [ col_x1 - col_x0 ]
                    use_filter : bool [ editor.last_sel_line == li && editor.filter_rect ]
                    crop_x : f32 [ (use_filter) ? editor.filter_rect.x : rx ]
                    crop_w : f32 [ (use_filter) ? editor.filter_rect.w : rw ]
                    # X clips to the (animated) selection/filter rect; Y clips
                    # to the editor bounds so partial rows can't spill on scroll. left is
                    # clamped to the gutter edge so horizontally-scrolled selected text
                    # never draws over the stationary line-number column.
                    sel_lx : f32 [ (crop_x > bounds.x + gut_w) ? crop_x : bounds.x + gut_w ]
                    cv.set_crop[ tx + sel_lx, ty + bounds.y,
                        tx + crop_x + crop_w, ty + bounds.y + bounds.h ]
                    cv.fill_color[ '#fff' ]
                    # match the underlying cached line, which blits at round[y]
                    # (line ~516); drawing this overlay at the un-rounded y_row left the
                    # selected text a sub-pixel off the glyphs beneath it on a fractional
                    # (mid-ease) scroll.y.
                    cv.draw_text[ editor.display_of[ lnv ],
                        rect [ x: bx, y: round[ y_row ], w: bounds.w - gut_w, h: lh ],
                        vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
                cv.paint[ ]
                # back to the code-region crop (gutter edge) for the cursor below
                cv.set_crop[ tx + bounds.x + gut_w, ty + bounds.y,
                    tx + bounds.x + bounds.w, ty + bounds.y + bounds.h ]

            if [ parent.focused ]
                y_sel : f32 [ y0 + f32[editor.sel_line] * lh - editor.scroll.y ]
                if [ y_sel + lh >= bounds.y && y_sel <= bounds.y + bounds.h ]
                    use_fr : bool [ has_sel && editor.filter_rect ]
                    cx : f32
                    cy : f32
                    if [ use_fr ]
                        cx = (before) ? editor.filter_rect.x + editor.filter_rect.w : editor.filter_rect.x
                        cy = editor.filter_rect.y
                    el
                        # caret x = EXACT rendered width of the display prefix (tabs
                        # expanded to spaces). measure_text, not vis_col*cw — the code
                        # font's space is narrower than cw, so the grid drifts ahead by
                        # ~1 space per tab. measuring the real glyphs keeps it tight.
                        clnv : editor.line_get[ editor.sel_line ]
                        # caret x from the DISPLAY of the prefix up to the model col — this
                        # is exactly where the char at sel_col renders (the text is drawn via
                        # display_of). vis_col disagreed with display_of by 1 on tab lines.
                        pre  : editor.display_of[ clnv.mid[ 0, editor.sel_col ] ]
                        cx   = x0 + editor.row_indent[ editor.sel_line ] + cv.measure_text[ pre ].w
                        cy   = y_sel
                    cv.fill_color[ '#fff' ]
                    cv.stroke_width[ 0.0 ]
                    cv.rect_to[ cx, cy + 2.0, 2.0, lh - 4.0 ]
                    cv.paint[]

            cv.restore[ ]

        # release the editor-bounds crop so following elements aren't clipped
        cv.clear_crop[ ]


Control Editor
    public  selected      : bool
    # find/replace bar open: drives the title's CSS :expanded state, which swaps the
    # single title row in place for the one-line findbar (scope | find | replace | all).
    # same height as the normal title, so the code content does NOT shift. lives on the
    # Editor so one state drives title + content.
    public  expanded      : bool
    # find-in-files results display: when show_hits is set the editor renders
    # `hits` (file-title headers + matched code lines) instead of file content.
    # both are fed from app state each frame (the Editor is rebuilt per frame).
    public  show_hits     : bool
    public  hits          : array FindHit
    # true while this pane shows the tab-explorer / navigate list (ed.lines = find_results,
    # set in apply_pane). drives the warm mouse-over row highlight in EditorLayer.
    public  finder_list   : bool
    # browse list density: when set, header rows are a single line tall (one FindHit
    # per entry) instead of the 2-slot double header. injected by orbiter per frame.
    public  single_line   : bool
    # this is the browse/navigate list (not find-in-files): rows get a PIN toggle on
    # hover (vs the find-in-files remove-match close icon).
    public  nav_list      : bool
    # render the index as a thumbnail grid instead of the row list (same hits).
    public  grid_mode     : bool
    # per-file thumbnail textures for the grid view, lazy-loaded + cached by abs path.
    mutable thumb_cache   : map Texture[string]
    # grid layout, computed each draw + read by hit-testing: column count, pinned-cell
    # count, and the y-pixel offset where results begin (after the pins + separator gap).
    mutable g_cols        : i32
    mutable g_pins        : i32
    mutable g_resoff      : f32
    # number of leading rows that are pinned dock entries; a separator line is drawn
    # after them to divide the dock from the browse results.
    public  dock_rows     : i32
    # double-header fonts: the (larger) name line, and the (smaller) dir line. 0 = use
    # the editor's default code font.
    public  header_size   : i32
    public  dir_size      : i32
    # the active search query — used to outline the matched substring per result row
    public  find_query    : string
    public  show_nav      : bool
    public  editor_mode   : string
    public  src           : path
    # injected each frame by orbiter (the Editor is rebuilt per frame): this pane's own
    # navigation history (back/forward), and its pane index (pane0..3, stamped on each stop).
    mutable nav           : Navigate
    mutable pane_index    : i32 [ 0 ]
    # non-text presentation view (image/audio/…) for the current src, else null (code).
    mutable rview         : ResourceView
    # the file's scroll position, stashed when the pane enters finder/browse mode so it
    # can be restored when the finder closes (the browse list reuses scroll.y).
    mutable saved_scroll  : f32
    # ext → ResourceView subclass Au_t. built ONCE (scan of direct subclasses), shared
    # across panes; file-open is then a map lookup, not a re-scan of every class.
    intern static view_registry : map Au_t[string]
    mutable lines         : list string
    mutable file_cache    : map FileBuf[string]
    # close icon for the per-row 'remove this match' button (lazy-loaded in draw)
    mutable close_icon    : SVGModel
    # pin icon for the browse list's pin/unpin toggle (lazy-loaded in draw)
    mutable pin_icon      : SVGModel
    # browse-list row icons (lazy-loaded): a folder glyph for directory links, a file
    # glyph for file rows.
    mutable folder_icon   : SVGModel
    mutable file_icon     : SVGModel
    # tracks show_hits across frames so entering results can clear the selection
    mutable was_showing   : bool
    # true while the mouse is over the gutter column — the close icon only shows
    # (and the line number only hides) when actually hovering that left area.
    mutable hover_gutter  : bool
    # true while dragging the scrollbar thumb
    mutable scroll_dragging : bool
    # TEST: sel_col overrides the base element's sel_col default. With the e_init
    # fix (af-bits reset to only the programmer-passed args after init), this
    # override should NOT cause apply_args to reconcile/zero the caret column.
    mutable sel_line      : i32 [ -1 ]
    mutable sel_col       : i32 [ 0 ]
    # soft-tab width: spaces emitted per Tab (aligned to the next multiple). matches the
    # 4-space indent these .ag files use (and silver's tab = 4 indent units).
    mutable tab_w         : i32 [ 4 ]
    # map mtime this editor last loaded syntax from; fmt_poll applies the map to any editor
    # whose value is behind, so a pane created AFTER the map loaded still gets highlighted.
    mutable fmt_mtime     : i64 [ 0 ]
    # smooth scroll: the wheel event only collects raw delta into pending_wheel; each render
    # frame folds it into scroll_target (with speed) and eases scroll.y toward the target, so
    # motion is paced by the frame rate and the per-event delta is never transformed.
    mutable scroll_target : f32 [ 0.0 ]
    mutable pending_wheel : f32 [ 0.0 ]
    # DIAG: line RASTERIZATION counters (cache misses only) — per-frame + cumulative.
    mutable text_lines_frame : i32 [ 0 ]
    mutable text_lines_total : i64 [ 0 ]
    # rasterized-text cache (content-addressed, quantized canvases, recycled). holds both
    # per-line slots and band-tile slots — the two text paths are mutually exclusive, so
    # they share one pool (see band_rows / code_band).
    mutable code_lines    : array EdLineCache
    mutable cl_frame      : i32 [ 0 ]
    mutable cl_cw         : f32 [ 0.0 ]
    mutable cl_lh         : f32 [ 0.0 ]
    # unlimited undo/redo, delta-based. `hist` aliases the current file's cur_buf.hist
    # (linked list of EditAction delta groups, shared by reference like lines↔buf.lines);
    # hist_i is the cursor = number of applied groups, mirrored into cur_buf by touch_hist.
    # edit_kind (0=type 1=lineop 2=delete; -1=none) + edit_cl/edit_cc (caret after the last
    # edit, for jump detection) drive coalescing; all transient (reset on file switch).
    mutable cur_buf       : FileBuf
    mutable hist          : list EditAction
    mutable hist_i        : i32 [ 0 ]
    # the currently-open delta group (ops append here; null = none open) and the caret
    # captured before that group's first op (its undo target).
    mutable cur_group     : EditAction
    mutable pend_sl0      : i32 [ 0 ]
    mutable pend_sc0      : i32 [ 0 ]
    mutable edit_kind     : i32 [ -1 ]
    mutable edit_cl       : i32 [ -1 ]
    mutable edit_cc       : i32 [ -1 ]
    # the line the debugger is currently halted on (-1 = none). orbiter sets this
    # from on_break; it draws a small white ">" arrow in the gutter of that line to
    # mark the active execution point. cleared when the session continues/exits.
    mutable stop_line     : i32 [ -1 ]
    # the exact column lldb reported for the stop (separate from sel_col) — drawn as
    # a marker on the stop line. -1 = none.
    mutable stop_col      : i32 [ -1 ]
    # debug edit-lock: while a debug session is live (debug_running, injected by
    # orbiter) the editor is read-only so the keyboard stays free for debugger
    # commands. a double-click on the body, or the title's 'active' button, sets
    # edit_armed to drop back into editing. double-click is the basic ev.mouse.double_click event.
    public  debug_running : bool
    # the live debug session for this editor's target (injected by orbiter); in the
    # active (non-edit) state the keyboard drives it: c continue, s step over,
    # i step into, o step out.
    public  debugger      : dbg
    # the stopped frame's variables (injected by orbiter while paused). drawn as
    # inline ghost annotations on each variable's decl line: `# name = value`.
    public  debug_vars    : array
    # ghost-annotation tree expansion: the flattened row list (base lines + each open
    # object's expanded subtree, depth-first) becomes the line model while active.
    # rebuilt at draw top each frame from debug_vars + each variable's `expanded` flag.
    mutable flat_rows     : array VRow
    mutable flat_active   : bool
    # mouse-over annotation line (for the green hover glow), in VISUAL/flat row coords.
    mutable hover_ann     : i32 [ -1 ]
    mutable edit_armed    : bool
    mutable lh_cache      : f32 [ 0.0 ]
    mutable cw_cache      : f32 [ 0.0 ]
    mutable anchor_line   : i32 [ 0 ]
    mutable dragging      : bool
    mutable cursor_idx    : i32 [ -1 ]
    mutable last_sel_line : -1
    mutable last_sel_col  : -1
    mutable last_before   : false
    mutable filter_rect   : rect
    mutable filter_next   : false
    mutable last_scroll_y : f32
    # last content width (bounds.w - rin); a change = resize → snap the selection rect
    mutable last_view_w   : f32
    # gutter: line under the mouse (hover highlight) and measured gutter width.
    # breakpoints are app-global, keyed by "source:line" -> condition string,
    # injected by orbiter (a shared map reference) — a present key colors the
    # whole line rather than drawing a dot.
    mutable hover_line    : i32 [ -1 ]
    mutable gutter_w      : f32 [ 0.0 ]
    public  breakpoints   : map string[string]
    # code font size (px), injected by orbiter; gutter labels render smaller.
    public  code_font_size : i32
    # the stack-split seam width (units), injected by orbiter each frame. not read
    # in draw (din is measured from the live 'dbg' element bounds) — it's here so a
    # seam drag changes this prop, marks the editor dirty, and the code re-clips LIVE
    # as you drag instead of only snapping on release.
    # per-editor toggle for the dbg sub-column (Fields/Callstack). unique to this
    # editor (its container) and persists across frames — the title menu icon flips
    # it, so each tab shows/hides its own panel.
    mutable dbg_open      : bool
    # band height in rows for the band-tile text path. 0 (unset) → default 8 (band on);
    # 1 → per-line path; >=2 → that height. band slots share the `code_lines` pool (the
    # two modes are mutually exclusive). no field default — an i32 default here would trip
    # the aether fbits codegen bug for fields past bit 64.
    public  band_rows     : i32
    # 'Replace' toggle open: drives the title's :replacing CSS state (un-hides the replace
    # input + 'All'). declared LAST with no default — a default here would trip the aether
    # fbits codegen bug for fields past the word boundary (same reason as band_rows).
    public  replacing     : bool

    # whole-line wash color: conditional (non-empty condition) vs plain.
    func bp_color [ cond: string ] -> rgba
        if [ cond && cond.count > 0 ] return rgba['#3b82f638']   # conditional
        return rgba['#e5394538']                                 # plain

    # the debug_vars index of the variable whose `name:` decl is on BASE line bli (a
    # word-boundary name immediately followed by ':'), else -1. scans the raw `lines`
    # (not line_get) so it's safe to call while rebuilding the flat model.
    func base_var_at [ bli: i32 ] -> i32
        if [ !debug_vars || bli < 0 || bli >= lines.count ] return -1
        # a decl on a line strictly AFTER the stop hasn't been reached — never live.
        if [ stop_line >= 0 && bli > stop_line ] return -1
        line : string lines.value_by_index[ bli ]
        if [ !line || line.count == 0 ] return -1
        for [ k: i32 0, k < debug_vars.count, k += 1 ]
            v : variable debug_vars[k]
            if [ !v || !v.name || v.name.count == 0 ] continue
            nm  : string v.name
            pos : i32 [ line.index_of[ nm ] ]
            if [ pos < 0 ] continue
            if [ pos > 0 ]
                pc : i32 [ line[ pos - 1 ] ]
                if [ (pc >= 97 && pc <= 122) || (pc >= 65 && pc <= 90) || (pc >= 48 && pc <= 57) || pc == 95 ] continue
            j : i32 [ pos + nm.count ]
            while [ j < line.count && (line[j] == 32 || line[j] == 9) ]
                j += 1
            if [ j < line.count && line[j] == 58 ]
                # only annotate variables the debugger has actually reached. lldb lists
                # every local regardless of the PC, so a not-yet-run decl shows as
                # "# i = ". on the stop line itself the row can't decide it (a loop var
                # is declared and incremented on the same for-line), so compare columns:
                # the decl is live only once the PC's column is past it.
                if [ stop_line >= 0 && bli == stop_line && stop_col >= 0 && stop_col <= pos ] return -1
                return k
        return -1

    # collapsed summary for a var: an object shows its first 2 fields, a scalar `= value`.
    func var_summary [ v: variable ] -> string
        if [ !v ] return ''
        nm : string v.name
        if [ v.children && v.children.count > 0 ]
            sum : string [ '' ]
            n   : i32 [ (v.children.count < 2) ? v.children.count : 2 ]
            for [ ci: i32 0, ci < n, ci += 1 ]
                c    : variable v.children[ci]
                part : '{c.name}: {c.value}'
                sum = (ci > 0) ? sum + ', ' + part : part
            if [ v.children.count > 2 ] sum = sum + ', ...'
            return nm + ' = (' + sum + ')'
        return '{nm} = {v.value}'

    # has fields → expandable.
    func var_expandable [ v: variable ] -> bool
        return v && v.children && v.children.count > 0

    # depth-first append of v's expanded subtree into flat_rows at the given indent.
    func splice_var [ v: variable, depth: i32 ]
        if [ !v || !v.expanded || !v.children ] return
        for [ ci: i32 0, ci < v.children.count, ci += 1 ]
            c : variable v.children[ci]
            flat_rows.push[ VRow [ src: -1, var: c, depth: depth ] ]
            splice_var[ c, depth + 1 ]

    # rebuild the flattened row list: every base code line, with each object var's
    # expanded subtree spliced in right after its decl line. flat_active when anything
    # was spliced (so the normal path is untouched when nothing is expanded).
    func rebuild_flat []
        flat_rows = array VRow []
        flat_active = false
        if [ !debug_vars ] return
        base : i32 [ lines.count ]
        for [ bli: i32 0, bli < base, bli += 1 ]
            flat_rows.push[ VRow [ src: bli ] ]
            k : i32 [ base_var_at[ bli ] ]
            if [ k >= 0 ]
                splice_var[ debug_vars[ k ], 1 ]
        flat_active = flat_rows.count > base

    # flat-row accessors (identity when no tree is open).
    func row_src [ vr: i32 ] -> i32
        if [ !flat_active || !flat_rows || vr < 0 || vr >= flat_rows.count ] return vr
        r : VRow flat_rows[ vr ]
        return r.src

    func row_var [ vr: i32 ] -> variable
        if [ !flat_active || !flat_rows || vr < 0 || vr >= flat_rows.count ] return null
        r : VRow flat_rows[ vr ]
        return r.var

    func row_depth [ vr: i32 ] -> i32
        if [ !flat_active || !flat_rows || vr < 0 || vr >= flat_rows.count ] return 0
        r : VRow flat_rows[ vr ]
        return r.depth

    # leading x-offset (px past x0) for a row's text/selection: virtual debug field
    # rows step in by their tree depth; base code rows sit flush at x0. single source
    # for the content draw AND the selection-rect/selected-text passes (so a selected
    # virtual row keeps its indent instead of snapping back to x0).
    func row_indent [ vr: i32 ] -> f32
        if [ row_var[ vr ] ] return 12.0 + f32[ row_depth[ vr ] ] * 16.0
        return 0.0

    # inverse of row_src: the visual flat row for base source line bli (identity when
    # no tree is open). passes negatives (e.g. an unset stop line) straight through.
    func vis_row [ bli: i32 ] -> i32
        if [ bli < 0 ] return bli
        if [ !flat_active || !flat_rows ] return bli
        for [ vr: i32 0, vr < flat_rows.count, vr += 1 ]
            r : VRow flat_rows[ vr ]
            if [ r.src == bli ] return vr
        return bli

    # row count of the active buffer: results (hits), the open debug tree, or lines.
    func line_count [] -> i32
        if [ show_hits && hits ] return hits.count
        if [ flat_active && flat_rows ] return flat_rows.count
        return lines.count

    # is row i a non-editable file-title slot (results mode only)?
    func row_header [ i: i32 ] -> bool
        if [ show_hits && hits && i >= 0 && i < hits.count ] return hits[i].is_header
        return false

    # is row i the SECOND (continuation) slot of a 2-slot file title? a title's first
    # slot carries the filename; its continuation slot is an empty-text header. detect
    # it explicitly — the old "previous row is a header" test fails for an all-titles
    # list (the navigate/tab list), where every slot but the first looks like one.
    func row_cont [ i: i32 ] -> bool
        if [ show_hits && hits && i >= 0 && i < hits.count ]
            return hits[i].is_header && hits[i].text.count == 0 && !hits[i].is_spacer
        return false

    func row_spacer [ i: i32 ] -> bool
        if [ show_hits && hits && i >= 0 && i < hits.count ] return hits[i].is_spacer
        return false

    # is `c` an identifier character (a-z A-Z 0-9 _) — used to find the token under
    # the cursor and to keep occurrence matches whole-word.
    func word_char [ c: i32 ] -> bool
        return (c >= 48 && c <= 57) || (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95

    # the identifier under (or just left of) the cursor, '' if none. drives the
    # highlight-all-occurrences pass.
    func cursor_token [] -> string
        if [ sel_line < 0 || sel_line >= line_count[] ] return ''
        if [ row_header[ sel_line ] ] return ''
        ln : line_get[ sel_line ]
        n  : i32 [ ln.count ]
        if [ n == 0 ] return ''
        s  : i32 [ clamp[ sel_col, 0, n ] ]
        # cursor at end of line / on a non-word char → try the char to its left
        if [ s >= n || !word_char[ i32[ ln[s] ] ] ] s = s - 1
        if [ s < 0 || !word_char[ i32[ ln[s] ] ] ] return ''
        a : i32 [ s ]
        while [ a > 0 && word_char[ i32[ ln[a - 1] ] ] ] a -= 1
        b : i32 [ s ]
        while [ b < n - 1 && word_char[ i32[ ln[b + 1] ] ] ] b += 1
        return ln.mid[ a, b - a + 1 ]

    # double-click: extend the selection to span the whole word under the caret.
    func select_word []
        if [ sel_line < 0 || sel_line >= line_count[] ] return
        if [ row_header[ sel_line ] ] return
        ln : line_get[ sel_line ]
        n  : i32 [ ln.count ]
        if [ n == 0 ] return
        s  : i32 [ clamp[ sel_col, 0, n ] ]
        if [ s >= n || !word_char[ i32[ ln[s] ] ] ] s = s - 1
        if [ s < 0 || !word_char[ i32[ ln[s] ] ] ] return
        a : i32 [ s ]
        while [ a > 0 && word_char[ i32[ ln[a - 1] ] ] ] a -= 1
        b : i32 [ s ]
        while [ b < n - 1 && word_char[ i32[ ln[b + 1] ] ] ] b += 1
        anchor_line = sel_line
        anchor_col  = a
        sel_col     = b + 1

    # nearest editable (non-title) row at/after ln, else before it. the cursor
    # never rests on a file-title slot.
    func snap_row [ ln: i32 ] -> i32
        n : i32 [ line_count[] ]
        if [ n <= 0 ] return 0
        r : i32 [ clamp[ ln, 0, n - 1 ] ]
        if [ !row_header[ r ] ] return r
        for [ i: i32 r, i < n, i += 1 ]
            if [ !row_header[ i ] ] return i
        for [ i: i32 r, i >= 0, i -= 1 ]
            if [ !row_header[ i ] ] return i
        return r

    # walk up / down past title slots for arrow navigation. prev_editable may
    # return -1 (nothing above); next_editable may return line_count (nothing below).
    func prev_editable [ ln: i32 ] -> i32
        r : i32 [ ln ]
        while [ r >= 0 && row_header[ r ] ] r -= 1
        return r

    func next_editable [ ln: i32 ] -> i32
        r : i32 [ ln ]
        n : i32 [ line_count[] ]
        while [ r < n && row_header[ r ] ] r += 1
        return r

    # bounds of the contiguous match-row block (one file's group) containing ln.
    # used to keep a results selection from dragging across a file header.
    func group_start [ ln: i32 ] -> i32
        r : i32 [ ln ]
        while [ r > 0 && !row_header[ r - 1 ] ] r -= 1
        return r

    func group_end [ ln: i32 ] -> i32
        r : i32 [ ln ]
        n : i32 [ line_count[] ]
        while [ r < n - 1 && !row_header[ r + 1 ] ] r += 1
        return r

    # drop a match row from the results (the `hits` array is the same object as
    # orbiter's find_hits, so the removal sticks). if it was the file's ONLY match,
    # also drop the 2 header slots so an empty file title doesn't linger.
    func remove_hit [ idx: i32 ]
        if [ !hits || idx < 0 || idx >= hits.count ] return
        if [ row_header[ idx ] ] return
        gs   : i32  [ group_start[ idx ] ]
        only : bool [ gs == group_end[ idx ] ]
        hits.remove[ idx ]
        # header = the 2 slots immediately before the group's first match row
        if [ only && gs >= 2 ]
            hits.remove[ gs - 1 ]
            hits.remove[ gs - 2 ]

    # remove an entire file group — its 2 header slots and all its match rows.
    # idx is any of the group's header slots (the close icon lives on the header).
    func remove_group [ idx: i32 ]
        if [ !hits || idx < 0 || idx >= hits.count || !row_header[ idx ] ] return
        hs : i32 [ idx ]
        while [ hs > 0 && row_header[ hs - 1 ] ] hs -= 1   # first header slot
        n  : i32 [ line_count[] ]
        he : i32 [ hs ]
        while [ he < n && row_header[ he ] ] he += 1       # past the header slots
        while [ he < n && !row_header[ he ] ] he += 1      # past the match rows
        # remove back-to-front so lower indices don't shift under us
        for [ i: i32 he - 1, i >= hs, i -= 1 ]
            hits.remove[ i ]

    # ---- tab rendering: tabs are stored verbatim in the model but DISPLAYED as spaces
    # to the next tab_w stop (the canvas font has no tab glyph → would draw a box). all
    # caret/selection/click math runs in VISUAL columns via these so it lines up. ----

    # visual column of model index c within s (each tab jumps to the next tab_w stop).
    func vis_col [ s: string, c: i32 ] -> i32
        v : i32 [ 0 ]
        for [ i: i32 0, i < c && i < s.count, i += 1 ]
            if [ s[i] == 9 ] v = (v / tab_w + 1) * tab_w
            el               v += 1
        return v

    # inverse of vis_col: the model index nearest visual column vx (for click → caret).
    func model_col [ s: string, vx: i32 ] -> i32
        v : i32 [ 0 ]
        for [ i: i32 0, i < s.count, i += 1 ]
            adv : i32 [ (s[i] == 9) ? ((v / tab_w + 1) * tab_w - v) : 1 ]
            if [ vx < v + (adv + 1) / 2 ] return i
            v += adv
        return s.count

    # s with tabs expanded to spaces (display only — the model keeps the real tabs).
    func display_of [ s: string ] -> string
        ht : bool [ false ]
        for [ i: i32 0, i < s.count, i += 1 ]
            if [ s[i] == 9 ]
                ht = true
                break
        if [ !ht ] return s
        out : string [ '' ]
        v   : i32 [ 0 ]
        for [ i: i32 0, i < s.count, i += 1 ]
            if [ s[i] == 9 ]
                sp : i32 [ (v / tab_w + 1) * tab_w - v ]
                for [ k: i32 0, k < sp, k += 1 ]
                    out = out + ' '
                v += sp
            el
                out = out + s.mid[ i, 1 ]
                v += 1
        return out

    # ---- syntax coloring: silver --format → theme → per-line color regions ----

    # map a Syntax enum kind (the values stamped on tokens in Au's `Syntax`) to a color.
    # this IS the theme — the one place coloring is decided; reformat[] bakes the result
    # into each ColorRegion so re-theming is a matter of re-running this map.
    func fmt_theme [ kind: i32 ] -> rgba
        switch [ kind ]
            case 1                          # keyword
                return rgba['#569cd6']
            case 2, 14                      # type, namespace
                return rgba['#4ec9b0']
            case 4                          # function
                return rgba['#dcdcaa']
            case 5, 6                       # param, property
                return rgba['#9cdcfe']
            case 7                          # number
                return rgba['#b5cea8']
            case 8, 9                       # string, character
                return rgba['#ce9178']
            case 10                         # boolean
                return rgba['#569cd6']
            case 11                         # comment
                return rgba['#6a9955']
            case 13                         # punctuation
                return rgba['#808080']
            case 15                         # constant
                return rgba['#4fc1ff']
            case 16                         # usertoken
                return rgba['#c586c0']
            case 17                         # parent class (Parent Child) — yellow
                return rgba['#d7ba7d']
            case 18                         # class name being defined — bright gold-green
                return rgba['#dcdc8a']
            case 19                         # meta / generic type arg — orange-tan
                return rgba['#d1a36a']
            default                         # none / ident / op
                return rgba['#d4d4d4']

    # read a little-endian u32 from the subprocess pipe (silver writes native LE).
    func fmt_u32 [ fp: handle ] -> u32
        b : local u8 [4]
        n : fread[ ref b[0], 1, 4, fp ]
        if [ n < 4 ] return 0
        return u32[ b[0] ] | (u32[ b[1] ] << 8) | (u32[ b[2] ] << 16) | (u32[ b[3] ] << 24)

    # how many color regions the active buffer has on model line `ml` (0 if none / no map).
    # both arrays are typed members, so their subscripts resolve correctly (a local would not).
    func line_reg_count [ ml: i32 ] -> i32
        if [ !cur_buf || !cur_buf.reg_off ] return 0
        if [ ml < 0 || ml + 1 >= cur_buf.reg_off.count ] return 0
        return cur_buf.reg_off[ ml + 1 ] - cur_buf.reg_off[ ml ]

    # the k-th color region on model line `ml` (caller bounds k via line_reg_count).
    func line_reg [ ml: i32, k: i32 ] -> ColorRegion
        return cur_buf.regions[ cur_buf.reg_off[ ml ] + k ]

    # structural edits shift line indices, so the cached regions no longer line up — drop
    # them; the next map reload rebuilds. (same-line typing keeps them: only mildly stale.)
    func fmt_invalidate []
        if [ cur_buf ]
            cur_buf.regions = null
            cur_buf.reg_off = null

    # rebuild the per-line offset index from the (line-sorted) regions. reg_off[L] = first
    # region index whose line >= L; a line's spans are [reg_off[L], reg_off[L+1]).
    func rebuild_reg_off [ buf: FileBuf ]
        if [ !buf || !buf.regions ] return
        mx : i32 [ 0 ]
        for [ ri: i32 0, ri < buf.regions.count, ri += 1 ]
            cr : ColorRegion buf.regions[ ri ]
            if [ cr.line + 1 > mx ] mx = cr.line + 1
        ro : array i32 []
        ci : i32 [ 0 ]
        for [ L: i32 0, L <= mx, L += 1 ]
            while [ ci < buf.regions.count ]
                cr : ColorRegion buf.regions[ ci ]
                if [ cr.line >= L ] break
                ci += 1
            ro.push[ ci ]
        buf.reg_off = ro

    # keep existing syntax regions aligned with a line insert/delete BEFORE the async
    # re-tokenize lands: delta +1 (insert at `at`) pushes regions at/below `at` down; delta
    # -1 (remove `at`) drops that line's regions and pulls the rest up. regions stay sorted.
    func shift_regions [ at: i32, delta: i32 ]
        if [ !cur_buf || !cur_buf.regions ] return
        if [ delta > 0 ]
            for [ ri: i32 0, ri < cur_buf.regions.count, ri += 1 ]
                cr : ColorRegion cur_buf.regions[ ri ]
                if [ cr.line >= at ] cr.line = cr.line + delta
            rebuild_reg_off[ cur_buf ]
        el [ delta < 0 ]
            kept : array ColorRegion []
            for [ ri: i32 0, ri < cur_buf.regions.count, ri += 1 ]
                cr : ColorRegion cur_buf.regions[ ri ]
                if [ cr.line == at ] continue
                if [ cr.line > at ] cr.line = cr.line + delta
                kept.push[ cr ]
            cur_buf.regions = kept
            rebuild_reg_off[ cur_buf ]

    # read the binary syntax map file silver wrote during its build (--format <mapfile>),
    # distributing per-line ColorRegion arrays into each file's buffer (keyed by the
    # canonical path silver emits). the map is a byproduct of the normal build/watch
    # pipeline — never its own pass — so this just reads the latest file the watcher produced.
    public func load_format [ mapfile: string ]
        # the .f is parsed by Au's single shared loader (path.read_format) — same code
        # silver uses. it returns an array of fmt_file (source path, mtime, Syntax tokens);
        # we just turn each file's tokens into this editor's ColorRegion list.
        mp    : path  '{mapfile}'
        files : array [ mp.read_format[] ]
        if [ !files ] return
        # debug trace silenced: in console render mode stdout IS the frame buffer, so
        # any stray puts scrolls the terminal and corrupts/eats the drawn UI.
        #puts 'format: ===== load_format {mapfile}: {files.count} file(s) ====='
        for [ fi: i32 0, fi < files.count, fi += 1 ]
            ff  : fmt_file files[fi]
            if [ !ff || !ff.source ] continue
            key : string '{ff.source}'
            ntk : i32 [ (ff.tokens) ? ff.tokens.count : 0 ]
            #puts 'format:   [{fi}] {key} -> {ntk} tokens'
            buf : FileBuf file_cache[ key ]
            if [ !buf ]
                buf = FileBuf []
                file_cache[ key ] = buf
            buf.regions = array ColorRegion []
            mx : i32 [ 0 ]
            nt : i32 [ (ff.tokens) ? ff.tokens.count : 0 ]
            for [ ti: i32 0, ti < nt, ti += 1 ]
                tk : fmt_token ff.tokens[ti]
                # silver token lines are 1-based; editor model lines are 0-based → shift down
                # by one so each line's tokens land on the line they came from.
                tl : i32 [ (i32 tk.line) - 1 ]
                if [ tl < 0 ] tl = 0
                buf.regions.push[ ColorRegion [ line: tl, col: i32 tk.column, len: i32 tk.length, color: fmt_theme[ i32 tk.syntax ] ] ]
                if [ tl + 1 > mx ] mx = tl + 1
            # tokens arrive in source order (line-sorted): reg_off[L] = first region index
            # whose line >= L, so each line's spans are the slice [reg_off[L], reg_off[L+1]).
            buf.reg_off = array i32 []
            ci : i32 [ 0 ]
            for [ L: i32 0, L <= mx, L += 1 ]
                while [ ci < buf.regions.count ]
                    cr : ColorRegion buf.regions[ ci ]
                    if [ cr.line >= L ] break
                    ci += 1
                buf.reg_off.push[ ci ]
        mine : i32 [ (cur_buf && cur_buf.regions) ? cur_buf.regions.count : 0 ]
        cp   : string [ (src) ? '{src.absolute[]}' : '(none)' ]
        #puts 'format: current file = {cp}'
        #puts 'format: cur_buf has {mine} colored token(s)'
        # dump the first regions of the visible buffer so the data is verifiable on stdout
        #if [ cur_buf && cur_buf.regions ]
        #    lim : i32 [ (mine < 12) ? mine : 12 ]
        #    for [ ri: i32 0, ri < lim, ri += 1 ]
        #        cr : ColorRegion cur_buf.regions[ ri ]
        #        puts 'format:     region {ri}: line {cr.line} col {cr.col} len {cr.len}'

    func line_get [ vr: i32 ] -> string
        if [ show_hits && hits ]
            if [ vr >= 0 && vr < hits.count ] return hits[vr].text
            return ''
        if [ flat_active && flat_rows && vr >= 0 && vr < flat_rows.count ]
            r : VRow flat_rows[ vr ]
            if [ r.src >= 0 ]
                fs : string lines.value_by_index[ r.src ]
                return (fs) ? fs : ''
            # virtual field row: indent is applied at draw via row_depth.
            return '# {r.var.name} = {r.var.value}'
        if [ vr >= 0 && vr < lines.count ]
            # null-safe: a null entry (e.g. a list desync after an insert) must not propagate
            # into save's string build — that put a null into path_save and SIGSEGV'd on Ctrl+S.
            s : string lines.value_by_index[ vr ]
            return (s) ? s : ''
        return ''

    # console render hook: expose the flat row model to the terminal paint path.
    func console_line_count [] -> i32
        return line_count[]

    func console_line [ vr: i32 ] -> string
        return line_get[ vr ]

    func line_set [ i: i32, val: string ]
        # results mode: edits live on the hit row's text in memory; they reach the
        # source file only on save (Ctrl-S writes the file of the selected line).
        if [ show_hits && hits ]
            hits[i].text = val
            return
        lines.remove[ i ]
        lines.insert_after[ val, i - 1 ]

    # ---- undo / redo (unlimited, kind-coalesced, DELTA-based) -----------------------
    # `hist` is the per-file linked list of EditAction groups; hist_i = how many groups
    # are currently applied (the cursor). groups [0,hist_i) are applied, [hist_i,count)
    # are the redo future. each group stores only its line deltas, so memory is O(edits)
    # not O(file). edits mutate `lines` IN PLACE (line_set/insert/remove), so the per-file
    # `cur_buf.lines` alias never breaks — no list-object replacement on undo/redo.

    # raw line ops (no recording) — used by undo/redo replay.
    func raw_set    [ i: i32, val: string ]    line_set[ i, val ]
    func raw_insert [ i: i32, val: string ]
        lines.insert_after[ val, i - 1 ]
        shift_regions[ i, 1 ]
    func raw_remove [ i: i32 ]
        shift_regions[ i, -1 ]
        lines.remove[ i ]

    # append an op to the open group, opening one lazily (capturing the before-caret and
    # discarding the redo tail) on the first op. consecutive replaces of the SAME line
    # collapse into one op so a typing run is a single delta.
    func rec [ op: LineOp ]
        if [ show_hits ] return
        if [ !cur_group ]
            # opening a fresh group invalidates the redo future — drop it.
            while [ hist && hist.count > hist_i ]
                hist.pop[]
            cur_group = EditAction []
            cur_group.ops = array LineOp []
            cur_group.sl0 = pend_sl0
            cur_group.sc0 = pend_sc0
            hist.push[ cur_group ]
            hist_i = hist.count
        n : i32 [ cur_group.ops.count ]
        if [ op.kind == 0 && n > 0 ]
            last2 : LineOp cur_group.ops[ n - 1 ]
            if [ last2.kind == 0 && last2.at == op.at ]
                last2.after = op.after          # collapse same-line replaces
                touch_hist[]
                return
        cur_group.ops.push[ op ]
        touch_hist[]

    # recording mutators — used by the edit handlers (capture the inverse, then mutate).
    func ed_set [ i: i32, val: string ]
        old : line_get[ i ]
        line_set[ i, val ]
        rec[ LineOp [ at: i, kind: 0, before: old, after: val ] ]

    func ed_insert [ i: i32, val: string ]     # val becomes line i (shifts the rest down)
        raw_insert[ i, val ]                    # inserts the line AND shifts regions down
        rec[ LineOp [ at: i, kind: 1, after: val ] ]

    func ed_remove [ i: i32 ]
        old : line_get[ i ]
        raw_remove[ i ]                         # shifts regions up AND removes the line
        rec[ LineOp [ at: i, kind: 2, before: old ] ]

    func apply_undo [ g: EditAction ]
        for [ k: i32 g.ops.count - 1, k >= 0, k -= 1 ]
            op : LineOp g.ops[ k ]
            if [ op.kind == 0 ]
                raw_set[ op.at, op.before ]
            el [ op.kind == 1 ]
                raw_remove[ op.at ]
            el
                raw_insert[ op.at, op.before ]
        sel_line    = g.sl0
        sel_col     = g.sc0
        anchor_line = g.sl0
        anchor_col  = g.sc0

    func apply_redo [ g: EditAction ]
        for [ k: i32 0, k < g.ops.count, k += 1 ]
            op : LineOp g.ops[ k ]
            if [ op.kind == 0 ]
                raw_set[ op.at, op.after ]
            el [ op.kind == 1 ]
                raw_insert[ op.at, op.after ]
            el
                raw_remove[ op.at ]
        sel_line    = g.sl1
        sel_col     = g.sc1
        anchor_line = g.sl1
        anchor_col  = g.sc1

    # point the live history at `buf`'s per-file delta history (created on first use), and
    # restore its cursor. the hist LIST is shared by reference so deltas flow into the
    # per-file store; only hist_i can drift, kept current by touch_hist.
    func swap_history [ buf: FileBuf ]
        if [ cur_buf == buf && buf.hist ] return    # already live → keep the live cursor
        if [ cur_buf && cur_buf != buf ]
            cur_buf.hist_i = hist_i
        if [ !buf.hist ]
            buf.hist   = list EditAction []
            buf.hist_i = 0
        hist      = buf.hist
        hist_i    = buf.hist_i
        cur_group = null
        edit_kind = -1
        edit_cl   = -1
        edit_cc   = -1
        cur_buf   = buf

    # mirror the live cursor into the per-file store so any reload reads it, not a stale
    # value (the hist LIST is already shared by reference; only hist_i drifts).
    func touch_hist []
        if [ cur_buf ] cur_buf.hist_i = hist_i

    # call BEFORE a mutating edit. a kind change or caret jump ends the open group, so the
    # next op starts a new one; same-kind contiguous edits keep appending (coalesce).
    func begin_edit [ kind: i32 ]
        if [ show_hits ] return
        jumped : bool [ sel_line != edit_cl || sel_col != edit_cc ]
        if [ edit_kind != kind || jumped ]
            cur_group = null
            edit_kind = kind
        if [ !cur_group ]
            pend_sl0 = sel_line     # caret before the (upcoming) group's first op
            pend_sc0 = sel_col

    # call AFTER a mutating edit: record the caret for the next jump test, and store it as
    # the open group's after-caret (here, not in rec — rec runs mid-edit, before the
    # handler advances the caret, so capturing there lags the redo caret by one).
    func end_edit []
        edit_cl = sel_line
        edit_cc = sel_col
        if [ cur_group ]
            cur_group.sl1 = sel_line
            cur_group.sc1 = sel_col

    func undo []
        if [ show_hits || !hist ] return
        cur_group = null
        edit_kind = -1
        if [ hist_i <= 0 ] return
        hist_i -= 1
        apply_undo[ hist.value_by_index[ hist_i ] ]
        edit_cl = sel_line
        edit_cc = sel_col
        # bring the caret (and the view) to the spot that was just undone, so the
        # reverted change is visible even if it happened off-screen.
        ensure_caret_visible[]
        touch_hist[]
        pristine = false

    func redo []
        if [ show_hits || !hist ] return
        cur_group = null
        edit_kind = -1
        if [ hist_i >= hist.count ] return
        apply_redo[ hist.value_by_index[ hist_i ] ]
        hist_i += 1
        edit_cl = sel_line
        edit_cc = sel_col
        # bring the caret (and the view) to the spot that was just redone.
        ensure_caret_visible[]
        touch_hist[]
        pristine = false

    # write the file associated with the current row. in results mode that's the
    # source file of the selected match line: re-read it, patch every edited match
    # row that belongs to it, and write it back. in normal mode, write `src`.
    func save_current []
        if [ show_hits && hits ]
            if [ sel_line < 0 || sel_line >= hits.count ] return
            target : path [ hits[sel_line].file ]
            if [ !target ] return
            tkey    : '{target}'
            content : string [ target.load[ typeid[string], null ] ]
            if [ !content ] return
            parts : array string [ content.split["\n"] ]
            for [ i: i32 0, i < hits.count, i += 1 ]
                h : FindHit hits[i]
                if [ h.is_header ]
                    continue
                if [ '{h.file}' != tkey ]
                    continue
                idx : i32 [ h.line - 1 ]
                if [ idx >= 0 && idx < parts.count ] parts[idx] = h.text
            out : string [ '' ]
            for [ i: i32 0, i < parts.count, i += 1 ]
                if [ i > 0 ] out = out + '\n'
                out = out + parts[i]
            # same string-mis-typed-as-path guard as below — rebuild a real path before save.
            tp : path '{target}'
            tp.save[ out, null ]
            return
        if [ !src ] return
        out : string [ '' ]
        for [ i: i32 0, i < lines.count, i += 1 ]
            if [ i > 0 ] out = out + '\n'
            out = out + line_get[ i ]
        # src can be a string mis-typed into the path slot (Au string→path doesn't truly
        # convert, so the object keeps the string vtable and src.save dispatches to a garbage
        # function pointer → SIGSEGV). reconstruct a genuine path from its chars first.
        sp : path '{src}'
        sp.save[ out, null ]

    # the file's lowercase extension including the dot ('.png'), '' if none.
    func file_ext [ p: path ] -> string
        fn  : string p.filename[]
        n   : i32 [ fn.count ]
        dot : i32 [ -1 ]
        for [ i: i32 0, i < n, i += 1 ]
            if [ fn[i] == 46 ] dot = i        # '.'
        if [ dot < 0 ] return ''
        return fn.mid[ dot, n - dot ]

    # build the ext → view-type map ONCE: scan all types for DIRECT subclasses of
    # ResourceView and record each extension each one claims. drop a `ResourceView XView`
    # with an extensions[] into any module and it self-binds — no hardcoded format table.
    func ensure_view_registry []
        if [ view_registry ] return
        view_registry = map Au_t[string] []
        n    : i64 [ 0 ]
        subs : ref Au_t [ Au.subclasses[ typeid[ ResourceView ], ref n ] ]
        for [ i: i64 0, i < n, i += 1 ]
            t : subs[ i ]
            if [ t ]
                probe : ResourceView [ Au.new_object[ t, null, null, false, __FILE__, __LINE__, __SEQUENCE__ ] ]
                if [ probe ]
                    exts : probe.extensions*[]
                    for [ e: string ] in exts
                        view_registry[ e ] = t

    # pick a presentation view for a file format, or null for plain text/code — a map
    # lookup against the once-built registry, then instantiate the bound subclass.
    func resource_view_for [ p: path ] -> ResourceView
        ext : file_ext[ p ]
        if [ ext.count == 0 ] return null
        ensure_view_registry[]
        t : view_registry[ ext ]
        if [ !t ] return null
        return ResourceView [ Au.new_object[ t, null, null, false, __FILE__, __LINE__, __SEQUENCE__ ] ]

    # cached thumbnail texture for the grid (image files only; null otherwise). downscaled
    # so a folder of large pngs doesn't exhaust GPU memory; uses the gamma-correct (UNORM)
    # path like the full image viewer.
    # grid/thumbnail preview for a file. the format's ResourceView owns the actual decode +
    # texture (thumbnail[]); orbiter only resolves the right view by extension and caches.
    func thumb_for [ p: path, cv: Canvas ] -> Texture
        if [ !p ] return null
        if [ !thumb_cache ] thumb_cache = map Texture[string] []
        key : '{p.absolute[]}'
        ex : thumb_cache[ key ]
        if [ ex ] return ex
        rv : ResourceView resource_view_for[ p ]
        if [ !rv ] return null
        rv.src = p
        tex : Texture rv.thumbnail*[ cv ]
        if [ !tex ] return null
        thumb_cache[ key ] = tex
        return tex

    func load_file []
        if [ !src ] return
        # a resource view already loaded for THIS file → keep it. recreating it every
        # reload churns the GPU texture and the drop of the old view crashes; reuse it.
        if [ rview && rview.src ]
            rs : '{rview.src}'
            ss : '{src}'
            if [ rs.compare[ ss ] == 0 ] return
        # non-text formats render through a ResourceView instead of as code lines.
        rv : ResourceView resource_view_for[ src ]
        if [ rv ]
            rview = rv
            rview.src = src
            lines = list string []
            # a resource view (image/…) doesn't scroll like code — reset the scroll
            # position AND content size so it doesn't inherit the previous file's state.
            scroll.x      = 0.0
            scroll.y      = 0.0
            scroll_target = 0.0
            content_h     = 0.0
            saved_scroll  = 0.0
            return
        rview = null
        # key by the canonical (realpath) absolute path — the SAME identity silver stamps on
        # each map section — so the buffer the editor renders is the one load_format fills.
        key   : '{src.absolute[]}'
        mtime : i64    [ src.modified_time[] ]
        buf   : FileBuf file_cache[key]
        if [ buf && buf.mtime == mtime ]
            lines = buf.lines
            swap_history[ buf ]   # restore this file's own undo/redo (or seed it)
            return
        content : string src.load[ typeid[string], null ]
        if [ !content ] return
        parts : content.split["\n"]
        new_lines : list string []
        for [ i: i32 0, i < parts.count, i += 1 ]
            new_lines.push[ parts[i] ]
        if [ !buf ]
            buf = FileBuf []
            file_cache[key] = buf
        buf.lines = new_lines
        buf.mtime = mtime
        lines = new_lines
        # freshly (re)loaded content → start this file's history clean.
        buf.hist = null
        swap_history[ buf ]
    func init [ ]
        file_cache = map FileBuf[string] []
        # breakpoints is the shared map injected by orbiter. the editor element
        # is rebuilt every render (a throwaway per frame), and each one's dealloc
        # drops this ref — so hold it here to balance that drop, otherwise the
        # shared map's refcount drifts down and it's freed while still in use.
        if [ breakpoints ] breakpoints.hold[]
        lines = list string []
        lines.push[ '' ]
        load_file[]
        # no file loaded (scratch buffer, or load failed) → give it a transient FileBuf
        # so it still has its own per-buffer undo/redo.
        if [ !cur_buf ]
            sb : FileBuf []
            sb.lines = lines
            swap_history[ sb ]

    # compute the caret line/col from a click/drag point and set sel_line/sel_col.
    # grid view: the hits index of the cell at content-rel (mx,my), or -1. shared by the
    # click (place_cursor) and hover (on_move) so the highlight tracks the actual cell.
    func grid_hit_index [ mx: f32, my: f32, bw: f32 ] -> i32
        if [ !hits ] return -1
        gcw  : f32 [ 140.0 ]
        gch  : f32 [ 178.0 ]
        cols : i32 [ (g_cols > 0) ? g_cols : 1 ]
        ccol : i32 [ (mx - 4.0) / gcw ]
        if [ my < 0.0 || ccol < 0 || ccol >= cols ] return -1
        # which region: pinned rows, the break gap, or results (offset by g_resoff)?
        pin_rows : i32 [ (g_pins + cols - 1) / cols ]
        pin_end  : f32 [ f32[ pin_rows ] * gch ]
        want_pin : bool [ false ]
        grow     : i32  [ 0 ]
        if [ g_pins > 0 && my < pin_end ]
            want_pin = true
            grow = i32[ my / gch ]
        el [ my >= g_resoff ]
            want_pin = false
            grow = i32[ (my - g_resoff) / gch ]
        el
            return -1
        target : i32 [ grow * cols + ccol ]
        gi : i32 [ 0 ]
        for [ li: i32 0, li < hits.count, li += 1 ]
            h : FindHit hits[ li ]
            if [ !h || !h.is_header || !h.file || h.is_spacer ] continue
            if [ row_cont[ li ] ] continue
            is_pin : bool [ li < dock_rows ]
            if [ is_pin != want_pin ] continue
            if [ gi == target ] return li
            gi += 1
        return -1

    func place_cursor [ ev: Event ] -> none
        ele   : (layers) ? (layers['content'] to EditorLayer) : null
        if [ !ele ] return
        # nothing to place the cursor on (e.g. all results removed)
        if [ line_count[] <= 0 ]
            sel_line = -1
            return
        lh    : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
        cw    : f32 [ (cw_cache > 0.0) ? cw_cache : 8.0 ]
        # find_target already folds scroll.y into mouse.pos.y (trinity.ag), so the row
        # math must NOT re-add it — doing so put clicks off by the scroll amount once
        # scrolled. -gutter_w skips the gutter; mouse.pos.y is content-space already.
        rel_y : f32 [ ev.mouse.pos.y - ele.bounds.y ]
        # negative = the click landed above the first line (in the title band) — not a
        # content click, so don't place the cursor (clicking the title's '-' was
        # selecting line 0).
        if [ rel_y < 0.0 ] return
        # grid view: map the cell under the cursor → sel_line, so the existing
        # open/navigate path fires. (find_target already folded scroll into mouse.pos.y.)
        if [ grid_mode && show_hits && hits ]
            gli : i32 [ grid_hit_index[ ev.mouse.pos.x - ele.bounds.x, rel_y, ele.bounds.w ] ]
            if [ gli >= 0 ]
                sel_line    = gli
                anchor_line = gli
            return
        rel_x : f32 [ ev.mouse.pos.x - ele.bounds.x - gutter_w ]
        # rel_y/lh IS the row index — virtual tree rows are real lines in the flat model.
        raw   : i32 [ clamp [ rel_y / lh, 0, line_count[] - 1 ] ]
        ln    : i32 [ snap_row[ raw ] ]
        # any selection EXTEND (drag, or shift-click) stays inside the anchor's
        # group — you can't reach across a file header into another file's matches.
        # (a plain click sets a fresh anchor and is unconstrained.)
        if [ show_hits && (dragging || ev.key.shift) ]
            ln = clamp[ ln, group_start[ anchor_line ], group_end[ anchor_line ] ]
        # virtual rows render indented by depth, so the click-x is past x0 by that
        # much — subtract it before mapping to a column. map the visual column the click
        # landed on back to a model column (tabs occupy multiple visual columns).
        vx    : f32 [ round[ (rel_x - row_indent[ ln ] + scroll.x) / cw ] ]
        cl    : i32 [ model_col[ line_get[ ln ], i32[ vx ] ] ]
        # a significant click-jump (far from the current caret) is a navigation stop: push
        # the FROM location so Cmd+Left returns here. small/near clicks fall under the
        # threshold and are dropped; drags never record.
        if [ nav && src && !dragging ]
            jd : i32 [ sel_line - ln ]
            if [ jd < 0 ] jd = 0 - jd
            if [ jd >= nav.significance_lines ]
                nav.record[ pane_index, '{src.absolute[]}', sel_line, sel_col, scroll.y ]
        sel_line = ln
        sel_col  = cl

    func on_press [ ev: Event ]
        # debug-control buttons in this editor's dbg slide-out — same actions as the
        # keyboard (c/s/i/o). consume here so the press doesn't fall through to the caret.
        if [ debugger ]
            if [ ev.target.id == 'dbg_continue' ]
                if [ debugger.running ] debugger.pause[]
                el                      debugger.cont[]
                ev.no_default = true
                return
            if [ ev.target.id == 'dbg_step_over' ]
                debugger.step_over[]
                ev.no_default = true
                return
            if [ ev.target.id == 'dbg_step_into' ]
                debugger.step_into[]
                ev.no_default = true
                return
            if [ ev.target.id == 'dbg_step_out' ]
                debugger.step_out[]
                ev.no_default = true
                return
        # only the editor's own content responds to presses. a click that targets a
        # child element (the dbg sub-column, its buttons/panels, the title) belongs to
        # that element / the app — the editor must not steal it for caret/selection.
        # when split, the dbg column is outside the editor's content region.
        if [ ev.target != a ]
            return
        # a double-click (two presses within 350ms) while debug-locked re-arms editing
        # for this pane — the simple "I actually want to edit during a run" gesture.
        # double-click is a basic windowing event (ev.mouse.double_click) — the time + distance
        # gate lives in the event layer, never in a control.
        is_dbl : bool [ ev.mouse.double_click ]
        if [ debug_running && !edit_armed && is_dbl ]
            edit_armed = true
        ele   : (layers) ? (layers['content'] to EditorLayer) : null
        rel_x : f32 [ (ele) ? ev.mouse.pos.x - ele.bounds.x : 0.0 ]
        # the dbg sub-column overlays the editor's right edge while open — a press in
        # that band belongs to the dbg panel (its buttons/panels), never the editor
        # content. bail geometrically (like the pin column) so it works even if
        # find_target mis-routed the press back to the editor (e.g. scroll fold).
        dbg_el : element elements['dbg']
        if [ ele && dbg_el && dbg_el.bounds && rel_x > ele.bounds.w - dbg_el.bounds.w ]
            return
        # click to expand/collapse a node in the inline debug tree: a virtual object
        # field row toggles itself (anywhere); a base line's object annotation toggles
        # when clicked past the code text (the [+]). flipping `expanded` rebuilds the
        # flat model next frame. scalar rows fall through to normal caret/selection.
        if [ debug_vars ]
            lhp : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
            cwp : f32 [ (cw_cache > 0.0) ? cw_cache : 8.0 ]
            # mouse.pos.y is already scroll-folded by find_target — don't re-add scroll.
            ry  : f32 [ ev.mouse.pos.y - ele.bounds.y ]
            if [ ry >= 0.0 ]
                cln : i32      [ clamp[ ry / lhp, 0, line_count[] - 1 ] ]
                rv  : variable row_var[ cln ]
                if [ rv ]
                    if [ var_expandable[ rv ] ]
                        rv.expanded = !rv.expanded
                        pristine = false
                        ux.will_animate = true
                        return
                el
                    bk : i32 [ base_var_at[ row_src[ cln ] ] ]
                    if [ bk >= 0 ]
                        bv : variable debug_vars[ bk ]
                        if [ var_expandable[ bv ] ]
                            axp : f32 [ gutter_w + f32[ line_get[ cln ].count ] * cwp + 24.0 ]
                            if [ rel_x > axp ]
                                bv.expanded = !bv.expanded
                                pristine = false
                                ux.will_animate = true
                                return
        # scrollbar: a press in the rightmost grab zone grabs the thumb and scrolls.
        # checked before the pin column so the bar (the very right edge) wins there.
        sb : ScrollLayer (layers) ? (layers['scrollbar'] to ScrollLayer) : null
        grab : f32 [ (sb && sb.thumb_w > 0.0) ? sb.thumb_w * 2.0 + 8.0 : 16.0 ]
        if [ ele && sb && sb.scroll_max > 0.0 && rel_x > ele.bounds.w - grab ]
            # find_target folds e.scroll.y into mouse.pos.y; the thumb is screen-space
            # so subtract it to get the on-screen (track-relative) click position.
            my : f32 [ ev.mouse.pos.y - ele.bounds.y - scroll.y ]
            sb.grab_at[ my ]
            sy : f32 [ sb.drag_to[ my ] ]
            if [ sy >= 0.0 ]
                scroll.y        = sy
                scroll_target   = sy
                scroll_dragging = true
                sb.active       = true
                pristine        = false
                ux.will_animate = true
            return
        # a click in the pin column (right 144, present while searching) is a pin
        # click handled by the app — don't move the cursor or start a selection.
        if [ ele && elements['pins'] && rel_x > ele.bounds.w - 144.0 ]
            return
        # gutter click: in results it's the per-row remove control (close icon shown
        # on hover); in normal file editing it toggles a breakpoint on the line.
        if [ ele && rel_x < gutter_w ]
            lh    : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
            # mouse.pos.y is already scroll-folded by find_target — don't re-add scroll.
            rel_y : f32 [ ev.mouse.pos.y - ele.bounds.y ]
            # a click above the content origin (the title band) must NOT clamp to row 0 —
            # otherwise clicking the title silently toggles the first pinned dock item.
            if [ rel_y < 0.0 ] return
            vrl   : i32 [ clamp [ rel_y / lh, 0, line_count[] - 1 ] ]
            # browse/navigate list: the gutter pin toggles the file in the dock.
            # find-in-files results: a header's gutter click removes the whole file
            # group; a match row's removes just that line.
            if [ row_header[ vrl ] ]
                if [ nav_list && hits && vrl < hits.count ]
                    h : FindHit hits[ vrl ]
                    if [ h && h.file && !h.is_dir ]
                        orb : cast orbiter [ ux.app_object ]
                        if [ orb ] orb.toggle_dock[ h.file ]
                        pristine = false
                        ev.no_default = true
                    return
                if [ show_hits && hits ]
                    remove_group[ vrl ]
                    pristine = false
                return
            if [ show_hits && hits ]
                remove_hit[ vrl ]
                pristine = false
                return
            # a virtual debug field row has no gutter — no breakpoint toggle on it.
            if [ row_var[ vrl ] ] return
            ln    : i32 [ row_src[ vrl ] ]
            # normal mode: toggle a plain breakpoint on the line. toggle-off REMOVES
            # the key (not set-null) so the map count drops — that's what orbiter's
            # save watcher keys off, and it keeps dead keys out of the saved state.
            key   : '{src}:{ln + 1}'
            cur   : breakpoints[key]
            if [ cur ]
                breakpoints.rm[ key ]
            el
                breakpoints[key] = string[]
            pristine = false
            return
        if [ !ev.key.shift ]
            place_cursor[ ev ]
            anchor_line = sel_line
            anchor_col  = sel_col
            # double-click selects the whole word under the caret
            if [ is_dbl ] select_word[]
        el
            place_cursor[ ev ]
        dragging = true
        pristine = false

    func on_move [ ev: Event ]
        ele : (layers) ? (layers['content'] to EditorLayer) : null
        if [ scroll_dragging && ele ]
            sb : ScrollLayer (layers) ? (layers['scrollbar'] to ScrollLayer) : null
            if [ sb ]
                # subtract scroll.y (folded in by find_target) — thumb is screen-space
                sy : f32 [ sb.drag_to[ ev.mouse.pos.y - ele.bounds.y - scroll.y ] ]
                if [ sy >= 0.0 ] scroll.y = sy
            scroll_target = scroll.y
            pristine = false
            ux.will_animate = true
            return
        if [ dragging ]
            place_cursor[ ev ]
            pristine = false
            return
        # hover line for the gutter highlight (no press); also track whether the
        # mouse is over the gutter column so the close icon only shows there.
        if [ !ele ] return
        lh    : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
        # same coordinate math as place_cursor (find_target folds scroll into mouse.pos.y).
        rel_y : f32 [ ev.mouse.pos.y - ele.bounds.y ]
        rel_x : f32 [ ev.mouse.pos.x - ele.bounds.x ]
        # grid view hovers a cell, not a row — map the cell so the highlight tracks x too.
        hl    : i32  [ 0 ]
        if [ grid_mode && show_hits && hits ]
            hl = grid_hit_index[ rel_x, rel_y, ele.bounds.w ]
        el
            hl = clamp [ rel_y / lh, 0, line_count[] - 1 ]
        hg    : bool [ rel_x >= 0.0 && rel_x < gutter_w ]
        if [ rel_y < 0 ]
            hl  = -1
            hg = false
        # annotation hover (for the warm glow): mouse past the code text on an
        # expandable object's decl (base) line — virtual field rows don't glow.
        ha : i32 [ -1 ]
        if [ hl >= 0 && row_var[ hl ] == null ]
            bkh : i32 [ base_var_at[ row_src[ hl ] ] ]
            if [ bkh >= 0 && var_expandable[ debug_vars[ bkh ] ] ]
                cwh : f32 [ (cw_cache > 0.0) ? cw_cache : 8.0 ]
                axh : f32 [ gutter_w + f32[ line_get[ hl ].count ] * cwh + 24.0 ]
                if [ rel_x > axh ] ha = hl
        if [ ha != hover_ann ]
            hover_ann = ha
            pristine = false
            ux.will_animate = true
        # only repaint on a hover change that ACTUALLY affects what's drawn. hover_line drives
        # the glow/gutter highlight only in list mode (finder/results); otherwise hl_line is
        # the debugger stop line, so a code-line hover changes nothing visible. the header
        # close-icon is the other hover-dependent bit (shown over a header's gutter). outside
        # those, update the value but DON'T force a full text re-render every mouse move.
        if [ hl != hover_line || hg != hover_gutter ]
            in_list : bool [ finder_list || show_hits ]
            oh : bool [ hover_line >= 0 && (row_header[ hover_line ] || (hover_line > 0 && row_header[ hover_line - 1 ])) ]
            nh : bool [ hl >= 0 && (row_header[ hl ] || (hl > 0 && row_header[ hl - 1 ])) ]
            hover_line   = hl
            hover_gutter = hg
            if [ in_list || oh || nh ]
                pristine = false
                ux.will_animate = true

    func on_leave [ ev: Event ]
        if [ hover_line != -1 || hover_gutter || hover_ann != -1 ]
            hover_line   = -1
            hover_gutter = false
            hover_ann    = -1
            pristine = false

    func on_release [ ev: Event ]
        dragging        = false
        scroll_dragging = false
        sb : ScrollLayer (layers) ? (layers['scrollbar'] to ScrollLayer) : null
        if [ sb ]
            sb.active = false
            ux.will_animate = true

    func on_wheel [ ev: Event ]
        lh : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
        # shift + wheel scrolls horizontally (no horizontal scrollbar — the left-edge
        # fade is the only indicator). otherwise vertical.
        if [ ev.key.shift ]
            cw : f32 [ (cw_cache > 0.0) ? cw_cache : 8.0 ]
            scroll.x = scroll.x - ev.mouse.wheel_delta.y * cw * 3.0
            if [ scroll.x < 0.0 ] scroll.x = 0.0
        el
            # the event only COLLECTS the raw wheel delta — no scaling here. the render frame
            # consumes pending_wheel once per frame, applies the speed, and eases. keeping the
            # transform out of the event avoids per-event/lh inconsistencies in how it applies.
            pending_wheel = pending_wheel + ev.mouse.wheel_delta.y
        pristine = false
        ux.will_animate = true

    # scroll so the caret line is inside the viewport — call after any edit/cursor move that
    # can push the caret off-screen (Enter past the bottom, arrows, paste). render re-clamps.
    func ensure_caret_visible []
        if [ sel_line < 0 ] return
        ele : (layers) ? (layers['content'] to EditorLayer) : null
        vh  : f32 [ (ele && ele.bounds) ? ele.bounds.h : 400.0 ]
        lh  : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
        top : f32 [ sel_line ] * lh
        bot : top + lh
        if [ bot > scroll.y + vh ] scroll.y = bot - vh
        if [ top < scroll.y ]      scroll.y = top
        scroll_target = scroll.y
        pristine = false
        ux.will_animate = true

    func on_char [ ev: Event ]
        # debug-locked: swallow text so letters (s/n/c…) stay free for debugger keys
        if [ debug_running && !edit_armed ] return
        # tree open: visual rows ≠ base line indices, so edits would corrupt `lines`.
        # editing resumes once the inline debug tree collapses (debug_vars cleared).
        if [ flat_active ] return
        if [ line_count[] <= 0 ] return
        if [ sel_line < 0 ] sel_line = 0
        if [ sel_col  < 0 ] sel_col  = 0
        ch   : string [ ev.key.text ]
        # ignore control chars (tab/newline/etc.) — they're not insertable text and a
        # literal tab would render as a .notdef box. (>=0 lets UTF-8 lead bytes through,
        # which are negative as signed chars.) Tab is handled as a soft tab in on_key.
        if [ ch.count == 0 || (ch[0] >= 0 && ch[0] < 32) ] return
        # one undo group per typing run (coalesced) — snapshot taken before the run.
        begin_edit[ 0 ]
        # typing replaces an active selection (delete it first, then insert the char)
        delete_selection[]
        row  : i32 [ sel_line ]
        # file-title slots are not editable
        if [ row_header[ row ] ] return
        col  : i32 [ sel_col ]
        line : line_get[ row ]
        ed_set[ row, line.mid[0, col] + ch + line.mid[col, line.count - col] ]
        sel_col += 1
        # collapse the selection to the caret — typing isn't a selection gesture, so the
        # anchor must follow the caret (else each char extends a highlight over the text).
        anchor_line = sel_line
        anchor_col  = sel_col
        end_edit[]
        ensure_caret_visible[]
        pristine = false

    # insert `s` at the caret (replacing any selection). multi-line: '\n' splits into new
    # rows. the clip's first line joins the caret's prefix, the last joins the suffix.
    func insert_text [ s: string ]
        if [ !s || s.count == 0 ] return
        if [ line_count[] <= 0 ] return
        begin_edit[ 0 ]
        delete_selection[]
        if [ sel_line < 0 ] sel_line = 0
        if [ sel_col  < 0 ] sel_col  = 0
        row : i32 [ sel_line ]
        if [ row_header[ row ] ]
            end_edit[]
            return
        col    : i32 [ sel_col ]
        line   : string line_get[ row ]
        prefix : string line.mid[ 0, col ]
        suffix : string line.mid[ col, line.count - col ]
        parts  : array string s.split[ '\n' ]
        if [ parts.count <= 1 ]
            ed_set[ row, prefix + s + suffix ]
            sel_col = col + s.count
        el
            ed_set[ row, prefix + parts[0] ]
            for [ i: i32 1, i < parts.count, i += 1 ]
                val : string [ (i == parts.count - 1) ? (parts[i] + suffix) : parts[i] ]
                ed_insert[ row + i, val ]
            last_line : string parts[ parts.count - 1 ]
            sel_line = row + parts.count - 1
            sel_col  = last_line.count
        anchor_line = sel_line
        anchor_col  = sel_col
        end_edit[]
        ensure_caret_visible[]
        pristine = false

    # the highlighted text (anchor→caret), as one string with '\n' between rows.
    # empty when there's no selection. uses the live line model (file or results list).
    func selected_text [] -> string
        if [ sel_line < 0 ] return ''
        al : i32 [ anchor_line ]
        ac : i32 [ anchor_col ]
        sl : i32 [ sel_line ]
        sc : i32 [ sel_col ]
        before : bool [ al < sl || (al == sl && ac <= sc) ]
        s_line : i32 [ (before) ? al : sl ]
        s_col  : i32 [ (before) ? ac : sc ]
        e_line : i32 [ (before) ? sl : al ]
        e_col  : i32 [ (before) ? sc : ac ]
        out : string ''
        for [ li: i32 s_line, li <= e_line, li += 1 ]
            ln : string line_get[ li ]
            c0 : i32 [ (li == s_line) ? s_col : 0 ]
            c1 : i32 [ (li == e_line) ? e_col : ln.count ]
            if [ c0 < 0 ] c0 = 0
            if [ c1 > ln.count ] c1 = ln.count
            if [ c1 > c0 ] out = out + ln.mid[ c0, c1 - c0 ]
            if [ li < e_line ] out = out + '\n'
        return out

    # is there a non-empty selection (anchor differs from the caret)?
    func has_selection [] -> bool
        return sel_line >= 0 && (anchor_line != sel_line || anchor_col != sel_col)

    # delete the selected span and collapse the caret to its start. returns true when
    # something was removed (so callers can replace it with typed text / a newline, or
    # skip the plain backspace). a no-op in results mode (structural edits disallowed).
    func delete_selection [] -> bool
        if [ !has_selection[] || show_hits ] return false
        before : bool [ anchor_line < sel_line || (anchor_line == sel_line && anchor_col <= sel_col) ]
        s_line : i32 [ (before) ? anchor_line : sel_line ]
        s_col  : i32 [ (before) ? anchor_col  : sel_col ]
        e_line : i32 [ (before) ? sel_line : anchor_line ]
        e_col  : i32 [ (before) ? sel_col  : anchor_col ]
        if [ s_line == e_line ]
            ln : line_get[ s_line ]
            ed_set[ s_line, ln.mid[0, s_col] + ln.mid[e_col, ln.count - e_col] ]
        el
            # merge the start prefix with the end suffix, then drop the interior+end rows
            # bottom-up so indices don't shift under us. compute the merge BEFORE any
            # removal (line_get is a non-holding borrow).
            sline  : line_get[ s_line ]
            eline  : line_get[ e_line ]
            merged : sline.mid[0, s_col] + eline.mid[e_col, eline.count - e_col]
            for [ r: i32 e_line, r > s_line, r -= 1 ]
                ed_remove[ r ]
            ed_set[ s_line, merged ]
        sel_line    = s_line
        sel_col     = s_col
        anchor_line = s_line
        anchor_col  = s_col
        pristine = false
        return true

    # back (dir<0) / forward (dir>0) through THIS pane's nav history. snapshot the live caret
    # into the tip first (so forward returns to where you are), then restore the entry —
    # opening its file in this pane if it differs. no cross-pane routing: same editor side.
    func nav_walk [ dir: i32 ]
        if [ !nav || !src ] return
        nav.save_top[ pane_index, '{src.absolute[]}', sel_line, sel_col, scroll.y ]
        np : NavPoint
        if [ dir < 0 ]
            np = nav.back[]
        el
            np = nav.forward[]
        if [ !np ] return
        same : bool [ '{src.absolute[]}' == np.path ]
        if [ !same ]
            src = path '{np.path}'
            load_file[]
        sel_line      = np.line
        sel_col       = np.col
        anchor_line   = np.line
        anchor_col    = np.col
        scroll.y      = np.scroll_y
        scroll_target = np.scroll_y
        ensure_caret_visible[]
        pristine      = false

    func on_key [ ev: Event ]
        if [ !ev.key.state ] return
        # ignore modifier keys (shift/ctrl/alt/super, GLFW 340-347): they must not touch
        # the selection. a modifier's own keydown reports shift=0, so without this it
        # would fall through to the trailing "!shift collapses selection" and clear it.
        mk : i32 [ i32 ev.key.unicode ]
        if [ mk >= 340 && mk <= 347 ] return
        # active (non-edit) state: the keyboard drives the debugger, not editing —
        #   c = continue, s = step over, i = step into, o = step out, esc = edit
        # esc / double-click / the 'active' button all re-arm editing.
        if [ debug_running && !edit_armed ]
            k : i32 [ ev.key.unicode ]
            if [ k == 256 ]    # Key.Escape — leave active mode, back to editing
                edit_armed = true
                return
            if [ debugger ]
                if [ k == 67 ] debugger.cont[]        # Key.C
                if [ k == 83 ] debugger.step_over[]   # Key.S
                if [ k == 73 ] debugger.step_into[]   # Key.I
                if [ k == 79 ] debugger.step_out[]    # Key.O
            return

        # save: Ctrl/Cmd-S writes the file of the selected line. in results mode
        # that's the source file the match came from (its edited lines patched in).
        if [ (ev.key.ctrl || ev.key.meta) && ev.key.unicode == 83 ]    # Key.S
            save_current[]
            pristine = false
            return

        # copy: Ctrl/Cmd-C copies the highlighted text to the system clipboard.
        if [ (ev.key.ctrl || ev.key.meta) && ev.key.unicode == 67 ]    # Key.C
            txt : string selected_text[]
            puts 'copy: len={txt.count} ux={(ux) ? 1 : 0}'
            if [ txt.count > 0 && ux ] ux.set_clipboard[ txt ]
            return

        # cut: Ctrl/Cmd-X copies the highlighted text, then deletes it (delete_selection
        # collapses the caret to the span start and clears pristine on its own).
        if [ (ev.key.ctrl || ev.key.meta) && ev.key.unicode == 88 ]    # Key.X
            txt : string selected_text[]
            puts 'cut: len={txt.count} ux={(ux) ? 1 : 0}'
            if [ txt.count > 0 && ux ]
                ux.set_clipboard[ txt ]
                delete_selection[]
                ux.will_animate = true
            return

        # paste: Ctrl/Cmd-V inserts the clipboard text at the caret (replacing any selection).
        if [ (ev.key.ctrl || ev.key.meta) && ev.key.unicode == 86 ]    # Key.V
            if [ ux ]
                clip : string ux.get_clipboard[]
                puts 'paste: len={clip.count}'
                if [ clip && clip.count > 0 ]
                    insert_text[ clip ]
                    ux.will_animate = true
            return

        # undo / redo: Ctrl/Cmd-Z (Shift = redo); Ctrl/Cmd-Y also redoes.
        if [ (ev.key.ctrl || ev.key.meta) && ev.key.unicode == 90 ]    # Key.Z
            if [ ev.key.shift ]
                redo[]
            el
                undo[]
            ux.will_animate = true
            return
        if [ (ev.key.ctrl || ev.key.meta) && ev.key.unicode == 89 ]    # Key.Y
            redo[]
            ux.will_animate = true
            return

        # navigation history: Ctrl/Cmd + Left/Right walk back/forward through significant
        # locations in THIS pane (NOT line start/end).
        if [ (ev.key.ctrl || ev.key.meta) && (ev.key.unicode == 263 || ev.key.unicode == 262) ]
            nav_walk[ (ev.key.unicode == 263) ? -1 : 1 ]
            return

        if [ line_count[] <= 0 ] return
        if [ sel_line < 0 ] sel_line = 0
        if [ sel_col  < 0 ] sel_col  = 0
        row  : i32 [ sel_line ]
        col  : i32 [ sel_col ]
        key  : i32 [ ev.key.unicode ]

        # page up / down: move the cursor and scroll by half a viewport
        # (visible lines / 2). scroll.y is re-clamped in draw.
        if [ key == 266 || key == 267 ]    # Key.PageUp / Key.PageDown
            ele  : (layers) ? (layers['content'] to EditorLayer) : null
            vh   : f32 [ (ele && ele.bounds) ? ele.bounds.h : 400.0 ]
            lh   : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
            half2 : i32 [ i32[ (vh / lh) * 0.5 ] ]
            if [ half2 < 1 ] half2 = 1
            if [ key == 266 ]    # Key.PageUp
                sel_line = snap_row[ clamp[ sel_line - half2, 0, line_count[] - 1 ] ]
                scroll.y = scroll.y - f32[ half2 ] * lh
            el
                sel_line = snap_row[ clamp[ sel_line + half2, 0, line_count[] - 1 ] ]
                scroll.y = scroll.y + f32[ half2 ] * lh
            scroll_target = scroll.y
            sel_col  = clamp[ sel_col, 0, line_get[ sel_line ].count ]
            # plain page move collapses the selection to the cursor (no highlight);
            # shift+page extends it, like a normal editor.
            if [ !ev.key.shift ]
                anchor_line = sel_line
                anchor_col  = sel_col
            pristine = false
            return

        # title slots can't be split / merged / typed into; nor can anything while the
        # inline debug tree is open (visual rows ≠ base line indices — would corrupt).
        edits_locked : bool [ row_header[ row ] || flat_active ]

        if [ key == 257 ]    # Key.Enter
            # results rows can't be split: a new row would have no source line
            if [ show_hits || edits_locked ] return
            # line-op group (kind 1): coalesces a run of Enters, breaks from a typing run.
            begin_edit[ 1 ]
            # a selection is replaced by the newline (delete it, then split at the caret)
            if [ delete_selection[] ]
                row = sel_line
                col = sel_col
            line  : line_get[ row    ]
            left  : line.mid[ 0, col ]
            right : line.mid[col, line.count - col]
            ed_set[ row, left ]
            ed_insert[ row + 1, right ]
            sel_line += 1
            sel_col   = 0
            # collapse to the caret at the start of the new line (no stale selection)
            anchor_line = sel_line
            anchor_col  = sel_col
            end_edit[]

        el [ key == 258 ]    # Key.Tab — insert a real tab. tabs are the primary indent;
            # they're rendered as tab_w spaces (display_of/vis_col) so no .notdef box.
            if [ show_hits || edits_locked ] return
            begin_edit[ 0 ]   # a tab is an inserted char — coalesces with the typing run
            if [ delete_selection[] ]
                row = sel_line
                col = sel_col
            line : line_get[ row ]
            ed_set[ row, line.mid[0, col] + '\t' + line.mid[col, line.count - col] ]
            sel_col += 1
            # collapse the selection to the caret — a tab is an insert, not a selection
            # gesture; without this the anchor stays put and leaves a stale 1-cell highlight
            # (which also misreads later clicks).
            anchor_line = sel_line
            anchor_col  = sel_col
            end_edit[]

        el [ key == 259 ]    # Key.Backspace
            if [ edits_locked ] return
            begin_edit[ 2 ]   # delete group (kind 2): coalesces a run of backspaces
            # a non-empty selection is erased wholesale (not a single char in front of it)
            if [ delete_selection[] ]
                pristine = false
            el [ col > 0 ]
                line : line_get[ row ]
                ed_set[ row, line.mid[0, col - 1] + line.mid[col, line.count - col] ]
                sel_col -= 1
            # joining rows would drop a source line, so it's results-mode-disabled
            el [ row > 0 && !show_hits ]
                prev : line_get[ row - 1 ]
                sel_col  = prev.count
                ed_set[ row - 1, prev + line_get[ row ] ]
                ed_remove[ row ]
                sel_line -= 1
            end_edit[]

        el [ key == 265 ]    # Key.Up
            np : i32 [ prev_editable[ sel_line - 1 ] ]
            if [ np >= 0 ]
                sel_line = np
                sel_col = clamp[ sel_col, 0, line_get[ sel_line ].count ]

        el [ key == 264 ]    # Key.Down
            np : i32 [ next_editable[ sel_line + 1 ] ]
            if [ np < line_count[] ]
                sel_line = np
                sel_col = clamp[ sel_col, 0, line_get[ sel_line ].count ]

        el [ key == 263 ]    # Key.Left
            if [ col > 0 ]
                sel_col -= 1
            el [ row > 0 ]
                np : i32 [ prev_editable[ row - 1 ] ]
                if [ np >= 0 ]
                    sel_line = np
                    sel_col = line_get[ np ].count

        el [ key == 262 ]    # Key.Right
            if [ col < line_get[ row ].count ]
                sel_col += 1
            el [ row < line_count[] - 1 ]
                np : i32 [ next_editable[ row + 1 ] ]
                if [ np < line_count[] ]
                    sel_line = np
                    sel_col = 0

        # plain edits (Enter/Backspace) and cursor moves collapse the selection to the
        # caret; holding shift extends it instead (shift+arrow selects, like any editor).
        if [ !ev.key.shift ]
            anchor_line = sel_line
            anchor_col  = sel_col
        ensure_caret_visible[]
        pristine = false

    public func render [] -> Elements
        return null