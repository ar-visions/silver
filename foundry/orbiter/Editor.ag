extend orbiter

class FileBuf
    public lines : list string
    public mtime : i64 [ 0 ]
    # per-file undo history (keyed by URI via file_cache, same as `lines`). hist is the
    # linked list of EditAction delta groups; hist_i the cursor = number of groups applied
    # (groups before it are undoable, groups from it on are the redo future).
    public hist       : list EditAction
    public hist_i     : i32 [ 0 ]
    # the line model's theme-resolved coloring, built by load_format[] from silver's --format
    # map. `regions` is a FLAT, line-sorted `array ColorRegion` (each carries its own line);
    # `reg_off[L]` indexes the first region whose line >= L, so a line's spans are the slice
    # [reg_off[L], reg_off[L+1]). flat + typed member so element access resolves to ColorRegion
    # (a local array loses its element meta). stale-tolerant: a structural edit clears both
    # (fmt_invalidate) and the next map reload rebuilds them.
    public regions    : array ColorRegion
    public reg_off     : array i32

# one row in the find-in-files results view. a header row is a file title (drawn
# 2 code-rows tall, larger, centered); a non-header row is a matched line of code
# carrying its source line number. `file` is the source path (on every row so a
# match row knows what to open).
class FindHit
    public is_header : bool
    public text      : string
    public file      : path
    public line      : i32

# one row in the flattened editor view: either a base code line (src >= 0, var null)
# or a virtual debug field row (src = -1, var = the field node, depth = indent level).
# the flat list IS the line model when a debug tree is expanded, so selection / clicking
# / copy all work over it for free.
class VRow
    public src   : i32 [ -1 ]
    public var   : variable
    public depth : i32 [ 0 ]

# a single primitive line change within an edit group. kind: 0=replace line `at` (before
# → after), 1=insert `after` as line `at`, 2=remove line `at` (was `before`). undo applies
# the inverse; redo applies forward. stored as deltas so memory is O(edit), not O(file).
class LineOp
    public at     : i32 [ 0 ]
    public kind   : i32 [ 0 ]
    public before : string
    public after  : string

# one undo step (a coalesced logical edit: a typing run, a run of Enters, …). holds only
# the line ops it changed plus the caret before/after — NOT a copy of the whole buffer.
# consecutive replaces of the same line collapse into one op, so typing a 100-char line is
# one op (orig→final), not 100 snapshots.
class EditAction
    public ops : array LineOp
    public sl0 : i32 [ 0 ]   # caret line/col before the group
    public sc0 : i32 [ 0 ]
    public sl1 : i32 [ 0 ]   # caret line/col after the group
    public sc1 : i32 [ 0 ]

# one themed color span on a line: model column `col`, `len` chars, drawn in `color`.
# produced by reformat[] from a silver --format token (its Syntax kind run through the
# theme). the token text itself never contains tabs, so it draws as a literal substring;
# its x is measured from the tab-expanded display prefix up to `col`.
class ColorRegion
    public line  : i32 [ 0 ]
    public col   : i32 [ 0 ]
    public len   : i32 [ 0 ]
    public color : rgba

Layer EditorLayer
    mutable sel_color      : rgba
    mutable line_color     : rgba
    # active-line glow (css-colored): used for the tab-explorer mouse-over row AND the
    # debugger's current stop line. a warm gradient row + inner glow + text color.
    mutable hl_fill        : rgba
    mutable hl_grad        : rgba
    mutable hl_glow        : rgba
    mutable hl_text        : rgba

    # draw one warm highlighted row: gradient fill (hl_fill→hl_grad, vertical) + inner
    # glow (hl_glow), rounded. save/restore so the gradient/glow don't leak to later draws.
    func glow_row [ cv: Canvas, rx: f32, ry: f32, rw: f32, rh: f32 ]
        cv.save[ ]
        cv.rounded[ 6.0, 6.0, 6.0, 6.0 ]
        cv.stroke_width[ 0.0 ]
        cv.fill_color[ hl_fill ]
        if [ hl_grad ]
            cv.fill_grad[ hl_grad ]
            cv.fill_color_pos[ rx, ry ]
            cv.fill_grad_pos[ rx, ry + rh ]
        if [ hl_glow ] cv.inner_glow[ hl_glow, 14.0 ]
        cv.rect_to[ rx, ry, rw, rh ]
        cv.paint[ ]
        cv.restore[ ]

    func on_move [ ev: Event ]
        editor : Editor[ parent ]
        if [ !editor || !editor.dragging ] return
        lh : f32 [ (editor.lh_cache > 0.0) ? editor.lh_cache : 22.0 ]
        cw : f32 [ (editor.cw_cache > 0.0) ? editor.cw_cache : 8.0 ]
        rel_y : f32 [ ev.mouse.pos.y ]
        rel_x : f32 [ ev.mouse.pos.x ]
        raw : i32 [ clamp[ rel_y / lh, 0, editor.line_count[] - 1 ] ]
        ln  : i32 [ editor.snap_row[ raw ] ]
        vx  : f32 [ round[ (rel_x - editor.row_indent[ ln ] + editor.scroll.x) / cw ] ]
        cl  : i32 [ editor.model_col[ editor.line_get[ ln ], i32[ vx ] ] ]
        editor.sel_line = ln
        editor.sel_col  = cl
        editor.pristine = false

    func draw [ cv: Canvas ]
        editor : Editor[ parent ]
        if [ !editor || !editor.lines ] return
        # find-in-files results, propagated to this instance via apply_args
        showing : bool [ editor.show_hits ]
        # results open with NO selection — nothing is selected until a row is clicked
        if [ showing && !editor.was_showing ]
            editor.sel_line = -1
        editor.was_showing = showing
        hits    : array FindHit [ editor.hits ]
        # code font size from orbiter's setting (canvas default is large). set it
        # before measuring so line_height / char width track the chosen size.
        code_fs : i32 [ (editor.code_font_size > 0) ? editor.code_font_size : 15 ]
        cv.font_size[ code_fs ]
        cw_tm   : cv.measure_text[ 'x' ]
        lh      : f32 [ cv.get_line_height[] * ((label_height > 0.0) ? label_height : 1.0) ]
        # find/replace bar open: the title doubles (+44px). a CSS state override of
        # a layer's area doesn't apply (only the base does), so shift the content
        # layer's bounds here by that extra title height. both draw (y0) and
        # place_cursor reads bounds.y, so they stay in sync.
        if [ editor.expanded ]
            extra : f32 [ 44.0 ]
            bounds.y += extra
            bounds.h -= extra
        # gutter width = digit count of the last line number * char width + pad.
        # the code content is pushed right by this width.
        ndigits : i32 [ 1 ]
        ncount  : i32 [ editor.line_count[] ]
        while [ ncount >= 10 ]
            ncount  = ncount / 10
            ndigits += 1
        gut_w   : f32 [ f32[ ndigits ] * cw_tm.w + 16.0 ]
        editor.gutter_w = gut_w
        # x0 is the code-text origin; subtract scroll.x for horizontal scroll (the
        # gutter uses bounds.x, so it stays fixed). clamp scroll.x >= 0.
        if [ editor.scroll.x < 0.0 ] editor.scroll.x = 0.0
        x0      : f32 [ bounds.x + gut_w - editor.scroll.x ]
        y0      : f32 [ bounds.y ]
        # inset the content on the right so code/text never draws under the right-
        # side overlays: the pin list (144px while searching) and the stack sub-
        # column (its actual rendered width while open). take the wider — the pins
        # draw in front of the sub-column when both are present.
        dbg_el  : element editor.elements['dbg']
        din     : f32 [ 0.0 ]
        if [ dbg_el && dbg_el.bounds ]
            din = dbg_el.bounds.w
        pin_in  : f32 [ (editor.elements['pins']) ? 144.0 : 0.0 ]
        rin     : f32 [ maxf[ pin_in, din ] ]
        # edge text fades via the element's grayscale mask: the rightmost 1/8 always
        # fades (long lines dissolve), and on horizontal scroll the left fade turns on,
        # originating at the gutter's right edge (max there) so off-screen-left code
        # dissolves to alpha — same look as the right. vec4 = (top, right, bottom, left).
        left_fade : f32 [ (editor.scroll.x > 0.0) ? bounds.w / 8.0 : 0.0 ]
        parent.mask_glow = vec4f [ 0.0, bounds.w / 8.0, 0.0, left_fade ]
        # keep the line-number gutter fully opaque; the left fade starts just past it.
        parent.mask_keep_l = gut_w
        # start the top fade at the bottom of the title bar so code scrolls
        # cleanly under it; fall back to 70px if the title isn't laid out yet.
        title_bottom : f32 [ 70.0 ]
        te : element parent.elements['title']
        if [ te && te.bounds ]
            title_bottom = te.bounds.y + te.bounds.h
        # left inset = gut_w so the left fade originates at the gutter edge, not x=0.
        parent.mask_inset = vec4f [ title_bottom, 0.0, 0.0, gut_w ]
        editor.lh_cache  = lh
        editor.cw_cache  = cw_tm.w
        # rebuild the flat row model (base code lines + spliced-in expanded debug
        # field rows) once per frame, before any layout/draw consults line_count.
        editor.rebuild_flat[]
        # every visual row (incl. the 2 file-title slots and any expanded field rows)
        # is one line-height tall; line_count already folds the expanded rows in.
        editor.content_h = f32[ editor.line_count[] ] * lh
        editor.scroll_speed = lh

        # clamp scroll to [0, content - viewport] every frame so it can't go
        # negative (above the top) or past the end of the content.
        max_scroll : f32 [ editor.content_h - bounds.h ]
        if [ max_scroll < 0.0 ] max_scroll = 0.0
        if [ editor.scroll.y < 0.0 ] editor.scroll.y = 0.0
        if [ editor.scroll.y > max_scroll ] editor.scroll.y = max_scroll

        # clip scrolled text to the editor bounds (world-space px = transform
        # offset + local bounds). same crop data the shaders read for shapes.
        wtx : f32 [ cv.transform_tx[] ]
        wty : f32 [ cv.transform_ty[] ]
        cv.set_crop[ wtx + bounds.x, wty + bounds.y,
            wtx + bounds.x + bounds.w - rin, wty + bounds.y + bounds.h ]

        # active-line glow: in the tab explorer it's the mouse-over row; otherwise it's
        # the debugger's current stop line. drawn behind the gutter/code so numbers and
        # text sit on top. its text is recolored to hl_text in the content loop.
        # mouse-over highlight while navigating a list (tab explorer or find results);
        # otherwise the debugger's current stop line.
        in_list : bool [ editor.finder_list || showing ]
        # stop_line is a base source line; map it to its visual flat row so the glow,
        # text recolor, and gutter marker land on the right row when the tree is open.
        stop_vrow : i32 [ editor.vis_row[ editor.stop_line ] ]
        hl_line : i32 [ (in_list) ? editor.hover_line : stop_vrow ]
        if [ hl_line >= 0 && hl_fill ]
            hy : f32 [ y0 + f32[ hl_line ] * lh - editor.scroll.y ]
            if [ hy + lh >= bounds.y && hy <= bounds.y + bounds.h ]
                glow_row[ cv, bounds.x + 1.0, hy + 1.0, bounds.w - rin - 2.0, lh - 2.0 ]

        # ---- gutter: per-line flat cells, line numbers, hover + breakpoint ----
        # breakpoint colors the entire line (full width) behind the code; the
        # flat cell + right-aligned number sit in the gutter column on the left.
        cv.stroke_width[ 0.0 ]
        # line-number labels render 30% smaller than the code font, then 1px smaller
        num_fs  : i32 [ i32[ f32[ code_fs ] * 0.7 ] - 1 ]
        cv.font_size[ num_fs ]
        for [ li: i32 0, li < editor.line_count[], li += 1 ]
            # file-title slots get no gutter (number / cell / breakpoint); the title
            # itself is drawn in the content loop below.
            if [ editor.row_header[ li ] ] continue
            # virtual debug field rows get no gutter cell / number / breakpoint.
            if [ editor.row_var[ li ] ] continue
            yg : f32 [ y0 + f32[li] * lh - editor.scroll.y ]
            if [ yg + lh < bounds.y ] continue
            if [ yg > bounds.y + bounds.h ] break
            # each row keys its breakpoint + line number off its own source: in
            # results mode that's the match's origin file + line, else this editor's
            # base source line (which, with the tree open, differs from the visual row).
            bsl  : i32  [ editor.row_src[ li ] ]
            rnum : i32  [ (showing && hits) ? hits[li].line : bsl + 1 ]
            # breakpoints are a file-editing concept — never washed in results view
            if [ !showing ]
                bp : editor.breakpoints['{editor.src}:{bsl + 1}']
                if [ bp != null ]
                    cv.fill_color[ editor.bp_color[ bp ] ]
                    cv.rect_to[ bounds.x, yg, bounds.w - rin - 1.0, lh ]
                    cv.paint[ ]
            # current/selected-line background — painted here in the gutter stage (BEHIND
            # the code) exactly like the breakpoint band, so the code sits on top and the
            # color shows through, and it's masked at the edges the same way.
            if [ editor.sel_line >= 0 && editor.sel_line < editor.line_count[] ]
                a_ln : i32 [ clamp[ editor.anchor_line, 0, editor.line_count[] - 1 ] ]
                s_ln : i32 [ editor.sel_line ]
                lo   : i32 [ (a_ln < s_ln) ? a_ln : s_ln ]
                hi   : i32 [ (a_ln < s_ln) ? s_ln : a_ln ]
                if [ li >= lo && li <= hi ]
                    cv.fill_color[ (line_color) ? line_color : rgba['#ffffff18'] ]
                    cv.rect_to[ bounds.x, yg, bounds.w - rin - 1.0, lh ]
                    cv.paint[ ]
            cv.fill_color[ rgba['#ffffff08'] ]
            cv.rect_to[ bounds.x + 2.0, yg + 1.0, gut_w - 4.0, lh - 2.0 ]
            cv.paint[ ]
            # the debugger's current stop line (active break): a white border around the
            # entire colored line, plus a small filled white ">" arrow at the left edge
            # (x 0 → 6px), centered. drawn over the gutter cell so both stay visible.
            if [ !showing && stop_vrow == li ]
                mid : f32 [ yg + lh * 0.5 ]
                cv.save[ ]
                # white outline around the whole line — rounded to match the glow_row
                # highlight (same 6px radius + 1px inset).
                cv.rounded[ 6.0, 6.0, 6.0, 6.0 ]
                cv.fill_color[ rgba['#00000000'] ]
                cv.stroke_color[ rgba['#ff44'] ]
                cv.stroke_width[ 1.0 ]
                cv.rect_to[ bounds.x + 1.0, yg + 1.0, bounds.w - rin - 2.0, lh - 2.0 ]
                cv.paint[ ]
                cv.stroke_width[ 0.0 ]
                cv.rounded[ 0.0, 0.0, 0.0, 0.0 ]
                # execution marker: a sideways "house" (flat back + pointed front) — a
                # rectangular body that tapers to a point at the code. sits past the
                # line-number column, tip at the gutter/code boundary.
                cv.fill_color[ rgba['#ffffff'] ]
                gtip : f32 [ bounds.x + gut_w + 12.0 ]
                cv.move_to[ gtip - 11.0, mid - 6.0 ]
                cv.line_to[ gtip - 6.0,  mid - 6.0 ]
                cv.line_to[ gtip,        mid ]
                cv.line_to[ gtip - 6.0,  mid + 6.0 ]
                cv.line_to[ gtip - 11.0, mid + 6.0 ]
                cv.close_path[ ]
                cv.paint[ ]
                # the exact stop column lldb reported — a thin gold caret in the code
                # (separate from the edit selection), marking where execution paused.
                if [ editor.stop_col >= 0 ]
                    cx : f32 [ x0 + f32[editor.stop_col] * cw_tm.w ]
                    cv.fill_color[ rgba['#ffcc33'] ]
                    cv.rect_to[ cx, yg + 1.0, 2.0, lh - 2.0 ]
                    cv.paint[ ]
                cv.restore[ ]
            # only when the gutter itself is hovered does the close icon take it
            # over, so the line number is suppressed just then (icon drawn below).
            if [ !(showing && editor.hover_gutter && editor.hover_line == li) ]
                cv.fill_color[ rgba['#ffffff80'] ]
                cv.draw_text[ '{rnum}',
                    rect [ x: bounds.x, y: yg, w: gut_w - 6.0, h: lh ],
                    vec2f [ 1.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]

        # restore the code font before drawing line content
        cv.font_size[ code_fs ]
        # when horizontally scrolled, tighten the crop so code shifted left doesn't
        # draw over the (stationary) line-number gutter. the gutter loop above already
        # drew under the wider editor-bounds crop.
        if [ editor.scroll.x > 0.0 ]
            cv.set_crop[ wtx + bounds.x + gut_w, wty + bounds.y,
                wtx + bounds.x + bounds.w - rin, wty + bounds.y + bounds.h ]
        for [ li: i32 0, li < editor.line_count[], li += 1 ]
            y : f32 [ y0 + f32[li] * lh - editor.scroll.y ]
            if [ editor.row_header[ li ] ]
                # the title draws once, on the first of its 2 slots, spanning both
                if [ li > 0 && editor.row_header[ li - 1 ] ] continue
                rh : f32 [ lh * 2.0 ]
                if [ y + rh < bounds.y ] continue
                if [ y > bounds.y + bounds.h ] break
                # distinct background: inset 4px, 12px rounded, blended at 0.5 alpha
                cv.save[ ]
                cv.rounded[ 12.0, 12.0, 12.0, 12.0 ]
                cv.fill_color[ rgba['#2b3a5580'] ]
                cv.rect_to[ bounds.x + 4.0, y + 4.0, bounds.w - rin - 8.0, rh - 8.0 ]
                cv.paint[ ]
                cv.restore[ ]
                cv.fill_color[ rgba['#fff'] ]
                cv.draw_text[ editor.line_get[ li ],
                    rect [ x: bounds.x, y: y, w: bounds.w - rin, h: rh ],
                    vec2f [ 0.5, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]
                # close icon on the left of the header (centered over its 2 slots) —
                # clicking it removes the whole file group. shown when the header is
                # hovered (either of its two slots).
                if [ editor.hover_gutter && (editor.hover_line == li || editor.hover_line == li + 1) ]
                    if [ !editor.close_icon ]
                        editor.close_icon = SVGModel [ path 'images/close.svg' ]
                    hisz : f32 [ round[ lh * 0.5 ] ]
                    hiox : f32 [ round[ bounds.x + (gut_w - hisz) * 0.5 ] ]
                    hioy : f32 [ round[ y + (rh - hisz) * 0.5 ] ]
                    cv.draw_svg[ editor.close_icon, hiox, hioy, hisz, hisz ]
                    cv.paint[ ]
                continue
            if [ y + lh < bounds.y ] continue
            if [ y > bounds.y + bounds.h ] break
            ln    : editor.line_get[ li ]
            rvd   : variable editor.row_var[ li ]
            if [ rvd ]
                # virtual debug field row (# name = value) — indented by tree depth,
                # rendered in ghost-comment green so it reads as inline annotation. a
                # field that is itself an object/string gets a [+]/[-] so the nested
                # tree is discoverable (clicking the row toggles it).
                dpx : f32 [ x0 + editor.row_indent[ li ] ]
                vtg : string [ (editor.var_expandable[ rvd ]) ? ((rvd.expanded) ? '  [-]' : '  [+]') : '' ]
                cv.fill_color[ rgba['#6a9955cc'] ]
                cv.draw_text[ '{ln}{vtg}',
                    rect [ x: dpx, y: y, w: bounds.x + bounds.w - rin - dpx, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]
                continue
            txtc  : rgba [ (li == hl_line && hl_text) ? hl_text : rgba['#fff'] ]
            cv.fill_color[ txtc ]
            cv.draw_text[ editor.display_of[ ln ],
                rect [ x: x0, y: y, w: bounds.w - gut_w - rin, h: lh ],
                vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            # syntax overdraw: paint each themed token over the base line. tokens carry no
            # tabs, so each is a literal substring; its x is measured from the tab-expanded
            # display prefix up to its model column. comments/whitespace stay the base color.
            msl : i32 [ editor.row_src[ li ] ]
            nrg : i32 [ editor.line_reg_count[ msl ] ]
            for [ ri: i32 0, ri < nrg, ri += 1 ]
                cr  : ColorRegion editor.line_reg[ msl, ri ]
                pre : editor.display_of[ ln.mid[ 0, cr.col ] ]
                px  : f32 [ cv.measure_text[ pre ].w ]
                seg : ln.mid[ cr.col, cr.len ]
                cv.fill_color[ cr.color ]
                cv.draw_text[ seg,
                    rect [ x: x0 + px, y: y, w: bounds.w - gut_w - rin, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
        cv.paint[ ]

        # ---- debug-active: inline ghost value annotations (# name = value) ----
        # the collapsed summary at each variable's decl line (the future + expansion
        # title). own pass so it gets its own comment color/paint, after the code.
        if [ !showing && editor.debug_vars ]
            cv.font_size[ code_fs ]
            cv.fill_color[ rgba['#6a9955cc'] ]
            for [ li: i32 0, li < editor.line_count[], li += 1 ]
                if [ editor.row_header[ li ] ] continue
                if [ editor.row_var[ li ] ] continue   # virtual field rows drawn already
                bsl : i32 [ editor.row_src[ li ] ]
                if [ bsl < 0 ] continue
                bk  : i32 [ editor.base_var_at[ bsl ] ]
                if [ bk < 0 ] continue
                bv   : variable editor.debug_vars[ bk ]
                summ : editor.var_summary[ bv ]
                if [ !summ || summ.count == 0 ] continue
                ya : f32 [ y0 + f32[li] * lh - editor.scroll.y ]
                if [ ya + lh < bounds.y ] continue
                if [ ya > bounds.y + bounds.h ] break
                # expandable objects get a [+]/[-] toggle after the summary
                tog : (editor.var_expandable[ bv ]) ? ((bv.expanded) ? '  [-]' : '  [+]') : ''
                ln2 : editor.line_get[ li ]
                aw  : f32 [ cv.measure_text[ ln2 ].w ]
                ax  : f32 [ x0 + aw + 24.0 ]
                # mouse-over an expandable annotation → a soft green glow behind it.
                if [ editor.hover_ann == li ]
                    cv.save[ ]
                    cv.rounded[ 5.0, 5.0, 5.0, 5.0 ]
                    cv.stroke_width[ 0.0 ]
                    cv.fill_color[ rgba['#2f7a4a44'] ]
                    cv.inner_glow[ rgba['#5fd08abb'], 10.0 ]
                    cv.rect_to[ ax - 8.0, ya + 2.0, bounds.x + bounds.w - rin - ax + 4.0, lh - 4.0 ]
                    cv.paint[ ]
                    cv.restore[ ]
                    cv.fill_color[ rgba['#6a9955cc'] ]
                cv.draw_text[ '# {summ}{tog}',
                    rect [ x: ax, y: ya, w: bounds.x + bounds.w - rin - ax, h: lh ],
                    vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.clip, null ]
            cv.paint[ ]

        # outline the matched query substring on each visible result line (outline
        # only). measured against the actual glyph advances so tabs/indent line up.
        if [ showing && editor.find_query && editor.find_query.count > 0 ]
            for [ li: i32 0, li < editor.line_count[], li += 1 ]
                if [ editor.row_header[ li ] ] continue
                y : f32 [ y0 + f32[li] * lh - editor.scroll.y ]
                if [ y + lh < bounds.y ] continue
                if [ y > bounds.y + bounds.h ] break
                ln : editor.line_get[ li ]
                mi : ln.index_of[ editor.find_query ]
                if [ mi >= 0 ]
                    pre : f32 [ cv.measure_text[ ln.mid[ 0, mi ] ].w ]
                    mw  : f32 [ cv.measure_text[ ln.mid[ mi, editor.find_query.count ] ].w ]
                    cv.fill_color  [ rgba['#0000'] ]
                    cv.stroke_color[ rgba['#ffcc66cc'] ]
                    cv.stroke_width[ 1.0 ]
                    cv.rect_to     [ x0 + pre - 1.0, y + 2.0, mw + 2.0, lh - 4.0 ]
                    cv.paint       [ ]
            cv.stroke_width[ 0.0 ]

        # results: the hovered match row shows the close icon in the gutter (left),
        # centered over the suppressed line number. clicking the gutter removes the
        # row (see on_press). drawn on top, after the content paint.
        if [ showing && hits && editor.hover_gutter && editor.hover_line >= 0 && !editor.row_header[ editor.hover_line ] ]
            hy : f32 [ y0 + f32[ editor.hover_line ] * lh - editor.scroll.y ]
            if [ hy + lh >= bounds.y && hy <= bounds.y + bounds.h ]
                if [ !editor.close_icon ]
                    editor.close_icon = SVGModel [ path 'images/close.svg' ]
                isz : f32 [ round[ lh * 0.5 ] ]
                iox : f32 [ round[ bounds.x + (gut_w - isz) * 0.5 ] ]
                ioy : f32 [ round[ hy + (lh - isz) * 0.5 ] ]
                cv.draw_svg[ editor.close_icon, iox, ioy, isz, isz ]
                cv.paint[ ]

        # crop stays set to the editor bounds: the selection rects, their
        # text, and the cursor below all clip to it. cleared at draw end.
        # guard against a stale cursor/anchor past the end (e.g. after removing all
        # results) so the caret + selection loops never index out of bounds.
        if [ editor.sel_line >= editor.line_count[] ] editor.sel_line = -1
        if [ editor.sel_line >= 0 && editor.anchor_line >= editor.line_count[] ]
            editor.anchor_line = editor.line_count[] - 1
        if [ editor.sel_line >= 0 ]
            cv.save[ ]
            cv.stroke_width[ 0.0 ]
            al          : i32 [ editor.anchor_line ]
            ac          : i32 [ editor.anchor_col ]
            sl          : i32 [ editor.sel_line ]
            sc          : i32 [ editor.sel_col ]
            before      : bool [ al < sl || (al == sl && ac <= sc) ]
            start_line  : i32 [ (before) ? al : sl ]
            start_col   : i32 [ (before) ? ac : sc ]
            end_line    : i32 [ (before) ? sl : al ]
            end_col     : i32 [ (before) ? sc : ac ]
            cw          : f32 [ cw_tm.w ]
            has_sel : bool [ start_line != end_line || start_col != end_col ]

            scrolled : bool [ editor.scroll.y != editor.last_scroll_y ]
            editor.last_scroll_y = editor.scroll.y
            # a resize (window or dbg-seam) changes the editor's content width — the
            # selection goal jumps, so snap it (no easing) instead of filtering.
            resized  : bool [ (bounds.w - rin) != editor.last_view_w ]
            editor.last_view_w = bounds.w - rin
            if [ editor.last_sel_line != sl || editor.last_sel_col != ac || editor.last_before != before ]
                editor.last_sel_line = sl
                editor.last_sel_col  = ac
                editor.last_before   = before
                editor.filter_rect = null
                editor.filter_next = false

            # the base selected-line band(s) are painted earlier, in the gutter stage
            # (behind the code) — see the current-line band there. here we only draw the
            # rounded selection highlight in front of the text (masked).
            sel_col_val  : rgba [ (sel_color)  ? sel_color  : rgba['#264f78'] ]

            if [ has_sel ]
                cv.save[ ]
                cv.rounded[ 6.0, 6.0, 6.0, 6.0 ]
                pad : 2
                for [ li: i32 start_line, li <= end_line, li += 1 ]
                    y_row  : f32 [ y0 + f32[li] * lh - editor.scroll.y ]
                    if [ y_row + lh < bounds.y || y_row > bounds.y + bounds.h ] continue
                    is_sl  : bool [ li == start_line ]
                    is_el  : bool [ li == end_line ]
                    lnv    : editor.line_get[ li ]
                    dnv    : editor.display_of[ lnv ]
                    col_x0 : f32 [ (is_sl) ? cv.measure_text[ dnv.mid[ 0, editor.vis_col[ lnv, start_col ] ] ].w : 0.0 ]
                    col_x1 : f32 [ (is_el) ? cv.measure_text[ dnv.mid[ 0, editor.vis_col[ lnv, end_col ] ] ].w : bounds.w - gut_w - rin ]
                    bx     : f32 [ x0 + editor.row_indent[ li ] ]
                    rx     : f32 [ bx + col_x0 ]
                    rw     : f32 [ col_x1 - col_x0 ]

                    rr : rect [ x:rx + pad, y:y_row + pad,
                        w:rw - pad * 2, h:lh - pad * 2 ]
                    if [ editor.last_sel_line == li ]
                        if [ scrolled || resized ]
                            editor.filter_rect = null
                        if [ editor.filter_rect ]
                            # ease the selection rect toward its goal with the
                            # shared frame-rate-aware filter; snap to the goal once
                            # within tolerance so it settles cleanly and stops
                            # requesting frames.
                            gx  : f32 [ rr.x ]
                            gy  : f32 [ rr.y ]
                            gw  : f32 [ rr.w ]
                            gh  : f32 [ rr.h ]
                            amt : f32 [ 0.25 ]
                            rt  : f32 [ editor.ux.frame_factor ]
                            rr.x = filter_n[ editor.filter_rect.x, gx, amt, rt ]
                            rr.y = filter_n[ editor.filter_rect.y, gy, amt, rt ]
                            rr.w = filter_n[ editor.filter_rect.w, gw, amt, rt ]
                            rr.h = filter_n[ editor.filter_rect.h, gh, amt, rt ]
                            tol : f32 [ 0.5 ]
                            if [ abs[ gx - rr.x ] < tol && abs[ gy - rr.y ] < tol && abs[ gw - rr.w ] < tol && abs[ gh - rr.h ] < tol ]
                                rr.x = gx
                                rr.y = gy
                                rr.w = gw
                                rr.h = gh
                            el
                                editor.ux.will_animate = true
                                editor.needs_frame     = true

                        editor.filter_rect = rr
                        editor.filter_next = true

                    cv.fill_color  [ sel_col_val ]
                    cv.stroke_color[ rgba['#fff1'] ]
                    cv.stroke_width[ 0.5 ]
                    cv.rect_to     [ rr.x, rr.y - 0.5, rr.w, rr.h + 1 ]
                    cv.paint       [ ]
                    cv.stroke_width[ 0.0 ]
                cv.restore[ ]

                tx : f32 [ cv.transform_tx[] ]
                ty : f32 [ cv.transform_ty[] ]
                for [ li: i32 start_line, li <= end_line, li += 1 ]
                    y_row  : f32 [ y0 + f32[li] * lh - editor.scroll.y ]
                    if [ y_row + lh < bounds.y || y_row > bounds.y + bounds.h ] continue
                    is_sl  : bool [ li == start_line ]
                    is_el  : bool [ li == end_line ]
                    lnv    : editor.line_get[ li ]
                    dnv    : editor.display_of[ lnv ]
                    col_x0 : f32 [ (is_sl) ? cv.measure_text[ dnv.mid[ 0, editor.vis_col[ lnv, start_col ] ] ].w : 0.0 ]
                    col_x1 : f32 [ (is_el) ? cv.measure_text[ dnv.mid[ 0, editor.vis_col[ lnv, end_col ] ] ].w : bounds.w - gut_w - rin ]
                    bx     : f32 [ x0 + editor.row_indent[ li ] ]
                    rx     : f32 [ bx + col_x0 ]
                    rw     : f32 [ col_x1 - col_x0 ]
                    use_filter : bool [ editor.last_sel_line == li && editor.filter_rect ]
                    crop_x : f32 [ (use_filter) ? editor.filter_rect.x : rx ]
                    crop_w : f32 [ (use_filter) ? editor.filter_rect.w : rw ]
                    # X clips to the (animated) selection/filter rect; Y clips
                    # to the editor bounds so partial rows can't spill on scroll. left is
                    # clamped to the gutter edge so horizontally-scrolled selected text
                    # never draws over the stationary line-number column.
                    sel_lx : f32 [ (crop_x > bounds.x + gut_w) ? crop_x : bounds.x + gut_w ]
                    cv.set_crop[ tx + sel_lx, ty + bounds.y,
                        tx + crop_x + crop_w, ty + bounds.y + bounds.h ]
                    cv.fill_color[ '#fff' ]
                    cv.draw_text[ editor.display_of[ lnv ],
                        rect [ x: bx, y: y_row, w: bounds.w - gut_w, h: lh ],
                        vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
                cv.paint[ ]
                # back to the code-region crop (gutter edge) for the cursor below
                cv.set_crop[ tx + bounds.x + gut_w, ty + bounds.y,
                    tx + bounds.x + bounds.w, ty + bounds.y + bounds.h ]

            if [ parent.focused ]
                y_sel : f32 [ y0 + f32[editor.sel_line] * lh - editor.scroll.y ]
                if [ y_sel + lh >= bounds.y && y_sel <= bounds.y + bounds.h ]
                    use_fr : bool [ has_sel && editor.filter_rect ]
                    cx : f32
                    cy : f32
                    if [ use_fr ]
                        cx = (before) ? editor.filter_rect.x + editor.filter_rect.w : editor.filter_rect.x
                        cy = editor.filter_rect.y
                    el
                        # caret x = EXACT rendered width of the display prefix (tabs
                        # expanded to spaces). measure_text, not vis_col*cw — the code
                        # font's space is narrower than cw, so the grid drifts ahead by
                        # ~1 space per tab. measuring the real glyphs keeps it tight.
                        clnv : editor.line_get[ editor.sel_line ]
                        pre  : editor.display_of[ clnv ].mid[ 0, editor.vis_col[ clnv, editor.sel_col ] ]
                        cx   = x0 + editor.row_indent[ editor.sel_line ] + cv.measure_text[ pre ].w
                        cy   = y_sel
                    cv.fill_color[ '#fff' ]
                    cv.stroke_width[ 0.0 ]
                    cv.rect_to[ cx, cy + 2.0, 2.0, lh - 4.0 ]
                    cv.paint[]

            cv.restore[ ]

        # release the editor-bounds crop so following elements aren't clipped
        cv.clear_crop[ ]


Control Editor
    public  selected      : bool
    # find/replace bar open: doubles the title height (CSS :expanded), reveals the
    # stacked Find + Replace rows, and pushes the code content down so it doesn't
    # paint over them. lives on the Editor so one state drives title + content.
    public  expanded      : bool
    # find-in-files results display: when show_hits is set the editor renders
    # `hits` (file-title headers + matched code lines) instead of file content.
    # both are fed from app state each frame (the Editor is rebuilt per frame).
    public  show_hits     : bool
    public  hits          : array FindHit
    # true while this pane shows the tab-explorer / navigate list (ed.lines = find_results,
    # set in apply_pane). drives the warm mouse-over row highlight in EditorLayer.
    public  finder_list   : bool
    # the active search query — used to outline the matched substring per result row
    public  find_query    : string
    public  show_nav      : bool
    public  editor_mode   : string
    public  src           : path
    mutable lines         : list string
    mutable file_cache    : map FileBuf[string]
    # close icon for the per-row 'remove this match' button (lazy-loaded in draw)
    mutable close_icon    : SVGModel
    # tracks show_hits across frames so entering results can clear the selection
    mutable was_showing   : bool
    # true while the mouse is over the gutter column — the close icon only shows
    # (and the line number only hides) when actually hovering that left area.
    mutable hover_gutter  : bool
    # true while dragging the scrollbar thumb
    mutable scroll_dragging : bool
    # TEST: sel_col overrides the base element's sel_col default. With the e_init
    # fix (af-bits reset to only the programmer-passed args after init), this
    # override should NOT cause apply_args to reconcile/zero the caret column.
    mutable sel_line      : i32 [ -1 ]
    mutable sel_col       : i32 [ 0 ]
    # soft-tab width: spaces emitted per Tab (aligned to the next multiple). matches the
    # 4-space indent these .ag files use (and silver's tab = 4 indent units).
    mutable tab_w         : i32 [ 4 ]
    # unlimited undo/redo, delta-based. `hist` aliases the current file's cur_buf.hist
    # (linked list of EditAction delta groups, shared by reference like lines↔buf.lines);
    # hist_i is the cursor = number of applied groups, mirrored into cur_buf by touch_hist.
    # edit_kind (0=type 1=lineop 2=delete; -1=none) + edit_cl/edit_cc (caret after the last
    # edit, for jump detection) drive coalescing; all transient (reset on file switch).
    mutable cur_buf       : FileBuf
    mutable hist          : list EditAction
    mutable hist_i        : i32 [ 0 ]
    # the currently-open delta group (ops append here; null = none open) and the caret
    # captured before that group's first op (its undo target).
    mutable cur_group     : EditAction
    mutable pend_sl0      : i32 [ 0 ]
    mutable pend_sc0      : i32 [ 0 ]
    mutable edit_kind     : i32 [ -1 ]
    mutable edit_cl       : i32 [ -1 ]
    mutable edit_cc       : i32 [ -1 ]
    # the line the debugger is currently halted on (-1 = none). orbiter sets this
    # from on_break; it draws a small white ">" arrow in the gutter of that line to
    # mark the active execution point. cleared when the session continues/exits.
    mutable stop_line     : i32 [ -1 ]
    # the exact column lldb reported for the stop (separate from sel_col) — drawn as
    # a marker on the stop line. -1 = none.
    mutable stop_col      : i32 [ -1 ]
    # debug edit-lock: while a debug session is live (debug_running, injected by
    # orbiter) the editor is read-only so the keyboard stays free for debugger
    # commands. a double-click on the body, or the title's 'active' button, sets
    # edit_armed to drop back into editing. last_press_us drives double-click detect.
    public  debug_running : bool
    # the live debug session for this editor's target (injected by orbiter); in the
    # active (non-edit) state the keyboard drives it: c continue, s step over,
    # i step into, o step out.
    public  debugger      : dbg
    # the stopped frame's variables (injected by orbiter while paused). drawn as
    # inline ghost annotations on each variable's decl line: `# name = value`.
    public  debug_vars    : array
    # ghost-annotation tree expansion: the flattened row list (base lines + each open
    # object's expanded subtree, depth-first) becomes the line model while active.
    # rebuilt at draw top each frame from debug_vars + each variable's `expanded` flag.
    mutable flat_rows     : array VRow
    mutable flat_active   : bool
    # mouse-over annotation line (for the green hover glow), in VISUAL/flat row coords.
    mutable hover_ann     : i32 [ -1 ]
    mutable edit_armed    : bool
    mutable last_press_us : i64
    mutable lh_cache      : f32 [ 0.0 ]
    mutable cw_cache      : f32 [ 0.0 ]
    mutable anchor_line   : i32 [ 0 ]
    mutable dragging      : bool
    mutable cursor_idx    : i32 [ -1 ]
    mutable last_sel_line : -1
    mutable last_sel_col  : -1
    mutable last_before   : false
    mutable filter_rect   : rect
    mutable filter_next   : false
    mutable last_scroll_y : f32
    # last content width (bounds.w - rin); a change = resize → snap the selection rect
    mutable last_view_w   : f32
    # gutter: line under the mouse (hover highlight) and measured gutter width.
    # breakpoints are app-global, keyed by "source:line" -> condition string,
    # injected by orbiter (a shared map reference) — a present key colors the
    # whole line rather than drawing a dot.
    mutable hover_line    : i32 [ -1 ]
    mutable gutter_w      : f32 [ 0.0 ]
    public  breakpoints   : map string[string]
    # code font size (px), injected by orbiter; gutter labels render smaller.
    public  code_font_size : i32 [ 15 ]
    # the stack-split seam width (units), injected by orbiter each frame. not read
    # in draw (din is measured from the live 'dbg' element bounds) — it's here so a
    # seam drag changes this prop, marks the editor dirty, and the code re-clips LIVE
    # as you drag instead of only snapping on release.
    # per-editor toggle for the dbg sub-column (Fields/Callstack). unique to this
    # editor (its container) and persists across frames — the title menu icon flips
    # it, so each tab shows/hides its own panel.
    mutable dbg_open      : bool

    # whole-line wash color: conditional (non-empty condition) vs plain.
    func bp_color [ cond: string ] -> rgba
        if [ cond && cond.count > 0 ] return rgba['#3b82f638']   # conditional
        return rgba['#e5394538']                                 # plain

    # the debug_vars index of the variable whose `name:` decl is on BASE line bli (a
    # word-boundary name immediately followed by ':'), else -1. scans the raw `lines`
    # (not line_get) so it's safe to call while rebuilding the flat model.
    func base_var_at [ bli: i32 ] -> i32
        if [ !debug_vars || bli < 0 || bli >= lines.count ] return -1
        # a decl on a line strictly AFTER the stop hasn't been reached — never live.
        if [ stop_line >= 0 && bli > stop_line ] return -1
        line : string lines.value_by_index[ bli ]
        if [ !line || line.count == 0 ] return -1
        for [ k: i32 0, k < debug_vars.count, k += 1 ]
            v : variable debug_vars[k]
            if [ !v || !v.name || v.name.count == 0 ] continue
            nm  : string v.name
            pos : i32 [ line.index_of[ nm ] ]
            if [ pos < 0 ] continue
            if [ pos > 0 ]
                pc : i32 [ line[ pos - 1 ] ]
                if [ (pc >= 97 && pc <= 122) || (pc >= 65 && pc <= 90) || (pc >= 48 && pc <= 57) || pc == 95 ] continue
            j : i32 [ pos + nm.count ]
            while [ j < line.count && (line[j] == 32 || line[j] == 9) ]
                j += 1
            if [ j < line.count && line[j] == 58 ]
                # only annotate variables the debugger has actually reached. lldb lists
                # every local regardless of the PC, so a not-yet-run decl shows as
                # "# i = ". on the stop line itself the row can't decide it (a loop var
                # is declared and incremented on the same for-line), so compare columns:
                # the decl is live only once the PC's column is past it.
                if [ stop_line >= 0 && bli == stop_line && stop_col >= 0 && stop_col <= pos ] return -1
                return k
        return -1

    # collapsed summary for a var: an object shows its first 2 fields, a scalar `= value`.
    func var_summary [ v: variable ] -> string
        if [ !v ] return ''
        nm : string v.name
        if [ v.children && v.children.count > 0 ]
            sum : string [ '' ]
            n   : i32 [ (v.children.count < 2) ? v.children.count : 2 ]
            for [ ci: i32 0, ci < n, ci += 1 ]
                c    : variable v.children[ci]
                part : '{c.name}: {c.value}'
                sum = (ci > 0) ? sum + ', ' + part : part
            if [ v.children.count > 2 ] sum = sum + ', ...'
            return nm + ' = (' + sum + ')'
        return '{nm} = {v.value}'

    # has fields → expandable.
    func var_expandable [ v: variable ] -> bool
        return v && v.children && v.children.count > 0

    # depth-first append of v's expanded subtree into flat_rows at the given indent.
    func splice_var [ v: variable, depth: i32 ]
        if [ !v || !v.expanded || !v.children ] return
        for [ ci: i32 0, ci < v.children.count, ci += 1 ]
            c : variable v.children[ci]
            flat_rows.push[ VRow [ src: -1, var: c, depth: depth ] ]
            splice_var[ c, depth + 1 ]

    # rebuild the flattened row list: every base code line, with each object var's
    # expanded subtree spliced in right after its decl line. flat_active when anything
    # was spliced (so the normal path is untouched when nothing is expanded).
    func rebuild_flat []
        flat_rows = array VRow []
        flat_active = false
        if [ !debug_vars ] return
        base : i32 [ lines.count ]
        for [ bli: i32 0, bli < base, bli += 1 ]
            flat_rows.push[ VRow [ src: bli ] ]
            k : i32 [ base_var_at[ bli ] ]
            if [ k >= 0 ]
                splice_var[ debug_vars[ k ], 1 ]
        flat_active = flat_rows.count > base

    # flat-row accessors (identity when no tree is open).
    func row_src [ vr: i32 ] -> i32
        if [ !flat_active || !flat_rows || vr < 0 || vr >= flat_rows.count ] return vr
        r : VRow flat_rows[ vr ]
        return r.src

    func row_var [ vr: i32 ] -> variable
        if [ !flat_active || !flat_rows || vr < 0 || vr >= flat_rows.count ] return null
        r : VRow flat_rows[ vr ]
        return r.var

    func row_depth [ vr: i32 ] -> i32
        if [ !flat_active || !flat_rows || vr < 0 || vr >= flat_rows.count ] return 0
        r : VRow flat_rows[ vr ]
        return r.depth

    # leading x-offset (px past x0) for a row's text/selection: virtual debug field
    # rows step in by their tree depth; base code rows sit flush at x0. single source
    # for the content draw AND the selection-rect/selected-text passes (so a selected
    # virtual row keeps its indent instead of snapping back to x0).
    func row_indent [ vr: i32 ] -> f32
        if [ row_var[ vr ] ] return 12.0 + f32[ row_depth[ vr ] ] * 16.0
        return 0.0

    # inverse of row_src: the visual flat row for base source line bli (identity when
    # no tree is open). passes negatives (e.g. an unset stop line) straight through.
    func vis_row [ bli: i32 ] -> i32
        if [ bli < 0 ] return bli
        if [ !flat_active || !flat_rows ] return bli
        for [ vr: i32 0, vr < flat_rows.count, vr += 1 ]
            r : VRow flat_rows[ vr ]
            if [ r.src == bli ] return vr
        return bli

    # row count of the active buffer: results (hits), the open debug tree, or lines.
    func line_count [] -> i32
        if [ show_hits && hits ] return hits.count
        if [ flat_active && flat_rows ] return flat_rows.count
        return lines.count

    # is row i a non-editable file-title slot (results mode only)?
    func row_header [ i: i32 ] -> bool
        if [ show_hits && hits && i >= 0 && i < hits.count ] return hits[i].is_header
        return false

    # nearest editable (non-title) row at/after ln, else before it. the cursor
    # never rests on a file-title slot.
    func snap_row [ ln: i32 ] -> i32
        n : i32 [ line_count[] ]
        if [ n <= 0 ] return 0
        r : i32 [ clamp[ ln, 0, n - 1 ] ]
        if [ !row_header[ r ] ] return r
        for [ i: i32 r, i < n, i += 1 ]
            if [ !row_header[ i ] ] return i
        for [ i: i32 r, i >= 0, i -= 1 ]
            if [ !row_header[ i ] ] return i
        return r

    # walk up / down past title slots for arrow navigation. prev_editable may
    # return -1 (nothing above); next_editable may return line_count (nothing below).
    func prev_editable [ ln: i32 ] -> i32
        r : i32 [ ln ]
        while [ r >= 0 && row_header[ r ] ] r -= 1
        return r

    func next_editable [ ln: i32 ] -> i32
        r : i32 [ ln ]
        n : i32 [ line_count[] ]
        while [ r < n && row_header[ r ] ] r += 1
        return r

    # bounds of the contiguous match-row block (one file's group) containing ln.
    # used to keep a results selection from dragging across a file header.
    func group_start [ ln: i32 ] -> i32
        r : i32 [ ln ]
        while [ r > 0 && !row_header[ r - 1 ] ] r -= 1
        return r

    func group_end [ ln: i32 ] -> i32
        r : i32 [ ln ]
        n : i32 [ line_count[] ]
        while [ r < n - 1 && !row_header[ r + 1 ] ] r += 1
        return r

    # drop a match row from the results (the `hits` array is the same object as
    # orbiter's find_hits, so the removal sticks). if it was the file's ONLY match,
    # also drop the 2 header slots so an empty file title doesn't linger.
    func remove_hit [ idx: i32 ]
        if [ !hits || idx < 0 || idx >= hits.count ] return
        if [ row_header[ idx ] ] return
        gs   : i32  [ group_start[ idx ] ]
        only : bool [ gs == group_end[ idx ] ]
        hits.remove[ idx ]
        # header = the 2 slots immediately before the group's first match row
        if [ only && gs >= 2 ]
            hits.remove[ gs - 1 ]
            hits.remove[ gs - 2 ]

    # remove an entire file group — its 2 header slots and all its match rows.
    # idx is any of the group's header slots (the close icon lives on the header).
    func remove_group [ idx: i32 ]
        if [ !hits || idx < 0 || idx >= hits.count || !row_header[ idx ] ] return
        hs : i32 [ idx ]
        while [ hs > 0 && row_header[ hs - 1 ] ] hs -= 1   # first header slot
        n  : i32 [ line_count[] ]
        he : i32 [ hs ]
        while [ he < n && row_header[ he ] ] he += 1       # past the header slots
        while [ he < n && !row_header[ he ] ] he += 1      # past the match rows
        # remove back-to-front so lower indices don't shift under us
        for [ i: i32 he - 1, i >= hs, i -= 1 ]
            hits.remove[ i ]

    # ---- tab rendering: tabs are stored verbatim in the model but DISPLAYED as spaces
    # to the next tab_w stop (the canvas font has no tab glyph → would draw a box). all
    # caret/selection/click math runs in VISUAL columns via these so it lines up. ----

    # visual column of model index c within s (each tab jumps to the next tab_w stop).
    func vis_col [ s: string, c: i32 ] -> i32
        v : i32 [ 0 ]
        for [ i: i32 0, i < c && i < s.count, i += 1 ]
            if [ s[i] == 9 ] v = (v / tab_w + 1) * tab_w
            el               v += 1
        return v

    # inverse of vis_col: the model index nearest visual column vx (for click → caret).
    func model_col [ s: string, vx: i32 ] -> i32
        v : i32 [ 0 ]
        for [ i: i32 0, i < s.count, i += 1 ]
            adv : i32 [ (s[i] == 9) ? ((v / tab_w + 1) * tab_w - v) : 1 ]
            if [ vx < v + (adv + 1) / 2 ] return i
            v += adv
        return s.count

    # s with tabs expanded to spaces (display only — the model keeps the real tabs).
    func display_of [ s: string ] -> string
        ht : bool [ false ]
        for [ i: i32 0, i < s.count, i += 1 ]
            if [ s[i] == 9 ]
                ht = true
                break
        if [ !ht ] return s
        out : string [ '' ]
        v   : i32 [ 0 ]
        for [ i: i32 0, i < s.count, i += 1 ]
            if [ s[i] == 9 ]
                sp : i32 [ (v / tab_w + 1) * tab_w - v ]
                for [ k: i32 0, k < sp, k += 1 ]
                    out = out + ' '
                v += sp
            el
                out = out + s.mid[ i, 1 ]
                v += 1
        return out

    # ---- syntax coloring: silver --format → theme → per-line color regions ----

    # map a Syntax enum kind (the values stamped on tokens in Au's `Syntax`) to a color.
    # this IS the theme — the one place coloring is decided; reformat[] bakes the result
    # into each ColorRegion so re-theming is a matter of re-running this map.
    func fmt_theme [ kind: i32 ] -> rgba
        switch [ kind ]
            case 1                          # keyword
                return rgba['#569cd6']
            case 2, 14                      # type, namespace
                return rgba['#4ec9b0']
            case 4                          # function
                return rgba['#dcdcaa']
            case 5, 6                       # param, property
                return rgba['#9cdcfe']
            case 7                          # number
                return rgba['#b5cea8']
            case 8, 9                       # string, character
                return rgba['#ce9178']
            case 10                         # boolean
                return rgba['#569cd6']
            case 11                         # comment
                return rgba['#6a9955']
            case 13                         # punctuation
                return rgba['#808080']
            case 15                         # constant
                return rgba['#4fc1ff']
            case 16                         # usertoken
                return rgba['#c586c0']
            default                         # none / ident / op
                return rgba['#d4d4d4']

    # read a little-endian u32 from the subprocess pipe (silver writes native LE).
    func fmt_u32 [ fp: handle ] -> u32
        b : local u8 [4]
        n : fread[ ref b[0], 1, 4, fp ]
        if [ n < 4 ] return 0
        return u32[ b[0] ] | (u32[ b[1] ] << 8) | (u32[ b[2] ] << 16) | (u32[ b[3] ] << 24)

    # how many color regions the active buffer has on model line `ml` (0 if none / no map).
    # both arrays are typed members, so their subscripts resolve correctly (a local would not).
    func line_reg_count [ ml: i32 ] -> i32
        if [ !cur_buf || !cur_buf.reg_off ] return 0
        if [ ml < 0 || ml + 1 >= cur_buf.reg_off.count ] return 0
        return cur_buf.reg_off[ ml + 1 ] - cur_buf.reg_off[ ml ]

    # the k-th color region on model line `ml` (caller bounds k via line_reg_count).
    func line_reg [ ml: i32, k: i32 ] -> ColorRegion
        return cur_buf.regions[ cur_buf.reg_off[ ml ] + k ]

    # structural edits shift line indices, so the cached regions no longer line up — drop
    # them; the next map reload rebuilds. (same-line typing keeps them: only mildly stale.)
    func fmt_invalidate []
        if [ cur_buf ]
            cur_buf.regions = null
            cur_buf.reg_off = null

    # read the binary syntax map file silver wrote during its build (--format <mapfile>),
    # distributing per-line ColorRegion arrays into each file's buffer (keyed by the
    # canonical path silver emits). the map is a byproduct of the normal build/watch
    # pipeline — never its own pass — so this just reads the latest file the watcher produced.
    public func load_format [ mapfile: string ]
        fp  : handle [ fopen[ mapfile.chars, 'rb' ] ]
        if [ !fp ] return
        magic : fmt_u32[ fp ]
        ver   : fmt_u32[ fp ]
        if [ magic != u32 0x53464D54 ]
            fclose[ fp ]
            return
        nsec : i32 [ 0 ]
        for [ s: i32 0, s < 100000, s += 1 ]
            tag : fmt_u32[ fp ]
            if [ tag != u32 0xC0DEFACE ] break        # 0 = clean end, anything else = stop
            nsec += 1
            plen : i32 [ fmt_u32[ fp ] ]
            pbuf : array u8 [ alloc: plen + 1 ]
            for [ k: i32 0, k < plen, k += 1 ]
                cb : local u8 [1]
                fread[ ref cb[0], 1, 1, fp ]
                pbuf.push[ cb[0] ]
            pbuf.push[ u8 0 ]
            pstr : ref u8 [ pbuf ]
            ntok : i32 [ fmt_u32[ fp ] ]
            buf  : FileBuf file_cache[ pstr ]
            if [ !buf ]
                buf = FileBuf []
                file_cache[ pstr ] = buf
            buf.regions = array ColorRegion []
            mx : i32 [ 0 ]
            for [ t: i32 0, t < ntok, t += 1 ]
                tl   : i32 [ fmt_u32[ fp ] ]
                tc   : i32 [ fmt_u32[ fp ] ]
                tlen : i32 [ fmt_u32[ fp ] ]
                tk   : i32 [ fmt_u32[ fp ] ]
                buf.regions.push[ ColorRegion [ line: tl, col: tc, len: tlen, color: fmt_theme[ tk ] ] ]
                if [ tl + 1 > mx ] mx = tl + 1
            # tokens arrive in source order (line-sorted), so build the per-line offset index:
            # reg_off[L] = first region index whose line >= L. lines with no tokens get an
            # empty slice (reg_off[L] == reg_off[L+1]).
            buf.reg_off = array i32 []
            ci : i32 [ 0 ]
            for [ L: i32 0, L <= mx, L += 1 ]
                while [ ci < buf.regions.count ]
                    cr : ColorRegion buf.regions[ ci ]
                    if [ cr.line >= L ] break
                    ci += 1
                buf.reg_off.push[ ci ]
        fclose[ fp ]
        mine : i32 [ (cur_buf && cur_buf.regions) ? cur_buf.regions.count : 0 ]
        puts 'format: loaded {nsec} files; this buffer has {mine} colored tokens'

    func line_get [ vr: i32 ] -> string
        if [ show_hits && hits ]
            if [ vr >= 0 && vr < hits.count ] return hits[vr].text
            return ''
        if [ flat_active && flat_rows && vr >= 0 && vr < flat_rows.count ]
            r : VRow flat_rows[ vr ]
            if [ r.src >= 0 ] return lines.value_by_index[ r.src ]
            # virtual field row: indent is applied at draw via row_depth.
            return '# {r.var.name} = {r.var.value}'
        if [ vr >= 0 && vr < lines.count ] return lines.value_by_index[ vr ]
        return ''

    func line_set [ i: i32, val: string ]
        # results mode: edits live on the hit row's text in memory; they reach the
        # source file only on save (Ctrl-S writes the file of the selected line).
        if [ show_hits && hits ]
            hits[i].text = val
            return
        lines.remove[ i ]
        lines.insert_after[ val, i - 1 ]

    # ---- undo / redo (unlimited, kind-coalesced, DELTA-based) -----------------------
    # `hist` is the per-file linked list of EditAction groups; hist_i = how many groups
    # are currently applied (the cursor). groups [0,hist_i) are applied, [hist_i,count)
    # are the redo future. each group stores only its line deltas, so memory is O(edits)
    # not O(file). edits mutate `lines` IN PLACE (line_set/insert/remove), so the per-file
    # `cur_buf.lines` alias never breaks — no list-object replacement on undo/redo.

    # raw line ops (no recording) — used by undo/redo replay.
    func raw_set    [ i: i32, val: string ]    line_set[ i, val ]
    func raw_insert [ i: i32, val: string ]    lines.insert_after[ val, i - 1 ]
    func raw_remove [ i: i32 ]                 lines.remove[ i ]

    # append an op to the open group, opening one lazily (capturing the before-caret and
    # discarding the redo tail) on the first op. consecutive replaces of the SAME line
    # collapse into one op so a typing run is a single delta.
    func rec [ op: LineOp ]
        if [ show_hits ] return
        if [ !cur_group ]
            # opening a fresh group invalidates the redo future — drop it.
            while [ hist && hist.count > hist_i ]
                hist.pop[]
            cur_group = EditAction []
            cur_group.ops = array LineOp []
            cur_group.sl0 = pend_sl0
            cur_group.sc0 = pend_sc0
            hist.push[ cur_group ]
            hist_i = hist.count
        n : i32 [ cur_group.ops.count ]
        if [ op.kind == 0 && n > 0 ]
            last2 : LineOp cur_group.ops[ n - 1 ]
            if [ last2.kind == 0 && last2.at == op.at ]
                last2.after = op.after          # collapse same-line replaces
                touch_hist[]
                return
        cur_group.ops.push[ op ]
        touch_hist[]

    # recording mutators — used by the edit handlers (capture the inverse, then mutate).
    func ed_set [ i: i32, val: string ]
        old : line_get[ i ]
        line_set[ i, val ]
        rec[ LineOp [ at: i, kind: 0, before: old, after: val ] ]

    func ed_insert [ i: i32, val: string ]     # val becomes line i (shifts the rest down)
        lines.insert_after[ val, i - 1 ]
        fmt_invalidate[]
        rec[ LineOp [ at: i, kind: 1, after: val ] ]

    func ed_remove [ i: i32 ]
        old : line_get[ i ]
        lines.remove[ i ]
        fmt_invalidate[]
        rec[ LineOp [ at: i, kind: 2, before: old ] ]

    func apply_undo [ g: EditAction ]
        for [ k: i32 g.ops.count - 1, k >= 0, k -= 1 ]
            op : LineOp g.ops[ k ]
            if [ op.kind == 0 ]
                raw_set[ op.at, op.before ]
            el [ op.kind == 1 ]
                raw_remove[ op.at ]
            el
                raw_insert[ op.at, op.before ]
        sel_line    = g.sl0
        sel_col     = g.sc0
        anchor_line = g.sl0
        anchor_col  = g.sc0

    func apply_redo [ g: EditAction ]
        for [ k: i32 0, k < g.ops.count, k += 1 ]
            op : LineOp g.ops[ k ]
            if [ op.kind == 0 ]
                raw_set[ op.at, op.after ]
            el [ op.kind == 1 ]
                raw_insert[ op.at, op.after ]
            el
                raw_remove[ op.at ]
        sel_line    = g.sl1
        sel_col     = g.sc1
        anchor_line = g.sl1
        anchor_col  = g.sc1

    # point the live history at `buf`'s per-file delta history (created on first use), and
    # restore its cursor. the hist LIST is shared by reference so deltas flow into the
    # per-file store; only hist_i can drift, kept current by touch_hist.
    func swap_history [ buf: FileBuf ]
        if [ cur_buf == buf && buf.hist ] return    # already live → keep the live cursor
        if [ cur_buf && cur_buf != buf ]
            cur_buf.hist_i = hist_i
        if [ !buf.hist ]
            buf.hist   = list EditAction []
            buf.hist_i = 0
        hist      = buf.hist
        hist_i    = buf.hist_i
        cur_group = null
        edit_kind = -1
        edit_cl   = -1
        edit_cc   = -1
        cur_buf   = buf

    # mirror the live cursor into the per-file store so any reload reads it, not a stale
    # value (the hist LIST is already shared by reference; only hist_i drifts).
    func touch_hist []
        if [ cur_buf ] cur_buf.hist_i = hist_i

    # call BEFORE a mutating edit. a kind change or caret jump ends the open group, so the
    # next op starts a new one; same-kind contiguous edits keep appending (coalesce).
    func begin_edit [ kind: i32 ]
        if [ show_hits ] return
        jumped : bool [ sel_line != edit_cl || sel_col != edit_cc ]
        if [ edit_kind != kind || jumped ]
            cur_group = null
            edit_kind = kind
        if [ !cur_group ]
            pend_sl0 = sel_line     # caret before the (upcoming) group's first op
            pend_sc0 = sel_col

    # call AFTER a mutating edit: record the caret for the next jump test, and store it as
    # the open group's after-caret (here, not in rec — rec runs mid-edit, before the
    # handler advances the caret, so capturing there lags the redo caret by one).
    func end_edit []
        edit_cl = sel_line
        edit_cc = sel_col
        if [ cur_group ]
            cur_group.sl1 = sel_line
            cur_group.sc1 = sel_col

    func undo []
        if [ show_hits || !hist ] return
        cur_group = null
        edit_kind = -1
        if [ hist_i <= 0 ] return
        hist_i -= 1
        apply_undo[ hist.value_by_index[ hist_i ] ]
        edit_cl = sel_line
        edit_cc = sel_col
        touch_hist[]
        pristine = false

    func redo []
        if [ show_hits || !hist ] return
        cur_group = null
        edit_kind = -1
        if [ hist_i >= hist.count ] return
        apply_redo[ hist.value_by_index[ hist_i ] ]
        hist_i += 1
        edit_cl = sel_line
        edit_cc = sel_col
        touch_hist[]
        pristine = false

    # write the file associated with the current row. in results mode that's the
    # source file of the selected match line: re-read it, patch every edited match
    # row that belongs to it, and write it back. in normal mode, write `src`.
    func save_current []
        if [ show_hits && hits ]
            if [ sel_line < 0 || sel_line >= hits.count ] return
            target : path [ hits[sel_line].file ]
            if [ !target ] return
            tkey    : '{target}'
            content : string [ target.load[ typeid[string], null ] ]
            if [ !content ] return
            parts : array string [ content.split["\n"] ]
            for [ i: i32 0, i < hits.count, i += 1 ]
                h : FindHit hits[i]
                if [ h.is_header ]
                    continue
                if [ '{h.file}' != tkey ]
                    continue
                idx : i32 [ h.line - 1 ]
                if [ idx >= 0 && idx < parts.count ] parts[idx] = h.text
            out : string [ '' ]
            for [ i: i32 0, i < parts.count, i += 1 ]
                if [ i > 0 ] out = out + '\n'
                out = out + parts[i]
            target.save[ out, null ]
            return
        if [ !src ] return
        out : string [ '' ]
        for [ i: i32 0, i < lines.count, i += 1 ]
            if [ i > 0 ] out = out + '\n'
            out = out + line_get[ i ]
        src.save[ out, null ]

    func load_file []
        if [ !src ] return
        # key by the canonical (realpath) absolute path — the SAME identity silver stamps on
        # each map section — so the buffer the editor renders is the one load_format fills.
        key   : '{src.absolute[]}'
        mtime : i64    [ src.modified_time[] ]
        buf   : FileBuf file_cache[key]
        if [ buf && buf.mtime == mtime ]
            lines = buf.lines
            swap_history[ buf ]   # restore this file's own undo/redo (or seed it)
            return
        content : string src.load[ typeid[string], null ]
        if [ !content ] return
        parts : content.split["\n"]
        new_lines : list string []
        for [ i: i32 0, i < parts.count, i += 1 ]
            new_lines.push[ parts[i] ]
        if [ !buf ]
            buf = FileBuf []
            file_cache[key] = buf
        buf.lines = new_lines
        buf.mtime = mtime
        lines = new_lines
        # freshly (re)loaded content → start this file's history clean.
        buf.hist = null
        swap_history[ buf ]
    func init [ ]
        file_cache = map FileBuf[string] []
        # breakpoints is the shared map injected by orbiter. the editor element
        # is rebuilt every render (a throwaway per frame), and each one's dealloc
        # drops this ref — so hold it here to balance that drop, otherwise the
        # shared map's refcount drifts down and it's freed while still in use.
        if [ breakpoints ] breakpoints.hold[]
        lines = list string []
        lines.push[ '' ]
        load_file[]
        # no file loaded (scratch buffer, or load failed) → give it a transient FileBuf
        # so it still has its own per-buffer undo/redo.
        if [ !cur_buf ]
            sb : FileBuf []
            sb.lines = lines
            swap_history[ sb ]

    # compute the caret line/col from a click/drag point and set sel_line/sel_col.
    func place_cursor [ ev: Event ] -> none
        ele   : (layers) ? (layers['content'] to EditorLayer) : null
        if [ !ele ] return
        # nothing to place the cursor on (e.g. all results removed)
        if [ line_count[] <= 0 ]
            sel_line = -1
            return
        lh    : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
        cw    : f32 [ (cw_cache > 0.0) ? cw_cache : 8.0 ]
        # find_target already folds scroll.y into mouse.pos.y (trinity.ag), so the row
        # math must NOT re-add it — doing so put clicks off by the scroll amount once
        # scrolled. -gutter_w skips the gutter; mouse.pos.y is content-space already.
        rel_y : f32 [ ev.mouse.pos.y - ele.bounds.y ]
        # negative = the click landed above the first line (in the title band) — not a
        # content click, so don't place the cursor (clicking the title's '-' was
        # selecting line 0).
        if [ rel_y < 0.0 ] return
        rel_x : f32 [ ev.mouse.pos.x - ele.bounds.x - gutter_w ]
        # rel_y/lh IS the row index — virtual tree rows are real lines in the flat model.
        raw   : i32 [ clamp [ rel_y / lh, 0, line_count[] - 1 ] ]
        ln    : i32 [ snap_row[ raw ] ]
        # any selection EXTEND (drag, or shift-click) stays inside the anchor's
        # group — you can't reach across a file header into another file's matches.
        # (a plain click sets a fresh anchor and is unconstrained.)
        if [ show_hits && (dragging || ev.key.shift) ]
            ln = clamp[ ln, group_start[ anchor_line ], group_end[ anchor_line ] ]
        # virtual rows render indented by depth, so the click-x is past x0 by that
        # much — subtract it before mapping to a column. map the visual column the click
        # landed on back to a model column (tabs occupy multiple visual columns).
        vx    : f32 [ round[ (rel_x - row_indent[ ln ] + scroll.x) / cw ] ]
        cl    : i32 [ model_col[ line_get[ ln ], i32[ vx ] ] ]
        sel_line = ln
        sel_col  = cl

    func on_press [ ev: Event ]
        # debug-control buttons in this editor's dbg slide-out — same actions as the
        # keyboard (c/s/i/o). consume here so the press doesn't fall through to the caret.
        if [ debugger ]
            if [ ev.target.id == 'dbg_continue' ]
                if [ debugger.running ] debugger.pause[]
                el                      debugger.cont[]
                ev.no_default = true
                return
            if [ ev.target.id == 'dbg_step_over' ]
                debugger.step_over[]
                ev.no_default = true
                return
            if [ ev.target.id == 'dbg_step_into' ]
                debugger.step_into[]
                ev.no_default = true
                return
            if [ ev.target.id == 'dbg_step_out' ]
                debugger.step_out[]
                ev.no_default = true
                return
        # only the editor's own content responds to presses. a click that targets a
        # child element (the dbg sub-column, its buttons/panels, the title) belongs to
        # that element / the app — the editor must not steal it for caret/selection.
        # when split, the dbg column is outside the editor's content region.
        if [ ev.target != a ]
            return
        # a double-click (two presses within 350ms) while debug-locked re-arms editing
        # for this pane — the simple "I actually want to edit during a run" gesture.
        now : i64 [ epoch_micros[] ]
        if [ debug_running && !edit_armed && (now - last_press_us) < 350000 ]
            edit_armed = true
        last_press_us = now
        ele   : (layers) ? (layers['content'] to EditorLayer) : null
        rel_x : f32 [ (ele) ? ev.mouse.pos.x - ele.bounds.x : 0.0 ]
        # the dbg sub-column overlays the editor's right edge while open — a press in
        # that band belongs to the dbg panel (its buttons/panels), never the editor
        # content. bail geometrically (like the pin column) so it works even if
        # find_target mis-routed the press back to the editor (e.g. scroll fold).
        dbg_el : element elements['dbg']
        if [ ele && dbg_el && dbg_el.bounds && rel_x > ele.bounds.w - dbg_el.bounds.w ]
            return
        # click to expand/collapse a node in the inline debug tree: a virtual object
        # field row toggles itself (anywhere); a base line's object annotation toggles
        # when clicked past the code text (the [+]). flipping `expanded` rebuilds the
        # flat model next frame. scalar rows fall through to normal caret/selection.
        if [ debug_vars ]
            lhp : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
            cwp : f32 [ (cw_cache > 0.0) ? cw_cache : 8.0 ]
            # mouse.pos.y is already scroll-folded by find_target — don't re-add scroll.
            ry  : f32 [ ev.mouse.pos.y - ele.bounds.y ]
            if [ ry >= 0.0 ]
                cln : i32      [ clamp[ ry / lhp, 0, line_count[] - 1 ] ]
                rv  : variable row_var[ cln ]
                if [ rv ]
                    if [ var_expandable[ rv ] ]
                        rv.expanded = !rv.expanded
                        pristine = false
                        ux.will_animate = true
                        return
                el
                    bk : i32 [ base_var_at[ row_src[ cln ] ] ]
                    if [ bk >= 0 ]
                        bv : variable debug_vars[ bk ]
                        if [ var_expandable[ bv ] ]
                            axp : f32 [ gutter_w + f32[ line_get[ cln ].count ] * cwp + 24.0 ]
                            if [ rel_x > axp ]
                                bv.expanded = !bv.expanded
                                pristine = false
                                ux.will_animate = true
                                return
        # scrollbar: a press in the rightmost grab zone grabs the thumb and scrolls.
        # checked before the pin column so the bar (the very right edge) wins there.
        sb : ScrollLayer (layers) ? (layers['scrollbar'] to ScrollLayer) : null
        grab : f32 [ (sb && sb.thumb_w > 0.0) ? sb.thumb_w * 2.0 + 8.0 : 16.0 ]
        if [ ele && sb && sb.scroll_max > 0.0 && rel_x > ele.bounds.w - grab ]
            # find_target folds e.scroll.y into mouse.pos.y; the thumb is screen-space
            # so subtract it to get the on-screen (track-relative) click position.
            my : f32 [ ev.mouse.pos.y - ele.bounds.y - scroll.y ]
            sb.grab_at[ my ]
            sy : f32 [ sb.drag_to[ my ] ]
            if [ sy >= 0.0 ]
                scroll.y        = sy
                scroll_dragging = true
                sb.active       = true
                pristine        = false
                ux.will_animate = true
            return
        # a click in the pin column (right 144, present while searching) is a pin
        # click handled by the app — don't move the cursor or start a selection.
        if [ ele && elements['pins'] && rel_x > ele.bounds.w - 144.0 ]
            return
        # gutter click: in results it's the per-row remove control (close icon shown
        # on hover); in normal file editing it toggles a breakpoint on the line.
        if [ ele && rel_x < gutter_w ]
            lh    : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
            # mouse.pos.y is already scroll-folded by find_target — don't re-add scroll.
            rel_y : f32 [ ev.mouse.pos.y - ele.bounds.y ]
            vrl   : i32 [ clamp [ rel_y / lh, 0, line_count[] - 1 ] ]
            # a header's gutter click removes the whole file group; a match row's
            # removes just that line. (both only in results.)
            if [ row_header[ vrl ] ]
                if [ show_hits && hits ]
                    remove_group[ vrl ]
                    pristine = false
                return
            if [ show_hits && hits ]
                remove_hit[ vrl ]
                pristine = false
                return
            # a virtual debug field row has no gutter — no breakpoint toggle on it.
            if [ row_var[ vrl ] ] return
            ln    : i32 [ row_src[ vrl ] ]
            # normal mode: toggle a plain breakpoint on the line. toggle-off REMOVES
            # the key (not set-null) so the map count drops — that's what orbiter's
            # save watcher keys off, and it keeps dead keys out of the saved state.
            key   : '{src}:{ln + 1}'
            cur   : breakpoints[key]
            if [ cur ]
                breakpoints.rm[ key ]
            el
                breakpoints[key] = string[]
            pristine = false
            return
        if [ !ev.key.shift ]
            place_cursor[ ev ]
            anchor_line = sel_line
            anchor_col  = sel_col
        el
            place_cursor[ ev ]
        dragging = true
        pristine = false

    func on_move [ ev: Event ]
        ele : (layers) ? (layers['content'] to EditorLayer) : null
        if [ scroll_dragging && ele ]
            sb : ScrollLayer (layers) ? (layers['scrollbar'] to ScrollLayer) : null
            if [ sb ]
                # subtract scroll.y (folded in by find_target) — thumb is screen-space
                sy : f32 [ sb.drag_to[ ev.mouse.pos.y - ele.bounds.y - scroll.y ] ]
                if [ sy >= 0.0 ] scroll.y = sy
            pristine = false
            ux.will_animate = true
            return
        if [ dragging ]
            place_cursor[ ev ]
            pristine = false
            return
        # hover line for the gutter highlight (no press); also track whether the
        # mouse is over the gutter column so the close icon only shows there.
        if [ !ele ] return
        lh    : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
        # same coordinate math as place_cursor (find_target folds scroll into mouse.pos.y).
        rel_y : f32 [ ev.mouse.pos.y - ele.bounds.y ]
        rel_x : f32 [ ev.mouse.pos.x - ele.bounds.x ]
        hl    : i32  [ clamp [ rel_y / lh, 0, line_count[] - 1 ] ]   # visual row = flat row
        hg    : bool [ rel_x >= 0.0 && rel_x < gutter_w ]
        if [ rel_y < 0 ]
            hl  = -1
            hg = false
        # annotation hover (for the warm glow): mouse past the code text on an
        # expandable object's decl (base) line — virtual field rows don't glow.
        ha : i32 [ -1 ]
        if [ hl >= 0 && row_var[ hl ] == null ]
            bkh : i32 [ base_var_at[ row_src[ hl ] ] ]
            if [ bkh >= 0 && var_expandable[ debug_vars[ bkh ] ] ]
                cwh : f32 [ (cw_cache > 0.0) ? cw_cache : 8.0 ]
                axh : f32 [ gutter_w + f32[ line_get[ hl ].count ] * cwh + 24.0 ]
                if [ rel_x > axh ] ha = hl
        if [ ha != hover_ann ]
            hover_ann = ha
            pristine = false
            ux.will_animate = true
        # only repaint on an actual hover change (row / gutter). the scrollbar's
        # proximity tracking is owned by ScrollLayer, which sustains frames while the
        # cursor is in its zone — so the editor doesn't blanket-request frames here.
        if [ hl != hover_line || hg != hover_gutter ]
            hover_line   = hl
            hover_gutter = hg
            pristine = false
            ux.will_animate = true

    func on_leave [ ev: Event ]
        if [ hover_line != -1 || hover_gutter || hover_ann != -1 ]
            hover_line   = -1
            hover_gutter = false
            hover_ann    = -1
            pristine = false

    func on_release [ ev: Event ]
        dragging        = false
        scroll_dragging = false
        sb : ScrollLayer (layers) ? (layers['scrollbar'] to ScrollLayer) : null
        if [ sb ]
            sb.active = false
            ux.will_animate = true

    func on_wheel [ ev: Event ]
        lh : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
        # shift + wheel scrolls horizontally (no horizontal scrollbar — the left-edge
        # fade is the only indicator). otherwise vertical.
        if [ ev.key.shift ]
            cw : f32 [ (cw_cache > 0.0) ? cw_cache : 8.0 ]
            scroll.x = scroll.x - ev.mouse.wheel_delta.y * cw * 3.0
            if [ scroll.x < 0.0 ] scroll.x = 0.0
        el
            scroll.y = scroll.y - ev.mouse.wheel_delta.y * lh * 3.0
        pristine = false
        ux.will_animate = true

    # scroll so the caret line is inside the viewport — call after any edit/cursor move that
    # can push the caret off-screen (Enter past the bottom, arrows, paste). render re-clamps.
    func ensure_caret_visible []
        if [ sel_line < 0 ] return
        ele : (layers) ? (layers['content'] to EditorLayer) : null
        vh  : f32 [ (ele && ele.bounds) ? ele.bounds.h : 400.0 ]
        lh  : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
        top : f32 [ sel_line ] * lh
        bot : top + lh
        if [ bot > scroll.y + vh ] scroll.y = bot - vh
        if [ top < scroll.y ]      scroll.y = top
        pristine = false
        ux.will_animate = true

    func on_char [ ev: Event ]
        # debug-locked: swallow text so letters (s/n/c…) stay free for debugger keys
        if [ debug_running && !edit_armed ] return
        # tree open: visual rows ≠ base line indices, so edits would corrupt `lines`.
        # editing resumes once the inline debug tree collapses (debug_vars cleared).
        if [ flat_active ] return
        if [ line_count[] <= 0 ] return
        if [ sel_line < 0 ] sel_line = 0
        if [ sel_col  < 0 ] sel_col  = 0
        ch   : string [ ev.key.text ]
        # ignore control chars (tab/newline/etc.) — they're not insertable text and a
        # literal tab would render as a .notdef box. (>=0 lets UTF-8 lead bytes through,
        # which are negative as signed chars.) Tab is handled as a soft tab in on_key.
        if [ ch.count == 0 || (ch[0] >= 0 && ch[0] < 32) ] return
        # one undo group per typing run (coalesced) — snapshot taken before the run.
        begin_edit[ 0 ]
        # typing replaces an active selection (delete it first, then insert the char)
        delete_selection[]
        row  : i32 [ sel_line ]
        # file-title slots are not editable
        if [ row_header[ row ] ] return
        col  : i32 [ sel_col ]
        line : line_get[ row ]
        ed_set[ row, line.mid[0, col] + ch + line.mid[col, line.count - col] ]
        sel_col += 1
        # collapse the selection to the caret — typing isn't a selection gesture, so the
        # anchor must follow the caret (else each char extends a highlight over the text).
        anchor_line = sel_line
        anchor_col  = sel_col
        end_edit[]
        ensure_caret_visible[]
        pristine = false

    # the highlighted text (anchor→caret), as one string with '\n' between rows.
    # empty when there's no selection. uses the live line model (file or results list).
    func selected_text [] -> string
        if [ sel_line < 0 ] return ''
        al : i32 [ anchor_line ]
        ac : i32 [ anchor_col ]
        sl : i32 [ sel_line ]
        sc : i32 [ sel_col ]
        before : bool [ al < sl || (al == sl && ac <= sc) ]
        s_line : i32 [ (before) ? al : sl ]
        s_col  : i32 [ (before) ? ac : sc ]
        e_line : i32 [ (before) ? sl : al ]
        e_col  : i32 [ (before) ? sc : ac ]
        out : string ''
        for [ li: i32 s_line, li <= e_line, li += 1 ]
            ln : string line_get[ li ]
            c0 : i32 [ (li == s_line) ? s_col : 0 ]
            c1 : i32 [ (li == e_line) ? e_col : ln.count ]
            if [ c0 < 0 ] c0 = 0
            if [ c1 > ln.count ] c1 = ln.count
            if [ c1 > c0 ] out = out + ln.mid[ c0, c1 - c0 ]
            if [ li < e_line ] out = out + '\n'
        return out

    # is there a non-empty selection (anchor differs from the caret)?
    func has_selection [] -> bool
        return sel_line >= 0 && (anchor_line != sel_line || anchor_col != sel_col)

    # delete the selected span and collapse the caret to its start. returns true when
    # something was removed (so callers can replace it with typed text / a newline, or
    # skip the plain backspace). a no-op in results mode (structural edits disallowed).
    func delete_selection [] -> bool
        if [ !has_selection[] || show_hits ] return false
        before : bool [ anchor_line < sel_line || (anchor_line == sel_line && anchor_col <= sel_col) ]
        s_line : i32 [ (before) ? anchor_line : sel_line ]
        s_col  : i32 [ (before) ? anchor_col  : sel_col ]
        e_line : i32 [ (before) ? sel_line : anchor_line ]
        e_col  : i32 [ (before) ? sel_col  : anchor_col ]
        if [ s_line == e_line ]
            ln : line_get[ s_line ]
            ed_set[ s_line, ln.mid[0, s_col] + ln.mid[e_col, ln.count - e_col] ]
        el
            # merge the start prefix with the end suffix, then drop the interior+end rows
            # bottom-up so indices don't shift under us. compute the merge BEFORE any
            # removal (line_get is a non-holding borrow).
            sline  : line_get[ s_line ]
            eline  : line_get[ e_line ]
            merged : sline.mid[0, s_col] + eline.mid[e_col, eline.count - e_col]
            for [ r: i32 e_line, r > s_line, r -= 1 ]
                ed_remove[ r ]
            ed_set[ s_line, merged ]
        sel_line    = s_line
        sel_col     = s_col
        anchor_line = s_line
        anchor_col  = s_col
        pristine = false
        return true

    func on_key [ ev: Event ]
        if [ !ev.key.state ] return
        # ignore modifier keys (shift/ctrl/alt/super, GLFW 340-347): they must not touch
        # the selection. a modifier's own keydown reports shift=0, so without this it
        # would fall through to the trailing "!shift collapses selection" and clear it.
        mk : i32 [ i32 ev.key.unicode ]
        if [ mk >= 340 && mk <= 347 ] return
        # active (non-edit) state: the keyboard drives the debugger, not editing —
        #   c = continue, s = step over, i = step into, o = step out, esc = edit
        # esc / double-click / the 'active' button all re-arm editing.
        if [ debug_running && !edit_armed ]
            k : i32 [ ev.key.unicode ]
            if [ k == 256 ]    # Key.Escape — leave active mode, back to editing
                edit_armed = true
                return
            if [ debugger ]
                if [ k == 67 ] debugger.cont[]        # Key.C
                if [ k == 83 ] debugger.step_over[]   # Key.S
                if [ k == 73 ] debugger.step_into[]   # Key.I
                if [ k == 79 ] debugger.step_out[]    # Key.O
            return

        # save: Ctrl/Cmd-S writes the file of the selected line. in results mode
        # that's the source file the match came from (its edited lines patched in).
        if [ (ev.key.ctrl || ev.key.meta) && ev.key.unicode == 83 ]    # Key.S
            save_current[]
            pristine = false
            return

        # copy: Ctrl/Cmd-C copies the highlighted text to the system clipboard.
        if [ (ev.key.ctrl || ev.key.meta) && ev.key.unicode == 67 ]    # Key.C
            txt : string selected_text[]
            if [ txt.count > 0 && ux ] ux.set_clipboard[ txt ]
            return

        # undo / redo: Ctrl/Cmd-Z (Shift = redo); Ctrl/Cmd-Y also redoes.
        if [ (ev.key.ctrl || ev.key.meta) && ev.key.unicode == 90 ]    # Key.Z
            if [ ev.key.shift ]
                redo[]
            el
                undo[]
            ux.will_animate = true
            return
        if [ (ev.key.ctrl || ev.key.meta) && ev.key.unicode == 89 ]    # Key.Y
            redo[]
            ux.will_animate = true
            return

        if [ line_count[] <= 0 ] return
        if [ sel_line < 0 ] sel_line = 0
        if [ sel_col  < 0 ] sel_col  = 0
        row  : i32 [ sel_line ]
        col  : i32 [ sel_col ]
        key  : i32 [ ev.key.unicode ]

        # page up / down: move the cursor and scroll by half a viewport
        # (visible lines / 2). scroll.y is re-clamped in draw.
        if [ key == 266 || key == 267 ]    # Key.PageUp / Key.PageDown
            ele  : (layers) ? (layers['content'] to EditorLayer) : null
            vh   : f32 [ (ele && ele.bounds) ? ele.bounds.h : 400.0 ]
            lh   : f32 [ (lh_cache > 0.0) ? lh_cache : 22.0 ]
            half2 : i32 [ i32[ (vh / lh) * 0.5 ] ]
            if [ half2 < 1 ] half2 = 1
            if [ key == 266 ]    # Key.PageUp
                sel_line = snap_row[ clamp[ sel_line - half2, 0, line_count[] - 1 ] ]
                scroll.y = scroll.y - f32[ half2 ] * lh
            el
                sel_line = snap_row[ clamp[ sel_line + half2, 0, line_count[] - 1 ] ]
                scroll.y = scroll.y + f32[ half2 ] * lh
            sel_col  = clamp[ sel_col, 0, line_get[ sel_line ].count ]
            # plain page move collapses the selection to the cursor (no highlight);
            # shift+page extends it, like a normal editor.
            if [ !ev.key.shift ]
                anchor_line = sel_line
                anchor_col  = sel_col
            pristine = false
            return

        # title slots can't be split / merged / typed into; nor can anything while the
        # inline debug tree is open (visual rows ≠ base line indices — would corrupt).
        edits_locked : bool [ row_header[ row ] || flat_active ]

        if [ key == 257 ]    # Key.Enter
            # results rows can't be split: a new row would have no source line
            if [ show_hits || edits_locked ] return
            # line-op group (kind 1): coalesces a run of Enters, breaks from a typing run.
            begin_edit[ 1 ]
            # a selection is replaced by the newline (delete it, then split at the caret)
            if [ delete_selection[] ]
                row = sel_line
                col = sel_col
            line  : line_get[ row    ]
            left  : line.mid[ 0, col ]
            right : line.mid[col, line.count - col]
            ed_set[ row, left ]
            ed_insert[ row + 1, right ]
            sel_line += 1
            sel_col   = 0
            end_edit[]

        el [ key == 258 ]    # Key.Tab — insert a real tab. tabs are the primary indent;
            # they're rendered as tab_w spaces (display_of/vis_col) so no .notdef box.
            if [ show_hits || edits_locked ] return
            begin_edit[ 0 ]   # a tab is an inserted char — coalesces with the typing run
            if [ delete_selection[] ]
                row = sel_line
                col = sel_col
            line : line_get[ row ]
            ed_set[ row, line.mid[0, col] + '\t' + line.mid[col, line.count - col] ]
            sel_col += 1
            end_edit[]

        el [ key == 259 ]    # Key.Backspace
            if [ edits_locked ] return
            begin_edit[ 2 ]   # delete group (kind 2): coalesces a run of backspaces
            # a non-empty selection is erased wholesale (not a single char in front of it)
            if [ delete_selection[] ]
                pristine = false
            el [ col > 0 ]
                line : line_get[ row ]
                ed_set[ row, line.mid[0, col - 1] + line.mid[col, line.count - col] ]
                sel_col -= 1
            # joining rows would drop a source line, so it's results-mode-disabled
            el [ row > 0 && !show_hits ]
                prev : line_get[ row - 1 ]
                sel_col  = prev.count
                ed_set[ row - 1, prev + line_get[ row ] ]
                ed_remove[ row ]
                sel_line -= 1
            end_edit[]

        el [ key == 265 ]    # Key.Up
            np : i32 [ prev_editable[ sel_line - 1 ] ]
            if [ np >= 0 ]
                sel_line = np
                sel_col = clamp[ sel_col, 0, line_get[ sel_line ].count ]

        el [ key == 264 ]    # Key.Down
            np : i32 [ next_editable[ sel_line + 1 ] ]
            if [ np < line_count[] ]
                sel_line = np
                sel_col = clamp[ sel_col, 0, line_get[ sel_line ].count ]

        el [ key == 263 ]    # Key.Left
            if [ col > 0 ]
                sel_col -= 1
            el [ row > 0 ]
                np : i32 [ prev_editable[ row - 1 ] ]
                if [ np >= 0 ]
                    sel_line = np
                    sel_col = line_get[ np ].count

        el [ key == 262 ]    # Key.Right
            if [ col < line_get[ row ].count ]
                sel_col += 1
            el [ row < line_count[] - 1 ]
                np : i32 [ next_editable[ row + 1 ] ]
                if [ np < line_count[] ]
                    sel_line = np
                    sel_col = 0

        # plain edits (Enter/Backspace) and cursor moves collapse the selection to the
        # caret; holding shift extends it instead (shift+arrow selects, like any editor).
        if [ !ev.key.shift ]
            anchor_line = sel_line
            anchor_col  = sel_col
        ensure_caret_visible[]
        pristine = false

    public func render [] -> Elements
        return null