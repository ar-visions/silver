import AcademySoftwareFoundation:Imath/c0396a0 
    -I{install}/include/Imath
    -I{install}/include/OpenEXR

import opencv:opencv/1c39583
    -I{install}/include/opencv4
    -lopencv_core -lopencv_imgproc

import AcademySoftwareFoundation:openexr/0b83825
    -DBUILD_SHARED_LIBS=ON
    -lOpenEXR -lOpenEXRCore -lOpenEXRUtil

import madler:zlib/51b7f2a <zlib.h>
    -DCMAKE_POLICY_VERSION_MINIMUM=3.5
    -lz

import glennrp:libpng/07b8803 <png.h>
    -lpng

import <string.h>
import vec


enum Join
    none           : 0
    miter           : 1
    round           : 2
    bevel           : 3

enum Pixel
    none            : 0
    rgba8           : 1
    rgb8            : 2
    rgbf32          : 3
    u8              : 4
    rgbaf32         : 5
    f32             : 6

enum Filter
    none            : 0
    nearest         : 1
    bilinear        : 3
    trilinear       : 4
    low             : 5
    med             : 6
    high            : 7

enum Surface
    none            : 0
    color           : 1
    normal          : 2
    emission        : 3
    rough           : 4
    metal           : 5
    height          : 6
    ao              : 7
    ior             : 8
    environment     : 9
    iris            : 10
    iris_melanin    : 11
    iris_disp_a     : 12
    iris_disp_b     : 13
    iris_disp_c     : 14
    sclera_disp     : 15

enum Cap
    none            : 0
    round           : 1
    square          : 2

enum Variant
    none            : 0
    small_caps      : 1
    mono            : 2

class Font
    uri         : path
    bold        : bool
    italic      : bool
    underline   : bool
    var         : Variant
    size        : f32
    kerning     : f32
    res         : handle
    tf          : handle
    
    intern static font_manager_init    : hook
    intern static font_manager_dealloc : hook

    static func set_font_manager[ init:hook, dealloc:hook ] 
        font_manager_init    = init
        font_manager_dealloc = dealloc

    func dealloc[] 
        font_manager_dealloc a

    func copy[ ] -> Font
        b : super.copy[]
        font_manager_init [b] 
        return b

    func init[] 
        font_manager_init [a]

    construct [ u:path ]
        uri = u


class Image
    uri:            path
    surface:        Surface
    format:         Pixel
    pixel_size:     i32 0
    width:          i32 0
    height:         i32 0
    channels:       i32 0
    source:         Au
    filter:         Filter
    user:           Au
    res2:           handle
    res_dealloc:    hook
    manual res_bits: ARef
    manual pixels:  @u8

    construct [ i:symbol ]
        uri = path i
    
    construct [ i:cstr ]
        uri = path i
    
    construct [ i:string ]
        uri = path i

    func exr [ path ] -> i32

    func init    [ ] 

    func dealloc [ ]  # some comment
        info : header[ a ]
        if [ res_dealloc ] res_dealloc [ a ]
        # zero-copy pixels (res_bits) rebind the header data to foreign
        # memory (a mapped buffer); the release hook owns it — clear the
        # pointer so the base dealloc never drops non-Au memory
        if [ res_bits ] info.data = null

    func copy[ ] -> Image
        res: Image[ width:1, height:2, format:format, surface:surface ]
        memcpy res.vdata[], vdata[], byte_count[]
        return res

    # copy a sub-rectangle into a fresh Image (clamped to the source bounds)
    func crop[ cx:i32, cy:i32, cw:i32, ch:i32 ] -> Image
        check width > 0 && height > 0, "null Image given to crop"
        x0 : i32 [ (cx < 0) ? 0 : cx ]
        y0 : i32 [ (cy < 0) ? 0 : cy ]
        x1 : i32 [ cx + cw ]
        y1 : i32 [ cy + ch ]
        if [ x1 > width  ] x1 = width
        if [ y1 > height ] y1 = height
        ow : i32 [ x1 - x0 ]
        oh : i32 [ y1 - y0 ]
        check ow > 0 && oh > 0, "empty crop"
        output : Image
            width:  ow,
            height: oh,
            :format, :surface, :channels
        ps  : i32 [ pixel_size ]
        src : @u8 vdata[]
        dst : @u8 output.vdata[]
        for [ ry: i32 0, ry < oh, ry += 1 ]
            so : i64 [ (i64[ y0 + ry ] * i64[ width ] + i64[ x0 ]) * i64[ ps ] ]
            df : i64 [ i64[ ry ] * i64[ ow ] * i64[ ps ] ]
            memcpy @dst[ df ], @src[ so ], i64[ ow * ps ]
        return output

    # horizontal mirror into a fresh Image — converts a render's mirror-view
    # to real camera handedness (subject's left on the image's right)
    func mirror_x[ ] -> Image
        check width > 0 && height > 0, "null Image given to mirror_x"
        output : Image
            width:  width,
            height: height,
            :format, :surface, :channels
        ps  : i32 [ pixel_size ]
        src : @u8 vdata[]
        dst : @u8 output.vdata[]
        for [ ry: i32 0, ry < height, ry += 1 ]
            ro : i64 [ i64[ ry ] * i64[ width ] * i64[ ps ] ]
            for [ rx: i32 0, rx < width, rx += 1 ]
                so : i64 [ ro + i64[ rx ] * i64[ ps ] ]
                df : i64 [ ro + i64[ width - 1 - rx ] * i64[ ps ] ]
                memcpy @dst[ df ], @src[ so ], i64[ ps ]
        return output

    # single-channel copy (first channel, no averaging): mono sensors save
    # a quarter of the bytes and encode ~4x faster
    func gray[] -> Image
        check width > 0 && height > 0, "null Image given to gray"
        if [ channels == 1 ] return copy[]
        output : Image
            width:    width,
            height:   height,
            format:   Pixel.u8,
            channels: 1,
            :surface
        ps  : i32 [ pixel_size ]
        src : @u8 vdata[]
        dst : @u8 output.vdata[]
        n : i32 [ width * height ]
        for [ i: i32 0, i < n, i += 1 ]
            si : i64 [ i64[ i ] * i64[ ps ] ]
            dst[ i ] = src[ si ]
        return output

    # box-average reduction by an integer factor: each output pixel is the
    # plain mean of its f x f source block (u8 channels). the cheapest
    # correct filter — supersampled renders reduce through this.
    func reduce_box[ f: i32 ] -> Image
        check width > 0 && height > 0, "null Image given to reduce_box"
        check f > 0, "invalid reduce_box factor"
        if [ f == 1 ] return copy[]
        ow : i32 [ width / f ]
        oh : i32 [ height / f ]
        check ow > 0 && oh > 0, "reduce_box factor exceeds image size"
        output : Image
            width:  ow,
            height: oh,
            :format, :surface, :channels
        ps  : i32 [ pixel_size ]
        src : @u8 vdata[]
        dst : @u8 output.vdata[]
        area : i32 [ f * f ]
        for [ ry: i32 0, ry < oh, ry += 1 ]
            for [ rx: i32 0, rx < ow, rx += 1 ]
                for [ c: i32 0, c < ps, c += 1 ]
                    acc : i32 [ 0 ]
                    for [ by: i32 0, by < f, by += 1 ]
                        so : i64 [ (i64[ ry * f + by ] * i64[ width ] + i64[ rx * f ]) * i64[ ps ] + i64[ c ] ]
                        for [ bx: i32 0, bx < f, bx += 1 ]
                            si : i64 [ so + i64[ bx * ps ] ]
                            acc += i32[ src[ si ] ]
                    di : i64 [ (i64[ ry ] * i64[ ow ] + i64[ rx ]) * i64[ ps ] + i64[ c ] ]
                    av : i32 [ acc / area ]
                    dst[ di ] = u8[ av ]
        return output

    func resize[ out_w:i32, out_h:i32 ] -> Image
        check width > 0 && height > 0, "null Image given to resize"
        check out_w > 0 && out_h  > 0, "invalid size"
        
        if [ width == out_w && height == out_h ]
            return copy[]
        
        scale_x : float width / out_w
        scale_y : float height / out_h

        output  : Image
            width    :out_w,
            height   :out_h,
            :format, :surface, :channels

        src  : @u8 vdata[]
        src2 : @u8 vdata[]
        src3 : @u8 vdata[]
        dst  : @u8 output.vdata[]

        opencv_resize_area
            src,      dst,   format == Pixel.rgbaf32,
            width,    height,
            channels, out_w, out_h
        
        return output

    func gaussian[ amount:float ] -> Image
        if [ amount < 0.1f ]
            return copy[]
        
        output : Image
            :width,  :height,
            :format, :surface, :channels

        src : @u8 vdata[]
        dst : @u8 output.vdata[]

        opencv_gaussian
            src, dst, format == Pixel.rgbaf32,
            width, height, channels, amount
        
        return output


    # save gray or colored png based on channel count; if we want conversion we may just use methods to alter an object
    func png [ image_uri:path ] -> i32
        e       : image_uri.ext[]
        success : 1

        if [ e == "png" ]
            # lets support libpng only, so only "png" ext from path
            expect file : fopen [ image_uri, "wb" ],
                'could not open file for writing: {image_uri}'

            png2 : png_create_write_struct[ PNG_LIBPNG_VER_STRING, null, null, null ]
            check png2, "could not create PNG write struct"

            info : png_create_info_struct [ png2 ]
            check info, "could not create PNG info struct"

            if [ !setjmp[ png_jmpbuf[ png2 ] ] ]
                png_init_io png2, file
                # fast zlib: encode-bound batch exports (IR frames) go ~3x
                # quicker for a few percent of file size
                png_set_compression_level png2, 1

                ctype2 : i32 [ PNG_COLOR_TYPE_RGBA ]
                if [ channels == 1 ] ctype2 = PNG_COLOR_TYPE_GRAY
                if [ channels == 3 ] ctype2 = PNG_COLOR_TYPE_RGB
                png_set_IHDR
                    png2, info, width, height,
                    8, ctype2, PNG_INTERLACE_NONE,
                    PNG_COMPRESSION_TYPE_DEFAULT, PNG_FILTER_TYPE_DEFAULT

                png_write_info png2, info
                rows : new png_bytep [ sizeof png_bytep * height ]
                data2 : @u8 vdata[]
                for [ y : 0, y < height, y += 1 ]
                    rows[y] = @data2 [ y * width * channels ]

                png_write_image png2, rows
                png_write_end   png2, null
            el
                success = 0
            
            png_destroy_write_struct @png2, @info
            fclose file

        el
            check false, 'unsupported format: {e}'
            success = 0
        
        return success


    func len[ ] -> sz
        return height

    func byte_count[ ] -> sz
        return width * height * pixel_size

    func get[ y:num ] -> Au
        row : @u8 vdata[]
        return @row [ pixel_size * width * y ]


# all 4 opencv functions implemented in img.cc
func opencv_resize_area[@u8, @u8, int, int, int, int, int, int] 

func opencv_gaussian[@u8, @u8, int, int, int, int, float] 

func opencv_gaussian_fast[@u8, @u8, int, int, int, int , float] 

func opencv_blur_equirect[@u8, int, int] 
