			case 0xCA  # MOV1 mem.bit, C
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				r      : u8  [ spc_r[maddr] ]
