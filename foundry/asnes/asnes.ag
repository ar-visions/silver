				spc.pc  = addr

			case 0xC1  # TCALL 12
				addr : u16 [ spc_r[0xFFC6] | (spc_r[0xFFC7] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0xD1  # TCALL 13
				addr : u16 [ spc_r[0xFFC4] | (spc_r[0xFFC5] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0xE1  # TCALL 14
				addr : u16 [ spc_r[0xFFC2] | (spc_r[0xFFC3] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0xF1  # TCALL 15
				addr : u16 [ spc_r[0xFFC0] | (spc_r[0xFFC1] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x6F  # RET
				spc.sp += 1
				lo     : u8 [ spc_r[ 0x0100 + u16[spc.sp] ] ]
				spc.sp += 1
				hi     : u8 [ spc_r[ 0x0100 + u16[spc.sp] ] ]
				spc.pc  = lo | (hi << 8)

			case 0x7F  # RETI
				spc.sp  += 1
				spc.psw  = spc_r[ 0x0100 + u16[spc.sp] ]
				spc.sp  += 1
				lo       : u8 [ spc_r[ 0x0100 + u16[spc.sp] ] ]
				spc.sp  += 1
				hi       : u8 [ spc_r[ 0x0100 + u16[spc.sp] ] ]
				spc.pc    = lo | (hi << 8)

			case 0x2D  # PUSH A
				spc_w[ 0x0100 + spc.sp, spc.a ]
				spc.sp -= 1

			case 0x4D  # PUSH X
				spc_w[ 0x0100 + spc.sp, spc.x ]
				spc.sp -= 1

			case 0x6D  # PUSH Y
				spc_w[ 0x0100 + spc.sp, spc.y ]
				spc.sp -= 1

			case 0x0D  # PUSH PSW
				spc_w[ 0x0100 + spc.sp, spc.psw ]
				spc.sp -= 1

			case 0xAE  # POP A
				spc.sp += 1
				spc.a   = spc_r[ 0x0100 + u16[spc.sp] ]

			case 0xCE  # POP X
				spc.sp += 1
				spc.x   = spc_r[ 0x0100 + u16[spc.sp] ]

			case 0xEE  # POP Y
				spc.sp += 1
				spc.y   = spc_r[ 0x0100 + u16[spc.sp] ]

			case 0x8E  # POP PSW
				spc.sp  += 1
				spc.psw  = spc_r[ 0x0100 + u16[spc.sp] ]

			case 0x60  # CLRC
				spc.psw &= ~0x01

			case 0x80  # SETC
				spc.psw |= 0x01

			case 0xE0  # CLRV
				spc.psw &= ~0x40

			case 0x20  # CLRP
				spc.psw &= ~0x20

			case 0x40  # SETP
				spc.psw |= 0x20

			case 0xA0  # EI
				spc.psw &= ~0x04

			case 0xC0  # DI
				spc.psw |= 0x04

			case 0x9F  # XCN A
				spc.a   = (spc.a << 4) | (spc.a >> 4)
				spc_nz[ spc.a ]

			case 0xDF  # DAA A
				if [ (spc.a & 0x0F) > 9 || (spc.psw & 0x08) ]
					spc.a += 6
				if [ (spc.a & 0xF0) > 0x90 || (spc.psw & 0x01) ]
					spc.a   += 0x60
					spc.psw |= 0x01
				el
					spc.psw &= ~0x01
				spc_nz[ spc.a ]

			case 0xBE  # DAS A
				if [ !(spc.psw & 0x08) && (spc.a & 0x0F) > 9 ]
					spc.a -= 6
				if [ !(spc.psw & 0x01) && spc.a > 0x99 ]
					spc.a   -= 0x60
					spc.psw &= ~0x01
				spc_nz[ spc.a ]

			case 0xED  # NOTC
				spc.psw ^= 0x01

			case 0x9E  # DIV YA, X
				ya : u16 [ spc.a | (spc.y << 8) ]
				if [ spc.x == 0 ]
					spc.psw |= 0x40
					spc.a    = 0xFF
					spc.y    = 0xFF
				el
					spc.psw &= ~0x40
					spc.a    = ya / spc.x
					spc.y    = ya % spc.x
				spc_nz[ spc.a ]

			case 0xCF  # MUL YA
				result : u16 [ u16[spc.a] * u16[spc.y] ]
				spc.a   = result & 0xFF
				spc.y   = (result >> 8) & 0xFF
				spc_nz[ spc.y ]

			case 0xBA  # MOVW YA, dp
				dp : u16 [ spc_dp[] ]
				spc.a    = spc_r[dp]
				spc.y    = spc_r[dp + 1]
				ya       : u16 [ spc.a | (spc.y << 8) ]
				spc.psw  = (spc.psw & ~0x82) | ((ya == 0) ? 0x02 : 0) | (spc.y & 0x80)

			case 0xDA  # MOVW dp, YA
				dp : u16 [ spc_dp[] ]
				spc_w[ dp,     spc.a ]
				spc_w[ dp + 1, spc.y ]

			case 0x3A  # INCW dp
				dp : u16 [ spc_dp[] ]
				wd : u16 [ (spc_r[dp] | (spc_r[dp + 1] << 8)) + 1 ]
				spc_w[ dp,     u8[wd & 0xFF] ]
				spc_w[ dp + 1, u8[wd >> 8] ]
				spc.psw = (spc.psw & ~0x82) | ((wd == 0) ? 0x02 : 0) | ((wd & 0x8000) ? 0x80 : 0)

			case 0x1A  # DECW dp
				dp : u16 [ spc_dp[] ]
				wd : u16 [ (spc_r[dp] | (spc_r[dp + 1] << 8)) - 1 ]
				spc_w[ dp,     u8[wd & 0xFF] ]
				spc_w[ dp + 1, u8[wd >> 8] ]
				spc.psw = (spc.psw & ~0x82) | ((wd == 0) ? 0x02 : 0) | ((wd & 0x8000) ? 0x80 : 0)

			case 0x7A  # ADDW YA, dp
				dp : u16 [ spc_dp[] ]
				ya  : u16 [ spc.a | (spc.y << 8) ]
				wd  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				res : u32 [ u32[ya] + u32[wd] ]
				c : u8 [ (res > 0xFFFF) ? 0x01 : 0 ]
				z : u8 [ ((res & 0xFFFF) == 0) ? 0x02 : 0 ]
				n : u8 [ ((res & 0x8000) != 0) ? 0x80 : 0 ]
				v : u8 [ (((ya ^ res) & (wd ^ res) & 0x8000) != 0) ? 0x40 : 0 ]
				h : u8 [ (((ya & 0x0FFF) + (wd & 0x0FFF)) > 0x0FFF) ? 0x08 : 0 ]
				spc.psw = (spc.psw & ~0xCB) | c | z | n | v | h
				spc.a = res & 0xFF
				spc.y = (res >> 8) & 0xFF

			case 0x9A  # SUBW YA, dp
				dp : u16 [ spc_dp[] ]
				ya  : u16 [ spc.a | (spc.y << 8) ]
				wd  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				res : i32 [ i32[ya] - i32[wd] ]
				c : u8 [ (res >= 0) ? 0x01 : 0 ]
				z : u8 [ ((res & 0xFFFF) == 0) ? 0x02 : 0 ]
				n : u8 [ ((res & 0x8000) != 0) ? 0x80 : 0 ]
				v : u8 [ (((ya ^ wd) & (ya ^ res) & 0x8000) != 0) ? 0x40 : 0 ]
				h : u8 [ (((ya & 0x0FFF) - (wd & 0x0FFF)) < 0) ? 0x08 : 0 ]
				spc.psw = (spc.psw & ~0xCB) | c | z | n | v | h
				spc.a = res & 0xFF
				spc.y = (res >> 8) & 0xFF

			case 0x5A  # CMPW YA, dp   (16-bit compare; sets N,Z,C only)
				dp : u16 [ spc_dp[] ]
				ya  : u16 [ spc.a | (spc.y << 8) ]
				wd  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				res : i32 [ i32[ya] - i32[wd] ]
				c : u8 [ (res >= 0) ? 0x01 : 0 ]
				z : u8 [ ((res & 0xFFFF) == 0) ? 0x02 : 0 ]
				n : u8 [ ((res & 0x8000) != 0) ? 0x80 : 0 ]
				spc.psw = (spc.psw & ~0x83) | c | z | n

			case 0xFF  # STOP
				return spc.op_cyc

			case 0xEF  # SLEEP
				# wait for interrupt; treated as NOP here

			case 0x00  # NOP
				# no-op

			default
				fprintf[ stderr, "unhandled spc opcode %02X at %04X\n", opcode, spc.pc - 1 ]
				fault 'unhandled spc opcode — implement it then re-run (one at a time)'
		return spc.op_cyc

	# --- 65816 CPU flag helpers ---

	func cpu_nz [ v: u8 ]
		cpu.p = (cpu.p & ~0x82) | ((v == 0) ? 0x02 : 0) | (v & 0x80)

	func cpu_nzc [ v: u8, c: u8 ]
		cpu.p = (cpu.p & ~0x83) | c | ((v == 0) ? 0x02 : 0) | (v & 0x80)

	func cpu_cmp [ res: u16 ]
		c : u8 [ (res < 0x100) ? 0x01 : 0 ]
		z : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n : u8 [ res & 0x80 ]
		cpu.p = (cpu.p & ~0x83) | c | z | n

	func cpu_adc [ aa: u8, val: u8, res: u16 ]
		c  : u8 [ (res > 0xFF) ? 0x01 : 0 ]
		z  : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n  : u8 [ res & 0x80 ]
		ov : u8 [ ((u16[aa] ^ res) & (u16[val] ^ res) & 0x80) ? 0x40 : 0 ]
		cpu.p = (cpu.p & ~0xC3) | c | z | n | ov

	func cpu_sbc [ aa: u8, val: u8, res: u16 ]
		c  : u8 [ (res < 0x100) ? 0x01 : 0 ]
		z  : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n  : u8 [ res & 0x80 ]
		ov : u8 [ ((aa ^ val) & (aa ^ res) & 0x80) ? 0x40 : 0 ]
		cpu.p = (cpu.p & ~0xC3) | c | z | n | ov

	func cpu_bit [ val: u8 ]
		z : u8 [ ((cpu.a & val) == 0) ? 0x02 : 0 ]
		cpu.p = (cpu.p & ~0xC2) | (val & 0xC0) | z

	# --- width-aware ALU helpers (A follows the M flag) — every ALU
	# addressing-mode handler reads its operand then calls one of these ---

	func cpu_ora_a [ value: u16 ]
		cpu_set_A[ cpu_get_A[] | value ]
		cpu_nz_a[ cpu_get_A[] ]

	func cpu_and_a [ value: u16 ]
		cpu_set_A[ cpu_get_A[] & value ]
		cpu_nz_a[ cpu_get_A[] ]

	func cpu_eor_a [ value: u16 ]
		cpu_set_A[ cpu_get_A[] ^ value ]
		cpu_nz_a[ cpu_get_A[] ]

	func cpu_cmp_a [ value: u16 ]
		a16  : u16 [ cpu_get_A[] ]
		diff : u16 [ a16 - value ]
		nm   : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
		c : u8 [ (a16 >= value) ? 0x01 : 0 ]
		z : u8 [ (diff == 0) ? 0x02 : 0 ]
		n : u8 [ ((diff & nm) != 0) ? 0x80 : 0 ]
		cpu.p = (cpu.p & ~0x83) | c | z | n

	func cpu_adc_a [ value: u16 ]
		a16 : u16 [ cpu_get_A[] ]
		if [ cpu.p & 0x20 ]
			result : u16 [ a16 + value + (cpu.p & 0x01) ]
			cpu_adc[ a16, value, result ]
			cpu_set_A[ result & 0xFF ]
		el
			r32 : u32 [ u32[a16] + u32[value] + (cpu.p & 0x01) ]
			c  : u8 [ (r32 > 0xFFFF) ? 0x01 : 0 ]
			z  : u8 [ ((r32 & 0xFFFF) == 0) ? 0x02 : 0 ]
			n  : u8 [ ((r32 & 0x8000) != 0) ? 0x80 : 0 ]
			ov : u8 [ (((a16 ^ r32) & (value ^ r32) & 0x8000) != 0) ? 0x40 : 0 ]
			cpu.p = (cpu.p & ~0xC3) | c | z | n | ov
			cpu_set_A[ r32 & 0xFFFF ]

	func cpu_sbc_a [ value: u16 ]
		a16 : u16 [ cpu_get_A[] ]
		if [ cpu.p & 0x20 ]
			result : u16 [ a16 - value - (1 - (cpu.p & 0x01)) ]
			cpu_sbc[ a16, value, result ]
			cpu_set_A[ result & 0xFF ]
		el
			borrow : u32 [ 1 - (cpu.p & 0x01) ]
			r32    : u32 [ u32[a16] - u32[value] - borrow ]
			c  : u8 [ (r32 < 0x10000) ? 0x01 : 0 ]
			z  : u8 [ ((r32 & 0xFFFF) == 0) ? 0x02 : 0 ]
			n  : u8 [ ((r32 & 0x8000) != 0) ? 0x80 : 0 ]
			ov : u8 [ (((a16 ^ value) & (a16 ^ r32) & 0x8000) != 0) ? 0x40 : 0 ]
			cpu.p = (cpu.p & ~0xC3) | c | z | n | ov
			cpu_set_A[ r32 & 0xFFFF ]

	# --- width-aware RMW value transforms (return new value, set N/Z/C) ---

	func cpu_asl_v [ v: u16 ] -> u16
		msb : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
		msk : u16 [ (cpu.p & 0x20) ? 0xFF : 0xFFFF ]
		res : u16 [ (v << 1) & msk ]
		cpu.p = (cpu.p & ~0x01) | (((v & msb) != 0) ? 0x01 : 0)
		cpu_nz_a[ res ]
		return res

	func cpu_lsr_v [ v: u16 ] -> u16
		res : u16 [ v >> 1 ]
		cpu.p = (cpu.p & ~0x01) | (((v & 0x01) != 0) ? 0x01 : 0)
		cpu_nz_a[ res ]
		return res

	func cpu_rol_v [ v: u16 ] -> u16
		msb : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
		msk : u16 [ (cpu.p & 0x20) ? 0xFF : 0xFFFF ]
		oc  : u16 [ cpu.p & 0x01 ]
		res : u16 [ ((v << 1) | oc) & msk ]
		cpu.p = (cpu.p & ~0x01) | (((v & msb) != 0) ? 0x01 : 0)
		cpu_nz_a[ res ]
		return res

	func cpu_ror_v [ v: u16 ] -> u16
		msb : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
		oc  : u16 [ (cpu.p & 0x01) ? msb : 0 ]
		res : u16 [ (v >> 1) | oc ]
		cpu.p = (cpu.p & ~0x01) | (((v & 0x01) != 0) ? 0x01 : 0)
		cpu_nz_a[ res ]
		return res

	func cpu_inc_v [ v: u16 ] -> u16
		msk : u16 [ (cpu.p & 0x20) ? 0xFF : 0xFFFF ]
		res : u16 [ (v + 1) & msk ]
		cpu_nz_a[ res ]
		return res

	func cpu_dec_v [ v: u16 ] -> u16
		msk : u16 [ (cpu.p & 0x20) ? 0xFF : 0xFFFF ]
		res : u16 [ (v - 1) & msk ]
		cpu_nz_a[ res ]
		return res

	# width-aware read through a 24-bit [dp] long pointer (and the [dp],Y form)
	func cpu_read_long_dp [ dp: u16 ] -> u16
		lo   : u32 [ cpu_r[dp] ]
		mid  : u32 [ cpu_r[dp + 1] ]
		bank : u32 [ cpu_r[dp + 2] ]
		la   : u32 [ lo | (mid << 8) | (bank << 16) ]
		last_rd = la
		if [ cpu.p & 0x20 ] return cpu.memory[la]
		return cpu.memory[la] | (cpu.memory[la + 1] << 8)

	func cpu_read_long_dp_y [ dp: u16 ] -> u16
		lo   : u32 [ cpu_r[dp] ]
		mid  : u32 [ cpu_r[dp + 1] ]
		bank : u32 [ cpu_r[dp + 2] ]
		la   : u32 [ (lo | (mid << 8) | (bank << 16)) + cpu_get_Y[] ]
		last_rd = la
		if [ cpu.p & 0x20 ] return cpu.memory[la]
		return cpu.memory[la] | (cpu.memory[la + 1] << 8)

	# read the 3-byte long operand and return the width-aware value (absolute long)
	func cpu_read_long [] -> u16
		lo:u32[cpu_rb[]]  mid:u32[cpu_rb[]]  bank:u32[cpu_rb[]]
		la:u32[ lo | (mid << 8) | (bank << 16) ]
		last_rd = la
		if [ cpu.p & 0x20 ] return cpu.memory[la]
		return cpu.memory[la] | (cpu.memory[la + 1] << 8)

	func cpu_read_long_x [] -> u16
		lo:u32[cpu_rb[]]  mid:u32[cpu_rb[]]  bank:u32[cpu_rb[]]
		la:u32[ (lo | (mid << 8) | (bank << 16)) + cpu_get_X[] ]
		last_rd = la
		if [ cpu.p & 0x20 ] return cpu.memory[la]
		return cpu.memory[la] | (cpu.memory[la + 1] << 8)

	# stack-relative (d,s) read and its (d,s),Y indirect form
	func cpu_read_sr [] -> u16
		sr:u8[cpu_rb[]]  sa:u16[ (cpu.sp + sr) & 0xFFFF ]
		if [ cpu.p & 0x20 ] return cpu_r[sa]
		return cpu_r[sa] | (cpu_r[sa + 1] << 8)

	func cpu_read_sr_y [] -> u16
		sr:u8[cpu_rb[]]  sa:u16[ (cpu.sp + sr) & 0xFFFF ]
		base:u16[ cpu_r[sa] | (cpu_r[sa + 1] << 8) ]
		addr:u16[ base + cpu_get_Y[] ]
		if [ cpu.p & 0x20 ] return cpu_r[addr]
		return cpu_r[addr] | (cpu_r[addr + 1] << 8)

	# X-width memory read (for index loads/compares — width follows the X flag)
	func cpu_read_mem_x [ addr: u16 ] -> u16
		if [ cpu.p & 0x10 ] return cpu_db_r[addr]
		return cpu_db_r[addr] | (cpu_db_r[addr + 1] << 8)

	func cpu_cmp_x [ x16: u16, value: u16 ]
		diff : u16 [ x16 - value ]
		nm   : u16 [ (cpu.p & 0x10) ? 0x80 : 0x8000 ]
		c : u8 [ (x16 >= value) ? 0x01 : 0 ]
		z : u8 [ (diff == 0) ? 0x02 : 0 ]
		n : u8 [ ((diff & nm) != 0) ? 0x80 : 0 ]
		cpu.p = (cpu.p & ~0x83) | c | z | n

	func cpu_bit_a [ value: u16 ]
		nb : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
		vb : u16 [ (cpu.p & 0x20) ? 0x40 : 0x4000 ]
		z  : u8 [ ((cpu_get_A[] & value) == 0) ? 0x02 : 0 ]
		n  : u8 [ ((value & nb) != 0) ? 0x80 : 0 ]
		v  : u8 [ ((value & vb) != 0) ? 0x40 : 0 ]
		cpu.p = (cpu.p & ~0xC2) | n | v | z

	# push a 16-bit value (high then low, matching the stack convention)
	func cpu_push16 [ v: u16 ]
		cpu_w[ cpu.sp, u8[v >> 8] ]
		cpu.sp -= 1
		cpu_w[ cpu.sp, u8[v & 0xFF] ]
		cpu.sp -= 1

	# --- 65816 CPU step ---

	func cpu_step [] -> i32
		slot : i32 [ tr_i % 32 ]
		tr_addr[slot] = (u32[cpu.pbr] << 16) | u32[cpu.pc]
		tr_b0[slot] = cpu_fetch_at[ cpu.pc ]
		tr_b1[slot] = cpu_fetch_at[ cpu.pc + 1 ]
		tr_b2[slot] = cpu_fetch_at[ cpu.pc + 2 ]
		tr_b3[slot] = cpu_fetch_at[ cpu.pc + 3 ]
		tr_p[slot]  = cpu.p
		tr_a[slot]  = cpu.a
		tr_x[slot]  = cpu.x
		tr_y[slot]  = cpu.y
		tr_i += 1
		if [ env_trace && cpu.pbr == 0x00 && cpu.pc == 0x8B11 && dbg_t < 1 ]
			printf[ "==== 32 instrs before demo-entry $00:8B11 (f%u) ====\n", dbg_frames ]
			for [ kk: i32 0, kk < 32, kk += 1 ]
				st : i32 [ (tr_i + kk) % 32 ]
				printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[st] >> 16, tr_addr[st] & 0xFFFF, tr_b0[st], tr_b1[st], tr_b2[st], tr_b3[st], tr_p[st], tr_a[st], tr_x[st], tr_y[st] ]
			dbg_t += 1
		if [ cpu.pbr == 0x09 && cpu.pc >= 0xFA60 && cpu.pc <= 0xFA72 && dbg_frames >= 905 && dbg_frames <= 912 && dbg_t < 60 ]
			printf[ "SE 09:%04X D=%04X X=%04X Y=%04X P=%03X f%u\n", cpu.pc, cpu.dp, cpu.x, cpu.y, cpu.p, dbg_frames ]
			dbg_t += 1
		if [ dbg_frames == 300 && dbg_w < 80 ]
			printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X dp00=%02X%02X dp03=%02X\n", cpu.pbr, cpu.pc, cpu_fetch_at[cpu.pc], cpu_fetch_at[cpu.pc+1], cpu_fetch_at[cpu.pc+2], cpu_fetch_at[cpu.pc+3], cpu.p, cpu.a, cpu.x, cpu.y, cpu_db_r[1], cpu_db_r[0], cpu_db_r[3] ]
			dbg_w += 1
		if [ !dbg_cached ]                   # read debug env flags ONCE, not per-instruction
			dbg_cached   = true
			env_cputrace = (getenv['ASNES_CPUTRACE']) ? true : false
			env_trace    = (getenv['ASNES_TRACE']) ? true : false
			env_logzp    = (getenv['ASNES_LOG_ZP']) ? true : false
			env_pal      = (getenv['ASNES_PAL_LOG']) ? true : false
			env_map      = (getenv['ASNES_MAP_LOG']) ? true : false
			env_vrw      = (getenv['ASNES_VRW_LOG']) ? true : false
			env_dma      = (getenv['ASNES_DMA_LOG']) ? true : false
		if [ env_cputrace ]
			if [ cpu.pbr == 0x03 && cpu.pc == 0x8B68 ] ct_on = true
			if [ ct_on && ct_n < 30000 ]
				printf[ "%02X%04X %04X %04X %04X %02X\n", cpu.pbr, cpu.pc, cpu.a | (cpu.b << 8), cpu.x | (cpu.xh << 8), cpu.y | (cpu.yh << 8), cpu.p ]
				ct_n += 1
		op_master   = 0
		op_accesses = 0
		count_cpu   = true                   # count memory-access master cycles for this instruction
		opcode   : u8   [ cpu_rb[] ]
		cycles   : i32  [ 0 ]
		old_pc   : u16  [ cpu.pc ]
		ualign   : bool [ (cpu.dp & 0xFF) != 0 ]
		is_16bit : bool [ !(cpu.p & 0x20) ]

		#puts[ 'asnes_step op: 0x{opcode:02X}' ]


		switch [ opcode ]
			case 0x1A  # INC A
				cpu_set_A[ cpu_inc_v[ cpu_get_A[] ] ]
				cycles  = 2

			case 0x3A  # DEC A
				cpu_set_A[ cpu_dec_v[ cpu_get_A[] ] ]
				cycles  = 2

			case 0x9B  # TXY (width-aware)
				cpu_set_Y[ cpu_get_X[] ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 2

			case 0xBB  # TYX (width-aware)
				cpu_set_X[ cpu_get_Y[] ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0xA5  # LDA dp (width-aware)
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_set_A[ cpu_read_dp[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0xAD  # LDA abs (width-aware)
				addr   : u16 [ cpu_rw[] ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 4

			case 0xAC  # LDY abs (width-aware on X flag)
				addr   : u16 [ cpu_rw[] ]
				if [ cpu.p & 0x10 ]
					cpu_set_Y[ cpu_r[addr] ]
				el
					cpu_set_Y[ cpu_r[addr] | (cpu_r[addr + 1] << 8) ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 4

			case 0xAF  # LDA long (24-bit absolute, width-aware)
				lo     : u32 [ cpu_rb[] ]
				hi     : u32 [ cpu_rb[] ]
				bank   : u32 [ cpu_rb[] ]
				laddr  : u32 [ lo | (hi << 8) | (bank << 16) ]
				if [ cpu.p & 0x20 ]
					cpu_set_A[ cpu_long_r[laddr] ]
				el
					v : u16 [ cpu_long_r[laddr] | (cpu_long_r[laddr + 1] << 8) ]
					cpu_set_A[ v ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 5

			case 0xB7  # LDA [dp],Y (long indirect indexed, width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				lo     : u32 [ cpu_r[dp] ]
				mid    : u32 [ cpu_r[dp + 1] ]
				bank   : u32 [ cpu_r[dp + 2] ]
				base   : u32 [ lo | (mid << 8) | (bank << 16) ]
				addr   : u32 [ base + cpu_get_Y[] ]
				if [ cpu.p & 0x20 ]
					cpu_set_A[ cpu_long_r[addr] ]
				el
					v : u16 [ cpu_long_r[addr] | (cpu_long_r[addr + 1] << 8) ]
					cpu_set_A[ v ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 6

			case 0xBD  # LDA abs,X (width-aware)
				base   : u16 [ cpu_rw[] ]
				addr   : u16 [ base + cpu_get_X[] ]
				cross  : bool [ (base & 0xFF00) != (addr & 0xFF00) ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 4 + ((cross) ? 1 : 0)

			case 0xB9  # LDA abs,Y (width-aware)
				base   : u16 [ cpu_rw[] ]
				addr   : u16 [ base + cpu_get_Y[] ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 4

			case 0xA1  # LDA (dp,X) (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				ptr    : u16 [ (dp + cpu.x) & 0xFFFF ]
				addr   : u16 [ cpu_r[ptr] | (cpu_r[ptr + 1] << 8) ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 6 + ((ualign) ? 1 : 0)

			case 0xB1  # LDA (dp),Y (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				base   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				addr   : u16 [ base + cpu_get_Y[] ]
				cross  : bool [ (base & 0xFF00) != (addr & 0xFF00) ]
				if [ env_map && cpu.pbr == 0x03 && (dp == 0x0009 || dp == 0x000C) && dbg_w2 < 40 ]
					printf[ "DPY dp=%04X base=%04X Y=%02X addr=%04X DBR=%02X D=%04X val=%02X pc=%04X f%u\n",
						dp, base, cpu_get_Y[], addr, cpu.dbr, cpu.dp, cpu_db_r[addr], cpu.pc, dbg_frames ]
					dbg_w2 += 1
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 5 + ((cross) ? 1 : 0) + ((ualign) ? 1 : 0)

			case 0x85  # STA dp (width-aware)
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_get_A[] ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0x8D  # STA abs (width-aware)
				addr   : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 4

			case 0x8F  # STA long (24-bit absolute, width-aware)
				lo     : u32 [ cpu_rb[] ]
				hi     : u32 [ cpu_rb[] ]
				bank   : u32 [ cpu_rb[] ]
				laddr  : u32 [ lo | (hi << 8) | (bank << 16) ]
				a16    : u16 [ cpu_get_A[] ]
				cpu_long_w[ laddr, u8[ a16 & 0xFF ] ]
				if [ !(cpu.p & 0x20) ] cpu_long_w[ laddr + 1, u8[ a16 >> 8 ] ]
				cycles = 5

			case 0x86  # STX dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_w[ addr, cpu.x ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.xh ]
				cycles = 3

			case 0x8E  # STX abs
				addr   : u16 [ cpu_rw[] ]
				cpu_w[ addr, cpu.x ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.xh ]
				cycles = 4

			case 0x84  # STY dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_w[ addr, cpu.y ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.yh ]
				cycles = 3

			case 0x8C  # STY abs
				addr   : u16 [ cpu_rw[] ]
				cpu_w[ addr, cpu.y ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.yh ]
				cycles = 4

			case 0x95  # STA dp,X
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_get_A[] ]
				cycles = 4 + ((ualign) ? 1 : 0)

			case 0x9D  # STA abs,X (width-aware)
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0x99  # STA abs,Y (width-aware)
				addr   : u16 [ cpu_rw[] + cpu_get_Y[] ]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 5

			case 0x81  # STA (dp,X) (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				ptr    : u16 [ (dp + cpu.x) & 0xFFFF ]
				addr   : u16 [ cpu_r[ptr] | (cpu_r[ptr + 1] << 8) ]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 6 + ((ualign) ? 1 : 0)

			case 0x91  # STA (dp),Y (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				base   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				addr   : u16 [ base + cpu_get_Y[] ]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 6 + ((ualign) ? 1 : 0)

			case 0xA4  # LDY dp (width-aware on X flag)
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.p & 0x10 ]
					cpu_set_Y[ cpu_r[addr] ]
				el
					cpu_set_Y[ cpu_r[addr] | (cpu_r[addr + 1] << 8) ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0xA6  # LDX dp (width-aware on X flag)
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.p & 0x10 ]
					cpu_set_X[ cpu_r[addr] ]
				el
					cpu_set_X[ cpu_r[addr] | (cpu_r[addr + 1] << 8) ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0xAE  # LDX abs (width-aware on X flag)
				addr   : u16 [ cpu_rw[] ]
				if [ cpu.p & 0x10 ]
					cpu_set_X[ cpu_r[addr] ]
				el
					cpu_set_X[ cpu_r[addr] | (cpu_r[addr + 1] << 8) ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 4

			case 0xB6  # LDX dp,Y
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_Y[]) & 0xFFFF ]
				cpu_set_X[ cpu_read_dp_x[addr] ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 4 + ((ualign) ? 1 : 0)

			case 0xBE  # LDX abs,Y
				base   : u16 [ cpu_rw[] ]
				addr   : u16 [ base + cpu_get_Y[] ]
				cross  : bool [ (base & 0xFF00) != (addr & 0xFF00) ]
				if [ env_pal && base == 0xA463 ]
					printf[ "LDX $A463,Y: Y=%04X addr=%04X DBR=%02X read=%04X f%u\n",
						cpu_get_Y[], addr, cpu.dbr, cpu_read_mem_x[addr], dbg_frames ]
				cpu_set_X[ cpu_read_mem_x[addr] ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 4 + ((cross) ? 1 : 0)

			case 0xA0  # LDY #imm (width-aware)
				cpu_set_Y[ cpu_imm_x[] ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 2

			case 0xA2  # LDX #imm (width-aware)
				cpu_set_X[ cpu_imm_x[] ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0xA9  # LDA #imm (width-aware)
				cpu_set_A[ cpu_imm_a[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2

			case 0xEA  # NOP
				cycles = 2

			case 0x18  # CLC
				cpu.p &= ~0x01
				cycles = 2

			case 0x38  # SEC
				cpu.p |= 0x01
				cycles = 2

			case 0xD8  # CLD
				cpu.p &= ~0x08
				cycles = 2

			case 0xF8  # SED
				cpu.p |= 0x08
				cycles = 2

			case 0x78  # SEI
				cpu.p |= 0x04
				cycles = 2

			case 0x58  # CLI
				cpu.p &= ~0x04
				cycles = 2

			case 0xB8  # CLV
				cpu.p &= ~0x40
				cycles = 2

			case 0xAA  # TAX (width-aware)
				cpu_set_X[ cpu.a | (cpu.b << 8) ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0xA8  # TAY (width-aware)
				cpu_set_Y[ cpu.a | (cpu.b << 8) ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 2

			case 0x8A  # TXA (width-aware)
				cpu_set_A[ cpu_get_X[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2

			case 0x98  # TYA (width-aware)
				cpu_set_A[ cpu_get_Y[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2

			case 0xBA  # TSX (width-aware)
				cpu_set_X[ cpu.sp ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0x9A  # TXS
				if [ cpu.e ]
					cpu.sp = 0x0100 | cpu.x
				el
					cpu.sp = cpu.x | (cpu.xh << 8)
				cycles = 2

			case 0x4C  # JMP abs
				cpu.pc = cpu_rw[]
				cycles = 3

			case 0x6C  # JMP (abs)
				ptr    : u16 [ cpu_rw[] ]
				cpu.pc = cpu_r[ptr] | (cpu_r[ptr + 1] << 8)
				cycles = 5

			case 0x20  # JSR abs
				target : u16 [ cpu_rw[] ]
				ret    : u16 [ cpu.pc - 1 ]
				cpu_w[ cpu.sp, u8[ret >> 8] ]
				cpu.sp -= 1
				cpu_w[ cpu.sp, u8[ret & 0xFF] ]
				cpu.sp -= 1
				cpu.pc  = target
				cycles  = 6

			case 0x60  # RTS
				lo     : u16 [ cpu_r[u16[cpu.sp + 1]] ]
				hi     : u16 [ cpu_r[u16[cpu.sp + 2]] ]
				cpu.sp += 2
				cpu.pc  = (lo | (hi << 8)) + 1
				cycles  = 6

			case 0x90  # BCC
				off : i8 [ cpu_rb[] ]
				if [ !(cpu.p & 0x01) ]
					cross_pc : bool [ (old_pc & 0xFF00) != (cpu.pc & 0xFF00) ]
					cpu.pc   = u16[i32[cpu.pc] + off]
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0xB0  # BCS
				off : i8 [ cpu_rb[] ]
				if [ cpu.p & 0x01 ]
					cross_pc : bool [ (old_pc & 0xFF00) != (cpu.pc & 0xFF00) ]
					cpu.pc   = u16[i32[cpu.pc] + off]
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0xF0  # BEQ
				off : i8 [ cpu_rb[] ]
				if [ cpu.p & 0x02 ]
					cross_pc : bool [ (old_pc & 0xFF00) != (cpu.pc & 0xFF00) ]
					cpu.pc   = u16[i32[cpu.pc] + off]
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0xD0  # BNE
				off : i8 [ cpu_rb[] ]
				if [ !(cpu.p & 0x02) ]
					cross_pc : bool [ (old_pc & 0xFF00) != (cpu.pc & 0xFF00) ]
					cpu.pc   = u16[i32[cpu.pc] + off]
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0x10  # BPL
				off : i8 [ cpu_rb[] ]
				if [ !(cpu.p & 0x80) ]
					cross_pc : bool [ (old_pc & 0xFF00) != (cpu.pc & 0xFF00) ]
					cpu.pc   = u16[i32[cpu.pc] + off]
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0x30  # BMI
				off : i8 [ cpu_rb[] ]
				if [ cpu.p & 0x80 ]
					cross_pc : bool [ (old_pc & 0xFF00) != (cpu.pc & 0xFF00) ]
					cpu.pc   = u16[i32[cpu.pc] + off]
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0x50  # BVC
				off : i8 [ cpu_rb[] ]
				if [ !(cpu.p & 0x40) ]
					cross_pc : bool [ (old_pc & 0xFF00) != (cpu.pc & 0xFF00) ]
					cpu.pc   = u16[i32[cpu.pc] + off]
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0x70  # BVS
				off : i8 [ cpu_rb[] ]
				if [ cpu.p & 0x40 ]
					cross_pc : bool [ (old_pc & 0xFF00) != (cpu.pc & 0xFF00) ]
					cpu.pc   = u16[i32[cpu.pc] + off]
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0x80  # BRA
				off    : i8 [ cpu_rb[] ]
				cpu.pc  = u16[i32[cpu.pc] + off]
				cycles  = 3

			case 0x69  # ADC #imm (width-aware)
				value  : u16 [ cpu_imm_a[] ]
				a16    : u16 [ cpu_get_A[] ]
				if [ cpu.p & 0x20 ]
					result : u16 [ a16 + value + (cpu.p & 0x01) ]
					cpu_adc[ a16, value, result ]
					cpu_set_A[ result & 0xFF ]
				el
					r32 : u32 [ u32[a16] + u32[value] + (cpu.p & 0x01) ]
					c  : u8 [ (r32 > 0xFFFF) ? 0x01 : 0 ]
					z  : u8 [ ((r32 & 0xFFFF) == 0) ? 0x02 : 0 ]
					n  : u8 [ ((r32 & 0x8000) != 0) ? 0x80 : 0 ]
					ov : u8 [ (((a16 ^ r32) & (value ^ r32) & 0x8000) != 0) ? 0x40 : 0 ]
					cpu.p = (cpu.p & ~0xC3) | c | z | n | ov
					cpu_set_A[ r32 & 0xFFFF ]
				cycles  = 2

			case 0x65  # ADC dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_adc_a[ cpu_read_dp[addr] ]
				cycles  = 3 + ((ualign) ? 1 : 0)

			case 0x6D  # ADC abs
				addr   : u16 [ cpu_rw[] ]
				cpu_adc_a[ cpu_read_mem[addr] ]
				cycles  = 4

			case 0xE9  # SBC #imm (width-aware)
				value  : u16 [ cpu_imm_a[] ]
				a16    : u16 [ cpu_get_A[] ]
				if [ cpu.p & 0x20 ]
					result : u16 [ a16 - value - (1 - (cpu.p & 0x01)) ]
					cpu_sbc[ a16, value, result ]
					cpu_set_A[ result & 0xFF ]
				el
					borrow : u32 [ 1 - (cpu.p & 0x01) ]
					r32    : u32 [ u32[a16] - u32[value] - borrow ]
					c  : u8 [ (r32 < 0x10000) ? 0x01 : 0 ]
					z  : u8 [ ((r32 & 0xFFFF) == 0) ? 0x02 : 0 ]
					n  : u8 [ ((r32 & 0x8000) != 0) ? 0x80 : 0 ]
					ov : u8 [ (((a16 ^ value) & (a16 ^ r32) & 0x8000) != 0) ? 0x40 : 0 ]
					cpu.p = (cpu.p & ~0xC3) | c | z | n | ov
					cpu_set_A[ r32 & 0xFFFF ]
				cycles  = 2

			case 0xE5  # SBC dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_sbc_a[ cpu_read_dp[addr] ]
				cycles  = 3 + ((ualign) ? 1 : 0)

			case 0xED  # SBC abs
				addr   : u16 [ cpu_rw[] ]
				cpu_sbc_a[ cpu_read_mem[addr] ]
				cycles  = 4

			case 0xC9  # CMP #imm (width-aware)
				value : u16 [ cpu_imm_a[] ]
				a16   : u16 [ cpu_get_A[] ]
				diff  : u16 [ a16 - value ]
				nmask : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
				c : u8 [ (a16 >= value) ? 0x01 : 0 ]
				z : u8 [ (diff == 0) ? 0x02 : 0 ]
				n : u8 [ ((diff & nmask) != 0) ? 0x80 : 0 ]
				cpu.p = (cpu.p & ~0x83) | c | z | n
				cycles = 2

			case 0xC5  # CMP dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_cmp_a[ cpu_read_dp[addr] ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0xCD  # CMP abs (width-aware on M flag)
				cpu_cmp_a[ cpu_read_mem[ cpu_rw[] ] ]
				cycles = 4

			case 0xE0  # CPX #imm (width-aware)
				value : u16 [ cpu_imm_x[] ]
				x16   : u16 [ cpu_get_X[] ]
				diff  : u16 [ x16 - value ]
				nmask : u16 [ (cpu.p & 0x10) ? 0x80 : 0x8000 ]
				c : u8 [ (x16 >= value) ? 0x01 : 0 ]
				z : u8 [ (diff == 0) ? 0x02 : 0 ]
				n : u8 [ ((diff & nmask) != 0) ? 0x80 : 0 ]
				cpu.p = (cpu.p & ~0x83) | c | z | n
				cycles = 2

			case 0xC0  # CPY #imm (width-aware)
				value : u16 [ cpu_imm_x[] ]
				y16   : u16 [ cpu_get_Y[] ]
				diff  : u16 [ y16 - value ]
				nmask : u16 [ (cpu.p & 0x10) ? 0x80 : 0x8000 ]
				c : u8 [ (y16 >= value) ? 0x01 : 0 ]
				z : u8 [ (diff == 0) ? 0x02 : 0 ]
				n : u8 [ ((diff & nmask) != 0) ? 0x80 : 0 ]
				cpu.p = (cpu.p & ~0x83) | c | z | n
				cycles = 2

			case 0xE6  # INC dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_inc_v[ cpu_read_dp[addr] ] ]
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0xEE  # INC abs
				addr  : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_inc_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0xE8  # INX (width-aware)
				cpu_set_X[ cpu_get_X[] + 1 ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0xC8  # INY (width-aware)
				cpu_set_Y[ cpu_get_Y[] + 1 ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 2

			case 0xC6  # DEC dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_dec_v[ cpu_read_dp[addr] ] ]
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0xCE  # DEC abs
				addr  : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_dec_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0xCA  # DEX (width-aware)
				cpu_set_X[ cpu_get_X[] - 1 ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0x88  # DEY (width-aware)
				cpu_set_Y[ cpu_get_Y[] - 1 ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 2

			case 0x29  # AND #imm (width-aware)
				cpu_set_A[ cpu_get_A[] & cpu_imm_a[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2

			case 0x25  # AND dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_and_a[ cpu_read_dp[addr] ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0x2D  # AND abs
				addr  : u16 [ cpu_rw[] ]
				cpu_and_a[ cpu_read_mem[addr] ]
				cycles = 4

			case 0x01  # ORA (dp,X) — width-aware (A follows M flag)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				ptr    : u16 [ (dp + cpu.x) & 0xFFFF ]
				addr   : u16 [ cpu_r[ptr] | (cpu_r[ptr + 1] << 8) ]
				res    : u16 [ cpu_get_A[] | cpu_read_mem[addr] ]
				cpu_set_A[ res ]
				if [ cpu.p & 0x20 ]
					cpu.p = (cpu.p & ~0x82) | ((res == 0) ? 0x02 : 0) | (res & 0x80)
				el
					cpu.p = (cpu.p & ~0x82) | ((res == 0) ? 0x02 : 0) | ((res & 0x8000) ? 0x80 : 0)
				cycles = 6

			case 0x09  # ORA #imm (width-aware)
				cpu_set_A[ cpu_get_A[] | cpu_imm_a[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2

			case 0x05  # ORA dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_ora_a[ cpu_read_dp[addr] ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0x0D  # ORA abs
				addr  : u16 [ cpu_rw[] ]
				cpu_ora_a[ cpu_read_mem[addr] ]
				cycles = 4

			case 0x49  # EOR #imm (width-aware)
				cpu_set_A[ cpu_get_A[] ^ cpu_imm_a[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2

			case 0x45  # EOR dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_eor_a[ cpu_read_dp[addr] ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0x4D  # EOR abs
				addr  : u16 [ cpu_rw[] ]
				cpu_eor_a[ cpu_read_mem[addr] ]
				cycles = 4

			case 0x0A  # ASL A
				cpu_set_A[ cpu_asl_v[ cpu_get_A[] ] ]
				cycles = 2

			case 0x06  # ASL dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_asl_v[ cpu_read_dp[addr] ] ]
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0x4A  # LSR A
				cpu_set_A[ cpu_lsr_v[ cpu_get_A[] ] ]
				cycles = 2

			case 0x46  # LSR dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_lsr_v[ cpu_read_dp[addr] ] ]
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0x2A  # ROL A
				cpu_set_A[ cpu_rol_v[ cpu_get_A[] ] ]
				cycles  = 2

			case 0x26  # ROL dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_rol_v[ cpu_read_dp[addr] ] ]
				cycles  = 5 + ((ualign) ? 1 : 0)

			case 0x6A  # ROR A
				cpu_set_A[ cpu_ror_v[ cpu_get_A[] ] ]
				cycles  = 2

			case 0x66  # ROR dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_ror_v[ cpu_read_dp[addr] ] ]
				cycles  = 5 + ((ualign) ? 1 : 0)

			case 0x24  # BIT dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_bit_a[ cpu_read_dp[addr] ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0x2C  # BIT abs
				addr  : u16 [ cpu_rw[] ]
				cpu_bit_a[ cpu_read_mem[addr] ]
				cycles = 4

			case 0x48  # PHA
				if [ cpu.p & 0x20 ]
					cpu_w[ cpu.sp, cpu.a ]
					cpu.sp -= 1
				el
					cpu_w[ cpu.sp, cpu.b ]
					cpu.sp -= 1
					cpu_w[ cpu.sp, cpu.a ]
					cpu.sp -= 1
				cycles  = 3

			case 0x68  # PLA
				if [ cpu.p & 0x20 ]
					cpu.sp += 1
					cpu.a   = cpu_r[ cpu.sp ]
					cpu.p   = (cpu.p & ~0x82) | ((cpu.a == 0) ? 0x02 : 0) | (cpu.a & 0x80)
				el
					cpu.sp += 1
					al     : u16 [ cpu_r[ cpu.sp ] ]
					cpu.sp += 1
					ah     : u16 [ cpu_r[ cpu.sp ] ]
					cpu.a   = al
					cpu.b   = ah
					av     : u16 [ al | (ah << 8) ]
					cpu.p   = (cpu.p & ~0x82) | ((av == 0) ? 0x02 : 0) | ((av & 0x8000) ? 0x80 : 0)
