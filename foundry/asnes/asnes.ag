			case 0xB2  # LDA (dp) (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				addr   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 5 + dpen + m1

			case 0x92  # STA (dp) (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				addr   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 5 + dpen + m1

			case 0x75  # ADC dp,X (width-aware)
				addr   : u16  [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_adc_a[ cpu_read_dp[addr] ]
				cycles = 4 + dpen + m1

			case 0x73  # ADC (d,S),Y (stack-relative indirect indexed, width-aware)
				sr2    : u8  [ cpu_rb[] ]
				sa2    : u16 [ (cpu.sp + sr2) & 0xFFFF ]
				p2     : u16 [ cpu_r[sa2] | (cpu_r[sa2 + 1] << 8) ]
				a2     : u16 [ p2 + cpu_get_Y[] ]
				cpu_adc_a[ cpu_read_mem[a2] ]
				cycles = 7 + m1

			case 0x72  # ADC (dp) (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				addr   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cpu_adc_a[ cpu_read_mem[addr] ]
				cycles = 5 + dpen + m1

			case 0x76  # ROR dp,X (width-aware RMW)
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				rv_ : u16 [ cpu_read_dp[addr] ]
				cpu_idle[]
				cpu_write_dp[ addr, cpu_ror_v[ rv_ ] ]
				cycles = 6 + dpen + ((is_16bit) ? 2 : 0)

			case 0x16  # ASL dp,X
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				rv_ : u16 [ cpu_read_dp[addr] ]
				cpu_idle[]
				cpu_write_dp[ addr, cpu_asl_v[ rv_ ] ]
				cycles = 6 + dpen + ((is_16bit) ? 2 : 0)

			case 0x1E  # ASL abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_idle[]
				rv_ : u16 [ cpu_read_mem[addr] ]
				cpu_idle[]
				cpu_write_mem[ addr, cpu_asl_v[ rv_ ] ]
				cycles = 7 + ((is_16bit) ? 2 : 0)

			case 0x56  # LSR dp,X
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				rv_ : u16 [ cpu_read_dp[addr] ]
				cpu_idle[]
				cpu_write_dp[ addr, cpu_lsr_v[ rv_ ] ]
				cycles = 6 + dpen + ((is_16bit) ? 2 : 0)

