				if [ spc_r[dp] & 0x01 ] spc_take[ i32[off] ]

			case 0x23  # BBS dp.1, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x02 ] spc_take[ i32[off] ]

			case 0x43  # BBS dp.2, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x04 ] spc_take[ i32[off] ]

			case 0x63  # BBS dp.3, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x08 ] spc_take[ i32[off] ]

			case 0x83  # BBS dp.4, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x10 ] spc_take[ i32[off] ]

			case 0xA3  # BBS dp.5, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x20 ] spc_take[ i32[off] ]

			case 0xC3  # BBS dp.6, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x40 ] spc_take[ i32[off] ]

			case 0xE3  # BBS dp.7, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x80 ] spc_take[ i32[off] ]

			case 0x13  # BBC dp.0, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x01) ] spc_take[ i32[off] ]

			case 0x33  # BBC dp.1, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x02) ] spc_take[ i32[off] ]

			case 0x53  # BBC dp.2, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x04) ] spc_take[ i32[off] ]

			case 0x73  # BBC dp.3, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x08) ] spc_take[ i32[off] ]

			case 0x93  # BBC dp.4, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x10) ] spc_take[ i32[off] ]

			case 0xB3  # BBC dp.5, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x20) ] spc_take[ i32[off] ]

			case 0xD3  # BBC dp.6, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x40) ] spc_take[ i32[off] ]

			case 0xF3  # BBC dp.7, rel
				dp : u16 [ spc_dp[] ]
