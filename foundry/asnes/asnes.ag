				cpu.sp -= 1
				cpu_w[ 0x0100 + cpu.sp, u8[cpu.pc & 0xFF] ]
				cpu.sp -= 1
				cpu_w[ 0x0100 + cpu.sp, cpu.p | 0x10 ]
				cpu.sp -= 1
				cpu.p  |= 0x04
				lo     : u16 [ cpu_r[0xFFFE] ]
				hi     : u16 [ cpu_r[0xFFFF] ]
				cpu.pc  = lo | (hi << 8)
				cycles  = 7

			case 0xFB  # XCE
				old_carry : u8 [ cpu.p & 0x01 ]
				if [ cpu.p & 0x100 ]
					cpu.p &= ~0x100
					cpu.p |= old_carry
				el
					cpu.p |= 0x100
					cpu.p  = (cpu.p & ~0x01) | old_carry
				cycles = 2

			case 0xC2  # REP #imm
				mask   : u8 [ cpu_rb[] ]
				cpu.p &= ~mask
				cycles = 3

			case 0xE2  # SEP #imm
				mask   : u8 [ cpu_rb[] ]
				cpu.p |= mask
				cycles = 3

			case 0x14  # TRB dp
				dp     : u8 [ cpu_rb[] ]
				value  : u8 [ cpu_r[dp] ]
				result : u8 [ cpu.a & value ]
				cpu_w[ dp, value & ~cpu.a ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0x1C  # TRB abs
				addr   : u16 [ cpu_rw[] ]
				value  : u8  [ cpu_r[addr] ]
				result : u8  [ cpu.a & value ]
				cpu_w[ addr, value & ~cpu.a ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 6

			case 0x04  # TSB dp
				dp     : u8 [ cpu_rb[] ]
				value  : u8 [ cpu_r[dp] ]
				result : u8 [ cpu.a & value ]
				cpu_w[ dp, value | cpu.a ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0x0C  # TSB abs
				addr   : u16 [ cpu_rw[] ]
				value  : u8  [ cpu_r[addr] ]
				result : u8  [ cpu.a & value ]
				cpu_w[ addr, value | cpu.a ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 6

			case 0x64  # STZ dp
				dp : u8 [ cpu_rb[] ]
				cpu_w[ dp, 0 ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0x74  # STZ dp,X
				dp : u8 [ cpu_rb[] ]
				cpu_w[ (dp + cpu.x) & 0xFF, 0 ]
				cycles = 4 + ((ualign) ? 1 : 0)

			case 0x9C  # STZ abs
				addr : u16 [ cpu_rw[] ]
				cpu_w[ addr, 0 ]
				cycles = 4

			case 0x9E  # STZ abs,X
				addr : u16 [ cpu_rw[] + cpu.x ]
				cpu_w[ addr, 0 ]
				cycles = 5

			case 0xFF  # SBC long,X
				lo     : u8  [ cpu_rb[] ]
				hi     : u8  [ cpu_rb[] ]
				bank   : u8  [ cpu_rb[] ]
				addr   : u32 [ lo | u32[hi << 8] | u32[bank << 16] ]
				value  : u8  [ cpu_r[ u16[(addr + cpu.x) & 0xFFFFFF] ] ]
				result : u16 [ cpu.a - value - (1 - (cpu.p & 0x01)) ]
				cpu_sbc[ cpu.a, value, result ]
