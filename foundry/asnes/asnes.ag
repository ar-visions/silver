			case 0xDC  # JML [abs] (jump long, absolute indirect)
				jptr   : u16 [ cpu_rw[] ]
				jlo    : u16 [ cpu_r[jptr] ]
				jhi    : u16 [ cpu_r[jptr + 1] ]
				jbank  : u8  [ cpu_r[jptr + 2] ]
				cpu.pc  = jlo | (jhi << 8)
				cpu.pbr = jbank
				cycles  = 6

			case 0x5C  # JML long (jump long, absolute)
				clo    : u32 [ cpu_rb[] ]
				chi    : u32 [ cpu_rb[] ]
				cbank  : u8  [ cpu_rb[] ]
				cpu.pc  = clo | (chi << 8)
				cpu.pbr = cbank
