				bank : u32 [ cpu_r[dp + 2] ]
				la : u32 [ lo | (mid << 8) | (bank << 16) ]
				av : u16 [ cpu_get_A[] ]
				cpu.memory[la] = u8[ av & 0xFF ]
				if [ !(cpu.p & 0x20) ] cpu.memory[la + 1] = u8[ av >> 8 ]
				cycles = 6
			case 0x97  # STA [dp],Y
				dp : u8 [ cpu_rb[] ]
				lo : u32 [ cpu_r[dp] ]
				mid : u32 [ cpu_r[dp + 1] ]
				bank : u32 [ cpu_r[dp + 2] ]
				la : u32 [ (lo | (mid << 8) | (bank << 16)) + cpu_get_Y[] ]
				av : u16 [ cpu_get_A[] ]
				cpu.memory[la] = u8[ av & 0xFF ]
				if [ !(cpu.p & 0x20) ] cpu.memory[la + 1] = u8[ av >> 8 ]
				cycles = 7
			case 0x9F  # STA long,X
				lo : u32 [ cpu_rb[] ]
				mid : u32 [ cpu_rb[] ]
				bank : u32 [ cpu_rb[] ]
				la : u32 [ (lo | (mid << 8) | (bank << 16)) + cpu_get_X[] ]
				av : u16 [ cpu_get_A[] ]
				cpu.memory[la] = u8[ av & 0xFF ]
				if [ !(cpu.p & 0x20) ] cpu.memory[la + 1] = u8[ av >> 8 ]
				cycles = 5
			case 0x93  # STA (d,s),Y
				sr : u8 [ cpu_rb[] ]
				sa : u16 [ 0x0100 + ((cpu.sp + sr) & 0xFF) ]
				base : u16 [ cpu_r[sa] | (cpu_r[sa + 1] << 8) ]
				cpu_write_mem[ base + cpu_get_Y[], cpu_get_A[] ]
				cycles = 7
			case 0x94  # STY dp,X
				addr : u8 [ (cpu_rb[] + cpu.x) & 0xFF ]
				cpu_w[ addr, cpu.y ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.yh ]
				cycles = 4
			case 0x96  # STX dp,Y
				addr : u8 [ (cpu_rb[] + cpu.y) & 0xFF ]
				cpu_w[ addr, cpu.x ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.xh ]
				cycles = 4

			# --- compares (X-width) ---
			case 0xC4  # CPY dp
				cpu_cmp_x[ cpu_get_Y[], cpu_read_mem_x[ cpu_rb[] ] ]
				cycles = 3
			case 0xCC  # CPY abs
				cpu_cmp_x[ cpu_get_Y[], cpu_read_mem_x[ cpu_rw[] ] ]
				cycles = 4
			case 0xE4  # CPX dp
				cpu_cmp_x[ cpu_get_X[], cpu_read_mem_x[ cpu_rb[] ] ]
				cycles = 3
			case 0xEC  # CPX abs
				cpu_cmp_x[ cpu_get_X[], cpu_read_mem_x[ cpu_rw[] ] ]
				cycles = 4

			# --- BIT ---
			case 0x89  # BIT #imm (only affects Z)
				value : u16 [ cpu_imm_a[] ]
				z : u8 [ ((cpu_get_A[] & value) == 0) ? 0x02 : 0 ]
				cpu.p = (cpu.p & ~0x02) | z
				cycles = 2
			case 0x34  # BIT dp,X
				cpu_bit_a[ cpu_read_mem[ (cpu_rb[] + cpu.x) & 0xFF ] ]
				cycles = 4
			case 0x3C  # BIT abs,X
				cpu_bit_a[ cpu_read_mem[ cpu_rw[] + cpu_get_X[] ] ]
				cycles = 4

			# --- control flow ---
			case 0x7C  # JMP (abs,X)
				ptr : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu.pc = cpu_r[ptr] | (cpu_r[ptr + 1] << 8)
				cycles = 6
			case 0xFC  # JSR (abs,X)
				ptr : u16 [ cpu_rw[] ]
				ret : u16 [ cpu.pc - 1 ]
				cpu_push16[ ret ]
				addr : u16 [ (ptr + cpu_get_X[]) & 0xFFFF ]
				cpu.pc = cpu_r[addr] | (cpu_r[addr + 1] << 8)
				cycles = 8
			case 0x82  # BRL (branch long)
				rel : u16 [ cpu_rw[] ]
				cpu.pc = cpu.pc + rel
				cycles = 4
			case 0x62  # PER
				rel : u16 [ cpu_rw[] ]
				cpu_push16[ cpu.pc + rel ]
				cycles = 6
			case 0xD4  # PEI
				dp : u8 [ cpu_rb[] ]
				cpu_push16[ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cycles = 6
			case 0xF4  # PEA
				cpu_push16[ cpu_rw[] ]
				cycles = 5

			# --- misc / system ---
			case 0x42  # WDM (2-byte no-op)
				cpu_rb[]
				cycles = 2
			case 0x02  # COP (consume signature, treat as no-op)
				cpu_rb[]
				cycles = 7
			case 0xCB  # WAI (no-op; NMI fires at frame boundary)
				cycles = 3
			case 0xDB  # STP (no-op)
				cycles = 3
			case 0x54  # MVN (block move, ascending)
				dstb : u32 [ cpu_rb[] ]
				srcb : u32 [ cpu_rb[] ]
				cpu.dbr = dstb
				cont : bool [ true ]
				while [ cont ]
					s : u32 [ (srcb << 16) | (cpu.x | (cpu.xh << 8)) ]
					d : u32 [ (dstb << 16) | (cpu.y | (cpu.yh << 8)) ]
					cpu.memory[d] = cpu.memory[s]
					nx : u16 [ ((cpu.x | (cpu.xh << 8)) + 1) & 0xFFFF ]
					ny : u16 [ ((cpu.y | (cpu.yh << 8)) + 1) & 0xFFFF ]
					cpu.x = nx & 0xFF
					cpu.xh = nx >> 8
					cpu.y = ny & 0xFF
					cpu.yh = ny >> 8
					cnt : u16 [ cpu.a | (cpu.b << 8) ]
					nc : u16 [ (cnt - 1) & 0xFFFF ]
					cpu.a = nc & 0xFF
					cpu.b = nc >> 8
					if [ cnt == 0 ] cont = false
				cycles = 7
			case 0x44  # MVP (block move, descending)
				dstb : u32 [ cpu_rb[] ]
				srcb : u32 [ cpu_rb[] ]
				cpu.dbr = dstb
				cont : bool [ true ]
				while [ cont ]
					s : u32 [ (srcb << 16) | (cpu.x | (cpu.xh << 8)) ]
					d : u32 [ (dstb << 16) | (cpu.y | (cpu.yh << 8)) ]
					cpu.memory[d] = cpu.memory[s]
					nx : u16 [ ((cpu.x | (cpu.xh << 8)) - 1) & 0xFFFF ]
					ny : u16 [ ((cpu.y | (cpu.yh << 8)) - 1) & 0xFFFF ]
					cpu.x = nx & 0xFF
					cpu.xh = nx >> 8
					cpu.y = ny & 0xFF
					cpu.yh = ny >> 8
					cnt : u16 [ cpu.a | (cpu.b << 8) ]
					nc : u16 [ (cnt - 1) & 0xFFFF ]
					cpu.a = nc & 0xFF
					cpu.b = nc >> 8
					if [ cnt == 0 ] cont = false
				cycles = 7

			case 0x67  # ADC [dp] (long indirect, width-aware)
				dp     : u8  [ cpu_rb[] ]
				blo    : u32 [ cpu_r[dp] ]
				bmid   : u32 [ cpu_r[dp + 1] ]
				bbank  : u32 [ cpu_r[dp + 2] ]
				la     : u32 [ blo | (bmid << 8) | (bbank << 16) ]
				if [ cpu.p & 0x20 ]
					cpu_adc_a[ cpu.memory[la] ]
				el
					cpu_adc_a[ cpu.memory[la] | (cpu.memory[la + 1] << 8) ]
				cycles = 7

			case 0x77  # ADC [dp],Y (long indirect indexed, width-aware)
				dp     : u8  [ cpu_rb[] ]
				ylo    : u32 [ cpu_r[dp] ]
				ymid   : u32 [ cpu_r[dp + 1] ]
				ybank  : u32 [ cpu_r[dp + 2] ]
				yla    : u32 [ (ylo | (ymid << 8) | (ybank << 16)) + cpu_get_Y[] ]
				if [ cpu.p & 0x20 ]
					cpu_adc_a[ cpu.memory[yla] ]
				el
					cpu_adc_a[ cpu.memory[yla] | (cpu.memory[yla + 1] << 8) ]
				cycles = 7

			case 0xB3  # LDA (d,S),Y (stack-relative indirect indexed, width-aware)
				sr     : u8  [ cpu_rb[] ]
				sa     : u16 [ 0x0100 + ((cpu.sp + sr) & 0xFF) ]
				ptr    : u16 [ cpu_r[sa] | (cpu_r[sa + 1] << 8) ]
				addr   : u16 [ ptr + cpu_get_Y[] ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 7

			case 0x1F  # ORA long,X (width-aware)
				lo     : u32 [ cpu_rb[] ]
				hi     : u32 [ cpu_rb[] ]
				bank   : u32 [ cpu_rb[] ]
				laddr  : u32 [ (lo | (hi << 8) | (bank << 16)) + cpu_get_X[] ]
				if [ cpu.p & 0x20 ]
					cpu_set_A[ cpu_get_A[] | cpu.memory[laddr] ]
				el
					m : u16 [ cpu.memory[laddr] | (cpu.memory[laddr + 1] << 8) ]
					cpu_set_A[ cpu_get_A[] | m ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 6

			default
				printf[ "unhandled cpu opcode %02X at %04X\n", opcode, cpu.pc - 1 ]
				fault 'unhandled cpu opcode — implement it then re-run (one at a time)'

		return cycles
