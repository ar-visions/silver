	# SPC700 base cycle count per opcode (real SMP cycles, conditional branches at
	# their NOT-TAKEN value; +2 added in the handler when taken). Verified against
	# reference hardware's measured per-opcode timing (g_spc_tbl/2).
	intern  spc_cyc : new u8 [256] [
		2,8,4,5,3,4,3,6, 2,6,5,4,5,4,6,8,
		2,8,4,5,4,5,5,6, 5,5,6,5,2,2,4,6,
		2,8,4,5,3,4,3,6, 2,6,5,4,5,4,5,4,
		2,8,4,5,4,5,5,6, 5,5,6,5,2,2,3,8,
		2,8,4,5,3,4,3,6, 2,6,4,4,5,4,6,6,
		2,8,4,5,4,5,5,6, 5,5,4,5,2,2,4,3,
		2,8,4,5,3,4,3,6, 2,6,4,4,5,4,5,5,
		2,8,4,5,4,5,5,6, 5,5,5,5,2,2,3,6,
		2,8,4,5,3,4,3,6, 2,6,5,4,5,2,4,5,
		2,8,4,5,4,5,5,6, 5,5,5,5,2,2,12,5,
		3,8,4,5,3,4,3,6, 2,6,4,4,5,2,4,4,
		2,8,4,5,4,5,5,6, 5,5,5,5,2,2,3,4,
		3,8,4,5,4,5,4,7, 2,5,6,4,5,2,4,9,
		2,8,4,5,5,6,6,7, 4,5,5,5,2,2,6,3,
		2,8,4,5,3,4,3,6, 2,4,5,3,4,3,4,3,
		2,8,4,5,4,5,5,6, 3,4,5,4,2,2,4,3
	]

	# --- SPC700 DSP voice key-on / key-off ---

	func spc_keyon [ ch: i32 ]
		spc.channels[ch].pos       = 0
		spc.channels[ch].frac      = 0
		spc.channels[ch].envelope  = 0
		spc.channels[ch].env_state = 0          # attack
		spc.channels[ch].env_count = 0
		spc.channels[ch].active    = 1
		spc.channels[ch].samples[0] = 0
		spc.channels[ch].samples[1] = 0
		spc.channels[ch].samples[2] = 0
		spc.channels[ch].samples[3] = 0
		spc.dsp[0x7C] = spc.dsp[0x7C] & ~(1 << ch)   # clear ENDX for this voice

	func spc_keyoff [ ch: i32 ]
		spc.channels[ch].env_state = 3          # release

	# --- SPC memory access ---

	# advance the SPC clock by one memory-access's worth of cycles (reference hardware wait()/step per access).
	# ticking per access — not once per opcode — is what makes a mid-opcode port read/write land
	# at its real cycle relative to the CPU, so the APU handshake matches reference hardware exactly.
	func spc_tick [ cycles: i32 ]
		spc.pos += i64[ cycles ] * 2684659

	func spc_r [ addr: u16 ] -> u8
		r : u8 [ 0 ]
		if [ addr >= 0xF4 && addr <= 0xF7 ]
			ri : i32 [ i32[addr] - 0xF4 ]
			# no timestamp filtering: causality comes from drain ORDER like reference hardware — the CPU
			# drains the SPC up to its clock BEFORE committing a port write, so whatever is
			# in ports[] here was already committed when this opcode's turn came
			r = spc.ports[ri]
			if [ env_sf4 ] puts[ 'SF4R pc={spc.pc} p{ri} val={r}' ]
		el [ addr == 0xF3 ]                      # DSP data read: live register, not last write
			r = spc.dsp[ spc.ram[0xF2] & 0x7F ]
		el [ addr == 0xF2 ]
			r = spc.ram[0xF2]
		el [ addr >= 0xFD && addr <= 0xFF ]      # timer output counters (read clears)
			t : i32 [ addr - 0xFD ]
			r = spc.timer_count[t] & 0x0F
			spc.timer_count[t] = 0
		el [ addr >= 0xFFC0 ]                     # IPL ROM read overlay ($FFC0-$FFFF); RAM underneath stays zero
			r = spc_boot_rom[ i32[addr] - 0xFFC0 ]
		el
			r = spc.ram[addr]
		spc_tick[ 1 ]                             # this access consumed one SPC cycle (read happened at the pre-tick clock)
		return r

	func spc_w [ addr: u16, val: u8 ]
		if [ addr >= 0xF4 && addr <= 0xF7 ]
			pi : i32 [ i32[addr] - 0xF4 ]
			spc.oports[pi] = val                        # visible to the CPU on its next drained read (drain order = causality, like reference hardware)
			spc.ram[addr] = val                         # reference hardware SMP::write: even IO writes affect underlying RAM (apuram shadow)
		el [ addr == 0xF3 ]
			reg : u8 [ spc.ram[0xF2] & 0x7F ]
			spc.dsp[ reg ] = val
			if [ dbg_frames >= 145 && dbg_ev3 < 140 ]
				if [ reg == 0x5D ]                # DIR: sample directory page
					printf[ "f%u DSP DIR=%02X (dir base $%04X)\n", dbg_frames, val, u16[val] << 8 ]
					dbg_ev3 += 1
				el [ (reg & 0x0F) == 0x04 && reg < 0x80 ]   # VxSRCN: voice sample index
					printf[ "f%u DSP V%d SRCN=%02X\n", dbg_frames, reg >> 4, val ]
					dbg_ev3 += 1
			if [ reg == 0x4C ]                    # KON: latch, applied per DSP sample
				spc.kon_latch = spc.kon_latch | val
				if [ val != 0 ] dbg_kon += 1
			el [ reg == 0x5C ]                    # KOFF: latch
				spc.koff_latch = spc.koff_latch | val
				if [ val != 0 ] dbg_cpu += 1
			el [ reg == 0x7C ]                    # writing ENDX clears the flags
				spc.dsp[0x7C] = 0
			spc.ram[0xF3] = val
		el [ addr == 0xF1 ]                       # timer control + port-clear
			for [ t: i32 0, t < 3, t += 1 ]
				# enabling a timer (0 -> 1) resets its stage and counter
				if [ (val & (1 << t)) && !(spc.timer_on & (1 << t)) ]
					spc.timer_stage[t] = 0
					spc.timer_count[t] = 0
			spc.timer_on = val & 0x07
			if [ (val & 0x30) && dbg_frames >= 50 && dbg_ev < 80 ]
				printf[ "SPC F1=%02X clear(c2a now %02X %02X %02X %02X) spcpc=%04X\n", val, spc.ports[0], spc.ports[1], spc.ports[2], spc.ports[3], spc.pc ]
				dbg_ev += 1
			if [ val & 0x10 ]                     # clear ports 0,1 (CPU->APU)
				spc.ports[0] = 0
				spc.ports[1] = 0
			if [ val & 0x20 ]                     # clear ports 2,3
				spc.ports[2] = 0
				spc.ports[3] = 0
			spc.ram[0xF1] = val
		el [ addr >= 0xFA && addr <= 0xFC ]       # timer dividers
			spc.timer_target[addr - 0xFA] = val
			spc.ram[addr] = val
		el
			spc.ram[addr] = val
		spc_tick[ 1 ]                             # this write consumed one SPC cycle (write timestamped at the pre-tick clock)

	func dsp_r [ reg: u8 ] -> u8
		return spc.dsp[ reg & 0x7F ]

	func spc_rb [] -> u8
		if [ dbg_frames >= 50 && spc.pc == 0xFFC0 && dbg_ev < 60 ]
			printf[ "f%u SPC re-enter IPL@FFC0 (block start) cports=%02X %02X %02X %02X\n", dbg_frames, spc.ports[0], spc.ports[1], spc.ports[2], spc.ports[3] ]
			dbg_ev += 1
		v : u8 [ spc_r[ spc.pc ] ]
		spc.pc += 1
		return v

	func spc_dp [] -> u16
		# direct-page operand: low byte from stream + page ($0100 when PSW.P set)
		return spc_rb[] | ((spc.psw & 0x20) ? 0x100 : 0)


	func spc_r16 [ aa: u16 ] -> u16
		return spc_r[ aa ] | (spc_r[aa + 1] << 8)

	func spc_rw [] -> u16
		lo : u8 [ spc_r[ spc.pc ] ]
		spc.pc += 1
		hi : u8 [ spc_r[ spc.pc ] ]
		spc.pc += 1
		return lo | (hi << 8)

	func spc_nz [ v: u8 ]
		spc.psw = (spc.psw & ~0x82) | ((v == 0) ? 0x02 : 0) | (v & 0x80)

	func spc_nzc [ v: u8, c: u8 ]
		spc.psw = (spc.psw & ~0x83) | c | ((v == 0) ? 0x02 : 0) | (v & 0x80)

	func spc_cmp [ res: u16 ]
		c : u8 [ (res < 0x100) ? 0x01 : 0 ]
		z : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n : u8 [ res & 0x80 ]
		spc.psw = (spc.psw & ~0x83) | c | z | n

	func spc_adc [ aa: u8, val: u8, res: u16 ]
		c  : u8 [ (res > 0xFF) ? 0x01 : 0 ]
		z  : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n  : u8 [ res & 0x80 ]
		h  : u8 [ ((aa ^ val ^ res) & 0x10) ? 0x08 : 0 ]
		ov : u8 [ ((aa ^ res) & (val ^ res) & 0x80) ? 0x40 : 0 ]
		spc.psw = (spc.psw & ~0xCB) | c | z | n | h | ov

	func spc_sbc [ aa: u8, val: u8, res: u16 ]
		c  : u8 [ (res < 0x100) ? 0x01 : 0 ]
		z  : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n  : u8 [ res & 0x80 ]
		h  : u8 [ ((aa ^ val ^ res) & 0x10) ? 0x08 : 0 ]
		ov : u8 [ ((aa ^ val) & (aa ^ res) & 0x80) ? 0x40 : 0 ]
		spc.psw = (spc.psw & ~0xCB) | c | z | n | h | ov

	# --- CPU memory access ---

	# --- DMA: block transfer CPU memory <-> PPU/APU registers ($420B trigger) ---
	# B-bus register offset for transfer byte 'step', per DMAP transfer mode.
	func dma_boff [ mode: u8, step: i32 ] -> u8
		if [ mode == 1 || mode == 5 ] return u8[ step & 1 ]
		if [ mode == 4 ]              return u8[ step & 3 ]
		if [ mode == 3 || mode == 7 ] return u8[ (step >> 1) & 1 ]
		return 0

	# is the SECOND cycle of this opcode an internal IO cycle (6 masters)? implied /
	# accumulator ops, push/pull, returns, XBA, NOP — reference hardware runs idle() there, so a
	# deferred GP-DMA interrupting it re-aligns to clockCount=6, not a bus cycle width
	func op2_internal [ op: u8 ] -> bool
		if [ op == 0x08 || op == 0x0A || op == 0x0B || op == 0x18 || op == 0x1A || op == 0x1B ] return true
		if [ op == 0x28 || op == 0x2A || op == 0x2B || op == 0x38 || op == 0x3A || op == 0x3B ] return true
		if [ op == 0x40 || op == 0x48 || op == 0x4A || op == 0x4B || op == 0x58 || op == 0x5A || op == 0x5B ] return true
		if [ op == 0x60 || op == 0x68 || op == 0x6A || op == 0x6B || op == 0x78 || op == 0x7A || op == 0x7B ] return true
		if [ op == 0x88 || op == 0x8A || op == 0x8B || op == 0x98 || op == 0x9A || op == 0x9B ] return true
		if [ op == 0xA8 || op == 0xAA || op == 0xAB || op == 0xB8 || op == 0xBA || op == 0xBB ] return true
		if [ op == 0xC8 || op == 0xCA || op == 0xD8 || op == 0xDA || op == 0xDB ] return true
		if [ op == 0xE8 || op == 0xEA || op == 0xEB || op == 0xF8 || op == 0xFA || op == 0xFB ] return true
		return false

	func do_dma [ mask: u8, ck: i32 ]
		count_cpu = false                                   # DMA accesses charged here with a running master (dm)
		dm : i32 [ frame_master + op_master + steal_master ]  # so DRAM refresh lands mid-DMA like reference hardware dmaEdge/edge
		sy : i32 [ 8 - ((master_phase + op_master + steal_master) & 7) ]  # sync to 8-master boundary on the ABSOLUTE master phase (reference hardware counter.cpu&7)
		cd : i32 [ sy ]                                     # reference hardware counter.dma: masters accumulated while dmaActive (starts at the sync)
		steal_master += sy
		dm += sy
		steal_master += 8                                   # DMA-init (reference hardware dmaRun step<8>)
		dm += 8
		cd += 8
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ (mask & (1 << ch)) == 0 ] continue
			base   : u16 [ 0x4300 + (ch << 4) ]
			params : u8  [ cpu.memory[base] ]
			bbad   : u8  [ cpu.memory[base + 1] ]
			a_lo   : u16 [ u16[cpu.memory[base + 2]] | (u16[cpu.memory[base + 3]] << 8) ]
			a_bank : u8  [ cpu.memory[base + 4] ]
			count  : u32 [ u32[cpu.memory[base + 5]] | (u32[cpu.memory[base + 6]] << 8) ]
			if [ count == 0 ] count = 0x10000
			if [ env_dma && bbad == 0x18 ] printf[ "VDMA src=%02X:%04X cnt=%04X dest=%04X\n", a_bank, a_lo, count, ppu.vram_addr ]
			steal_master += 8                               # channel overhead (reference hardware channel dmaRun step<8>)
			dm += 8
			cd += 8
			mode   : u8  [ params & 0x07 ]
			stepb  : u8  [ (params >> 3) & 0x03 ]
			a_to_b : bool [ (params & 0x80) == 0 ]
			if [ env_cglog ]
				printf[ "f%u DMA ch%d bbad=$21%02X count=%u src=%02X:%04X step=%d vmadd=%04X\n",
					dbg_frames, ch, bbad, count, a_bank, a_lo, (params >> 3) & 3, ppu.vram_addr ]
			ab     : u8  [ a_bank ]
			ao     : u16 [ a_lo ]
			i      : u32 [ 0 ]
			while [ i < count ]
				boff : u8  [ dma_boff[ mode, i32[i] ] ]
				breg : u16 [ 0x2100 + u16[bbad] + u16[boff] ]
				bval : bool [ true ]                     # reference hardware: B=$2180 with the A-address in WRAM is INVALID (both on the WRAM bus) — B-read floats 0x00, B-write is dropped. ff3 fires such transfers expecting the no-op; performing them shreds dp/stack via WMDATA
				if [ breg == 0x2180 ]
					aa : u32 [ (u32[ab] << 16) | u32[ao] ]
					if [ (aa & 0xFE0000) == 0x7E0000 || (aa & 0x40E000) == 0x000000 ] bval = false
				if [ a_to_b ]
					v : u8 [ cpu_bank_r[ ab, ao ] ]
					if [ bval ]
						if [ breg >= 0x2140 ] cpu_w[ breg, v ]   # APU($2140)/WMDATA($2180) not in ppu_w
						el ppu_w[ breg, v ]
				el
					v : u8 [ 0 ]
					if [ bval ]
						if [ breg >= 0x2140 ] v = cpu_r[ breg ]  # APU/WMDATA reads go through the CPU bus (ppu_r knows nothing above $213F and returned 0)
						el v = ppu_r[ breg ]
					cpu_bank_w[ ab, ao, v ]
				if [ stepb == 0 ] ao = (ao + 1) & 0xFFFF
				el [ stepb == 2 ] ao = (ao - 1) & 0xFFFF
				steal_master += 8                          # per byte: 8 master (reference hardware transfer readA)
				dm += 8
				cd += 8
				while [ refresh_line < 262 ]               # DRAM refresh charged DURING the DMA (reference hardware edge per byte)
					rp : i32 [ refresh_rp[ refresh_line ] ]
					if [ dm < rp ] break
					steal_master += 40
					dm += 40
					refresh_line += 1                      # NOTE: refresh does NOT count into cd — reference hardware counter.dma excludes refresh masters (BDMA cdma=2066 while body=2104), so the final align is computed on the transfer clocks only
				while [ hline < 225 ]                      # HDMA dots crossing DURING a GP-DMA are serviced at the next per-byte edge (reference hardware Channel::edge; dmaActive already set, so no extra arm edge). excluded from cd like refresh (BDMA: body=4528 vs cdma=4376 = 3 refreshes + one interleaved HDMA line)
					hp : i32 [ hline * 1364 + 1104 ]
					if [ dm < hp ] break
					sm1 : i32 [ steal_master ]
					hsrc = 4
					hdma_run_line[ 8 ]
					hline += 1
					dm += steal_master - sm1
					cd += steal_master - sm1               # unlike refresh, interleaved HDMA goes through reference hardware Channel::step and DOES count into counter.dma — the final align must include it (BDMA f1498: fin=2 not 8)
				snap_lines[ dm ]
				i += 1
			cpu.memory[base + 5] = 0          # DAS counts down to 0 after transfer
			cpu.memory[base + 6] = 0
			if [ stepb != 1 ]                # A1T advances with the transfer (hardware updates $4302/$4303); fixed mode (stepb==1) leaves it
				cpu.memory[base + 2] = u8[ ao & 0xFF ]
				cpu.memory[base + 3] = u8[ ao >> 8 ]
		steal_master += ck - (cd % ck)                      # final align: reference hardware step(clockCount - counter.dma%clockCount) — clockCount is the width of the INTERRUPTED cycle (6 for internal-2nd-cycle ops like DEX, else the operand access speed), NOT always 8
		if [ env_dma && dbg_frames >= 1488 && dbg_frames <= 1503 ]
			printf[ "ADMA f%u sy=%d cd=%d ck=%d total=%d phase=%d M=%ld\n", dbg_frames, sy, cd, ck, cd + (ck - (cd % ck)), (master_phase + op_master) & 7, cpu_cycles * 6 ]
		count_cpu = true                                    # re-enable: do_dma now runs during the instruction AFTER the $420B write

	# --- HDMA ($420C): per-scanline DMA, ported from reference hardware dma.cpp ---
	# bytes transferred per HDMA line, indexed by transfer mode
	func hdma_len [ mode: u8 ] -> i32
		if [ mode == 0 ] return 1
		if [ mode == 2 ] return 2
		if [ mode == 6 ] return 2
		if [ mode == 1 ] return 2
		return 4

	# read the next table entry header for a channel; loads line count (+ indirect addr)
	func hdma_reload [ ch: i32 ]
		base     : u16  [ 0x4300 + (ch << 4) ]
		params   : u8   [ cpu.memory[base] ]
		indirect : bool [ (params & 0x40) != 0 ]
		a_bank   : u8   [ cpu.memory[base + 4] ]
		steal_master += 8                                  # reference hardware hdmaReload does the header readA (8 master) EVERY line for every active channel — the read is unconditional, only the reload logic is gated on the expired counter
		if [ (hdma_line[ch] & 0x7F) == 0 ]
			data : u8 [ cpu_bank_r[ a_bank, hdma_addr[ch] ] ]
			if [ env_hdmalog && dbg_frames >= 1488 && dbg_frames <= 1503 ]
				printf[ "ARLD f%u v=%d ch=%d hdr=%02X addr=%04X\n", dbg_frames, hline, ch, u32[data], u32[hdma_addr[ch]] ]
			hdma_line[ch] = data
			hdma_addr[ch] = (hdma_addr[ch] + 1) & 0xFFFF
			if [ data == 0 ]
				hdma_done[ch] = 1
				hdma_do[ch]   = 0
			el
				hdma_done[ch] = 0
				hdma_do[ch]   = 1
			if [ indirect ]
				lo : u8 [ cpu_bank_r[ a_bank, hdma_addr[ch] ] ]
				hdma_addr[ch] = (hdma_addr[ch] + 1) & 0xFFFF
				hi : u8 [ cpu_bank_r[ a_bank, hdma_addr[ch] ] ]
				hdma_addr[ch] = (hdma_addr[ch] + 1) & 0xFFFF
				steal_master += 16                         # indirect address (2 byte reads)
				hdma_ind[ch] = u16[lo] | (u16[hi] << 8)

	# transfer this line's bytes to the B-bus ($2100+). A->B only (direction 0).
	func hdma_transfer [ ch: i32 ]
		if [ hdma_done[ch] ] return
		if [ !hdma_do[ch] ] return
		base     : u16  [ 0x4300 + (ch << 4) ]
		params   : u8   [ cpu.memory[base] ]
		bbad     : u8   [ cpu.memory[base + 1] ]
		mode     : u8   [ params & 0x07 ]
		indirect : bool [ (params & 0x40) != 0 ]
		a_bank   : u8   [ cpu.memory[base + 4] ]
		i_bank   : u8   [ cpu.memory[base + 7] ]
		n        : i32  [ hdma_len[ mode ] ]
		steal_master += n * 8                              # one byte read per transferred byte (8 master each)
		for [ idx: i32 0, idx < n, idx += 1 ]
			boff : u8  [ dma_boff[ mode, idx ] ]
			breg : u16 [ 0x2100 + u16[bbad] + u16[boff] ]
			if [ indirect ]
				v : u8 [ cpu_bank_r[ i_bank, hdma_ind[ch] ] ]
				ppu_w[ breg, v ]
				hdma_ind[ch] = (hdma_ind[ch] + 1) & 0xFFFF
			el
				v : u8 [ cpu_bank_r[ a_bank, hdma_addr[ch] ] ]
				ppu_w[ breg, v ]
				hdma_addr[ch] = (hdma_addr[ch] + 1) & 0xFFFF

	func hdma_advance [ ch: i32 ]
		if [ hdma_done[ch] ] return
		hdma_line[ch] = (hdma_line[ch] - 1) & 0xFF
		if [ hdma_line[ch] & 0x80 ] hdma_do[ch] = 1
		el hdma_do[ch] = 0
		hdma_reload[ ch ]

	# frame start: point each enabled channel at its table and prime the first entry
	func hdma_setup [ ck: i32 ]
		en : u8 [ cpu.memory[0x420C] ]
		if [ env_hdmalog && dbg_frames == 150 ]
			printf[ "HDMA f%u en=%02X\n", dbg_frames, en ]
			for [ ch: i32 0, ch < 8, ch += 1 ]
				if [ (en & (1 << ch)) == 0 ] continue
				b : u16 [ 0x4300 + (ch << 4) ]
				printf[ "  ch%d DMAP=%02X BBAD=$21%02X (reg $21%02X) A1=%02X:%02X%02X mode=%d ind=%d\n",
					ch, cpu.memory[b], cpu.memory[b+1], cpu.memory[b+1],
					cpu.memory[b+4], cpu.memory[b+3], cpu.memory[b+2],
					cpu.memory[b] & 7, (cpu.memory[b] >> 6) & 1 ]
		sm0 : i32 [ steal_master ]
		if [ en != 0 ]
			steal_master += 8 - ((master_phase + op_master + steal_master) & 7)   # entry sync (reference hardware brackets hdmaSetup like hdmaRun)
			steal_master += 8                              # HDMA setup overhead (reference hardware hdmaSetup step<8>)
		for [ ch: i32 0, ch < 8, ch += 1 ]
			hdma_do[ch]   = 1
			hdma_done[ch] = 0
			if [ (en & (1 << ch)) == 0 ] continue
			base : u16 [ 0x4300 + (ch << 4) ]
			hdma_addr[ch] = u16[cpu.memory[base + 2]] | (u16[cpu.memory[base + 3]] << 8)
			hdma_line[ch] = 0
			hdma_reload[ ch ]
		if [ en != 0 ]
			cds : i32 [ steal_master - sm0 ]
			steal_master += ck - (cds % ck)                # exit align to the interrupted cycle's width (reference hardware clockCount — 6 when the servicing edge is an idle cycle)

	# one scanline: all channels transfer, then all advance (reference hardware order)
	func hdma_run_line [ ck: i32 ]
		en : u8 [ cpu.memory[0x420C] ]
		if [ en == 0 ] return
		# reference hardware raises the per-line event only if hdmaActive() = enable && !completed:
		# once every channel's table is consumed (zelda fade: v192), NO further line
		# events fire — no sync, no overhead, nothing. charging enabled-but-done lines
		# was 16/line of phantom cost between table end and the NMI latch.
		act : bool [ false ]
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ (en & (1 << ch)) && !hdma_done[ch] ] act = true
		if [ !act ] return
		hm0 : i32 [ steal_master ]
		# reference hardware brackets every per-line HDMA like GP-DMA: entry sync to the 8-master
		# grid on the absolute phase, exit re-align to the interrupted cycle's width
		# (ck = current access speed at the mid-instruction dot, 8 at frame-loop
		# boundaries). now that the trigger fires at the true dot the phase varies
		# per line like reference hardware's (per-line costs 30/36/40, not a locked constant).
		sy : i32 [ 8 - ((master_phase + op_master + steal_master) & 7) ]
		steal_master += sy
		steal_master += 8                                  # per-scanline HDMA run overhead (reference hardware hdmaRun step<8>)
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ en & (1 << ch) ] hdma_transfer[ ch ]
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ en & (1 << ch) ] hdma_advance[ ch ]
		cd : i32 [ steal_master - hm0 ]                    # reference hardware counter.dma: sync + all HDMA steps (refresh excluded — it's charged in cpu_tick_n, not here)
		steal_master += ck - (cd % ck)                     # exit align to the interrupted cycle width
		if [ env_hdmalog && dbg_frames >= 1488 && dbg_frames <= 1503 ]
			printf[ "AHL f%u v=%d cost=%d sy=%d ck=%d cd=%d src=%d pos=%d\n", dbg_frames, hline, steal_master - hm0, sy, ck, cd, hsrc, frame_master + op_master + hm0 ]

	# capture the registers HDMA mutates for scanline y so the renderer is per-line
	func snap_lines [ clk: i32 ]
		while [ sline < 224 ]
			if [ (sline + 1) * 1364 + 8 > clk ] break
			ppu_snapshot_line[ sline ]
			sline += 1

	func ppu_snapshot_line [ y: i32 ]
		line_mode[y] = ppu.bgmode
		line_tm[y]   = ppu.tm
		line_ts[y]   = ppu.ts
		line_inidisp[y] = ppu.inidisp
		for [ bg: i32 0, bg < 4, bg += 1 ]
			line_h[ bg * 224 + y ] = ppu.bg_hofs[bg]
			line_v[ bg * 224 + y ] = ppu.bg_vofs[bg]
			line_bgsc[ bg * 224 + y ] = ppu.bg_sc[bg]
		line_nba[ y ]       = ppu.bg_nba[0]
		line_nba[ 224 + y ] = ppu.bg_nba[1]
		line_m7a[y] = ppu.m7a
		line_m7b[y] = ppu.m7b
		line_m7c[y] = ppu.m7c
		line_m7d[y] = ppu.m7d
		line_coldata[y] = ppu.coldata
		line_cgadsub[y] = ppu.cgadsub
		line_cgwsel[y]  = ppu.cgwsel
		line_wobjsel[y] = ppu.wobjsel
		line_wobjlog[y] = ppu.wobjlog
		line_wh0[y]     = ppu.wh0
		line_wh1[y]     = ppu.wh1
		line_wh2[y]     = ppu.wh2
		line_wh3[y]     = ppu.wh3
		line_tmw[y]     = ppu.tmw
		line_tsw[y]     = ppu.tsw
		line_w12sel[y]  = ppu.w12sel
		line_w34sel[y]  = ppu.w34sel
		line_wbglog[y]  = ppu.wbglog

	# --- PPU register access ($2100-$213F) ---
	func ppu_vram_inc []
		sel : u8  [ ppu.vmain & 0x03 ]
		amt : u16 [ 1 ]
		if [ sel == 1 ] amt = 32
		el [ sel >= 2 ] amt = 128
		ppu.vram_addr = (ppu.vram_addr + amt) & 0xFFFF

	# VMAIN bits 2-3 address translation (8/9/10-bit remap). Matches reference hardware vramAddress().
	# Games enable this for tile uploads; without it dynamically-uploaded tiles garble.
	func ppu_vram_map [] -> u32
		a : u32 [ u32[ppu.vram_addr] ]
		m : u8  [ (ppu.vmain >> 2) & 3 ]
		if [ m == 1 ] return (a & 0x7F00) | ((a << 3) & 0x00F8) | ((a >> 5) & 7)
		if [ m == 2 ] return (a & 0x7E00) | ((a << 3) & 0x01F8) | ((a >> 6) & 7)
		if [ m == 3 ] return (a & 0x7C00) | ((a << 3) & 0x03F8) | ((a >> 7) & 7)
		return a & 0x7FFF

	func ppu_w [ addr: u16, val: u8 ]
		r : u8 [ addr & 0xFF ]
		if [ r == 0x00 ]                                  # INIDISP
			if [ env_joylog && dbg_ww < 400 ]
				printf[ "INIw f%u val=%02X line=%d pc=%02X:%04X\n", dbg_frames, u32[val], frame_master / 1364, cpu.pbr, cpu.pc ]
				dbg_ww += 1
			ppu.inidisp = val
		el [ r == 0x01 ]                                  # OBSEL
			ppu.obsel = val
		el [ r == 0x02 ]                                  # OAMADDL (word addr -> byte cursor)
			ppu.oamadd_reload = (ppu.oamadd_reload & 0x200) | (u16[val] << 1)
			ppu.oamadd = ppu.oamadd_reload
			ppu.oam_toggle = false
		el [ r == 0x03 ]                                  # OAMADDH
			ppu.oamadd_reload = ((u16[val] & 1) << 9) | (ppu.oamadd_reload & 0x1FF)
			ppu.oamadd = ppu.oamadd_reload
			ppu.oam_toggle = false
		el [ r == 0x04 ]                                  # OAMDATA write
			a : u16 [ ppu.oamadd & 0x3FF ]
			if [ a < 0x200 ]
				if [ (a & 1) == 0 ]
					ppu.oam_latch = val
				el
					ppu.oam[ a - 1 ] = ppu.oam_latch
					ppu.oam[ a ]     = val
			el [ a < 0x220 ]
				ppu.oam[ a ] = val
			ppu.oamadd = (ppu.oamadd + 1) & 0x3FF
		el [ r == 0x05 ]                                  # BGMODE
			ppu.bgmode = val
		el [ r == 0x06 ]                                  # MOSAIC
			ppu.mosaic = val
		el [ r >= 0x07 && r <= 0x0A ]                     # BGnSC
			ppu.bg_sc[ r - 0x07 ] = val
		el [ r == 0x0B ]                                  # BG12NBA
			ppu.bg_nba[0] = val
		el [ r == 0x0C ]                                  # BG34NBA
			ppu.bg_nba[1] = val
		el [ r >= 0x0D && r <= 0x14 ]                     # BGn H/V scroll (write-twice)
			bg : i32 [ (r - 0x0D) / 2 ]
			if [ ((r - 0x0D) & 1) == 0 ]
				ppu.bg_hofs[bg] = (u16[val] << 8) | (u16[ppu.ofs_latch] & 0xFFF8) | (u16[ppu.ofs_hl[bg]] & 7)
				ppu.ofs_latch  = val
				ppu.ofs_hl[bg] = val
			el
				ppu.bg_vofs[bg] = (u16[val] << 8) | u16[ppu.ofs_latch]
				ppu.ofs_latch = val
			if [ r == 0x0D ]                              # $210D also = Mode 7 H scroll
				ppu.m7hofs = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
				ppu.m7_latch = val
			el [ r == 0x0E ]                              # $210E also = Mode 7 V scroll
				ppu.m7vofs = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
				ppu.m7_latch = val
		el [ r == 0x15 ]                                  # VMAIN
			ppu.vmain = val
		el [ r == 0x16 ]                                  # VMADDL
			ppu.vram_addr = (ppu.vram_addr & 0xFF00) | u16[val]
		el [ r == 0x17 ]                                  # VMADDH
			ppu.vram_addr = (ppu.vram_addr & 0x00FF) | (u16[val] << 8)
		el [ r == 0x18 ]                                  # VMDATAL
			wa : u32 [ ppu_vram_map[] * 2 ]
			if [ env_vrw && wa >= 0x8000 && wa < 0xA000 ] printf[ "VW %04X L %02X\n", wa / 2, val ]
			ppu.vram[ wa ] = val
			if [ (ppu.vmain & 0x80) == 0 ] ppu_vram_inc[]
		el [ r == 0x19 ]                                  # VMDATAH
			wa : u32 [ ppu_vram_map[] * 2 ]
			if [ env_vrw && wa >= 0x8000 && wa < 0xA000 ] printf[ "VW %04X H %02X\n", wa / 2, val ]
			ppu.vram[ wa + 1 ] = val
			if [ ppu.vmain & 0x80 ] ppu_vram_inc[]
		el [ r == 0x1A ]                                  # M7SEL
			ppu.m7sel = val
		el [ r == 0x1B ]                                  # M7A (write-twice, shared latch)
			ppu.m7a = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x1C ]                                  # M7B
			ppu.m7b = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x1D ]                                  # M7C
			ppu.m7c = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x1E ]                                  # M7D
			ppu.m7d = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x1F ]                                  # M7X (center)
			ppu.m7x = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x20 ]                                  # M7Y (center)
			ppu.m7y = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x21 ]                                  # CGADD
			ppu.cgadd = val
			ppu.cg_toggle = false
		el [ r == 0x22 ]                                  # CGDATA write (2-byte)
			if [ !ppu.cg_toggle ]
				ppu.cg_latch = val
			el
				ci : u16 [ u16[ppu.cgadd] << 1 ]
				ppu.cgram[ ci ]     = ppu.cg_latch
				ppu.cgram[ ci + 1 ] = val
				ppu.cgadd = (ppu.cgadd + 1) & 0xFF
			ppu.cg_toggle = !ppu.cg_toggle
		el [ r == 0x23 ] ppu.w12sel = val                 # W12SEL
		el [ r == 0x24 ] ppu.w34sel = val                 # W34SEL
		el [ r == 0x25 ] ppu.wobjsel = val                # WOBJSEL
		el [ r == 0x26 ] ppu.wh0 = val                    # WH0 window1 left
		el [ r == 0x27 ] ppu.wh1 = val                    # WH1 window1 right
		el [ r == 0x28 ] ppu.wh2 = val                    # WH2 window2 left
		el [ r == 0x29 ] ppu.wh3 = val                    # WH3 window2 right
		el [ r == 0x2A ] ppu.wbglog = val                 # WBGLOG
		el [ r == 0x2B ] ppu.wobjlog = val                # WOBJLOG
		el [ r == 0x2C ]                                  # TM (main screen)
			ppu.tm = val
		el [ r == 0x2D ]                                  # TS (sub screen)
			ppu.ts = val
		el [ r == 0x2E ] ppu.tmw = val                    # TMW (window main-screen disable)
		el [ r == 0x2F ] ppu.tsw = val                    # TSW (window sub-screen disable)
		el [ r == 0x30 ]                                  # CGWSEL
			ppu.cgwsel = val
		el [ r == 0x31 ]                                  # CGADSUB
			ppu.cgadsub = val
		el [ r == 0x32 ]                                  # COLDATA (fixed color)
			inten : u16 [ u16[val] & 0x1F ]
			if [ val & 0x20 ] ppu.coldata = (ppu.coldata & 0x7FE0) | inten
			if [ val & 0x40 ] ppu.coldata = (ppu.coldata & 0x7C1F) | (inten << 5)
			if [ val & 0x80 ] ppu.coldata = (ppu.coldata & 0x03FF) | (inten << 10)
		el [ r == 0x33 ]                                  # SETINI
			ppu.setini = val

	func ppu_r [ addr: u16 ] -> u8
		r : u8 [ addr & 0xFF ]
		if [ r == 0x38 ]                                  # OAMDATAREAD
			a : u16 [ ppu.oamadd & 0x3FF ]
			v : u8  [ 0 ]
			if [ a < 0x220 ] v = ppu.oam[a]
			ppu.oamadd = (ppu.oamadd + 1) & 0x3FF
			return v
		el [ r == 0x39 ]                                  # VMDATALREAD
			v : u8 [ u8[ppu.vram_pre & 0xFF] ]
			if [ (ppu.vmain & 0x80) == 0 ]
				wa : u32 [ ppu_vram_map[] * 2 ]
				ppu.vram_pre = u16[ppu.vram[wa]] | (u16[ppu.vram[wa + 1]] << 8)
				ppu_vram_inc[]
			return v
		el [ r == 0x3A ]                                  # VMDATAHREAD
			v : u8 [ u8[ppu.vram_pre >> 8] ]
			if [ ppu.vmain & 0x80 ]
				wa : u32 [ ppu_vram_map[] * 2 ]
				ppu.vram_pre = u16[ppu.vram[wa]] | (u16[ppu.vram[wa + 1]] << 8)
				ppu_vram_inc[]
			return v
		el [ r == 0x3B ]                                  # CGDATAREAD
			cb  : u16 [ 0 ]
			if [ ppu.cg_toggle ] cb = 1
			idx : u16 [ (u16[ppu.cgadd] << 1) | cb ]
			v   : u8  [ ppu.cgram[idx] ]
			if [ ppu.cg_toggle ] ppu.cgadd = (ppu.cgadd + 1) & 0xFF
			ppu.cg_toggle = !ppu.cg_toggle
			return v
		el [ r == 0x34 ]                                  # MPYL: signed M7A(16) * M7B_hi(8), 24-bit product
			if [ env_mpylog ]
				printf[ "MPY f%u m7a=%d m7b=%d\n", dbg_frames, i32[ppu.m7a], i32[ i8[ u8[ u16[ppu.m7b] >> 8 ] ] ] ]
			return u8[ (i32[ppu.m7a] * i32[ i8[ u8[ u16[ppu.m7b] >> 8 ] ] ]) & 0xFF ]
		el [ r == 0x35 ]                                  # MPYM
			return u8[ ((i32[ppu.m7a] * i32[ i8[ u8[ u16[ppu.m7b] >> 8 ] ] ]) >> 8) & 0xFF ]
		el [ r == 0x36 ]                                  # MPYH
			return u8[ ((i32[ppu.m7a] * i32[ i8[ u8[ u16[ppu.m7b] >> 8 ] ] ]) >> 16) & 0xFF ]
		el [ r == 0x37 ]                                  # SLHV: latch H/V counters at the current dot
			pos : i32 [ frame_master + op_master + steal_master ]
			ppu.opvct = u16[ (pos / 1364) % 262 ]
			ppu.ophct = u16[ (pos % 1364) / 4 ]
			ppu.hv_latched = true
			return 0x00
		el [ r == 0x3C ]                                  # OPHCT: latched H, low byte then bit8
			v : u8 [ u8[ppu.ophct & 0xFF] ]
			if [ ppu.ophct_tog ] v = u8[ (ppu.ophct >> 8) & 1 ]
			ppu.ophct_tog = !ppu.ophct_tog
			return v
		el [ r == 0x3D ]                                  # OPVCT: latched V, low byte then bit8
			v : u8 [ u8[ppu.opvct & 0xFF] ]
			if [ ppu.opvct_tog ] v = u8[ (ppu.opvct >> 8) & 1 ]
			ppu.opvct_tog = !ppu.opvct_tog
			return v
		el [ r == 0x3E ]                                  # STAT77 (PPU1 5C77, version 1)
			return 0x01
		el [ r == 0x3F ]                                  # STAT78 (PPU2 5C78, NTSC, version 3); read resets latch + toggles
			v : u8 [ 0x03 ]
			if [ ppu.hv_latched ] v = 0x43
			ppu.ophct_tog = false
			ppu.opvct_tog = false
			ppu.hv_latched = false
			return v
		return 0x00

	# CGRAM color index -> 15-bit BGR555 word
	func ppu_cgram_color [ idx: u32 ] -> u16
		ci : u32 [ idx * 2 ]
		if [ use_shot ]
			return u16[ppu.cgram_shot[ci]] | (u16[ppu.cgram_shot[ci + 1]] << 8)
		lo : u16 [ u16[ppu.cgram[ci]] ]
		hi : u16 [ u16[ppu.cgram[ci + 1]] ]
		return lo | (hi << 8)

	# BGR555 word + brightness(0-15) -> RGBA8 (R low byte, matches R8G8B8A8 UNORM)
	func ppu_color [ w: u16, bright: u32 ] -> u32
		r5 : u32 [ u32[w] & 0x1F ]
		g5 : u32 [ (u32[w] >> 5) & 0x1F ]
		b5 : u32 [ (u32[w] >> 10) & 0x1F ]
		r8 : u32 [ (r5 << 3) | (r5 >> 2) ]
		g8 : u32 [ (g5 << 3) | (g5 >> 2) ]
		b8 : u32 [ (b5 << 3) | (b5 >> 2) ]
		r8 = (r8 * bright) / 15
		g8 = (g8 * bright) / 15
		b8 = (b8 * bright) / 15
		return 0xFF000000 | (b8 << 16) | (g8 << 8) | r8

	# read one OAM byte (from the end-of-active-display snapshot during rendering)
	func ppu_ob [ i: i32 ] -> u8
		if [ use_shot ] return ppu.oam_shot[i]
		return ppu.oam[i]

	# read one VRAM word (15-bit word address)
	func ppu_vw [ waddr: u32 ] -> u32
		b : u32 [ (waddr & 0x7FFF) * 2 ]
		if [ use_shot ] return u32[ppu.vram_shot[b]] | (u32[ppu.vram_shot[b + 1]] << 8)
		return u32[ppu.vram[b]] | (u32[ppu.vram[b + 1]] << 8)

	# Render ONE scanline of one background layer (bg 0..3, bpp 2 or 4). 8x8 tiles,
	# per-line H/V scroll (from the HDMA snapshot), tile flip, 32/64 tilemaps.
	# Is BG `bg` pixel (x,y) masked off (disabled) on this screen by its window?
	# screen: 0 = main (TMW), 1 = sub (TSW). Games like F-Zero double-buffer dialogs
	# on BG1/BG2 and use window1 + TMW to mask the stale layer, revealing the live one.
	func bg_win_masked [ bg: i32, x: i32, y: i32, screen: i32 ] -> bool
		tmw : u8 [ line_tmw[y] ]
		if [ screen ] tmw = line_tsw[y]
		if [ (tmw & (1 << bg)) == 0 ] return false        # BG not window-masked here
		sel : u8 [ line_w12sel[y] ]
		if [ bg >= 2 ] sel = line_w34sel[y]
		sh  : u32 [ 0 ]
		if [ bg & 1 ] sh = 4                               # BG2/BG4 use the high nibble
		s   : u32 [ (u32[sel] >> sh) & 0x0F ]
		w1en : bool [ (s & 2) != 0 ]
		w1inv: bool [ (s & 1) != 0 ]
		w2en : bool [ (s & 8) != 0 ]
		w2inv: bool [ (s & 4) != 0 ]
		if [ !w1en && !w2en ] return false                # no window enabled => empty mask
		in1 : bool [ u32[x] >= u32[line_wh0[y]] && u32[x] <= u32[line_wh1[y]] ]
		in2 : bool [ u32[x] >= u32[line_wh2[y]] && u32[x] <= u32[line_wh3[y]] ]
		if [ w1inv ] in1 = !in1
		if [ w2inv ] in2 = !in2
		if [ w1en && !w2en ] return in1
		if [ !w1en && w2en ] return in2
		lg : u32 [ (u32[line_wbglog[y]] >> (bg * 2)) & 3 ]
		if   [ lg == 0 ] return in1 || in2
		if   [ lg == 1 ] return in1 && in2
		if   [ lg == 2 ] return in1 != in2
		return in1 == in2

	# Color idx 0 = transparent. Priority/16x16 not fully handled; BG window masking applied.
	func ppu_bg_line [ bg: i32, bpp: i32, y: i32, bright: u32, want_prio: u32 ]
		# y may lie in the ±16 overscan band in layer mode — register/window
		# lookups clamp to the visible line; scroll math keeps the real y
		yr    : i32 [ y ]
		if [ yr < 0 ] yr = 0
		if [ yr > 223 ] yr = 223
		sc    : u8  [ line_bgsc[ bg * 224 + yr ] ]
		tbase : u32 [ (u32[sc >> 2] & 0x3F) * 0x400 ]    # tilemap base (word)
		nb    : u8  [ line_nba[ (bg >> 1) * 224 + yr ] ]
		nibble: u32 [ u32[nb] & 0x0F ]
		if [ bg & 1 ] nibble = (u32[nb] >> 4) & 0x0F
		cbase : u32 [ nibble * 0x1000 ]                  # char data base (word)
		w64   : bool [ (sc & 1) != 0 ]
		h64   : bool [ (sc & 2) != 0 ]
		big   : bool [ ((u32[line_mode[yr]] >> (4 + bg)) & 1) != 0 ]   # BGMODE bits 4-7: 16x16 tiles per BG (ff3 battle animation layer)
		tshift: u32 [ 3 ]
		if [ big ] tshift = 4
		hofs  : u32 [ u32[line_h[ bg * 224 + yr ]] & 0x3FF ]
		vofs  : u32 [ u32[line_v[ bg * 224 + yr ]] & 0x3FF ]
		hmask : u32 [ 0xFF ]
		vmask : u32 [ 0xFF ]
		if [ w64 ] hmask = 0x1FF
		if [ h64 ] vmask = 0x1FF
		if [ big ]
			hmask = (hmask << 1) | 1                     # 16px tiles double the pixel span of the 32x32 entry map
			vmask = (vmask << 1) | 1
		tilesz: u32 [ 16 ]                               # 4bpp tile = 16 words
		if [ bpp == 2 ] tilesz = 8                       # 2bpp tile = 8 words
		sy : u32 [ (u32[y + 1] + vofs) & vmask ]         # framebuf row y = hardware scanline y+1 (line 0 is never displayed; reference hardware shows V=1..224)
		scr : i32 [ 0 ]
		if [ rendering_sub ] scr = 1
		x0 : i32 [ 0 ]
		x1 : i32 [ 256 ]
		if [ lay_en ]
			x0 = -16                                     # overscan bleed columns (glide reveal)
			x1 = 272
		for [ x: i32 x0, x < x1, x += 1 ]
			if [ x >= 0 && x < 256 && y >= 0 && y < 224 ]
				if [ bg_win_masked[ bg, x, yr, scr ] ] continue
			sx : u32 [ (u32[x] + hofs) & hmask ]
			tx : u32 [ sx >> tshift ]
			ty : u32 [ sy >> tshift ]
			blk: u32 [ 0 ]
			if [ tx & 32 ] blk += 1
			if [ ty & 32 ]
				if [ w64 ] blk += 2
				el blk += 1
			ent : u32 [ tbase + blk * 0x400 + (ty & 31) * 32 + (tx & 31) ]
			e   : u32 [ ppu_vw[ ent ] ]
			if [ ((e >> 13) & 1) != want_prio ] continue   # only this priority level
			tile: u32 [ e & 0x3FF ]
			pal : u32 [ (e >> 10) & 7 ]
			tmax: u32 [ (u32[1] << tshift) - 1 ]
			px  : u32 [ sx & tmax ]
			py  : u32 [ sy & tmax ]
			if [ e & 0x4000 ] px = tmax - px
			if [ e & 0x8000 ] py = tmax - py
			if [ big ]                                    # 16x16: entry names the top-left 8x8; right +1, bottom row +16
				if [ px >= 8 ] tile += 1
				if [ py >= 8 ] tile += 16
				tile = tile & 0x3FF
				px = px & 7
				py = py & 7
			bit : u32 [ 7 - px ]
			base: u32 [ cbase + tile * tilesz + py ]
			w01 : u32 [ ppu_vw[ base ] ]
			idx : u32 [ ((w01 >> bit) & 1) | (((w01 >> (bit + 8)) & 1) << 1) ]
			if [ bpp == 4 ]
				w23 : u32 [ ppu_vw[ base + 8 ] ]
				idx = idx | (((w23 >> bit) & 1) << 2) | (((w23 >> (bit + 8)) & 1) << 3)
			if [ idx ]
				cgidx : u32 [ pal * 16 + idx ]
				if [ bpp == 2 ] cgidx = pal * 4 + idx
				bgrv : u16 [ ppu_cgram_color[ cgidx ] ]
				di   : i32 [ y * 256 + x ]
				if [ rendering_sub ]
					ppu.sub_bgr[ di ] = bgrv
					ppu.sub_src[ di ] = u8[bg]
				el [ lay_en ]
					# composed top pixel already carries color math + windows +
					# brightness — copy it so glide frames match still frames
					# exactly; only occluded pixels lack math (edge slivers)
					dl : i32 [ (y + 16) * 288 + (x + 16) ]
					cp : bool [ false ]
					if [ x >= 0 && x < 256 && y >= 0 && y < 224 ]
						if [ ppu.px_src[ di ] == u8[bg] ] cp = true
					if [ cp ]
						lay_out[ dl ] = ppu.framebuf[ di ]
					el
						xc : i32 [ x ]
						if [ xc < 0 ] xc = 0
						if [ xc > 255 ] xc = 255
						lay_out[ dl ] = lay_math_px[ bgrv, bg, xc, yr, bright ]
				el
					ppu.framebuf[ di ] = ppu_color[ bgrv, bright ]
					ppu.px_bgr[ di ]   = bgrv
					ppu.px_src[ di ]   = u8[bg]

	# Phase 3: render the framebuffer from real PPU state, PER SCANLINE using the
	# HDMA snapshots (line_mode / line_h / line_v / line_tm). Backdrop first, then
	# Mode 1 BG layers (BG3 back -> BG1 front) for whatever mode that line is in.
	# Sprite (OBJ) layer. 4bpp, palettes 8-15 (CGRAM 128+pal*16). OBSEL size pairs,
	# 9-bit X (high OAM), 9-bit tile (name select), H/V flip, 16x16 tile-grid wrap.
	# Builds the obj_color / obj_prio buffers (drawn 127->0 so sprite 0 wins per pixel);
	# the composite step interleaves these by priority with the BG layers.
	# No 32/34 per-line limit yet.
	func ppu_sprites [ bright: u32 ]
		for [ i: i32 0, i < 256 * 224, i += 1 ]
			ppu.obj_color[i] = 0
		ws : local u8 [ 16 ] [ 8, 8, 8, 16, 16, 32, 16, 16, 16, 32, 64, 32, 64, 64, 32, 32 ]
		hs : local u8 [ 16 ] [ 8, 8, 8, 16, 16, 32, 32, 32, 16, 32, 64, 32, 64, 64, 64, 32 ]
		obsel : u8  [ ppu.obsel ]
		tbase : u32 [ (u32[obsel] << 13) & 0x6000 ]
		nsel  : u32 [ (u32[obsel] >> 3) & 3 ]
		bsize : u32 [ (u32[obsel] >> 5) & 7 ]
		n : i32 [ 127 ]
		while [ n >= 0 ]
			o     : i32 [ n * 4 ]
			b0    : u8  [ ppu_ob[o] ]
			b1    : u8  [ ppu_ob[o + 1] ]
			b2    : u8  [ ppu_ob[o + 2] ]
			b3    : u8  [ ppu_ob[o + 3] ]
			hbyte : u8  [ ppu_ob[512 + (n >> 2)] ]
			hbits : u32 [ (u32[hbyte] >> ((n & 3) * 2)) & 3 ]
			big   : u32 [ (hbits >> 1) & 1 ]
			sw    : i32 [ i32[ws[ big * 8 + bsize ]] ]
			sh    : i32 [ i32[hs[ big * 8 + bsize ]] ]
			fx    : i32 [ i32[b0] | (i32[hbits & 1] << 8) ]
			if [ fx >= 256 ] fx -= 512
			pal   : u32 [ (u32[b3] >> 1) & 7 ]
			oprio : u32 [ (u32[b3] >> 4) & 3 ]
			hflip : u32 [ (u32[b3] >> 6) & 1 ]
			vflip : u32 [ (u32[b3] >> 7) & 1 ]
			nlo   : u32 [ u32[b2] ]
			taddr : u32 [ tbase ]
			if [ b3 & 1 ] taddr = tbase + ((1 + nsel) << 12)
			cgb   : u32 [ 128 + pal * 16 ]
			oy : i32 [ 0 ]
			while [ oy < sh ]
				scy : i32 [ (i32[b1] + oy) & 0xFF ]
				if [ scy < 224 && (line_tm[scy] & 0x10) ]
					syp : i32 [ oy ]
					if [ vflip ] syp = sh - 1 - oy
					cy  : u32 [ ((nlo >> 4) + u32[syp >> 3]) & 0x0F ]
					ox : i32 [ 0 ]
					while [ ox < sw ]
						scx : i32 [ fx + ox ]
						if [ scx >= 0 && scx < 256 ]
							sxp  : i32 [ ox ]
							if [ hflip ] sxp = sw - 1 - ox
							cx   : u32 [ ((nlo & 0x0F) + u32[sxp >> 3]) & 0x0F ]
							addr : u32 [ taddr + (cy * 16 + cx) * 16 + u32[syp & 7] ]
							w01  : u32 [ ppu_vw[ addr ] ]
							w23  : u32 [ ppu_vw[ addr + 8 ] ]
							bit  : u32 [ u32[7 - (sxp & 7)] ]
							col  : u32 [ ((w01 >> bit) & 1) | (((w01 >> (bit + 8)) & 1) << 1) | (((w23 >> bit) & 1) << 2) | (((w23 >> (bit + 8)) & 1) << 3) ]
							if [ col ]
								di : i32 [ scy * 256 + scx ]
								ocol : u16 [ ppu_cgram_color[ cgb + col ] ]
								ppu.obj_color[di] = ppu_color[ ocol, bright ]
								ppu.obj_bgr[di]   = ocol
								ppu.obj_prio[di]  = u8[oprio]
								ppu.obj_idx[di]   = u8[n]
						ox += 1
				oy += 1
			n -= 1

	# composite the sprite buffer for one scanline at a given OBJ priority level
	func ppu_obj_line [ y: i32, want_prio: u32, bright: u32 ]
		base : i32 [ y * 256 ]
		for [ x: i32 0, x < 256, x += 1 ]
			i : i32 [ base + x ]
			if [ ppu.obj_color[i] != 0 && u32[ppu.obj_prio[i]] == want_prio ]
				ppu.framebuf[i] = ppu_color[ ppu.obj_bgr[i], bright ]   # per-line brightness from the pre-brightness BGR555 plane
				ppu.px_bgr[i]   = ppu.obj_bgr[i]
				ppu.px_src[i]   = 5                     # OBJ (CGADSUB bit4)

	# sprite scanline into the provenance layers: world sprites (ride the BG1
	# camera) vs screen sprites (pinned), split by the classified OAM index
	func ppu_obj_layer [ y: i32, bright: u32 ]
		base : i32 [ y * 256 ]
		for [ x: i32 0, x < 256, x += 1 ]
			i : i32 [ base + x ]
			if [ ppu.obj_color[i] != 0 ]
				# only pixels where the sprite WON the composed per-pixel
				# priority battle — where a high-prio BG covers the sprite
				# (doorway walls over Link) the layer keeps a transparent
				# hole, and the covering BG shows through. sprite and wall
				# share a glide offset, so the hole stays aligned in motion.
				if [ ppu.px_src[i] == 5 ]
					oi : i32 [ i32[ ppu.obj_idx[i] ] ]
					if [ spr_world[ oi ] != 0 ] lay_sw[i] = ppu.framebuf[i]
					el lay_ss[i] = ppu.framebuf[i]

	# slot-independent position-set matching (rgen pattern): a sprite is WORLD
	# if some sprite sat exactly one camera-delta away last frame AND isn't
	# also parked at its own old position. Handles SAT shuffling.
	func classify_sprites [ d1x: i32, d1y: i32, d2x: i32, d2y: i32 ]
		use_shot = shot_valid
		curx : local i32 [ 128 ]
		cury : local i32 [ 128 ]
		wm1  : local u8 [ 128 ]
		wm2  : local u8 [ 128 ]
		wsf  : local u8 [ 128 ]
		for [ n: i32 0, n < 128, n += 1 ]
			o     : i32 [ n * 4 ]
			b0    : u8  [ ppu_ob[o] ]
			b1    : u8  [ ppu_ob[o + 1] ]
			hbyte : u8  [ ppu_ob[512 + (n >> 2)] ]
			hbits : u32 [ (u32[hbyte] >> ((n & 3) * 2)) & 3 ]
			fx    : i32 [ i32[b0] | (i32[hbits & 1] << 8) ]
			if [ fx >= 256 ] fx -= 512
			curx[n] = fx
			cury[n] = i32[b1]
			wm1[n] = 0
			wm2[n] = 0
			wsf[n] = 0
		moving : bool [ d1x != 0 || d1y != 0 || spr_m1x != 0 || spr_m1y != 0 ]
		if [ d2x != 0 || d2y != 0 || spr_m2x != 0 || spr_m2y != 0 ] moving = true
		if [ moving ]
			# games write sprites a frame out of phase with the scroll regs, so
			# each plane matches on THIS frame's delta or LAST frame's. an
			# unmoved sprite (self-match) is neutral — misses only count when
			# the sprite moved off-pattern.
			tol1 : i32 [ 1 ]
			a1 : i32 [ d1x ]
			if [ a1 < 0 ] a1 = 0 - a1
			a2 : i32 [ d1y ]
			if [ a2 < 0 ] a2 = 0 - a2
			if [ a1 <= 1 && a2 <= 1 ] tol1 = 0
			tol2 : i32 [ 1 ]
			a3 : i32 [ d2x ]
			if [ a3 < 0 ] a3 = 0 - a3
			a4 : i32 [ d2y ]
			if [ a4 < 0 ] a4 = 0 - a4
			if [ a3 <= 1 && a4 <= 1 ] tol2 = 0
			c1 : i32 [ 0 ]
			c2 : i32 [ 0 ]
			for [ n: i32 0, n < 128, n += 1 ]
				if [ cury[n] >= 224 ] continue         # offscreen park: keep prior class
				# asymmetric tolerance: STRICT to attach (Link's bobbing head must
				# not accumulate matches), LOOSE to stay attached (a walking enemy
				# = world delta + own animation step; detaching it to the pinned
				# layer makes it jiggle against the glide)
				t1 : i32 [ tol1 ]
				t2 : i32 [ tol2 ]
				if [ spr_world[n] != 0 ]
					if [ t1 < 1 ] t1 = 1
					if [ t2 < 1 ] t2 = 1
				w1x : i32 [ curx[n] + d1x ]
				w1y : i32 [ cury[n] + d1y ]
				l1x : i32 [ curx[n] + spr_m1x ]
				l1y : i32 [ cury[n] + spr_m1y ]
				w2x : i32 [ curx[n] + d2x ]
				w2y : i32 [ cury[n] + d2y ]
				l2x : i32 [ curx[n] + spr_m2x ]
				l2y : i32 [ cury[n] + spr_m2y ]
				for [ j: i32 0, j < 128, j += 1 ]
					if [ d1x != 0 || d1y != 0 ]
						jx : i32 [ spr_prevx[j] - w1x ]
						jy : i32 [ spr_prevy[j] - w1y ]
						if [ jx >= (0 - t1) && jx <= t1 ] if [ jy >= (0 - t1) && jy <= t1 ] wm1[n] = 1
					if [ spr_m1x != 0 || spr_m1y != 0 ]
						kx : i32 [ spr_prevx[j] - l1x ]
						ky : i32 [ spr_prevy[j] - l1y ]
						if [ kx >= (0 - t1) && kx <= t1 ] if [ ky >= (0 - t1) && ky <= t1 ] wm1[n] = 1
					if [ d2x != 0 || d2y != 0 ]
						mx : i32 [ spr_prevx[j] - w2x ]
						my : i32 [ spr_prevy[j] - w2y ]
						if [ mx >= (0 - t2) && mx <= t2 ] if [ my >= (0 - t2) && my <= t2 ] wm2[n] = 1
					if [ spr_m2x != 0 || spr_m2y != 0 ]
						nx : i32 [ spr_prevx[j] - l2x ]
						ny : i32 [ spr_prevy[j] - l2y ]
						if [ nx >= (0 - t2) && nx <= t2 ] if [ ny >= (0 - t2) && ny <= t2 ] wm2[n] = 1
					if [ spr_prevx[j] == curx[n] ] if [ spr_prevy[j] == cury[n] ] wsf[n] = 1
				if [ wsf[n] == 0 ]
					if [ wm1[n] != 0 ] c1 += 1
					if [ wm2[n] != 0 ] c2 += 1
			# anchor the world layer to the plane the sprites actually follow;
			# clear margin so the anchor never flaps between planes
			if [ c2 > c1 + 2 ] spr_anchor = 1
			if [ c1 > c2 + 2 ] spr_anchor = 0
			adx : i32 [ d1x ]
			ady : i32 [ d1y ]
			if [ spr_anchor == 1 ]
				adx = d2x
				ady = d2y
			anchor_moving : bool [ adx != 0 || ady != 0 ]
			for [ n: i32 0, n < 128, n += 1 ]
				if [ cury[n] >= 224 ] continue
				fm : bool [ wm1[n] != 0 ]
				if [ spr_anchor == 1 ] fm = wm2[n] != 0
				# evidence: +1 = moved exactly with the world; -1 = moved
				# off-pattern OR sat still while the world moved (a world
				# sprite MUST move when the world does); 0 = neutral
				ev : i32 [ 0 ]
				if [ fm && wsf[n] == 0 ] ev = 1
				el [ wsf[n] == 0 ] ev = 0 - 1
				el [ anchor_moving && !fm ] ev = 0 - 1
				if [ ev > 0 ]
					spr_miss[n] = 0
					if [ spr_hit[n] < 15 ] spr_hit[n] += 1
					if [ spr_hit[n] >= 2 ] spr_world[n] = 1
				el [ ev < 0 ]
					spr_hit[n] = 0
					if [ spr_miss[n] < 15 ] spr_miss[n] += 1
					if [ spr_world[n] != 0 && getenv[ 'ASNES_GLIDE' ] && dbg_spr < 200 ]
						printf[ "SPRC f%u n=%d cur=%d,%d anchor=%d d1=%d,%d d2=%d,%d miss=%d self=%d\n",
							dbg_frames, n, curx[n], cury[n], spr_anchor, d1x, d1y, d2x, d2y, i32[spr_miss[n]], i32[wsf[n]] ]
						dbg_spr += 1
					if [ spr_miss[n] >= 3 ] spr_world[n] = 0
		spr_m1x = d1x
		spr_m1y = d1y
		spr_m2x = d2x
		spr_m2y = d2y
		for [ n: i32 0, n < 128, n += 1 ]
			spr_prevx[n] = curx[n]
			spr_prevy[n] = cury[n]
		use_shot = false

	# provenance-layer render (glide frames only): same per-line tile fetch as
	# the composed path, but each BG lands in its own transparent buffer so the
	# render thread can glide them independently. Priority is flattened per BG
	# (BG3 back or front by BGMODE bit3) — the composed path still runs for
	# every non-glide frame, so flattening only ever exists in motion.
	func ppu_render_layers [ frame_b3: bool ]
		use_shot = shot_valid
		for [ i: i32 0, i < 73728, i += 1 ]
			lay_bg1[i] = 0
			lay_bg2[i] = 0
			lay_bg3[i] = 0
		for [ i: i32 0, i < 57344, i += 1 ]
			lay_sw[i]  = 0
			lay_ss[i]  = 0
		bg : u16 [ ppu_cgram_color[ 0 ] ]
		blay : ref u32 [ lay_bg3 ]                     # backdrop rides the first-drawn layer
		if [ frame_b3 ] blay = lay_bg2
		for [ y: i32 -16, y < 240, y += 1 ]
			yr : i32 [ y ]
			if [ yr < 0 ] yr = 0
			if [ yr > 223 ] yr = 223
			li     : u8  [ line_inidisp[yr] ]
			bright : u32 [ u32[li] & 0x0F ]
			if [ li & 0x80 ] bright = 0
			px : u32 [ ppu_color[ bg, bright ] ]
			for [ X2: i32 0, X2 < 288, X2 += 1 ]
				dl2 : i32 [ (y + 16) * 288 + X2 ]
				dc2 : i32 [ y * 256 + (X2 - 16) ]
				cp2 : bool [ false ]
				if [ y >= 0 && y < 224 && X2 >= 16 && X2 < 272 ]
					if [ ppu.px_src[ dc2 ] == 8 ] cp2 = true
				if [ cp2 ] blay[ dl2 ] = ppu.framebuf[ dc2 ]
				el
					xc2 : i32 [ X2 - 16 ]
					if [ xc2 < 0 ] xc2 = 0
					if [ xc2 > 255 ] xc2 = 255
					blay[ dl2 ] = lay_math_px[ bg, 8, xc2, yr, bright ]
			if [ bright == 0 ] continue
			mode : u8 [ line_mode[yr] & 7 ]
			if [ mode > 1 ] continue                   # 8bpp / offset-per-tile modes stay composed
			tm    : u8  [ line_tm[yr] ]
			b1bpp : i32 [ 4 ]
			if [ mode == 0 ] b1bpp = 2
			if [ tm & 0x04 ]
				lay_en  = true
				lay_out = lay_bg3
				ppu_bg_line[ 2, 2, y, bright, 0 ]
				ppu_bg_line[ 2, 2, y, bright, 1 ]
			if [ tm & 0x02 ]
				lay_en  = true
				lay_out = lay_bg2
				ppu_bg_line[ 1, b1bpp, y, bright, 0 ]
				ppu_bg_line[ 1, b1bpp, y, bright, 1 ]
			if [ tm & 0x01 ]
				lay_en  = true
				lay_out = lay_bg1
				ppu_bg_line[ 0, b1bpp, y, bright, 0 ]
				ppu_bg_line[ 0, b1bpp, y, bright, 1 ]
			lay_en = false
			if [ y >= 0 && y < 224 ] if [ tm & 0x10 ] ppu_obj_layer[ y, bright ]
		use_shot = false

	# subtractive color math in BGR555 space (clamped, optional half). Used for the
	# Mode 7 distance fog: each scanline subtracts the HDMA'd COLDATA from the plane.
	func ppu_cmath_sub [ main: u16, sub: u16, hf: bool ] -> u16
		rr : i32 [ i32[main & 0x1F] - i32[sub & 0x1F] ]
		gg : i32 [ i32[(main >> 5) & 0x1F] - i32[(sub >> 5) & 0x1F] ]
		bb : i32 [ i32[(main >> 10) & 0x1F] - i32[(sub >> 10) & 0x1F] ]
		if [ rr < 0 ] rr = 0
		if [ gg < 0 ] gg = 0
		if [ bb < 0 ] bb = 0
		if [ hf ]
			rr >>= 1
			gg >>= 1
			bb >>= 1
		return u16[ rr | (gg << 5) | (bb << 10) ]

	# additive color math in BGR555 space (clamped, optional half). Used for HUD
	# fills like F-Zero's POWER bar: COLDATA red added to BG/backdrop inside a window.
	func ppu_cmath_add [ main: u16, add: u16, hf: bool ] -> u16
		rr : i32 [ i32[main & 0x1F] + i32[add & 0x1F] ]
		gg : i32 [ i32[(main >> 5) & 0x1F] + i32[(add >> 5) & 0x1F] ]
		bb : i32 [ i32[(main >> 10) & 0x1F] + i32[(add >> 10) & 0x1F] ]
		if [ hf ]
			rr >>= 1
			gg >>= 1
			bb >>= 1
		if [ rr > 31 ] rr = 31
		if [ gg > 31 ] gg = 31
		if [ bb > 31 ] bb = 31
		return u16[ rr | (gg << 5) | (bb << 10) ]

	# Apply CGADSUB color math to one composited (mode-1) scanline using the per-pixel
	# source layer (px_src) + window (fog_enabled). bit7=subtract else add; bit6=half.
	# Layer bits: 0-3=BG1-4, 4=OBJ, 5=backdrop. Mode 7 does its math inline in ppu_m7_line.
	func ppu_cmath_line [ y: i32, bright: u32 ]
		cg : u8 [ line_cgadsub[y] ]
		if [ (cg & 0x3F) == 0 ] return
		base : i32 [ y * 256 ]
		for [ x: i32 0, x < 256, x += 1 ]
			i : i32 [ base + x ]
			if [ (ppu.framebuf[i] >> 24) == 0 ] continue   # GPU-owned hole (Mode-7 plane beneath): the 2D layer has no pixel here — its math happens in the m7 shader; writing an opaque result blacked out the plane
			s : u8 [ ppu.px_src[i] ]
			mbit : u8 [ 0x20 ]
			if [ s < 4 ] mbit = u8[1 << s]
			el [ s == 5 ] mbit = 0x10
			if [ (cg & mbit) == 0 ] continue
			if [ !fog_enabled[ x, y ] ] continue
			cwv : u16 [ ppu.px_bgr[i] ]
			other : u16 [ line_coldata[y] ]
			hf : bool [ (cg & 0x40) != 0 ]
			if [ (line_cgwsel[y] & 0x02) != 0 ]
				other = ppu.sub_bgr[i]
				if [ ppu.sub_src[i] == 0xFF ] hf = false   # sub pixel is the COL backdrop: reference hardware cancels halve when the operand is the COL backdrop — ff3 title logo stays white through add-halve math
			if [ cg & 0x80 ] cwv = ppu_cmath_sub[ cwv, other, hf ]
			el cwv = ppu_cmath_add[ cwv, other, hf ]
			ppu.framebuf[i] = ppu_color[ cwv, bright ]

	# Color-math enable test for one pixel, matching SNES CGWSEL "belowMask" + the
	# color window (WOBJSEL/WOBJLOG + WH0-3). belowMask = CGWSEL bits 4-5:
	# 0=always, 1=inside color window, 2=outside, 3=never. The color window is
	# HDMA'd per scanline (F-Zero animates WH0/WH1 to confine the race haze band).
	# raw color-window test: is pixel X inside the color window on line y?
	# (WOBJSEL bits 4-7 select/invert window 1/2, WOBJLOG bits 2-3 combine)
	func color_win_inside [ X: i32, y: i32 ] -> bool
		ws   : u8   [ line_wobjsel[y] ]
		w1en : bool [ (ws & 0x20) != 0 ]
		w1inv: bool [ (ws & 0x10) != 0 ]
		w2en : bool [ (ws & 0x80) != 0 ]
		w2inv: bool [ (ws & 0x40) != 0 ]
		if [ !w1en && !w2en ] return false
		om : bool [ false ]
		tm : bool [ false ]
		if [ w1en ] om = (X >= i32[line_wh0[y]] && X <= i32[line_wh1[y]]) != w1inv
		if [ w2en ] tm = (X >= i32[line_wh2[y]] && X <= i32[line_wh3[y]]) != w2inv
		comb : bool [ false ]
		if [ w1en && w2en ]
			lg : u32 [ (u32[line_wobjlog[y]] >> 2) & 3 ]
			if [ lg == 0 ] comb = om || tm
			el [ lg == 1 ] comb = om && tm
			el [ lg == 2 ] comb = om != tm
			el comb = om == tm
		el [ w1en ] comb = om
		el comb = tm
		return comb

	# color-math enable for one pixel: CGWSEL belowMask (bits 4-5) against the
	# color window. 0=always, 1=inside, 2=outside, 3=never.
	func fog_enabled [ X: i32, y: i32 ] -> bool
		bmask : u32 [ (u32[line_cgwsel[y]] >> 4) & 3 ]
		if [ bmask == 0 ] return true
		if [ bmask == 3 ] return false
		ws   : u8   [ line_wobjsel[y] ]
		w1en : bool [ (ws & 0x20) != 0 ]
		w2en : bool [ (ws & 0x80) != 0 ]
		setv : bool [ bmask == 1 ]                     # value when inside the window
		if [ !w1en && !w2en ] return !setv
		if [ color_win_inside[ X, y ] ] return setv
		return !setv

	# CGWSEL bits 6-7: force MAIN screen black by the color window
	# (0=never, 1=outside window, 2=inside window, 3=always). This is how
	# LTTP's iris wipe blacks everything outside the growing circle — without
	# it the masked region shows the raw backdrop (green field color).
	# Clipped pixels keep px_src (math may still add over black, per hardware)
	# but their math operand px_bgr becomes black.
	# math-approximate a layer pixel the composed frame did NOT have on top
	# (occluded): apply the same CGADSUB math the hardware would if this
	# source were visible. without it, glide-revealed pixels (BG sliding
	# under the pinned BG3 HUD digits) show raw un-mathed color — a bright
	# or shadow ghost around the HUD text while walking.
	func lay_math_px [ bgrv: u16, src: i32, x: i32, y: i32, bright: u32 ] -> u32
		cg : u8 [ line_cgadsub[y] ]
		if [ (cg & 0x3F) == 0 ] return ppu_color[ bgrv, bright ]
		mbit : u8 [ 0x20 ]
		if [ src < 4 ] mbit = u8[ 1 << src ]
		el [ src == 5 ] mbit = 0x10
		if [ (cg & mbit) == 0 ] return ppu_color[ bgrv, bright ]
		if [ !fog_enabled[ x, y ] ] return ppu_color[ bgrv, bright ]
		other : u16 [ line_coldata[y] ]
		hf : bool [ (cg & 0x40) != 0 ]
		if [ (line_cgwsel[y] & 0x02) != 0 ]
			di : i32 [ y * 256 + x ]
			other = ppu.sub_bgr[di]
			if [ ppu.sub_src[di] == 0xFF ] hf = false
		v : u16 [ 0 ]
		if [ cg & 0x80 ] v = ppu_cmath_sub[ bgrv, other, hf ]
		el v = ppu_cmath_add[ bgrv, other, hf ]
		return ppu_color[ v, bright ]

	func ppu_mainclip_line [ y: i32 ]
		mm : u32 [ (u32[line_cgwsel[y]] >> 6) & 3 ]
		if [ mm == 0 ] return
		base : i32 [ y * 256 ]
		for [ x: i32 0, x < 256, x += 1 ]
			i : i32 [ base + x ]
			if [ (ppu.framebuf[i] >> 24) == 0 ] continue   # GPU-owned Mode-7 hole
			blk : bool [ true ]
			if [ mm == 1 ] blk = !color_win_inside[ x, y ]
			el [ mm == 2 ] blk = color_win_inside[ x, y ]
			if [ blk ]
				ppu.framebuf[i] = 0xFF000000
				ppu.px_bgr[i]   = 0

	# 13-bit signed wrap for the (offset - center) terms
	func m7_clip [ n: i32 ] -> i32
		if [ n & 0x2000 ] return n | (~1023)
		return n & 1023

	# sign-extend a 13-bit value held in a 16-bit register
	func sx13 [ v: i32 ] -> i32
		s : i32 [ v & 0x1FFF ]
		if [ s & 0x1000 ] return s | (~0x1FFF)
		return s

	# Mode 7 affine layer (BG1), one scanline. Uses the per-scanline matrix
	# (line_m7a-d, HDMA'd) + frame center/scroll. VRAM is interleaved: even byte =
	# tilemap entry (128x128), odd byte = 8bpp char pixel. Ported from reference hardware ppu-fast.
	func ppu_m7_line [ y: i32, bright: u32 ]
		a  : i32 [ i32[line_m7a[y]] ]
		b  : i32 [ i32[line_m7b[y]] ]
		c  : i32 [ i32[line_m7c[y]] ]
		d  : i32 [ i32[line_m7d[y]] ]
		hc : i32 [ sx13[ i32[frame_m7x] ] ]
		vc : i32 [ sx13[ i32[frame_m7y] ] ]
		ho : i32 [ sx13[ i32[ppu.m7hofs] ] ]
		vo : i32 [ sx13[ i32[ppu.m7vofs] ] ]
		hflip  : bool [ (ppu.m7sel & 1) != 0 ]
		vflip  : bool [ (ppu.m7sel & 2) != 0 ]
		repeat : u32  [ (u32[ppu.m7sel] >> 6) & 3 ]
		yy : i32 [ y + 1 ]                       # framebuf row y = hardware scanline y+1 (reference hardware m7 uses vcounter)
		if [ vflip ] yy = 255 - (y + 1)
		ch : i32 [ m7_clip[ ho - hc ] ]
		cv : i32 [ m7_clip[ vo - vc ] ]
		originX : i32 [ ((a * ch) & (~63)) + ((b * cv) & (~63)) + ((b * yy) & (~63)) + (hc << 8) ]
		originY : i32 [ ((c * ch) & (~63)) + ((d * cv) & (~63)) + ((d * yy) & (~63)) + (vc << 8) ]
		for [ X: i32 0, X < 256, X += 1 ]
			xx : i32 [ X ]
			if [ hflip ] xx = 255 - X
			pixelX : i32 [ (originX + a * xx) >> 8 ]
			pixelY : i32 [ (originY + c * xx) >> 8 ]
			tileX : i32 [ (pixelX >> 3) & 127 ]
			tileY : i32 [ (pixelY >> 3) & 127 ]
			oob : i32 [ (pixelX | pixelY) & (~1023) ]
			tile : u32 [ 0 ]
			if [ repeat == 3 && oob != 0 ]
				tile = 0
			el
				tile = u32[ppu.vram[ (tileY * 128 + tileX) * 2 ]]
			pix : u32 [ 0 ]
			if [ repeat == 2 && oob != 0 ]
				pix = 0
			el
				palAddr : i32 [ ((pixelY & 7) << 3) + (pixelX & 7) ]
				ci      : u32 [ (tile << 6) | u32[palAddr] ]
				pix = u32[ppu.vram[ ci * 2 + 1 ]]
			if [ pix != 0 ]
				cw : u16 [ ppu_cgram_color[ pix ] ]
				# distance fog: BG1 subtractive color math, but ONLY when CGWSEL's
				# color-math region is "always" (0). F-Zero's race sets region=1
				# (inside an empty window) => no math => bright road.
				# (math now applied by the generic ppu_cmath_line pass — handles ADD too,
				# e.g. zelda's sword-strike COLDATA flash over the Mode-7 logo)
				fi : i32 [ y * 256 + X ]
				ppu.px_bgr[ fi ]   = cw
				ppu.px_src[ fi ]   = 0                  # BG1 (CGADSUB bit0)
				ppu.framebuf[ fi ] = ppu_color[ cw, bright ]

	# GPU Mode 7: expand the interleaved Mode-7 VRAM (even byte = 128x128 tilemap,
	# odd byte = 8bpp linear char) into a 1024x1024 RGBA plane with the palette
	# already applied (pix 0 -> transparent). Uploaded to m7_src for the shader.
	func m7_unpack [ bright: u32 ]
		for [ tY: i32 0, tY < 128, tY += 1 ]
			for [ tX: i32 0, tX < 128, tX += 1 ]
				tile : u32 [ u32[pub_vram[ (tY * 128 + tX) * 2 ]] ]
				for [ py: i32 0, py < 8, py += 1 ]
					for [ px: i32 0, px < 8, px += 1 ]
						ci  : u32 [ (tile << 6) | u32[(py << 3) | px] ]
						pix : u32 [ u32[pub_vram[ ci * 2 + 1 ]] ]
						col : u32 [ 0 ]
						if [ pix != 0 ]
							cw : u16 [ u16[pub_cgram[pix * 2]] | (u16[pub_cgram[pix * 2 + 1]] << 8) ]
							col = ppu_color[ cw, bright ]
						m7_buf[ (tY * 8 + py) * 1024 + (tX * 8 + px) ] = col
		if [ vec_m7 ]
			# corner-cut 2x (Scale2x rule, exact-color compares — right for the
			# paletted plane; wrap-aware neighbors, the m7 plane tiles). runs
			# only on rebakes (scene/palette changes), not per frame.
			for [ y: i32 0, y < 1024, y += 1 ]
				rn : i32 [ ((y + 1) & 1023) * 1024 ]
				rp : i32 [ ((y - 1) & 1023) * 1024 ]
				rc : i32 [ y * 1024 ]
				dr : i32 [ (y * 2) * 2048 ]
				ds : i32 [ (y * 2 + 1) * 2048 ]
				for [ x: i32 0, x < 1024, x += 1 ]
					ee : u32 [ m7_buf[ rc + x ] ]
					bb : u32 [ m7_buf[ rp + x ] ]
					hh : u32 [ m7_buf[ rn + x ] ]
					dd : u32 [ m7_buf[ rc + ((x - 1) & 1023) ] ]
					ff : u32 [ m7_buf[ rc + ((x + 1) & 1023) ] ]
					e0 : u32 [ ee ]
					e1 : u32 [ ee ]
					e2 : u32 [ ee ]
					e3 : u32 [ ee ]
					if [ bb != hh && dd != ff ]
						if [ dd == bb ] e0 = dd
						if [ bb == ff ] e1 = ff
						if [ dd == hh ] e2 = dd
						if [ hh == ff ] e3 = ff
					m7_buf2x[ dr + x * 2 ]     = e0
					m7_buf2x[ dr + x * 2 + 1 ] = e1
					m7_buf2x[ ds + x * 2 ]     = e2
					m7_buf2x[ ds + x * 2 + 1 ] = e3
			m7_src.upload[ m7_buf2x, 2048 * 2048 * 4 ]
		el
			m7_src.upload[ m7_buf, 1024 * 1024 * 4 ]

	# Cheap weighted-sample hash of the Mode-7 VRAM + CGRAM, to detect when the plane
	# (tilemap + char + palette) actually changed so we only re-unpack/upload on
	# track/palette loads, not every frame (the camera moves via the per-scanline
	# matrix instead). CGRAM matters: palette-cycling flashes (zelda sword strike)
	# DMA new colors with zero VRAM change — the baked plane must re-bake.
	func m7_vram_hash [] -> i64
		h : i64 [ 0 ]
		for [ i: i32 0, i < 0x10000, i += 4 ]
			h += i64[ pub_vram[i] ] * i64[ i + 1 ]
		for [ i: i32 0, i < 0x200, i += 1 ]
			h += i64[ pub_cgram[i] ] * i64[ 0x10000 + i ]
		return h

	# GPU Mode 7: precompute each scanline's affine setup exactly as ppu_m7_line
	# (origin folds in the b/d*yy term + center; per-pixel uses originX + a*x).
	# Packed into m7_mat as { originX, originY, a, c } floats per texel row.
	# k < 1 eases each line's displayed ROTATION coefficients toward the
	# current emulated frame by k per call (render-side EMA, frame-rate
	# independent: the plane redraws every display refresh); the line origin
	# is rebuilt from the eased coefficients + exact position, so translation
	# follows 1:1 while the angle glides. k=1 = exact current frame
	# (non-smooth path).
	func m7_matrices [ k: f32 ]
		hc : i32 [ sx13[ i32[pub_m7x] ] ]
		vc : i32 [ sx13[ i32[pub_m7y] ] ]
		ho : i32 [ sx13[ i32[pub_m7hofs] ] ]
		vo : i32 [ sx13[ i32[pub_m7vofs] ] ]
		vflip : bool [ (pub_m7sel & 2) != 0 ]
		ch : i32 [ m7_clip[ ho - hc ] ]
		cv : i32 [ m7_clip[ vo - vc ] ]
		ease : bool [ k < 1.0 ]
		g_eased   : i32 [ 0 ]
		g_snapped : i32 [ 0 ]
		for [ y: i32 0, y < 224, y += 1 ]
			a : i32 [ i32[pub_m7a[y]] ]
			b : i32 [ i32[pub_m7b[y]] ]
			c : i32 [ i32[pub_m7c[y]] ]
			d : i32 [ i32[pub_m7d[y]] ]
			yy : i32 [ y ]
			if [ vflip ] yy = 255 - y
			af : f32 [ f32[ a ] ]
			bf : f32 [ f32[ b ] ]
			cf : f32 [ f32[ c ] ]
			df : f32 [ f32[ d ] ]
			eased : bool [ false ]
			if [ ease ]
				pa : f32 [ m7f_a[y] ]
				pb : f32 [ m7f_b[y] ]
				pc : f32 [ m7f_c[y] ]
				pd : f32 [ m7f_d[y] ]
				ja : f32 [ af - pa ]
				jb : f32 [ bf - pb ]
				jc : f32 [ cf - pc ]
				jd : f32 [ df - pd ]
				# teleport guard: unrelated states (scene change, mode-7
				# entry) must snap, not ease. 2.0 (8.8) coefficient limit.
				if [ ja > -512.0 && ja < 512.0 && jb > -512.0 && jb < 512.0 && jc > -512.0 && jc < 512.0 && jd > -512.0 && jd < 512.0 ]
					af = pa + ja * k
					bf = pb + jb * k
					cf = pc + jc * k
					df = pd + jd * k
					eased = true
					g_eased += 1
				el
					g_snapped += 1
			m7f_a[y] = af
			m7f_b[y] = bf
			m7f_c[y] = cf
			m7f_d[y] = df
			oxf : f32 [ 0.0 ]
			oyf : f32 [ 0.0 ]
			if [ eased ]
				# origin from EASED rotation + EXACT position/center: the
				# angle glides, translation follows 1:1
				oxf = af * f32[ ch ] + bf * f32[ cv ] + bf * f32[ yy ] + f32[ hc << 8 ]
				oyf = cf * f32[ ch ] + df * f32[ cv ] + df * f32[ yy ] + f32[ vc << 8 ]
			el
				ox : i32 [ ((a * ch) & (~63)) + ((b * cv) & (~63)) + ((b * yy) & (~63)) + (hc << 8) ]
				oy : i32 [ ((c * ch) & (~63)) + ((d * cv) & (~63)) + ((d * yy) & (~63)) + (vc << 8) ]
				oxf = f32[ ox ]
				oyf = f32[ oy ]
			m7_matbuf[ y * 4 + 0 ] = oxf
			m7_matbuf[ y * 4 + 1 ] = oyf
			m7_matbuf[ y * 4 + 2 ] = af
			m7_matbuf[ y * 4 + 3 ] = cf
			# rows 1-2: per-line color window + CGADSUB math for the plane (fog / craft shadow)
			ws : u8 [ pub_wobjsel[y] ]
			cgs : u8 [ pub_cgwsel[y] ]
			cga : u8 [ pub_cgadsub[y] ]
			mwf : u32 [ 0 ]
			if [ ws & 0x20 ] mwf = mwf | 1
			if [ ws & 0x10 ] mwf = mwf | 2
			if [ ws & 0x80 ] mwf = mwf | 4
			if [ ws & 0x40 ] mwf = mwf | 8
			mwf = mwf | (((u32[pub_wobjlog[y]] >> 2) & 3) << 4)
			reg : u32 [ (u32[cgs] >> 4) & 3 ]
			if [ (cga & 0x01) == 0 ] reg = 3               # math not enabled for BG1: never applies to the plane
			if [ (cga & 0x3F) == 0 ] reg = 3
			mwf = mwf | (reg << 6)
			if [ cga & 0x80 ] mwf = mwf | 256
			if [ cga & 0x40 ] mwf = mwf | 512
			cold : u16 [ pub_coldata[y] ]
			m7_matbuf[ (256 + y) * 4 + 0 ] = f32[ u32[pub_wh0[y]] ]
			m7_matbuf[ (256 + y) * 4 + 1 ] = f32[ u32[pub_wh1[y]] ]
			m7_matbuf[ (256 + y) * 4 + 2 ] = f32[ u32[pub_wh2[y]] ]
			m7_matbuf[ (256 + y) * 4 + 3 ] = f32[ u32[pub_wh3[y]] ]
			m7_matbuf[ (512 + y) * 4 + 0 ] = f32[ mwf ]
			m7_matbuf[ (512 + y) * 4 + 1 ] = f32[ u32[cold] & 31 ]
			m7_matbuf[ (512 + y) * 4 + 2 ] = f32[ (u32[cold] >> 5) & 31 ]
			m7_matbuf[ (512 + y) * 4 + 3 ] = f32[ (u32[cold] >> 10) & 31 ]
		if [ getenv[ 'ASNES_GLIDE' ] && ease && dbg_m7l < 600 ]
			printf[ "M7EASE k=%.3f eased=%d snapped=%d\n", f64[ k ], g_eased, g_snapped ]
			dbg_m7l += 1
		m7_mat.upload[ m7_matbuf, 768 * 4 * 4 ]

	# Render the SUB-screen for one scanline into sub_bgr/sub_src. The sub-screen
	# backdrop is the fixed COLDATA color (so unpainted pixels blend as fixed color),
	# then TS-enabled layers paint over it by Mode-1 priority. Used as the "below"
	# color when CGWSEL blendMode (bit1) = subscreen. SMW's intro sky/mountains are
	# BG2 on the sub-screen, composited to the main screen via this path.
	func ppu_sub_line [ y: i32, bright: u32 ]
		sbd : u16 [ line_coldata[y] ]
		for [ x: i32 0, x < 256, x += 1 ]
			di : i32 [ y * 256 + x ]
			ppu.sub_bgr[ di ] = sbd
			ppu.sub_src[ di ] = 0xFF
		ts   : u8 [ line_ts[y] ]
		b3hi : bool [ (line_mode[y] & 0x08) != 0 ]
		rendering_sub = true
		if [ ts & 0x04 ] ppu_bg_line[ 2, 2, y, bright, 0 ]   # BG3.0
		if [ ts & 0x04 ] if [ !b3hi ] ppu_bg_line[ 2, 2, y, bright, 1 ]  # BG3.1 (low pos)
		if [ ts & 0x02 ] ppu_bg_line[ 1, 4, y, bright, 0 ]   # BG2.0
		if [ ts & 0x01 ] ppu_bg_line[ 0, 4, y, bright, 0 ]   # BG1.0
		if [ ts & 0x02 ] ppu_bg_line[ 1, 4, y, bright, 1 ]   # BG2.1
		if [ ts & 0x01 ] ppu_bg_line[ 0, 4, y, bright, 1 ]   # BG1.1
		if [ ts & 0x04 ] if [ b3hi ] ppu_bg_line[ 2, 2, y, bright, 1 ]   # BG3.1 (front)
		rendering_sub = false

	# latch VRAM/OAM/CGRAM/INIDISP at the end of active display, before the game's
	# vblank code streams the NEXT frame's OBJ tiles over them (zelda's Triforce intro).
	func ppu_latch_shot []
		memcpy[ ppu.vram_shot,  ppu.vram,  0x10000 ]
		memcpy[ ppu.cgram_shot, ppu.cgram, 0x200 ]
		memcpy[ ppu.oam_shot,   ppu.oam,   0x220 ]
		ppu.inidisp_shot = ppu.inidisp
		shot_valid = true

	func ppu_render []
		use_shot = shot_valid                          # render from the end-of-active-display snapshot
		bg : u16 [ ppu_cgram_color[ 0 ] ]
		ppu_sprites[ 15 ]                              # coverage/prio planes; per-line brightness applied in ppu_obj_line via obj_bgr
		# Per-scanline brightness (line_inidisp): brightness/force-blank apply at the line
		# they were written, NOT per frame — ff3 blanks at line 215 (early vblank work) and
		# holds the fade level through the visible lines; a single frame-global sample of
		# INIDISP at vblank start reads the blank and blacked the whole frame.
		# Mode 1 priority order, painted BACK -> FRONT (later overwrites). BG3 high-prio
		# goes to the very front when BGMODE bit3 is set, else just above OBJ.0.
		# NOTE: silver binds && tighter than &, so a layer-enable test MUST be a nested
		# if [ tm & bit ] then if [ cond ] -- never `tm & bit && cond` (that parses as
		# tm & (bit && cond) and fires whenever bit0 of tm is set, drawing disabled layers).
		for [ y: i32 0, y < 224, y += 1 ]
			li     : u8  [ line_inidisp[y] ]
			bright : u32 [ u32[li] & 0x0F ]
			if [ li & 0x80 ] bright = 0                # forced blank -> black line
			px : u32 [ ppu_color[ bg, bright ] ]
			for [ X2: i32 0, X2 < 256, X2 += 1 ]
				i2 : i32 [ y * 256 + X2 ]
				ppu.framebuf[ i2 ] = px
				ppu.px_bgr[ i2 ]   = bg
				ppu.px_src[ i2 ]   = 8                  # backdrop (CGADSUB bit5)
			if [ bright == 0 ] continue
			mode : u8 [ line_mode[y] & 7 ]
			tm   : u8 [ line_tm[y] ]
			b3hi : bool [ (line_mode[y] & 0x08) != 0 ]
			if [ mode == 1 ]
				if [ tm & 0x04 ] ppu_bg_line[ 2, 2, y, bright, 0 ]   # BG3.0
				if [ tm & 0x10 ] ppu_obj_line[ y, 0, bright ]        # OBJ.0
				if [ tm & 0x04 ] if [ !b3hi ] ppu_bg_line[ 2, 2, y, bright, 1 ]  # BG3.1 (low pos)
				if [ tm & 0x10 ] ppu_obj_line[ y, 1, bright ]        # OBJ.1
				if [ tm & 0x02 ] ppu_bg_line[ 1, 4, y, bright, 0 ]   # BG2.0
				if [ tm & 0x01 ] ppu_bg_line[ 0, 4, y, bright, 0 ]   # BG1.0
				if [ tm & 0x10 ] ppu_obj_line[ y, 2, bright ]        # OBJ.2
				if [ tm & 0x02 ] ppu_bg_line[ 1, 4, y, bright, 1 ]   # BG2.1
				if [ tm & 0x01 ] ppu_bg_line[ 0, 4, y, bright, 1 ]   # BG1.1
				if [ tm & 0x10 ] ppu_obj_line[ y, 3, bright ]        # OBJ.3
				if [ tm & 0x04 ] if [ b3hi ] ppu_bg_line[ 2, 2, y, bright, 1 ]   # BG3.1 (front)
				# build the sub-screen whenever CGWSEL selects it as the math operand —
				# even with TS=0: the sub backdrop is COLDATA, which is exactly how
				# zelda's sword-strike flash works (add fixed color over a bare backdrop)
				if [ (line_cgwsel[y] & 0x02) || (line_ts[y] & 0x07) ] ppu_sub_line[ y, bright ]
				ppu_mainclip_line[ y ]                               # CGWSEL force-main-black (LTTP iris wipe)
				ppu_cmath_line[ y, bright ]                          # CGADSUB add/sub (POWER bar fill, HUD fog)
			el [ mode == 7 ]
				if [ m7_gpu ]                                        # GPU owns the plane: leave it transparent
					for [ X: i32 0, X < 256, X += 1 ]
						ppu.framebuf[ y * 256 + X ] = 0
				el [ tm & 0x01 ] ppu_m7_line[ y, bright ]            # CPU Mode 7 plane (BG1)
				if [ tm & 0x10 ]                                     # sprites on top
					ppu_obj_line[ y, 0, bright ]
					ppu_obj_line[ y, 1, bright ]
					ppu_obj_line[ y, 2, bright ]
					ppu_obj_line[ y, 3, bright ]
				ppu_mainclip_line[ y ]                               # CGWSEL force-main-black applies in Mode 7 too
				ppu_cmath_line[ y, bright ]                          # CGADSUB add/sub applies in Mode 7 too (fog = sub, sword-strike flash = COLDATA add)
		use_shot = false

	func cpu_r [ addr: u16 ] -> u8
		if [ addr >= 0x2140 && addr <= 0x2143 ]
			# reference hardware CPU::read: step<n-4> (with refresh check), bus.read (synchronizeSMP inside
			# readAPU samples the port HERE), then step<4> (refresh check again). Split the tick
			# the same way so a DRAM refresh landing in the last 4 master of the access is
			# charged AFTER the sample, not folded into the drain target.
			last_axs = cpu_speed[ 0, addr ]
			cpu_tick_n[ last_axs - 4, true ]
			port_read = true
			spc_drain[ i32[ audio_slice_size[] ] ]    # sync SPC to the read's sample cycle (reference hardware synchronizeSMP in readAPU)
			if [ nmi_frames == 0 ] dbg_pr += 1
			if [ dbg_frames >= 59 && cpu.pc != 0xF817 && cpu.pc != 0xF814 && dbg_ev2 < 120 ]
				printf[ "f%u CPUrd port%d=%02X cpupc=%04X\n", dbg_frames, addr - 0x2140, spc.oports[addr - 0x2140], cpu.pc ]
				dbg_ev2 += 1
			rp : i32 [ i32[addr] - 0x2140 ]
			v : u8 [ spc.oports[rp] ]                 # sampled at the drained clock (reference hardware synchronizeSMP) — no timestamp filter
			if [ env_sf4 && dbg_frames >= 199 && dbg_frames <= 227 ] puts[ 'SF4C f{dbg_frames} p{rp} val={v} n={spc_nops}' ]
			cpu_tick_n[ 4, false ]                    # bus-hold tail of the access (reference hardware step<4,0> after the read)
			return v
		cpu_tick[ 0, addr ]
		if [ addr >= 0x2100 && addr <= 0x213F ]
			return ppu_r[ addr ]
		el [ addr == 0x2180 ]                          # WMDATA: read WRAM via WMADD, auto-inc
			v : u8 [ cpu.memory[ 0x7E0000 + (wram_addr & 0x1FFFF) ] ]
			wram_addr = (wram_addr + 1) & 0x1FFFF
			return v
		el [ addr >= 0x4000 && addr <= 0x43FF ]
			if [ addr == 0x4210 ]            # RDNMI: bit7 = NMI flag (cleared on read); bits4-6 = open bus
				v : u8 [ (mdr & 0x70) | ((nmi_occurred) ? 0x80 : 0x00) | 0x02 ]
				if [ env_joylog && dbg_jl < 400 ]
					printf[ "RDNMI f%u pc=%02X:%04X v=%02X cnl=%d\n", dbg_frames, cpu.pbr, cpu.pc, u32[v], frame_master / 1364 ]
					dbg_jl += 1
				rpos : i32 [ frame_master + op_master + steal_master ]
				if [ rpos < 306902 || rpos > 306926 ]  # reference hardware nmiHold: reads inside the 4-cycle raise window return 1 WITHOUT clearing the latch
					nmi_occurred = false
				return v
			if [ addr == 0x4211 ]            # TIMEUP: bit7 = IRQ flag (cleared on read); bits0-6 = open bus
				v : u8 [ (mdr & 0x7F) | ((irq_occurred) ? 0x80 : 0x00) ]
				irq_occurred = false
				return v
			if [ addr == 0x4212 ]            # HVBJOY: bit7=vblank, bit6=hblank, bit0=joy-busy; bits1-5 = open bus
				vb : u8 [ (in_vblank) ? 0x80 : 0 ]
				# hblank from the exact mid-instruction master clock (same continuous
				# clock as DRAM refresh); reference hardware: hcounter <= 2 || hcounter >= 1096.
				# the old frame_cycle%228 (CPU cycles) drifted 2/3 cycle per line vs the
				# real 1364-master line — half a scanline off by mid-frame, which broke
				# zelda's BIT $4212 / BVC hblank wait (story-scene corruption).
				hpos : i32 [ (frame_master + op_master + steal_master) % 1364 ]
				hb : u8 [ (hpos <= 2 || hpos >= 1096) ? 0x40 : 0 ]
				return (mdr & 0x3E) | vb | hb
			if [ addr == 0x4214 ] return u8[rddiv & 0xFF]         # RDDIVL
			if [ addr == 0x4215 ] return u8[(rddiv >> 8) & 0xFF]  # RDDIVH
			if [ addr == 0x4216 ] return u8[rdmpy & 0xFF]         # RDMPYL
			if [ addr == 0x4217 ] return u8[(rdmpy >> 8) & 0xFF]  # RDMPYH
			if [ addr == 0x4016 ]            # JOYSER0: serial controller-1 read
				if [ env_joylog && dbg_jl < 400 ]
					printf[ "JOYR f%u $4016 strobe=%d idx=%d pc=%02X:%04X\n", dbg_frames, joy_strobe & 1, joy_index, cpu.pbr, cpu.pc ]
					dbg_jl += 1
				if [ joy_strobe & 1 ] return u8[(pad1 >> 15) & 1]
				if [ joy_index >= 16 ] return 0x01
				rb : u8 [ u8[(pad1 >> (15 - joy_index)) & 1] ]
				joy_index += 1
				return rb
			if [ addr == 0x4017 ] return 0x00
			if [ addr == 0x4218 ]            # JOY1L (auto-joypad)
				if [ env_joylog && dbg_jl < 400 ]
					printf[ "JOYR f%u $4218 val=%02X pc=%02X:%04X\n", dbg_frames, u32[pad1 & 0xFF], cpu.pbr, cpu.pc ]
					dbg_jl += 1
				return u8[pad1 & 0xFF]
			if [ addr == 0x4219 ]            # JOY1H
				if [ env_joylog && dbg_jl < 400 ]
					printf[ "JOYR f%u $4219 val=%02X pc=%02X:%04X\n", dbg_frames, u32[(pad1 >> 8) & 0xFF], cpu.pbr, cpu.pc ]
					dbg_jl += 1
				return u8[(pad1 >> 8) & 0xFF]
			if [ addr >= 0x421A && addr <= 0x421F ] return 0x00  # controllers 2-4
			return 0x00
		el [ addr >= 0x0000 && addr <= 0x1FFF ]
			return cpu.memory[0x7E0000 + (addr & 0x1FFF)]
		el [ addr >= 0x6000 && addr <= 0x7FFF ]
			return cpu.memory[addr]
		return cpu.memory[addr]

	func cpu_w [ addr: u16, val: u8 ]
		if [ env_ww && addr >= 0x1002 && addr <= 0x1008 && dbg_frames >= 1524 && dbg_frames <= 1529 ]
			printf[ "ABUF f%u [%04X]=%02X pc=%02X:%04X fmaster=%d\n", dbg_frames, u32[addr], u32[val], cpu.pbr, cpu.pc, frame_master ]
		if [ env_ww && addr == 0x0005 && dbg_frames >= 1524 && dbg_frames <= 1529 ]
			printf[ "AZP f%u [0005]=%02X pc=%02X:%04X fmaster=%d ptr=%02X%02X%02X Y=%04X raw1004=%02X raw1002=%02X%02X%02X%02X%02X%02X\n", dbg_frames, u32[val], cpu.pbr, cpu.pc, frame_master, cpu.memory[0x7E0002], cpu.memory[0x7E0001], cpu.memory[0x7E0000], (u32[cpu.yh] << 8) | u32[cpu.y], cpu.memory[0x7E1004], cpu.memory[0x7E1002], cpu.memory[0x7E1003], cpu.memory[0x7E1004], cpu.memory[0x7E1005], cpu.memory[0x7E1006], cpu.memory[0x7E1007] ]
		cpu_tick[ 0, addr ]
		if [ env_ww && addr == 0x01FA && dbg_frames >= 94 && dbg_frames <= 97 ] printf[ "AWW f%u [01FA]=%02X pc=%02X:%04X\n", dbg_frames, val, cpu.pbr, cpu.pc ]
		if [ addr >= 0x2140 && addr <= 0x2143 ]
			wi : i32 [ i32[addr] - 0x2140 ]
			spc_drain[ i32[ audio_slice_size[] ] ]     # reference hardware writeCPUIO: synchronizeSMP BEFORE the write commits — SPC opcodes up to this clock run against the OLD value, everything after sees the new one
			spc.ports[wi] = val
			if [ env_sf4 && dbg_frames >= 199 && dbg_frames <= 227 ] puts[ 'SF4W f{dbg_frames} p{wi} val={val} n={spc_nops}' ]
			if [ dbg_frames >= 125 && val != 0x00 && dbg_ev2 < 160 ]
				printf[ "f%u CPUw port%d=%02X src=%06X dbr=%02X cpupc=%04X\n", dbg_frames, addr - 0x2140, val, last_rd, cpu.dbr, cpu.pc ]
				dbg_ev2 += 1
		el [ addr >= 0x2100 && addr <= 0x213F ]
			ppu_w[ addr, val ]
		el [ addr == 0x2180 ]                          # WMDATA: write WRAM via WMADD, auto-inc
			if [ env_joylog && (wram_addr & 0x1FFFF) >= 0x0876 && (wram_addr & 0x1FFFF) <= 0x0886 && dbg_ww < 400 ]
				printf[ "WW-wm [%05X]=%02X pc=%02X:%04X f%u\n", wram_addr & 0x1FFFF, u32[val], cpu.pbr, cpu.pc, dbg_frames ]
				dbg_ww += 1
			cpu.memory[ 0x7E0000 + (wram_addr & 0x1FFFF) ] = val
			wram_addr = (wram_addr + 1) & 0x1FFFF
		el [ addr == 0x2181 ] wram_addr = (wram_addr & 0x1FF00) | u32[val]            # WMADDL
		el [ addr == 0x2182 ] wram_addr = (wram_addr & 0x100FF) | (u32[val] << 8)     # WMADDM
		el [ addr == 0x2183 ] wram_addr = (wram_addr & 0x0FFFF) | ((u32[val] & 1) << 16) # WMADDH
		el [ addr >= 0x4000 && addr <= 0x43FF ]
			if [ addr == 0x4016 ]                  # JOYSER0 strobe: latch/reset serial
				joy_strobe = val
				if [ val & 1 ] joy_index = 0
			el [ addr == 0x4202 ] mpya = val       # WRMPYA
			el [ addr == 0x4203 ]                  # WRMPYB (write triggers 8x8 multiply)
				mpyb = val
				rdmpy = u16[ (u32[mpya] * u32[mpyb]) & 0xFFFF ]
			el [ addr == 0x4204 ] wrdiv = (wrdiv & 0xFF00) | u16[val]          # WRDIVL
			el [ addr == 0x4205 ] wrdiv = (wrdiv & 0x00FF) | (u16[val] << 8)   # WRDIVH
			el [ addr == 0x4206 ]                  # WRDIVB (write triggers 16/8 divide)
				if [ val == 0 ]
					rddiv = 0xFFFF
					rdmpy = wrdiv
				el
					rddiv = wrdiv / u16[val]
					rdmpy = wrdiv % u16[val]
			el [ addr == 0x4200 ]                  # NMITIMEN: bit7=NMI, bit5=V-IRQ, bit4=H-IRQ
				if [ env_irqlog && dbg_frames < 200 && val != nmitimen ]
					printf[ "NMITIMEN<-%02X f%u pc=%02X:%04X vtime=%d htime=%d\n", val, dbg_frames, cpu.pbr, cpu.pc, i32[vtime], i32[htime] ]
				if [ (val & 0x80) && !(nmitimen & 0x80) && nmi_occurred && in_vblank ] nmi_retro = true   # enable rose with the NMI LINE high (vblank level, not the RDNMI latch) -> immediate NMI (reference hardware nmitimenUpdate raise+nmiLine)
				nmitimen = val
			el [ addr == 0x4207 ] htime = (htime & 0x100) | u16[val]              # HTIMEL
			el [ addr == 0x4208 ] htime = (htime & 0x0FF) | ((u16[val] & 1) << 8) # HTIMEH
			el [ addr == 0x4209 ] vtime = (vtime & 0x100) | u16[val]              # VTIMEL
			el [ addr == 0x420A ] vtime = (vtime & 0x0FF) | ((u16[val] & 1) << 8) # VTIMEH
			el [ addr == 0x420B ] dma_pending = i32[ val ]    # MDMAEN: defer GP-DMA to next instr (reference hardware runs it at the 2nd dmaEdge after this write)
			el [ addr == 0x420C ]
				if [ env_hdmalog ] printf[ "HDMAEN f%u write=%02X fmaster=%d line=%d\n", dbg_frames, u32[val], frame_master, frame_master / 1364 ]
				cpu.memory[addr] = val   # HDMAEN: per-scanline DMA enable mask
			el [ addr == 0x420D ] cpu_fastrom = (val & 1) != 0   # MEMSEL: banks $80-FF fast (6 master) when set
			el [ addr >= 0x4300 && addr <= 0x437F ] cpu.memory[addr] = val   # DMA channel regs
		el [ addr >= 0x0000 && addr <= 0x1FFF ]
			wo : u16 [ addr & 0x1FFF ]
			ww : u32 [ 0x7E0000 + wo ]
			if [ env_joylog && wo >= 0x0876 && wo <= 0x0886 && dbg_ww < 400 ]
				printf[ "WW-cw [%04X]=%02X pc=%02X:%04X f%u\n", wo, u32[val], cpu.pbr, cpu.pc, dbg_frames ]
				dbg_ww += 1
			if [ env_logzp && (wo == 0x0041 || wo == 0x0046 || wo == 0x0051 || wo == 0x005D || wo == 0x0060 || wo == 0x0062 || wo == 0x00F0) ]
				printf[ "W[%04X]=%02X pc=%02X:%04X\n", wo, val, cpu.pbr, cpu.pc ]
			if [ env_trace && wo == 0x0060 && val == 1 && dbg_t < 1 ]
				printf[ "==== 32 instrs before $0060<-01 (demo-entry) f%u ====\n", dbg_frames ]
				for [ kk: i32 0, kk < 32, kk += 1 ]
					st : i32 [ (tr_i + kk) % 32 ]
					printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[st] >> 16, tr_addr[st] & 0xFFFF, tr_b0[st], tr_b1[st], tr_b2[st], tr_b3[st], tr_p[st], tr_a[st], tr_x[st], tr_y[st] ]
				dbg_t += 1
			if [ env_pal && wo >= 0x0520 && wo <= 0x0530 && dbg_w < 80 ]
				printf[ "PALw[%04X]=%02X pc=%02X:%04X dbr=%02X f%u (cpuw)\n", wo, val, cpu.pbr, cpu.pc, cpu.dbr, dbg_frames ]
				dbg_w += 1
			if [ wo >= 0x012C && wo <= 0x012F && val != 0 && dbg_frames >= 820 && dbg_w < 160 ]
				printf[ "SNDQ[%04X]=%02X sub=%02X pc=%02X:%04X f%u\n", wo, val, cpu.memory[0x7E0011], cpu.pbr, cpu.pc, dbg_frames ]
				dbg_w += 1
			cpu.memory[ww] = val
		el [ addr >= 0x6000 && addr <= 0x7FFF ]
			cpu.memory[addr] = val
		el
			cpu.memory[addr] = val

	# bank-aware instruction/operand fetch: uses the program bank (pbr).
	# low addresses ($0000-$1FFF) mirror WRAM; everything else is the flat map.
	func cpu_fetch_at [ fa: u16 ] -> u8
		bank : u32 [ cpu.pbr ]
		if [ is_hirom && ((bank >= 0x40 && bank <= 0x7D) || bank >= 0xC0) ]
			return cpu.memory[ (bank << 16) | u32[fa] ]
		if [ fa < 0x2000 && bank != 0x7E && bank != 0x7F ]
			waddr : u32 [ 0x7E0000 + u32[fa] ]
			return cpu.memory[waddr]
		faddr : u32 [ (bank << 16) | u32[fa] ]
		return cpu.memory[faddr]

	# SNES bus access speed in MASTER clocks, by region (mirrors reference hardware cpu/memory.cpp):
	#   6 = FastROM ($80-FF when $420D.0) + fast I/O ($2100-21FF,$2140-217F,$2180-83,$44xx-5FFF)
	#   8 = SlowROM (all $00-7F ROM, $80-FF when slow), WRAM $7E-7F, low mirror $0000-1FFF, SRAM $6000-7FFF
	#  12 = $4000-43FF (joypad/DMA/CPU regs, xslow)
	func cpu_speed [ bank: u32, addr: u16 ] -> i32
		a : u32 [ (bank << 16) | u32[addr] ]
		if [ (a & 0x408000) != 0 ]
			if [ (a & 0x800000) != 0 && cpu_fastrom ] return 6
			return 8
		if [ ((a + 0x6000) & 0x4000) != 0 ] return 8
		if [ ((a - 0x4000) & 0x7E00) != 0 ] return 6
		return 12

	# charge one CPU memory access (gated so DMA/HDMA/snapshot reads don't double-count)
	# reference hardware dramRefreshPosition = 530 + 8 - dmaCounter(), where dmaCounter = (absolute master & 7)
	# sampled at the scanline's start. frame_phase0 = (master_phase - frame_master) & 7 (both advance
	# by instr_master, so their difference is the frame-start absolute phase, no extra state needed).
	func refresh_rp [ ln: i32 ] -> i32
		# field-1 (odd frame) scanline 240 is 1360 master (-4): lines 241+ start 4 earlier
		sfl : i32 [ (((dbg_frames & 1) == 1) && ln >= 241) ? 4 : 0 ]
		ls : i32 [ ln * 1364 - sfl ]                          # this scanline's frame-relative start
		p0 : i32 [ (master_phase - frame_master) & 7 ]        # absolute master phase at frame start
		ph : i32 [ (p0 + ls) & 7 ]                            # reference hardware dmaCounter at this scanline's start
		return ls + 538 - ph                                  # reference hardware dramRefreshPosition = 530 + 8 - dmaCounter

	# charge mcyc master cycles (a whole access or part of one) + any DRAM refresh whose
	# position falls inside them. count_access ticks op_accesses (once per real access).
	# reference hardware dmaEdge at the START of a bus/internal cycle of width ck: pending HDMA
	# setup + line dots are serviced here, before the cycle's clocks. two-edge
	# pipeline: first edge after a dot arms; the second runs it.
	func cyc_edge [ ck: i32 ]
		if [ hsetup_pend ]
			sp : i32 [ 12 + ((master_phase - frame_master) & 7) ]
			if [ (frame_master + op_master + steal_master) >= sp ]
				if [ !hsetup_arm ]
					hsetup_arm = true              # first edge past the setup dot: arm only (reference hardware dmaActive)
					if [ env_hdmalog && dbg_frames >= 1497 && dbg_frames <= 1499 ]
						printf[ "ASET f%u sp=%d pos=%d p0=%d\n", dbg_frames, sp, frame_master + op_master + steal_master, (master_phase - frame_master) & 7 ]
				el
					hsetup_arm  = false
					hsetup_pend = false
					count_cpu = false
					hdma_setup[ ck ]
					count_cpu = true
		while [ hline < 225 ]
			hp : i32 [ hline * 1364 + 1104 ]
			if [ (frame_master + op_master + steal_master) < hp ] break
			if [ !hdma_edge_arm ]
				hdma_edge_arm = true               # first edge after the dot: arm only (reference hardware dmaActive)
				if [ env_hdmalog && dbg_frames >= 1497 && dbg_frames <= 1499 ]
					printf[ "AARM f%u v=%d pos=%d ck=%d pc=%02X:%04X op=%02X\n", dbg_frames, hline, frame_master + op_master + steal_master, ck, cpu.pbr, cpu.pc, u32[nmi_lastop] ]
				break
			hdma_edge_arm = false
			count_cpu = false
			hsrc = 1
			hdma_run_line[ ck ]
			count_cpu = true
			hline += 1

	# one internal (IO) cycle at its TRUE position inside the instruction — reference hardware
	# idle(): a 6-master cycle with a dmaEdge at its start and refresh checked
	# through it. `cycles` counts already include these; idle_done tells the tail
	# how many were charged in place (unconverted opcodes keep tail behavior).
	func cpu_idle []
		if [ !count_cpu ] return
		cyc_edge[ 6 ]
		tm0 : i32 [ op_master ]
		op_master += 6
		idle_done += 1
		while [ refresh_line < 262 ]
			rp : i32 [ refresh_rp[ refresh_line ] ]
			if [ (frame_master + op_master + steal_master) < rp ] break
			op_master += 40
			refresh_line += 1
		spc.cycle_accum += i64[ op_master - tm0 ] * 128160

	func cpu_tick_n [ mcyc: i32, count_access: bool ]
		if [ !count_cpu ] return
		if [ count_access ] cyc_edge[ last_axs ]
		tm0 : i32 [ op_master ]
		op_master += mcyc
		if [ count_access ] op_accesses += 1
		# DRAM refresh, checked per (partial) access like reference hardware checks after every step<N> —
		# so it lands at the exact sub-instruction position reference hardware charges it to.
		while [ refresh_line < 262 ]
			rp : i32 [ refresh_rp[ refresh_line ] ]
			if [ (frame_master + op_master + steal_master) < rp ] break   # include pending steal (HDMA/DMA) so the refresh position matches reference hardware's mid-instruction clock
			if [ env_sf4 && cpu_cycles * 6 >= 433700 && cpu_cycles * 6 <= 434500 ] puts[ 'REFX line={refresh_line} rp={rp} at={frame_master + op_master + steal_master} M={cpu_cycles * 6}' ]
			op_master += 40
			refresh_line += 1
		spc.cycle_accum += i64[ op_master - tm0 ] * 128160   # advance SPC clock per access (sub-instruction) so an APU-port read syncs the SPC to the exact read cycle like reference hardware (EXACT ratio: 2050560/16 per master, APU crystal 24606720Hz)

	func cpu_tick [ bank: u32, addr: u16 ]
		spd : i32 [ cpu_speed[ bank, addr ] ]
		last_axs = spd
		cpu_tick_n[ spd, true ]

	# 24-bit data access for long-addressing opcodes. Route the I/O register window
	# ($2000-$43FF in banks $00-$3F/$80-$BF) to the register handler so a long read of
	# e.g. $004214 (RDDIV) hits the register, not raw RAM. ROM/WRAM stay flat as before.
	func cpu_long_r [ la: u32 ] -> u8
		bank : u32 [ la >> 16 ]
		addr : u16 [ u16[ la & 0xFFFF ] ]
		if [ (bank & 0x40) == 0 && addr < 0x2000 ]           # banks 00-3F/80-BF, $0000-1FFF = WRAM mirror — flat memory[la] there is JUNK (zelda's story parser reads its command list through a bank-00 long pointer)
			cpu_tick[ bank, addr ]
			wa : u32 [ 0x7E0000 + u32[addr] ]
			return cpu.memory[ wa ]
		if [ (bank & 0x40) == 0 && addr >= 0x2000 && addr <= 0x43FF ]
			return cpu_r[ addr ]
		cpu_tick[ bank, addr ]
		return cpu.memory[ la ]

	func cpu_long_w [ la: u32, val: u8 ]
		bank : u32 [ la >> 16 ]
		addr : u16 [ u16[ la & 0xFFFF ] ]
		if [ (bank & 0x40) == 0 && addr < 0x2000 ]           # WRAM mirror (see cpu_long_r)
			cpu_tick[ bank, addr ]
			wa : u32 [ 0x7E0000 + u32[addr] ]
			if [ env_joylog && wa >= 0x7E0876 && wa <= 0x7E0886 && dbg_ww < 400 ]
				printf[ "WW-lm [%06X]=%02X pc=%02X:%04X f%u\n", wa, u32[val], cpu.pbr, cpu.pc, dbg_frames ]
				dbg_ww += 1
			cpu.memory[ wa ] = val
			return
		if [ (bank & 0x40) == 0 && addr >= 0x2000 && addr <= 0x43FF ]
			cpu_w[ addr, val ]
			return
		cpu_tick[ bank, addr ]
		if [ env_joylog && la >= 0x7E0876 && la <= 0x7E0886 && dbg_ww < 400 ]
			printf[ "WW-ld [%06X]=%02X pc=%02X:%04X f%u\n", la, u32[val], cpu.pbr, cpu.pc, dbg_frames ]
			dbg_ww += 1
		cpu.memory[ la ] = val

	func cpu_rb [] -> u8
		v : u8 [ cpu_fetch_at[ cpu.pc ] ]
		cpu_tick[ cpu.pbr, cpu.pc ]
		cpu.pc += 1
		mdr = v                                   # open-bus latch (last bus value)
		return v

	func cpu_rw [] -> u16
		lo : u8 [ cpu_fetch_at[ cpu.pc ] ]
		cpu_tick[ cpu.pbr, cpu.pc ]
		cpu.pc += 1
		hi : u8 [ cpu_fetch_at[ cpu.pc ] ]
		cpu_tick[ cpu.pbr, cpu.pc ]
		cpu.pc += 1
		mdr = hi                                  # open-bus latch (last bus value)
		return lo | (hi << 8)

	# --- CPU register width helpers ---

	func cpu_get_A [] -> u16
		if [ cpu.p & 0x20 ]
			return cpu.a
		return cpu.a | (cpu.b << 8)

	func cpu_set_A [ v: u16 ]
		cpu.a = v & 0xFF
		if [ !(cpu.p & 0x20) ]
			cpu.b = v >> 8

	func cpu_get_X [] -> u16
		if [ cpu.p & 0x10 ]
			return cpu.x
		return cpu.x | (cpu.xh << 8)

	func cpu_set_X [ v: u16 ]
		cpu.x = v & 0xFF
		if [ cpu.p & 0x10 ]
			cpu.xh = 0                  # 8-bit index: high byte forced to 0
		el
			cpu.xh = v >> 8

	func cpu_get_Y [] -> u16
		if [ cpu.p & 0x10 ]
			return cpu.y
		return cpu.y | (cpu.yh << 8)

	func cpu_set_Y [ v: u16 ]
		cpu.y = v & 0xFF
		if [ cpu.p & 0x10 ]
			cpu.yh = 0                  # 8-bit index: high byte forced to 0
		el
			cpu.yh = v >> 8

	# width-aware immediate fetch: #imm is 1 byte in 8-bit mode, 2 in 16-bit.
	# getting this wrong desyncs the PC, so all A/X/Y immediate ops use these.
	func cpu_imm_a [] -> u16
		if [ cpu.p & 0x20 ] return cpu_rb[]
		return cpu_rw[]

	func cpu_imm_x [] -> u16
		if [ cpu.p & 0x10 ] return cpu_rb[]
		return cpu_rw[]

	# width-aware N/Z flag set for A-width / X-width results
	func cpu_nz_a [ v: u16 ]
		if [ cpu.p & 0x20 ]
			cpu.p = (cpu.p & ~0x82) | (((v & 0xFF) == 0) ? 0x02 : 0) | (v & 0x80)
		el
			cpu.p = (cpu.p & ~0x82) | ((v == 0) ? 0x02 : 0) | (((v & 0x8000) != 0) ? 0x80 : 0)

	func cpu_nz_x [ v: u16 ]
		if [ cpu.p & 0x10 ]
			cpu.p = (cpu.p & ~0x82) | (((v & 0xFF) == 0) ? 0x02 : 0) | (v & 0x80)
		el
			cpu.p = (cpu.p & ~0x82) | ((v == 0) ? 0x02 : 0) | (((v & 0x8000) != 0) ? 0x80 : 0)

	# data-bank-relative byte read: low system area (WRAM/registers) is bank-agnostic;
	# the ROM/data region uses the data bank register (DBR). dp modes pass low
	# addresses so DBR never affects them; absolute modes pass the real address.
	# bank-explicit byte read/write applying the LoROM map: low system area
	# (WRAM mirror / hardware registers) is bank-agnostic for system banks,
	# the rest reads the flat 24-bit map. Used by DBR-relative reads and MVN/MVP.
	func cpu_bank_r [ bank: u32, addr: u16 ] -> u8
		a32  : u32 [ u32[addr] ]
		if [ is_hirom && ((bank >= 0x40 && bank <= 0x7D) || bank >= 0xC0) ]
			cpu_tick[ bank, addr ]
			return cpu.memory[ (bank << 16) | a32 ]
		if [ bank != 0x7E && bank != 0x7F ]
			if [ addr < 0x2000 ]
				cpu_tick[ bank, addr ]                        # WRAM-mirror leaf access
				wa : u32 [ 0x7E0000 + a32 ]                   # WRAM mirror
				if [ dbg_frames >= 140 && dbg_frames <= 175 && addr == 0x0011 && dbg_ev < 80 ]
					printf[ "R[0011]=%02X pc=%02X:%04X f%u\n", cpu.memory[wa], cpu.pbr, cpu.pc, dbg_frames ]
					dbg_ev += 1
				return cpu.memory[ wa ]
			if [ addr >= 0x2000 && addr <= 0x43FF ]
				return cpu_r[ addr ]                          # hardware registers (cpu_r ticks)
		cpu_tick[ bank, addr ]                                # flat 24-bit leaf access
		fa : u32 [ (bank << 16) | a32 ]
		return cpu.memory[ fa ]

	func cpu_bank_w [ bank: u32, addr: u16, val: u8 ]
		a32  : u32 [ u32[addr] ]
		if [ is_hirom && ((bank >= 0x40 && bank <= 0x7D) || bank >= 0xC0) ]
			cpu_tick[ bank, addr ]
			cpu.memory[ (bank << 16) | a32 ] = val
			return
		if [ bank != 0x7E && bank != 0x7F ]
			if [ addr < 0x2000 ]
				cpu_tick[ bank, addr ]                        # WRAM-mirror leaf access
				wa : u32 [ 0x7E0000 + a32 ]                   # WRAM mirror
				if [ env_logzp && (addr == 0x0041 || addr == 0x0046 || addr == 0x0051 || addr == 0x005D || addr == 0x0060 || addr == 0x0062 || addr == 0x00F0) ]
					printf[ "W[%04X]=%02X pc=%02X:%04X (m)\n", addr, val, cpu.pbr, cpu.pc ]
				if [ env_pal && addr >= 0x0520 && addr <= 0x0530 && dbg_w < 80 ]
					printf[ "PALw[%04X]=%02X pc=%02X:%04X dbr=%02X f%u (mirror b=%02X)\n", addr, val, cpu.pbr, cpu.pc, cpu.dbr, dbg_frames, bank ]
					dbg_w += 1
				if [ addr >= 0x012C && addr <= 0x012F && val != 0 && dbg_w < 200 ]
					printf[ "SNDQ[%04X]=%02X sub=%02X pc=%02X:%04X f%u\n", addr, val, cpu.memory[0x7E0011], cpu.pbr, cpu.pc, dbg_frames ]
					dbg_w += 1
				if [ env_ww && a32 >= 0x1002 && a32 <= 0x1008 && dbg_frames >= 1524 && dbg_frames <= 1529 ]
					printf[ "ABUF f%u [%04X]=%02X pc=%02X:%04X fmaster=%d (m)\n", dbg_frames, a32, u32[val], cpu.pbr, cpu.pc, frame_master ]
				if [ env_joylog && a32 >= 0x0876 && a32 <= 0x0886 && dbg_ww < 400 ]
					printf[ "WW-bm [%04X]=%02X pc=%02X:%04X f%u\n", a32, u32[val], cpu.pbr, cpu.pc, dbg_frames ]
					dbg_ww += 1
				cpu.memory[ wa ] = val
				return
			if [ addr >= 0x2000 && addr <= 0x43FF ]
				cpu_w[ addr, val ]                            # hardware registers (cpu_w ticks)
				return
		cpu_tick[ bank, addr ]                                # flat 24-bit leaf access
		fa : u32 [ (bank << 16) | a32 ]
		if [ env_ww && fa >= 0x7E1002 && fa <= 0x7E1008 && dbg_frames >= 1524 && dbg_frames <= 1529 ]
			printf[ "ABUF f%u [%04X]=%02X pc=%02X:%04X fmaster=%d (d)\n", dbg_frames, a32, u32[val], cpu.pbr, cpu.pc, frame_master ]
		if [ env_pal && fa >= 0x7E0520 && fa <= 0x7E0530 && dbg_w < 80 ]
			printf[ "PALw[%04X]=%02X pc=%02X:%04X dbr=%02X f%u (direct b=%02X)\n", a32, val, cpu.pbr, cpu.pc, cpu.dbr, dbg_frames, bank ]
			dbg_w += 1
		if [ env_map && fa >= 0x7F4A00 && fa <= 0x7F4A07 && dbg_w2 < 120 ]
			printf[ "MAPw[%06X]=%02X pc=%02X:%04X f%u\n", fa, val, cpu.pbr, cpu.pc, dbg_frames ]
			dbg_w2 += 1
		if [ dbg_frames >= 205 && fa >= 0x7E1F00 && fa <= 0x7E1F0B && dbg_w < 60 ]
			printf[ "WRAM[%04X]=%02X bank_w-DIRECT bank=%02X pc=%02X:%04X f%u\n", a32, val, bank, cpu.pbr, cpu.pc, dbg_frames ]
			dbg_w += 1
		if [ env_joylog && fa >= 0x7E0876 && fa <= 0x7E0886 && dbg_ww < 400 ]
			printf[ "WW-bd [%06X]=%02X pc=%02X:%04X f%u\n", fa, u32[val], cpu.pbr, cpu.pc, dbg_frames ]
			dbg_ww += 1
		cpu.memory[ fa ] = val

	func cpu_db_r [ addr: u16 ] -> u8
		last_rd = (u32[cpu.dbr] << 16) | u32[addr]
		return cpu_bank_r[ cpu.dbr, addr ]

	func cpu_db_w [ addr: u16, val: u8 ]
		cpu_bank_w[ cpu.dbr, addr, val ]

	# reference hardware idle4: indexed READ (abs,X / abs,Y) adds one cycle when the index is 16-bit
	# (X flag clear) OR the effective address crosses a page boundary.
	func idx_pen [ base: u16, addr: u16 ] -> i32
		if [ (cpu.p & 0x10) == 0 ] return 1
		if [ (base & 0xFF00) != (addr & 0xFF00) ] return 1
		return 0

	# DBR-relative data access: the untruncated sum carries into DBR+1 (reference hardware readBank:
	# read((B << 16) + address & 0xffffff)) — callers may pass base+index sums > $FFFF
	func cpu_read_mem [ addr: u32 ] -> u16
		bk0 : u32 [ (u32[cpu.dbr] + (addr >> 16)) & 0xFF ]
		lo  : u16 [ cpu_bank_r[ bk0, u16[addr & 0xFFFF] ] ]
		if [ cpu.p & 0x20 ]
			return lo
		a1  : u32 [ addr + 1 ]
		bk1 : u32 [ (u32[cpu.dbr] + (a1 >> 16)) & 0xFF ]
		hi  : u16 [ cpu_bank_r[ bk1, u16[a1 & 0xFFFF] ] ]
		if [ u16[addr] == 0x1F0A && dbg_frames >= 219 && dbg_w < 70 ]
			m0 : u32 [ 0x7E1F0A ]
			m1 : u32 [ 0x7E1F0B ]
			printf[ "RD1F0A lo=%02X hi=%02X dbr=%02X mem=%02X %02X pc=%02X:%04X f%u\n", lo, hi, cpu.dbr, cpu.memory[m0], cpu.memory[m1], cpu.pbr, cpu.pc, dbg_frames ]
			dbg_w += 1
		return lo | (hi << 8)

	func cpu_write_mem [ addr: u32, v: u16 ]
		bk0 : u32 [ (u32[cpu.dbr] + (addr >> 16)) & 0xFF ]
		cpu_bank_w[ bk0, u16[addr & 0xFFFF], u8[v & 0xFF] ]
		if [ !(cpu.p & 0x20) ]
			a1  : u32 [ addr + 1 ]
			bk1 : u32 [ (u32[cpu.dbr] + (a1 >> 16)) & 0xFF ]
			cpu_bank_w[ bk1, u16[a1 & 0xFFFF], u8[v >> 8] ]

	# stack pointer adjust with emulation-mode wrap (reference hardware push/pull: E wraps S.l within page 1)
	func cpu_sp_dec []
		if [ cpu.e ] cpu.sp = 0x0100 | ((cpu.sp - 1) & 0xFF)
		el cpu.sp = (cpu.sp - 1) & 0xFFFF

	func cpu_sp_inc []
		if [ cpu.e ] cpu.sp = 0x0100 | ((cpu.sp + 1) & 0xFF)
		el cpu.sp = (cpu.sp + 1) & 0xFFFF

	# software interrupt body (BRK/COP): native pushes PBR and vectors into bank 0;
	# I set, D cleared (reference hardware instructionInterrupt)
	func cpu_swi [ vaddr: u16 ]
		if [ !cpu.e ]
			cpu_w[ cpu.sp, cpu.pbr ]
			cpu_sp_dec[]
		cpu_w[ cpu.sp, u8[cpu.pc >> 8] ]
		cpu_sp_dec[]
		cpu_w[ cpu.sp, u8[cpu.pc & 0xFF] ]
		cpu_sp_dec[]
		cpu_w[ cpu.sp, cpu.p ]
		cpu_sp_dec[]
		cpu.p = (cpu.p | 0x04) & ~0x08
		swlo : u16 [ cpu_r[vaddr] ]
		swhi : u16 [ cpu_r[vaddr + 1] ]
		cpu.pc  = swlo | (swhi << 8)
		cpu.pbr = 0

	# Direct-page accesses are ALWAYS bank 0 (never DBR). Use cpu_r/cpu_w (bank-0
	# semantics) so dp reads/writes agree with the (dp) pointer fetches, which also
	# use bank 0. (Bug: routing dp through DBR broke when DBR=$7F, e.g. fzero's
	# Mode 7 track decompressor doing STA $0C / LDA ($0C),Y.)
	func cpu_read_dp [ addr: u16 ] -> u16
		if [ cpu.p & 0x20 ]
			return cpu_r[ addr ]
		return cpu_r[ addr ] | (cpu_r[ (addr + 1) & 0xFFFF ] << 8)

	func cpu_write_dp [ addr: u16, v: u16 ]
		cpu_w[ addr, u8[v & 0xFF] ]
		if [ !(cpu.p & 0x20) ]
			cpu_w[ (addr + 1) & 0xFFFF, u8[v >> 8] ]

	# index-width-aware bank-0 dp read (for LDX/LDY/CPX/CPY dp)
	func cpu_read_dp_x [ addr: u16 ] -> u16
		if [ cpu.p & 0x10 ]
			return cpu_r[ addr ]
		return cpu_r[ addr ] | (cpu_r[ (addr + 1) & 0xFFFF ] << 8)

	# vblank NMI: push PCH,PCL,P (matches RTI pull order), jump to NMI vector.
	func cpu_nmi []
		if [ env_joylog && cpu.pbr == 0 && cpu.pc < 0x0100 && dbg_w2 < 3 ]
			printf[ "NMI FROM NULL %02X:%04X f%u sp=%04X — last 32 instrs:\n", cpu.pbr, cpu.pc, dbg_frames, cpu.sp ]
			for [ kq2: i32 0, kq2 < 32, kq2 += 1 ]
				sq2 : i32 [ (tr_i + kq2) % 32 ]
				printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[sq2] >> 16, tr_addr[sq2] & 0xFFFF, tr_b0[sq2], tr_b1[sq2], tr_b2[sq2], tr_b3[sq2], tr_p[sq2], tr_a[sq2], tr_x[sq2], tr_y[sq2] ]
			dbg_w2 += 1
		nmi_frames += 1                            # NMI-fired frame count (same unit as reference hardware g_frame)
		if [ nmi_frames <= 3 ] printf[ "asnes NMI#%u at cpu_cycles=%ld boot_port_reads=%ld\n", nmi_frames, cpu_cycles, dbg_pr ]
		if [ env_nmiabs ] printf[ "NMIABS n%u M=%ld intPC=%02X:%04X\n", nmi_frames, cpu_cycles * 6, cpu.pbr, cpu.pc ]
		op_master   = 0                            # count the interrupt sequence's access cycles
		idle_done   = 0
		op_accesses = 0
		count_cpu   = true
		cpu_tick[ u32[cpu.pbr], cpu.pc ]           # reference hardware interrupt() opens with read(PC.d) dummy read before the pushes
		##
		if [ dbg_frames >= 60 ]
			printf[ "NMIENTRY f%u savedpc=%02X:%04X sp=%04X p=%03X\n", dbg_frames, cpu.pbr, cpu.pc, cpu.sp, cpu.p ]
			if [ dbg_frames >= 72 && dbg_bad < 1 ]
				printf[ "  ---- 32 instrs before this NMI (savedpc=%04X) ----\n", cpu.pc ]
				for [ k: i32 0, k < 32, k += 1 ]
					s : i32 [ (tr_i + k) % 32 ]
					printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[s] >> 16, tr_addr[s] & 0xFFFF, tr_b0[s], tr_b1[s], tr_b2[s], tr_b3[s], tr_p[s], tr_a[s], tr_x[s], tr_y[s] ]
				dbg_bad += 1
		##
		if [ !cpu.e ]                              # native mode: interrupt pushes PBR
			cpu_w[ cpu.sp, cpu.pbr ]
			cpu_sp_dec[]
		cpu_w[ cpu.sp, u8[cpu.pc >> 8] ]
		cpu_sp_dec[]
		cpu_w[ cpu.sp, u8[cpu.pc & 0xFF] ]
		cpu_sp_dec[]
		cpu_w[ cpu.sp, cpu.p ]
		cpu_sp_dec[]
		cpu.p  |= 0x04
		cpu.p  &= ~0x08
		vaddr : u16 [ (cpu.e) ? 0xFFFA : 0xFFEA ]
		lo     : u8  [ cpu_r[ vaddr ] ]
		hi     : u8  [ cpu_r[ vaddr + 1 ] ]
		cpu.pc  = lo | (hi << 8)
		cpu.pbr = 0
		nmi_occurred = true
		count_cpu = false
		steal_master += op_master + ((cpu.e) ? 12 : 6)  # interrupt: pushes/vector reads + idle; idleJump is a no-op in native mode (reference hardware idle6: only when EF)
		op_master = 0
		if [ dbg_cpu < 6 ]
			printf[ "NMI fired: e=%d vec=%04X -> handler %04X (nmitimen=%02X)\n",
				cpu.e, vaddr, cpu.pc, nmitimen ]
			dbg_cpu += 1

	# Maskable H/V scanline IRQ. Mirrors cpu_nmi's push sequence; vector $FFFE
	# (emu) / $FFEE (native). Caller checks the I-flag before invoking.
	func cpu_irq []
		if [ env_joylog && cpu.pbr == 0 && cpu.pc < 0x0100 && dbg_w2 < 3 ]
			printf[ "IRQ FROM NULL %02X:%04X f%u sp=%04X — last 32 instrs:\n", cpu.pbr, cpu.pc, dbg_frames, cpu.sp ]
			for [ kq: i32 0, kq < 32, kq += 1 ]
				sq : i32 [ (tr_i + kq) % 32 ]
				printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[sq] >> 16, tr_addr[sq] & 0xFFFF, tr_b0[sq], tr_b1[sq], tr_b2[sq], tr_b3[sq], tr_p[sq], tr_a[sq], tr_x[sq], tr_y[sq] ]
			dbg_w2 += 1
		op_master   = 0                            # count the interrupt sequence's access cycles
		idle_done   = 0
		op_accesses = 0
		count_cpu   = true
		cpu_tick[ u32[cpu.pbr], cpu.pc ]           # reference hardware interrupt() opens with read(PC.d) dummy read before the pushes (cpu_nmi charges the same)
		if [ !cpu.e ]                              # native mode: push PBR
			cpu_w[ cpu.sp, cpu.pbr ]
			cpu_sp_dec[]
		cpu_w[ cpu.sp, u8[cpu.pc >> 8] ]
		cpu_sp_dec[]
		cpu_w[ cpu.sp, u8[cpu.pc & 0xFF] ]
		cpu_sp_dec[]
		cpu_w[ cpu.sp, cpu.p ]
		cpu_sp_dec[]
		cpu.p  |= 0x04
		cpu.p  &= ~0x08
		vaddr : u16 [ (cpu.e) ? 0xFFFE : 0xFFEE ]
		lo     : u8  [ cpu_r[ vaddr ] ]
		hi     : u8  [ cpu_r[ vaddr + 1 ] ]
		cpu.pc  = lo | (hi << 8)
		cpu.pbr = 0
		irq_occurred = true
		count_cpu = false
		steal_master += op_master + ((cpu.e) ? 12 : 6)  # interrupt: pushes/vector reads + idle; idleJump is a no-op in native mode (reference hardware idle6: only when EF)
		op_master = 0
		if [ env_irqlog && dbg_frames < 200 ]
			printf[ "IRQ f%u line=%d vtime=%d htime=%d nmitimen=%02X $0041=%02X%02X\n", dbg_frames, frame_cycle / 228, i32[vtime], i32[htime], nmitimen, cpu.memory[0x7E0042], cpu.memory[0x7E0041] ]

	# --- Gaussian interpolation for BRR samples ---

	func gaussian_interpolate [ frac: i32, ch: u16 ] -> i16
		fr : frac & 0xFF
		s0 : i16 [ spc.channels[ch].samples[0] ]
		s1 : i16 [ spc.channels[ch].samples[1] ]
		s2 : i16 [ spc.channels[ch].samples[2] ]
		s3 : i16 [ spc.channels[ch].samples[3] ]
		# authentic S-DSP 4-tap gaussian: s0=newest .. s3=oldest
		result : i32 [
			gauss[255 - fr] * i32[s3] +
			gauss[511 - fr] * i32[s2] +
			gauss[256 + fr] * i32[s1] +
			gauss[  0 + fr] * i32[s0]
		]
		result >>= 11
		if [ result >  32767 ] result = 32767
		if [ result < -32768 ] result = -32768
		return i16[result]

	# --- Echo processing ---

	func echo_add [ left: f32, right: f32 ]
		echo_delay  : u8  [ dsp_r[0x7D] & 0x0F ]
		echo_length : u16 [ echo_delay * 0x800 ]
		if [ echo_length == 0 ] return
		# FLG bit5 (ECEN, 0x20) DISABLES echo-buffer writes to RAM. real HW honors
		# this; writing anyway corrupts whatever the driver stores in that region.
		echo_writes : bool [ (dsp_r[0x6C] & 0x20) == 0 ]

		echo_enable   : u8 [ dsp_r[0x4D ] ]
		echo_volume_l : u8 [ dsp_r[0x2C ] ]
		echo_volume_r : u8 [ dsp_r[0x3C ] ]
		echo_feedback : u8 [ dsp_r[0x0D ] ]
		echo_start    : u16 [ dsp_r[0x6D ] << 8 ]

		echo_input_l : f32 [ 0.0 ]
		echo_input_r : f32 [ 0.0 ]
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ echo_enable & (1 << ch) ]
				echo_input_l += spc.channels[ch].output_l
				echo_input_r += spc.channels[ch].output_r

		nsamples    : u16 [ echo_length / 4 ]
		echo_addr_l : u16 [ echo_start + (spc.echo_pos * 4)     ]
		echo_addr_r : u16 [ echo_start + (spc.echo_pos * 4) + 2 ]

		# read the delayed sample from the ring buffer and push it into the 8-tap
		# FIR delay line (8 *consecutive* reads, NOT spread across the buffer —
		# spreading produces a per-buffer-length repeat that masks the music).
		spc.fir_idx = (spc.fir_idx + 1) & 7
		spc.fir_hist_l[spc.fir_idx] = i16[spc_r16[echo_addr_l]] / 32768.0
		spc.fir_hist_r[spc.fir_idx] = i16[spc_r16[echo_addr_r]] / 32768.0

		fir_l : f32 [ 0.0 ]
		fir_r : f32 [ 0.0 ]
		for [ tap: i32 0, tap < 8, tap += 1 ]
			coeff : f32 [ i8[dsp_r[0x0F + (tap * 0x10)]] / 128.0 ]
			h     : i32 [ (spc.fir_idx - 7 + tap) & 7 ]   # tap 7 = newest
			fir_l += spc.fir_hist_l[h] * coeff
			fir_r += spc.fir_hist_r[h] * coeff

		efb : f32 [ i8[echo_feedback] / 128.0 ]
		# write back: this sample's dry echo input + FIR output * feedback
		new_l : f32 [ clamp[ echo_input_l + fir_l * efb, -1.0, 1.0 ] ]
		new_r : f32 [ clamp[ echo_input_r + fir_r * efb, -1.0, 1.0 ] ]
		if [ echo_writes ]
			nel : i16 [ new_l * 32767 ]
			ner : i16 [ new_r * 32767 ]
			spc_w[ echo_addr_l,     u8[nel & 0xFF] ]
			spc_w[ echo_addr_l + 1, u8[nel >> 8]   ]
			spc_w[ echo_addr_r,     u8[ner & 0xFF] ]
			spc_w[ echo_addr_r + 1, u8[ner >> 8]   ]

		spc.echo_pos = (spc.echo_pos + 1) % nsamples

		echo_out_l = fir_l * (i8[echo_volume_l] / 128.0)
		echo_out_r = fir_r * (i8[echo_volume_r] / 128.0)

	# --- Direct DSP audio test (no CPU, no upload) ---
	# Loads a tiny looping BRR square wave into SPC RAM, points voice 0 at it,
	# and keys it on by writing the DSP registers directly. Proves the
	# SPC-DSP -> generate_audio -> ALSA path in isolation from the cartridge.
	func audio_test []
		reset_spc[]
		# two BRR blocks of a square wave. block0 ($0200) is plain data; block1
		# ($0209) carries end+loop so the decoder loops back to $0200 -> a
		# continuous ~1kHz square. shift=12, filter=0.
		spc.ram[0x0200] = 0xC0              # block0 header: shift=C, no flags
		spc.ram[0x0209] = 0xC3              # block1 header: shift=C, end+loop
		for [ n: i32 0, n < 4, n += 1 ]
			spc.ram[0x0201 + n] = 0x77      # block0: two +7 nibbles
			spc.ram[0x0205 + n] = 0x88      # block0: two -8 nibbles
			spc.ram[0x020A + n] = 0x77      # block1: two +7 nibbles
			spc.ram[0x020E + n] = 0x88      # block1: two -8 nibbles
		# sample directory at $0100, entry 0: start=$0200, loop=$0200
		spc.ram[0x0100] = 0x00
		spc.ram[0x0101] = 0x02
		spc.ram[0x0102] = 0x00
		spc.ram[0x0103] = 0x02
		# DSP voice 0 + master volume, gain mode (no ADSR ramp), key on
		spc.dsp[0x5D] = 0x01                # sample directory page = $0100
		spc.dsp[0x00] = 0x7F                # voice 0 vol L
		spc.dsp[0x01] = 0x7F                # voice 0 vol R
		spc.dsp[0x02] = 0x00                # pitch lo
		spc.dsp[0x03] = 0x10                # pitch hi -> 0x1000 = 1.0x (32kHz)
		spc.dsp[0x04] = 0x00                # source number 0
		spc.dsp[0x05] = 0x00                # ADSR1 bit7=0 -> use GAIN
		spc.dsp[0x07] = 0x7F                # GAIN direct, near-max envelope
		spc.dsp[0x0C] = 0x7F                # master vol L
		spc.dsp[0x1C] = 0x7F                # master vol R
		spc.dsp[0x4C] = 0x01                # KON voice 0
		spc_keyon[ 0 ]
		puts[ 'audio_test: voice 0 keyed on (~2kHz square)' ]

	# --- .spc playback (isolates SPC700 + DSP + timers; no CPU/ROM/upload) ---
	# Loads an APU snapshot: 64KB RAM, 128 DSP regs, and the SPC700 registers,
	# then we just run spc_step + generate_audio. Proves the SPC core end-to-end.
	func load_spc []
		reset_spc[]
		f : ref FILE [ fopen[ spcfile, 'rb' ] ]
		expect f, 'could not open spc file: {spcfile}'
		buf : ref u8 [ calloc[ 1, 0x10200 ] ]
		fread[ buf, 1, 0x10200, f ]
		fclose[ f ]
		spc.pc  = u16[buf[0x25]] | (u16[buf[0x26]] << 8)
		spc.a   = buf[0x27]
		spc.x   = buf[0x28]
		spc.y   = buf[0x29]
		spc.psw = buf[0x2A]
		spc.sp  = buf[0x2B]
		memcpy[ spc.ram, buf + 0x100, 0x10000 ]
		memcpy[ spc.dsp, buf + 0x10100, 128 ]
		free[ buf ]
		# seed the APU input ports (CPU->APU latch) from the snapshot. a .spc rip
		# has no main CPU, so these stay frozen at capture — the driver keeps
		# seeing the same "play track" handshake and never fades/stops.
		spc.ports[0] = spc.ram[0xF4]
		spc.ports[1] = spc.ram[0xF5]
		spc.ports[2] = spc.ram[0xF6]
		spc.ports[3] = spc.ram[0xF7]
		# seed timer state from the snapshot's APU registers
		spc.timer_on        = spc.ram[0xF1] & 0x07
		spc.timer_target[0] = spc.ram[0xFA]
		spc.timer_target[1] = spc.ram[0xFB]
		spc.timer_target[2] = spc.ram[0xFC]
		# key on any voices the snapshot left active
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ spc.dsp[0x4C] & (1 << ch) ] spc_keyon[ ch ]
		printf[ "loaded spc: pc=%04X a=%02X sp=%02X F1=%02X dividers=%02X %02X %02X\n",
			spc.pc, spc.a, spc.sp, spc.ram[0xF1], spc.ram[0xFA], spc.ram[0xFB], spc.ram[0xFC] ]


	# --- Audio generation ---

	# apply key-off then key-on latched since the last DSP sample (KON wins,
	# matching the S-DSP: a voice keyed this sample sounds)
	func apply_latches []
		if [ spc.koff_latch || spc.kon_latch ]
			for [ kc: i32 0, kc < 8, kc += 1 ]
				if [ spc.koff_latch & (1 << kc) ] spc_keyoff[ kc ]
				if [ spc.kon_latch & (1 << kc) ] spc_keyon[ kc ]
			spc.kon_latch  = 0
			spc.koff_latch = 0

	func wall_ms [] -> i64
		tsp : local i64 [ 2 ]
		clock_gettime[ 1, tsp ]
		return tsp[0] * 1000 + tsp[1] / 1000000

	func audio_slice_size [] -> sz
		to_write : sz [ spc.sample_rate / 60 ]
		if [ to_write > spc.buffer_size ] to_write = spc.buffer_size
		return to_write

	func flush_audio [ to_write: sz ]
		wr : i64 [ snd_pcm_writei[ spc.pcm_handle, spc.audio_buffer, to_write ] ]
		if [ wr == -EPIPE ]
			printf[ "AUDIO underrun f%u (wrote %ld of %ld)\n", dbg_frames, wr, i64[to_write] ]
			snd_pcm_recover[ spc.pcm_handle, wr, 0 ]
			snd_pcm_prepare[ spc.pcm_handle ]

	# Advance the SPC to catch up to the CPU (drain accumulated cycles), emitting audio
	# samples as it goes. Called on every APU-port access (reference hardware synchronizeSMP) so the
	# CPU sees a fresh port value / the SPC has processed pending command writes.
	func spc_drain [ tgt: i32 ]
		while [ spc.cycle_accum > 0 ]                # run SPC until at-or-ahead of the CPU clock (reference hardware: SMP runs while smp.clock < 0, crossing to >= 0)
			scy : i32 [ spc_step[] ]
			spc.cycle_accum -= i64[ scy ] * 2684659    # 2684659 per SPC cycle vs 128160 per master = EXACT reference hardware ratio 42954544:2050560 reduced by 16
			spc.audio_sub += scy
			if [ spc.audio_sub >= 32 ]
				spc.audio_sub -= 32
				# DSP state (envelopes, BRR position, ENDX, echo) advances every 32 SPC cycles
				# UNCONDITIONALLY, like reference hardware running the DSP alongside the SMP — the driver
				# reads ENDX/envelopes, so state must not depend on audio-buffer room. Only
				# the buffer store is capped: i = -1 drops the sample.
				mix_one_sample[ (spc.audio_done < tgt) ? spc.audio_done : -1 ]
				if [ spc.audio_done < tgt ] spc.audio_done += 1

	# mix one DSP output sample (8 voices + echo) into audio_buffer[i]
	func mix_one_sample [ i: i32 ]
			apply_latches[]

			left  : f32 [ 0.0 ]
			right : f32 [ 0.0 ]

			for [ ch: u16 0, ch < 8, ch += 1 ]
				# inactive voices must contribute 0 to the echo, not their stale
				# last output — otherwise dead voices keep feeding the echo buffer
				if [ !spc.channels[ch].active ]
					spc.channels[ch].output_l = 0.0
					spc.channels[ch].output_r = 0.0
					continue

				ch_base : u8 [ ch * 0x10 ]
				vol_l   : u8 [ dsp_r[ch_base + 0x00 ] ]
				vol_r   : u8 [ dsp_r[ch_base + 0x01 ] ]
				pitch_l : u8 [ dsp_r[ch_base + 0x02 ] ]
				pitch_h : u8 [ dsp_r[ch_base + 0x03 ] ]
				src_n   : u8 [ dsp_r[ch_base + 0x04 ] ]
				adsr1   : u8 [ dsp_r[ch_base + 0x05 ] ]
				adsr2   : u8 [ dsp_r[ch_base + 0x06 ] ]
				gain    : u8 [ dsp_r[ch_base + 0x07 ] ]

				pitch : u16 [ pitch_l | ((pitch_h & 0x3F) << 8) ]
				if [ pitch == 0 ]
					spc.channels[ch].output_l = 0.0
					spc.channels[ch].output_r = 0.0
					continue

				dir_page     : u8  [ dsp_r[0x5D ] ]
				src_dir      : u16 [ (dir_page << 8) + (src_n * 4) ]
				sample_start : u16 [ spc_r16[src_dir] ]
				sample_loop  : u16 [ spc_r16[src_dir + 2] ]

				spc.channels[ch].frac += pitch
				while [ spc.channels[ch].frac >= 0x1000 ]
					spc.channels[ch].frac -= 0x1000
					spc.channels[ch].pos  += 1

					block_pos : u16 [ sample_start + (spc.channels[ch].pos / 16) * 9 ]
					block_header : u8  [ spc_r[ block_pos ] ]
					sample_idx   : u8  [ spc.channels[ch].pos % 16 ]

					sample_byte : u8  [ spc_r[ block_pos + 1 + (sample_idx / 2) ] ]
					hi_nib      : i8 [ (sample_byte >> 4) & 0xF ]
					lo_nib      : i8 [ sample_byte & 0xF ]
					sample_4bit : i8 [ (sample_idx & 1) ? lo_nib : hi_nib ]
					if [ sample_4bit > 7 ] sample_4bit -= 16

					shift_amt  : u8  [ block_header >> 4 ]
					dec_sample : i32 [ i32[sample_4bit] << shift_amt ]
					if [ shift_amt > 12 ]                  # invalid shift: sign bit only
						dec_sample = (i32[sample_4bit] >> 4) << 11
					# BRR IIR filters use arithmetic shifts (floor), matching the
					# S-DSP exactly — C-style * / truncation buzzes on negatives.
					bfilter    : u8  [ (block_header >> 2) & 0x3 ]
					switch [ bfilter ]
						case 0
							# no filter
						case 1
							s0 : i32 [ spc.channels[ch].samples[0] ]
							dec_sample += s0 + ((0 - s0) >> 4)
						case 2
							s0 : i32 [ spc.channels[ch].samples[0] ]
							s1 : i32 [ spc.channels[ch].samples[1] ]
							dec_sample += (s0 << 1) + ((0 - (s0 * 3)) >> 5) - s1 + (s1 >> 4)
						case 3
							s0 : i32 [ spc.channels[ch].samples[0] ]
							s1 : i32 [ spc.channels[ch].samples[1] ]
							dec_sample += (s0 << 1) + ((0 - (s0 * 13)) >> 6) - s1 + ((s1 * 3) >> 4)

					if [ dec_sample >  32767 ] dec_sample =  32767
					if [ dec_sample < -32768 ] dec_sample = -32768

					spc.channels[ch].samples[3] = spc.channels[ch].samples[2]
					spc.channels[ch].samples[2] = spc.channels[ch].samples[1]
					spc.channels[ch].samples[1] = spc.channels[ch].samples[0]
					spc.channels[ch].samples[0] = i16[dec_sample]

					# end-of-block: after decoding sample 15, honor the END/LOOP flags
					# BRR header bit0 = END, bit1 = LOOP
					if [ sample_idx == 15 && (block_header & 0x01) ]
						spc.dsp[0x7C] = spc.dsp[0x7C] | (1 << ch)   # set ENDX
						if [ block_header & 0x02 ]                  # loop
							spc.channels[ch].pos = (((sample_loop - sample_start) / 9) * 16) - 1
						el
							spc.channels[ch].active   = 0           # one-shot finished
							spc.channels[ch].envelope = 0

				frac_v : u8  [ spc.channels[ch].frac >> 4 ]
				interp : i16 [ gaussian_interpolate[ frac_v, ch ] ]

				# --- envelope update (range 0..0x7FF) ---
				env : i32 [ spc.channels[ch].envelope ]
				if [ spc.channels[ch].env_state == 3 ]
					env -= 8                                   # release: linear fade
					if [ env <= 0 ]
						env = 0
						spc.channels[ch].active = 0
				el [ adsr1 & 0x80 ]
					arate : i32 [ adsr2 & 0x1F ]               # sustain rate default
					if [ spc.channels[ch].env_state == 0 ]
						arate = ((adsr1 & 0x0F) << 1) + 1         # attack
					el [ spc.channels[ch].env_state == 1 ]
						arate = (((adsr1 >> 4) & 0x07) << 1) + 16 # decay
					aper : i32 [ env_rate[ arate ] ]
					if [ aper > 0 ]
						spc.channels[ch].env_count += 1
						if [ spc.channels[ch].env_count >= aper ]
							spc.channels[ch].env_count = 0
							if [ spc.channels[ch].env_state == 0 ]
								env += ((arate == 31) ? 1024 : 32)
								if [ env >= 0x7FF ]
									env = 0x7FF
									spc.channels[ch].env_state = 1
							el
								env -= (((env - 1) >> 8) + 1)
								sl : i32 [ (((adsr2 >> 5) & 0x07) + 1) << 8 ]
								if [ spc.channels[ch].env_state == 1 && env <= sl ]
									spc.channels[ch].env_state = 2
				el
					if [ gain & 0x80 ]
						gmode : u8  [ (gain >> 5) & 0x03 ]
						grate : i32 [ gain & 0x1F ]
						gper  : i32 [ env_rate[ grate ] ]
						if [ gper > 0 ]
							spc.channels[ch].env_count += 1
							if [ spc.channels[ch].env_count >= gper ]
								spc.channels[ch].env_count = 0
								switch [ gmode ]
									case 0
										env -= 32
									case 1
										env -= (((env - 1) >> 8) + 1)
									case 2
										env += 32
									default
										env += ((env < 0x600) ? 32 : 8)
					el
						env = (gain & 0x7F) << 4                  # direct gain
				if [ env > 0x7FF ] env = 0x7FF
				if [ env < 0 ] env = 0
				spc.channels[ch].envelope = i16[ env ]
				spc.dsp[ ch_base + 0x08 ] = u8[ (env >> 4) & 0x7F ]   # ENVX

				final_sample : i32 [ (i32[interp] * env) >> 11 ]
				if [ final_sample >  32767 ] final_sample =  32767
				if [ final_sample < -32768 ] final_sample = -32768
				l : f32 [ (final_sample / 32768.0) * (i8[vol_l] / 128.0) ]
				r : f32 [ (final_sample / 32768.0) * (i8[vol_r] / 128.0) ]
				spc.channels[ch].output_l = l
				spc.channels[ch].output_r = r
				left  += l
				right += r

			mvol_l : u8 [ dsp_r[0x0C ] ]
			mvol_r : u8 [ dsp_r[0x1C ] ]
			left  *= i8 [ mvol_l ] / 128.0
			right *= i8 [ mvol_r ] / 128.0

			echo_add[ left, right ]
			left  = clamp[ left  + echo_out_l, -1.0, 1.0 ]
			right = clamp[ right + echo_out_r, -1.0, 1.0 ]

			if [ i >= 0 ]                          # i = -1: buffer full — DSP state advanced above, sample dropped
				spc.audio_buffer[i * 2]     = i16[ left  * 32000 * volume ]
				spc.audio_buffer[i * 2 + 1] = i16[ right * 32000 * volume ]

	# .spc / beep path: SPC + DSP only, no CPU. one real-time slice per call.
	func generate_audio [ sps: i32 ]
		avail : i64 [ snd_pcm_avail[ spc.pcm_handle ] ]
		if [ avail < 0 ]
			if [ avail == -EPIPE ]
				snd_pcm_recover[ spc.pcm_handle, avail, 0 ]
				snd_pcm_prepare[ spc.pcm_handle ]
			return
		to_write : sz [ audio_slice_size[] ]
		if [ to_write <= 0 ] return
		for [ i: i32 0, i < to_write, i += 1 ]
			for [ k: i32 0, k < sps, k += 1 ]
				spc_step[]
			mix_one_sample[ i ]
		flush_audio[ to_write ]

	# ROM path: co-schedule the 65816 + SPC700/DSP for one real-time frame.
	# the SPC advances ONLY at safe points — when the CPU reads an APU port
	# (handshake catch-up) and in a bulk pass after the CPU frame — so the
	# game's multi-port command bursts land atomically and the driver never
	# reads a half-written command. blocking audio paces it to 60fps.
	# legacy pre-refactor scheduling (continuous SPC stepping in the CPU loop,
	# mix the whole slice at the end). diagnostic: this version flowed the
	# 2nd-upload command (music played) but had the steady-state port race.
	# Boot phase (silent): step the SPC continuously so the sound driver reaches
	# its loader and the song uploads (the boot handshake needs continuous SPC).
	# no audio is playing yet, so the port race can't corrupt anything audible.
	func run_rom_frame_boot []
		avail : i64 [ snd_pcm_avail[ spc.pcm_handle ] ]
		if [ avail < 0 ]
			if [ avail == -EPIPE ]
				snd_pcm_recover[ spc.pcm_handle, avail, 0 ]
				snd_pcm_prepare[ spc.pcm_handle ]
			return
		to_write : sz [ audio_slice_size[] ]
		if [ to_write <= 0 ] return
		samples   : i32  [ i32[to_write] ]
		spc.audio_done = 0
		spc.audio_sub  = 0
		nmi_cyc   : i32  [ 225 * 1364 / 6 ]
		nmi_fired : bool [ false ]
		nmi_arm   : bool [ false ]
		irq_arm   : bool [ false ]
		flen      : i32  [ ((dbg_frames & 1) == 0) ? 357368 : 357364 ]   # NTSC field toggle: scanline 240 is 1360 (-4) on field 1 — frame 0 is the FULL field (reference hardware first vc-wrap at exactly 262*1364)
		fcpu      : i32  [ 0 ]
		hline = 0
		sline = 0
		frame_master = frame_carry                                       # master-based frame: carry the overshoot, stays aligned with reference hardware's dot
		if [ env_fstart ] printf[ "FSTART f%u M=%ld carry=%d flen=%d\n", dbg_frames, cpu_cycles*6 + i64[cpu_master_rem], frame_carry, flen ]
		refresh_line = 0
		irq_line_fired : i32 [ -1 ]
		in_vblank = false
		nmi_occurred = false                         # RDNMI latch auto-lowers at vblank end (reference hardware: nmiValid falling edge at vc=0)
		hsetup_pend = true                           # fired at dot 12+dmaCounter via the cycle-start edge (reference hardware hdmaSetupPosition)
		frame_m7x = ppu.m7x
		frame_m7y = ppu.m7y
		while [ frame_master < flen ]
			if [ cpu_wai && !nmi_fired ]
				wtar : i32 [ 306902 ]
				wim  : u8  [ nmitimen & 0x30 ]
				if [ wim != 0 && (cpu.p & 0x04) == 0 ]
					witl : i32 [ -1 ]
					if [ wim == 0x10 ] witl = (frame_master / 1364) + 1
					el [ irq_line_fired != i32[vtime] ] witl = i32[vtime]
					if [ witl >= 0 ]
						wic : i32 [ witl * 1364 + (((wim & 0x10) != 0) ? (i32[htime] * 4) : 0) + 2 ]   # wake at the derived IRQ latch (htime dots into the line for H/HV)
						if [ wic > frame_master && wic < wtar ] wtar = wic
				if [ wtar > frame_master ]
					wk : i32 [ (wtar - frame_master + 5) / 6 ]   # reference hardware instructionWait burns 6-master idles: wake on the entry-phase 6-grid at/after the latch
					frame_master += wk * 6
					fcpu         += wk
					cpu_cycles   += i64[ wk ]                    # WAI idles are REAL master cycles: the M-clock advances through them (this was frozen -> frame-relative drift vs reference hardware)
					master_phase = (master_phase + wk * 6) & 7   # the absolute phase advances through WAI too — skipping this shifted the DMA-sync baseline by wk*6 mod 8 per WAI (f1498 scroll DMA sy=8 vs reference hardware sync=6)
					spc.cycle_accum += i64[ wk * 6 ] * 128160    # and the SPC runs through them too
					snap_lines[ frame_master ]
					if [ hsetup_pend && frame_master >= 20 ]
						hsetup_pend = false
						hdma_setup[ 6 ]
					while [ hline < 225 ]                        # service HDMA dots the WAI jump passed (idle edges, clk=6)
						if [ (hline * 1364 + 1104) > frame_master ] break
						hsrc = 3
						hdma_run_line[ 6 ]
						hline += 1
			if [ env_irqov && !nmi_fired && frame_master >= 306902 ] puts[ 'NMIOV f{dbg_frames} over={frame_master - 306902} iend={nmi_iend} arm={nmi_arm} op={nmi_lastop} axs={last_axs}' ]
			if [ !nmi_fired && frame_master >= 306902 && !nmi_arm && !cpu_wai && (frame_master - 306902) < ((nmi_iend) ? 10 : 12) ]   # NMI bounds FIXED 10/12 (from-reset master data: f159 INY crossing delays at raw over ~8 — the conv +2 does NOT extend the take window, it only adds entry cost)
				nmi_arm = true                         # latch fell in the crossing instruction's LAST cycle: sampled too late, taken one instruction later. Cutoff = last-cycle master + 4 (nmiPoll pipeline): internal-final ops (op_accesses==1) end in a 6-master idle -> 10; memory-ending ops end in an 8-master access -> 12
				in_vblank    = true                    # RDNMI latch rises at the vblank latch, NOT at the take (reference hardware nmiLine raise):
				nmi_occurred = true                    # the ONE instruction between arm and take (ff3's LDA $4210 poll at C0:B7A0) must read bit7=1
			el [ !nmi_fired && frame_master >= 306902 ]
				# reference hardware idleIRQ: a pending interrupt converts the interrupted instruction's final
				# INTERNAL cycle into a PC bus read (8 master in slow ROM vs 6 idle) — applies to
				# 2-cycle implied/transfer ops (single fetch access + internal cycle)
				if [ nmi_conv && !cpu_wai && (nmitimen & 0x80) ]
					xir : i32 [ cpu_speed[ cpu.pbr, cpu.pc ] - 6 ]
					if [ xir > 0 ] steal_master += xir     # steal propagates into instr_master -> frame_master + SPC accum at the handler's first instruction
				in_vblank    = true
				nmi_occurred = true
				cpu_wai      = false
				ppu_latch_shot[]
				if [ env_hashlog && (nmitimen & 0x80) ] printf[ "HASH f%u %08X\n", dbg_frames, state_hash[] ]
				if [ env_fsig && (nmitimen & 0x80) ] emit_sigs[ '.' ]
				if [ env_gfxlog && (nmitimen & 0x80) ] printf[ "GFX f%u %08X\n", dbg_frames, gfx_hash[] ]
				if [ env_wdump >= 0 && dbg_frames == u32[env_wdump] ] write_snapshot[ '/tmp/asnes_wram.bin' ]
				if [ env_nmifire && dbg_frames >= 1480 && dbg_frames <= 1535 ] printf[ "NMIFIRE f%u intPC=%02X:%04X fmaster=%d\n", dbg_frames, cpu.pbr, cpu.pc, frame_master ]
				if [ env_nmiabs && (nmitimen & 0x80) ] printf[ "NMIABS f%u fmaster=%d M=%ld intPC=%02X:%04X\n", dbg_frames, frame_master, cpu_cycles*6, cpu.pbr, cpu.pc ]
				if [ nmitimen & 0x80 ] cpu_nmi[]
				nmi_fired = true
			if [ nmi_retro ]                            # $4200 enable-during-vblank retro-trigger (independent of the per-frame NMI)
				nmi_retro = false
				cpu_wai   = false
				cpu_nmi[]
			cnl : i32 [ frame_master / 1364 ]   # exact scanline (fcpu/228 was CPU-cycle-based: 228*6=1368 != 1364, drifting 4 master/line)
			im  : u8  [ nmitimen & 0x30 ]
			if [ im != 0 && (cpu.p & 0x04) == 0 && cnl < 224 ]
				do_irq : bool [ false ]
				if [ im == 0x10 ]
					if [ cnl != irq_line_fired ] do_irq = true
				el [ cnl == i32[vtime] && irq_line_fired != i32[vtime] ]   # EXACT line match (reference hardware: vcounter==vtime): >= retro-fired a vtime=0 V-IRQ the instant ff3 enabled it mid-frame, jumping through its not-yet-installed handler pointer to $0000
					do_irq = true
				if [ do_irq ]
					# same interrupt pipeline as NMI: latch = line start + 2; the take/arm cutoff and
					# the idleIRQ +2 conversion mirror the calibrated NMI rules
					lirq : i32 [ ((im == 0x10) ? cnl : i32[vtime]) * 1364 + (((im & 0x10) != 0) ? (i32[htime] * 4) : 0) + 2 ]   # H and HV IRQs latch at htime dots (4 master each) into the line; V-only latches at line start
					ovr : i32 [ frame_master - lirq ]
					if [ env_irqov ] puts[ 'IRQOV f{dbg_frames} over={ovr} iend={nmi_iend}' ]
					# derived from 1060 reference hardware IRQABS entries: take the IRQ iff over >= last-cycle+12
					# (18 internal-final, 20 memory-ending); below that just re-check at the next
					# boundary — no one-shot arm (reference hardware waits through MULTIPLE short boundaries,
					# e.g. f459 skipped over=2 AND over=16 before firing at 48). CLI skips one boundary.
					if [ cpu_wai || (ovr >= ((nmi_iend) ? 18 : (last_axs + 12)) && !irq_cli) ]   # memory-ending: bound = the FINAL ACCESS's real speed + 12 (6-master I/O-ending ops fire at 18, 8-master at 20)
						cpu_wai = false
						if [ nmi_conv ]
							xii : i32 [ cpu_speed[ cpu.pbr, cpu.pc ] - 6 ]
							if [ xii > 0 ] steal_master += xii
						cpu_irq[]
						if [ im == 0x10 ] irq_line_fired = cnl
						el irq_line_fired = i32[vtime]
			if [ cpu_wai ]
				break
			snap_lines[ frame_master ]
			c : i32 [ cpu_step[] ]
			if [ c < 2 ] c = 2
			fcpu += c
			cpu_cycles += i64[ c ]
			frame_cycle = fcpu
			if [ cpu_wai ]                             # only WAI advances the clock without ticks; normal dots roll to the next instruction's fetch edge (reference hardware cycle-start semantics)
				nl : i32 [ (frame_master + 260) / 1364 ]
				while [ hline < nl && hline < 225 ]
					hsrc = 3
					hdma_run_line[ 6 ]
					hline += 1
			spc_drain[ samples ]                     # boot: SPC clock advanced per-access in cpu_tick; drain to keep it synced every instruction
		frame_carry = frame_master - flen            # conserve overshoot in MASTER (keeps frame_master aligned with reference hardware's dot across frames)
		if [ frame_carry < 0 ] frame_carry = 0
		if [ hsetup_pend ]
			hsetup_pend = false
			hdma_setup[ 8 ]
		snap_lines[ 400000 ]
		while [ hline < 225 ]
			hsrc = 3
			hdma_run_line[ 6 ]
			hline += 1
		if [ !nmi_fired ]
			in_vblank    = true
			nmi_occurred = true
			ppu_latch_shot[]
			if [ nmitimen & 0x80 ] cpu_nmi[]
		spc_drain[ samples ]                         # end-of-frame catch-up: SPC runs only to the CPU's clock (never past it) — the balance carries across frames like reference hardware; audio gets however many samples that yields
		in_vblank = false
		flush_audio[ sz[ spc.audio_done ] ]          # write only what was actually produced this frame

	# Co-scheduler (clean ding): SPC advances only at safe points — when the CPU
	# reads an APU port (handshake catch-up) and in a bulk pass after the CPU
	# frame — so command write-bursts are atomic to the SPC. blocking audio paces 60fps.
	func run_rom_frame []
		avail : i64 [ snd_pcm_avail[ spc.pcm_handle ] ]
		if [ avail < 0 ]
			if [ avail == -EPIPE ]
				snd_pcm_recover[ spc.pcm_handle, avail, 0 ]
				snd_pcm_prepare[ spc.pcm_handle ]
			return
		to_write : sz [ audio_slice_size[] ]
		if [ to_write <= 0 ] return
		samples   : i32  [ i32[to_write] ]
		spc.audio_done = 0
		spc.audio_sub  = 0
		nmi_cyc   : i32  [ 225 * 1364 / 6 ]
		nmi_fired : bool [ false ]
		nmi_arm   : bool [ false ]
		irq_arm   : bool [ false ]
		flen      : i32  [ ((dbg_frames & 1) == 0) ? 357368 : 357364 ]   # NTSC field toggle: scanline 240 is 1360 (-4) on field 1 — frame 0 is the FULL field (reference hardware first vc-wrap at exactly 262*1364)
		fcpu      : i32  [ 0 ]
		hline = 0
		sline = 0
		frame_master = frame_carry                                       # master-based frame: carry the overshoot, stays aligned with reference hardware's dot
		if [ env_fstart ] printf[ "FSTART f%u M=%ld carry=%d flen=%d\n", dbg_frames, cpu_cycles*6 + i64[cpu_master_rem], frame_carry, flen ]
		refresh_line = 0
		irq_line_fired : i32 [ -1 ]
		in_vblank = false
		nmi_occurred = false                         # RDNMI latch auto-lowers at vblank end (reference hardware: nmiValid falling edge at vc=0)
		hsetup_pend = true                           # fired at dot 12+dmaCounter via the cycle-start edge (reference hardware hdmaSetupPosition)
		frame_m7x = ppu.m7x
		frame_m7y = ppu.m7y
		while [ frame_master < flen ]
			if [ cpu_wai && !nmi_fired ]
				wtar : i32 [ 306902 ]
				wim  : u8  [ nmitimen & 0x30 ]
				if [ wim != 0 && (cpu.p & 0x04) == 0 ]
					witl : i32 [ -1 ]
					if [ wim == 0x10 ] witl = (frame_master / 1364) + 1
					el [ irq_line_fired != i32[vtime] ] witl = i32[vtime]
					if [ witl >= 0 ]
						wic : i32 [ witl * 1364 + (((wim & 0x10) != 0) ? (i32[htime] * 4) : 0) + 2 ]   # wake at the derived IRQ latch (htime dots into the line for H/HV)
						if [ wic > frame_master && wic < wtar ] wtar = wic
				if [ wtar > frame_master ]
					wk : i32 [ (wtar - frame_master + 5) / 6 ]   # reference hardware instructionWait burns 6-master idles: wake on the entry-phase 6-grid at/after the latch
					frame_master += wk * 6
					fcpu         += wk
					cpu_cycles   += i64[ wk ]                    # WAI idles are REAL master cycles: the M-clock advances through them (this was frozen -> frame-relative drift vs reference hardware)
					master_phase = (master_phase + wk * 6) & 7   # the absolute phase advances through WAI too — skipping this shifted the DMA-sync baseline by wk*6 mod 8 per WAI (f1498 scroll DMA sy=8 vs reference hardware sync=6)
					spc.cycle_accum += i64[ wk * 6 ] * 128160    # and the SPC runs through them too
					snap_lines[ frame_master ]
					if [ hsetup_pend && frame_master >= 20 ]
						hsetup_pend = false
						hdma_setup[ 6 ]
					while [ hline < 225 ]                        # service HDMA dots the WAI jump passed (idle edges, clk=6)
						if [ (hline * 1364 + 1104) > frame_master ] break
						hsrc = 3
						hdma_run_line[ 6 ]
						hline += 1
			if [ env_irqov && !nmi_fired && frame_master >= 306902 ] puts[ 'NMIOV f{dbg_frames} over={frame_master - 306902} iend={nmi_iend} arm={nmi_arm} op={nmi_lastop} axs={last_axs}' ]
			if [ !nmi_fired && frame_master >= 306902 && !nmi_arm && !cpu_wai && (frame_master - 306902) < ((nmi_iend) ? 10 : 12) ]   # NMI bounds FIXED 10/12 (from-reset master data: f159 INY crossing delays at raw over ~8 — the conv +2 does NOT extend the take window, it only adds entry cost)
				nmi_arm = true                         # latch fell in the crossing instruction's LAST cycle: sampled too late, taken one instruction later. Cutoff = last-cycle master + 4 (nmiPoll pipeline): internal-final ops (op_accesses==1) end in a 6-master idle -> 10; memory-ending ops end in an 8-master access -> 12
				in_vblank    = true                    # RDNMI latch rises at the vblank latch, NOT at the take (reference hardware nmiLine raise):
				nmi_occurred = true                    # the ONE instruction between arm and take (ff3's LDA $4210 poll at C0:B7A0) must read bit7=1
			el [ !nmi_fired && frame_master >= 306902 ]
				# reference hardware idleIRQ: a pending interrupt converts the interrupted instruction's final
				# INTERNAL cycle into a PC bus read (8 master in slow ROM vs 6 idle) — applies to
				# 2-cycle implied/transfer ops (single fetch access + internal cycle)
				if [ nmi_conv && !cpu_wai && (nmitimen & 0x80) ]
					xir : i32 [ cpu_speed[ cpu.pbr, cpu.pc ] - 6 ]
					if [ xir > 0 ] steal_master += xir     # steal propagates into instr_master -> frame_master + SPC accum at the handler's first instruction
				in_vblank    = true
				nmi_occurred = true
				cpu_wai      = false
				ppu_latch_shot[]
				if [ env_hashlog && (nmitimen & 0x80) ] printf[ "HASH f%u %08X\n", dbg_frames, state_hash[] ]
				if [ env_fsig && (nmitimen & 0x80) ] emit_sigs[ '.' ]
				if [ env_gfxlog && (nmitimen & 0x80) ] printf[ "GFX f%u %08X\n", dbg_frames, gfx_hash[] ]
				if [ env_wdump >= 0 && dbg_frames == u32[env_wdump] ] write_snapshot[ '/tmp/asnes_wram.bin' ]
				if [ env_nmifire && dbg_frames >= 1480 && dbg_frames <= 1535 ] printf[ "NMIFIRE f%u intPC=%02X:%04X fmaster=%d\n", dbg_frames, cpu.pbr, cpu.pc, frame_master ]
				if [ env_nmiabs && (nmitimen & 0x80) ] printf[ "NMIABS f%u fmaster=%d M=%ld intPC=%02X:%04X\n", dbg_frames, frame_master, cpu_cycles*6, cpu.pbr, cpu.pc ]
				if [ nmitimen & 0x80 ] cpu_nmi[]
				nmi_fired = true
			if [ nmi_retro ]                            # $4200 enable-during-vblank retro-trigger (independent of the per-frame NMI)
				nmi_retro = false
				cpu_wai   = false
				cpu_nmi[]
			cnl : i32 [ frame_master / 1364 ]   # exact scanline (fcpu/228 was CPU-cycle-based: 228*6=1368 != 1364, drifting 4 master/line)
			im  : u8  [ nmitimen & 0x30 ]
			if [ im != 0 && (cpu.p & 0x04) == 0 && cnl < 224 ]
				do_irq : bool [ false ]
				if [ im == 0x10 ]
					if [ cnl != irq_line_fired ] do_irq = true
				el [ cnl == i32[vtime] && irq_line_fired != i32[vtime] ]   # EXACT line match (reference hardware: vcounter==vtime): >= retro-fired a vtime=0 V-IRQ the instant ff3 enabled it mid-frame, jumping through its not-yet-installed handler pointer to $0000
					do_irq = true
				if [ do_irq ]
					# same interrupt pipeline as NMI: latch = line start + 2; the take/arm cutoff and
					# the idleIRQ +2 conversion mirror the calibrated NMI rules
					lirq : i32 [ ((im == 0x10) ? cnl : i32[vtime]) * 1364 + (((im & 0x10) != 0) ? (i32[htime] * 4) : 0) + 2 ]   # H and HV IRQs latch at htime dots (4 master each) into the line; V-only latches at line start
					ovr : i32 [ frame_master - lirq ]
					if [ env_irqov ] puts[ 'IRQOV f{dbg_frames} over={ovr} iend={nmi_iend}' ]
					# derived from 1060 reference hardware IRQABS entries: take the IRQ iff over >= last-cycle+12
					# (18 internal-final, 20 memory-ending); below that just re-check at the next
					# boundary — no one-shot arm (reference hardware waits through MULTIPLE short boundaries,
					# e.g. f459 skipped over=2 AND over=16 before firing at 48). CLI skips one boundary.
					if [ cpu_wai || (ovr >= ((nmi_iend) ? 18 : (last_axs + 12)) && !irq_cli) ]   # memory-ending: bound = the FINAL ACCESS's real speed + 12 (6-master I/O-ending ops fire at 18, 8-master at 20)
						cpu_wai = false
						if [ nmi_conv ]
							xii : i32 [ cpu_speed[ cpu.pbr, cpu.pc ] - 6 ]
							if [ xii > 0 ] steal_master += xii
						cpu_irq[]
						if [ im == 0x10 ] irq_line_fired = cnl
						el irq_line_fired = i32[vtime]
			if [ cpu_wai ]
				break
			snap_lines[ frame_master ]
			port_read = false
			c : i32 [ cpu_step[] ]
			if [ c < 1 ] c = 1
			fcpu += c
			cpu_cycles += i64[ c ]
			frame_cycle = fcpu
			if [ cpu_wai ]                             # only WAI advances the clock without ticks; normal dots roll to the next instruction's fetch edge (reference hardware cycle-start semantics)
				nl : i32 [ (frame_master + 260) / 1364 ]
				while [ hline < nl && hline < 225 ]
					hsrc = 3
					hdma_run_line[ 6 ]
					hline += 1
			# SPC clock advanced per-access in cpu_tick; drains on every APU-port read (reference hardware synchronizeSMP)
		frame_carry = frame_master - flen            # conserve overshoot in MASTER (keeps frame_master aligned with reference hardware's dot across frames)
		if [ frame_carry < 0 ] frame_carry = 0
		if [ hsetup_pend ]
			hsetup_pend = false
			hdma_setup[ 8 ]
		snap_lines[ 400000 ]
		while [ hline < 225 ]
			hsrc = 3
			hdma_run_line[ 6 ]
			hline += 1
		if [ !nmi_fired ]
			in_vblank    = true
			nmi_occurred = true
			ppu_latch_shot[]
			if [ nmitimen & 0x80 ] cpu_nmi[]
		spc_drain[ samples ]                         # end-of-frame catch-up: SPC runs only to the CPU's clock (never past it) — the balance carries across frames like reference hardware; audio gets however many samples that yields
		in_vblank = false
		flush_audio[ sz[ spc.audio_done ] ]          # write only what was actually produced this frame

	# --- Load ROM ---

	func reset_spc [] -> bool
		if [ !spc_rom_loaded ]
			if [ !spc_boot_rom ]
				spc_boot_rom = calloc[ 1, 64 ]
			# default the SPC700 IPL to bios.rom in the launch cwd unless --spc_rom given
			if [ !spc_rom ] spc_rom = path '{path.path_startup[]}/bios.rom'
			f    : ref FILE [ fopen[ spc_rom, 'rb' ] ]
			size : sz [ 0 ]
			expect f, 'could not open spc-rom file: {spc_rom}'
			fseek [ f, 0, SEEK_END ]
			size = ftell[ f ]
			rewind[ f ]
			expect size == 64, 'bad spc rom size'
			nrd : i64 [ fread[spc_boot_rom, size, 1, f] ]
			expect nrd == 1, "spc rom read failed"
			fclose[ f ]
			spc_rom_loaded = true

		spc = spc_state []
		# IPL ROM is a read-only overlay at $FFC0-$FFFF (applied in spc_r), NOT stored in APU
		# RAM — so spc.ram stays zero there, matching reference hardware apuram (all zero at power-on).
		spc.dsp[0x6C] = 0xE0            # DSP FLG powers on = soft-reset|mute|echo-disable (matches reference hardware spc_dsp.reset)
		spc.pc          = 0xFFC0
		spc.sp          = 0xFF
		spc.psw         = 0x02
		spc.sample_rate = 32000
		spc.buffer_size = 1024
		spc.audio_buffer = calloc[ 1, spc.buffer_size * 2 * 2 ]

		pb  : i32 [ SND_PCM_STREAM_PLAYBACK ]
		err : i32 [ snd_pcm_open[ref spc.pcm_handle, 'pulse', pb, 0] ]

		if [ err < 0 ] return false

		psz    : snd_pcm_hw_params_sizeof[ ]
		params : ref snd_pcm_hw_params_t [ calloc[ 1, psz ] ]
		snd_pcm_hw_params_any         [ spc.pcm_handle, params ]
		rw  : i32 [ SND_PCM_ACCESS_RW_INTERLEAVED ]
		fmt : i32 [ SND_PCM_FORMAT_S16_LE ]

		snd_pcm_hw_params_set_access  [spc.pcm_handle, params, rw]
		snd_pcm_hw_params_set_format  [spc.pcm_handle, params, fmt]
		snd_pcm_hw_params_set_channels[spc.pcm_handle, params, 2]
		snd_pcm_hw_params_set_rate[spc.pcm_handle, params, spc.sample_rate, 0]
		# keep the ring buffer small so snd_pcm_avail paces the SPC to real-time
		# (otherwise PulseAudio reports a ~32s buffer and the engine races ahead).
		bufsz : sz [ 4096 ]
		persz : sz [ 64 ]                             # small periods: snd_pcm_avail advances in period granularity — 1024 quantized the DAC-pacing gate to 32ms steps (jerky ~30Hz rom-frame rate); 64 tracks the drain at 2ms
		snd_pcm_hw_params_set_buffer_size_near[ spc.pcm_handle, params, ref bufsz ]
		snd_pcm_hw_params_set_period_size_near[ spc.pcm_handle, params, ref persz, null ]

		spc.ports[0] = 0xAA
		spc.ports[1] = 0xBB

		success : bool [ snd_pcm_hw_params[ spc.pcm_handle, params ] >= 0 ]
		if [ success ]
			perr : i32 [ snd_pcm_prepare[ spc.pcm_handle ] ]
			if [ perr < 0 ]
				puts[ 'ALSA prepare failed: {snd_strerror[perr]}' ]
				success = false
		
		return success

	func load [] -> bool
		# cache ALL debug env flags ONCE — getenv in hot paths (per instruction/access) is slow
		env_sig     = (getenv['ASNES_SIG']) ? true : false
		env_sf4     = (getenv['ASNES_SF4']) ? true : false
		env_irqov   = (getenv['ASNES_IRQOV']) ? true : false
		env_nmim    = (getenv['ASNES_NMIM']) ? true : false
		env_acclog  = (getenv['ASNES_ACCLOG']) ? true : false
		env_spct    = (getenv['ASNES_SPCT']) ? true : false
		env_nmiabs  = (getenv['ASNES_NMIABS']) ? true : false
		env_hashlog = (getenv['ASNES_HASHLOG']) ? true : false
		env_fsig    = (getenv['ASNES_FSIG']) ? true : false
		env_gfxlog  = (getenv['ASNES_GFXLOG']) ? true : false
		env_ww      = (getenv['ASNES_WW']) ? true : false
		env_irqlog  = (getenv['ASNES_IRQ_LOG']) ? true : false
		env_cglog   = (getenv['ASNES_CG_LOG']) ? true : false
		env_hdmalog = (getenv['ASNES_HDMA_LOG']) ? true : false
		env_mpylog  = (getenv['ASNES_MPYLOG']) ? true : false
		env_nmifire = (getenv['ASNES_NMIFIRE']) ? true : false
		env_fstart  = (getenv['ASNES_FSTART']) ? true : false
		env_joylog  = (getenv['ASNES_JOYLOG']) ? true : false
		env_wdump   = (getenv['ASNES_WDUMP']) ? atoi[ getenv['ASNES_WDUMP'] ] : -1
		f : ref FILE [ fopen[ rom, 'rb' ] ]
		expect f, 'could not open ROM file'
		fseek[ f, 0, SEEK_END ]
		size : sz [ ftell[ f ] ]
		rewind[ f ]
		# .smc copier header: 512 bytes present when size mod 0x8000 == 512.
		# skip it so the reset vector / banks aren't shifted by 512.
		header : sz [ ((size % 0x8000) == 512) ? 512 : 0 ]
		if [ header ]
			fseek[ f, header, SEEK_SET ]
			size -= header
		expect size < 0x1000000, 'ROM too large'

		cpu = cpu_state []
		ppu = ppu_state []
		cpu.memory = calloc[ 1, 0x1000000 ]
		# match reference hardware deterministic power-on state exactly (for hash lockstep):
		cpu.memory[0x7E01FD] = 0x24                # 65816 reset sequence leaves this stack byte = 0x24
		for [ n: i32 0, n < 128, n += 1 ]
			ppu.oam[n * 4 + 1] = 0xFF             # every sprite's y-byte powers on 0xFF (reference hardware readObject y-1 of default-0 object)
		nbanks : i32 [ size / 0x8000 ]
		if [ nbanks < 1 ] nbanks = 1
		rombuf : ref u8 [ calloc[ 1, (nbanks + 1) * 0x8000 ] ]
		fread[ rombuf, 1, size, f ]
		fclose[ f ]
		# detect HiROM vs LoROM by the internal-header checksum at the two candidate header
		# locations ($FFDC/DE = HiROM, $7FDC/DE = LoROM); checksum + complement == $FFFF.
		hirom : bool [ false ]
		if [ size >= 0x10000 ]
			hcs : i32 [ i32[rombuf[0xFFDE]] | (i32[rombuf[0xFFDF]] << 8) ]
			hcc : i32 [ i32[rombuf[0xFFDC]] | (i32[rombuf[0xFFDD]] << 8) ]
			lcs : i32 [ i32[rombuf[0x7FDE]] | (i32[rombuf[0x7FDF]] << 8) ]
			lcc : i32 [ i32[rombuf[0x7FDC]] | (i32[rombuf[0x7FDD]] << 8) ]
			hi_ok : bool [ hcs != 0 && ((hcs + hcc) & 0xFFFF) == 0xFFFF ]
			lo_ok : bool [ lcs != 0 && ((lcs + lcc) & 0xFFFF) == 0xFFFF ]
			if [ hi_ok && !lo_ok ] hirom = true
			el [ hi_ok == lo_ok && (rombuf[0xFFD5] & 1) != 0 ] hirom = true
		if [ hirom ]
			# HiROM: banks $C0-$FF and $40-$7D map full $0000-$FFFF; banks $00-$3F / $80-$BF
			# map only $8000-$FFFF. ROM chunk = (bank & $3F) into 64KB banks.
			hb : i32 [ size / 0x10000 ]
			if [ hb < 1 ] hb = 1
			for [ b: i32 0, b < 0x100, b += 1 ]
				if [ b == 0x7E ] continue
				if [ b == 0x7F ] continue
				chunk : i32 [ (b & 0x3F) % hb ]
				if [ (b >= 0x40 && b <= 0x7D) || b >= 0xC0 ]
					memcpy[ cpu.memory + b * 0x10000, rombuf + chunk * 0x10000, 0x10000 ]
				el
					memcpy[ cpu.memory + b * 0x10000 + 0x8000, rombuf + chunk * 0x10000 + 0x8000, 0x8000 ]
			is_hirom = true
			puts 'HiROM mapping'
		el
			# flat 24-bit LoROM map: each bank's $8000-$FFFF window mirrors a 32KB ROM slice.
			for [ b: i32 0, b < 0x100, b += 1 ]
				if [ b == 0x7E ] continue
				if [ b == 0x7F ] continue
				chunk : i32 [ (b & 0x7F) % nbanks ]
				dst   : i64 [ (b * 0x10000) + 0x8000 ]
				src   : i64 [ chunk * 0x8000 ]
				memcpy[ cpu.memory + dst, rombuf + src, 0x8000 ]
		free[ rombuf ]

		puts[ 'loaded rom: {rom} ({size} bytes)' ]
		reset_vector : u16 [ cpu.memory[0xFFFC] | (cpu.memory[0xFFFD] << 8) ]
		printf[ "reset vector: 0x%04X\n", reset_vector ]
		printf[ "first op: 0x%02X\n", cpu.memory[reset_vector] ]
		irq_hi : u8 [ cpu.memory[0xFFFF] ]
		irq_lo : u8 [ cpu.memory[0xFFFE] ]
		printf[ "IRQ vector: 0x%02X%02X\n", irq_hi, irq_lo ]

		cpu.pc = reset_vector
		cpu.sp = 0x01FC                            # 65816 reset sequence does 3 dummy stack decrements from 0x01FF (matches reference hardware S after power-on)
		cpu.p  = 0x34
		cpu.e  = true                             # 65816 powers on in emulation mode (E=1); boot code does CLC/XCE to enter native
		master_phase = 2                          # reference hardware runs ~186 master (22 idle + reset interrupt) before the first op; 186 & 7 = 2, so seed the DMA/refresh phase to match its counter.cpu&7
		frame_carry = 186                         # those 186 reset master cycles are part of scanline 0 (reference hardware counts them): the frame loop sets frame_master=frame_carry, so seed the carry to start frame 0 there — DRAM-refresh/DMA/scanline positions then line up with reference hardware's absolute hcounter

		reset_spc[]
		# In the single-function reference hardware, the SMP catches up through the CPU's ~186-master reset
		# and lands at PC=$FFC6 (x=EF, sp=EF, a=0) — the top of the IPL zero-page clear loop,
		# APU RAM still zero — by the CPU's first instruction. Run our SPC to that exact state.
		# That is 4 IPL ops: mov x,#$EF / mov sp,x / mov a,#$00 / mov (x),a. The SPC reaches it
		# ahead of the master clock, then coasts until the CPU catches up — carry that lead as
		# negative accum so we coast identically instead of running the clear loop too early.
		# Model the CPU's ~186-master power-on reset exactly as reference hardware does: hand the SPC that
		# much clock budget and let the normal drain run whole IPL opcodes until it crosses the
		# budget. It lands mid-IPL at $FFC6 with the same residual phase reference hardware has at the CPU's
		# first instruction — no hand-tuned coast lead.
		spc.cycle_accum = i64[ 186 * 128160 ]
		spc_drain[ 0 ]
		return true

	# --- Trinity ---

	# --- SPC700 opcode self-test (deterministic, no ROM/.spc needed) ---
	func t_chk [ name: symbol, got: i32, want: i32 ]
		if [ got != want ]
			printf[ "FAIL %-12s got=%02X want=%02X\n", name, got, want ]
			dbg_h += 1
		el
			printf[ "ok   %s\n", name ]

	# run one instruction placed at $0300 with the given operand bytes
	func t_run [ op: u8, o1: u8, o2: u8 ]
		spc.ram[0x0300] = op
		spc.ram[0x0301] = o1
		spc.ram[0x0302] = o2
		spc.pc = 0x0300
		spc_step[]

	func spc_test []
		spc = spc_state []
		dbg_h = 0

		# ADC A,#imm : 0x50 + 0x50 = 0xA0, N|V set, C|Z|H clear
		spc.a = 0x50  spc.psw = 0x00
		t_run[ 0x88, 0x50, 0x00 ]
		t_chk[ 'ADC.res', spc.a, 0xA0 ]
		t_chk[ 'ADC.NVZC', spc.psw & 0xC3, 0xC0 ]
		# ADC carry-out + half-carry: 0xFF + 0x01 = 0x00, C|Z|H set
		spc.a = 0xFF  spc.psw = 0x00
		t_run[ 0x88, 0x01, 0x00 ]
		t_chk[ 'ADC2.res', spc.a, 0x00 ]
		t_chk[ 'ADC2.HZC', spc.psw & 0x0B, 0x0B ]

		# SBC A,#imm : 0x50 - 0x30 (C=1) = 0x20, C set, N|V|Z clear
		spc.a = 0x50  spc.psw = 0x01
		t_run[ 0xA8, 0x30, 0x00 ]
		t_chk[ 'SBC.res', spc.a, 0x20 ]
		t_chk[ 'SBC.C', spc.psw & 0x01, 0x01 ]

		# CMP A,#imm equal : Z|C set, N clear
		spc.a = 0x42  spc.psw = 0x00
		t_run[ 0x68, 0x42, 0x00 ]
		t_chk[ 'CMP.ZC', spc.psw & 0x83, 0x03 ]
		# CMP A < imm : C clear, N set
		spc.a = 0x10  spc.psw = 0x00
		t_run[ 0x68, 0x20, 0x00 ]
		t_chk[ 'CMP2.NC', spc.psw & 0x83, 0x80 ]

		# AND/OR/EOR A,#imm  (N,Z)
		spc.a = 0xF0  spc.psw = 0x00
		t_run[ 0x28, 0x0F, 0x00 ]
		t_chk[ 'AND.res', spc.a, 0x00 ]
		t_chk[ 'AND.Z', spc.psw & 0x82, 0x02 ]
		spc.a = 0x0F  spc.psw = 0x00
		t_run[ 0x08, 0x80, 0x00 ]
		t_chk[ 'OR.res', spc.a, 0x8F ]
		t_chk[ 'OR.N', spc.psw & 0x82, 0x80 ]

		# shifts/rotates on A
		spc.a = 0x81  spc.psw = 0x00
		t_run[ 0x1C, 0x00, 0x00 ]          # ASL A
		t_chk[ 'ASL.res', spc.a, 0x02 ]
		t_chk[ 'ASL.C', spc.psw & 0x01, 0x01 ]
		spc.a = 0x01  spc.psw = 0x00
		t_run[ 0x5C, 0x00, 0x00 ]          # LSR A
		t_chk[ 'LSR.res', spc.a, 0x00 ]
		t_chk[ 'LSR.ZC', spc.psw & 0x03, 0x03 ]
		spc.a = 0x80  spc.psw = 0x01
		t_run[ 0x3C, 0x00, 0x00 ]          # ROL A (carry in)
		t_chk[ 'ROL.res', spc.a, 0x01 ]
		t_chk[ 'ROL.C', spc.psw & 0x01, 0x01 ]
		spc.a = 0x01  spc.psw = 0x01
		t_run[ 0x7C, 0x00, 0x00 ]          # ROR A (carry in)
		t_chk[ 'ROR.res', spc.a, 0x80 ]
		t_chk[ 'ROR.NC', spc.psw & 0x81, 0x81 ]

		# INC/DEC A
		spc.a = 0xFF  spc.psw = 0x00
		t_run[ 0xBC, 0x00, 0x00 ]
		t_chk[ 'INC.ZA', spc.a, 0x00 ]
		t_chk[ 'INC.Z', spc.psw & 0x82, 0x02 ]
		spc.a = 0x00  spc.psw = 0x00
		t_run[ 0x9C, 0x00, 0x00 ]
		t_chk[ 'DEC.A', spc.a, 0xFF ]
		t_chk[ 'DEC.N', spc.psw & 0x82, 0x80 ]

		# word ops: INCW / ADDW / SUBW on dp $20
		spc.ram[0x20] = 0xFF  spc.ram[0x21] = 0x00
		t_run[ 0x3A, 0x20, 0x00 ]          # INCW $20 -> 0x0100
		t_chk[ 'INCW.lo', spc.ram[0x20], 0x00 ]
		t_chk[ 'INCW.hi', spc.ram[0x21], 0x01 ]
		spc.a = 0x34  spc.y = 0x12  spc.ram[0x20] = 0xCD  spc.ram[0x21] = 0xAB
		t_run[ 0x7A, 0x20, 0x00 ]          # ADDW YA,$20 : 0x1234+0xABCD=0xBE01
		t_chk[ 'ADDW.lo', spc.a, 0x01 ]
		t_chk[ 'ADDW.hi', spc.y, 0xBE ]

		# branches: BNE taken when Z clear, not taken when Z set
		spc.psw = 0x00
		t_run[ 0xD0, 0x10, 0x00 ]          # BNE +0x10 from $0302 -> $0312
		t_chk[ 'BNE.taken', spc.pc, 0x0312 ]
		spc.psw = 0x02
		t_run[ 0xD0, 0x10, 0x00 ]          # Z set -> fall through to $0302
		t_chk[ 'BNE.fall', spc.pc, 0x0302 ]
		# BCS taken when C set
		spc.psw = 0x01
		t_run[ 0xB0, 0x20, 0x00 ]          # BCS +0x20 -> $0322
		t_chk[ 'BCS.taken', spc.pc, 0x0322 ]

		if [ dbg_h == 0 ]
			puts[ 'SPC700 self-test: ALL PASS' ]
		el
			printf[ "SPC700 self-test: %d FAILURES\n", dbg_h ]

	func init []
		animated   = true                          # emulator: repaint every frame, never cache-skip (NOT style-owned `volatile`)
		focusable  = true
		if [ volume == 0.0 ] volume = 0.22         # default playback volume (keep prop-pair override)

	# display-pipeline test: fill a 256x224 CPU array with an animated pattern,
	# upload it to a Texture, and blit it to the screen scaled to the window.
	# keyboard -> SNES controller 1. WASD = D-pad, ;'./ = X Y A B, Enter/Shift =
	# Start/Select, Q/E = L/R. Pad bit layout: B Y Sel St Up Dn L R A X L R (bit15..4).
	public func on_key [ ev: Event ]
		code : i32  [ ev.key.unicode ]
		down : bool [ ev.key.state ]
		bit  : i32  [ -1 ]
		if   [ code == 87 ]  bit = 11                   # W  Up
		el [ code == 83 ]  bit = 10                   # S  Down
		el [ code == 65 ]  bit = 9                    # A  Left
		el [ code == 68 ]  bit = 8                    # D  Right
		el [ code == 47 ]  bit = 15                   # /  B
		el [ code == 39 ]  bit = 14                   # '  Y
		el [ code == 46 ]  bit = 7                    # .  A
		el [ code == 59 ]  bit = 6                    # ;  X
		el [ code == 257 ] bit = 12                   # Enter  Start
		el [ code == 340 || code == 344 ] bit = 13    # Shift  Select
		el [ code == 81 ]  bit = 5                    # Q  L
		el [ code == 69 ]  bit = 4                    # E  R
		if [ bit >= 0 ]
			m : u16 [ u16[1 << bit] ]
			if [ down ] pad1 = pad1 | m
			el pad1 = pad1 & (~m)
		# volume: '-' quieter, '=' / '+' louder (0.02 steps, clamped 0..1)
		if [ down ]
			if   [ code == 45 ] volume = clamp[ volume - 0.02, 0.0, 1.0 ]
			el [ code == 61 || code == 43 ] volume = clamp[ volume + 0.02, 0.0, 1.0 ]
			if [ code == 45 || code == 61 || code == 43 ] puts 'asnes volume {volume}'
			if [ code == 80 ] save_req = true              # 'P' -> save savestate
			if [ code == 76 ] load_req = true              # 'L' -> load savestate
			if [ code == 32 ] paused = !paused             # Space pause/resume

	# Build the GPU Mode-7 render path once: source + matrix textures, the Mode7
	# shader, a Model binding them by name, and a Render that draws the quad into
	# m7_render.color (full window res = supersampled). Mirrors trinity's chain.
	func m7_setup [ cv: Canvas ]
		# vec_m7: the plane texture is a corner-cut 2x bake (2048) — the shader
		# samples normalized UVs, so the size swap is transparent to it, and the
		# mip/aniso chain then filters VECTORIZED texels (the effect survives
		# the perspective sampling instead of being erased by it)
		msz  : i32 [ (vec_m7) ? 2048 : 1024 ]
		mlv  : i32 [ (vec_m7) ? 12 : 11 ]
		m7_src = Texture [ vk: cv.vk, w: cv.w, width: msz, height: msz, linear: true, mip_levels: mlv, anisotropy: 8 ]
		m7_mat = Texture [ vk: cv.vk, w: cv.w, width: 256, height: 3, linear: false, pixel_format: Pixel.rgbaf32 ]
		m7_shader = Mode7 [ vk: cv.vk, name: 'mode7' ]
		m7_model  = Model [ w: cv.w, s: m7_shader, samplers: map Texture[string] [ 'src': m7_src, 'mat': m7_mat ] ]
		m7_render = Render [ vk: cv.vk, w: cv.w, wscale: 0.5, models: array Model [ m7_model ] ]

	# Build the scaler chains for the composed screen + the five provenance
	# layers (knes pattern). vec = VectorScale straight to window res; se_2d =
	# Super Eagle on its native 2x lattice + PixelSharp lift; blocky =
	# PixelSharp on the raw layers. Textures must already exist.
	func scaler_setup [ cv: Canvas ]
		# bled BG layers (288x256) get matching render targets so the window
		# region stays exactly 1:1 with the unbled chains
		lw2 : i32 [ (i32[ bounds.w ] * 288) / 256 ]
		lh2 : i32 [ (i32[ bounds.h ] * 256) / 224 ]
		if [ se_2d && ! vec ]
			se_shader  = SuperEagle [ vk: cv.vk, name: 'supereagle' ]
			se_model   = Model [ w: cv.w, s: se_shader, samplers: map Texture[string] [ 'color': screen_tex ] ]
			se_render  = Render [ vk: cv.vk, w: cv.w, wscale: 0.5, models: array Model [ se_model ] ]
			se1_shader = SuperEagle [ vk: cv.vk, name: 'supereagle' ]
			se1_model  = Model [ w: cv.w, s: se1_shader, samplers: map Texture[string] [ 'color': lay1_tex ] ]
			se1_render = Render [ vk: cv.vk, w: cv.w, width: 576, height: 512, models: array Model [ se1_model ] ]
			se2_shader = SuperEagle [ vk: cv.vk, name: 'supereagle' ]
			se2_model  = Model [ w: cv.w, s: se2_shader, samplers: map Texture[string] [ 'color': lay2_tex ] ]
			se2_render = Render [ vk: cv.vk, w: cv.w, width: 576, height: 512, models: array Model [ se2_model ] ]
			se3_shader = SuperEagle [ vk: cv.vk, name: 'supereagle' ]
			se3_model  = Model [ w: cv.w, s: se3_shader, samplers: map Texture[string] [ 'color': lay3_tex ] ]
			se3_render = Render [ vk: cv.vk, w: cv.w, width: 576, height: 512, models: array Model [ se3_model ] ]
			sew_shader = SuperEagle [ vk: cv.vk, name: 'supereagle' ]
			sew_model  = Model [ w: cv.w, s: sew_shader, samplers: map Texture[string] [ 'color': layw_tex ] ]
			sew_render = Render [ vk: cv.vk, w: cv.w, wscale: 0.5, models: array Model [ sew_model ] ]
			ses_shader = SuperEagle [ vk: cv.vk, name: 'supereagle' ]
			ses_model  = Model [ w: cv.w, s: ses_shader, samplers: map Texture[string] [ 'color': lays_tex ] ]
			ses_render = Render [ vk: cv.vk, w: cv.w, wscale: 0.5, models: array Model [ ses_model ] ]
		if [ vec ]
			vsc_shader = VectorScale [ vk: cv.vk, name: 'vectorscale' ]
			occ_model  = Model [ w: cv.w, s: vsc_shader, samplers: map Texture[string] [ 'color': screen_tex ] ]
			occ_render = Render [ vk: cv.vk, w: cv.w, wscale: 1.0, models: array Model [ occ_model ] ]
			vs1_shader = VectorScale [ vk: cv.vk, name: 'vectorscale' ]
			oc1_model  = Model [ w: cv.w, s: vs1_shader, samplers: map Texture[string] [ 'color': lay1_tex ] ]
			oc1_render = Render [ vk: cv.vk, w: cv.w, width: lw2, height: lh2, models: array Model [ oc1_model ] ]
			vs2_shader = VectorScale [ vk: cv.vk, name: 'vectorscale' ]
			oc2_model  = Model [ w: cv.w, s: vs2_shader, samplers: map Texture[string] [ 'color': lay2_tex ] ]
			oc2_render = Render [ vk: cv.vk, w: cv.w, width: lw2, height: lh2, models: array Model [ oc2_model ] ]
			vs3_shader = VectorScale [ vk: cv.vk, name: 'vectorscale' ]
			oc3_model  = Model [ w: cv.w, s: vs3_shader, samplers: map Texture[string] [ 'color': lay3_tex ] ]
			oc3_render = Render [ vk: cv.vk, w: cv.w, width: lw2, height: lh2, models: array Model [ oc3_model ] ]
			vsw_shader = VectorScale [ vk: cv.vk, name: 'vectorscale' ]
			ocw_model  = Model [ w: cv.w, s: vsw_shader, samplers: map Texture[string] [ 'color': layw_tex ] ]
			ocw_render = Render [ vk: cv.vk, w: cv.w, wscale: 1.0, models: array Model [ ocw_model ] ]
			vss_shader = VectorScale [ vk: cv.vk, name: 'vectorscale' ]
			ocs_model  = Model [ w: cv.w, s: vss_shader, samplers: map Texture[string] [ 'color': lays_tex ] ]
			ocs_render = Render [ vk: cv.vk, w: cv.w, wscale: 1.0, models: array Model [ ocs_model ] ]
		el
			psc_shader = PixelSharp [ vk: cv.vk, name: 'pixelsharp' ]
			occ_model  = Model [ w: cv.w, s: psc_shader, samplers: map Texture[string] [ 'color': (se_2d) ? se_render.color : screen_tex ] ]
			occ_render = Render [ vk: cv.vk, w: cv.w, wscale: 1.0, models: array Model [ occ_model ] ]
			ps1_shader = PixelSharp [ vk: cv.vk, name: 'pixelsharp' ]
			oc1_model  = Model [ w: cv.w, s: ps1_shader, samplers: map Texture[string] [ 'color': (se_2d) ? se1_render.color : lay1_tex ] ]
			oc1_render = Render [ vk: cv.vk, w: cv.w, width: lw2, height: lh2, models: array Model [ oc1_model ] ]
			ps2_shader = PixelSharp [ vk: cv.vk, name: 'pixelsharp' ]
			oc2_model  = Model [ w: cv.w, s: ps2_shader, samplers: map Texture[string] [ 'color': (se_2d) ? se2_render.color : lay2_tex ] ]
			oc2_render = Render [ vk: cv.vk, w: cv.w, width: lw2, height: lh2, models: array Model [ oc2_model ] ]
			ps3_shader = PixelSharp [ vk: cv.vk, name: 'pixelsharp' ]
			oc3_model  = Model [ w: cv.w, s: ps3_shader, samplers: map Texture[string] [ 'color': (se_2d) ? se3_render.color : lay3_tex ] ]
			oc3_render = Render [ vk: cv.vk, w: cv.w, width: lw2, height: lh2, models: array Model [ oc3_model ] ]
			psw_shader = PixelSharp [ vk: cv.vk, name: 'pixelsharp' ]
			ocw_model  = Model [ w: cv.w, s: psw_shader, samplers: map Texture[string] [ 'color': (se_2d) ? sew_render.color : layw_tex ] ]
			ocw_render = Render [ vk: cv.vk, w: cv.w, wscale: 1.0, models: array Model [ ocw_model ] ]
			pss_shader = PixelSharp [ vk: cv.vk, name: 'pixelsharp' ]
			ocs_model  = Model [ w: cv.w, s: pss_shader, samplers: map Texture[string] [ 'color': (se_2d) ? ses_render.color : lays_tex ] ]
			ocs_render = Render [ vk: cv.vk, w: cv.w, wscale: 1.0, models: array Model [ ocs_model ] ]

	# decaying replay offset for one glide channel: delta * (1-alpha) * scale
	func lay_off [ v: f32, t: i64, p: i64, now: i64, sc: f32 ] -> f32
		if [ v == 0.0 || p <= 0 ] return 0.0
		a : f32 [ f32[ now - t ] / f32[ p ] ]
		if [ a > 1.0 ] a = 1.0
		if [ a < 0.0 ] a = 0.0
		r : f32 [ v * (1.0 - a) * sc ]
		lim : f32 [ 16.0 * sc ]                        # overscan bleed budget
		if [ r > lim ] r = lim
		if [ r < (0.0 - lim) ] r = 0.0 - lim
		return r

	# element paint hook: screen walk only (compose would double-run GPU
	# submits and sample the glide clock twice); element-local viewport.
	public func draw [ w: Window ]
		if [ w.draw_stage != CanvasType.screen ] return
		ux.will_animate = true
		paint[ w.screen, rect [ x: 0.0, y: 0.0, w: bounds.w, h: bounds.h ] ]

	# draw the emulator into `vp` on any canvas — the element path passes the
	# element-local rect; orbiter's emulator ResourceView passes pane bounds
	public func paint [ cv: Canvas, vp: rect ]
		bounds = vp                                # size basis for every scale below
		if [ spctest ]
			if [ !spc ] spc_test[]
			return
		# --beep: bypass the CPU/upload entirely, key on one DSP voice directly.
		if [ beep ]
			if [ !spc ] audio_test[]
			generate_audio[ 0 ]
			return
		# --spcfile: play a real APU snapshot. generate_audio runs 16 SPC steps
		# per output sample (~32 cycles), interleaving the engine with the DSP.
		if [ spcfile ]
			if [ !spc ] load_spc[]
			generate_audio[ 16 ]
			return
		# --rom maps onto the public `rom` member; args land after init, so
		# load lazily on the first frame once rom is set
		if [ rom && !cpu && !putest ] load[]
		if [ cpu && !emu_started ]
			emu_started = true
			pub_lock = mutex [ cond: false ]
			tid : local u64 [ 1 ]
			pthread_create[ tid, null, ref emu_entry, a ]
		if [ putest ]
			if [ !screen_tex ]
				screen_tex = Texture [ vk: cv.vk, w: cv.w, width: 256, height: 224, linear: true ]
			for [ y: i32 0, y < 224, y += 1 ]
				for [ x: i32 0, x < 256, x += 1 ]
					rr : u32 [ u32[x] & 0xFF ]
					gg : u32 [ u32[y] & 0xFF ]
					bb : u32 [ u32[(x + y + test_t) & 0xFF] ]
					test_buf[ y * 256 + x ] = 0xFF000000 | (bb << 16) | (gg << 8) | rr
			test_t += 1
			screen_tex.upload[ test_buf, 256 * 224 * 4 ]
			dst : rect [ x: vp.x, y: vp.y, w: vp.w, h: vp.h ]
			cv.draw_image[ screen_tex, dst ]
			return
		if [ !cpu || !pub_valid ]
			return
		pub_lock.lock[]
		if [ !screen_tex ]
			screen_tex = Texture [ vk: cv.vk, w: cv.w, width: 256, height: 224, linear: true ]
		screen_tex.upload[ pub_framebuf, 256 * 224 * 4 ]
		lay_on : bool [ smooth && pub_layered ]
		b3 : bool [ pub_b3hi ]
		scaled : bool [ vec || se_2d || blocky ]
		if [ lay_on || scaled ]
			if [ !lay1_tex ]
				lay1_tex = Texture [ vk: cv.vk, w: cv.w, width: 288, height: 256, linear: true ]
				lay2_tex = Texture [ vk: cv.vk, w: cv.w, width: 288, height: 256, linear: true ]
				lay3_tex = Texture [ vk: cv.vk, w: cv.w, width: 288, height: 256, linear: true ]
				layw_tex = Texture [ vk: cv.vk, w: cv.w, width: 256, height: 224, linear: true ]
				lays_tex = Texture [ vk: cv.vk, w: cv.w, width: 256, height: 224, linear: true ]
				lay_on = true                          # settle fresh textures with one upload
			if [ lay_on ]
				lay1_tex.upload[ pub_lay1, 288 * 256 * 4 ]
				lay2_tex.upload[ pub_lay2, 288 * 256 * 4 ]
				lay3_tex.upload[ pub_lay3, 288 * 256 * 4 ]
				layw_tex.upload[ pub_layw, 256 * 224 * 4 ]
				lays_tex.upload[ pub_lays, 256 * 224 * 4 ]
			lay_on = smooth && pub_layered
		# glide channels are written by the emu thread under this same lock —
		# snapshot them here so the draw tail (post-unlock) can't read a torn
		# mid-update delta/timestamp pair (rare 1-frame offset pops)
		g1dx : f32 [ bgg_dx[0] ]
		g1dy : f32 [ bgg_dy[0] ]
		g1t  : i64 [ bgg_t[0] ]
		g1p  : i64 [ bgg_p[0] ]
		g2dx : f32 [ bgg_dx[1] ]
		g2dy : f32 [ bgg_dy[1] ]
		g2t  : i64 [ bgg_t[1] ]
		g2p  : i64 [ bgg_p[1] ]
		g3dx : f32 [ bgg_dx[2] ]
		g3dy : f32 [ bgg_dy[2] ]
		g3t  : i64 [ bgg_t[2] ]
		g3p  : i64 [ bgg_p[2] ]
		ganch : i32 [ spr_anchor ]
		gmdx : f32 [ m7g_dx ]
		gmdy : f32 [ m7g_dy ]
		gmt  : i64 [ m7g_t ]
		gmp  : i64 [ m7g_p ]
		out : rect [ x: vp.x, y: vp.y, w: vp.w, h: vp.h ]
		# GPU Mode-7 plane is the base layer; the CPU framebuffer (sprites / mode-1 HUD,
		# transparent over the plane) composites on top. Both GPU passes are recorded and
		# SUBMITTED first so they overlap on the GPU, then waited once each -- serial
		# submit/wait would stall the CPU and starve the real-time audio ring.
		m7_active : bool [ m7_gpu && (pub_mode[100] & 7) == 7 ]
		if [ m7_active ]
			if [ !m7_render ] m7_setup[ cv ]
			bri : u32 [ u32[pub_inidisp] & 0x0F ]
			vh : i64 [ m7_vram_hash[] ]
			if [ vh != m7_vhash || i32[bri] != m7_bri_cache ]
				m7_unpack[ bri ]
				m7_vhash = vh
				m7_bri_cache = i32[bri]
			# smooth: ease the displayed affine params 22% toward the newest
			# published frame per 60Hz-normalized frame. dt-scaled so any
			# display refresh rate converges identically; the remainder
			# eases out asymptotically when the camera stops.
			m7k : f32 [ 1.0 ]
			if [ smooth ]
				g_pn : i64 [ wall_ms[] * 1000 ]
				g_dt : i64 [ g_pn - m7f_last ]
				m7f_last = g_pn
				if [ g_dt < 0 ] g_dt = 0
				if [ g_dt > 100000 ] g_dt = 100000
				g_ff : f64 [ f64[ g_dt ] / 16639.0 ]
				m7k = f32[ 1.0 - pow[ 0.78, g_ff ] ]
			m7_matrices[ m7k ]
			hf : f32 [ 0.0 ]
			vf : f32 [ 0.0 ]
			if [ pub_m7sel & 1 ] hf = 1.0
			if [ pub_m7sel & 2 ] vf = 1.0
			m7_shader.params = vec4f [ hf, vf, f32[ (u32[pub_m7sel] >> 6) & 3 ], 0.0 ]
			m7_render.update[]
			m7_render.draw[]
			m7_render.flush_submit[]
		pub_lock.unlock[]
		if [ scaled ]
			if [ !occ_render ] scaler_setup[ cv ]
			if [ se_2d && ! vec ]
				if [ lay_on && !m7_active ]
					se1_render.update[]
					se1_render.draw[]
					se1_render.flush_submit[]
					se2_render.update[]
					se2_render.draw[]
					se2_render.flush_submit[]
					se3_render.update[]
					se3_render.draw[]
					se3_render.flush_submit[]
					sew_render.update[]
					sew_render.draw[]
					sew_render.flush_submit[]
					ses_render.update[]
					ses_render.draw[]
					ses_render.flush_submit[]
					se1_render.sync_fence[]
					se2_render.sync_fence[]
					se3_render.sync_fence[]
					sew_render.sync_fence[]
					ses_render.sync_fence[]
				el
					se_render.update[]
					se_render.draw[]
					se_render.flush_submit[]
					se_render.sync_fence[]
			if [ lay_on && !m7_active ]
				oc1_render.update[]
				oc1_render.draw[]
				oc1_render.flush_submit[]
				oc2_render.update[]
				oc2_render.draw[]
				oc2_render.flush_submit[]
				oc3_render.update[]
				oc3_render.draw[]
				oc3_render.flush_submit[]
				ocw_render.update[]
				ocw_render.draw[]
				ocw_render.flush_submit[]
				ocs_render.update[]
				ocs_render.draw[]
				ocs_render.flush_submit[]
			el
				occ_render.update[]
				occ_render.draw[]
				occ_render.flush_submit[]
		if [ m7_active ]
			m7_render.sync_fence[]
			# NO glide on mode-7 frames (smoothing is mode-0/1 only): the plane
			# is drawn per-scanline from HDMA'd matrices — a whole-frame rect
			# offset can't represent that, and the rep-line measurement publishes
			# 16-22px vertical spikes on F-Zero straightaways (visible bounce)
			cv.draw_image[ m7_render.color, out ]
		if [ lay_on && !m7_active ]
			# provenance layers, back -> front, each on its own glide channel;
			# world sprites ride BG1, screen sprites + retired BGs sit pinned
			g_now : i64 [ wall_ms[] * 1000 ]
			g_scx : f32 [ bounds.w / 256.0 ]
			g_scy : f32 [ bounds.h / 224.0 ]
			o1x : f32 [ lay_off[ g1dx, g1t, g1p, g_now, g_scx ] ]
			o1y : f32 [ lay_off[ g1dy, g1t, g1p, g_now, g_scy ] ]
			o2x : f32 [ lay_off[ g2dx, g2t, g2p, g_now, g_scx ] ]
			o2y : f32 [ lay_off[ g2dy, g2t, g2p, g_now, g_scy ] ]
			o3x : f32 [ lay_off[ g3dx, g3t, g3p, g_now, g_scx ] ]
			o3y : f32 [ lay_off[ g3dy, g3t, g3p, g_now, g_scy ] ]
			r1 : rect [ x: vp.x - 16.0 * g_scx + o1x, y: vp.y - 16.0 * g_scy + o1y, w: 288.0 * g_scx, h: 256.0 * g_scy ]
			r2 : rect [ x: vp.x - 16.0 * g_scx + o2x, y: vp.y - 16.0 * g_scy + o2y, w: 288.0 * g_scx, h: 256.0 * g_scy ]
			r3 : rect [ x: vp.x - 16.0 * g_scx + o3x, y: vp.y - 16.0 * g_scy + o3y, w: 288.0 * g_scx, h: 256.0 * g_scy ]
			owx : f32 [ o1x ]
			owy : f32 [ o1y ]
			if [ ganch == 1 ]
				owx = o2x
				owy = o2y
			rw : rect [ x: vp.x + owx, y: vp.y + owy, w: vp.w, h: vp.h ]
			if [ scaled ]
				if [ !b3 ]
					oc3_render.sync_fence[]
					cv.draw_image[ oc3_render.color, r3 ]
				oc2_render.sync_fence[]
				cv.draw_image[ oc2_render.color, r2 ]
				oc1_render.sync_fence[]
				cv.draw_image[ oc1_render.color, r1 ]
				ocw_render.sync_fence[]
				cv.draw_image[ ocw_render.color, rw ]
				if [ b3 ]
					oc3_render.sync_fence[]
					cv.draw_image[ oc3_render.color, r3 ]
				ocs_render.sync_fence[]
				cv.draw_image[ ocs_render.color, out ]
			el
				if [ !b3 ] cv.draw_image[ lay3_tex, r3 ]
				cv.draw_image[ lay2_tex, r2 ]
				cv.draw_image[ lay1_tex, r1 ]
				cv.draw_image[ layw_tex, rw ]
				if [ b3 ] cv.draw_image[ lay3_tex, r3 ]
				cv.draw_image[ lays_tex, out ]
		el [ scaled ]
			occ_render.sync_fence[]
			cv.draw_image[ occ_render.color, out ]
		el
			cv.draw_image[ screen_tex, out ]

	# write a full PPU/CPU snapshot (WRAM+VRAM+CGRAM+OAM+regs+per-line arrays) to a file.
	# shared by the ASNES_DUMP_FILE env path and the 'P' snapshot key (snap_req).
	# complete PPU register + OAM state, as labeled text for cross-emulator diffing
	# FNV-1a over the 128K WRAM — a game-state fingerprint for locating the first frame
	# that diverges from a reference emulator (ASNES_HASHLOG=1). WRAM only (not the
	# volatile registers) so the hash reflects committed state, not NMI-timing jitter.
	func state_hash [] -> u32
		h : u32 [ 2166136261 ]
		hi : i32 [ 0 ]
		while [ hi < 0x20000 ]
			h = (h ^ u32[cpu.memory[0x7E0000 + hi]]) * 16777619
			hi += 1
		return h

	# FNV-1a over VRAM + CGRAM — graphics-state fingerprint to locate the first frame the
	# rendered data (tiles/palette) diverges from reference hardware, independent of the WRAM hash.
	func gfx_hash [] -> u32
		h : u32 [ 2166136261 ]
		i : i32 [ 0 ]
		while [ i < 0x10000 ]
			h = (h ^ u32[ppu.vram[i]]) * 16777619
			i += 1
		i = 0
		while [ i < 0x200 ]
			h = (h ^ u32[ppu.cgram[i]]) * 16777619
			i += 1
		return h

	# FNV-1a over an arbitrary memory range — building block for the per-section state signature.
	func fnv_range [ p: ref u8, off: i32, n: i32 ] -> u32
		h : u32 [ 2166136261 ]
		i : i32 [ 0 ]
		while [ i < n ]
			h = (h ^ u32[p[off + i]]) * 16777619
			i += 1
		return h

	# Complete-state signature: an individual FNV-1a hash for EVERY section of machine state
	# (all memory regions + every register block), emitted on one line so a byte-for-byte diff
	# against reference hardware pinpoints both WHICH instruction and WHICH section first diverges.
	func emit_sigs [ tag: symbol ]
		wram  : u32 [ fnv_range[ cpu.memory, 0x7E0000, 0x20000 ] ]
		vram  : u32 [ fnv_range[ ppu.vram,  0, 0x10000 ] ]
		cgram : u32 [ fnv_range[ ppu.cgram, 0, 0x200 ] ]
		oam   : u32 [ fnv_range[ ppu.oam,   0, 0x220 ] ]
		apu   : u32 [ fnv_range[ spc.ram,   0, 0x10000 ] ]
		dsp   : u32 [ fnv_range[ spc.dsp,   0, 128 ] ]
		b : new u8 [ 4096 ]
		o : i32 [ 0 ]
		# --- CPU registers ---
		o = st_w16[ b, o, cpu.pc ]
		o = st_w8[ b, o, cpu.a ]
		o = st_w8[ b, o, cpu.x ]
		o = st_w8[ b, o, cpu.y ]
		o = st_w16[ b, o, cpu.sp ]
		o = st_w8[ b, o, cpu.p ]
		o = st_w16[ b, o, cpu.dp ]
		o = st_w8[ b, o, cpu.dbr ]
		o = st_w8[ b, o, cpu.pbr ]
		o = st_w8[ b, o, (cpu.e) ? u8[1] : u8[0] ]
		o = st_w8[ b, o, cpu.b ]
		o = st_w8[ b, o, cpu.xh ]
		o = st_w8[ b, o, cpu.yh ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, cpu.ports[k] ]
		ocpu : i32 [ o ]
		# --- PPU registers ---
		o = st_w8[ b, o, ppu.inidisp ]
		o = st_w8[ b, o, ppu.obsel ]
		o = st_w8[ b, o, ppu.bgmode ]
		o = st_w8[ b, o, ppu.mosaic ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, ppu.bg_sc[k] ]
		o = st_w8[ b, o, ppu.bg_nba[0] ]
		o = st_w8[ b, o, ppu.bg_nba[1] ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w16[ b, o, ppu.bg_hofs[k] ]
			o = st_w16[ b, o, ppu.bg_vofs[k] ]
		o = st_w8[ b, o, ppu.ofs_latch ]
		for [ k: i32 0, k < 8, k += 1 ]
			o = st_w8[ b, o, ppu.ofs_hl[k] ]
		o = st_w8[ b, o, ppu.vmain ]
		o = st_w16[ b, o, ppu.vram_addr ]
		o = st_w16[ b, o, ppu.vram_pre ]
		o = st_w8[ b, o, ppu.cgadd ]
		o = st_w8[ b, o, ppu.cg_latch ]
		o = st_w8[ b, o, (ppu.cg_toggle) ? u8[1] : u8[0] ]
		o = st_w16[ b, o, ppu.oamadd ]
		o = st_w16[ b, o, ppu.oamadd_reload ]
		o = st_w8[ b, o, ppu.oam_latch ]
		o = st_w8[ b, o, (ppu.oam_toggle) ? u8[1] : u8[0] ]
		o = st_w8[ b, o, ppu.tm ]
		o = st_w8[ b, o, ppu.ts ]
		o = st_w8[ b, o, ppu.w12sel ]
		o = st_w8[ b, o, ppu.w34sel ]
		o = st_w8[ b, o, ppu.wobjsel ]
		o = st_w8[ b, o, ppu.wh0 ]
		o = st_w8[ b, o, ppu.wh1 ]
		o = st_w8[ b, o, ppu.wh2 ]
		o = st_w8[ b, o, ppu.wh3 ]
		o = st_w8[ b, o, ppu.wbglog ]
		o = st_w8[ b, o, ppu.wobjlog ]
		o = st_w8[ b, o, ppu.tmw ]
		o = st_w8[ b, o, ppu.tsw ]
		o = st_w8[ b, o, ppu.cgwsel ]
		o = st_w8[ b, o, ppu.cgadsub ]
		o = st_w16[ b, o, ppu.coldata ]
		o = st_w8[ b, o, ppu.setini ]
		o = st_w16[ b, o, u16[ppu.m7a] ]
		o = st_w16[ b, o, u16[ppu.m7b] ]
		o = st_w16[ b, o, u16[ppu.m7c] ]
		o = st_w16[ b, o, u16[ppu.m7d] ]
		o = st_w16[ b, o, u16[ppu.m7x] ]
		o = st_w16[ b, o, u16[ppu.m7y] ]
		o = st_w16[ b, o, u16[ppu.m7hofs] ]
		o = st_w16[ b, o, u16[ppu.m7vofs] ]
		o = st_w8[ b, o, ppu.m7sel ]
		o = st_w8[ b, o, ppu.m7_latch ]
		oppu : i32 [ o ]
		# --- SPC / APU registers ---
		o = st_w16[ b, o, spc.pc ]
		o = st_w8[ b, o, spc.a ]
		o = st_w8[ b, o, spc.x ]
		o = st_w8[ b, o, spc.y ]
		o = st_w8[ b, o, spc.sp ]
		o = st_w8[ b, o, spc.psw ]
		o = st_w8[ b, o, spc.direct_page ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, spc.ports[k] ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, spc.in_stage[k] ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, spc.oports[k] ]
		o = st_w16[ b, o, spc.echo_pos ]
		o = st_w32[ b, o, u32[spc.fir_idx] ]
		o = st_w8[ b, o, spc.timer_on ]
		for [ k: i32 0, k < 3, k += 1 ]
			o = st_w8[ b, o, spc.timer_target[k] ]
		for [ k: i32 0, k < 3, k += 1 ]
			o = st_w8[ b, o, spc.timer_count[k] ]
		for [ k: i32 0, k < 3, k += 1 ]
			o = st_w32[ b, o, u32[spc.timer_stage[k]] ]
		o = st_w32[ b, o, u32[spc.tcyc] ]
		o = st_w8[ b, o, spc.kon_latch ]
		o = st_w8[ b, o, spc.koff_latch ]
		o = st_w32[ b, o, u32[spc.cycle_accum] ]
		for [ c: i32 0, c < 8, c += 1 ]
			o = st_w16[ b, o, spc.channels[c].pos ]
			o = st_w16[ b, o, spc.channels[c].frac ]
			for [ s: i32 0, s < 4, s += 1 ]
				o = st_w16[ b, o, u16[spc.channels[c].samples[s]] ]
			o = st_w16[ b, o, u16[spc.channels[c].envelope] ]
			o = st_w8[ b, o, spc.channels[c].env_state ]
			o = st_w32[ b, o, u32[spc.channels[c].env_count] ]
			o = st_w8[ b, o, spc.channels[c].active ]
		ospc : i32 [ o ]
		# --- CPU I/O registers (nmitimen, mult/div, joypad, timing) ---
		o = st_w8[ b, o, nmitimen ]
		o = st_w8[ b, o, (nmi_occurred) ? u8[1] : u8[0] ]
		o = st_w32[ b, o, wram_addr ]
		o = st_w8[ b, o, mpya ]
		o = st_w8[ b, o, mpyb ]
		o = st_w16[ b, o, wrdiv ]
		o = st_w16[ b, o, rddiv ]
		o = st_w16[ b, o, rdmpy ]
		o = st_w16[ b, o, pad1 ]
		o = st_w8[ b, o, joy_strobe ]
		o = st_w32[ b, o, u32[joy_index] ]
		o = st_w16[ b, o, htime ]
		o = st_w16[ b, o, vtime ]
		o = st_w8[ b, o, (irq_occurred) ? u8[1] : u8[0] ]
		o = st_w32[ b, o, u32[frame_cycle] ]
		o = st_w8[ b, o, (in_vblank) ? u8[1] : u8[0] ]
		o = st_w8[ b, o, (cpu_wai) ? u8[1] : u8[0] ]
		oio : i32 [ o ]
		# --- DMA / HDMA channel state ---
		for [ k: i32 0, k < 8, k += 1 ]
			o = st_w16[ b, o, hdma_addr[k] ]
			o = st_w8[ b, o, hdma_line[k] ]
			o = st_w16[ b, o, hdma_ind[k] ]
			o = st_w8[ b, o, hdma_do[k] ]
			o = st_w8[ b, o, hdma_done[k] ]
		cpu_h : u32 [ fnv_range[ b, 0,    ocpu ] ]
		ppu_h : u32 [ fnv_range[ b, ocpu, oppu - ocpu ] ]
		spc_h : u32 [ fnv_range[ b, oppu, ospc - oppu ] ]
		io_h  : u32 [ fnv_range[ b, ospc, oio  - ospc ] ]
		dma_h : u32 [ fnv_range[ b, oio,  o    - oio ] ]
		printf[ "SIG %s f%u %02X:%04X A=%04X X=%04X Y=%04X S=%04X D=%04X DB=%02X P=%02X E=%d wram=%08X vram=%08X cgram=%08X oam=%08X apu=%08X dsp=%08X spcpc=%04X spca=%02X spcx=%02X spcy=%02X spcs=%02X spcp=%02X accum=%lld pos=%lld\n", tag, dbg_frames, cpu.pbr, cpu.pc, cpu.a | (cpu.b << 8), cpu.x | (cpu.xh << 8), cpu.y | (cpu.yh << 8), cpu.sp, cpu.dp, cpu.dbr, cpu.p, (cpu.e) ? 1 : 0, wram, vram, cgram, oam, apu, dsp, spc.pc, spc.a, spc.x, spc.y, spc.sp, spc.psw, spc.cycle_accum, spc.pos ]

	func dump_pstate [ fn: symbol ]
		lf : ref FILE [ fopen[ '/tmp/asnes_lines.txt', 'wb' ] ]
		if [ lf ]
			for [ ly: i32 0, ly < 224, ly += 1 ]
				fprintf[ lf, "y%03d ini=%02X mode=%02X tm=%02X tmw=%02X cgad=%02X cgw=%02X cold=%04X wh=%02X,%02X,%02X,%02X w12=%02X bg1v=%04X bg3h=%04X bg3v=%04X\n",
					ly, u32[line_inidisp[ly]], u32[line_mode[ly]], u32[line_tm[ly]], u32[line_tmw[ly]], u32[line_cgadsub[ly]], u32[line_cgwsel[ly]], u32[line_coldata[ly]],
					u32[line_wh0[ly]], u32[line_wh1[ly]], u32[line_wh2[ly]], u32[line_wh3[ly]], u32[line_w12sel[ly]], u32[line_v[ly]], u32[line_h[2 * 224 + ly]], u32[line_v[2 * 224 + ly]] ]
			fclose[ lf ]
		f : ref FILE [ fopen[ fn, 'wb' ] ]
		if [ !f ] return
		fprintf[ f, "INIDISP %02X\n", u32[ppu.inidisp] ]
		fprintf[ f, "OBSEL %02X\n", u32[ppu.obsel] ]
		fprintf[ f, "BGMODE %02X\n", u32[ppu.bgmode] ]
		fprintf[ f, "MOSAIC %02X\n", u32[ppu.mosaic] ]
		for [ k: i32 0, k < 4, k += 1 ]
			fprintf[ f, "BG%dSC %02X\n", k + 1, u32[ppu.bg_sc[k]] ]
		fprintf[ f, "BG12NBA %02X\n", u32[ppu.bg_nba[0]] ]
		fprintf[ f, "BG34NBA %02X\n", u32[ppu.bg_nba[1]] ]
		for [ k: i32 0, k < 4, k += 1 ]
			fprintf[ f, "BG%dHOFS %04X\n", k + 1, u32[ppu.bg_hofs[k]] ]
			fprintf[ f, "BG%dVOFS %04X\n", k + 1, u32[ppu.bg_vofs[k]] ]
		fprintf[ f, "TM %02X\n", u32[ppu.tm] ]
		fprintf[ f, "TS %02X\n", u32[ppu.ts] ]
		fprintf[ f, "TMW %02X\n", u32[ppu.tmw] ]
		fprintf[ f, "TSW %02X\n", u32[ppu.tsw] ]
		fprintf[ f, "W12SEL %02X\n", u32[ppu.w12sel] ]
		fprintf[ f, "W34SEL %02X\n", u32[ppu.w34sel] ]
		fprintf[ f, "WOBJSEL %02X\n", u32[ppu.wobjsel] ]
		fprintf[ f, "WBGLOG %02X\n", u32[ppu.wbglog] ]
		fprintf[ f, "WOBJLOG %02X\n", u32[ppu.wobjlog] ]
		fprintf[ f, "WH0 %02X\n", u32[ppu.wh0] ]
		fprintf[ f, "WH1 %02X\n", u32[ppu.wh1] ]
		fprintf[ f, "WH2 %02X\n", u32[ppu.wh2] ]
		fprintf[ f, "WH3 %02X\n", u32[ppu.wh3] ]
		fprintf[ f, "CGWSEL %02X\n", u32[ppu.cgwsel] ]
		fprintf[ f, "CGADSUB %02X\n", u32[ppu.cgadsub] ]
		fprintf[ f, "COLDATA %04X\n", u32[ppu.coldata] ]
		fprintf[ f, "SETINI %02X\n", u32[ppu.setini] ]
		fprintf[ f, "M7SEL %02X\n", u32[ppu.m7sel] ]
		fprintf[ f, "M7A %04X\n", u32[u16[ppu.m7a]] ]
		fprintf[ f, "M7B %04X\n", u32[u16[ppu.m7b]] ]
		fprintf[ f, "M7C %04X\n", u32[u16[ppu.m7c]] ]
		fprintf[ f, "M7D %04X\n", u32[u16[ppu.m7d]] ]
		fprintf[ f, "M7X %04X\n", u32[u16[ppu.m7x]] ]
		fprintf[ f, "M7Y %04X\n", u32[u16[ppu.m7y]] ]
		for [ k: i32 0, k < 0x220, k += 1 ]
			fprintf[ f, "OAM%03X %02X\n", k, u32[ppu.oam[k]] ]
		fclose[ f ]

	func write_snapshot [ fn: symbol ]
		wf : ref FILE [ fopen[ fn, 'wb' ] ]
		if [ !wf ] return
		fwrite[ cpu.memory + 0x7E0000, 1, 0x20000, wf ]
		fwrite[ ppu.vram,  1, 0x10000, wf ]
		fwrite[ ppu.cgram, 1, 0x200,   wf ]
		fwrite[ ppu.oam,   1, 0x220,   wf ]
		rg : new u8 [ 64 ]
		rg[0]  = ppu.inidisp
		rg[1]  = ppu.bgmode
		rg[2]  = ppu.mosaic
		rg[3]  = ppu.obsel
		rg[4]  = ppu.tm
		rg[5]  = ppu.ts
		rg[6]  = ppu.vmain
		rg[7]  = ppu.bg_sc[0]
		rg[8]  = ppu.bg_sc[1]
		rg[9]  = ppu.bg_sc[2]
		rg[10] = ppu.bg_sc[3]
		rg[11] = ppu.bg_nba[0]
		rg[12] = ppu.bg_nba[1]
		for [ k: i32 0, k < 4, k += 1 ]
			rg[13 + k * 2] = u8[ ppu.bg_hofs[k] & 0xFF ]
			rg[14 + k * 2] = u8[ ppu.bg_hofs[k] >> 8 ]
			rg[21 + k * 2] = u8[ ppu.bg_vofs[k] & 0xFF ]
			rg[22 + k * 2] = u8[ ppu.bg_vofs[k] >> 8 ]
		rg[29] = cpu.memory[0x420C]
		for [ ch: i32 0, ch < 8, ch += 1 ]
			rg[30 + ch] = cpu.memory[0x4300 + (ch << 4)]
			rg[38 + ch] = cpu.memory[0x4301 + (ch << 4)]
		rg[46] = ppu.m7sel
		rg[47] = u8[ u16[ppu.m7x] & 0xFF ]
		rg[48] = u8[ (u16[ppu.m7x] >> 8) & 0xFF ]
		rg[49] = u8[ u16[ppu.m7y] & 0xFF ]
		rg[50] = u8[ (u16[ppu.m7y] >> 8) & 0xFF ]
		rg[51] = u8[ u16[ppu.m7hofs] & 0xFF ]
		rg[52] = u8[ (u16[ppu.m7hofs] >> 8) & 0xFF ]
		rg[53] = u8[ u16[ppu.m7vofs] & 0xFF ]
		rg[54] = u8[ (u16[ppu.m7vofs] >> 8) & 0xFF ]
		rg[55] = ppu.cgwsel
		rg[56] = ppu.tmw
		rg[57] = ppu.tsw
		rg[58] = ppu.w12sel
		rg[59] = ppu.wh0
		rg[60] = ppu.wh1
		fwrite[ rg, 1, 64, wf ]
		fwrite[ line_mode, 1, 224, wf ]
		fwrite[ line_m7a, 2, 224, wf ]
		fwrite[ line_m7b, 2, 224, wf ]
		fwrite[ line_m7c, 2, 224, wf ]
		fwrite[ line_m7d, 2, 224, wf ]
		fwrite[ line_coldata, 2, 224, wf ]
		fwrite[ line_cgadsub, 1, 224, wf ]
		fwrite[ line_cgwsel, 1, 224, wf ]
		fwrite[ line_wobjsel, 1, 224, wf ]
		fwrite[ line_wobjlog, 1, 224, wf ]
		fwrite[ line_wh0, 1, 224, wf ]
		fwrite[ line_wh1, 1, 224, wf ]
		fwrite[ line_wh2, 1, 224, wf ]
		fwrite[ line_wh3, 1, 224, wf ]
		ppu_render[]                                   # ensure framebuf reflects current state
		fwrite[ ppu.framebuf, 4, 256 * 224, wf ]       # actual rendered output (ground truth)
		fclose[ wf ]
		puts 'asnes snapshot written'

	# Save the current rendered frame as a PNG (the app's own output). Uses the img
	# module's Image (RGBA8) + libpng. ppu.framebuf is RGBA8, 256x224.
	func ppu_screenshot [ fn: symbol ]
		ppu_render[]
		shot : Image [ width: 256, height: 224, format: Pixel.rgba8 ]
		memcpy[ shot.vdata[], ppu.framebuf, 256 * 224 * 4 ]
		shot.png[ path fn ]
		bd : u16 [ u16[ppu.cgram[0]] | (u16[ppu.cgram[1]] << 8) ]
		printf[ "asnes bgmode=%02X tm=%02X ts=%02X backdrop=%04X obsel=%02X\n", u32[ppu.bgmode], u32[ppu.tm], u32[ppu.ts], u32[bd], u32[ppu.obsel] ]
		printf[ "  cpu_cycles=%ld dbg_frames=%u\n", cpu_cycles, dbg_frames ]
		printf[ "  cmath y100: cgadsub=%02X cgwsel=%02X ts=%02X coldata=%04X | y150: cgadsub=%02X cgwsel=%02X ts=%02X\n", u32[line_cgadsub[100]], u32[line_cgwsel[100]], u32[line_ts[100]], u32[line_coldata[100]], u32[line_cgadsub[150]], u32[line_cgwsel[150]], u32[line_ts[150]] ]
		for [ yy: i32 0, yy < 224, yy += 32 ]
			printf[ "  win y%d: wobjsel=%02X wobjlog=%02X wh0=%d wh1=%d wh2=%d wh3=%d fen=%d\n", yy, u32[line_wobjsel[yy]], u32[line_wobjlog[yy]], i32[line_wh0[yy]], i32[line_wh1[yy]], i32[line_wh2[yy]], i32[line_wh3[yy]], i32[bool[fog_enabled[128,yy]]] ]
		nopen : i32 [ 0 ]
		for [ yy: i32 0, yy < 224, yy += 1 ]
			if [ line_wh0[yy] < line_wh1[yy] ] nopen += 1
		printf[ "  rendered scanlines with an OPEN window (wh0<wh1): %d / 224\n", nopen ]
		for [ g: i32 0, g < 4, g += 1 ]
			sc : u8  [ ppu.bg_sc[g] ]
			nb : u8  [ ppu.bg_nba[g >> 1] ]
			nib: u32 [ u32[nb] & 0x0F ]
			if [ g & 1 ] nib = (u32[nb] >> 4) & 0x0F
			printf[ "  BG%d scr=%04X char=%04X hofs=%d vofs=%d on=%d\n", g + 1, ((u32[sc] >> 2) & 0x3F) * 0x400, nib * 0x1000, i32[ppu.bg_hofs[g]], i32[ppu.bg_vofs[g]], (ppu.tm >> g) & 1 ]
		puts 'asnes screenshot {fn}'

	# render ONE background layer (both priorities) over the backdrop, save as PNG.
	func ppu_shot_bg [ fn: symbol, bg: i32, bpp: i32 ]
		bg0 : u16 [ ppu_cgram_color[ 0 ] ]
		px  : u32 [ ppu_color[ bg0, 15 ] ]
		for [ i: i32 0, i < 256 * 224, i += 1 ]
			ppu.framebuf[i] = px
		for [ y: i32 0, y < 224, y += 1 ]
			ppu_bg_line[ bg, bpp, y, 15, 0 ]
			ppu_bg_line[ bg, bpp, y, 15, 1 ]
		shot : Image [ width: 256, height: 224, format: Pixel.rgba8 ]
		memcpy[ shot.vdata[], ppu.framebuf, 256 * 224 * 4 ]
		shot.png[ path fn ]
		puts 'asnes bg{bg} -> {fn}'

	# render the 4bpp char data at a word base as a 32x28 tile atlas (896 tiles),
	# grayscale by pixel index, so missing/garbled tiles are visible.
	func ppu_atlas [ fn: symbol, cbase: u32 ]
		for [ i: i32 0, i < 256 * 224, i += 1 ]
			ppu.framebuf[i] = 0xFF000000
		for [ t: i32 0, t < 896, t += 1 ]
			tx : i32 [ (t % 32) * 8 ]
			ty : i32 [ (t / 32) * 8 ]
			tb : u32 [ cbase + u32[t] * 16 ]
			for [ row: i32 0, row < 8, row += 1 ]
				w01 : u32 [ ppu_vw[ tb + u32[row] ] ]
				w23 : u32 [ ppu_vw[ tb + 8 + u32[row] ] ]
				for [ col: i32 0, col < 8, col += 1 ]
					bit : u32 [ u32[7 - col] ]
					idx : u32 [ ((w01 >> bit) & 1) | (((w01 >> (bit + 8)) & 1) << 1) | (((w23 >> bit) & 1) << 2) | (((w23 >> (bit + 8)) & 1) << 3) ]
					g   : u32 [ idx * 17 ]
					ppu.framebuf[ (ty + row) * 256 + (tx + col) ] = 0xFF000000 | (g << 16) | (g << 8) | g
		shot : Image [ width: 256, height: 224, format: Pixel.rgba8 ]
		memcpy[ shot.vdata[], ppu.framebuf, 256 * 224 * 4 ]
		shot.png[ path fn ]
		puts 'asnes atlas {cbase} -> {fn}'

	# --- savestate: full resumable machine state (P=save, L=load, --state=boot-load) ---
	# Order MUST match between save_state and load_state. Float audio tails (echo/fir/lp)
	# are intentionally skipped; they self-heal within a few samples on resume.
	func save_state [ fn: symbol ]
		if [ !cpu || !spc ] return
		wf : ref FILE [ fopen[ fn, 'wb' ] ]
		if [ !wf ] return
		# header: 8-byte magic + 1024-byte zero-padded rom path, so states are
		# self-describing and a restore can verify it matches the loaded rom
		mg : symbol [ 'ASNESSV1' ]
		fwrite[ mg, 1, 8, wf ]
		pb : new u8 [ 1024 ]
		memset[ pb, 0, 1024 ]
		rp : symbol [ rom.chars ]
		rl : i32 [ i32[ strlen[ rp ] ] ]
		if [ rl > 1023 ] rl = 1023
		memcpy[ pb, rp, rl ]
		fwrite[ pb, 1, 1024, wf ]
		fwrite[ cpu.memory, 1, 0x1000000, wf ]
		fwrite[ ppu.vram,  1, 0x10000, wf ]
		fwrite[ ppu.cgram, 1, 0x200,   wf ]
		fwrite[ ppu.oam,   1, 0x220,   wf ]
		fwrite[ spc.ram,   1, 0x10000, wf ]
		fwrite[ spc.dsp,   1, 128,     wf ]
		b : new u8 [ 4096 ]
		o : i32 [ 0 ]
		o = st_w16[ b, o, cpu.pc ]
		o = st_w8[ b, o, cpu.a ]
		o = st_w8[ b, o, cpu.x ]
		o = st_w8[ b, o, cpu.y ]
		o = st_w16[ b, o, cpu.sp ]
		o = st_w8[ b, o, cpu.p ]
		o = st_w16[ b, o, cpu.dp ]
		o = st_w8[ b, o, cpu.dbr ]
		o = st_w8[ b, o, cpu.pbr ]
		o = st_w8[ b, o, (cpu.e) ? u8[1] : u8[0] ]
		o = st_w8[ b, o, cpu.b ]
		o = st_w8[ b, o, cpu.xh ]
		o = st_w8[ b, o, cpu.yh ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, cpu.ports[k] ]
		o = st_w8[ b, o, ppu.inidisp ]
		o = st_w8[ b, o, ppu.obsel ]
		o = st_w8[ b, o, ppu.bgmode ]
		o = st_w8[ b, o, ppu.mosaic ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, ppu.bg_sc[k] ]
		o = st_w8[ b, o, ppu.bg_nba[0] ]
		o = st_w8[ b, o, ppu.bg_nba[1] ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w16[ b, o, ppu.bg_hofs[k] ]
			o = st_w16[ b, o, ppu.bg_vofs[k] ]
		o = st_w8[ b, o, ppu.ofs_latch ]
		for [ k: i32 0, k < 8, k += 1 ]
			o = st_w8[ b, o, ppu.ofs_hl[k] ]
		o = st_w8[ b, o, ppu.vmain ]
		o = st_w16[ b, o, ppu.vram_addr ]
		o = st_w16[ b, o, ppu.vram_pre ]
		o = st_w8[ b, o, ppu.cgadd ]
		o = st_w8[ b, o, ppu.cg_latch ]
		o = st_w8[ b, o, (ppu.cg_toggle) ? u8[1] : u8[0] ]
		o = st_w16[ b, o, ppu.oamadd ]
		o = st_w16[ b, o, ppu.oamadd_reload ]
		o = st_w8[ b, o, ppu.oam_latch ]
		o = st_w8[ b, o, (ppu.oam_toggle) ? u8[1] : u8[0] ]
		o = st_w8[ b, o, ppu.tm ]
		o = st_w8[ b, o, ppu.ts ]
		o = st_w8[ b, o, ppu.w12sel ]
		o = st_w8[ b, o, ppu.w34sel ]
		o = st_w8[ b, o, ppu.wobjsel ]
		o = st_w8[ b, o, ppu.wh0 ]
		o = st_w8[ b, o, ppu.wh1 ]
		o = st_w8[ b, o, ppu.wh2 ]
		o = st_w8[ b, o, ppu.wh3 ]
		o = st_w8[ b, o, ppu.wbglog ]
		o = st_w8[ b, o, ppu.wobjlog ]
		o = st_w8[ b, o, ppu.tmw ]
		o = st_w8[ b, o, ppu.tsw ]
		o = st_w8[ b, o, ppu.cgwsel ]
		o = st_w8[ b, o, ppu.cgadsub ]
		o = st_w16[ b, o, ppu.coldata ]
		o = st_w8[ b, o, ppu.setini ]
		o = st_w16[ b, o, u16[ppu.m7a] ]
		o = st_w16[ b, o, u16[ppu.m7b] ]
		o = st_w16[ b, o, u16[ppu.m7c] ]
		o = st_w16[ b, o, u16[ppu.m7d] ]
		o = st_w16[ b, o, u16[ppu.m7x] ]
		o = st_w16[ b, o, u16[ppu.m7y] ]
		o = st_w16[ b, o, u16[ppu.m7hofs] ]
		o = st_w16[ b, o, u16[ppu.m7vofs] ]
		o = st_w8[ b, o, ppu.m7sel ]
		o = st_w8[ b, o, ppu.m7_latch ]
		o = st_w16[ b, o, spc.pc ]
		o = st_w8[ b, o, spc.a ]
		o = st_w8[ b, o, spc.x ]
		o = st_w8[ b, o, spc.y ]
		o = st_w8[ b, o, spc.sp ]
		o = st_w8[ b, o, spc.psw ]
		o = st_w8[ b, o, spc.direct_page ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, spc.ports[k] ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, spc.in_stage[k] ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, spc.oports[k] ]
		o = st_w16[ b, o, spc.echo_pos ]
		o = st_w32[ b, o, u32[spc.fir_idx] ]
		o = st_w8[ b, o, spc.timer_on ]
		for [ k: i32 0, k < 3, k += 1 ]
			o = st_w8[ b, o, spc.timer_target[k] ]
		for [ k: i32 0, k < 3, k += 1 ]
			o = st_w8[ b, o, spc.timer_count[k] ]
		for [ k: i32 0, k < 3, k += 1 ]
			o = st_w32[ b, o, u32[spc.timer_stage[k]] ]
		o = st_w32[ b, o, u32[spc.tcyc] ]
		o = st_w8[ b, o, spc.kon_latch ]
		o = st_w8[ b, o, spc.koff_latch ]
		o = st_w32[ b, o, u32[spc.cycle_accum] ]
		for [ c: i32 0, c < 8, c += 1 ]
			o = st_w16[ b, o, spc.channels[c].pos ]
			o = st_w16[ b, o, spc.channels[c].frac ]
			for [ s: i32 0, s < 4, s += 1 ]
				o = st_w16[ b, o, u16[spc.channels[c].samples[s]] ]
			o = st_w16[ b, o, u16[spc.channels[c].envelope] ]
			o = st_w8[ b, o, spc.channels[c].env_state ]
			o = st_w32[ b, o, u32[spc.channels[c].env_count] ]
			o = st_w8[ b, o, spc.channels[c].active ]
		o = st_w8[ b, o, nmitimen ]
		o = st_w8[ b, o, (nmi_occurred) ? u8[1] : u8[0] ]
		o = st_w32[ b, o, wram_addr ]
		o = st_w8[ b, o, mpya ]
		o = st_w8[ b, o, mpyb ]
		o = st_w16[ b, o, wrdiv ]
		o = st_w16[ b, o, rddiv ]
		o = st_w16[ b, o, rdmpy ]
		o = st_w16[ b, o, pad1 ]
		o = st_w8[ b, o, joy_strobe ]
		o = st_w32[ b, o, u32[joy_index] ]
		o = st_w16[ b, o, htime ]
		o = st_w16[ b, o, vtime ]
		o = st_w8[ b, o, (irq_occurred) ? u8[1] : u8[0] ]
		o = st_w32[ b, o, u32[frame_cycle] ]
		o = st_w8[ b, o, (in_vblank) ? u8[1] : u8[0] ]
		o = st_w8[ b, o, (cpu_wai) ? u8[1] : u8[0] ]
		o = st_w32[ b, o, dbg_frames ]
		o = st_w8[ b, o, (spc_rom_loaded) ? u8[1] : u8[0] ]
		for [ k: i32 0, k < 8, k += 1 ]
			o = st_w16[ b, o, hdma_addr[k] ]
			o = st_w8[ b, o, hdma_line[k] ]
			o = st_w16[ b, o, hdma_ind[k] ]
			o = st_w8[ b, o, hdma_do[k] ]
			o = st_w8[ b, o, hdma_done[k] ]
		fwrite[ b, 1, 4096, wf ]
		fclose[ wf ]
		puts 'asnes state saved'

	func load_state [ fn: symbol ]
		if [ !cpu || !spc ] return
		rf : ref FILE [ fopen[ fn, 'rb' ] ]
		if [ !rf ] return
		# header check: new states carry magic + rom path — refuse a state
		# saved from a different rom. headerless legacy states load as-is.
		hb : new u8 [ 8 ]
		fread[ hb, 1, 8, rf ]
		mg : symbol [ 'ASNESSV1' ]
		if [ memcmp[ hb, mg, 8 ] == 0 ]
			pb : new u8 [ 1024 ]
			fread[ pb, 1, 1024, rf ]
			rp : symbol [ rom.chars ]
			if [ strcmp[ pb, rp ] != 0 ]
				puts 'asnes state is for a different rom — not loading'
				fclose[ rf ]
				return
		el
			fseek[ rf, 0, 0 ]
		fread[ cpu.memory, 1, 0x1000000, rf ]
		fread[ ppu.vram,  1, 0x10000, rf ]
		fread[ ppu.cgram, 1, 0x200,   rf ]
		fread[ ppu.oam,   1, 0x220,   rf ]
		fread[ spc.ram,   1, 0x10000, rf ]
		fread[ spc.dsp,   1, 128,     rf ]
		b : new u8 [ 4096 ]
		fread[ b, 1, 4096, rf ]
		fclose[ rf ]
		o : i32 [ 0 ]
		cpu.pc = st_r16[ b, o ]
		o += 2
		cpu.a = b[o]
		o += 1
		cpu.x = b[o]
		o += 1
		cpu.y = b[o]
		o += 1
		cpu.sp = st_r16[ b, o ]
		o += 2
		cpu.p = b[o]
		o += 1
		cpu.dp = st_r16[ b, o ]
		o += 2
		cpu.dbr = b[o]
		o += 1
		cpu.pbr = b[o]
		o += 1
		cpu.e = b[o] != 0
		o += 1
		cpu.b = b[o]
		o += 1
		cpu.xh = b[o]
		o += 1
		cpu.yh = b[o]
		o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			cpu.ports[k] = b[o]
			o += 1
		ppu.inidisp = b[o]
		o += 1
		ppu.obsel = b[o]
		o += 1
		ppu.bgmode = b[o]
		o += 1
		ppu.mosaic = b[o]
		o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			ppu.bg_sc[k] = b[o]
			o += 1
		ppu.bg_nba[0] = b[o]
		o += 1
		ppu.bg_nba[1] = b[o]
		o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			ppu.bg_hofs[k] = st_r16[ b, o ]
			o += 2
			ppu.bg_vofs[k] = st_r16[ b, o ]
			o += 2
		ppu.ofs_latch = b[o]
		o += 1
		for [ k: i32 0, k < 8, k += 1 ]
			ppu.ofs_hl[k] = b[o]
			o += 1
		ppu.vmain = b[o]
		o += 1
		ppu.vram_addr = st_r16[ b, o ]
		o += 2
		ppu.vram_pre = st_r16[ b, o ]
		o += 2
		ppu.cgadd = b[o]
		o += 1
		ppu.cg_latch = b[o]
		o += 1
		ppu.cg_toggle = b[o] != 0
		o += 1
		ppu.oamadd = st_r16[ b, o ]
		o += 2
		ppu.oamadd_reload = st_r16[ b, o ]
		o += 2
		ppu.oam_latch = b[o]
		o += 1
		ppu.oam_toggle = b[o] != 0
		o += 1
		ppu.tm = b[o]
		o += 1
		ppu.ts = b[o]
		o += 1
		ppu.w12sel = b[o]
		o += 1
		ppu.w34sel = b[o]
		o += 1
		ppu.wobjsel = b[o]
		o += 1
		ppu.wh0 = b[o]
		o += 1
		ppu.wh1 = b[o]
		o += 1
		ppu.wh2 = b[o]
		o += 1
		ppu.wh3 = b[o]
		o += 1
		ppu.wbglog = b[o]
		o += 1
		ppu.wobjlog = b[o]
		o += 1
		ppu.tmw = b[o]
		o += 1
		ppu.tsw = b[o]
		o += 1
		ppu.cgwsel = b[o]
		o += 1
		ppu.cgadsub = b[o]
		o += 1
		ppu.coldata = st_r16[ b, o ]
		o += 2
		ppu.setini = b[o]
		o += 1
		ppu.m7a = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7b = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7c = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7d = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7x = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7y = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7hofs = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7vofs = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7sel = b[o]
		o += 1
		ppu.m7_latch = b[o]
		o += 1
		spc.pc = st_r16[ b, o ]
		o += 2
		spc.a = b[o]
		o += 1
		spc.x = b[o]
		o += 1
		spc.y = b[o]
		o += 1
		spc.sp = b[o]
		o += 1
		spc.psw = b[o]
		o += 1
		spc.direct_page = b[o]
		o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			spc.ports[k] = b[o]
			o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			spc.in_stage[k] = b[o]
			o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			spc.oports[k] = b[o]
			o += 1
		spc.echo_pos = st_r16[ b, o ]
		o += 2
		spc.fir_idx = i32[st_r32[ b, o ]]
		o += 4
		spc.timer_on = b[o]
		o += 1
		for [ k: i32 0, k < 3, k += 1 ]
			spc.timer_target[k] = b[o]
			o += 1
		for [ k: i32 0, k < 3, k += 1 ]
			spc.timer_count[k] = b[o]
			o += 1
		for [ k: i32 0, k < 3, k += 1 ]
			spc.timer_stage[k] = i32[st_r32[ b, o ]]
			o += 4
		spc.tcyc = i32[st_r32[ b, o ]]
		o += 4
		spc.kon_latch = b[o]
		o += 1
		spc.koff_latch = b[o]
		o += 1
		spc.cycle_accum = i32[st_r32[ b, o ]]
		o += 4
		for [ c: i32 0, c < 8, c += 1 ]
			spc.channels[c].pos = st_r16[ b, o ]
			o += 2
			spc.channels[c].frac = st_r16[ b, o ]
			o += 2
			for [ s: i32 0, s < 4, s += 1 ]
				spc.channels[c].samples[s] = i16[st_r16[ b, o ]]
				o += 2
			spc.channels[c].envelope = i16[st_r16[ b, o ]]
			o += 2
			spc.channels[c].env_state = b[o]
			o += 1
			spc.channels[c].env_count = i32[st_r32[ b, o ]]
			o += 4
			spc.channels[c].active = b[o]
			o += 1
		nmitimen = b[o]
		o += 1
		nmi_occurred = b[o] != 0
		o += 1
		wram_addr = st_r32[ b, o ]
		o += 4
		mpya = b[o]
		o += 1
		mpyb = b[o]
		o += 1
		wrdiv = st_r16[ b, o ]
		o += 2
		rddiv = st_r16[ b, o ]
		o += 2
		rdmpy = st_r16[ b, o ]
		o += 2
		pad1 = st_r16[ b, o ]
		o += 2
		joy_strobe = b[o]
		o += 1
		joy_index = i32[st_r32[ b, o ]]
		o += 4
		htime = st_r16[ b, o ]
		o += 2
		vtime = st_r16[ b, o ]
		o += 2
		irq_occurred = b[o] != 0
		o += 1
		frame_cycle = i32[st_r32[ b, o ]]
		o += 4
		in_vblank = b[o] != 0
		o += 1
		cpu_wai = b[o] != 0
		o += 1
		dbg_frames = st_r32[ b, o ]
		o += 4
		spc_rom_loaded = b[o] != 0
		o += 1
		for [ k: i32 0, k < 8, k += 1 ]
			hdma_addr[k] = st_r16[ b, o ]
			o += 2
			hdma_line[k] = b[o]
			o += 1
			hdma_ind[k] = st_r16[ b, o ]
			o += 2
			hdma_do[k] = b[o]
			o += 1
			hdma_done[k] = b[o]
			o += 1
		puts 'asnes state loaded'

	# little-endian pack/unpack helpers for savestate scalar block
	func st_w8 [ b: ref u8, o: i32, v: u8 ] -> i32
		b[o] = v
		return o + 1

	func st_w16 [ b: ref u8, o: i32, v: u16 ] -> i32
		b[o] = u8[v & 0xFF]
		b[o + 1] = u8[(v >> 8) & 0xFF]
		return o + 2

	func st_w32 [ b: ref u8, o: i32, v: u32 ] -> i32
		b[o] = u8[v & 0xFF]
		b[o + 1] = u8[(v >> 8) & 0xFF]
		b[o + 2] = u8[(v >> 16) & 0xFF]
		b[o + 3] = u8[(v >> 24) & 0xFF]
		return o + 4

	func st_r16 [ b: ref u8, o: i32 ] -> u16
		return u16[b[o]] | (u16[b[o + 1]] << 8)

	func st_r32 [ b: ref u8, o: i32 ] -> u32
		return u32[b[o]] | (u32[b[o + 1]] << 8) | (u32[b[o + 2]] << 16) | (u32[b[o + 3]] << 24)

	# per-iteration emulation-thread work: rigs + one DAC-paced rom frame + publish
	func emu_tick []
		now_e : i64 [ wall_ms[] ]
		if [ last_entry != 0 ] itv_ms30 += now_e - last_entry
		last_entry = now_e
		df : symbol [ getenv[ 'ASNES_DUMP_FRAME' ] ]
		if [ df && dbg_frames == atoi[ df ] ]
			fn : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
			if [ fn ]
				ppu_screenshot[ fn ]
				ppu_shot_bg[ '/tmp/asnes_bg1.png', 0, 4 ]
				ppu_shot_bg[ '/tmp/asnes_bg3.png', 2, 2 ]
				ppu_atlas[ '/tmp/asnes_atlas0.png', 0x0000 ]
				write_snapshot[ '/tmp/asnes_blob.bin' ]
				dump_pstate[ '/tmp/asnes_pstate.txt' ]
			exit[ 0 ]
		# cycle-index trigger (shared baseline): capture at first frame boundary where
		# total CPU cycles reach the target. ASNES_DUMP_CYCLE=N ASNES_DUMP_FILE=x.png
		dcy : symbol [ getenv[ 'ASNES_DUMP_CYCLE' ] ]
		if [ dcy && cpu_cycles >= i64[ atoi[ dcy ] ] ]
			printf[ "asnes capture at cpu_cycles=%ld dbg_frames=%u\n", cpu_cycles, dbg_frames ]
			fnc : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
			if [ fnc ]
				ppu_screenshot[ fnc ]
				ppu_shot_bg[ '/tmp/asnes_bg1.png', 0, 4 ]
				ppu_shot_bg[ '/tmp/asnes_bg3.png', 2, 2 ]
				ppu_atlas[ '/tmp/asnes_atlas0.png', 0x0000 ]
				write_snapshot[ '/tmp/asnes_blob.bin' ]
			exit[ 0 ]
		# --state <file>: load savestate once on the first frame after boot
		if [ state && !state_loaded ]
			state_loaded = true
			load_state[ state.chars ]
			write_snapshot[ '/tmp/asnes_snap.bin' ]      # also drop a diagnostic snapshot for analysis
		# hot-reload flash restore: the host leaves SILVER_RELOAD_LOAD set after
		# a live reload — pick up exactly where the previous instance left off
		el [ !state && !state_loaded && getenv[ 'SILVER_RELOAD_LOAD' ] ]
			state_loaded = true
			ff : ref FILE [ fopen[ '/tmp/asnes_flash.state', 'rb' ] ]
			if [ ff ]
				fclose[ ff ]
				load_state[ '/tmp/asnes_flash.state' ]
				puts 'asnes flash: state restored after reload'
		# loaded a state via --state: run one frame to populate the renderer, then capture + exit
		if [ state_loaded && state ]
			post_load += 1
			# ASNES_SEQ=N: ONE run dumps every post-load frame to /tmp/asnes_seq_<n>.png,
			# then exits at frame N. For watching a time-based effect (palette flash)
			# without relaunching the app per sample.
			seq : symbol [ getenv[ 'ASNES_SEQ' ] ]
			if [ seq ]
				sfn : symbol [ '/tmp/asnes_seq_{post_load}.png' ]
				ppu_screenshot[ sfn ]
				cw0 : u16 [ ppu_cgram_color[ 0 ] ]
				printf[ "CGS f%u bg=%02X cg0=%04X coldata=%04X cgadsub=%02X cgwsel=%02X tm=%02X ts=%02X\n",
					post_load, u32[line_mode[112]], u32[cw0], u32[line_coldata[112]],
					u32[line_cgadsub[112]], u32[line_cgwsel[112]], u32[line_tm[112]], u32[line_ts[112]] ]
				if [ post_load >= atoi[ seq ] ]
					dump_pstate[ '/tmp/asnes_pstate.txt' ]
					ppu_atlas[ '/tmp/asnes_atlas0.png', 0x0000 ]
					ppu_shot_bg[ '/tmp/asnes_bg1.png', 0, 4 ]
					ppu_shot_bg[ '/tmp/asnes_bg2.png', 1, 4 ]
					ppu_shot_bg[ '/tmp/asnes_bg3.png', 2, 2 ]
					write_snapshot[ '/tmp/asnes_blob.bin' ]
					exit[ 0 ]
			inj : symbol [ getenv[ 'ASNES_INJECT_START' ] ]
			if [ inj ]
				# run frames so the decompressor uploads the car tiles; capture at the env frame.
				# optional ASNES_PRESS_START: hold Start for 12 frames to advance a menu first.
				# value >= 2 sets the press frame (default window 5-16).
				psv   : symbol [ getenv['ASNES_PRESS_START'] ]
				pab   : symbol [ getenv['ASNES_PRESS_AB'] ]
				pa1   : symbol [ getenv['ASNES_PRESS_A'] ]
				pmask : u16 [ 0x1000 ]
				if [ pab ]
					pmask = 0x8080
					psv   = pab
				if [ pa1 ]
					pmask = 0x0080
					psv   = pa1
				if [ psv ]
					psb : i32 [ atoi[ psv ] ]
					if [ psb < 2 ] psb = 5
					if [ post_load >= psb && post_load <= (psb + 11) ] pad1 = pad1 | pmask
					el pad1 = pad1 & (~pmask)
				if [ post_load == atoi[ inj ] ]
					fni : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
					if [ fni ]
						ppu_screenshot[ fni ]
						write_snapshot[ '/tmp/asnes_blob.bin' ]
					exit[ 0 ]
			el [ !seq && post_load == 2 ]
				fns : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
				if [ fns ]
					ppu_screenshot[ fns ]
					write_snapshot[ '/tmp/asnes_blob.bin' ]
				exit[ 0 ]
		# boot-mode auto-drive: press Start ("Enter") at ~2s and ~3.3s to reach car-select,
		# then capture at the env frame. ASNES_AUTO_START=<capture-frame>.
		ab : symbol [ getenv[ 'ASNES_AUTO_START' ] ]
		if [ ab && cpu ]
			if [ dbg_frames >= 120 && dbg_frames <= 131 ] pad1 = pad1 | 0x1000
			el [ dbg_frames >= 200 && dbg_frames <= 211 ] pad1 = pad1 | 0x1000
			el [ dbg_frames >= 300 && dbg_frames <= 311 ] pad1 = pad1 | 0x1000
			el [ dbg_frames >= 400 && dbg_frames <= 411 ] pad1 = pad1 | 0x1000
			el pad1 = pad1 & (~0x1000)
			if [ dbg_frames == atoi[ ab ] ]
				fna : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
				if [ fna ]
					ppu_screenshot[ fna ]
					write_snapshot[ '/tmp/asnes_blob.bin' ]
				dump_pstate[ '/tmp/asnes_pstate.txt' ]
				exit[ 0 ]
		# 'P' = save savestate, 'L' = load savestate (also writes a diagnostic snapshot)
		if [ save_req ]
			save_req = false
			save_state[ '/tmp/asnes.state' ]
			write_snapshot[ '/tmp/asnes_snap.bin' ]
		if [ load_req ]
			load_req = false
			load_state[ '/tmp/asnes.state' ]
		# silent boot uses continuous SPC (load the song); playback uses the atomic
		# co-scheduler (clean ding + music, no port race). switch after the upload.
		# Emulation thread: the blocking audio write inside the frame paces this loop to
		# the DAC clock. The display never gates emulation and vice versa.
		t_emu : i64 [ wall_ms[] ]
		if [ dbg_frames < 28 ]
			run_rom_frame_boot[]
		el
			run_rom_frame[]
		emu_ms30 += wall_ms[] - t_emu
		dbg_frames += 1
		if [ getenv[ 'ASNES_CYCLOG' ] && (dbg_frames % 30) == 0 ]
			av2 : i64 [ snd_pcm_avail[ spc.pcm_handle ] ]
			printf[ "CYCF frame %u cyc_total=%ld carry=%d adone=%d avail=%ld emu_ms=%ld itv_ms=%ld\n", dbg_frames, cpu_cycles, frame_carry, spc.audio_done, av2, emu_ms30, itv_ms30 ]
			emu_ms30 = 0
			itv_ms30 = 0
		sf : symbol [ getenv[ 'ASNES_SHOTAT' ] ]
		if [ sf && dbg_frames == atoi[ sf ] ]
			df : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
			if [ df ] ppu_screenshot[ df ]
			dump_pstate[ '/tmp/asnes_pstate.txt' ]
			write_snapshot[ '/tmp/asnes_blob.bin' ]
			exit[ 0 ]
		if [ spc.pc < 0x8000 && dbg_h < 1 ]
			printf[ "ENGINE@%04X wait0873: %02X %02X %02X %02X %02X %02X  dspENvol7D=%02X ECEN4D=%02X\n",
				spc.pc, spc.ram[0x0873], spc.ram[0x0874], spc.ram[0x0875],
				spc.ram[0x0876], spc.ram[0x0877], spc.ram[0x0878], spc.dsp[0x7D], spc.dsp[0x4D] ]
			dbg_h += 1
		if [ (dbg_frames % 30) == 0 ]
			nzdsp : i32 [ 0 ]
			for [ r: i32 0, r < 128, r += 1 ]
				if [ spc.dsp[r] != 0 ] nzdsp += 1
			printf[ "frame %u cpu=%02X:%04X dbr=%02X spc=%04X nmien=%02X nmifires=%d kon=%d koff=%d c2a=%02X %02X %02X %02X a2c=%02X %02X %02X %02X sp=%04X dp=%04X e0E=%02X%02X%02X%02X ini=%02X shot=%02X sv=%d\n",
				dbg_frames, cpu.pbr, cpu.pc, cpu.dbr, spc.pc, nmitimen, dbg_spc, dbg_kon, dbg_cpu,
				spc.ports[0], spc.ports[1], spc.ports[2], spc.ports[3],
				spc.oports[0], spc.oports[1], spc.oports[2], spc.oports[3],
				cpu.sp, cpu.dp, cpu.memory[0x7E000E], cpu.memory[0x7E000F], cpu.memory[0x7E0010], cpu.memory[0x7E0011], ppu.inidisp, ppu.inidisp_shot, (shot_valid) ? 1 : 0 ]
		ppu_render[]
		# mode-0/1 glide: per-BG scroll delta at rep line 180, wrap-aware,
		# teleport-guarded. Layers render pre-lock so the render thread never
		# stalls behind the layer pass.
		rdh : local i32 [ 4 ]
		rdv : local i32 [ 4 ]
		for [ gb: i32 0, gb < 4, gb += 1 ]
			g_ch2 : i32 [ i32[line_h[ gb * 224 + 180 ]] & 0x3FF ]
			g_cv2 : i32 [ i32[line_v[ gb * 224 + 180 ]] & 0x3FF ]
			g_dh : i32 [ g_ch2 - bgg_prevh[gb] ]
			g_dv : i32 [ g_cv2 - bgg_prevv[gb] ]
			bgg_prevh[gb] = g_ch2
			bgg_prevv[gb] = g_cv2
			if [ g_dh > 512 ]  g_dh -= 1024
			if [ g_dh < -512 ] g_dh += 1024
			if [ g_dv > 512 ]  g_dv -= 1024
			if [ g_dv < -512 ] g_dv += 1024
			if [ g_dh > 48 || g_dh < -48 ] g_dh = 0
			if [ g_dv > 48 || g_dv < -48 ] g_dv = 0
			rdh[gb] = g_dh
			rdv[gb] = g_dv
		lay_frame : bool [ false ]
		if [ smooth && (line_mode[180] & 7) <= 1 ]
			for [ gb: i32 0, gb < 3, gb += 1 ]
				if [ rdh[gb] != 0 || rdv[gb] != 0 ] lay_frame = true
				if [ bgg_dx[gb] != 0.0 || bgg_dy[gb] != 0.0 ] lay_frame = true
		frame_b3 : bool [ (line_mode[180] & 0x08) != 0 ]
		if [ getenv[ 'ASNES_GLIDE' ] && dbg_bgr < 40 ]
			for [ gb: i32 0, gb < 4, gb += 1 ]
				if [ rdh[gb] != 0 || rdv[gb] != 0 ]
					printf[ "BGRAW f%u bg%d d=%d,%d mode180=%d lay=%d\n", dbg_frames, gb + 1,
						rdh[gb], rdv[gb], i32[line_mode[180]] & 7, (lay_frame) ? 1 : 0 ]
					dbg_bgr += 1
		if [ getenv[ 'ASNES_GLIDE' ] && lay_frame && (dbg_frames % 15) == 0 ]
			printf[ "BGLIDE f%u d1=%d,%d d2=%d,%d d3=%d,%d b3hi=%d\n",
				dbg_frames, rdh[0], rdv[0], rdh[1], rdv[1], rdh[2], rdv[2], (frame_b3) ? 1 : 0 ]
		classify_sprites[ rdh[0], rdv[0], rdh[1], rdv[1] ]
		if [ lay_frame ] ppu_render_layers[ frame_b3 ]
		pub_lock.lock[]
		if [ lay_frame ]
			memcpy[ pub_lay1, lay_bg1, 294912 ]
			memcpy[ pub_lay2, lay_bg2, 294912 ]
			memcpy[ pub_lay3, lay_bg3, 294912 ]
			memcpy[ pub_layw, lay_sw,  229376 ]
			memcpy[ pub_lays, lay_ss,  229376 ]
		pub_layered = lay_frame
		pub_b3hi    = frame_b3
		memcpy[ pub_framebuf, ppu.framebuf, 229376 ]
		memcpy[ pub_vram,  ppu.vram,  65536 ]
		memcpy[ pub_cgram, ppu.cgram, 512 ]
		memcpy[ pub_m7a, line_m7a, 448 ]
		memcpy[ pub_m7b, line_m7b, 448 ]
		memcpy[ pub_m7c, line_m7c, 448 ]
		memcpy[ pub_m7d, line_m7d, 448 ]
		memcpy[ pub_mode, line_mode, 224 ]
		memcpy[ pub_wh0, line_wh0, 224 ]
		memcpy[ pub_wh1, line_wh1, 224 ]
		memcpy[ pub_wh2, line_wh2, 224 ]
		memcpy[ pub_wh3, line_wh3, 224 ]
		memcpy[ pub_wobjsel, line_wobjsel, 224 ]
		memcpy[ pub_wobjlog, line_wobjlog, 224 ]
		memcpy[ pub_cgwsel, line_cgwsel, 224 ]
		memcpy[ pub_cgadsub, line_cgadsub, 224 ]
		memcpy[ pub_coldata, line_coldata, 448 ]
		pub_inidisp = ppu.inidisp
		pub_m7sel   = ppu.m7sel
		pub_m7hofs  = ppu.m7hofs
		pub_m7vofs  = ppu.m7vofs
		pub_m7x     = frame_m7x
		pub_m7y     = frame_m7y
		pub_valid   = true
		# --- mode-7 glide measurement (hardware-specific): rep-line origin
		# delta mapped to SCREEN space through the inverse matrix; rotation
		# frames guard to zero (a rect glide can't represent rotation) ---
		g_hc : i32 [ sx13[ i32[ pub_m7x ] ] ]
		g_vc : i32 [ sx13[ i32[ pub_m7y ] ] ]
		g_ho : i32 [ sx13[ i32[ pub_m7hofs ] ] ]
		g_vo : i32 [ sx13[ i32[ pub_m7vofs ] ] ]
		g_ch : i32 [ m7_clip[ g_ho - g_hc ] ]
		g_cv : i32 [ m7_clip[ g_vo - g_vc ] ]
		g_a : i32 [ i32[ pub_m7a[ 180 ] ] ]
		g_b : i32 [ i32[ pub_m7b[ 180 ] ] ]
		g_c : i32 [ i32[ pub_m7c[ 180 ] ] ]
		g_d : i32 [ i32[ pub_m7d[ 180 ] ] ]
		g_ox : f64 [ f64[ ((g_a * g_ch) & (~63)) + ((g_b * g_cv) & (~63)) + ((g_b * 180) & (~63)) + (g_hc << 8) ] / 256.0 ]
		g_oy : f64 [ f64[ ((g_c * g_ch) & (~63)) + ((g_d * g_cv) & (~63)) + ((g_d * 180) & (~63)) + (g_vc << 8) ] / 256.0 ]
		g_af : f64 [ f64[ g_a ] / 256.0 ]
		g_bf : f64 [ f64[ g_b ] / 256.0 ]
		g_cf : f64 [ f64[ g_c ] / 256.0 ]
		g_df : f64 [ f64[ g_d ] / 256.0 ]
		g_dox : f64 [ g_ox - m7g_prevx ]
		g_doy : f64 [ g_oy - m7g_prevy ]
		g_rot : f64 [ (g_af - m7g_preva) * (g_af - m7g_preva) + (g_cf - m7g_prevc) * (g_cf - m7g_prevc) ]
		m7g_prevx = g_ox
		m7g_prevy = g_oy
		m7g_preva = g_af
		m7g_prevc = g_cf
		g_det : f64 [ g_af * g_df - g_bf * g_cf ]
		g_sx : f64 [ 0.0 ]
		g_sy : f64 [ 0.0 ]
		if [ g_rot < 0.0004 && (g_det > 0.01 || g_det < -0.01) ]
			g_sx = (0.0 - (g_df * g_dox - g_bf * g_doy)) / g_det
			g_sy = (0.0 - (g_af * g_doy - g_cf * g_dox)) / g_det
		if [ g_sx > 64.0 || g_sx < -64.0 ] g_sx = 0.0
		if [ g_sy > 64.0 || g_sy < -64.0 ] g_sy = 0.0
		if [ getenv[ 'ASNES_GLIDE' ] && (dbg_frames % 15) == 0 ]
			printf[ "GLIDE f%u sx=%.2f sy=%.2f rot=%.6f det=%.3f dox=%.1f doy=%.1f\n",
				dbg_frames, g_sx, g_sy, g_rot, g_det, g_dox, g_doy ]
		# phase-locked clock + cadence window (knes/rgen pattern, local copy)
		g_now : i64 [ wall_ms[] * 1000 ]
		if [ m7g_model == 0 ] m7g_model = g_now
		el
			m7g_model += 16639
			g_err : i64 [ g_now - m7g_model ]
			if [ g_err > 8000 || g_err < -8000 ] m7g_model = g_now
			el m7g_model += g_err / 16
		m7g_gap += 1
		if [ g_sx > 0.25 || g_sx < -0.25 || g_sy > 0.25 || g_sy < -0.25 ]
			m7g_dx = f32[ g_sx ]
			m7g_dy = f32[ g_sy ]
			m7g_t = m7g_model
			g_gp : i32 [ (m7g_gap > 3) ? 3 : m7g_gap ]
			m7g_p = i64[ g_gp ] * 16639
			m7g_gap = 0
		el [ m7g_gap > 4 ]
			m7g_dx = 0.0
			m7g_dy = 0.0
		# per-BG cadence publish (same clock): a nonzero delta opens a replay
		# window sized by its own cadence; still frames retire the channel
		for [ gb: i32 0, gb < 3, gb += 1 ]
			bgg_gap[gb] += 1
			if [ rdh[gb] != 0 || rdv[gb] != 0 ]
				bgg_dx[gb] = f32[ rdh[gb] ]
				bgg_dy[gb] = f32[ rdv[gb] ]
				bgg_t[gb]  = m7g_model
				g_gp2 : i32 [ bgg_gap[gb] ]
				if [ g_gp2 > 4 ] g_gp2 = 4
				bgg_p[gb]  = i64[ g_gp2 ] * 16639
				bgg_gap[gb] = 0
			el [ bgg_gap[gb] > 4 ]
				bgg_dx[gb] = 0.0
				bgg_dy[gb] = 0.0
		pub_lock.unlock[]

	func emu_entry [] -> none
		emu_running = true
		while [ !emu_stop ]
			if [ context_req ]
				context_req = false
				ctx : string context_text[]
				ctx.hold[]
				context_out = ctx
				context_seq += 1
			if [ paused ]
				usleep[ 15000 ]
			el
				emu_tick[]
		emu_running = false

	func ctx_hex2 [ v: u32 ] -> string
		hx : string [ '0123456789ABCDEF' ]
		return '{hx.mid[ i32[ (v >> 4) & 15 ], 1 ]}{hx.mid[ i32[ v & 15 ], 1 ]}'

	func ctx_hex4 [ v: u32 ] -> string
		return '{ctx_hex2[ (v >> 8) & 255 ]}{ctx_hex2[ v & 255 ]}'

	# machine-state dump published when the emulation pauses — the host feeds
	# this to the AI console so it can reason about the live machine
	func context_text [] -> string
		if [ !cpu ] return 'asnes paused: no machine state (rom not loaded)'
		s : string 'SNES emulator paused ({rom}) — machine context\n'
		s = s + 'frame {dbg_frames}, cpu cycles {cpu_cycles}\n'
		s = s + '65816: PC=${ctx_hex2[ u32[ cpu.pbr ] ]}:{ctx_hex4[ u32[ cpu.pc ] ]} A=${ctx_hex2[ u32[ cpu.b ] ]}{ctx_hex2[ u32[ cpu.a ] ]} X=${ctx_hex2[ u32[ cpu.xh ] ]}{ctx_hex2[ u32[ cpu.x ] ]} Y=${ctx_hex2[ u32[ cpu.yh ] ]}{ctx_hex2[ u32[ cpu.y ] ]}\n'
		s = s + '       SP=${ctx_hex4[ u32[ cpu.sp ] ]} DP=${ctx_hex4[ u32[ cpu.dp ] ]} DBR=${ctx_hex2[ u32[ cpu.dbr ] ]} P=${ctx_hex2[ u32[ cpu.p ] ]} E={(cpu.e) ? 1 : 0} (NVMXDIZC)\n'
		s = s + 'PPU: bgmode=${ctx_hex2[ u32[ ppu.bgmode ] ]} inidisp=${ctx_hex2[ u32[ ppu.inidisp ] ]} tm=${ctx_hex2[ u32[ ppu.tm ] ]} ts=${ctx_hex2[ u32[ ppu.ts ] ]}\n'
		s = s + 'code bytes at PC: '
		for [ bi: u32 0, bi < 16, bi += 1 ]
			bv : u16 [ cpu_bank_r[ u32[ cpu.pbr ], u16[ (u32[ cpu.pc ] + bi) & 0xFFFF ] ] ]
			s = s + ctx_hex2[ u32[ bv & 0xFF ] ] + ' '
		s = s + '\n'
		return s

	# reload/exit teardown: stop the emulation thread DETERMINISTICALLY (before
	# the module's code unloads — dealloc order can't be relied on for threads).
	# hot-reload flash save: the host sets SILVER_RELOAD_SAVE around the
	# reload-path destroy only — the fresh instance restores this state so a
	# recompile drops you back exactly where you were.
	public func on_unload []
		if [ emu_started ]
			emu_stop = true
			while [ emu_running ]
				usleep[ 2000 ]
			if [ getenv[ 'SILVER_RELOAD_SAVE' ] && cpu ]
				save_state[ '/tmp/asnes_flash.state' ]
				puts 'asnes flash: state saved for reload'

	func dealloc []
		if [ emu_started ]
			emu_stop = true
			while [ emu_running ]
				usleep[ 2000 ]
		# cpu/spc are Au class objects (cpu_state[] / spc_state[]) — released by the
		# framework's drop_members, NOT free() (free() on an Au object = invalid pointer).
		# Only the raw calloc'd buffers below are freed manually.
		if [ cpu ]
			free[ cpu.memory ]
		if [ spc ]
			if [ spc.audio_buffer ] free[ spc.audio_buffer ]
		if [ spc_boot_rom ] free[ spc_boot_rom ]

	# --- SPC700 step ---

	# advance the three SPC700 timers by `cyc` SPC cycles. timer0/1 prescale at
	# 128 cycles (8kHz), timer2 at 16 cycles (64kHz); each output is a 4-bit
	# counter the engine polls at $FD-$FF to sequence music.
	func spc_tick_timers [ cyc: i32 ]
		spc.tcyc += cyc
		while [ spc.tcyc >= 128 ]
			spc.tcyc -= 128
			if [ spc.timer_on & 0x01 ]
				spc.timer_stage[0] += 1
				t0 : i32 [ (spc.timer_target[0] == 0) ? 256 : spc.timer_target[0] ]
				if [ spc.timer_stage[0] >= t0 ]
					spc.timer_stage[0] = 0
					spc.timer_count[0] = (spc.timer_count[0] + 1) & 0x0F
			if [ spc.timer_on & 0x02 ]
				spc.timer_stage[1] += 1
				t1 : i32 [ (spc.timer_target[1] == 0) ? 256 : spc.timer_target[1] ]
				if [ spc.timer_stage[1] >= t1 ]
					spc.timer_stage[1] = 0
					spc.timer_count[1] = (spc.timer_count[1] + 1) & 0x0F
			if [ spc.timer_on & 0x04 ]
				spc.timer_stage[2] += 8
				t2 : i32 [ (spc.timer_target[2] == 0) ? 256 : spc.timer_target[2] ]
				while [ spc.timer_stage[2] >= t2 ]
					spc.timer_stage[2] -= t2
					spc.timer_count[2] = (spc.timer_count[2] + 1) & 0x0F

	# taken conditional branch: apply the relative offset and add the +2 cycle penalty
	func spc_take [ off: i32 ]
		spc.pc = u16[ i32[spc.pc] + off ]
		spc.op_cyc += 2
		spc_tick_timers[ 2 ]                  # the +2 penalty cycles also advance the timers (reference hardware idles step timers); spc_step only ticked the base op_cyc

	func spc_step [] -> i32
		spc_nops += 1
		spct_pc : u16 [ spc.pc ]
		pos0 : i64 [ spc.pos ]                      # opcode-start SPC clock; accesses tick spc.pos forward from here
		opcode : u8 [ spc_rb[] ]
		spc.op_cyc = i32[ spc_cyc[ opcode ] ]      # base SMP cycles; branch handlers add +2 when taken
		spc_tick_timers[ spc.op_cyc ]
		switch [ opcode ]
			case 0x8F  # MOV dp, #imm  (encoding: 8F imm dp — immediate byte first)
				imm : u8 [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, imm ]

			case 0xCD  # MOV X, #imm
				spc.x   = spc_rb[]
				spc_nz[ spc.x ]

			case 0xBD  # MOV SP, X
				spc.sp = spc.x

			case 0x9D  # MOV X, SP
				spc.x   = spc.sp
				spc_nz[ spc.x ]

			case 0x7D  # MOV A, X
				spc.a   = spc.x
				spc_nz[ spc.a ]

			case 0x5D  # MOV X, A
				spc.x   = spc.a
				spc_nz[ spc.x ]

			case 0xDD  # MOV A, Y
				spc.a   = spc.y
				spc_nz[ spc.a ]

			case 0xFD  # MOV Y, A
				spc.y   = spc.a
				spc_nz[ spc.y ]

			case 0xE4  # MOV A, dp
				dp : u16 [ spc_dp[] ]
				spc.a   = spc_r[dp]
				spc_nz[ spc.a ]

			case 0xF4  # MOV A, dp+X
				dp : u16 [ spc_dp[] ]
				spc.a   = spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				spc_nz[ spc.a ]

			case 0xE5  # MOV A, abs
				addr    : u16 [ spc_rw[] ]
				spc.a   = spc_r[addr]
				spc_nz[ spc.a ]

			case 0xF5  # MOV A, abs+X
				addr    : u16 [ spc_rw[] ]
				spc.a   = spc_r[ (addr + spc.x) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0xF6  # MOV A, abs+Y
				addr    : u16 [ spc_rw[] ]
				spc.a   = spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0xE6  # MOV A, (X)
				spc.a   = spc_r[spc.x]
				spc_nz[ spc.a ]

			case 0xBF  # MOV A, (X)+
				spc.a   = spc_r[spc.x]
				spc.x  += 1
				spc_nz[ spc.a ]

			case 0xE7  # MOV A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr     : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr    : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				spc.a   = spc_r[addr]
				spc_nz[ spc.a ]

			case 0xF7  # MOV A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr    : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				spc.a   = spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0xE8  # MOV A, #imm
				spc.a   = spc_rb[]
				spc_nz[ spc.a ]

			case 0xF8  # MOV X, dp
				dp : u16 [ spc_dp[] ]
				spc.x   = spc_r[dp]
				spc_nz[ spc.x ]

			case 0xF9  # MOV X, dp+Y
				dp : u16 [ spc_dp[] ]
				spc.x   = spc_r[ ((dp & 0xFF00) | ((dp + spc.y) & 0xFF)) ]
				spc_nz[ spc.x ]

			case 0xE9  # MOV X, abs
				addr    : u16 [ spc_rw[] ]
				spc.x   = spc_r[addr]
				spc_nz[ spc.x ]

			case 0x8D  # MOV Y, #imm
				spc.y   = spc_rb[]
				spc_nz[ spc.y ]

			case 0xEB  # MOV Y, dp
				dp : u16 [ spc_dp[] ]
				spc.y   = spc_r[dp]
				spc_nz[ spc.y ]

			case 0xFB  # MOV Y, dp+X
				dp : u16 [ spc_dp[] ]
				spc.y   = spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				spc_nz[ spc.y ]

			case 0xEC  # MOV Y, abs
				addr    : u16 [ spc_rw[] ]
				spc.y   = spc_r[addr]
				spc_nz[ spc.y ]

			case 0xC4  # MOV dp, A
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc.a ]

			case 0xD4  # MOV dp+X, A
				dp : u16 [ spc_dp[] ]
				spc_w[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)), spc.a ]

			case 0xC5  # MOV abs, A
				addr : u16 [ spc_rw[] ]
				spc_w[ addr, spc.a ]

			case 0xD5  # MOV abs+X, A
				addr : u16 [ spc_rw[] ]
				spc_w[ (addr + spc.x) & 0xFFFF, spc.a ]

			case 0xD6  # MOV abs+Y, A
				addr : u16 [ spc_rw[] ]
				spc_w[ (addr + spc.y) & 0xFFFF, spc.a ]

			case 0xC6  # MOV (X), A
				spc_w[ spc.x, spc.a ]

			case 0xAF  # MOV (X)+, A
				spc_w[ spc.x, spc.a ]
				spc.x += 1

			case 0xC7  # MOV [dp+X], A
				dp : u16 [ spc_dp[] ]
				ptr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				spc_w[ addr, spc.a ]

			case 0xD7  # MOV [dp]+Y, A
				dp : u16 [ spc_dp[] ]
				addr : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				spc_w[ (addr + spc.y) & 0xFFFF, spc.a ]

			case 0xC9  # MOV abs, X
				addr : u16 [ spc_rw[] ]
				spc_w[ addr, spc.x ]

			case 0xD9  # MOV dp+Y, X
				dp : u16 [ spc_dp[] ]
				spc_w[ ((dp & 0xFF00) | ((dp + spc.y) & 0xFF)), spc.x ]

			case 0xDB  # MOV dp+X, Y
				dp : u16 [ spc_dp[] ]
				spc_w[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)), spc.y ]

			case 0xCB  # MOV dp, Y
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc.y ]

			case 0xD8  # MOV dp, X
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc.x ]

			case 0xCC  # MOV abs, Y
				addr : u16 [ spc_rw[] ]
				spc_w[ addr, spc.y ]

			case 0xFA  # MOV dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				spc_w[ dst, spc_r[src] ]

			case 0x84  # ADC A, dp
				dp : u16 [ spc_dp[] ]
				val8  : u8  [ spc_r[dp] ]
				result : u16 [ u16[spc.a] + u16[val8] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0x94  # ADC A, dp+X
				dp : u16 [ spc_dp[] ]
				val8  : u8  [ spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ] ]
				result : u16 [ u16[spc.a] + u16[val8] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0x85  # ADC A, abs
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] + u16[val8] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0x95  # ADC A, abs+X
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[ (addr + spc.x) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] + u16[val8] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0x96  # ADC A, abs+Y
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] + u16[val8] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0x86  # ADC A, (X)
				val8  : u8  [ spc_r[spc.x] ]
				result : u16 [ u16[spc.a] + u16[val8] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0x97  # ADC A, [dp]+Y   (indirect, post-indexed by Y)
				dp : u16 [ spc_dp[] ]
				addr   : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				val8  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] + u16[val8] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0x87  # ADC A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr    : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr   : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				val8  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] + u16[val8] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0x88  # ADC A, #imm
				val8  : u8  [ spc_rb[] ]
				result : u16 [ u16[spc.a] + u16[val8] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0x99  # ADC (X), (Y)
				x_val  : u8  [ spc_r[spc.x] ]
				y_val  : u8  [ spc_r[spc.y] ]
				result : u16 [ u16[x_val] + u16[y_val] + (spc.psw & 0x01) ]
				spc_adc[ x_val, y_val, result ]
				spc_w[ spc.x, result & 0xFF ]

			case 0x89  # ADC dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				src_val : u8  [ spc_r[src] ]
				dst_val : u8  [ spc_r[dst] ]
				result  : u16 [ u16[dst_val] + u16[src_val] + (spc.psw & 0x01) ]
				spc_adc[ dst_val, src_val, result ]
				spc_w[ dst, result & 0xFF ]

			case 0x98  # ADC dp, #imm  (imm first)
				imm     : u8  [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				dp_val  : u8  [ spc_r[dp] ]
				result  : u16 [ u16[dp_val] + u16[imm] + (spc.psw & 0x01) ]
				spc_adc[ dp_val, imm, result ]
				spc_w[ dp, result & 0xFF ]

			case 0xA4  # SBC A, dp
				dp : u16 [ spc_dp[] ]
				val8  : u8  [ spc_r[dp] ]
				result : u16 [ u16[spc.a] - u16[val8] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0xB4  # SBC A, dp+X
				dp : u16 [ spc_dp[] ]
				val8  : u8  [ spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ] ]
				result : u16 [ u16[spc.a] - u16[val8] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0xA5  # SBC A, abs
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] - u16[val8] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0xB5  # SBC A, abs+X
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[ (addr + spc.x) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[val8] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0xB6  # SBC A, abs+Y
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[val8] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0xA6  # SBC A, (X)
				val8  : u8  [ spc_r[spc.x] ]
				result : u16 [ u16[spc.a] - u16[val8] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0xB7  # SBC A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr   : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				val8  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[val8] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0xA7  # SBC A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr    : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr   : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				val8  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] - u16[val8] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0xA8  # SBC A, #imm
				val8  : u8  [ spc_rb[] ]
				result : u16 [ u16[spc.a] - u16[val8] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, val8, result ]
				spc.a   = result & 0xFF

			case 0xB9  # SBC (X), (Y)
				x_val  : u8  [ spc_r[spc.x] ]
				y_val  : u8  [ spc_r[spc.y] ]
				result : u16 [ u16[x_val] - u16[y_val] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ x_val, y_val, result ]
				spc_w[ spc.x, result & 0xFF ]

			case 0xA9  # SBC dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				src_val : u8  [ spc_r[src] ]
				dst_val : u8  [ spc_r[dst] ]
				result  : u16 [ u16[dst_val] - u16[src_val] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ dst_val, src_val, result ]
				spc_w[ dst, result & 0xFF ]

			case 0xB8  # SBC dp, #imm  (imm first)
				imm     : u8  [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				dp_val  : u8  [ spc_r[dp] ]
				result  : u16 [ u16[dp_val] - u16[imm] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ dp_val, imm, result ]
				spc_w[ dp, result & 0xFF ]

			case 0x64  # CMP A, dp
				dp : u16 [ spc_dp[] ]
				val8  : u8  [ spc_r[dp] ]
				result : u16 [ u16[spc.a] - u16[val8] ]
				spc_cmp[ result ]

			case 0x74  # CMP A, dp+X
				dp : u16 [ spc_dp[] ]
				val8  : u8  [ spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ] ]
				result : u16 [ u16[spc.a] - u16[val8] ]
				spc_cmp[ result ]

			case 0x65  # CMP A, abs
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] - u16[val8] ]
				spc_cmp[ result ]

			case 0x75  # CMP A, abs+X
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[ (addr + spc.x) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[val8] ]
				spc_cmp[ result ]

			case 0x76  # CMP A, abs+Y
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[val8] ]
				spc_cmp[ result ]

			case 0x66  # CMP A, (X)
				val8  : u8  [ spc_r[spc.x] ]
				result : u16 [ u16[spc.a] - u16[val8] ]
				spc_cmp[ result ]

			case 0x77  # CMP A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr   : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				val8  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[val8] ]
				spc_cmp[ result ]

			case 0x67  # CMP A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr    : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr   : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				val8  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] - u16[val8] ]
				spc_cmp[ result ]

			case 0x68  # CMP A, #imm
				val8  : u8  [ spc_rb[] ]
				result : u16 [ u16[spc.a] - u16[val8] ]
				spc_cmp[ result ]

			case 0x79  # CMP (X), (Y)
				x_val  : u8  [ spc_r[spc.x] ]
				y_val  : u8  [ spc_r[spc.y] ]
				result : u16 [ u16[x_val] - u16[y_val] ]
				spc_cmp[ result ]

			case 0x69  # CMP dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				src_val : u8  [ spc_r[src] ]
				dst_val : u8  [ spc_r[dst] ]
				result  : u16 [ u16[dst_val] - u16[src_val] ]
				spc_cmp[ result ]

			case 0x78  # CMP dp, #imm  (imm first)
				imm     : u8  [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				dp_val  : u8  [ spc_r[dp] ]
				result  : u16 [ u16[dp_val] - u16[imm] ]
				spc_cmp[ result ]

			case 0xC8  # CMP X, #imm
				val8  : u8  [ spc_rb[] ]
				result : u16 [ u16[spc.x] - u16[val8] ]
				spc_cmp[ result ]

			case 0x3E  # CMP X, dp
				dp : u16 [ spc_dp[] ]
				val8  : u8  [ spc_r[dp] ]
				result : u16 [ u16[spc.x] - u16[val8] ]
				spc_cmp[ result ]

			case 0x1E  # CMP X, abs
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.x] - u16[val8] ]
				spc_cmp[ result ]

			case 0xAD  # CMP Y, #imm
				val8  : u8  [ spc_rb[] ]
				result : u16 [ u16[spc.y] - u16[val8] ]
				spc_cmp[ result ]

			case 0x7E  # CMP Y, dp
				dp : u16 [ spc_dp[] ]
				val8  : u8  [ spc_r[dp] ]
				result : u16 [ u16[spc.y] - u16[val8] ]
				spc_cmp[ result ]

			case 0x5E  # CMP Y, abs
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.y] - u16[val8] ]
				spc_cmp[ result ]

			case 0x24  # AND A, dp
				dp : u16 [ spc_dp[] ]
				spc.a &= spc_r[dp]
				spc_nz[ spc.a ]

			case 0x34  # AND A, dp+X
				dp : u16 [ spc_dp[] ]
				spc.a &= spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				spc_nz[ spc.a ]

			case 0x25  # AND A, abs
				addr  : u16 [ spc_rw[] ]
				spc.a &= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x35  # AND A, abs+X
				addr  : u16 [ spc_rw[] ]
				spc.a &= spc_r[ (addr + spc.x) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x36  # AND A, abs+Y
				addr  : u16 [ spc_rw[] ]
				spc.a &= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x26  # AND A, (X)
				spc.a &= spc_r[spc.x]
				spc_nz[ spc.a ]

			case 0x37  # AND A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				spc.a &= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x27  # AND A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr   : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr  : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				spc.a &= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x28  # AND A, #imm
				spc.a &= spc_rb[]
				spc_nz[ spc.a ]

			case 0x39  # AND (X), (Y)
				result : u8 [ spc_r[spc.x] & spc_r[spc.y] ]
				spc_w[ spc.x, result ]
				spc_nz[ result ]

			case 0x29  # AND dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dst] & spc_r[src] ]
				spc_w[ dst, result ]
				spc_nz[ result ]

			case 0x38  # AND dp, #imm  (imm first)
				imm    : u8 [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dp] & imm ]
				spc_w[ dp, result ]
				spc_nz[ result ]

			case 0x04  # OR A, dp
				dp : u16 [ spc_dp[] ]
				spc.a |= spc_r[dp]
				spc_nz[ spc.a ]

			case 0x14  # OR A, dp+X
				dp : u16 [ spc_dp[] ]
				spc.a |= spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				spc_nz[ spc.a ]

			case 0x05  # OR A, abs
				addr  : u16 [ spc_rw[] ]
				spc.a |= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x15  # OR A, abs+X
				addr  : u16 [ spc_rw[] ]
				spc.a |= spc_r[ (addr + spc.x) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x16  # OR A, abs+Y
				addr  : u16 [ spc_rw[] ]
				spc.a |= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x06  # OR A, (X)
				spc.a |= spc_r[spc.x]
				spc_nz[ spc.a ]

			case 0x17  # OR A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				spc.a |= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x07  # OR A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr   : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr  : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				spc.a |= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x08  # OR A, #imm
				spc.a |= spc_rb[]
				spc_nz[ spc.a ]

			case 0x19  # OR (X), (Y)
				result : u8 [ spc_r[spc.x] | spc_r[spc.y] ]
				spc_w[ spc.x, result ]
				spc_nz[ result ]

			case 0x09  # OR dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dst] | spc_r[src] ]
				spc_w[ dst, result ]
				spc_nz[ result ]

			case 0x18  # OR dp, #imm  (imm first)
				imm    : u8 [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dp] | imm ]
				spc_w[ dp, result ]
				spc_nz[ result ]

			case 0x44  # EOR A, dp
				dp : u16 [ spc_dp[] ]
				spc.a ^= spc_r[dp]
				spc_nz[ spc.a ]

			case 0x54  # EOR A, dp+X
				dp : u16 [ spc_dp[] ]
				spc.a ^= spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				spc_nz[ spc.a ]

			case 0x45  # EOR A, abs
				addr  : u16 [ spc_rw[] ]
				spc.a ^= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x55  # EOR A, abs+X
				addr  : u16 [ spc_rw[] ]
				spc.a ^= spc_r[ (addr + spc.x) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x56  # EOR A, abs+Y
				addr  : u16 [ spc_rw[] ]
				spc.a ^= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x46  # EOR A, (X)
				spc.a ^= spc_r[spc.x]
				spc_nz[ spc.a ]

			case 0x57  # EOR A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				spc.a ^= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x47  # EOR A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr   : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr  : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				spc.a ^= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x48  # EOR A, #imm
				spc.a ^= spc_rb[]
				spc_nz[ spc.a ]

			case 0x59  # EOR (X), (Y)
				result : u8 [ spc_r[spc.x] ^ spc_r[spc.y] ]
				spc_w[ spc.x, result ]
				spc_nz[ result ]

			case 0x49  # EOR dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dst] ^ spc_r[src] ]
				spc_w[ dst, result ]
				spc_nz[ result ]

			case 0x58  # EOR dp, #imm  (imm first)
				imm    : u8 [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dp] ^ imm ]
				spc_w[ dp, result ]
				spc_nz[ result ]

			case 0xBC  # INC A
				spc.a  += 1
				spc_nz[ spc.a ]

			case 0x3D  # INC X
				spc.x  += 1
				spc_nz[ spc.x ]

			case 0xFC  # INC Y
				spc.y  += 1
				spc_nz[ spc.y ]

			case 0xAB  # INC dp
				dp : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dp] + 1 ]
				spc_w[ dp, result ]
				spc_nz[ result ]

			case 0xBB  # INC dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				result : u8 [ spc_r[xaddr] + 1 ]
				spc_w[ xaddr, result ]
				spc_nz[ result ]

			case 0xAC  # INC abs
				addr   : u16 [ spc_rw[] ]
				result : u8  [ spc_r[addr] + 1 ]
				spc_w[ addr, result ]
				spc_nz[ result ]

			case 0x9C  # DEC A
				spc.a  -= 1
				spc_nz[ spc.a ]

			case 0x1D  # DEC X
				spc.x  -= 1
				spc_nz[ spc.x ]

			case 0xDC  # DEC Y
				spc.y  -= 1
				spc_nz[ spc.y ]

			case 0x8B  # DEC dp
				dp : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dp] - 1 ]
				spc_w[ dp, result ]
				spc_nz[ result ]

			case 0x9B  # DEC dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				result : u8 [ spc_r[xaddr] - 1 ]
				spc_w[ xaddr, result ]
				spc_nz[ result ]

			case 0x8C  # DEC abs
				addr   : u16 [ spc_rw[] ]
				result : u8  [ spc_r[addr] - 1 ]
				spc_w[ addr, result ]
				spc_nz[ result ]

			case 0x1C  # ASL A
				carry  : u8 [ (spc.a & 0x80) ? 0x01 : 0 ]
				spc.a <<= 1
				spc_nzc[ spc.a, carry ]

			case 0x0B  # ASL dp
				dp : u16 [ spc_dp[] ]
				val8  : u8 [ spc_r[dp] ]
				carry  : u8 [ (val8 & 0x80) ? 0x01 : 0 ]
				val8 <<= 1
				spc_w[ dp, val8 ]
				spc_nzc[ val8, carry ]

			case 0x1B  # ASL dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				val8  : u8 [ spc_r[xaddr] ]
				carry  : u8 [ (val8 & 0x80) ? 0x01 : 0 ]
				val8 <<= 1
				spc_w[ xaddr, val8 ]
				spc_nzc[ val8, carry ]

			case 0x0C  # ASL abs
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[addr] ]
				carry  : u8  [ (val8 & 0x80) ? 0x01 : 0 ]
				val8 <<= 1
				spc_w[ addr, val8 ]
				spc_nzc[ val8, carry ]

			case 0x5C  # LSR A
				carry  : u8 [ spc.a & 0x01 ]
				spc.a >>= 1
				spc.psw = (spc.psw & ~0x83) | carry | ((spc.a == 0) ? 0x02 : 0)

			case 0x4B  # LSR dp
				dp : u16 [ spc_dp[] ]
				val8  : u8 [ spc_r[dp] ]
				carry  : u8 [ val8 & 0x01 ]
				val8 >>= 1
				spc_w[ dp, val8 ]
				spc.psw = (spc.psw & ~0x83) | carry | ((val8 == 0) ? 0x02 : 0)

			case 0x5B  # LSR dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				val8  : u8 [ spc_r[xaddr] ]
				carry  : u8 [ val8 & 0x01 ]
				val8 >>= 1
				spc_w[ xaddr, val8 ]
				spc.psw = (spc.psw & ~0x83) | carry | ((val8 == 0) ? 0x02 : 0)

			case 0x4C  # LSR abs
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[addr] ]
				carry  : u8  [ val8 & 0x01 ]
				val8 >>= 1
				spc_w[ addr, val8 ]
				spc.psw = (spc.psw & ~0x83) | carry | ((val8 == 0) ? 0x02 : 0)

			case 0x3C  # ROL A
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ (spc.a & 0x80) ? 0x01 : 0 ]
				spc.a   = (spc.a << 1) | old_c
				spc_nzc[ spc.a, new_c ]

			case 0x2B  # ROL dp
				dp : u16 [ spc_dp[] ]
				val8  : u8 [ spc_r[dp] ]
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ (val8 & 0x80) ? 0x01 : 0 ]
				val8   = (val8 << 1) | old_c
				spc_w[ dp, val8 ]
				spc_nzc[ val8, new_c ]

			case 0x3B  # ROL dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				val8  : u8 [ spc_r[xaddr] ]
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ (val8 & 0x80) ? 0x01 : 0 ]
				val8   = (val8 << 1) | old_c
				spc_w[ xaddr, val8 ]
				spc_nzc[ val8, new_c ]

			case 0x2C  # ROL abs
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[addr] ]
				old_c  : u8  [ spc.psw & 0x01 ]
				new_c  : u8  [ (val8 & 0x80) ? 0x01 : 0 ]
				val8   = (val8 << 1) | old_c
				spc_w[ addr, val8 ]
				spc_nzc[ val8, new_c ]

			case 0x7C  # ROR A
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ spc.a & 0x01 ]
				spc.a   = (spc.a >> 1) | (old_c << 7)
				spc_nzc[ spc.a, new_c ]

			case 0x6B  # ROR dp
				dp : u16 [ spc_dp[] ]
				val8  : u8 [ spc_r[dp] ]
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ val8 & 0x01 ]
				val8   = (val8 >> 1) | (old_c << 7)
				spc_w[ dp, val8 ]
				spc_nzc[ val8, new_c ]

			case 0x7B  # ROR dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				val8  : u8 [ spc_r[xaddr] ]
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ val8 & 0x01 ]
				val8   = (val8 >> 1) | (old_c << 7)
				spc_w[ xaddr, val8 ]
				spc_nzc[ val8, new_c ]

			case 0x6C  # ROR abs
				addr   : u16 [ spc_rw[] ]
				val8  : u8  [ spc_r[addr] ]
				old_c  : u8  [ spc.psw & 0x01 ]
				new_c  : u8  [ val8 & 0x01 ]
				val8   = (val8 >> 1) | (old_c << 7)
				spc_w[ addr, val8 ]
				spc_nzc[ val8, new_c ]

			case 0x10  # BPL rel
				off : i8 [ spc_rb[] ]
				if [ !(spc.psw & 0x80) ] spc_take[ i32[off] ]

			case 0x30  # BMI rel
				off : i8 [ spc_rb[] ]
				if [ spc.psw & 0x80 ] spc_take[ i32[off] ]

			case 0x50  # BVC rel
				off : i8 [ spc_rb[] ]
				if [ !(spc.psw & 0x40) ] spc_take[ i32[off] ]

			case 0x70  # BVS rel
				off : i8 [ spc_rb[] ]
				if [ spc.psw & 0x40 ] spc_take[ i32[off] ]

			case 0x90  # BCC rel
				off : i8 [ spc_rb[] ]
				if [ !(spc.psw & 0x01) ] spc_take[ i32[off] ]

			case 0xB0  # BCS rel
				off : i8 [ spc_rb[] ]
				if [ spc.psw & 0x01 ] spc_take[ i32[off] ]

			case 0xD0  # BNE rel
				off : i8 [ spc_rb[] ]
				if [ !(spc.psw & 0x02) ] spc_take[ i32[off] ]

			case 0xF0  # BEQ rel
				off : i8 [ spc_rb[] ]
				if [ spc.psw & 0x02 ] spc_take[ i32[off] ]

			case 0xFE  # DBNZ Y, rel
				off : i8 [ spc_rb[] ]
				spc.y -= 1
				if [ spc.y != 0 ] spc_take[ i32[off] ]

			case 0x6E  # DBNZ dp, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				v   : u8 [ spc_r[dp] - 1 ]
				spc_w[ dp, v ]
				if [ v != 0 ] spc_take[ i32[off] ]

			case 0xDE  # CBNE dp+X, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				v   : u8 [ spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ] ]
				if [ spc.a != v ] spc_take[ i32[off] ]

			case 0x2E  # CBNE dp, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				v   : u8 [ spc_r[dp] ]
				if [ spc.a != v ] spc_take[ i32[off] ]

			case 0x0E  # TSET1 abs
				addr : u16 [ spc_rw[] ]
				data : u8  [ spc_r[addr] ]
				diff : u8  [ (u16[spc.a] - u16[data]) & 0xFF ]
				spc.psw = (spc.psw & ~0x82) | ((diff == 0) ? 0x02 : 0) | (diff & 0x80)
				spc_w[ addr, data | spc.a ]

			case 0x4E  # TCLR1 abs
				addr : u16 [ spc_rw[] ]
				data : u8  [ spc_r[addr] ]
				diff : u8  [ (u16[spc.a] - u16[data]) & 0xFF ]
				spc.psw = (spc.psw & ~0x82) | ((diff == 0) ? 0x02 : 0) | (diff & 0x80)
				spc_w[ addr, data & ~spc.a ]

			case 0x2F  # BRA rel
				off    : i8 [ spc_rb[] ]
				spc.pc  = u16[i32[spc.pc] + i32[off]]

			case 0x0A  # OR1 C, mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ spc_r[maddr] & (1 << bit) ] spc.psw |= 0x01

			case 0x2A  # OR1 C, /mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ !(spc_r[maddr] & (1 << bit)) ] spc.psw |= 0x01

			case 0x4A  # AND1 C, mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ !(spc_r[maddr] & (1 << bit)) ] spc.psw &= ~0x01

			case 0x6A  # AND1 C, /mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ spc_r[maddr] & (1 << bit) ] spc.psw &= ~0x01

			case 0x8A  # EOR1 C, mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ spc_r[maddr] & (1 << bit) ] spc.psw ^= 0x01

			case 0xAA  # MOV1 C, mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ spc_r[maddr] & (1 << bit) ]
					spc.psw |= 0x01
				el
					spc.psw &= ~0x01

			case 0xCA  # MOV1 mem.bit, C
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				r      : u8  [ spc_r[maddr] ]
				if [ spc.psw & 0x01 ]
					spc_w[ maddr, r | u8[1 << bit] ]
				el
					spc_w[ maddr, r & ~u8[1 << bit] ]

			case 0xEA  # NOT1 mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				r      : u8  [ spc_r[maddr] ]
				spc_w[ maddr, r ^ u8[1 << bit] ]

			case 0x02  # SET1 dp.0
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x01 ]

			case 0x22  # SET1 dp.1
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x02 ]

			case 0x42  # SET1 dp.2
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x04 ]

			case 0x62  # SET1 dp.3
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x08 ]

			case 0x82  # SET1 dp.4
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x10 ]

			case 0xA2  # SET1 dp.5
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x20 ]

			case 0xC2  # SET1 dp.6
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x40 ]

			case 0xE2  # SET1 dp.7
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x80 ]

			case 0x12  # CLR1 dp.0
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x01 ]

			case 0x32  # CLR1 dp.1
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x02 ]

			case 0x52  # CLR1 dp.2
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x04 ]

			case 0x72  # CLR1 dp.3
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x08 ]

			case 0x92  # CLR1 dp.4
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x10 ]

			case 0xB2  # CLR1 dp.5
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x20 ]

			case 0xD2  # CLR1 dp.6
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x40 ]

			case 0xF2  # CLR1 dp.7
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x80 ]

			case 0x03  # BBS dp.0, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x01 ] spc_take[ i32[off] ]

			case 0x23  # BBS dp.1, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x02 ] spc_take[ i32[off] ]

			case 0x43  # BBS dp.2, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x04 ] spc_take[ i32[off] ]

			case 0x63  # BBS dp.3, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x08 ] spc_take[ i32[off] ]

			case 0x83  # BBS dp.4, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x10 ] spc_take[ i32[off] ]

			case 0xA3  # BBS dp.5, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x20 ] spc_take[ i32[off] ]

			case 0xC3  # BBS dp.6, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x40 ] spc_take[ i32[off] ]

			case 0xE3  # BBS dp.7, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x80 ] spc_take[ i32[off] ]

			case 0x13  # BBC dp.0, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x01) ] spc_take[ i32[off] ]

			case 0x33  # BBC dp.1, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x02) ] spc_take[ i32[off] ]

			case 0x53  # BBC dp.2, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x04) ] spc_take[ i32[off] ]

			case 0x73  # BBC dp.3, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x08) ] spc_take[ i32[off] ]

			case 0x93  # BBC dp.4, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x10) ] spc_take[ i32[off] ]

			case 0xB3  # BBC dp.5, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x20) ] spc_take[ i32[off] ]

			case 0xD3  # BBC dp.6, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x40) ] spc_take[ i32[off] ]

			case 0xF3  # BBC dp.7, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ !(spc_r[dp] & 0x80) ] spc_take[ i32[off] ]

			case 0x5F  # JMP abs
				spc.pc = spc_rw[]

			case 0x1F  # JMP [abs+X]
				addr   : u16 [ spc_rw[] + spc.x ]
				spc.pc  = spc_r[addr] | (spc_r[addr + 1] << 8)

			case 0x3F  # CALL abs
				addr : u16 [ spc_rw[] ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x4F  # PCALL up
				page   : u8 [ spc_rb[] ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = 0xFF00 | page

			case 0x01  # TCALL 0
				addr : u16 [ spc_r[0xFFDE] | (spc_r[0xFFDF] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x11  # TCALL 1
				addr : u16 [ spc_r[0xFFDC] | (spc_r[0xFFDD] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x21  # TCALL 2
				addr : u16 [ spc_r[0xFFDA] | (spc_r[0xFFDB] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x31  # TCALL 3
				addr : u16 [ spc_r[0xFFD8] | (spc_r[0xFFD9] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x41  # TCALL 4
				addr : u16 [ spc_r[0xFFD6] | (spc_r[0xFFD7] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x51  # TCALL 5
				addr : u16 [ spc_r[0xFFD4] | (spc_r[0xFFD5] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x61  # TCALL 6
				addr : u16 [ spc_r[0xFFD2] | (spc_r[0xFFD3] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x71  # TCALL 7
				addr : u16 [ spc_r[0xFFD0] | (spc_r[0xFFD1] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x81  # TCALL 8
				addr : u16 [ spc_r[0xFFCE] | (spc_r[0xFFCF] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x91  # TCALL 9
				addr : u16 [ spc_r[0xFFCC] | (spc_r[0xFFCD] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0xA1  # TCALL 10
				addr : u16 [ spc_r[0xFFCA] | (spc_r[0xFFCB] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0xB1  # TCALL 11
				addr : u16 [ spc_r[0xFFC8] | (spc_r[0xFFC9] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0xC1  # TCALL 12
				addr : u16 [ spc_r[0xFFC6] | (spc_r[0xFFC7] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0xD1  # TCALL 13
				addr : u16 [ spc_r[0xFFC4] | (spc_r[0xFFC5] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0xE1  # TCALL 14
				addr : u16 [ spc_r[0xFFC2] | (spc_r[0xFFC3] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0xF1  # TCALL 15
				addr : u16 [ spc_r[0xFFC0] | (spc_r[0xFFC1] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x6F  # RET
				spc.sp += 1
				lo     : u8 [ spc_r[ 0x0100 + u16[spc.sp] ] ]
				spc.sp += 1
				hi     : u8 [ spc_r[ 0x0100 + u16[spc.sp] ] ]
				spc.pc  = lo | (hi << 8)

			case 0x7F  # RETI
				spc.sp  += 1
				spc.psw  = spc_r[ 0x0100 + u16[spc.sp] ]
				spc.sp  += 1
				lo       : u8 [ spc_r[ 0x0100 + u16[spc.sp] ] ]
				spc.sp  += 1
				hi       : u8 [ spc_r[ 0x0100 + u16[spc.sp] ] ]
				spc.pc    = lo | (hi << 8)

			case 0x2D  # PUSH A
				spc_w[ 0x0100 + spc.sp, spc.a ]
				spc.sp -= 1

			case 0x4D  # PUSH X
				spc_w[ 0x0100 + spc.sp, spc.x ]
				spc.sp -= 1

			case 0x6D  # PUSH Y
				spc_w[ 0x0100 + spc.sp, spc.y ]
				spc.sp -= 1

			case 0x0D  # PUSH PSW
				spc_w[ 0x0100 + spc.sp, spc.psw ]
				spc.sp -= 1

			case 0xAE  # POP A
				spc.sp += 1
				spc.a   = spc_r[ 0x0100 + u16[spc.sp] ]

			case 0xCE  # POP X
				spc.sp += 1
				spc.x   = spc_r[ 0x0100 + u16[spc.sp] ]

			case 0xEE  # POP Y
				spc.sp += 1
				spc.y   = spc_r[ 0x0100 + u16[spc.sp] ]

			case 0x8E  # POP PSW
				spc.sp  += 1
				spc.psw  = spc_r[ 0x0100 + u16[spc.sp] ]

			case 0x60  # CLRC
				spc.psw &= ~0x01

			case 0x80  # SETC
				spc.psw |= 0x01

			case 0xE0  # CLRV
				spc.psw &= ~0x40

			case 0x20  # CLRP
				spc.psw &= ~0x20

			case 0x40  # SETP
				spc.psw |= 0x20

			case 0xA0  # EI
				spc.psw &= ~0x04

			case 0xC0  # DI
				spc.psw |= 0x04

			case 0x9F  # XCN A
				spc.a   = (spc.a << 4) | (spc.a >> 4)
				spc_nz[ spc.a ]

			case 0xDF  # DAA A
				if [ (spc.a & 0x0F) > 9 || (spc.psw & 0x08) ]
					spc.a += 6
				if [ (spc.a & 0xF0) > 0x90 || (spc.psw & 0x01) ]
					spc.a   += 0x60
					spc.psw |= 0x01
				el
					spc.psw &= ~0x01
				spc_nz[ spc.a ]

			case 0xBE  # DAS A
				if [ !(spc.psw & 0x08) && (spc.a & 0x0F) > 9 ]
					spc.a -= 6
				if [ !(spc.psw & 0x01) && spc.a > 0x99 ]
					spc.a   -= 0x60
					spc.psw &= ~0x01
				spc_nz[ spc.a ]

			case 0xED  # NOTC
				spc.psw ^= 0x01

			case 0x9E  # DIV YA, X
				ya : u16 [ spc.a | (spc.y << 8) ]
				if [ spc.x == 0 ]
					spc.psw |= 0x40
					spc.a    = 0xFF
					spc.y    = 0xFF
				el
					spc.psw &= ~0x40
					spc.a    = ya / spc.x
					spc.y    = ya % spc.x
				spc_nz[ spc.a ]

			case 0xCF  # MUL YA
				result : u16 [ u16[spc.a] * u16[spc.y] ]
				spc.a   = result & 0xFF
				spc.y   = (result >> 8) & 0xFF
				spc_nz[ spc.y ]

			case 0xBA  # MOVW YA, dp
				dp : u16 [ spc_dp[] ]
				spc.a    = spc_r[dp]
				spc.y    = spc_r[dp + 1]
				ya       : u16 [ spc.a | (spc.y << 8) ]
				spc.psw  = (spc.psw & ~0x82) | ((ya == 0) ? 0x02 : 0) | (spc.y & 0x80)

			case 0xDA  # MOVW dp, YA
				dp : u16 [ spc_dp[] ]
				spc_w[ dp,     spc.a ]
				spc_w[ dp + 1, spc.y ]

			case 0x3A  # INCW dp
				dp : u16 [ spc_dp[] ]
				wd : u16 [ (spc_r[dp] | (spc_r[dp + 1] << 8)) + 1 ]
				spc_w[ dp,     u8[wd & 0xFF] ]
				spc_w[ dp + 1, u8[wd >> 8] ]
				spc.psw = (spc.psw & ~0x82) | ((wd == 0) ? 0x02 : 0) | ((wd & 0x8000) ? 0x80 : 0)

			case 0x1A  # DECW dp
				dp : u16 [ spc_dp[] ]
				wd : u16 [ (spc_r[dp] | (spc_r[dp + 1] << 8)) - 1 ]
				spc_w[ dp,     u8[wd & 0xFF] ]
				spc_w[ dp + 1, u8[wd >> 8] ]
				spc.psw = (spc.psw & ~0x82) | ((wd == 0) ? 0x02 : 0) | ((wd & 0x8000) ? 0x80 : 0)

			case 0x7A  # ADDW YA, dp
				dp : u16 [ spc_dp[] ]
				ya  : u16 [ spc.a | (spc.y << 8) ]
				wd  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				res : u32 [ u32[ya] + u32[wd] ]
				c : u8 [ (res > 0xFFFF) ? 0x01 : 0 ]
				z : u8 [ ((res & 0xFFFF) == 0) ? 0x02 : 0 ]
				n : u8 [ ((res & 0x8000) != 0) ? 0x80 : 0 ]
				v : u8 [ (((ya ^ res) & (wd ^ res) & 0x8000) != 0) ? 0x40 : 0 ]
				h : u8 [ (((ya & 0x0FFF) + (wd & 0x0FFF)) > 0x0FFF) ? 0x08 : 0 ]
				spc.psw = (spc.psw & ~0xCB) | c | z | n | v | h
				spc.a = res & 0xFF
				spc.y = (res >> 8) & 0xFF

			case 0x9A  # SUBW YA, dp
				dp : u16 [ spc_dp[] ]
				ya  : u16 [ spc.a | (spc.y << 8) ]
				wd  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				res : i32 [ i32[ya] - i32[wd] ]
				c : u8 [ (res >= 0) ? 0x01 : 0 ]
				z : u8 [ ((res & 0xFFFF) == 0) ? 0x02 : 0 ]
				n : u8 [ ((res & 0x8000) != 0) ? 0x80 : 0 ]
				v : u8 [ (((ya ^ wd) & (ya ^ res) & 0x8000) != 0) ? 0x40 : 0 ]
				h : u8 [ (((ya & 0x0FFF) - (wd & 0x0FFF)) < 0) ? 0x08 : 0 ]
				spc.psw = (spc.psw & ~0xCB) | c | z | n | v | h
				spc.a = res & 0xFF
				spc.y = (res >> 8) & 0xFF

			case 0x5A  # CMPW YA, dp   (16-bit compare; sets N,Z,C only)
				dp : u16 [ spc_dp[] ]
				ya  : u16 [ spc.a | (spc.y << 8) ]
				wd  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				res : i32 [ i32[ya] - i32[wd] ]
				c : u8 [ (res >= 0) ? 0x01 : 0 ]
				z : u8 [ ((res & 0xFFFF) == 0) ? 0x02 : 0 ]
				n : u8 [ ((res & 0x8000) != 0) ? 0x80 : 0 ]
				spc.psw = (spc.psw & ~0x83) | c | z | n

			case 0xFF  # STOP
				return spc.op_cyc

			case 0xEF  # SLEEP
				# wait for interrupt; treated as NOP here

			case 0x00  # NOP
				# no-op

			default
				fprintf[ stderr, "unhandled spc opcode %02X at %04X\n", opcode, spc.pc - 1 ]
				fault 'unhandled spc opcode — implement it then re-run (one at a time)'
		spc.pos = pos0 + i64[ spc.op_cyc ] * 2684659   # force exact opcode-end position (per-access ticks placed mid-opcode I/O; this keeps the opcode total exact incl. taken-branch +2)
		if [ env_spct ] printf[ "SPCT %04X op=%02X clk=%d\n", spct_pc, opcode, spc.op_cyc * 2 ]
		return spc.op_cyc

	# --- 65816 CPU flag helpers ---

	func cpu_nz [ v: u8 ]
		cpu.p = (cpu.p & ~0x82) | ((v == 0) ? 0x02 : 0) | (v & 0x80)

	func cpu_nzc [ v: u8, c: u8 ]
		cpu.p = (cpu.p & ~0x83) | c | ((v == 0) ? 0x02 : 0) | (v & 0x80)

	func cpu_cmp [ res: u16 ]
		c : u8 [ (res < 0x100) ? 0x01 : 0 ]
		z : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n : u8 [ res & 0x80 ]
		cpu.p = (cpu.p & ~0x83) | c | z | n

	func cpu_adc [ aa: u8, val: u8, res: u16 ]
		c  : u8 [ (res > 0xFF) ? 0x01 : 0 ]
		z  : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n  : u8 [ res & 0x80 ]
		ov : u8 [ ((u16[aa] ^ res) & (u16[val] ^ res) & 0x80) ? 0x40 : 0 ]
		cpu.p = (cpu.p & ~0xC3) | c | z | n | ov

	func cpu_sbc [ aa: u8, val: u8, res: u16 ]
		c  : u8 [ (res < 0x100) ? 0x01 : 0 ]
		z  : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n  : u8 [ res & 0x80 ]
		ov : u8 [ ((aa ^ val) & (aa ^ res) & 0x80) ? 0x40 : 0 ]
		cpu.p = (cpu.p & ~0xC3) | c | z | n | ov

	func cpu_bit [ val: u8 ]
		z : u8 [ ((cpu.a & val) == 0) ? 0x02 : 0 ]
		cpu.p = (cpu.p & ~0xC2) | (val & 0xC0) | z

	# --- width-aware ALU helpers (A follows the M flag) — every ALU
	# addressing-mode handler reads its operand then calls one of these ---

	func cpu_ora_a [ val8: u16 ]
		cpu_set_A[ cpu_get_A[] | val8 ]
		cpu_nz_a[ cpu_get_A[] ]

	func cpu_and_a [ val8: u16 ]
		cpu_set_A[ cpu_get_A[] & val8 ]
		cpu_nz_a[ cpu_get_A[] ]

	func cpu_eor_a [ val8: u16 ]
		cpu_set_A[ cpu_get_A[] ^ val8 ]
		cpu_nz_a[ cpu_get_A[] ]

	func cpu_cmp_a [ val8: u16 ]
		a16  : u16 [ cpu_get_A[] ]
		diff : u16 [ a16 - val8 ]
		nm   : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
		c : u8 [ (a16 >= val8) ? 0x01 : 0 ]
		z : u8 [ (diff == 0) ? 0x02 : 0 ]
		n : u8 [ ((diff & nm) != 0) ? 0x80 : 0 ]
		cpu.p = (cpu.p & ~0x83) | c | z | n

	func cpu_adc_a [ val8: u16 ]
		a16 : u16 [ cpu_get_A[] ]
		dfl : bool [ (cpu.p & 0x08) != 0 ]
		cin : i32 [ i32[cpu.p & 0x01] ]
		if [ cpu.p & 0x20 ]
			av8 : i32 [ i32[a16 & 0xFF] ]
			dv8 : i32 [ i32[val8 & 0xFF] ]
			r8  : i32 [ 0 ]
			if [ !dfl ]
				r8 = av8 + dv8 + cin
			el
				r8 = (av8 & 0x0F) + (dv8 & 0x0F) + cin
				if [ r8 > 0x09 ] r8 += 0x06
				h8 : i32 [ (r8 > 0x0F) ? 1 : 0 ]
				r8 = (av8 & 0xF0) + (dv8 & 0xF0) + (h8 << 4) + (r8 & 0x0F)
			ov8 : u8 [ (((~(av8 ^ dv8)) & (av8 ^ r8) & 0x80) != 0) ? 0x40 : 0 ]
			if [ dfl && r8 > 0x9F ] r8 += 0x60
			c8 : u8 [ (r8 > 0xFF) ? 0x01 : 0 ]
			z8 : u8 [ ((r8 & 0xFF) == 0) ? 0x02 : 0 ]
			n8 : u8 [ ((r8 & 0x80) != 0) ? 0x80 : 0 ]
			cpu.p = (cpu.p & ~0xC3) | c8 | z8 | n8 | ov8
			cpu_set_A[ u16[r8 & 0xFF] ]
		el
			avw : i32 [ i32[a16] ]
			dvw : i32 [ i32[val8] ]
			rw  : i32 [ 0 ]
			if [ !dfl ]
				rw = avw + dvw + cin
			el
				rw = (avw & 0x000F) + (dvw & 0x000F) + cin
				if [ rw > 0x0009 ] rw += 0x0006
				k1 : i32 [ (rw > 0x000F) ? 1 : 0 ]
				rw = (avw & 0x00F0) + (dvw & 0x00F0) + (k1 << 4) + (rw & 0x000F)
				if [ rw > 0x009F ] rw += 0x0060
				k2 : i32 [ (rw > 0x00FF) ? 1 : 0 ]
				rw = (avw & 0x0F00) + (dvw & 0x0F00) + (k2 << 8) + (rw & 0x00FF)
				if [ rw > 0x09FF ] rw += 0x0600
				k3 : i32 [ (rw > 0x0FFF) ? 1 : 0 ]
				rw = (avw & 0xF000) + (dvw & 0xF000) + (k3 << 12) + (rw & 0x0FFF)
			ovw : u8 [ (((~(avw ^ dvw)) & (avw ^ rw) & 0x8000) != 0) ? 0x40 : 0 ]
			if [ dfl && rw > 0x9FFF ] rw += 0x6000
			cw : u8 [ (rw > 0xFFFF) ? 0x01 : 0 ]
			zw : u8 [ ((rw & 0xFFFF) == 0) ? 0x02 : 0 ]
			nw : u8 [ ((rw & 0x8000) != 0) ? 0x80 : 0 ]
			cpu.p = (cpu.p & ~0xC3) | cw | zw | nw | ovw
			cpu_set_A[ u16[rw & 0xFFFF] ]

	func cpu_sbc_a [ val8: u16 ]
		a16 : u16 [ cpu_get_A[] ]
		dfl : bool [ (cpu.p & 0x08) != 0 ]
		cin : i32 [ i32[cpu.p & 0x01] ]
		if [ cpu.p & 0x20 ]
			av8 : i32 [ i32[a16 & 0xFF] ]
			dv8 : i32 [ (~i32[val8]) & 0xFF ]
			r8  : i32 [ 0 ]
			if [ !dfl ]
				r8 = av8 + dv8 + cin
			el
				r8 = (av8 & 0x0F) + (dv8 & 0x0F) + cin
				if [ r8 <= 0x0F ] r8 -= 0x06
				h8 : i32 [ (r8 > 0x0F) ? 1 : 0 ]
				r8 = (av8 & 0xF0) + (dv8 & 0xF0) + (h8 << 4) + (r8 & 0x0F)
			ov8 : u8 [ (((~(av8 ^ dv8)) & (av8 ^ r8) & 0x80) != 0) ? 0x40 : 0 ]
			if [ dfl && r8 <= 0xFF ] r8 -= 0x60
			c8 : u8 [ (r8 > 0xFF) ? 0x01 : 0 ]
			z8 : u8 [ ((r8 & 0xFF) == 0) ? 0x02 : 0 ]
			n8 : u8 [ ((r8 & 0x80) != 0) ? 0x80 : 0 ]
			cpu.p = (cpu.p & ~0xC3) | c8 | z8 | n8 | ov8
			cpu_set_A[ u16[r8 & 0xFF] ]
		el
			avw : i32 [ i32[a16] ]
			dvw : i32 [ (~i32[val8]) & 0xFFFF ]
			rw  : i32 [ 0 ]
			if [ !dfl ]
				rw = avw + dvw + cin
			el
				rw = (avw & 0x000F) + (dvw & 0x000F) + cin
				if [ rw <= 0x000F ] rw -= 0x0006
				k1 : i32 [ (rw > 0x000F) ? 1 : 0 ]
				rw = (avw & 0x00F0) + (dvw & 0x00F0) + (k1 << 4) + (rw & 0x000F)
				if [ rw <= 0x00FF ] rw -= 0x0060
				k2 : i32 [ (rw > 0x00FF) ? 1 : 0 ]
				rw = (avw & 0x0F00) + (dvw & 0x0F00) + (k2 << 8) + (rw & 0x00FF)
				if [ rw <= 0x0FFF ] rw -= 0x0600
				k3 : i32 [ (rw > 0x0FFF) ? 1 : 0 ]
				rw = (avw & 0xF000) + (dvw & 0xF000) + (k3 << 12) + (rw & 0x0FFF)
			ovw : u8 [ (((~(avw ^ dvw)) & (avw ^ rw) & 0x8000) != 0) ? 0x40 : 0 ]
			if [ dfl && rw <= 0xFFFF ] rw -= 0x6000
			cw : u8 [ (rw > 0xFFFF) ? 0x01 : 0 ]
			zw : u8 [ ((rw & 0xFFFF) == 0) ? 0x02 : 0 ]
			nw : u8 [ ((rw & 0x8000) != 0) ? 0x80 : 0 ]
			cpu.p = (cpu.p & ~0xC3) | cw | zw | nw | ovw
			cpu_set_A[ u16[rw & 0xFFFF] ]

	# --- width-aware RMW value transforms (return new value, set N/Z/C) ---

	func cpu_asl_v [ v: u16 ] -> u16
		msb : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
		msk : u16 [ (cpu.p & 0x20) ? 0xFF : 0xFFFF ]
		res : u16 [ (v << 1) & msk ]
		cpu.p = (cpu.p & ~0x01) | (((v & msb) != 0) ? 0x01 : 0)
		cpu_nz_a[ res ]
		return res

	func cpu_lsr_v [ v: u16 ] -> u16
		res : u16 [ v >> 1 ]
		cpu.p = (cpu.p & ~0x01) | (((v & 0x01) != 0) ? 0x01 : 0)
		cpu_nz_a[ res ]
		return res

	func cpu_rol_v [ v: u16 ] -> u16
		msb : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
		msk : u16 [ (cpu.p & 0x20) ? 0xFF : 0xFFFF ]
		oc  : u16 [ cpu.p & 0x01 ]
		res : u16 [ ((v << 1) | oc) & msk ]
		cpu.p = (cpu.p & ~0x01) | (((v & msb) != 0) ? 0x01 : 0)
		cpu_nz_a[ res ]
		return res

	func cpu_ror_v [ v: u16 ] -> u16
		msb : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
		oc  : u16 [ (cpu.p & 0x01) ? msb : 0 ]
		res : u16 [ (v >> 1) | oc ]
		cpu.p = (cpu.p & ~0x01) | (((v & 0x01) != 0) ? 0x01 : 0)
		cpu_nz_a[ res ]
		return res

	func cpu_inc_v [ v: u16 ] -> u16
		msk : u16 [ (cpu.p & 0x20) ? 0xFF : 0xFFFF ]
		res : u16 [ (v + 1) & msk ]
		cpu_nz_a[ res ]
		return res

	func cpu_dec_v [ v: u16 ] -> u16
		msk : u16 [ (cpu.p & 0x20) ? 0xFF : 0xFFFF ]
		res : u16 [ (v - 1) & msk ]
		cpu_nz_a[ res ]
		return res

	# width-aware read through a 24-bit [dp] long pointer (and the [dp],Y form)
	# 24-bit leaf byte read that honors the I/O register window ($2000-$43FF in banks
	# $00-$3F/$80-$BF). Long-addressing data reads MUST use this so e.g. LDA/SBC $004214
	# (RDDIV) hits the hardware register, not raw RAM. ROM/WRAM read flat as before.
	func cpu_long_leaf [ la: u32 ] -> u8
		bank : u32 [ la >> 16 ]
		addr : u16 [ u16[ la & 0xFFFF ] ]
		if [ (bank & 0x40) == 0 && addr < 0x2000 ]    # WRAM mirror (banks 00-3F/80-BF): ff3 reads its event script via LDA [dp] with bank 00 — the flat map returned 0s instead of $7E xxxx
			cpu_tick[ bank, addr ]
			return cpu.memory[ 0x7E0000 + u32[addr] ]
		if [ (bank & 0x40) == 0 && addr >= 0x2000 && addr <= 0x43FF ] return cpu_r[ addr ]
		cpu_tick[ bank, addr ]                        # charge the data access (slow ROM/WRAM) — else counted as 6-master idle
		return cpu.memory[ la ]

	func cpu_read_long_dp [ dp: u16 ] -> u16
		lo   : u32 [ cpu_r[dp] ]
		mid  : u32 [ cpu_r[dp + 1] ]
		bank : u32 [ cpu_r[dp + 2] ]
		la   : u32 [ lo | (mid << 8) | (bank << 16) ]
		last_rd = la
		if [ cpu.p & 0x20 ] return cpu_long_leaf[la]
		return cpu_long_leaf[la] | (cpu_long_leaf[la + 1] << 8)

	func cpu_read_long_dp_y [ dp: u16 ] -> u16
		lo   : u32 [ cpu_r[dp] ]
		mid  : u32 [ cpu_r[dp + 1] ]
		bank : u32 [ cpu_r[dp + 2] ]
		la   : u32 [ (lo | (mid << 8) | (bank << 16)) + cpu_get_Y[] ]
		last_rd = la
		if [ cpu.p & 0x20 ] return cpu_long_leaf[la]
		return cpu_long_leaf[la] | (cpu_long_leaf[la + 1] << 8)

	# read the 3-byte long operand and return the width-aware value (absolute long)
	func cpu_read_long [] -> u16
		lo:u32[cpu_rb[]]  mid:u32[cpu_rb[]]  bank:u32[cpu_rb[]]
		la:u32[ lo | (mid << 8) | (bank << 16) ]
		last_rd = la
		if [ cpu.p & 0x20 ] return cpu_long_leaf[la]
		return cpu_long_leaf[la] | (cpu_long_leaf[la + 1] << 8)

	func cpu_read_long_x [] -> u16
		lo:u32[cpu_rb[]]  mid:u32[cpu_rb[]]  bank:u32[cpu_rb[]]
		la:u32[ (lo | (mid << 8) | (bank << 16)) + cpu_get_X[] ]
		last_rd = la
		if [ cpu.p & 0x20 ] return cpu_long_leaf[la]
		return cpu_long_leaf[la] | (cpu_long_leaf[la + 1] << 8)

	# stack-relative (d,s) read and its (d,s),Y indirect form
	func cpu_read_sr [] -> u16
		sr:u8[cpu_rb[]]  sa:u16[ (cpu.sp + sr) & 0xFFFF ]
		cpu_idle[]
		if [ cpu.p & 0x20 ] return cpu_r[sa]
		return cpu_r[sa] | (cpu_r[sa + 1] << 8)

	func cpu_read_sr_y [] -> u16
		sr:u8[cpu_rb[]]  sa:u16[ (cpu.sp + sr) & 0xFFFF ]
		cpu_idle[]
		base:u16[ cpu_r[sa] | (cpu_r[sa + 1] << 8) ]
		cpu_idle[]
		return cpu_read_mem[ u32[base] + u32[cpu_get_Y[]] ]   # data read is DBR-relative with bank carry (reference hardware readBank), only the pointer is bank 0

	# X-width memory read (for index loads/compares — width follows the X flag)
	func cpu_read_mem_x [ addr: u32 ] -> u16
		bk0 : u32 [ (u32[cpu.dbr] + (addr >> 16)) & 0xFF ]
		lo  : u16 [ cpu_bank_r[ bk0, u16[addr & 0xFFFF] ] ]
		if [ cpu.p & 0x10 ] return lo
		a1  : u32 [ addr + 1 ]
		bk1 : u32 [ (u32[cpu.dbr] + (a1 >> 16)) & 0xFF ]
		return lo | (cpu_bank_r[ bk1, u16[a1 & 0xFFFF] ] << 8)

	func cpu_cmp_x [ x16: u16, val8: u16 ]
		diff : u16 [ x16 - val8 ]
		nm   : u16 [ (cpu.p & 0x10) ? 0x80 : 0x8000 ]
		c : u8 [ (x16 >= val8) ? 0x01 : 0 ]
		z : u8 [ (diff == 0) ? 0x02 : 0 ]
		n : u8 [ ((diff & nm) != 0) ? 0x80 : 0 ]
		cpu.p = (cpu.p & ~0x83) | c | z | n

	func cpu_bit_a [ val8: u16 ]
		nb : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
		vb : u16 [ (cpu.p & 0x20) ? 0x40 : 0x4000 ]
		z  : u8 [ ((cpu_get_A[] & val8) == 0) ? 0x02 : 0 ]
		n  : u8 [ ((val8 & nb) != 0) ? 0x80 : 0 ]
		v  : u8 [ ((val8 & vb) != 0) ? 0x40 : 0 ]
		cpu.p = (cpu.p & ~0xC2) | n | v | z

	# push a 16-bit value (high then low, matching the stack convention)
	func cpu_push16 [ v: u16 ]
		cpu_w[ cpu.sp, u8[v >> 8] ]
		cpu_sp_dec[]
		cpu_w[ cpu.sp, u8[v & 0xFF] ]
		cpu_sp_dec[]

	# --- 65816 CPU step ---

	func cpu_step [] -> i32
		slot : i32 [ tr_i % 32 ]
		tr_addr[slot] = (u32[cpu.pbr] << 16) | u32[cpu.pc]
		tr_b0[slot] = cpu_fetch_at[ cpu.pc ]
		tr_b1[slot] = cpu_fetch_at[ cpu.pc + 1 ]
		tr_b2[slot] = cpu_fetch_at[ cpu.pc + 2 ]
		tr_b3[slot] = cpu_fetch_at[ cpu.pc + 3 ]
		tr_p[slot]  = cpu.p
		tr_a[slot]  = cpu.a
		tr_x[slot]  = cpu.x
		tr_y[slot]  = cpu.y
		tr_i += 1
		if [ env_trace && cpu.pbr == 0x00 && cpu.pc == 0x8B11 && dbg_t < 1 ]
			printf[ "==== 32 instrs before demo-entry $00:8B11 (f%u) ====\n", dbg_frames ]
			for [ kk: i32 0, kk < 32, kk += 1 ]
				st : i32 [ (tr_i + kk) % 32 ]
				printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[st] >> 16, tr_addr[st] & 0xFFFF, tr_b0[st], tr_b1[st], tr_b2[st], tr_b3[st], tr_p[st], tr_a[st], tr_x[st], tr_y[st] ]
			dbg_t += 1
		if [ env_joylog && cpu.pbr == 0xC0 && cpu.pc == 0x7792 && dbg_ww < 400 ]
			iptr : u32 [ u32[cpu.memory[0x7E002A]] | (u32[cpu.memory[0x7E002B]] << 8) | (u32[cpu.memory[0x7E002C]] << 16) ]
			printf[ "EVRD f%u ptr=%06X byte=%02X sp=%04X\n", dbg_frames, iptr, cpu.memory[0x7E0000 + (iptr & 0x1FFFF)], cpu.sp ]
			dbg_ww += 1
		if [ env_joylog && cpu.pbr == 0xC0 && cpu.pc == 0x68F4 && dbg_frames >= 3280 && dbg_t < 40 ]
			printf[ "ENTRY 68F4 f%u sp=%04X ret=%02X%02X dp0E=%02X%02X %02X%02X\n", dbg_frames, cpu.sp, cpu.memory[0x7E0000 + u32[cpu.sp] + 2], cpu.memory[0x7E0000 + u32[cpu.sp] + 1], cpu.memory[0x7E000F], cpu.memory[0x7E000E], cpu.memory[0x7E0011], cpu.memory[0x7E0010] ]
			dbg_t += 1
		if [ env_joylog && ((cpu.pbr == 0 && cpu.pc < 0x0100) || (cpu.pbr == 0xC0 && cpu.pc < 0x0008)) && dbg_bad < 1 ]
			printf[ "==== JUMP TO NULL ZONE %02X:%04X (f%u) sp=%04X dp=%04X dbr=%02X ====\n", cpu.pbr, cpu.pc, dbg_frames, cpu.sp, cpu.dp, cpu.dbr ]
			for [ kk3: i32 0, kk3 < 32, kk3 += 1 ]
				st3 : i32 [ (tr_i + kk3) % 32 ]
				printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[st3] >> 16, tr_addr[st3] & 0xFFFF, tr_b0[st3], tr_b1[st3], tr_b2[st3], tr_b3[st3], tr_p[st3], tr_a[st3], tr_x[st3], tr_y[st3] ]
			dbg_bad += 1
		if [ cpu.pbr == 0x09 && cpu.pc >= 0xFA60 && cpu.pc <= 0xFA72 && dbg_frames >= 905 && dbg_frames <= 912 && dbg_t < 60 ]
			printf[ "SE 09:%04X D=%04X X=%04X Y=%04X P=%03X f%u\n", cpu.pc, cpu.dp, cpu.x, cpu.y, cpu.p, dbg_frames ]
			dbg_t += 1
		if [ dbg_frames == 300 && dbg_w < 80 ]
			printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X dp00=%02X%02X dp03=%02X\n", cpu.pbr, cpu.pc, cpu_fetch_at[cpu.pc], cpu_fetch_at[cpu.pc+1], cpu_fetch_at[cpu.pc+2], cpu_fetch_at[cpu.pc+3], cpu.p, cpu.a, cpu.x, cpu.y, cpu_db_r[1], cpu_db_r[0], cpu_db_r[3] ]
			dbg_w += 1
		if [ !dbg_cached ]                   # read debug env flags ONCE, not per-instruction
			dbg_cached   = true
			env_cputrace = (getenv['ASNES_CPUTRACE']) ? true : false
			env_trace    = (getenv['ASNES_TRACE']) ? true : false
			env_logzp    = (getenv['ASNES_LOG_ZP']) ? true : false
			env_pal      = (getenv['ASNES_PAL_LOG']) ? true : false
			env_map      = (getenv['ASNES_MAP_LOG']) ? true : false
			env_vrw      = (getenv['ASNES_VRW_LOG']) ? true : false
			env_dma      = (getenv['ASNES_DMA_LOG']) ? true : false
		if [ env_cputrace ]
			if [ dbg_frames == 0 ] ct_on = true
			if [ ct_on && ct_n < 26000000 ]
				printf[ "%02X:%04X op=%02X M=%ld\n", cpu.pbr, cpu.pc, cpu_fetch_at[ cpu.pc ], cpu_cycles * 6 + i64[ cpu_master_rem ] ]
				if [ env_sig && dbg_frames >= 1090 && dbg_frames <= 1110 ]
					spc_drain[ 0 ]                # sample at the same point reference-hardware-DET does (SMP drained before every CPU instruction); drains are causally neutral
					emit_sigs[ '.' ]
				ct_n += 1
		if [ env_nmim && cpu.pbr == 0 && cpu.pc == 0x80C9 ] printf[ "NMIM f%u M=%ld\n", dbg_frames, cpu_cycles * 6 ]
		op_master   = 0
		op_accesses = 0
		idle_done   = 0
		count_cpu   = true                   # count memory-access master cycles for this instruction
		opcode   : u8   [ cpu_rb[] ]
		if [ dma_pending != 0 ]                # deferred GP-DMA: reference hardware runs it during the instr AFTER $420B, post opcode-fetch
			m : u8 [ u8[ dma_pending ] ]
			dma_pending = 0
			# the DMA interrupts THIS instruction's 2nd cycle: reference hardware's final re-align uses
			# that cycle's clockCount — 6 for internal IO (DEX etc), else the operand speed
			ck : i32 [ (op2_internal[ opcode ]) ? 6 : cpu_speed[ cpu.pbr, cpu.pc ] ]
			do_dma[ m, ck ]
		cycles   : i32  [ 0 ]
		old_pc   : u16  [ cpu.pc ]
		ualign   : bool [ (cpu.dp & 0xFF) != 0 ]
		is_16bit : bool [ !(cpu.p & 0x20) ]
		m1       : i32  [ (is_16bit) ? 1 : 0 ]        # +1 cycle when 16-bit accumulator/memory (M flag clear)
		dpen     : i32  [ (ualign) ? 1 : 0 ]          # +1 cycle when direct-page low byte nonzero
		xpen     : i32  [ (cpu.p & 0x10) ? 0 : 1 ]    # +1 cycle when 16-bit index (X flag clear)

		#puts[ 'asnes_step op: 0x{opcode:02X}' ]


		switch [ opcode ]
			case 0x1A  # INC A
				cpu_set_A[ cpu_inc_v[ cpu_get_A[] ] ]
				cycles = 2

			case 0x3A  # DEC A
				cpu_set_A[ cpu_dec_v[ cpu_get_A[] ] ]
				cycles = 2

			case 0x9B  # TXY (width-aware)
				cpu_set_Y[ cpu_get_X[] ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 2

			case 0xBB  # TYX (width-aware)
				cpu_set_X[ cpu_get_Y[] ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0xA5  # LDA dp (width-aware)
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_set_A[ cpu_read_dp[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 3 + dpen + m1

			case 0xAD  # LDA abs (width-aware)
				addr   : u16 [ cpu_rw[] ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 4 + m1

			case 0xAC  # LDY abs (width-aware on X flag; DBR-relative like reference hardware BankRead)
				addr   : u16 [ cpu_rw[] ]
				cpu_set_Y[ cpu_read_mem_x[ addr ] ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 4 + xpen

			case 0xAF  # LDA long (24-bit absolute, width-aware)
				lo     : u32 [ cpu_rb[] ]
				hi     : u32 [ cpu_rb[] ]
				bank   : u32 [ cpu_rb[] ]
				laddr  : u32 [ lo | (hi << 8) | (bank << 16) ]
				if [ cpu.p & 0x20 ]
					cpu_set_A[ cpu_long_r[laddr] ]
				el
					v : u16 [ cpu_long_r[laddr] | (cpu_long_r[laddr + 1] << 8) ]
					cpu_set_A[ v ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 5 + m1

			case 0xB7  # LDA [dp],Y (long indirect indexed, width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				lo     : u32 [ cpu_r[dp] ]
				mid    : u32 [ cpu_r[dp + 1] ]
				bank   : u32 [ cpu_r[dp + 2] ]
				base   : u32 [ lo | (mid << 8) | (bank << 16) ]
				addr   : u32 [ base + cpu_get_Y[] ]
				if [ cpu.p & 0x20 ]
					cpu_set_A[ cpu_long_r[addr] ]
				el
					v : u16 [ cpu_long_r[addr] | (cpu_long_r[addr + 1] << 8) ]
					cpu_set_A[ v ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 6 + dpen + m1

			case 0xBD  # LDA abs,X (width-aware)
				base   : u16 [ cpu_rw[] ]
				addr   : u16 [ base + cpu_get_X[] ]
				cross  : bool [ (base & 0xFF00) != (addr & 0xFF00) ]
				if [ ((cpu.p & 0x10) == 0) || cross ] cpu_idle[]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = (4 + m1) + ((((cpu.p & 0x10) == 0) || cross) ? 1 : 0)

			case 0xB9  # LDA abs,Y (width-aware)
				base   : u16 [ cpu_rw[] ]
				addr   : u16 [ base + cpu_get_Y[] ]
				cross  : bool [ (base & 0xFF00) != (addr & 0xFF00) ]
				if [ ((cpu.p & 0x10) == 0) || cross ] cpu_idle[]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = (4 + m1) + ((((cpu.p & 0x10) == 0) || cross) ? 1 : 0)

			case 0xA1  # LDA (dp,X) (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				ptr    : u16 [ (dp + cpu_get_X[]) & 0xFFFF ]
				cpu_idle[]
				addr   : u16 [ cpu_r[ptr] | (cpu_r[ptr + 1] << 8) ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 6 + dpen + m1

			case 0xB1  # LDA (dp),Y (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				base   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				addr   : u16 [ base + cpu_get_Y[] ]
				cross  : bool [ (base & 0xFF00) != (addr & 0xFF00) ]
				if [ env_map && cpu.pbr == 0x03 && (dp == 0x0009 || dp == 0x000C) && dbg_w2 < 40 ]
					printf[ "DPY dp=%04X base=%04X Y=%02X addr=%04X DBR=%02X D=%04X val=%02X pc=%04X f%u\n",
						dp, base, cpu_get_Y[], addr, cpu.dbr, cpu.dp, cpu_db_r[addr], cpu.pc, dbg_frames ]
					dbg_w2 += 1
				if [ idx_pen[ base, addr ] != 0 ] cpu_idle[]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = (5 + m1) + dpen + idx_pen[ base, addr ]

			case 0x85  # STA dp (width-aware)
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_write_dp[ addr, cpu_get_A[] ]
				cycles = 3 + dpen + m1

			case 0x8D  # STA abs (width-aware)
				addr   : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 4 + m1

			case 0x8F  # STA long (24-bit absolute, width-aware)
				lo     : u32 [ cpu_rb[] ]
				hi     : u32 [ cpu_rb[] ]
				bank   : u32 [ cpu_rb[] ]
				laddr  : u32 [ lo | (hi << 8) | (bank << 16) ]
				a16    : u16 [ cpu_get_A[] ]
				cpu_long_w[ laddr, u8[ a16 & 0xFF ] ]
				if [ !(cpu.p & 0x20) ] cpu_long_w[ laddr + 1, u8[ a16 >> 8 ] ]
				cycles = 5 + m1

			case 0x86  # STX dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_w[ addr, cpu.x ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.xh ]
				cycles = 3 + dpen + xpen

			case 0x8E  # STX abs (DBR-relative like reference hardware BankWrite)
				addr   : u16 [ cpu_rw[] ]
				cpu_db_w[ addr, cpu.x ]
				if [ !(cpu.p & 0x10) ] cpu_db_w[ addr + 1, cpu.xh ]
				cycles = 4 + xpen

			case 0x84  # STY dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_w[ addr, cpu.y ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.yh ]
				cycles = 3 + dpen + xpen

			case 0x8C  # STY abs (DBR-relative like reference hardware BankWrite)
				addr   : u16 [ cpu_rw[] ]
				cpu_db_w[ addr, cpu.y ]
				if [ !(cpu.p & 0x10) ] cpu_db_w[ addr + 1, cpu.yh ]
				cycles = 4 + xpen

			case 0x95  # STA dp,X
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_write_dp[ addr, cpu_get_A[] ]
				cycles = 4 + dpen + m1

			case 0x9D  # STA abs,X (width-aware)
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_idle[]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 5 + m1

			case 0x99  # STA abs,Y (width-aware)
				addr   : u16 [ cpu_rw[] + cpu_get_Y[] ]
				cpu_idle[]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 5 + m1

			case 0x81  # STA (dp,X) (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				ptr    : u16 [ (dp + cpu_get_X[]) & 0xFFFF ]
				cpu_idle[]
				addr   : u16 [ cpu_r[ptr] | (cpu_r[ptr + 1] << 8) ]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 6 + dpen + m1

			case 0x91  # STA (dp),Y (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				base   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				addr   : u16 [ base + cpu_get_Y[] ]
				cpu_idle[]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 6 + dpen + m1

			case 0xA4  # LDY dp (width-aware on X flag)
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				if [ cpu.p & 0x10 ]
					cpu_set_Y[ cpu_r[addr] ]
				el
					cpu_set_Y[ cpu_r[addr] | (cpu_r[addr + 1] << 8) ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 3 + dpen + xpen

			case 0xA6  # LDX dp (width-aware on X flag)
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				if [ cpu.p & 0x10 ]
					cpu_set_X[ cpu_r[addr] ]
				el
					cpu_set_X[ cpu_r[addr] | (cpu_r[addr + 1] << 8) ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 3 + dpen + xpen

			case 0xAE  # LDX abs (width-aware on X flag; DBR-relative like reference hardware BankRead)
				addr   : u16 [ cpu_rw[] ]
				cpu_set_X[ cpu_read_mem_x[ addr ] ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 4 + xpen

			case 0xB6  # LDX dp,Y
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_Y[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_set_X[ cpu_read_dp_x[addr] ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 4 + dpen + xpen

			case 0xBE  # LDX abs,Y
				base   : u16 [ cpu_rw[] ]
				addr   : u16 [ base + cpu_get_Y[] ]
				cross  : bool [ (base & 0xFF00) != (addr & 0xFF00) ]
				if [ env_pal && base == 0xA463 ]
					printf[ "LDX $A463,Y: Y=%04X addr=%04X DBR=%02X read=%04X f%u\n",
						cpu_get_Y[], addr, cpu.dbr, cpu_read_mem_x[addr], dbg_frames ]
				if [ idx_pen[ base, addr ] != 0 ] cpu_idle[]
				cpu_set_X[ cpu_read_mem_x[addr] ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = (4 + xpen) + idx_pen[ base, addr ]

			case 0xA0  # LDY #imm (width-aware)
				cpu_set_Y[ cpu_imm_x[] ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 2 + xpen

			case 0xA2  # LDX #imm (width-aware)
				cpu_set_X[ cpu_imm_x[] ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2 + xpen

			case 0xA9  # LDA #imm (width-aware)
				cpu_set_A[ cpu_imm_a[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2 + m1

			case 0xEA  # NOP
				cycles = 2

			case 0x18  # CLC
				cpu.p &= ~0x01
				cycles = 2

			case 0x38  # SEC
				cpu.p |= 0x01
				cycles = 2

			case 0xD8  # CLD
				cpu.p &= ~0x08
				cycles = 2

			case 0xF8  # SED
				cpu.p |= 0x08
				cycles = 2

			case 0x78  # SEI
				cpu.p |= 0x04
				cycles = 2

			case 0x58  # CLI
				cpu.p &= ~0x04
				cycles = 2

			case 0xB8  # CLV
				cpu.p &= ~0x40
				cycles = 2

			case 0xAA  # TAX (width-aware)
				cpu_set_X[ cpu.a | (cpu.b << 8) ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0xA8  # TAY (width-aware)
				cpu_set_Y[ cpu.a | (cpu.b << 8) ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 2

			case 0x8A  # TXA (width-aware)
				cpu_set_A[ cpu_get_X[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2

			case 0x98  # TYA (width-aware)
				cpu_set_A[ cpu_get_Y[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2

			case 0xBA  # TSX (width-aware)
				cpu_set_X[ cpu.sp ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0x9A  # TXS
				if [ cpu.e ]
					cpu.sp = 0x0100 | cpu.x
				el
					cpu.sp = cpu.x | (cpu.xh << 8)
				cycles = 2

			case 0x4C  # JMP abs
				cpu.pc = cpu_rw[]
				cycles = 3

			case 0x6C  # JMP (abs)
				ptr    : u16 [ cpu_rw[] ]
				cpu.pc = cpu_r[ptr] | (cpu_r[ptr + 1] << 8)
				cycles = 5

			case 0x20  # JSR abs
				target : u16 [ cpu_rw[] ]
				ret    : u16 [ cpu.pc - 1 ]
				cpu_idle[]
				cpu_w[ cpu.sp, u8[ret >> 8] ]
				cpu_sp_dec[]
				cpu_w[ cpu.sp, u8[ret & 0xFF] ]
				cpu_sp_dec[]
				cpu.pc  = target
				cycles = 6

			case 0x60  # RTS
				cpu_idle[]
				cpu_idle[]
				lo     : u16 [ cpu_r[u16[cpu.sp + 1]] ]
				hi     : u16 [ cpu_r[u16[cpu.sp + 2]] ]
				cpu.sp += 2
				cpu.pc  = (lo | (hi << 8)) + 1
				cycles = 6

			case 0x90  # BCC
				off : i8 [ cpu_rb[] ]
				if [ !(cpu.p & 0x01) ]
					tgt      : u16 [ u16[ i32[cpu.pc] + off ] ]
					cross_pc : bool [ cpu.e && ((cpu.pc & 0xFF00) != (tgt & 0xFF00)) ]
					cpu.pc   = tgt
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0xB0  # BCS
				off : i8 [ cpu_rb[] ]
				if [ cpu.p & 0x01 ]
					tgt      : u16 [ u16[ i32[cpu.pc] + off ] ]
					cross_pc : bool [ cpu.e && ((cpu.pc & 0xFF00) != (tgt & 0xFF00)) ]
					cpu.pc   = tgt
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0xF0  # BEQ
				off : i8 [ cpu_rb[] ]
				if [ cpu.p & 0x02 ]
					tgt      : u16 [ u16[ i32[cpu.pc] + off ] ]
					cross_pc : bool [ cpu.e && ((cpu.pc & 0xFF00) != (tgt & 0xFF00)) ]
					cpu.pc   = tgt
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0xD0  # BNE
				off : i8 [ cpu_rb[] ]
				if [ !(cpu.p & 0x02) ]
					tgt      : u16 [ u16[ i32[cpu.pc] + off ] ]
					cross_pc : bool [ cpu.e && ((cpu.pc & 0xFF00) != (tgt & 0xFF00)) ]
					cpu.pc   = tgt
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0x10  # BPL
				off : i8 [ cpu_rb[] ]
				if [ !(cpu.p & 0x80) ]
					tgt      : u16 [ u16[ i32[cpu.pc] + off ] ]
					cross_pc : bool [ cpu.e && ((cpu.pc & 0xFF00) != (tgt & 0xFF00)) ]
					cpu.pc   = tgt
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0x30  # BMI
				off : i8 [ cpu_rb[] ]
				if [ cpu.p & 0x80 ]
					tgt      : u16 [ u16[ i32[cpu.pc] + off ] ]
					cross_pc : bool [ cpu.e && ((cpu.pc & 0xFF00) != (tgt & 0xFF00)) ]
					cpu.pc   = tgt
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0x50  # BVC
				off : i8 [ cpu_rb[] ]
				if [ !(cpu.p & 0x40) ]
					tgt      : u16 [ u16[ i32[cpu.pc] + off ] ]
					cross_pc : bool [ cpu.e && ((cpu.pc & 0xFF00) != (tgt & 0xFF00)) ]
					cpu.pc   = tgt
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0x70  # BVS
				off : i8 [ cpu_rb[] ]
				if [ cpu.p & 0x40 ]
					tgt      : u16 [ u16[ i32[cpu.pc] + off ] ]
					cross_pc : bool [ cpu.e && ((cpu.pc & 0xFF00) != (tgt & 0xFF00)) ]
					cpu.pc   = tgt
					cycles   = 3 + ((cross_pc) ? 1 : 0)
				el
					cycles = 2

			case 0x80  # BRA
				off    : i8 [ cpu_rb[] ]
				tgtb   : u16 [ u16[ i32[cpu.pc] + off ] ]
				cycles = 3 + ((cpu.e && ((cpu.pc & 0xFF00) != (tgtb & 0xFF00))) ? 1 : 0)
				cpu.pc  = tgtb

			case 0x69  # ADC #imm (width-aware, decimal-aware)
				cpu_adc_a[ cpu_imm_a[] ]
				cycles = 2 + m1

			case 0x65  # ADC dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_adc_a[ cpu_read_dp[addr] ]
				cycles = 3 + dpen + m1

			case 0x6D  # ADC abs
				addr   : u16 [ cpu_rw[] ]
				cpu_adc_a[ cpu_read_mem[addr] ]
				cycles = 4 + m1

			case 0xE9  # SBC #imm (width-aware, decimal-aware)
				cpu_sbc_a[ cpu_imm_a[] ]
				cycles = 2 + m1

			case 0xE5  # SBC dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_sbc_a[ cpu_read_dp[addr] ]
				cycles = 3 + dpen + m1

			case 0xED  # SBC abs
				addr   : u16 [ cpu_rw[] ]
				cpu_sbc_a[ cpu_read_mem[addr] ]
				cycles = 4 + m1

			case 0xC9  # CMP #imm (width-aware)
				val8 : u16 [ cpu_imm_a[] ]
				a16   : u16 [ cpu_get_A[] ]
				diff  : u16 [ a16 - val8 ]
				nmask : u16 [ (cpu.p & 0x20) ? 0x80 : 0x8000 ]
				c : u8 [ (a16 >= val8) ? 0x01 : 0 ]
				z : u8 [ (diff == 0) ? 0x02 : 0 ]
				n : u8 [ ((diff & nmask) != 0) ? 0x80 : 0 ]
				cpu.p = (cpu.p & ~0x83) | c | z | n
				cycles = 2 + m1

			case 0xC5  # CMP dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_cmp_a[ cpu_read_dp[addr] ]
				cycles = 3 + dpen + m1

			case 0xCD  # CMP abs (width-aware on M flag)
				cpu_cmp_a[ cpu_read_mem[ cpu_rw[] ] ]
				cycles = 4 + m1

			case 0xE0  # CPX #imm (width-aware)
				val8 : u16 [ cpu_imm_x[] ]
				x16   : u16 [ cpu_get_X[] ]
				diff  : u16 [ x16 - val8 ]
				nmask : u16 [ (cpu.p & 0x10) ? 0x80 : 0x8000 ]
				c : u8 [ (x16 >= val8) ? 0x01 : 0 ]
				z : u8 [ (diff == 0) ? 0x02 : 0 ]
				n : u8 [ ((diff & nmask) != 0) ? 0x80 : 0 ]
				cpu.p = (cpu.p & ~0x83) | c | z | n
				cycles = 2 + xpen

			case 0xC0  # CPY #imm (width-aware)
				val8 : u16 [ cpu_imm_x[] ]
				y16   : u16 [ cpu_get_Y[] ]
				diff  : u16 [ y16 - val8 ]
				nmask : u16 [ (cpu.p & 0x10) ? 0x80 : 0x8000 ]
				c : u8 [ (y16 >= val8) ? 0x01 : 0 ]
				z : u8 [ (diff == 0) ? 0x02 : 0 ]
				n : u8 [ ((diff & nmask) != 0) ? 0x80 : 0 ]
				cpu.p = (cpu.p & ~0x83) | c | z | n
				cycles = 2 + xpen

			case 0xE6  # INC dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				rv_ : u16 [ cpu_read_dp[addr] ]
				cpu_idle[]
				cpu_write_dp[ addr, cpu_inc_v[ rv_ ] ]
				cycles = 5 + dpen + ((is_16bit) ? 2 : 0)

			case 0xEE  # INC abs
				addr  : u16 [ cpu_rw[] ]
				rv_ : u16 [ cpu_read_mem[addr] ]
				cpu_idle[]
				cpu_write_mem[ addr, cpu_inc_v[ rv_ ] ]
				cycles = 6 + ((is_16bit) ? 2 : 0)

			case 0xE8  # INX (width-aware)
				cpu_set_X[ cpu_get_X[] + 1 ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0xC8  # INY (width-aware)
				cpu_set_Y[ cpu_get_Y[] + 1 ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 2

			case 0xC6  # DEC dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				rv_ : u16 [ cpu_read_dp[addr] ]
				cpu_idle[]
				cpu_write_dp[ addr, cpu_dec_v[ rv_ ] ]
				cycles = 5 + dpen + ((is_16bit) ? 2 : 0)

			case 0xCE  # DEC abs
				addr  : u16 [ cpu_rw[] ]
				rv_ : u16 [ cpu_read_mem[addr] ]
				cpu_idle[]
				cpu_write_mem[ addr, cpu_dec_v[ rv_ ] ]
				cycles = 6 + ((is_16bit) ? 2 : 0)

			case 0xCA  # DEX (width-aware)
				cpu_set_X[ cpu_get_X[] - 1 ]
				cpu_nz_x[ cpu_get_X[] ]
				cycles = 2

			case 0x88  # DEY (width-aware)
				cpu_set_Y[ cpu_get_Y[] - 1 ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 2

			case 0x29  # AND #imm (width-aware)
				cpu_set_A[ cpu_get_A[] & cpu_imm_a[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2 + m1

			case 0x25  # AND dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_and_a[ cpu_read_dp[addr] ]
				cycles = 3 + dpen + m1

			case 0x2D  # AND abs
				addr  : u16 [ cpu_rw[] ]
				cpu_and_a[ cpu_read_mem[addr] ]
				cycles = 4 + m1

			case 0x01  # ORA (dp,X) — width-aware (A follows M flag)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				ptr    : u16 [ (dp + cpu_get_X[]) & 0xFFFF ]
				cpu_idle[]
				addr   : u16 [ cpu_r[ptr] | (cpu_r[ptr + 1] << 8) ]
				res    : u16 [ cpu_get_A[] | cpu_read_mem[addr] ]
				cpu_set_A[ res ]
				if [ cpu.p & 0x20 ]
					cpu.p = (cpu.p & ~0x82) | ((res == 0) ? 0x02 : 0) | (res & 0x80)
				el
					cpu.p = (cpu.p & ~0x82) | ((res == 0) ? 0x02 : 0) | ((res & 0x8000) ? 0x80 : 0)
				cycles = 6 + dpen + m1

			case 0x09  # ORA #imm (width-aware)
				cpu_set_A[ cpu_get_A[] | cpu_imm_a[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2 + m1

			case 0x05  # ORA dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_ora_a[ cpu_read_dp[addr] ]
				cycles = 3 + dpen + m1

			case 0x0D  # ORA abs
				addr  : u16 [ cpu_rw[] ]
				cpu_ora_a[ cpu_read_mem[addr] ]
				cycles = 4 + m1

			case 0x49  # EOR #imm (width-aware)
				cpu_set_A[ cpu_get_A[] ^ cpu_imm_a[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 2 + m1

			case 0x45  # EOR dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_eor_a[ cpu_read_dp[addr] ]
				cycles = 3 + dpen + m1

			case 0x4D  # EOR abs
				addr  : u16 [ cpu_rw[] ]
				cpu_eor_a[ cpu_read_mem[addr] ]
				cycles = 4 + m1

			case 0x0A  # ASL A
				cpu_set_A[ cpu_asl_v[ cpu_get_A[] ] ]
				cycles = 2

			case 0x06  # ASL dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				rv_ : u16 [ cpu_read_dp[addr] ]
				cpu_idle[]
				cpu_write_dp[ addr, cpu_asl_v[ rv_ ] ]
				cycles = 5 + dpen + ((is_16bit) ? 2 : 0)

			case 0x4A  # LSR A
				cpu_set_A[ cpu_lsr_v[ cpu_get_A[] ] ]
				cycles = 2

			case 0x46  # LSR dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				rv_ : u16 [ cpu_read_dp[addr] ]
				cpu_idle[]
				cpu_write_dp[ addr, cpu_lsr_v[ rv_ ] ]
				cycles = 5 + dpen + ((is_16bit) ? 2 : 0)

			case 0x2A  # ROL A
				cpu_set_A[ cpu_rol_v[ cpu_get_A[] ] ]
				cycles = 2

			case 0x26  # ROL dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				rv_ : u16 [ cpu_read_dp[addr] ]
				cpu_idle[]
				cpu_write_dp[ addr, cpu_rol_v[ rv_ ] ]
				cycles = 5 + dpen + ((is_16bit) ? 2 : 0)

			case 0x6A  # ROR A
				cpu_set_A[ cpu_ror_v[ cpu_get_A[] ] ]
				cycles = 2

			case 0x66  # ROR dp
				addr   : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				rv_ : u16 [ cpu_read_dp[addr] ]
				cpu_idle[]
				cpu_write_dp[ addr, cpu_ror_v[ rv_ ] ]
				cycles = 5 + dpen + ((is_16bit) ? 2 : 0)

			case 0x24  # BIT dp
				addr  : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_bit_a[ cpu_read_dp[addr] ]
				cycles = 3 + dpen + m1

			case 0x2C  # BIT abs
				addr  : u16 [ cpu_rw[] ]
				cpu_bit_a[ cpu_read_mem[addr] ]
				cycles = 4 + m1

			case 0x48  # PHA
				cpu_idle[]
				if [ cpu.p & 0x20 ]
					cpu_w[ cpu.sp, cpu.a ]
					cpu_sp_dec[]
				el
					cpu_w[ cpu.sp, cpu.b ]
					cpu_sp_dec[]
					cpu_w[ cpu.sp, cpu.a ]
					cpu_sp_dec[]
				cycles = 3 + m1

			case 0x68  # PLA
				cpu_idle[]
				cpu_idle[]
				if [ cpu.p & 0x20 ]
					cpu_sp_inc[]
					cpu.a   = cpu_r[ cpu.sp ]
					cpu.p   = (cpu.p & ~0x82) | ((cpu.a == 0) ? 0x02 : 0) | (cpu.a & 0x80)
				el
					cpu_sp_inc[]
					al     : u16 [ cpu_r[ cpu.sp ] ]
					cpu_sp_inc[]
					ah     : u16 [ cpu_r[ cpu.sp ] ]
					cpu.a   = al
					cpu.b   = ah
					av     : u16 [ al | (ah << 8) ]
					cpu.p   = (cpu.p & ~0x82) | ((av == 0) ? 0x02 : 0) | ((av & 0x8000) ? 0x80 : 0)
				cycles = 4 + m1

			case 0x08  # PHP
				cpu_idle[]
				cpu_w[ cpu.sp, cpu.p ]
				cpu_sp_dec[]
				cycles = 3

			case 0x28  # PLP
				cpu_idle[]
				cpu_idle[]
				cpu_sp_inc[]
				cpu.p   = cpu_r[ cpu.sp ]
				if [ cpu.e ] cpu.p |= 0x30            # emulation forces M/X set
				if [ cpu.p & 0x10 ]            # 8-bit index: force XH/YH to 0
					cpu.xh = 0
					cpu.yh = 0
				is_16bit = !(cpu.p & 0x20)
				m1   = (is_16bit) ? 1 : 0
				xpen = (cpu.p & 0x10) ? 0 : 1
				cycles = 4

			case 0xDA  # PHX
				cpu_idle[]
				if [ cpu.p & 0x10 ]
					cpu_w[ cpu.sp, cpu.x ]
					cpu_sp_dec[]
				el
					cpu_w[ cpu.sp, cpu.xh ]
					cpu_sp_dec[]
					cpu_w[ cpu.sp, cpu.x ]
					cpu_sp_dec[]
				cycles = 3 + xpen

			case 0x5A  # PHY
				cpu_idle[]
				if [ cpu.p & 0x10 ]
					cpu_w[ cpu.sp, cpu.y ]
					cpu_sp_dec[]
				el
					cpu_w[ cpu.sp, cpu.yh ]
					cpu_sp_dec[]
					cpu_w[ cpu.sp, cpu.y ]
					cpu_sp_dec[]
				cycles = 3 + xpen

			case 0xFA  # PLX
				cpu_idle[]
				cpu_idle[]
				if [ cpu.p & 0x10 ]
					cpu_sp_inc[]
					cpu.x   = cpu_r[ cpu.sp ]
					cpu.p   = (cpu.p & ~0x82) | ((cpu.x == 0) ? 0x02 : 0) | (cpu.x & 0x80)
				el
					cpu_sp_inc[]
					xl     : u16 [ cpu_r[ cpu.sp ] ]
					cpu_sp_inc[]
					xh     : u16 [ cpu_r[ cpu.sp ] ]
					cpu.x   = xl
					cpu.xh  = xh
					xv     : u16 [ xl | (xh << 8) ]
					cpu.p   = (cpu.p & ~0x82) | ((xv == 0) ? 0x02 : 0) | ((xv & 0x8000) ? 0x80 : 0)
				cycles = 4 + xpen

			case 0x7A  # PLY
				cpu_idle[]
				cpu_idle[]
				if [ cpu.p & 0x10 ]
					cpu_sp_inc[]
					cpu.y   = cpu_r[ cpu.sp ]
					cpu.p   = (cpu.p & ~0x82) | ((cpu.y == 0) ? 0x02 : 0) | (cpu.y & 0x80)
				el
					cpu_sp_inc[]
					yl     : u16 [ cpu_r[ cpu.sp ] ]
					cpu_sp_inc[]
					yh     : u16 [ cpu_r[ cpu.sp ] ]
					cpu.y   = yl
					cpu.yh  = yh
					yv     : u16 [ yl | (yh << 8) ]
					cpu.p   = (cpu.p & ~0x82) | ((yv == 0) ? 0x02 : 0) | ((yv & 0x8000) ? 0x80 : 0)
				cycles = 4 + xpen

			case 0x8B  # PHB
				cpu_idle[]
				cpu_w[ cpu.sp, cpu.dbr ]
				cpu_sp_dec[]
				cycles = 3

			case 0xAB  # PLB
				cpu_idle[]
				cpu_idle[]
				cpu_sp_inc[]
				cpu.dbr = cpu_r[ cpu.sp ]
				cpu.p   = (cpu.p & ~0x82) | ((cpu.dbr == 0) ? 0x02 : 0) | (cpu.dbr & 0x80)
				cycles = 4

			case 0x4B  # PHK
				cpu_idle[]
				cpu_w[ cpu.sp, cpu.pbr ]
				cpu_sp_dec[]
				cycles = 3

			case 0x0B  # PHD
				cpu_idle[]
				cpu_w[ cpu.sp, u8[cpu.dp >> 8] ]
				cpu_sp_dec[]
				cpu_w[ cpu.sp, u8[cpu.dp & 0xFF] ]
				cpu_sp_dec[]
				cycles = 4

			case 0x2B  # PLD
				cpu_idle[]
				cpu_idle[]
				cpu_sp_inc[]
				dl     : u16 [ cpu_r[ cpu.sp ] ]
				cpu_sp_inc[]
				dh     : u16 [ cpu_r[ cpu.sp ] ]
				cpu.dp  = dl | (dh << 8)
				cpu.p   = (cpu.p & ~0x82) | ((cpu.dp == 0) ? 0x02 : 0) | ((cpu.dp & 0x8000) ? 0x80 : 0)
				ualign = (cpu.dp & 0xFF) != 0
				dpen   = (ualign) ? 1 : 0
				cycles = 5

			case 0xEB  # XBA
				tmp    : u8 [ cpu.a ]
				cpu.a   = cpu.b
				cpu.b   = tmp
				cpu.p   = (cpu.p & ~0x82) | ((cpu.a == 0) ? 0x02 : 0) | (cpu.a & 0x80)
				cycles = 3

			case 0x1B  # TCS (C -> S), no flags
				if [ cpu.e ]
					cpu.sp = 0x0100 | cpu.a
				el
					cpu.sp = cpu.a | (cpu.b << 8)
				cycles = 2

			case 0x3B  # TSC (S -> C), 16-bit N/Z
				sv     : u16 [ cpu.sp ]
				cpu.a   = sv & 0xFF
				cpu.b   = sv >> 8
				cpu.p   = (cpu.p & ~0x82) | ((sv == 0) ? 0x02 : 0) | ((sv & 0x8000) ? 0x80 : 0)
				cycles = 2

			case 0x5B  # TCD (C -> D), 16-bit N/Z
				cv     : u16 [ cpu.a | (cpu.b << 8) ]
				cpu.dp  = cv
				cpu.p   = (cpu.p & ~0x82) | ((cv == 0) ? 0x02 : 0) | ((cv & 0x8000) ? 0x80 : 0)
				ualign = (cpu.dp & 0xFF) != 0
				dpen   = (ualign) ? 1 : 0
				cycles = 2

			case 0x7B  # TDC (D -> C), 16-bit N/Z
				cpu.a   = cpu.dp & 0xFF
				cpu.b   = cpu.dp >> 8
				cpu.p   = (cpu.p & ~0x82) | ((cpu.dp == 0) ? 0x02 : 0) | ((cpu.dp & 0x8000) ? 0x80 : 0)
				cycles = 2

			case 0x40  # RTI
				cpu_idle[]
				cpu_idle[]
				cpu_sp_inc[]
				cpu.p   = cpu_r[cpu.sp]
				if [ cpu.e ] cpu.p |= 0x30            # emulation forces M/X set
				if [ cpu.p & 0x10 ]            # 8-bit index: force XH/YH to 0
					cpu.xh = 0
					cpu.yh = 0
				cpu_sp_inc[]
				lo     : u16 [ cpu_r[cpu.sp] ]
				cpu_sp_inc[]
				hi     : u16 [ cpu_r[cpu.sp] ]
				cpu.pc  = lo | (hi << 8)
				if [ !cpu.e ]                          # native mode: RTI restores PBR
					cpu_sp_inc[]
					cpu.pbr = cpu_r[cpu.sp]
				is_16bit = !(cpu.p & 0x20)
				m1   = (is_16bit) ? 1 : 0
				xpen = (cpu.p & 0x10) ? 0 : 1
				cycles = (cpu.e) ? 6 : 7

			case 0x00  # BRK — software interrupt (native: $FFE6, pushes PBR; emulation: $FFFE)
				cpu_rb[]
				bvec   : u16 [ (cpu.e) ? 0xFFFE : 0xFFE6 ]
				cpu_swi[ bvec ]
				cycles = (cpu.e) ? 7 : 8

			case 0xFB  # XCE — exchange carry and emulation-mode flags
				old_carry : u8 [ cpu.p & 0x01 ]
				cpu.p = (cpu.p & ~0x01) | ((cpu.e) ? 1 : 0)   # C := old E
				cpu.e = (old_carry != 0)                       # E := old C
				if [ cpu.e ]
					cpu.p |= 0x30                 # emulation forces 8-bit A (M) and 8-bit index (X)
					cpu.xh = 0
					cpu.yh = 0
					cpu.sp = 0x0100 | (cpu.sp & 0xFF)   # emulation forces the stack into page 1
				is_16bit = !(cpu.p & 0x20)
				m1   = (is_16bit) ? 1 : 0
				xpen = (cpu.p & 0x10) ? 0 : 1
				cycles = 2

			case 0xC2  # REP #imm
				mask   : u8 [ cpu_rb[] ]
				cpu.p &= ~mask
				if [ cpu.e ] cpu.p |= 0x30            # emulation: M/X cannot be cleared
				is_16bit = !(cpu.p & 0x20)
				m1   = (is_16bit) ? 1 : 0
				xpen = (cpu.p & 0x10) ? 0 : 1
				cycles = 3

			case 0xE2  # SEP #imm
				mask   : u8 [ cpu_rb[] ]
				cpu.p |= mask
				if [ mask & 0x10 ]              # entering 8-bit index: force XH/YH to 0
					cpu.xh = 0
					cpu.yh = 0
				is_16bit = !(cpu.p & 0x20)
				m1   = (is_16bit) ? 1 : 0
				xpen = (cpu.p & 0x10) ? 0 : 1
				cycles = 3

			case 0x14  # TRB dp
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				val8  : u16 [ cpu_read_dp[dp] ]
				a16    : u16 [ cpu_get_A[] ]
				result : u16 [ a16 & val8 ]
				cpu_idle[]
				cpu_write_dp[ dp, val8 & ~a16 ]
