			case 0xE1  # SBC (dp,X)
				dpx : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				px  : u16 [ (dpx + cpu_get_X[]) & 0xFFFF ]
				cpu_idle[]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_sbc_a[ cpu_read_mem[ax] ]
				cycles = 6 + dpen + m1

			# --- ALU (dp),Y: ptr at dp, + Y ---
			case 0x11  # ORA (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				ad  : u16 [ by + cpu_get_Y[] ]
				if [ idx_pen[ by, ad ] != 0 ] cpu_idle[]
				cpu_ora_a[ cpu_read_mem[ ad ] ]
				cycles = (5 + m1) + dpen + idx_pen[ by, ad ]
			case 0x31  # AND (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				ad  : u16 [ by + cpu_get_Y[] ]
				if [ idx_pen[ by, ad ] != 0 ] cpu_idle[]
				cpu_and_a[ cpu_read_mem[ ad ] ]
				cycles = (5 + m1) + dpen + idx_pen[ by, ad ]
			case 0x51  # EOR (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				ad  : u16 [ by + cpu_get_Y[] ]
				if [ idx_pen[ by, ad ] != 0 ] cpu_idle[]
				cpu_eor_a[ cpu_read_mem[ ad ] ]
				cycles = (5 + m1) + dpen + idx_pen[ by, ad ]
			case 0x71  # ADC (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				ad  : u16 [ by + cpu_get_Y[] ]
				if [ idx_pen[ by, ad ] != 0 ] cpu_idle[]
				cpu_adc_a[ cpu_read_mem[ ad ] ]
				cycles = (5 + m1) + dpen + idx_pen[ by, ad ]
			case 0xD1  # CMP (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				ad  : u16 [ by + cpu_get_Y[] ]
				if [ idx_pen[ by, ad ] != 0 ] cpu_idle[]
				cpu_cmp_a[ cpu_read_mem[ ad ] ]
				cycles = (5 + m1) + dpen + idx_pen[ by, ad ]
			case 0xF1  # SBC (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				ad  : u16 [ by + cpu_get_Y[] ]
				if [ idx_pen[ by, ad ] != 0 ] cpu_idle[]
				cpu_sbc_a[ cpu_read_mem[ ad ] ]
				cycles = (5 + m1) + dpen + idx_pen[ by, ad ]

			# --- ALU (dp): ptr at dp ---
			case 0x12  # ORA (dp)
				dpz : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_ora_a[ cpu_read_mem[az] ]
				cycles = 5 + dpen + m1
			case 0x32  # AND (dp)
				dpz : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_and_a[ cpu_read_mem[az] ]
				cycles = 5 + dpen + m1
			case 0x52  # EOR (dp)
				dpz : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_eor_a[ cpu_read_mem[az] ]
				cycles = 5 + dpen + m1
			case 0xD2  # CMP (dp)
				dpz : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_cmp_a[ cpu_read_mem[az] ]
				cycles = 5 + dpen + m1
			case 0xF2  # SBC (dp)
				dpz : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_sbc_a[ cpu_read_mem[az] ]
				cycles = 5 + dpen + m1

			# --- ALU abs,X ---
			case 0x1D  # ORA abs,X
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_X[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_ora_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]
			case 0x3D  # AND abs,X
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_X[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_and_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]
			case 0x5D  # EOR abs,X
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_X[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_eor_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]
			case 0x7D  # ADC abs,X
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_X[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_adc_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]
			case 0xDD  # CMP abs,X
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_X[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_cmp_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]
			case 0xFD  # SBC abs,X
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_X[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_sbc_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]

			# --- ALU abs,Y ---
			case 0x19  # ORA abs,Y
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_Y[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_ora_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]
			case 0x39  # AND abs,Y
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_Y[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_and_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]
			case 0x59  # EOR abs,Y
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_Y[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_eor_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]
			case 0x79  # ADC abs,Y
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_Y[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_adc_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]
			case 0xD9  # CMP abs,Y
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_Y[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_cmp_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]
			case 0xF9  # SBC abs,Y
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_Y[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_sbc_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]

			# --- ALU dp,X ---
			case 0x15  # ORA dp,X
				da_ : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_ora_a[ cpu_read_dp[ da_ ] ]
				cycles = 4 + dpen + m1
			case 0x35  # AND dp,X
				da_ : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_and_a[ cpu_read_dp[ da_ ] ]
				cycles = 4 + dpen + m1
			case 0x55  # EOR dp,X
				da_ : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_eor_a[ cpu_read_dp[ da_ ] ]
				cycles = 4 + dpen + m1
			case 0xD5  # CMP dp,X
				da_ : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_cmp_a[ cpu_read_dp[ da_ ] ]
				cycles = 4 + dpen + m1
			case 0xF5  # SBC dp,X
				da_ : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_sbc_a[ cpu_read_dp[ da_ ] ]
				cycles = 4 + dpen + m1

			# --- ALU absolute long ---
			case 0x0F  # ORA long
				cpu_ora_a[ cpu_read_long[] ]
				cycles = 5 + m1
			case 0x2F  # AND long
				cpu_and_a[ cpu_read_long[] ]
				cycles = 5 + m1
			case 0x4F  # EOR long
				cpu_eor_a[ cpu_read_long[] ]
				cycles = 5 + m1
			case 0x6F  # ADC long
				cpu_adc_a[ cpu_read_long[] ]
				cycles = 5 + m1
			case 0xCF  # CMP long
				cpu_cmp_a[ cpu_read_long[] ]
				cycles = 5 + m1
			case 0xEF  # SBC long
				cpu_sbc_a[ cpu_read_long[] ]
				cycles = 5 + m1

			# --- ALU absolute long,X ---
			case 0x3F  # AND long,X
				cpu_and_a[ cpu_read_long_x[] ]
				cycles = 5 + m1
			case 0x5F  # EOR long,X
				cpu_eor_a[ cpu_read_long_x[] ]
				cycles = 5 + m1
			case 0x7F  # ADC long,X
				cpu_adc_a[ cpu_read_long_x[] ]
				cycles = 5 + m1
			case 0xDF  # CMP long,X
				cpu_cmp_a[ cpu_read_long_x[] ]
				cycles = 5 + m1

			# --- ALU stack-relative (d,s) ---
			case 0x03  # ORA d,s
				cpu_ora_a[ cpu_read_sr[] ]
				cycles = 4 + m1
			case 0x23  # AND d,s
				cpu_and_a[ cpu_read_sr[] ]
				cycles = 4 + m1
			case 0x43  # EOR d,s
				cpu_eor_a[ cpu_read_sr[] ]
				cycles = 4 + m1
			case 0x63  # ADC d,s
				cpu_adc_a[ cpu_read_sr[] ]
				cycles = 4 + m1
			case 0xC3  # CMP d,s
				cpu_cmp_a[ cpu_read_sr[] ]
				cycles = 4 + m1
			case 0xE3  # SBC d,s
				cpu_sbc_a[ cpu_read_sr[] ]
				cycles = 4 + m1

			# --- ALU (d,s),Y ---
			case 0x13  # ORA (d,s),Y
				cpu_ora_a[ cpu_read_sr_y[] ]
				cycles = 7 + m1
			case 0x33  # AND (d,s),Y
				cpu_and_a[ cpu_read_sr_y[] ]
				cycles = 7 + m1
			case 0x53  # EOR (d,s),Y
				cpu_eor_a[ cpu_read_sr_y[] ]
				cycles = 7 + m1
			case 0xD3  # CMP (d,s),Y
				cpu_cmp_a[ cpu_read_sr_y[] ]
				cycles = 7 + m1
			case 0xF3  # SBC (d,s),Y
				cpu_sbc_a[ cpu_read_sr_y[] ]
				cycles = 7 + m1

			# --- loads ---
			case 0xA3  # LDA d,s
				cpu_set_A[ cpu_read_sr[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 4 + m1
			case 0xA7  # LDA [dp]
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_set_A[ cpu_read_long_dp[dp] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 6 + dpen + m1
			case 0xB5  # LDA dp,X
				da_ : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_set_A[ cpu_read_dp[ da_ ] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 4 + dpen + m1
			case 0xBF  # LDA long,X
				cpu_set_A[ cpu_read_long_x[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 5 + m1
			case 0xB4  # LDY dp,X
				cpu_set_Y[ cpu_read_dp_x[ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ] ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 4 + dpen + xpen
			case 0xBC  # LDY abs,X
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_X[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_set_Y[ cpu_read_mem_x[ ad ] ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = (4 + xpen) + idx_pen[ bs, ad ]

			# --- stores ---
			case 0x83  # STA d,s (stack-relative: always bank 0, reference hardware writeStack)
				sr : u8 [ cpu_rb[] ]
				cpu_idle[]
				sa : u16 [ (cpu.sp + sr) & 0xFFFF ]
				av : u16 [ cpu_get_A[] ]
				cpu_w[ sa, u8[av & 0xFF] ]
				if [ !(cpu.p & 0x20) ] cpu_w[ (sa + 1) & 0xFFFF, u8[av >> 8] ]
				cycles = 4 + m1
			case 0x87  # STA [dp]
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				lo : u32 [ cpu_r[dp] ]
				mid : u32 [ cpu_r[dp + 1] ]
				bank : u32 [ cpu_r[dp + 2] ]
				la : u32 [ lo | (mid << 8) | (bank << 16) ]
				av : u16 [ cpu_get_A[] ]
				cpu_long_w[ la, u8[ av & 0xFF ] ]
				if [ !(cpu.p & 0x20) ] cpu_long_w[ la + 1, u8[ av >> 8 ] ]
				cycles = 6 + dpen + m1
			case 0x97  # STA [dp],Y
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				lo : u32 [ cpu_r[dp] ]
				mid : u32 [ cpu_r[dp + 1] ]
				bank : u32 [ cpu_r[dp + 2] ]
				la : u32 [ (lo | (mid << 8) | (bank << 16)) + cpu_get_Y[] ]
				av : u16 [ cpu_get_A[] ]
				cpu_long_w[ la, u8[ av & 0xFF ] ]
				if [ !(cpu.p & 0x20) ] cpu_long_w[ la + 1, u8[ av >> 8 ] ]
				cycles = 6 + dpen + m1
			case 0x9F  # STA long,X
				lo : u32 [ cpu_rb[] ]
				mid : u32 [ cpu_rb[] ]
				bank : u32 [ cpu_rb[] ]
				la : u32 [ (lo | (mid << 8) | (bank << 16)) + cpu_get_X[] ]
				av : u16 [ cpu_get_A[] ]
				cpu_long_w[ la, u8[ av & 0xFF ] ]
				if [ !(cpu.p & 0x20) ] cpu_long_w[ la + 1, u8[ av >> 8 ] ]
				cycles = 5 + m1
			case 0x93  # STA (d,s),Y
				sr : u8 [ cpu_rb[] ]
				cpu_idle[]
				sa : u16 [ (cpu.sp + sr) & 0xFFFF ]
				base : u16 [ cpu_r[sa] | (cpu_r[sa + 1] << 8) ]
				cpu_idle[]
				cpu_write_mem[ base + cpu_get_Y[], cpu_get_A[] ]
				cycles = 7 + m1
			case 0x94  # STY dp,X
				addr : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				cpu_w[ addr, cpu.y ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.yh ]
				cycles = 4 + dpen + xpen
			case 0x96  # STX dp,Y
				addr : u16 [ (cpu.dp + cpu_rb[] + cpu_get_Y[]) & 0xFFFF ]
				cpu_w[ addr, cpu.x ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.xh ]
				cycles = 4 + dpen + xpen

			# --- compares (X-width) ---
			case 0xC4  # CPY dp
				cpu_cmp_x[ cpu_get_Y[], cpu_read_dp_x[ (cpu.dp + cpu_rb[]) & 0xFFFF ] ]
				cycles = 3 + dpen + xpen
			case 0xCC  # CPY abs
				cpu_cmp_x[ cpu_get_Y[], cpu_read_mem_x[ cpu_rw[] ] ]
				cycles = 4 + xpen
			case 0xE4  # CPX dp
				cpu_cmp_x[ cpu_get_X[], cpu_read_dp_x[ (cpu.dp + cpu_rb[]) & 0xFFFF ] ]
				cycles = 3 + dpen + xpen
			case 0xEC  # CPX abs
				cpu_cmp_x[ cpu_get_X[], cpu_read_mem_x[ cpu_rw[] ] ]
				cycles = 4 + xpen

			# --- BIT ---
			case 0x89  # BIT #imm (only affects Z)
				val8 : u16 [ cpu_imm_a[] ]
				z : u8 [ ((cpu_get_A[] & val8) == 0) ? 0x02 : 0 ]
				cpu.p = (cpu.p & ~0x02) | z
				cycles = 2 + m1
			case 0x34  # BIT dp,X
				da_ : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_bit_a[ cpu_read_dp[ da_ ] ]
				cycles = 4 + dpen + m1
			case 0x3C  # BIT abs,X
				bs : u16 [ cpu_rw[] ]
				ad : u16 [ bs + cpu_get_X[] ]
				if [ idx_pen[ bs, ad ] != 0 ] cpu_idle[]
				cpu_bit_a[ cpu_read_mem[ ad ] ]
				cycles = (4 + m1) + idx_pen[ bs, ad ]

			# --- control flow ---
			case 0x7C  # JMP (abs,X)
				ptr : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_idle[]
				cpu_tick[ u32[cpu.pbr], ptr ]              # indirect pointer reads are real bus accesses (program bank)
				cpu_tick[ u32[cpu.pbr], ptr + 1 ]
				cpu.pc = cpu_fetch_at[ptr] | (cpu_fetch_at[ptr + 1] << 8)
				cycles = 6
			case 0xFC  # JSR (abs,X)
				ptr : u16 [ cpu_rw[] ]
				ret : u16 [ cpu.pc - 1 ]
				cpu_push16[ ret ]
				addr : u16 [ (ptr + cpu_get_X[]) & 0xFFFF ]
				cpu_idle[]
				cpu_tick[ u32[cpu.pbr], addr ]            # indirect pointer reads are real bus accesses (program bank)
				cpu_tick[ u32[cpu.pbr], addr + 1 ]
				cpu.pc = cpu_fetch_at[addr] | (cpu_fetch_at[addr + 1] << 8)
				cycles = 8
			case 0x82  # BRL (branch long)
				rel : u16 [ cpu_rw[] ]
				cpu.pc = cpu.pc + rel
				cycles = 4
			case 0x62  # PER
				rel : u16 [ cpu_rw[] ]
				cpu_idle[]
				cpu_push16[ cpu.pc + rel ]
				cycles = 6
			case 0xD4  # PEI
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_push16[ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cycles = 6 + dpen
			case 0xF4  # PEA
				cpu_push16[ cpu_rw[] ]
				cycles = 5

			# --- misc / system ---
			case 0x42  # WDM (2-byte no-op)
				cpu_rb[]
				cycles = 2
			case 0x02  # COP — software interrupt (native: $FFE4, pushes PBR; emulation: $FFF4)
				cpu_rb[]
				cvec   : u16 [ (cpu.e) ? 0xFFF4 : 0xFFE4 ]
				cpu_swi[ cvec ]
				cycles = (cpu.e) ? 7 : 8
			case 0xCB  # WAI: halt CPU until the next interrupt; frame loop fast-forwards to NMI
				cpu_wai = true
				cycles = 3
			case 0xDB  # STP: processor halts until reset — re-execute forever (self-loop)
				cpu.pc -= 1
				cycles = 3
			case 0x54  # MVN (block move, ascending)
				dstb : u32 [ cpu_rb[] ]
				srcb : u32 [ cpu_rb[] ]
				cpu.dbr = dstb
				if [ env_pal ]
					dyy : u16 [ cpu.y | (cpu.yh << 8) ]
					if [ dyy >= 0x0500 && dyy <= 0x0540 ]
						sxx : u16 [ cpu.x | (cpu.xh << 8) ]
						printf[ "MVN->%04X src=%02X:%04X n=%04X firstbyte=%02X f%u pc=%04X\n",
							dyy, srcb, sxx, cpu.a | (cpu.b << 8), cpu_bank_r[ srcb, sxx ], dbg_frames, cpu.pc ]
						if [ dyy == 0x0520 && dbg_bad < 1 ]
							printf[ "  ---- 32 instrs before MVN->0520 ----\n" ]
							for [ k: i32 0, k < 32, k += 1 ]
								s2 : i32 [ (tr_i + k) % 32 ]
								printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[s2] >> 16, tr_addr[s2] & 0xFFFF, tr_b0[s2], tr_b1[s2], tr_b2[s2], tr_b3[s2], tr_p[s2], tr_a[s2], tr_x[s2], tr_y[s2] ]
							dbg_bad += 1
				if [ dbg_ev3 < 60 ]
					printf[ "f%u MVN src=%02X:%04X -> dst=%02X:%04X n=%04X\n", dbg_frames, srcb, cpu.x | (cpu.xh << 8), dstb, cpu.y | (cpu.yh << 8), cpu.a | (cpu.b << 8) ]
					dbg_ev3 += 1
				if [ dbg_frames >= 200 && dbg_bad < 2 ]
					printf[ "  ---- 32 instrs before this MVN (f%u) ----\n", dbg_frames ]
					for [ k: i32 0, k < 32, k += 1 ]
						s2 : i32 [ (tr_i + k) % 32 ]
						printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[s2] >> 16, tr_addr[s2] & 0xFFFF, tr_b0[s2], tr_b1[s2], tr_b2[s2], tr_b3[s2], tr_p[s2], tr_a[s2], tr_x[s2], tr_y[s2] ]
					dbg_bad += 1
				# ONE byte per step, like reference hardware: re-fetch opcode+operands each iteration (7 cycles/byte)
				# and rewind PC while the count remains — NMI/IRQ land BETWEEN bytes (interruptible)
				sx : u16 [ cpu.x | (cpu.xh << 8) ]
				dy : u16 [ cpu.y | (cpu.yh << 8) ]
				cpu_bank_w[ dstb, dy, cpu_bank_r[ srcb, sx ] ]
				nx : u16 [ (sx + 1) & 0xFFFF ]
				ny : u16 [ (dy + 1) & 0xFFFF ]
				if [ cpu.p & 0x10 ]              # 8-bit index: only the low bytes advance (reference hardware BlockMove8)
					cpu.x = nx & 0xFF
					cpu.y = ny & 0xFF
				el
					cpu.x = nx & 0xFF
					cpu.xh = nx >> 8
					cpu.y = ny & 0xFF
					cpu.yh = ny >> 8
				cnt : u16 [ cpu.a | (cpu.b << 8) ]
				nc : u16 [ (cnt - 1) & 0xFFFF ]
				cpu.a = nc & 0xFF
				cpu.b = nc >> 8
				if [ cnt != 0 ] cpu.pc -= 3        # count remains: re-execute this MVN next step
				cycles = 7
			case 0x44  # MVP (block move, descending)
				dstb : u32 [ cpu_rb[] ]
				srcb : u32 [ cpu_rb[] ]
				cpu.dbr = dstb
				# ONE byte per step, like reference hardware (see MVN above) — interruptible between bytes
				sx : u16 [ cpu.x | (cpu.xh << 8) ]
				dy : u16 [ cpu.y | (cpu.yh << 8) ]
				cpu_bank_w[ dstb, dy, cpu_bank_r[ srcb, sx ] ]
				nx : u16 [ (sx - 1) & 0xFFFF ]
				ny : u16 [ (dy - 1) & 0xFFFF ]
				if [ cpu.p & 0x10 ]              # 8-bit index: only the low bytes advance (reference hardware BlockMove8)
					cpu.x = nx & 0xFF
					cpu.y = ny & 0xFF
				el
					cpu.x = nx & 0xFF
					cpu.xh = nx >> 8
					cpu.y = ny & 0xFF
					cpu.yh = ny >> 8
				cnt : u16 [ cpu.a | (cpu.b << 8) ]
				nc : u16 [ (cnt - 1) & 0xFFFF ]
				cpu.a = nc & 0xFF
				cpu.b = nc >> 8
				if [ cnt != 0 ] cpu.pc -= 3        # count remains: re-execute this MVP next step
				cycles = 7

			case 0x67  # ADC [dp] (long indirect, width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				blo    : u32 [ cpu_r[dp] ]
				bmid   : u32 [ cpu_r[dp + 1] ]
				bbank  : u32 [ cpu_r[dp + 2] ]
				la     : u32 [ blo | (bmid << 8) | (bbank << 16) ]
				if [ cpu.p & 0x20 ]
					cpu_adc_a[ cpu_long_r[la] ]
				el
					cpu_adc_a[ cpu_long_r[la] | (cpu_long_r[la + 1] << 8) ]
				cycles = 6 + dpen + m1

			case 0x77  # ADC [dp],Y (long indirect indexed, width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				ylo    : u32 [ cpu_r[dp] ]
				ymid   : u32 [ cpu_r[dp + 1] ]
				ybank  : u32 [ cpu_r[dp + 2] ]
				yla    : u32 [ (ylo | (ymid << 8) | (ybank << 16)) + cpu_get_Y[] ]
				if [ cpu.p & 0x20 ]
					cpu_adc_a[ cpu_long_r[yla] ]
				el
					cpu_adc_a[ cpu_long_r[yla] | (cpu_long_r[yla + 1] << 8) ]
				cycles = 6 + dpen + m1

			case 0xB3  # LDA (d,S),Y (stack-relative indirect indexed, width-aware)
				sr     : u8  [ cpu_rb[] ]
				sa     : u16 [ (cpu.sp + sr) & 0xFFFF ]
				ptr    : u16 [ cpu_r[sa] | (cpu_r[sa + 1] << 8) ]
				addr   : u16 [ ptr + cpu_get_Y[] ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 7 + m1

			case 0x1F  # ORA long,X (width-aware)
				lo     : u32 [ cpu_rb[] ]
				hi     : u32 [ cpu_rb[] ]
				bank   : u32 [ cpu_rb[] ]
				laddr  : u32 [ (lo | (hi << 8) | (bank << 16)) + cpu_get_X[] ]
				if [ cpu.p & 0x20 ]
					cpu_set_A[ cpu_get_A[] | cpu_long_r[laddr] ]
				el
					m : u16 [ cpu_long_r[laddr] | (cpu_long_r[laddr + 1] << 8) ]
					cpu_set_A[ cpu_get_A[] | m ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 5 + m1

			default
				printf[ "unhandled cpu opcode %02X at %04X\n", opcode, cpu.pc - 1 ]
				fault 'unhandled cpu opcode — implement it then re-run (one at a time)'

		# charge the REMAINING internal cycles through cpu_idle so idles, DRAM refresh
		# and HDMA edges all interleave in true positional order (opcodes converted to
		# explicit cycle order have idle_done == their idle count; unconverted ops and
		# end-of-instruction idles land here — for those the idles really are last)
		rem_idle : i32 [ cycles - op_accesses - idle_done ]
		while [ rem_idle > 0 ]
			cpu_idle[]
			rem_idle -= 1
		count_cpu = false
		# does this instruction END with an internal (non-bus) cycle? reference hardware runs idleIRQ() there:
		# implied ops (single fetch access) and TAKEN branches (final branch idle; cycles>=3)
		nmi_iend = (op_accesses == 1) || (cycles >= 3 && (opcode == 0x10 || opcode == 0x30 || opcode == 0x50 || opcode == 0x70 || opcode == 0x80 || opcode == 0x90 || opcode == 0xB0 || opcode == 0xD0 || opcode == 0xF0 || opcode == 0x82)) || opcode == 0x60 || opcode == 0x44 || opcode == 0x54 || opcode == 0xC2 || opcode == 0xE2
		nmi_conv = (op_accesses == 1) && (cycles == 2)
		irq_cli  = (opcode == 0x58)
		nmi_lastop = opcode
		if [ env_acclog && ct_on ] printf[ "ACC op=%02X acc=%d cyc=%d m=%d dl=%d\n", opcode, op_accesses, cycles, (is_16bit) ? 1 : 0, (ualign) ? 1 : 0 ]
		# real master cycles = sum of access speeds + internal/idle cycles (6 master each).
		# idle = total opcode cycle count minus the memory accesses we actually performed.
		# each opcode's `cycles` is the exact reference hardware total (accesses + idles); 16-bit RMW ops
		# carry their +2 explicitly in their own case, so no blanket adjustment is needed here.
		idle : i32 [ 0 ]                     # all internal cycles were charged in place via cpu_idle
		instr_master : i32 [ op_master + steal_master ]
		# DRAM refresh: reference hardware stalls the CPU 40 master at hcounter 530 of every scanline.
		# Charge it to whichever instruction spans that master point (continuous frame_master
		# clock, no rounding) so the cumulative — and thus interrupt timing — matches reference hardware at
		# every instruction boundary.
		while [ refresh_line < 262 ]
			rp : i32 [ refresh_rp[ refresh_line ] ]
			if [ (frame_master + instr_master) < rp ] break
			instr_master += 40
			refresh_line += 1
		spc.cycle_accum += i64[ instr_master - op_master ] * 128160   # SPC also runs through this instruction's idle/steal/refresh master, not just its accesses (i64 cast: big-DMA instr_master*128160 exceeds i32)
		frame_master += instr_master
		master_phase = (master_phase + instr_master) & 7      # monotonic master phase for DMA sync
		tm : i32 [ instr_master + cpu_master_rem ]
		steal_master   = 0
		rc : i32 [ tm / 6 ]
		cpu_master_rem = tm - rc * 6        # carry sub-cpu-cycle remainder so accounting stays exact
		return rc

# standalone host: a thin trinity app that mounts the asnes element
# full-window. every emulator property lives ON the element — the app only
# carries the CLI surface and forwards it each frame.
trinity asnes_app
	public  emu     : asnes            # auto-binds to the live 'emu' element
	public  rom     : path
	public  spc_rom : path
	public  state   : path
	# forwarded props are re-applied to the element every frame (af-bit
	# reconcile), so the app must carry the REAL default — forwarding 0.0
	# would permanently override the element's own volume guard (silence)
	public  volume  : f32 [ 0.22 ]
	public  smooth  : bool [ true ]
	public  vec     : bool [ true ]
	public  se_2d   : bool
	public  blocky  : bool
	public  vec_m7  : bool
	public  putest  : bool
	public  spctest : bool
	public  beep    : bool
	public  spcfile : path

	func init []
		width      = 1024
		height     = 896
		background = 'Background'

	# keys land on the app when no element holds focus — hand them to the emu
	public func on_key [ ev: Event ]
		if [ emu ] emu.on_key[ ev ]

	func on_render [ w: Window ] -> Elements
		e : Elements [ ]
		e['emu'] = asnes [ rom: rom, spc_rom: spc_rom, state: state, volume: volume, smooth: smooth, vec: vec, se_2d: se_2d, blocky: blocky, vec_m7: vec_m7, putest: putest, spctest: spctest, beep: beep, spcfile: spcfile ]
		return e
