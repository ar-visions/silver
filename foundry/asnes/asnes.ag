			case 0x72  # ADC (dp) (width-aware)
				dp     : u8  [ cpu_rb[] ]
				addr   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cpu_adc_a[ cpu_read_mem[addr] ]
				cycles = 5

			case 0x76  # ROR dp,X (width-aware RMW)
				addr   : u8 [ (cpu_rb[] + cpu.x) & 0xFF ]
				cpu_write_mem[ addr, cpu_ror_v[ cpu_read_mem[addr] ] ]
