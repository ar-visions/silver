				cpu_idle[]
				cpu_sp_inc[]
				rlo    : u16 [ cpu_r[cpu.sp] ]
				cpu_sp_inc[]
				rhi    : u16 [ cpu_r[cpu.sp] ]
				cpu_sp_inc[]
				cpu.pbr = cpu_r[cpu.sp]
				cpu.pc  = (rlo | (rhi << 8)) + 1
				cycles = 6

			case 0xDC  # JML [abs] (jump long, absolute indirect)
				jptr   : u16 [ cpu_rw[] ]
				jlo    : u16 [ cpu_r[jptr] ]
				jhi    : u16 [ cpu_r[jptr + 1] ]
				jbank  : u8  [ cpu_r[jptr + 2] ]
				cpu.pc  = jlo | (jhi << 8)
				cpu.pbr = jbank
