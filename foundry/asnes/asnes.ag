				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_asl_v[ cpu_read_mem[addr] ] ]
				cycles = 7

			case 0x56  # LSR dp,X
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_lsr_v[ cpu_read_dp[addr] ] ]
				cycles = 6

			case 0x5E  # LSR abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_lsr_v[ cpu_read_mem[addr] ] ]
				cycles = 7

			case 0x36  # ROL dp,X
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_rol_v[ cpu_read_dp[addr] ] ]
				cycles = 6

			case 0x3E  # ROL abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_rol_v[ cpu_read_mem[addr] ] ]
				cycles = 7

			case 0x7E  # ROR abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_ror_v[ cpu_read_mem[addr] ] ]
				cycles = 7

			case 0x0E  # ASL abs
				addr   : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_asl_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x2E  # ROL abs
				addr   : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_rol_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x4E  # LSR abs
				addr   : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_lsr_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x6E  # ROR abs
				addr   : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_ror_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x07  # ORA [dp]
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_ora_a[ cpu_read_long_dp[dp] ]
				cycles = 7
			case 0x27  # AND [dp]
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_and_a[ cpu_read_long_dp[dp] ]
				cycles = 7
			case 0x47  # EOR [dp]
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_eor_a[ cpu_read_long_dp[dp] ]
				cycles = 7
