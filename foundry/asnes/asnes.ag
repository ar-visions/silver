			case 0xDC  # JML [abs] (jump long, absolute indirect)
				jptr   : u16 [ cpu_rw[] ]
				jlo    : u16 [ cpu_r[jptr] ]
				jhi    : u16 [ cpu_r[jptr + 1] ]
				jbank  : u8  [ cpu_r[jptr + 2] ]
				cpu.pc  = jlo | (jhi << 8)
				cpu.pbr = jbank
				cycles  = 6

			case 0x5C  # JML long (jump long, absolute)
				clo    : u32 [ cpu_rb[] ]
				chi    : u32 [ cpu_rb[] ]
				cbank  : u8  [ cpu_rb[] ]
				cpu.pc  = clo | (chi << 8)
				cpu.pbr = cbank
				cycles  = 4

			case 0xB2  # LDA (dp) (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				addr   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 5

			case 0x92  # STA (dp) (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				addr   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 5

			case 0x75  # ADC dp,X (width-aware)
				addr   : u16  [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				cpu_adc_a[ cpu_read_dp[addr] ]
				cycles = 4

			case 0x73  # ADC (d,S),Y (stack-relative indirect indexed, width-aware)
				sr2    : u8  [ cpu_rb[] ]
				sa2    : u16 [ (cpu.sp + sr2) & 0xFFFF ]
				p2     : u16 [ cpu_r[sa2] | (cpu_r[sa2 + 1] << 8) ]
				a2     : u16 [ p2 + cpu_get_Y[] ]
				cpu_adc_a[ cpu_read_mem[a2] ]
				cycles = 7

			case 0x72  # ADC (dp) (width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				addr   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cpu_adc_a[ cpu_read_mem[addr] ]
				cycles = 5

			case 0x76  # ROR dp,X (width-aware RMW)
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_ror_v[ cpu_read_dp[addr] ] ]
				cycles = 6

			case 0x16  # ASL dp,X
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_asl_v[ cpu_read_dp[addr] ] ]
				cycles = 6

