				cpu_idle[]
				cpu_write_mem[ addr, cpu_asl_v[ rv_ ] ]
				cycles = 6 + ((is_16bit) ? 2 : 0)

			case 0x2E  # ROL abs
				addr   : u16 [ cpu_rw[] ]
				rv_ : u16 [ cpu_read_mem[addr] ]
				cpu_idle[]
				cpu_write_mem[ addr, cpu_rol_v[ rv_ ] ]
				cycles = 6 + ((is_16bit) ? 2 : 0)

			case 0x4E  # LSR abs
				addr   : u16 [ cpu_rw[] ]
