	mutable spr_m2y        	: i32
	mutable spr_anchor     	: i32               # plane the sprite population follows: 0=BG1 1=BG2
	mutable lay_out        	: ref u32           # ppu_bg_line layer target (valid when lay_en)
	mutable lay_en         	: bool              # ppu_bg_line writes to lay_out, not the composed planes
	mutable lay_bg1        	: new u32 [ 73728 ] # provenance layers, 288x256: 16px overscan bleed
	mutable lay_bg2        	: new u32 [ 73728 ]
	mutable lay_bg3        	: new u32 [ 73728 ]
	mutable lay_sw         	: new u32 [ 57344 ] # world sprites (ride BG1)
	mutable lay_ss         	: new u32 [ 57344 ] # screen sprites (pinned)
