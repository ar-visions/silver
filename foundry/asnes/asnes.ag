				cpu_idle[]
				cpu_write_mem[ addr, val8 | a16 ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 6 + ((is_16bit) ? 2 : 0)

			case 0x64  # STZ dp
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_write_dp[ dp, 0 ]
				cycles = 3 + dpen + m1

			case 0x74  # STZ dp,X
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				cpu_idle[]
				cpu_write_dp[ (dp + cpu_get_X[]) & 0xFFFF, 0 ]
				cycles = 4 + dpen + m1

			case 0x9C  # STZ abs
				addr : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, 0 ]
				cycles = 4 + m1

			case 0x9E  # STZ abs,X
				addr : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_idle[]
				cpu_write_mem[ addr, 0 ]
				cycles = 5 + m1

			case 0xFF  # SBC long,X
				cpu_sbc_a[ cpu_read_long_x[] ]
				cycles = 5 + m1

			case 0x22  # JSL (jump subroutine long)
				lo     : u32 [ cpu_rb[] ]
				hi     : u32 [ cpu_rb[] ]
				nbank  : u8  [ cpu_rb[] ]
				ret    : u16 [ cpu.pc - 1 ]
				cpu_w[ cpu.sp, cpu.pbr ]
				cpu_sp_dec[]
				cpu_idle[]
				cpu_w[ cpu.sp, u8[ret >> 8] ]
				cpu_sp_dec[]
				cpu_w[ cpu.sp, u8[ret & 0xFF] ]
				cpu_sp_dec[]
				cpu.pbr = nbank
				cpu.pc  = lo | (hi << 8)
				cycles = 8

			case 0x6B  # RTL (return subroutine long)
