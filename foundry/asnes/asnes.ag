				cycles = 5 + dpen + ((is_16bit) ? 2 : 0)

			case 0x0C  # TSB abs
				addr   : u16 [ cpu_rw[] ]
				val8  : u16 [ cpu_read_mem[addr] ]
				a16    : u16 [ cpu_get_A[] ]
