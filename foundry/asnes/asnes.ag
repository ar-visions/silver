					cpu.sp += 1
					cpu.pbr = cpu_r[cpu.sp]
				cycles  = 6

			case 0x00  # BRK
				cpu.pc += 1
				cpu_w[ cpu.sp, u8[cpu.pc >> 8] ]
				cpu.sp -= 1
				cpu_w[ cpu.sp, u8[cpu.pc & 0xFF] ]
				cpu.sp -= 1
				cpu_w[ cpu.sp, cpu.p | 0x10 ]
				cpu.sp -= 1
				cpu.p  |= 0x04
