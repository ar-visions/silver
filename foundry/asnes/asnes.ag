# asnes: an SNES emulator based on Au schema
# this is meant as an educational device, and one to get people writing 
# software for the greatest system ever made
export 0.8.8

import trinity
import img
import vec
import <alsa/asoundlib.h>
import <time.h>
import <pthread.h>
	-lasound
import <math.h>
import <stdio.h>
import <stdlib.h>
import <string.h>


struct dsp_channel
	pos       		: u16
	frac      		: u16
	samples   		: local i16 [ 4 ]
	envelope  		: i16            # current envelope, 0..0x7FF
	env_state 		: u8             # 0=attack 1=decay 2=sustain 3=release
	env_count 		: i32            # per-voice rate counter
	active    		: u8             # voice is producing output
	output_l  		: f32
	output_r  		: f32


class spc_state
	pc             	: u16
	a              	: u8
	x              	: u8
	y              	: u8
	sp             	: u8
	psw            	: u8
	direct_page    	: u8
	ports          	: new u8 [ 4 ]              # SPC-visible APU input (committed)
	in_stage       	: new u8 [ 4 ]              # CPU writes here; committed to ports on CPU read (atomic)
	oports         	: new u8 [ 4 ]
	oports_prev    	: new u8 [ 4 ]      # value before the last write (returned if the write's clock is past the CPU read's clock)
	oports_ts      	: new i64 [ 4 ]     # SPC-clock (spc.pos) at which each port was last written
	iports_ts      	: new i64 [ 4 ]     # CPU-clock (spc.pos+cycle_accum) at which the CPU last wrote each input port; SPC read returns in_stage (pre-write) if this is in the SPC's future
	pos            	: i64               # monotonic SPC position in accum units (advances per SPC opcode)
	echo_pos       	: u16
	echo_history_l 	: f32
	echo_history_r 	: f32
	fir_hist_l     	: new f32 [ 8 ]
	fir_hist_r     	: new f32 [ 8 ]
	fir_idx        	: i32
	lp_l           	: f32              # output low-pass state (SNES soft rolloff)
	lp_r           	: f32
	channels       	: new dsp_channel [ 8 ]
	dsp            	: new u8 [ 128 ]
	pcm_handle     	: ref snd_pcm_t
	audio_buffer   	: ref i16
	buffer_size    	: sz
	sample_rate    	: i32
	cycle_accum    	: i64               # SPC clock balance vs CPU, EXACT reference hardware ratio 128160:2684659 (=2050560:42954544; APU crystal is 24606720Hz = 32040*768, NOT nominal 24576000); i64 so big-DMA instr_master*128160 can't overflow
	audio_done     	: i32               # samples emitted into audio_buffer this frame (shared by port-read drain + bulk pass)
	audio_sub      	: i32               # SMP-cycle sub-counter toward the next 32-cycle sample
	op_cyc         	: i32               # SMP cycles consumed by the current SPC instruction (base + branch-taken)
	timer_on       	: u8                # $F1 bits 0-2: timer enables
	timer_target   	: new u8 [ 3 ]      # $FA-$FC dividers (0 => 256)
	timer_count    	: new u8 [ 3 ]      # $FD-$FF 4-bit output counters
	timer_stage    	: new i32 [ 3 ]     # internal pre-divider accumulators
	tcyc           	: i32               # SPC cycle accumulator for timers
	kon_latch      	: u8                # KON bits written since last DSP sample
	koff_latch     	: u8                # KOFF bits written since last DSP sample
	ram            	: new u8 [ 0x10000 ]

# --- SNES PPU (5C77 "PPU1" tile/BG/sprite fetch + 5C78 "PPU2" color math/output) ---
class ppu_state
	vram        	: new u8 [ 0x10000 ]    # 32K words, byte-addressed as word*2 + sel
	cgram       	: new u8 [ 0x200 ]      # 256 colors x 2 bytes (BGR555)
	oam         	: new u8 [ 0x220 ]      # 512 main + 32 high
	vram_shot   	: new u8 [ 0x10000 ]    # VRAM latched at end of active display (games stream OBJ tiles in vblank)
	cgram_shot  	: new u8 [ 0x200 ]      # CGRAM latched at end of active display
	oam_shot    	: new u8 [ 0x220 ]      # OAM latched at end of active display
	inidisp_shot	: u8                    # INIDISP (brightness/force-blank) latched at end of active display
	framebuf    	: new u32 [ 256 * 224 ] # RGBA8 output
	obj_color   	: new u32 [ 256 * 224 ] # sprite layer: resolved color (0 = transparent)
	obj_prio    	: new u8  [ 256 * 224 ] # sprite layer: per-pixel OBJ priority (0-3)
	obj_bgr     	: new u16 [ 256 * 224 ] # sprite layer: BGR555 color (for color math)
	obj_idx     	: new u8  [ 256 * 224 ] # sprite layer: OAM index of the winning sprite (world/screen split)
	px_bgr      	: new u16 [ 256 * 224 ] # top main-screen pixel BGR555 (pre-brightness, for color math)
	px_src      	: new u8  [ 256 * 224 ] # source layer per pixel: 0-3=BG1-4, 5=OBJ, 8=backdrop
	sub_bgr     	: new u16 [ 256 * 224 ] # top SUB-screen pixel BGR555 (for color-math subscreen blend)
	sub_src     	: new u8  [ 256 * 224 ] # sub-screen source layer per pixel (8=COL/fixed backdrop)
	inidisp     	: u8                    # $2100 brightness(0-3) + forced-blank(bit7)
	obsel       	: u8                    # $2101 sprite size + name base
	bgmode      	: u8                    # $2105 BG mode (bits0-2) + per-BG tile size
	mosaic      	: u8                    # $2106
	bg_sc       	: new u8 [ 4 ]          # $2107-A tilemap base/size per BG
	bg_nba      	: new u8 [ 2 ]          # $210B/C char-data base nibbles (BG1/2, BG3/4)
	bg_hofs     	: new u16 [ 4 ]         # $210D.. H scroll per BG (10/13-bit)
	bg_vofs     	: new u16 [ 4 ]         # V scroll per BG
	ofs_latch   	: u8                    # shared write-twice prev byte for scroll
	ofs_hl      	: new u8 [ 8 ]          # per-scroll-reg low/high toggle
	vmain       	: u8                    # $2115 VRAM address increment control
	vram_addr   	: u16                   # $2116/7 word address
	vram_pre    	: u16                   # read prefetch latch
	cgadd       	: u8                    # $2121 CGRAM word address
	cg_latch    	: u8                    # CGRAM first-byte hold
	cg_toggle   	: bool
	oamadd      	: u16                   # $2102/3 OAM word address (internal byte ptr = *2)
	oamadd_reload	: u16
	oam_latch   	: u8
	oam_toggle  	: bool
	ophct       	: u16                   # $213C latched H counter (dot)
	opvct       	: u16                   # $213D latched V counter (line)
	ophct_tog   	: bool                  # OPHCT low/high read toggle
	opvct_tog   	: bool                  # OPVCT low/high read toggle
	hv_latched  	: bool                  # STAT78 bit6: counters latched via $2137
	tm          	: u8                    # $212C main-screen layer enable
	ts          	: u8                    # $212D sub-screen layer enable
	w12sel      	: u8                    # $2123 BG1/2 window mask sel
	w34sel      	: u8                    # $2124 BG3/4 window mask sel
	wobjsel     	: u8                    # $2125 OBJ/color window sel
	wh0         	: u8                    # $2126 window1 left
	wh1         	: u8                    # $2127 window1 right
	wh2         	: u8                    # $2128 window2 left
	wh3         	: u8                    # $2129 window2 right
	wbglog      	: u8                    # $212A BG window mask logic
	wobjlog     	: u8                    # $212B OBJ window mask logic
	tmw         	: u8                    # $212E window mask main-screen disable
	tsw         	: u8                    # $212F window mask sub-screen disable
	cgwsel      	: u8                    # $2130
	cgadsub     	: u8                    # $2131
	coldata     	: u16                   # $2132 fixed color (BGR555, built per channel)
	setini      	: u8                    # $2133
	m7a         	: i16                   # $211B Mode 7 matrix A (1.7.8 fixed)
	m7b         	: i16                   # $211C matrix B
	m7c         	: i16                   # $211D matrix C
	m7d         	: i16                   # $211E matrix D
	m7x         	: i16                   # $211F center X (13-bit)
	m7y         	: i16                   # $2120 center Y
	m7hofs      	: i16                   # $210D Mode 7 H scroll (13-bit)
	m7vofs      	: i16                   # $210E Mode 7 V scroll
	m7sel       	: u8                    # $211A flip(0,1) + repeat(6,7)
	m7_latch    	: u8                    # shared write-twice latch for M7 regs


class cpu_state
	public pc     			: u16
	public a      			: u8
	public x      			: u8
	public y      			: u8
	public sp     			: u16
	public p      			: u8
	public dp     			: u16
	public dbr    			: u8
	public pbr    			: u8
	public e      			: bool
	public b      			: u8
	public xh     			: u8
	public yh     			: u8
	public ports  			: new u8 [ 4 ]
	public memory 			: ref u8


# SNES Mode 7 affine layer, rendered on the GPU as a textured fullscreen quad.
# 'src' = the unpacked 1024x1024 (128x128 tiles * 8px) Mode-7 plane, palette
# already applied (alpha 0 = transparent pixel). 'mat' = a 256x1 rgba32f texture
# whose texel y holds that scanline's precomputed affine { originX, originY, a, c }
# (exactly what ppu_m7_line computes on the CPU). The fragment shader does the
# per-pixel affine + samples the plane; bracketing-scanline coefficient lerp gives
# a smooth horizon the discrete CPU/hardware path can't. See project_asnes_mode7_vulkan.
enum Mode7Surface
	src : 0
	mat : 1

ModelViewProject Mode7
	mutable params : vec4f          # x=hflip, y=vflip, z=repeat-mode(0/1 wrap,2 transp,3 char0), w=0

	attrib src : LayoutBinding [ type:typeid[ Mode7Surface ], id:Mode7Surface.src, count:1, format: typeid[ rgba8 ] ]
	attrib mat : LayoutBinding [ type:typeid[ Mode7Surface ], id:Mode7Surface.mat, count:1, format: typeid[ rgbaf ] ]

	attrib pos       : VertexInput    [ type:typeid[ vec3f ] ]
	attrib uv        : VertexInput    [ type:typeid[ vec2f ] ]
	attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
	attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

	func init [ ]
		model = mat4f.identity[]
		eye:    vec3f [ 0.0, 0.0, 2.0 ]
		center: vec3f [ 0.0, 0.0, 0.0 ]
		up:     vec3f [ 0.0, 1.0, 0.0 ]
		view  = mat4f.look_at[ eye, center, up ]
		proj  = mat4f.ortho[ -1, 1, -1, 1, 0.1, 10.0 ]

	func vertex [] -> GLSL none {
		v_uv        = uv;
		gl_Position = vec4(pos.x, pos.y, 0.0, 1.0);
	}

	func fragment [] -> GLSL none {
		float sy = v_uv.y * 224.0;                       // SNES scanline (continuous)
		float sx = v_uv.x * 256.0;                       // pixel within the line
		if (ubo.params.x > 0.5) sx = 255.0 - sx;         // hflip
		// per-scanline affine coeffs, lerped between bracketing scanlines
		float y0 = floor(sy);
		float fy = sy - y0;
		int   iy = int(y0);
		vec4  m0 = texelFetch(mat, ivec2(iy,                  0), 0);   // {originX, originY, a, c}
		vec4  m1 = texelFetch(mat, ivec2(min(iy + 1, 223),   0), 0);
		vec4  m  = mix(m0, m1, fy);
		float px = (m.x + m.z * sx) / 256.0;             // plane pixelX
		float py = (m.y + m.w * sx) / 256.0;             // plane pixelY
		int   rep = int(ubo.params.z + 0.5);
		bool  oob = (px < 0.0 || px >= 1024.0 || py < 0.0 || py >= 1024.0);
		if (rep == 2 && oob) { fragColor = vec4(0.0); return; }
		vec2 raw = vec2(px, py) / 1024.0;
		vec2 ddx = dFdx(raw);
		vec2 ddy = dFdy(raw);
		vec2 uv2 = fract(raw);
		fragColor = textureGrad(src, uv2, ddx, ddy);
		// per-scanline color math on the plane (reference hardware CGADSUB on BG1
		// gated by the HDMA'd color window): row 1 = {wh0,wh1,wh2,wh3}, row 2 =
		// {flags, coldata r,g,b}. This is how the distance fog AND the craft
		// shadow (an ellipse traced per line in WH0/WH1) darken the plane.
		vec4 f1 = mix(texelFetch(mat, ivec2(iy, 1), 0), texelFetch(mat, ivec2(min(iy + 1, 223), 1), 0), 0.0);
		vec4 f2 = texelFetch(mat, ivec2(iy, 2), 0);
		int flags = int(f2.x + 0.5);
		int region = (flags >> 6) & 3;
		if (region != 3) {
			float wx = v_uv.x * 256.0;             // window applies to SCREEN x (pre-hflip)
			bool in1 = (wx >= f1.x && wx <= f1.y + 1.0);
			bool in2 = (wx >= f1.z && wx <= f1.w + 1.0);
			if ((flags & 2) != 0) in1 = !in1;
			if ((flags & 8) != 0) in2 = !in2;
			bool w1en = (flags & 1) != 0;
			bool w2en = (flags & 4) != 0;
			int lgc = (flags >> 4) & 3;
			bool w = false;
			if (w1en && !w2en) w = in1;
			else if (!w1en && w2en) w = in2;
			else if (w1en && w2en) w = (lgc == 0) ? (in1 || in2) : (lgc == 1) ? (in1 && in2) : (lgc == 2) ? (in1 != in2) : (in1 == in2);
			bool apply = (region == 0) || (region == 1 && w) || (region == 2 && !w);
			if (apply) {
				vec3 cold = f2.yzw / 31.0;
				vec3 c = ((flags & 256) != 0) ? fragColor.rgb - cold : fragColor.rgb + cold;
				if ((flags & 512) != 0) c *= 0.5;
				fragColor.rgb = clamp(c, 0.0, 1.0);
			}
			//fragColor.rgb = fragColor.bgr;
		}
	}


element asnes
	public  spc_rom        	: path
	public  rom            	: path
	public  state          	: path             # --state <file>: boot then load this savestate
	public  beep           	: bool
	public  spcfile        	: path
	public  spctest        	: bool
	public  putest         	: bool             # display-pipeline test: CPU buffer -> Texture -> screen
	public  volume         	: f32              # playback volume 0..1 (adjustable; default 0.22)
	mutable screen_tex     	: Texture
	# --- Mode 7 GPU path (Vulkan affine quad; see project_asnes_mode7_vulkan) ---
	mutable m7_src         	: Texture          # 1024x1024 RGBA: unpacked Mode-7 plane (palette applied)
	mutable m7_mat         	: Texture          # 256x1 rgba32f: per-scanline { originX, originY, a, c }
	mutable m7_buf         	: new u32 [ 1024 * 1024 ]   # CPU staging for m7_src
	mutable m7_matbuf      	: new f32 [ 768 * 4 ]       # CPU staging for m7_mat: row 0 = affine, row 1 = window bounds, row 2 = math flags + coldata
	mutable m7_shader      	: Mode7
	mutable m7_model       	: Model
	mutable m7_render      	: Render
	mutable m7_buf2x       	: new u32 [ 2048 * 2048 ]   # vec_m7: corner-cut 2x of m7_buf, baked at unpack (CPU — no GPU sync hazards)
	public  m7_gpu         	: bool [ true ]    # render the Mode-7 plane on the GPU (CPU path leaves it transparent)
	mutable m7_vhash       	: i64              # last unpacked Mode-7 VRAM hash (skip re-unpack when unchanged)
	mutable m7_bri_cache   	: i32 [ -1 ]       # brightness baked into the cached m7_src
	mutable frame_m7x      	: i16              # m7x/m7y latched at frame start (active for THIS frame's
	mutable frame_m7y      	: i16              # display) so the center aligns with the HDMA'd m7 scroll
	mutable is_hirom       	: bool             # HiROM mapping (banks $40-$7D/$C0-$FF are full ROM, no WRAM mirror)
	# --- 2D post-effect pass (Super Eagle pixel-art upscale of the sprite/HUD layer) ---
	mutable se_shader      	: SuperEagle
	mutable se_model       	: Model
	mutable se_render      	: Render
	public  vec            	: bool [ true ]    # VectorScale: continuous edges, any zoom
	public  se_2d          	: bool             # Super Eagle 2x basis + sharp lift (pass --vec false)
	public  blocky         	: bool             # sharp-bilinear hard squares
	public  vec_m7         	: bool             # VectorScale the Mode-7 plane too (on top of its aniso sampling)
	mutable save_req       	: bool             # 'P' key -> save savestate next frame
	mutable load_req       	: bool             # 'L' key -> load savestate next frame
	mutable state_loaded   	: bool             # --state boot-load done
	mutable post_load      	: i32              # frames elapsed since --state load (for instant capture)
	mutable test_buf       	: new u32 [ 256 * 224 ]
	mutable test_t         	: i32
	mutable hdma_addr      	: new u16 [ 8 ]         # A2A table running pointer per channel
	mutable hdma_line      	: new u8  [ 8 ]         # line counter per channel
	mutable hdma_ind       	: new u16 [ 8 ]         # indirect data address per channel
	mutable hdma_do        	: new u8  [ 8 ]         # do-transfer flag per channel
	mutable hdma_done      	: new u8  [ 8 ]         # channel completed for this frame
	mutable line_mode      	: new u8  [ 224 ]       # per-scanline BGMODE snapshot
	mutable line_tm        	: new u8  [ 224 ]       # per-scanline TM snapshot
	mutable line_ts        	: new u8  [ 224 ]       # per-scanline TS (sub-screen layer enable) snapshot
	mutable line_h         	: new u16 [ 4 * 224 ]   # per-scanline H scroll, [bg*224+y]
	mutable line_v         	: new u16 [ 4 * 224 ]   # per-scanline V scroll
	mutable line_m7a       	: new i16 [ 224 ]       # per-scanline Mode 7 matrix (HDMA'd)
	mutable line_m7b       	: new i16 [ 224 ]
	mutable line_m7c       	: new i16 [ 224 ]
	mutable line_m7d       	: new i16 [ 224 ]
	mutable line_coldata   	: new u16 [ 224 ]       # per-scanline COLDATA (HDMA'd fog color)
	mutable line_cgadsub   	: new u8  [ 224 ]       # per-scanline CGADSUB (color-math enable/mode)
	mutable line_cgwsel    	: new u8  [ 224 ]       # per-scanline CGWSEL (color-math region select)
	mutable line_wobjsel   	: new u8  [ 224 ]       # per-scanline WOBJSEL (color window enable/invert)
	mutable line_wobjlog   	: new u8  [ 224 ]       # per-scanline WOBJLOG (color window combine logic)
	mutable line_wh0       	: new u8  [ 224 ]       # per-scanline window1 left  (HDMA'd)
	mutable line_wh1       	: new u8  [ 224 ]       # per-scanline window1 right
	mutable line_wh2       	: new u8  [ 224 ]       # per-scanline window2 left
	mutable line_wh3       	: new u8  [ 224 ]       # per-scanline window2 right
	mutable line_tmw       	: new u8  [ 224 ]       # per-scanline TMW (BG window main-screen disable)
	mutable line_tsw       	: new u8  [ 224 ]       # per-scanline TSW (BG window sub-screen disable)
	mutable line_w12sel    	: new u8  [ 224 ]       # per-scanline W12SEL (BG1/2 window enable/invert)
	mutable line_w34sel    	: new u8  [ 224 ]       # per-scanline W34SEL (BG3/4 window enable/invert)
	mutable line_wbglog    	: new u8  [ 224 ]       # per-scanline WBGLOG (BG window1/2 combine logic)
	mutable line_inidisp   	: new u8  [ 224 ]       # per-scanline INIDISP (ff3 blanks at line 215 for early vblank work and restores brightness in vblank — one global sample reads 80 and blacked the frame)
	mutable line_bgsc      	: new u8  [ 896 ]       # per-scanline BGxSC tilemap base (ff3 HDMAs $2107 inside dialog boxes: BG1 base 48->40 points at the blank dialog tilemap; frame-global base drew the map inside the box)
	mutable line_nba       	: new u8  [ 448 ]       # per-scanline BG12NBA/BG34NBA char base (render-time live read raced vblank writes: ff3 battle BG1 char base fetched from the menu value -> font checkerboard)
	mutable cpu            	: cpu_state
	mutable spc            	: spc_state
	mutable ppu            	: ppu_state
	mutable spc_rom_loaded 	: bool
	mutable spc_boot_rom   	: ref u8
	mutable nmitimen       	: u8
	mutable nmi_occurred   	: bool
	mutable wram_addr      	: u32               # $2181-3 WMADD 17-bit WRAM pointer for $2180
	mutable mpya           	: u8                # $4202 WRMPYA
	mutable mpyb           	: u8                # $4203 WRMPYB (write triggers multiply)
	mutable wrdiv          	: u16               # $4204/5 WRDIV dividend
	mutable rddiv          	: u16               # $4214/5 RDDIV quotient
	mutable rdmpy          	: u16               # $4216/7 RDMPY product / remainder
	mutable mdr            	: u8                # CPU memory data register (open-bus value), for $4210-$4212 unused bits
	mutable pad1           	: u16               # controller 1 button bitfield (B Y Sel St U D L R A X L R)
	mutable joy_strobe     	: u8                # $4016 strobe latch
	mutable joy_index      	: i32               # $4016 serial read bit index
	mutable htime          	: u16               # $4207/8 H-IRQ trigger position (0-339)
	mutable vtime          	: u16               # $4209/A V-IRQ trigger scanline (0-261)
	mutable irq_occurred   	: bool              # $4211 TIMEUP bit7 (set on IRQ fire, cleared on read)
	mutable frame_cycle    	: i32               # CPU cycles elapsed in the current frame
	mutable frame_carry    	: i32               # CPU cycles a DMA overshot past the frame budget, stalling the CPU into the next frame
	mutable frame_master   	: i32               # cumulative master clocks this frame (continuous clock for dot-exact DRAM refresh, like reference hardware; max ~357366 fits i32)
	mutable refresh_line   	: i32               # next DRAM-refresh scanline pending this frame (0-261)
	mutable use_shot       	: bool              # renderer reads the end-of-active-display VRAM/OAM/CGRAM snapshot, not live state
	mutable shot_valid     	: bool              # a VRAM/OAM/CGRAM snapshot has been taken this session
	mutable in_vblank      	: bool              # PPU vblank flag ($4212 bit7), real rising/falling edge
	mutable cpu_wai        	: bool              # CPU halted on WAI until next interrupt
	mutable dbg_frames     	: u32
	mutable master_phase   	: i32               # monotonic master clock mod 8 — DMA 8-master sync phase (reference hardware counter.cpu & 7)
	mutable nmi_frames     	: u32               # NMI-fired frame count, matches reference hardware g_frame
	mutable cpu_cycles     	: i64               # total CPU cycles from reset (shared cycle-index baseline)
	mutable cpu_fastrom    	: bool              # $420D bit0: banks $80-FF run at 6 master when set
	mutable count_cpu      	: bool              # gate: only count cycles for real CPU instruction/interrupt accesses
	mutable op_master      	: i32               # master cycles of memory accesses in the current instruction
	mutable op_accesses    	: i32               # memory access count in the current instruction (for idle derivation)
	mutable cpu_master_rem 	: i32               # carried master-cycle remainder (keeps cpu-cycle accounting exact)
	mutable steal_master   	: i32               # master cycles stolen by DMA/HDMA/DRAM-refresh, folded into next instruction
	mutable dma_pending    	: i32               # deferred GP-DMA channel mask ($420B); DMA runs at next instr's post-opcode point (reference hardware dmaEdge defers ~2 bus accesses)
	mutable dbg_pr         	: i64               # diagnostic: count of APU-port reads before first NMI
	mutable rendering_sub  	: bool              # ppu_bg_line target: true = sub-screen buffers, false = main
	mutable dbg_cpu        	: i32
	mutable dbg_h          	: i32
	mutable dbg_kon        	: i32
	mutable dbg_slast      	: u16
	mutable dbg_bad        	: i32
	mutable port_read      	: bool              # set when the CPU reads an APU port; gates SPC catch-up
	mutable dbg_spc        	: i32               # NMI fire counter (debug)
	mutable dbg_ev         	: i32               # capped rendezvous event log counter
	mutable dbg_ev2        	: i32               # capped: CPU port writes
	mutable dbg_ev3        	: i32               # capped: IPL handshake region
	mutable tr_addr        	: new u32 [32]      # instruction ring buffer (pbr<<16|pc)
	mutable tr_b0          	: new u8 [32]
	mutable tr_b1          	: new u8 [32]
	mutable tr_b2          	: new u8 [32]
	mutable tr_b3          	: new u8 [32]
	mutable tr_p           	: new u16 [32]
	mutable tr_a           	: new u16 [32]
	mutable tr_x           	: new u16 [32]
	mutable tr_y           	: new u16 [32]
	mutable tr_i           	: i32
	mutable tr_done        	: bool
	mutable last_rd        	: u32               # last data-read effective 24-bit address
	mutable dbg_w          	: i32               # capped: WRAM $1F0x watch
	mutable dbg_w2         	: i32               # capped: Mode7 map staging watch
	mutable dbg_w3         	: i32               # capped: color-window write watch
	mutable dbg_w3b        	: i32               # capped: VMADD dest watch
	mutable iris_traced    	: bool              # one-shot: dumped the iris-fill instruction trace
	mutable ct_on          	: bool              # CPU-trace armed (after anchor pc hit)
	mutable ct_n           	: i32               # CPU-trace instruction counter
	mutable spc_nops       	: i64               # monotonic SPC opcode counter (drain-window diffing vs reference hardware g_smp_ops)
	mutable nmi_iend       	: bool              # last instruction ended with an INTERNAL cycle (implied op or taken branch) — NMI take/arm cutoff 10 not 12
	mutable nmi_conv       	: bool              # last instruction was a 2-CYCLE implied op — reference hardware ends ONLY those with idleIRQ() (XBA etc end with plain idle): +2 conversion applies
	mutable irq_cli        	: bool              # last instruction was CLI: a pending IRQ is taken one instruction LATE (I sampled during CLI's last cycle)
	mutable nmi_retro      	: bool              # $4200 NMI-enable rose while the vblank NMI line was set — fire an immediate NMI at the next boundary (reference hardware nmitimenUpdate)
	mutable last_axs       	: i32               # master cost of the last memory access (6/8/12) — interrupt take bound = last-cycle + pipeline, and the last cycle of memory-ending ops is THIS access
	mutable nmi_lastop     	: u8                # opcode of the last completed instruction (interrupt-boundary forensics)
	mutable hsrc           	: i32               # debug: which path fired the HDMA line (1=tick 2=tail 3=loop)
	mutable idle_done      	: i32               # idle cycles explicitly charged in-place this instruction (cpu_idle) — the tail bulk-charges only the remainder
	mutable hdma_edge_arm  	: bool              # reference hardware two-edge pipeline: the first dmaEdge after the dot only sets dmaActive; the SECOND edge runs the HDMA (same rule as deferred GP-DMA)
	mutable hsetup_arm     	: bool              # setup two-edge pipeline state (reference hardware arms dmaActive one edge before running)
	mutable hsetup_pend    	: bool              # HDMA setup deferred to its true dot (reference hardware hdmaSetupPosition = 12 + dmaCounter at frame start), fired from the cycle-start edge
	mutable emu_ms30       	: i64               # wall ms spent in run_rom_frame per 30-frame window (ASNES_CYCLOG)
	mutable emu_started    	: bool              # emulation thread spawned (decoupled from the render loop)
	mutable emu_stop       	: bool              # ask the emulation thread to exit (dealloc)
	mutable emu_running    	: bool              # emulation thread liveness (dealloc waits on it)
	mutable paused         	: bool              # space toggles; emu thread idles while set
	mutable context_req    	: bool              # host asks for a machine-state dump
	mutable context_out    	: string            # dump published by the emu thread
	mutable context_seq    	: i32               # bumped per publish (host drains one-shot)
	mutable pub_lock       	: mutex             # guards the published presentation snapshot below
	public  smooth         	: bool [ true ]    # ground-truth scroll glide (mode-1 layers + mode-7 plane)
	mutable m7g_prevx      	: f64               # prev rep-line origin (snes px)
	mutable m7g_prevy      	: f64
	mutable m7g_preva      	: f64               # prev matrix terms (rotation guard)
	mutable m7g_prevc      	: f64
	mutable m7g_dx         	: f32               # published screen-space delta (snes px)
	mutable m7g_dy         	: f32
	mutable m7g_t          	: i64
	mutable m7g_p          	: i64
	mutable m7g_gap        	: i32
	mutable m7g_model      	: i64
	# mode-0/1 smooth scroll: per-BG glide channels + provenance layers.
	# SNES gives HUD detection for free — a pinned BG (BG3 HUD) simply
	# measures delta 0 and never glides. Sprites split world/screen by
	# slot-independent position-set matching (rgen pattern).
	mutable dbg_bgr        	: i32               # BGRAW diag print budget
	mutable dbg_spr        	: i32               # SPRC class-flip diag budget
	mutable dbg_m7l        	: i32               # M7EASE diag print budget
