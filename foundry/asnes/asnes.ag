				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x21  # TCALL 2
				addr : u16 [ spc_r[0xFFDA] | (spc_r[0xFFDB] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
				spc.sp -= 1
				spc.pc  = addr

			case 0x31  # TCALL 3
				addr : u16 [ spc_r[0xFFD8] | (spc_r[0xFFD9] << 8) ]
				spc_w[ 0x0100 + spc.sp, u8[(spc.pc >> 8) & 0xFF] ]
				spc.sp -= 1
				spc_w[ 0x0100 + spc.sp, u8[spc.pc & 0xFF] ]
