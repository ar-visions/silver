			case 0x08  # PHP
				cpu_w[ cpu.sp, cpu.p ]
				cpu.sp -= 1
				cycles  = 3

			case 0x28  # PLP
				cpu.sp += 1
				cpu.p   = cpu_r[ cpu.sp ]
				if [ cpu.p & 0x10 ]            # 8-bit index: force XH/YH to 0
					cpu.xh = 0
					cpu.yh = 0
				cycles  = 4

			case 0xDA  # PHX
				if [ cpu.p & 0x10 ]
					cpu_w[ cpu.sp, cpu.x ]
					cpu.sp -= 1
				el
					cpu_w[ cpu.sp, cpu.xh ]
					cpu.sp -= 1
					cpu_w[ cpu.sp, cpu.x ]
					cpu.sp -= 1
				cycles = 3

			case 0x5A  # PHY
				if [ cpu.p & 0x10 ]
					cpu_w[ cpu.sp, cpu.y ]
					cpu.sp -= 1
				el
					cpu_w[ cpu.sp, cpu.yh ]
					cpu.sp -= 1
					cpu_w[ cpu.sp, cpu.y ]
					cpu.sp -= 1
				cycles = 3

			case 0xFA  # PLX
				if [ cpu.p & 0x10 ]
					cpu.sp += 1
					cpu.x   = cpu_r[ cpu.sp ]
					cpu.p   = (cpu.p & ~0x82) | ((cpu.x == 0) ? 0x02 : 0) | (cpu.x & 0x80)
				el
					cpu.sp += 1
					xl     : u16 [ cpu_r[ cpu.sp ] ]
					cpu.sp += 1
					xh     : u16 [ cpu_r[ cpu.sp ] ]
					cpu.x   = xl
					cpu.xh  = xh
					xv     : u16 [ xl | (xh << 8) ]
					cpu.p   = (cpu.p & ~0x82) | ((xv == 0) ? 0x02 : 0) | ((xv & 0x8000) ? 0x80 : 0)
				cycles = 4

			case 0x7A  # PLY
				if [ cpu.p & 0x10 ]
					cpu.sp += 1
					cpu.y   = cpu_r[ cpu.sp ]
					cpu.p   = (cpu.p & ~0x82) | ((cpu.y == 0) ? 0x02 : 0) | (cpu.y & 0x80)
				el
					cpu.sp += 1
					yl     : u16 [ cpu_r[ cpu.sp ] ]
					cpu.sp += 1
					yh     : u16 [ cpu_r[ cpu.sp ] ]
					cpu.y   = yl
					cpu.yh  = yh
					yv     : u16 [ yl | (yh << 8) ]
					cpu.p   = (cpu.p & ~0x82) | ((yv == 0) ? 0x02 : 0) | ((yv & 0x8000) ? 0x80 : 0)
				cycles = 4

			case 0x8B  # PHB
				cpu_w[ cpu.sp, cpu.dbr ]
				cpu.sp -= 1
				cycles  = 3

			case 0xAB  # PLB
				cpu.sp += 1
				cpu.dbr = cpu_r[ cpu.sp ]
				cpu.p   = (cpu.p & ~0x82) | ((cpu.dbr == 0) ? 0x02 : 0) | (cpu.dbr & 0x80)
				cycles  = 4

			case 0x4B  # PHK
				cpu_w[ cpu.sp, cpu.pbr ]
				cpu.sp -= 1
				cycles  = 3

			case 0x0B  # PHD
				cpu_w[ cpu.sp, u8[cpu.dp >> 8] ]
				cpu.sp -= 1
				cpu_w[ cpu.sp, u8[cpu.dp & 0xFF] ]
				cpu.sp -= 1
				cycles  = 4

			case 0x2B  # PLD
				cpu.sp += 1
				dl     : u16 [ cpu_r[ cpu.sp ] ]
				cpu.sp += 1
				dh     : u16 [ cpu_r[ cpu.sp ] ]
				cpu.dp  = dl | (dh << 8)
				cpu.p   = (cpu.p & ~0x82) | ((cpu.dp == 0) ? 0x02 : 0) | ((cpu.dp & 0x8000) ? 0x80 : 0)
				cycles  = 5

			case 0xEB  # XBA
				tmp    : u8 [ cpu.a ]
