			case 0x1C  # TRB abs
				addr   : u16 [ cpu_rw[] ]
				val8  : u16 [ cpu_read_mem[addr] ]
				a16    : u16 [ cpu_get_A[] ]
				result : u16 [ a16 & val8 ]
				cpu_idle[]
				cpu_write_mem[ addr, val8 & ~a16 ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 6 + ((is_16bit) ? 2 : 0)

			case 0x04  # TSB dp
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				if [ cpu.dp & 0xFF ] cpu_idle[]
				val8  : u16 [ cpu_read_dp[dp] ]
				a16    : u16 [ cpu_get_A[] ]
				result : u16 [ a16 & val8 ]
				cpu_idle[]
				cpu_write_dp[ dp, val8 | a16 ]
