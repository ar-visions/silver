				cpu.sp += 1
				rlo    : u16 [ cpu_r[cpu.sp] ]
				cpu.sp += 1
				rhi    : u16 [ cpu_r[cpu.sp] ]
				cpu.sp += 1
				cpu.pbr = cpu_r[cpu.sp]
				cpu.pc  = (rlo | (rhi << 8)) + 1
