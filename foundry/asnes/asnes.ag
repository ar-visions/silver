			# --- ALU (dp): ptr at dp ---
			case 0x12  # ORA (dp)
				dpz : u8  [ cpu_rb[] ]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_ora_a[ cpu_read_mem[az] ]
				cycles = 5
			case 0x32  # AND (dp)
				dpz : u8  [ cpu_rb[] ]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_and_a[ cpu_read_mem[az] ]
				cycles = 5
			case 0x52  # EOR (dp)
				dpz : u8  [ cpu_rb[] ]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_eor_a[ cpu_read_mem[az] ]
				cycles = 5
			case 0xD2  # CMP (dp)
				dpz : u8  [ cpu_rb[] ]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_cmp_a[ cpu_read_mem[az] ]
				cycles = 5
