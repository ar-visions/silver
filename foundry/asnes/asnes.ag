			case 0x22  # JSL (jump subroutine long)
				lo     : u32 [ cpu_rb[] ]
				hi     : u32 [ cpu_rb[] ]
				nbank  : u8  [ cpu_rb[] ]
				ret    : u16 [ cpu.pc - 1 ]
				cpu_w[ 0x0100 + cpu.sp, cpu.pbr ]
				cpu.sp -= 1
				cpu_w[ 0x0100 + cpu.sp, u8[ret >> 8] ]
				cpu.sp -= 1
				cpu_w[ 0x0100 + cpu.sp, u8[ret & 0xFF] ]
				cpu.sp -= 1
				cpu.pbr = nbank
				cpu.pc  = lo | (hi << 8)
				cycles  = 8

			case 0x6B  # RTL (return subroutine long)
				cpu.sp += 1
				rlo    : u16 [ cpu_r[0x0100 + cpu.sp] ]
				cpu.sp += 1
				rhi    : u16 [ cpu_r[0x0100 + cpu.sp] ]
				cpu.sp += 1
				cpu.pbr = cpu_r[0x0100 + cpu.sp]
				cpu.pc  = (rlo | (rhi << 8)) + 1
