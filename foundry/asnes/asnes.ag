		894, 899, 904, 908, 913, 918, 923, 927, 932, 937, 941, 946, 951, 955, 960, 965
		969, 974, 978, 983, 988, 992, 997, 1001, 1005, 1010, 1014, 1019, 1023, 1027, 1032, 1036
		1040, 1045, 1049, 1053, 1057, 1061, 1066, 1070, 1074, 1078, 1082, 1086, 1090, 1094, 1098, 1102
		1106, 1109, 1113, 1117, 1121, 1125, 1128, 1132, 1136, 1139, 1143, 1146, 1150, 1153, 1157, 1160
		1164, 1167, 1170, 1174, 1177, 1180, 1183, 1186, 1190, 1193, 1196, 1199, 1202, 1205, 1208, 1210
		1213, 1216, 1219, 1221, 1224, 1227, 1229, 1232, 1234, 1237, 1239, 1241, 1244, 1246, 1248, 1251
		1253, 1255, 1257, 1259, 1261, 1263, 1265, 1267, 1269, 1270, 1272, 1274, 1275, 1277, 1279, 1280
		1282, 1283, 1284, 1286, 1287, 1288, 1290, 1291, 1292, 1293, 1294, 1295, 1296, 1297, 1298, 1299
		1300, 1300, 1301, 1302, 1302, 1303, 1303, 1303, 1304, 1304, 1304, 1304, 1304, 1305, 1305, 1305
	]

	# S-DSP envelope rate table: samples between envelope steps per rate index
	# (index 0 = never update).
	intern  env_rate : new i32 [32] [
		0, 2048, 1536, 1280, 1024, 768, 640, 512, 384, 320, 256, 192,
		160, 128, 96, 80, 64, 48, 40, 32, 24, 20, 16, 12, 10, 8, 6, 5, 4, 3, 2, 1
	]

	# SPC700 base cycle count per opcode (real SMP cycles, conditional branches at
	# their NOT-TAKEN value; +2 added in the handler when taken). Verified against
	# bsnes's measured per-opcode timing (g_spc_tbl/2).
	intern  spc_cyc : new u8 [256] [
		2,8,4,5,3,4,3,6, 2,6,5,4,5,4,6,8,
		2,8,4,5,4,5,5,6, 5,5,6,5,2,2,4,6,
		2,8,4,5,3,4,3,6, 2,6,5,4,5,4,5,4,
		2,8,4,5,4,5,5,6, 5,5,6,5,2,2,3,8,
		2,8,4,5,3,4,3,6, 2,6,4,4,5,4,6,6,
		2,8,4,5,4,5,5,6, 5,5,4,5,2,2,4,3,
		2,8,4,5,3,4,3,6, 2,6,4,4,5,4,5,5,
		2,8,4,5,4,5,5,6, 5,5,5,5,2,2,3,6,
		2,8,4,5,3,4,3,6, 2,6,5,4,5,2,4,5,
		2,8,4,5,4,5,5,6, 5,5,5,5,2,2,12,5,
		3,8,4,5,3,4,3,6, 2,6,4,4,5,2,4,4,
		2,8,4,5,4,5,5,6, 5,5,5,5,2,2,3,4,
		3,8,4,5,4,5,4,7, 2,5,6,4,5,2,4,9,
		2,8,4,5,5,6,6,7, 4,5,5,5,2,2,6,3,
		2,8,4,5,3,4,3,6, 2,4,5,3,4,3,4,3,
		2,8,4,5,4,5,5,6, 3,4,5,4,2,2,4,3
	]

	# --- SPC700 DSP voice key-on / key-off ---

	func spc_keyon [ ch: i32 ]
		spc.channels[ch].pos       = 0
		spc.channels[ch].frac      = 0
		spc.channels[ch].envelope  = 0
		spc.channels[ch].env_state = 0          # attack
		spc.channels[ch].env_count = 0
		spc.channels[ch].active    = 1
		spc.channels[ch].samples[0] = 0
		spc.channels[ch].samples[1] = 0
		spc.channels[ch].samples[2] = 0
		spc.channels[ch].samples[3] = 0
		spc.dsp[0x7C] = spc.dsp[0x7C] & ~(1 << ch)   # clear ENDX for this voice

	func spc_keyoff [ ch: i32 ]
		spc.channels[ch].env_state = 3          # release

	# --- SPC memory access ---

	func spc_r [ addr: u16 ] -> u8
		if [ addr >= 0xF4 && addr <= 0xF7 ]
			return spc.ports[addr - 0xF4]
		if [ addr == 0xF3 ]                      # DSP data read: live register, not last write
			return spc.dsp[ spc.ram[0xF2] & 0x7F ]
		if [ addr == 0xF2 ]
			return spc.ram[0xF2]
		if [ addr >= 0xFD && addr <= 0xFF ]      # timer output counters (read clears)
			t : i32 [ addr - 0xFD ]
			v : u8  [ spc.timer_count[t] & 0x0F ]
			spc.timer_count[t] = 0
			return v
		return spc.ram[addr]

	func spc_w [ addr: u16, val: u8 ]
		if [ addr >= 0xF4 && addr <= 0xF7 ]
			if [ false ]
				printf[ "" ]
			spc.oports[addr - 0xF4] = val
		el [ addr == 0xF3 ]
			reg : u8 [ spc.ram[0xF2] & 0x7F ]
			spc.dsp[ reg ] = val
			if [ dbg_frames >= 145 && dbg_ev3 < 140 ]
				if [ reg == 0x5D ]                # DIR: sample directory page
					printf[ "f%u DSP DIR=%02X (dir base $%04X)\n", dbg_frames, val, u16[val] << 8 ]
					dbg_ev3 += 1
				el [ (reg & 0x0F) == 0x04 && reg < 0x80 ]   # VxSRCN: voice sample index
					printf[ "f%u DSP V%d SRCN=%02X\n", dbg_frames, reg >> 4, val ]
					dbg_ev3 += 1
			if [ reg == 0x4C ]                    # KON: latch, applied per DSP sample
				spc.kon_latch = spc.kon_latch | val
				if [ val != 0 ] dbg_kon += 1
			el [ reg == 0x5C ]                    # KOFF: latch
				spc.koff_latch = spc.koff_latch | val
				if [ val != 0 ] dbg_cpu += 1
			el [ reg == 0x7C ]                    # writing ENDX clears the flags
				spc.dsp[0x7C] = 0
			spc.ram[0xF3] = val
		el [ addr == 0xF1 ]                       # timer control + port-clear
			for [ t: i32 0, t < 3, t += 1 ]
				# enabling a timer (0 -> 1) resets its stage and counter
				if [ (val & (1 << t)) && !(spc.timer_on & (1 << t)) ]
					spc.timer_stage[t] = 0
					spc.timer_count[t] = 0
			spc.timer_on = val & 0x07
			if [ (val & 0x30) && dbg_frames >= 50 && dbg_ev < 80 ]
				printf[ "SPC F1=%02X clear(c2a now %02X %02X %02X %02X) spcpc=%04X\n", val, spc.ports[0], spc.ports[1], spc.ports[2], spc.ports[3], spc.pc ]
				dbg_ev += 1
			if [ val & 0x10 ]                     # clear ports 0,1 (CPU->APU)
				spc.ports[0] = 0
				spc.ports[1] = 0
			if [ val & 0x20 ]                     # clear ports 2,3
				spc.ports[2] = 0
				spc.ports[3] = 0
			spc.ram[0xF1] = val
		el [ addr >= 0xFA && addr <= 0xFC ]       # timer dividers
			spc.timer_target[addr - 0xFA] = val
			spc.ram[addr] = val
		el
			spc.ram[addr] = val

	func dsp_r [ reg: u8 ] -> u8
		return spc.dsp[ reg & 0x7F ]

	func spc_rb [] -> u8
		if [ dbg_frames >= 50 && spc.pc == 0xFFC0 && dbg_ev < 60 ]
			printf[ "f%u SPC re-enter IPL@FFC0 (block start) cports=%02X %02X %02X %02X\n", dbg_frames, spc.ports[0], spc.ports[1], spc.ports[2], spc.ports[3] ]
			dbg_ev += 1
		v : u8 [ spc_r[ spc.pc ] ]
		spc.pc += 1
		return v

	func spc_dp [] -> u16
		# direct-page operand: low byte from stream + page ($0100 when PSW.P set)
		return spc_rb[] | ((spc.psw & 0x20) ? 0x100 : 0)


	func spc_r16 [ aa: u16 ] -> u16
		return spc_r[ aa ] | (spc_r[aa + 1] << 8)

	func spc_rw [] -> u16
		lo : u8 [ spc_r[ spc.pc ] ]
		spc.pc += 1
		hi : u8 [ spc_r[ spc.pc ] ]
		spc.pc += 1
		return lo | (hi << 8)

	func spc_nz [ v: u8 ]
		spc.psw = (spc.psw & ~0x82) | ((v == 0) ? 0x02 : 0) | (v & 0x80)

	func spc_nzc [ v: u8, c: u8 ]
		spc.psw = (spc.psw & ~0x83) | c | ((v == 0) ? 0x02 : 0) | (v & 0x80)

	func spc_cmp [ res: u16 ]
		c : u8 [ (res < 0x100) ? 0x01 : 0 ]
		z : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n : u8 [ res & 0x80 ]
		spc.psw = (spc.psw & ~0x83) | c | z | n

	func spc_adc [ aa: u8, val: u8, res: u16 ]
		c  : u8 [ (res > 0xFF) ? 0x01 : 0 ]
		z  : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n  : u8 [ res & 0x80 ]
		h  : u8 [ ((aa ^ val ^ res) & 0x10) ? 0x08 : 0 ]
		ov : u8 [ ((aa ^ res) & (val ^ res) & 0x80) ? 0x40 : 0 ]
		spc.psw = (spc.psw & ~0xCB) | c | z | n | h | ov

	func spc_sbc [ aa: u8, val: u8, res: u16 ]
		c  : u8 [ (res < 0x100) ? 0x01 : 0 ]
		z  : u8 [ ((res & 0xFF) == 0) ? 0x02 : 0 ]
		n  : u8 [ res & 0x80 ]
		h  : u8 [ ((aa ^ val ^ res) & 0x10) ? 0x08 : 0 ]
		ov : u8 [ ((aa ^ val) & (aa ^ res) & 0x80) ? 0x40 : 0 ]
		spc.psw = (spc.psw & ~0xCB) | c | z | n | h | ov

	# --- CPU memory access ---

	# --- DMA: block transfer CPU memory <-> PPU/APU registers ($420B trigger) ---
	# B-bus register offset for transfer byte 'step', per DMAP transfer mode.
	func dma_boff [ mode: u8, step: i32 ] -> u8
		if [ mode == 1 || mode == 5 ] return u8[ step & 1 ]
		if [ mode == 4 ]              return u8[ step & 3 ]
		if [ mode == 3 || mode == 7 ] return u8[ (step >> 1) & 1 ]
		return 0

	func do_dma [ mask: u8 ]
		count_cpu = false                                   # DMA accesses are charged in bulk, not via cpu_tick
		steal_master += 8                                   # 8 master DMA-init alignment (bsnes dmaRun)
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ (mask & (1 << ch)) == 0 ] continue
			base   : u16 [ 0x4300 + (ch << 4) ]
			params : u8  [ cpu.memory[base] ]
			bbad   : u8  [ cpu.memory[base + 1] ]
			a_lo   : u16 [ u16[cpu.memory[base + 2]] | (u16[cpu.memory[base + 3]] << 8) ]
			a_bank : u8  [ cpu.memory[base + 4] ]
			count  : u32 [ u32[cpu.memory[base + 5]] | (u32[cpu.memory[base + 6]] << 8) ]
			if [ count == 0 ] count = 0x10000
			if [ env_dma && bbad == 0x18 ] printf[ "VDMA src=%02X:%04X cnt=%04X dest=%04X\n", a_bank, a_lo, count, ppu.vram_addr ]
			dcost : i32 [ i32[ count * 8 ] + 8 ]            # GP-DMA: 8 master/byte + 8 master channel overhead
			steal_master  += dcost
			dbg_dma_total += i64[ dcost ]
			mode   : u8  [ params & 0x07 ]
			stepb  : u8  [ (params >> 3) & 0x03 ]
			a_to_b : bool [ (params & 0x80) == 0 ]
			if [ getenv['ASNES_CG_LOG'] ]
				printf[ "f%u DMA ch%d bbad=$21%02X count=%u src=%02X:%04X step=%d vmadd=%04X\n",
					dbg_frames, ch, bbad, count, a_bank, a_lo, (params >> 3) & 3, ppu.vram_addr ]
			ab     : u8  [ a_bank ]
			ao     : u16 [ a_lo ]
			i      : u32 [ 0 ]
			while [ i < count ]
				boff : u8  [ dma_boff[ mode, i32[i] ] ]
				breg : u16 [ 0x2100 + u16[bbad] + u16[boff] ]
				if [ a_to_b ]
					v : u8 [ cpu_bank_r[ ab, ao ] ]
					if [ breg >= 0x2140 ] cpu_w[ breg, v ]   # APU($2140)/WMDATA($2180) not in ppu_w
					el ppu_w[ breg, v ]
				el
					v : u8 [ ppu_r[ breg ] ]
					cpu_bank_w[ ab, ao, v ]
				if [ stepb == 0 ] ao = (ao + 1) & 0xFFFF
				el [ stepb == 2 ] ao = (ao - 1) & 0xFFFF
				i += 1
			cpu.memory[base + 5] = 0          # DAS counts down to 0 after transfer
			cpu.memory[base + 6] = 0
			if [ stepb != 1 ]                # A1T advances with the transfer (hardware updates $4302/$4303); fixed mode (stepb==1) leaves it
				cpu.memory[base + 2] = u8[ ao & 0xFF ]
				cpu.memory[base + 3] = u8[ ao >> 8 ]
		count_cpu = true                                    # re-enable: do_dma runs inside the triggering instruction

	# --- HDMA ($420C): per-scanline DMA, ported from bsnes dma.cpp ---
	# bytes transferred per HDMA line, indexed by transfer mode
	func hdma_len [ mode: u8 ] -> i32
		if [ mode == 0 ] return 1
		if [ mode == 2 ] return 2
		if [ mode == 6 ] return 2
		if [ mode == 1 ] return 2
		return 4

	# read the next table entry header for a channel; loads line count (+ indirect addr)
	func hdma_reload [ ch: i32 ]
		base     : u16  [ 0x4300 + (ch << 4) ]
		params   : u8   [ cpu.memory[base] ]
		indirect : bool [ (params & 0x40) != 0 ]
		a_bank   : u8   [ cpu.memory[base + 4] ]
		if [ (hdma_line[ch] & 0x7F) == 0 ]
			data : u8 [ cpu_bank_r[ a_bank, hdma_addr[ch] ] ]
			steal_master += 8                              # header byte read (8 master)
			hdma_line[ch] = data
			hdma_addr[ch] = (hdma_addr[ch] + 1) & 0xFFFF
			if [ data == 0 ]
				hdma_done[ch] = 1
				hdma_do[ch]   = 0
			el
				hdma_done[ch] = 0
				hdma_do[ch]   = 1
			if [ indirect ]
				lo : u8 [ cpu_bank_r[ a_bank, hdma_addr[ch] ] ]
				hdma_addr[ch] = (hdma_addr[ch] + 1) & 0xFFFF
				hi : u8 [ cpu_bank_r[ a_bank, hdma_addr[ch] ] ]
				hdma_addr[ch] = (hdma_addr[ch] + 1) & 0xFFFF
				steal_master += 16                         # indirect address (2 byte reads)
				hdma_ind[ch] = u16[lo] | (u16[hi] << 8)

	# transfer this line's bytes to the B-bus ($2100+). A->B only (direction 0).
	func hdma_transfer [ ch: i32 ]
		if [ hdma_done[ch] ] return
		if [ !hdma_do[ch] ] return
		base     : u16  [ 0x4300 + (ch << 4) ]
		params   : u8   [ cpu.memory[base] ]
		bbad     : u8   [ cpu.memory[base + 1] ]
		mode     : u8   [ params & 0x07 ]
		indirect : bool [ (params & 0x40) != 0 ]
		a_bank   : u8   [ cpu.memory[base + 4] ]
		i_bank   : u8   [ cpu.memory[base + 7] ]
		n        : i32  [ hdma_len[ mode ] ]
		steal_master += n * 8                              # one byte read per transferred byte (8 master each)
		for [ idx: i32 0, idx < n, idx += 1 ]
			boff : u8  [ dma_boff[ mode, idx ] ]
			breg : u16 [ 0x2100 + u16[bbad] + u16[boff] ]
			if [ indirect ]
				v : u8 [ cpu_bank_r[ i_bank, hdma_ind[ch] ] ]
				ppu_w[ breg, v ]
				hdma_ind[ch] = (hdma_ind[ch] + 1) & 0xFFFF
			el
				v : u8 [ cpu_bank_r[ a_bank, hdma_addr[ch] ] ]
				ppu_w[ breg, v ]
				hdma_addr[ch] = (hdma_addr[ch] + 1) & 0xFFFF

	func hdma_advance [ ch: i32 ]
		if [ hdma_done[ch] ] return
		hdma_line[ch] = (hdma_line[ch] - 1) & 0xFF
		if [ hdma_line[ch] & 0x80 ] hdma_do[ch] = 1
		el hdma_do[ch] = 0
		hdma_reload[ ch ]

	# frame start: point each enabled channel at its table and prime the first entry
	func hdma_setup []
		en : u8 [ cpu.memory[0x420C] ]
		if [ getenv['ASNES_HDMA_LOG'] && dbg_frames == 150 ]
			printf[ "HDMA f%u en=%02X\n", dbg_frames, en ]
			for [ ch: i32 0, ch < 8, ch += 1 ]
				if [ (en & (1 << ch)) == 0 ] continue
				b : u16 [ 0x4300 + (ch << 4) ]
				printf[ "  ch%d DMAP=%02X BBAD=$21%02X (reg $21%02X) A1=%02X:%02X%02X mode=%d ind=%d\n",
					ch, cpu.memory[b], cpu.memory[b+1], cpu.memory[b+1],
					cpu.memory[b+4], cpu.memory[b+3], cpu.memory[b+2],
					cpu.memory[b] & 7, (cpu.memory[b] >> 6) & 1 ]
		if [ en != 0 ] steal_master += 8                   # HDMA setup overhead (bsnes hdmaSetup step<8>)
		for [ ch: i32 0, ch < 8, ch += 1 ]
			hdma_do[ch]   = 1
			hdma_done[ch] = 0
			if [ (en & (1 << ch)) == 0 ] continue
			base : u16 [ 0x4300 + (ch << 4) ]
			hdma_addr[ch] = u16[cpu.memory[base + 2]] | (u16[cpu.memory[base + 3]] << 8)
			hdma_line[ch] = 0
			hdma_reload[ ch ]

	# one scanline: all channels transfer, then all advance (bsnes order)
	func hdma_run_line []
		en : u8 [ cpu.memory[0x420C] ]
		if [ en == 0 ] return
		steal_master += 8                                  # per-scanline HDMA run overhead (bsnes hdmaRun step<8>)
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ en & (1 << ch) ] hdma_transfer[ ch ]
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ en & (1 << ch) ] hdma_advance[ ch ]

	# capture the registers HDMA mutates for scanline y so the renderer is per-line
	func ppu_snapshot_line [ y: i32 ]
		line_mode[y] = ppu.bgmode
		line_tm[y]   = ppu.tm
		line_ts[y]   = ppu.ts
		for [ bg: i32 0, bg < 4, bg += 1 ]
			line_h[ bg * 224 + y ] = ppu.bg_hofs[bg]
			line_v[ bg * 224 + y ] = ppu.bg_vofs[bg]
		line_m7a[y] = ppu.m7a
		line_m7b[y] = ppu.m7b
		line_m7c[y] = ppu.m7c
		line_m7d[y] = ppu.m7d
		line_coldata[y] = ppu.coldata
		line_cgadsub[y] = ppu.cgadsub
		line_cgwsel[y]  = ppu.cgwsel
		line_wobjsel[y] = ppu.wobjsel
		line_wobjlog[y] = ppu.wobjlog
		line_wh0[y]     = ppu.wh0
		line_wh1[y]     = ppu.wh1
		line_wh2[y]     = ppu.wh2
		line_wh3[y]     = ppu.wh3
		line_tmw[y]     = ppu.tmw
		line_tsw[y]     = ppu.tsw
		line_w12sel[y]  = ppu.w12sel
		line_w34sel[y]  = ppu.w34sel
		line_wbglog[y]  = ppu.wbglog

	# --- PPU register access ($2100-$213F) ---
	func ppu_vram_inc []
		sel : u8  [ ppu.vmain & 0x03 ]
		amt : u16 [ 1 ]
		if [ sel == 1 ] amt = 32
		el [ sel >= 2 ] amt = 128
		ppu.vram_addr = (ppu.vram_addr + amt) & 0xFFFF

	# VMAIN bits 2-3 address translation (8/9/10-bit remap). Matches bsnes vramAddress().
	# Games enable this for tile uploads; without it dynamically-uploaded tiles garble.
	func ppu_vram_map [] -> u32
		a : u32 [ u32[ppu.vram_addr] ]
		m : u8  [ (ppu.vmain >> 2) & 3 ]
		if [ m == 1 ] return (a & 0x7F00) | ((a << 3) & 0x00F8) | ((a >> 5) & 7)
		if [ m == 2 ] return (a & 0x7E00) | ((a << 3) & 0x01F8) | ((a >> 6) & 7)
		if [ m == 3 ] return (a & 0x7C00) | ((a << 3) & 0x03F8) | ((a >> 7) & 7)
		return a & 0x7FFF

	func ppu_w [ addr: u16, val: u8 ]
		r : u8 [ addr & 0xFF ]
		if [ r == 0x00 ]                                  # INIDISP
			ppu.inidisp = val
		el [ r == 0x01 ]                                  # OBSEL
			ppu.obsel = val
		el [ r == 0x02 ]                                  # OAMADDL (word addr -> byte cursor)
			ppu.oamadd_reload = (ppu.oamadd_reload & 0x200) | (u16[val] << 1)
			ppu.oamadd = ppu.oamadd_reload
			ppu.oam_toggle = false
		el [ r == 0x03 ]                                  # OAMADDH
			ppu.oamadd_reload = ((u16[val] & 1) << 9) | (ppu.oamadd_reload & 0x1FF)
			ppu.oamadd = ppu.oamadd_reload
			ppu.oam_toggle = false
		el [ r == 0x04 ]                                  # OAMDATA write
			a : u16 [ ppu.oamadd & 0x3FF ]
			if [ a < 0x200 ]
				if [ (a & 1) == 0 ]
					ppu.oam_latch = val
				el
					ppu.oam[ a - 1 ] = ppu.oam_latch
					ppu.oam[ a ]     = val
			el [ a < 0x220 ]
				ppu.oam[ a ] = val
			ppu.oamadd = (ppu.oamadd + 1) & 0x3FF
		el [ r == 0x05 ]                                  # BGMODE
			ppu.bgmode = val
		el [ r == 0x06 ]                                  # MOSAIC
			ppu.mosaic = val
		el [ r >= 0x07 && r <= 0x0A ]                     # BGnSC
			ppu.bg_sc[ r - 0x07 ] = val
		el [ r == 0x0B ]                                  # BG12NBA
			ppu.bg_nba[0] = val
		el [ r == 0x0C ]                                  # BG34NBA
			ppu.bg_nba[1] = val
		el [ r >= 0x0D && r <= 0x14 ]                     # BGn H/V scroll (write-twice)
			bg : i32 [ (r - 0x0D) / 2 ]
			if [ ((r - 0x0D) & 1) == 0 ]
				ppu.bg_hofs[bg] = (u16[val] << 8) | (u16[ppu.ofs_latch] & 0xFFF8) | (u16[ppu.ofs_hl[bg]] & 7)
				ppu.ofs_latch  = val
				ppu.ofs_hl[bg] = val
			el
				ppu.bg_vofs[bg] = (u16[val] << 8) | u16[ppu.ofs_latch]
				ppu.ofs_latch = val
			if [ r == 0x0D ]                              # $210D also = Mode 7 H scroll
				ppu.m7hofs = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
				ppu.m7_latch = val
			el [ r == 0x0E ]                              # $210E also = Mode 7 V scroll
				ppu.m7vofs = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
				ppu.m7_latch = val
		el [ r == 0x15 ]                                  # VMAIN
			ppu.vmain = val
		el [ r == 0x16 ]                                  # VMADDL
			ppu.vram_addr = (ppu.vram_addr & 0xFF00) | u16[val]
		el [ r == 0x17 ]                                  # VMADDH
			ppu.vram_addr = (ppu.vram_addr & 0x00FF) | (u16[val] << 8)
		el [ r == 0x18 ]                                  # VMDATAL
			wa : u32 [ ppu_vram_map[] * 2 ]
			if [ env_vrw && wa >= 0x8000 && wa < 0xA000 ] printf[ "VW %04X L %02X\n", wa / 2, val ]
			ppu.vram[ wa ] = val
			if [ (ppu.vmain & 0x80) == 0 ] ppu_vram_inc[]
		el [ r == 0x19 ]                                  # VMDATAH
			wa : u32 [ ppu_vram_map[] * 2 ]
			if [ env_vrw && wa >= 0x8000 && wa < 0xA000 ] printf[ "VW %04X H %02X\n", wa / 2, val ]
			ppu.vram[ wa + 1 ] = val
			if [ ppu.vmain & 0x80 ] ppu_vram_inc[]
		el [ r == 0x1A ]                                  # M7SEL
			ppu.m7sel = val
		el [ r == 0x1B ]                                  # M7A (write-twice, shared latch)
			ppu.m7a = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x1C ]                                  # M7B
			ppu.m7b = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x1D ]                                  # M7C
			ppu.m7c = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x1E ]                                  # M7D
			ppu.m7d = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x1F ]                                  # M7X (center)
			ppu.m7x = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x20 ]                                  # M7Y (center)
			ppu.m7y = i16[(u16[val] << 8) | u16[ppu.m7_latch]]
			ppu.m7_latch = val
		el [ r == 0x21 ]                                  # CGADD
			ppu.cgadd = val
			ppu.cg_toggle = false
		el [ r == 0x22 ]                                  # CGDATA write (2-byte)
			if [ !ppu.cg_toggle ]
				ppu.cg_latch = val
			el
				ci : u16 [ u16[ppu.cgadd] << 1 ]
				ppu.cgram[ ci ]     = ppu.cg_latch
				ppu.cgram[ ci + 1 ] = val
				ppu.cgadd = (ppu.cgadd + 1) & 0xFF
			ppu.cg_toggle = !ppu.cg_toggle
		el [ r == 0x23 ] ppu.w12sel = val                 # W12SEL
		el [ r == 0x24 ] ppu.w34sel = val                 # W34SEL
		el [ r == 0x25 ] ppu.wobjsel = val                # WOBJSEL
		el [ r == 0x26 ] ppu.wh0 = val                    # WH0 window1 left
		el [ r == 0x27 ] ppu.wh1 = val                    # WH1 window1 right
		el [ r == 0x28 ] ppu.wh2 = val                    # WH2 window2 left
		el [ r == 0x29 ] ppu.wh3 = val                    # WH3 window2 right
		el [ r == 0x2A ] ppu.wbglog = val                 # WBGLOG
		el [ r == 0x2B ] ppu.wobjlog = val                # WOBJLOG
		el [ r == 0x2C ]                                  # TM (main screen)
			ppu.tm = val
		el [ r == 0x2D ]                                  # TS (sub screen)
			ppu.ts = val
		el [ r == 0x2E ] ppu.tmw = val                    # TMW (window main-screen disable)
		el [ r == 0x2F ] ppu.tsw = val                    # TSW (window sub-screen disable)
		el [ r == 0x30 ]                                  # CGWSEL
			ppu.cgwsel = val
		el [ r == 0x31 ]                                  # CGADSUB
			ppu.cgadsub = val
		el [ r == 0x32 ]                                  # COLDATA (fixed color)
			inten : u16 [ u16[val] & 0x1F ]
			if [ val & 0x20 ] ppu.coldata = (ppu.coldata & 0x7FE0) | inten
			if [ val & 0x40 ] ppu.coldata = (ppu.coldata & 0x7C1F) | (inten << 5)
			if [ val & 0x80 ] ppu.coldata = (ppu.coldata & 0x03FF) | (inten << 10)
		el [ r == 0x33 ]                                  # SETINI
			ppu.setini = val

	func ppu_r [ addr: u16 ] -> u8
		r : u8 [ addr & 0xFF ]
		if [ r == 0x38 ]                                  # OAMDATAREAD
			a : u16 [ ppu.oamadd & 0x3FF ]
			v : u8  [ 0 ]
			if [ a < 0x220 ] v = ppu.oam[a]
			ppu.oamadd = (ppu.oamadd + 1) & 0x3FF
			return v
		el [ r == 0x39 ]                                  # VMDATALREAD
			v : u8 [ u8[ppu.vram_pre & 0xFF] ]
			if [ (ppu.vmain & 0x80) == 0 ]
				wa : u32 [ ppu_vram_map[] * 2 ]
				ppu.vram_pre = u16[ppu.vram[wa]] | (u16[ppu.vram[wa + 1]] << 8)
				ppu_vram_inc[]
			return v
		el [ r == 0x3A ]                                  # VMDATAHREAD
			v : u8 [ u8[ppu.vram_pre >> 8] ]
			if [ ppu.vmain & 0x80 ]
				wa : u32 [ ppu_vram_map[] * 2 ]
				ppu.vram_pre = u16[ppu.vram[wa]] | (u16[ppu.vram[wa + 1]] << 8)
				ppu_vram_inc[]
			return v
		el [ r == 0x3B ]                                  # CGDATAREAD
			cb  : u16 [ 0 ]
			if [ ppu.cg_toggle ] cb = 1
			idx : u16 [ (u16[ppu.cgadd] << 1) | cb ]
			v   : u8  [ ppu.cgram[idx] ]
			if [ ppu.cg_toggle ] ppu.cgadd = (ppu.cgadd + 1) & 0xFF
			ppu.cg_toggle = !ppu.cg_toggle
			return v
		el [ r == 0x3E ]                                  # STAT77 (PPU1 5C77, version 1)
			return 0x01
		el [ r == 0x3F ]                                  # STAT78 (PPU2 5C78, NTSC, version 3)
			return 0x03
		return 0x00

	# CGRAM color index -> 15-bit BGR555 word
	func ppu_cgram_color [ idx: u32 ] -> u16
		ci : u32 [ idx * 2 ]
		lo : u16 [ u16[ppu.cgram[ci]] ]
		hi : u16 [ u16[ppu.cgram[ci + 1]] ]
		return lo | (hi << 8)

	# BGR555 word + brightness(0-15) -> RGBA8 (R low byte, matches R8G8B8A8 UNORM)
	func ppu_color [ w: u16, bright: u32 ] -> u32
		r5 : u32 [ u32[w] & 0x1F ]
		g5 : u32 [ (u32[w] >> 5) & 0x1F ]
		b5 : u32 [ (u32[w] >> 10) & 0x1F ]
		r8 : u32 [ (r5 << 3) | (r5 >> 2) ]
		g8 : u32 [ (g5 << 3) | (g5 >> 2) ]
		b8 : u32 [ (b5 << 3) | (b5 >> 2) ]
		r8 = (r8 * bright) / 15
		g8 = (g8 * bright) / 15
		b8 = (b8 * bright) / 15
		return 0xFF000000 | (b8 << 16) | (g8 << 8) | r8

	# read one VRAM word (15-bit word address)
	func ppu_vw [ waddr: u32 ] -> u32
		b : u32 [ (waddr & 0x7FFF) * 2 ]
		return u32[ppu.vram[b]] | (u32[ppu.vram[b + 1]] << 8)

	# Render ONE scanline of one background layer (bg 0..3, bpp 2 or 4). 8x8 tiles,
	# per-line H/V scroll (from the HDMA snapshot), tile flip, 32/64 tilemaps.
	# Is BG `bg` pixel (x,y) masked off (disabled) on this screen by its window?
	# screen: 0 = main (TMW), 1 = sub (TSW). Games like F-Zero double-buffer dialogs
	# on BG1/BG2 and use window1 + TMW to mask the stale layer, revealing the live one.
	func bg_win_masked [ bg: i32, x: i32, y: i32, screen: i32 ] -> bool
		tmw : u8 [ line_tmw[y] ]
		if [ screen ] tmw = line_tsw[y]
		if [ (tmw & (1 << bg)) == 0 ] return false        # BG not window-masked here
		sel : u8 [ line_w12sel[y] ]
		if [ bg >= 2 ] sel = line_w34sel[y]
		sh  : u32 [ 0 ]
		if [ bg & 1 ] sh = 4                               # BG2/BG4 use the high nibble
		s   : u32 [ (u32[sel] >> sh) & 0x0F ]
		w1en : bool [ (s & 2) != 0 ]
		w1inv: bool [ (s & 1) != 0 ]
		w2en : bool [ (s & 8) != 0 ]
		w2inv: bool [ (s & 4) != 0 ]
		if [ !w1en && !w2en ] return false                # no window enabled => empty mask
		in1 : bool [ u32[x] >= u32[line_wh0[y]] && u32[x] <= u32[line_wh1[y]] ]
		in2 : bool [ u32[x] >= u32[line_wh2[y]] && u32[x] <= u32[line_wh3[y]] ]
		if [ w1inv ] in1 = !in1
		if [ w2inv ] in2 = !in2
		if [ w1en && !w2en ] return in1
		if [ !w1en && w2en ] return in2
		lg : u32 [ (u32[line_wbglog[y]] >> (bg * 2)) & 3 ]
		if   [ lg == 0 ] return in1 || in2
		if   [ lg == 1 ] return in1 && in2
		if   [ lg == 2 ] return in1 != in2
		return in1 == in2

	# Color idx 0 = transparent. Priority/16x16 not fully handled; BG window masking applied.
	func ppu_bg_line [ bg: i32, bpp: i32, y: i32, bright: u32, want_prio: u32 ]
		sc    : u8  [ ppu.bg_sc[ bg ] ]
		tbase : u32 [ (u32[sc >> 2] & 0x3F) * 0x400 ]    # tilemap base (word)
		nb    : u8  [ ppu.bg_nba[ bg >> 1 ] ]
		nibble: u32 [ u32[nb] & 0x0F ]
		if [ bg & 1 ] nibble = (u32[nb] >> 4) & 0x0F
		cbase : u32 [ nibble * 0x1000 ]                  # char data base (word)
		w64   : bool [ (sc & 1) != 0 ]
		h64   : bool [ (sc & 2) != 0 ]
		hofs  : u32 [ u32[line_h[ bg * 224 + y ]] & 0x3FF ]
		vofs  : u32 [ u32[line_v[ bg * 224 + y ]] & 0x3FF ]
		hmask : u32 [ 0xFF ]
		vmask : u32 [ 0xFF ]
		if [ w64 ] hmask = 0x1FF
		if [ h64 ] vmask = 0x1FF
		tilesz: u32 [ 16 ]                               # 4bpp tile = 16 words
		if [ bpp == 2 ] tilesz = 8                       # 2bpp tile = 8 words
		sy : u32 [ (u32[y] + vofs) & vmask ]
		scr : i32 [ 0 ]
		if [ rendering_sub ] scr = 1
		for [ x: i32 0, x < 256, x += 1 ]
			if [ bg_win_masked[ bg, x, y, scr ] ] continue
			sx : u32 [ (u32[x] + hofs) & hmask ]
			tx : u32 [ sx >> 3 ]
			ty : u32 [ sy >> 3 ]
			blk: u32 [ 0 ]
			if [ tx & 32 ] blk += 1
			if [ ty & 32 ]
				if [ w64 ] blk += 2
				el blk += 1
			ent : u32 [ tbase + blk * 0x400 + (ty & 31) * 32 + (tx & 31) ]
			e   : u32 [ ppu_vw[ ent ] ]
			if [ ((e >> 13) & 1) != want_prio ] continue   # only this priority level
			tile: u32 [ e & 0x3FF ]
			pal : u32 [ (e >> 10) & 7 ]
			px  : u32 [ sx & 7 ]
			py  : u32 [ sy & 7 ]
			if [ e & 0x4000 ] px = 7 - px
			if [ e & 0x8000 ] py = 7 - py
			bit : u32 [ 7 - px ]
			base: u32 [ cbase + tile * tilesz + py ]
			w01 : u32 [ ppu_vw[ base ] ]
			idx : u32 [ ((w01 >> bit) & 1) | (((w01 >> (bit + 8)) & 1) << 1) ]
			if [ bpp == 4 ]
				w23 : u32 [ ppu_vw[ base + 8 ] ]
				idx = idx | (((w23 >> bit) & 1) << 2) | (((w23 >> (bit + 8)) & 1) << 3)
			if [ idx ]
				cgidx : u32 [ pal * 16 + idx ]
				if [ bpp == 2 ] cgidx = pal * 4 + idx
				bgrv : u16 [ ppu_cgram_color[ cgidx ] ]
				di   : i32 [ y * 256 + x ]
				if [ rendering_sub ]
					ppu.sub_bgr[ di ] = bgrv
					ppu.sub_src[ di ] = u8[bg]
				el
					ppu.framebuf[ di ] = ppu_color[ bgrv, bright ]
					ppu.px_bgr[ di ]   = bgrv
					ppu.px_src[ di ]   = u8[bg]

	# Phase 3: render the framebuffer from real PPU state, PER SCANLINE using the
	# HDMA snapshots (line_mode / line_h / line_v / line_tm). Backdrop first, then
	# Mode 1 BG layers (BG3 back -> BG1 front) for whatever mode that line is in.
	# Sprite (OBJ) layer. 4bpp, palettes 8-15 (CGRAM 128+pal*16). OBSEL size pairs,
	# 9-bit X (high OAM), 9-bit tile (name select), H/V flip, 16x16 tile-grid wrap.
	# Builds the obj_color / obj_prio buffers (drawn 127->0 so sprite 0 wins per pixel);
	# the composite step interleaves these by priority with the BG layers.
	# No 32/34 per-line limit yet.
	func ppu_sprites [ bright: u32 ]
		for [ i: i32 0, i < 256 * 224, i += 1 ]
			ppu.obj_color[i] = 0
		ws : local u8 [ 16 ] [ 8, 8, 8, 16, 16, 32, 16, 16, 16, 32, 64, 32, 64, 64, 32, 32 ]
		hs : local u8 [ 16 ] [ 8, 8, 8, 16, 16, 32, 32, 32, 16, 32, 64, 32, 64, 64, 64, 32 ]
		obsel : u8  [ ppu.obsel ]
		tbase : u32 [ (u32[obsel] << 13) & 0x6000 ]
		nsel  : u32 [ (u32[obsel] >> 3) & 3 ]
		bsize : u32 [ (u32[obsel] >> 5) & 7 ]
		n : i32 [ 127 ]
		while [ n >= 0 ]
			o     : i32 [ n * 4 ]
			b0    : u8  [ ppu.oam[o] ]
			b1    : u8  [ ppu.oam[o + 1] ]
			b2    : u8  [ ppu.oam[o + 2] ]
			b3    : u8  [ ppu.oam[o + 3] ]
			hbyte : u8  [ ppu.oam[512 + (n >> 2)] ]
			hbits : u32 [ (u32[hbyte] >> ((n & 3) * 2)) & 3 ]
			big   : u32 [ (hbits >> 1) & 1 ]
			sw    : i32 [ i32[ws[ big * 8 + bsize ]] ]
			sh    : i32 [ i32[hs[ big * 8 + bsize ]] ]
			fx    : i32 [ i32[b0] | (i32[hbits & 1] << 8) ]
			if [ fx >= 256 ] fx -= 512
			pal   : u32 [ (u32[b3] >> 1) & 7 ]
			oprio : u32 [ (u32[b3] >> 4) & 3 ]
			hflip : u32 [ (u32[b3] >> 6) & 1 ]
			vflip : u32 [ (u32[b3] >> 7) & 1 ]
			nlo   : u32 [ u32[b2] ]
			taddr : u32 [ tbase ]
			if [ b3 & 1 ] taddr = tbase + ((1 + nsel) << 12)
			cgb   : u32 [ 128 + pal * 16 ]
			oy : i32 [ 0 ]
			while [ oy < sh ]
				scy : i32 [ (i32[b1] + oy) & 0xFF ]
				if [ scy < 224 && (line_tm[scy] & 0x10) ]
					syp : i32 [ oy ]
					if [ vflip ] syp = sh - 1 - oy
					cy  : u32 [ ((nlo >> 4) + u32[syp >> 3]) & 0x0F ]
					ox : i32 [ 0 ]
					while [ ox < sw ]
						scx : i32 [ fx + ox ]
						if [ scx >= 0 && scx < 256 ]
							sxp  : i32 [ ox ]
							if [ hflip ] sxp = sw - 1 - ox
							cx   : u32 [ ((nlo & 0x0F) + u32[sxp >> 3]) & 0x0F ]
							addr : u32 [ taddr + (cy * 16 + cx) * 16 + u32[syp & 7] ]
							w01  : u32 [ ppu_vw[ addr ] ]
							w23  : u32 [ ppu_vw[ addr + 8 ] ]
							bit  : u32 [ u32[7 - (sxp & 7)] ]
							col  : u32 [ ((w01 >> bit) & 1) | (((w01 >> (bit + 8)) & 1) << 1) | (((w23 >> bit) & 1) << 2) | (((w23 >> (bit + 8)) & 1) << 3) ]
							if [ col ]
								di : i32 [ scy * 256 + scx ]
								ocol : u16 [ ppu_cgram_color[ cgb + col ] ]
								ppu.obj_color[di] = ppu_color[ ocol, bright ]
								ppu.obj_bgr[di]   = ocol
								ppu.obj_prio[di]  = u8[oprio]
						ox += 1
				oy += 1
			n -= 1

	# composite the sprite buffer for one scanline at a given OBJ priority level
	func ppu_obj_line [ y: i32, want_prio: u32 ]
		base : i32 [ y * 256 ]
		for [ x: i32 0, x < 256, x += 1 ]
			i : i32 [ base + x ]
			if [ ppu.obj_color[i] != 0 && u32[ppu.obj_prio[i]] == want_prio ]
				ppu.framebuf[i] = ppu.obj_color[i]
				ppu.px_bgr[i]   = ppu.obj_bgr[i]
				ppu.px_src[i]   = 5                     # OBJ (CGADSUB bit4)

	# subtractive color math in BGR555 space (clamped, optional half). Used for the
	# Mode 7 distance fog: each scanline subtracts the HDMA'd COLDATA from the plane.
	func ppu_cmath_sub [ main: u16, sub: u16, hf: bool ] -> u16
		rr : i32 [ i32[main & 0x1F] - i32[sub & 0x1F] ]
		gg : i32 [ i32[(main >> 5) & 0x1F] - i32[(sub >> 5) & 0x1F] ]
		bb : i32 [ i32[(main >> 10) & 0x1F] - i32[(sub >> 10) & 0x1F] ]
		if [ rr < 0 ] rr = 0
		if [ gg < 0 ] gg = 0
		if [ bb < 0 ] bb = 0
		if [ hf ]
			rr >>= 1
			gg >>= 1
			bb >>= 1
		return u16[ rr | (gg << 5) | (bb << 10) ]

	# additive color math in BGR555 space (clamped, optional half). Used for HUD
	# fills like F-Zero's POWER bar: COLDATA red added to BG/backdrop inside a window.
	func ppu_cmath_add [ main: u16, add: u16, hf: bool ] -> u16
		rr : i32 [ i32[main & 0x1F] + i32[add & 0x1F] ]
		gg : i32 [ i32[(main >> 5) & 0x1F] + i32[(add >> 5) & 0x1F] ]
		bb : i32 [ i32[(main >> 10) & 0x1F] + i32[(add >> 10) & 0x1F] ]
		if [ hf ]
			rr >>= 1
			gg >>= 1
			bb >>= 1
		if [ rr > 31 ] rr = 31
		if [ gg > 31 ] gg = 31
		if [ bb > 31 ] bb = 31
		return u16[ rr | (gg << 5) | (bb << 10) ]

	# Apply CGADSUB color math to one composited (mode-1) scanline using the per-pixel
	# source layer (px_src) + window (fog_enabled). bit7=subtract else add; bit6=half.
	# Layer bits: 0-3=BG1-4, 4=OBJ, 5=backdrop. Mode 7 does its math inline in ppu_m7_line.
	func ppu_cmath_line [ y: i32, bright: u32 ]
		cg : u8 [ line_cgadsub[y] ]
		if [ (cg & 0x3F) == 0 ] return
		base : i32 [ y * 256 ]
		for [ x: i32 0, x < 256, x += 1 ]
			i : i32 [ base + x ]
			s : u8 [ ppu.px_src[i] ]
			mbit : u8 [ 0x20 ]
			if [ s < 4 ] mbit = u8[1 << s]
			el [ s == 5 ] mbit = 0x10
			if [ (cg & mbit) == 0 ] continue
			if [ !fog_enabled[ x, y ] ] continue
			cwv : u16 [ ppu.px_bgr[i] ]
			other : u16 [ line_coldata[y] ]
			if [ (line_cgwsel[y] & 0x02) != 0 ] other = ppu.sub_bgr[i]
			if [ cg & 0x80 ] cwv = ppu_cmath_sub[ cwv, other, (cg & 0x40) != 0 ]
			el cwv = ppu_cmath_add[ cwv, other, (cg & 0x40) != 0 ]
			ppu.framebuf[i] = ppu_color[ cwv, bright ]

	# Color-math enable test for one pixel, matching SNES CGWSEL "belowMask" + the
	# color window (WOBJSEL/WOBJLOG + WH0-3). belowMask = CGWSEL bits 4-5:
	# 0=always, 1=inside color window, 2=outside, 3=never. The color window is
	# HDMA'd per scanline (F-Zero animates WH0/WH1 to confine the race haze band).
	func fog_enabled [ X: i32, y: i32 ] -> bool
		bmask : u32 [ (u32[line_cgwsel[y]] >> 4) & 3 ]
		if [ bmask == 0 ] return true
		if [ bmask == 3 ] return false
		setv : bool [ bmask == 1 ]                     # value when inside the window
		ws   : u8   [ line_wobjsel[y] ]
		w1en : bool [ (ws & 0x20) != 0 ]
		w1inv: bool [ (ws & 0x10) != 0 ]
		w2en : bool [ (ws & 0x80) != 0 ]
		w2inv: bool [ (ws & 0x40) != 0 ]
		if [ !w1en && !w2en ] return !setv
		om : bool [ false ]
		tm : bool [ false ]
		if [ w1en ] om = (X >= i32[line_wh0[y]] && X <= i32[line_wh1[y]]) != w1inv
		if [ w2en ] tm = (X >= i32[line_wh2[y]] && X <= i32[line_wh3[y]]) != w2inv
		comb : bool [ false ]
		if [ w1en && w2en ]
			lg : u32 [ (u32[line_wobjlog[y]] >> 2) & 3 ]
			if [ lg == 0 ] comb = om || tm
			el [ lg == 1 ] comb = om && tm
			el [ lg == 2 ] comb = om != tm
			el comb = om == tm
		el [ w1en ] comb = om
		el comb = tm
		if [ comb ] return setv
		return !setv

	# 13-bit signed wrap for the (offset - center) terms
	func m7_clip [ n: i32 ] -> i32
		if [ n & 0x2000 ] return n | (~1023)
		return n & 1023

	# sign-extend a 13-bit value held in a 16-bit register
	func sx13 [ v: i32 ] -> i32
		s : i32 [ v & 0x1FFF ]
		if [ s & 0x1000 ] return s | (~0x1FFF)
		return s

	# Mode 7 affine layer (BG1), one scanline. Uses the per-scanline matrix
	# (line_m7a-d, HDMA'd) + frame center/scroll. VRAM is interleaved: even byte =
	# tilemap entry (128x128), odd byte = 8bpp char pixel. Ported from bsnes ppu-fast.
	func ppu_m7_line [ y: i32, bright: u32 ]
		a  : i32 [ i32[line_m7a[y]] ]
		b  : i32 [ i32[line_m7b[y]] ]
		c  : i32 [ i32[line_m7c[y]] ]
		d  : i32 [ i32[line_m7d[y]] ]
		hc : i32 [ sx13[ i32[ppu.m7x] ] ]
		vc : i32 [ sx13[ i32[ppu.m7y] ] ]
		ho : i32 [ sx13[ i32[ppu.m7hofs] ] ]
		vo : i32 [ sx13[ i32[ppu.m7vofs] ] ]
		hflip  : bool [ (ppu.m7sel & 1) != 0 ]
		vflip  : bool [ (ppu.m7sel & 2) != 0 ]
		repeat : u32  [ (u32[ppu.m7sel] >> 6) & 3 ]
		yy : i32 [ y ]
		if [ vflip ] yy = 255 - y
		ch : i32 [ m7_clip[ ho - hc ] ]
		cv : i32 [ m7_clip[ vo - vc ] ]
		originX : i32 [ ((a * ch) & (~63)) + ((b * cv) & (~63)) + ((b * yy) & (~63)) + (hc << 8) ]
		originY : i32 [ ((c * ch) & (~63)) + ((d * cv) & (~63)) + ((d * yy) & (~63)) + (vc << 8) ]
		for [ X: i32 0, X < 256, X += 1 ]
			xx : i32 [ X ]
			if [ hflip ] xx = 255 - X
			pixelX : i32 [ (originX + a * xx) >> 8 ]
			pixelY : i32 [ (originY + c * xx) >> 8 ]
			tileX : i32 [ (pixelX >> 3) & 127 ]
			tileY : i32 [ (pixelY >> 3) & 127 ]
			oob : i32 [ (pixelX | pixelY) & (~1023) ]
			tile : u32 [ 0 ]
			if [ repeat == 3 && oob != 0 ]
				tile = 0
			el
				tile = u32[ppu.vram[ (tileY * 128 + tileX) * 2 ]]
			pix : u32 [ 0 ]
			if [ repeat == 2 && oob != 0 ]
				pix = 0
			el
				palAddr : i32 [ ((pixelY & 7) << 3) + (pixelX & 7) ]
				ci      : u32 [ (tile << 6) | u32[palAddr] ]
				pix = u32[ppu.vram[ ci * 2 + 1 ]]
			if [ pix != 0 ]
				cw : u16 [ ppu_cgram_color[ pix ] ]
				cg : u8 [ line_cgadsub[y] ]
				# distance fog: BG1 subtractive color math, but ONLY when CGWSEL's
				# color-math region is "always" (0). F-Zero's race sets region=1
				# (inside an empty window) => no math => bright road.
				if [ (cg & 0x01) && (cg & 0x80) && fog_enabled[ X, y ] ]
					cw = ppu_cmath_sub[ cw, line_coldata[y], (cg & 0x40) != 0 ]
				ppu.framebuf[ y * 256 + X ] = ppu_color[ cw, bright ]

	# Render the SUB-screen for one scanline into sub_bgr/sub_src. The sub-screen
	# backdrop is the fixed COLDATA color (so unpainted pixels blend as fixed color),
	# then TS-enabled layers paint over it by Mode-1 priority. Used as the "below"
	# color when CGWSEL blendMode (bit1) = subscreen. SMW's intro sky/mountains are
	# BG2 on the sub-screen, composited to the main screen via this path.
	func ppu_sub_line [ y: i32, bright: u32 ]
		sbd : u16 [ line_coldata[y] ]
		for [ x: i32 0, x < 256, x += 1 ]
			di : i32 [ y * 256 + x ]
			ppu.sub_bgr[ di ] = sbd
			ppu.sub_src[ di ] = 0xFF
		ts   : u8 [ line_ts[y] ]
		b3hi : bool [ (line_mode[y] & 0x08) != 0 ]
		rendering_sub = true
		if [ ts & 0x04 ] ppu_bg_line[ 2, 2, y, bright, 0 ]   # BG3.0
		if [ ts & 0x04 ] if [ !b3hi ] ppu_bg_line[ 2, 2, y, bright, 1 ]  # BG3.1 (low pos)
		if [ ts & 0x02 ] ppu_bg_line[ 1, 4, y, bright, 0 ]   # BG2.0
		if [ ts & 0x01 ] ppu_bg_line[ 0, 4, y, bright, 0 ]   # BG1.0
		if [ ts & 0x02 ] ppu_bg_line[ 1, 4, y, bright, 1 ]   # BG2.1
		if [ ts & 0x01 ] ppu_bg_line[ 0, 4, y, bright, 1 ]   # BG1.1
		if [ ts & 0x04 ] if [ b3hi ] ppu_bg_line[ 2, 2, y, bright, 1 ]   # BG3.1 (front)
		rendering_sub = false

	func ppu_render []
		bright : u32 [ u32[ppu.inidisp] & 0x0F ]
		if [ ppu.inidisp & 0x80 ] bright = 0          # forced blank -> black
		bg : u16 [ ppu_cgram_color[ 0 ] ]
		px : u32 [ ppu_color[ bg, bright ] ]
		for [ i: i32 0, i < 256 * 224, i += 1 ]
			ppu.framebuf[ i ] = px
			ppu.px_bgr[ i ]   = bg
			ppu.px_src[ i ]   = 8                       # backdrop (CGADSUB bit5)
		if [ bright == 0 ] return
		ppu_sprites[ bright ]                              # build obj_color / obj_prio
		# Mode 1 priority order, painted BACK -> FRONT (later overwrites). BG3 high-prio
		# goes to the very front when BGMODE bit3 is set, else just above OBJ.0.
		# NOTE: silver binds && tighter than &, so a layer-enable test MUST be a nested
		# if [ tm & bit ] then if [ cond ] -- never `tm & bit && cond` (that parses as
		# tm & (bit && cond) and fires whenever bit0 of tm is set, drawing disabled layers).
		for [ y: i32 0, y < 224, y += 1 ]
			mode : u8 [ line_mode[y] & 7 ]
			tm   : u8 [ line_tm[y] ]
			b3hi : bool [ (line_mode[y] & 0x08) != 0 ]
			if [ mode == 1 ]
				if [ tm & 0x04 ] ppu_bg_line[ 2, 2, y, bright, 0 ]   # BG3.0
				if [ tm & 0x10 ] ppu_obj_line[ y, 0 ]                # OBJ.0
				if [ tm & 0x04 ] if [ !b3hi ] ppu_bg_line[ 2, 2, y, bright, 1 ]  # BG3.1 (low pos)
				if [ tm & 0x10 ] ppu_obj_line[ y, 1 ]                # OBJ.1
				if [ tm & 0x02 ] ppu_bg_line[ 1, 4, y, bright, 0 ]   # BG2.0
				if [ tm & 0x01 ] ppu_bg_line[ 0, 4, y, bright, 0 ]   # BG1.0
				if [ tm & 0x10 ] ppu_obj_line[ y, 2 ]                # OBJ.2
				if [ tm & 0x02 ] ppu_bg_line[ 1, 4, y, bright, 1 ]   # BG2.1
				if [ tm & 0x01 ] ppu_bg_line[ 0, 4, y, bright, 1 ]   # BG1.1
				if [ tm & 0x10 ] ppu_obj_line[ y, 3 ]                # OBJ.3
				if [ tm & 0x04 ] if [ b3hi ] ppu_bg_line[ 2, 2, y, bright, 1 ]   # BG3.1 (front)
				if [ line_ts[y] & 0x07 ] ppu_sub_line[ y, bright ]   # build sub-screen for color-math blend
				ppu_cmath_line[ y, bright ]                          # CGADSUB add/sub (POWER bar fill, HUD fog)
			el [ mode == 7 ]
				if [ tm & 0x01 ] ppu_m7_line[ y, bright ]            # Mode 7 plane (BG1)
				if [ tm & 0x10 ]                                     # sprites on top
					ppu_obj_line[ y, 0 ]
					ppu_obj_line[ y, 1 ]
					ppu_obj_line[ y, 2 ]
					ppu_obj_line[ y, 3 ]

	func cpu_r [ addr: u16 ] -> u8
		cpu_tick[ 0, addr ]
		if [ addr >= 0x2140 && addr <= 0x2143 ]
			port_read = true
			if [ nmi_frames == 0 ] dbg_pr += 1
			if [ dbg_frames >= 59 && cpu.pc != 0xF817 && cpu.pc != 0xF814 && dbg_ev2 < 120 ]
				printf[ "f%u CPUrd port%d=%02X cpupc=%04X\n", dbg_frames, addr - 0x2140, spc.oports[addr - 0x2140], cpu.pc ]
				dbg_ev2 += 1
			return spc.oports[addr - 0x2140]
		el [ addr >= 0x2100 && addr <= 0x213F ]
			return ppu_r[ addr ]
		el [ addr == 0x2180 ]                          # WMDATA: read WRAM via WMADD, auto-inc
			v : u8 [ cpu.memory[ 0x7E0000 + (wram_addr & 0x1FFFF) ] ]
			wram_addr = (wram_addr + 1) & 0x1FFFF
			return v
		el [ addr >= 0x4000 && addr <= 0x43FF ]
			if [ addr == 0x4210 ]            # RDNMI: bit7 = NMI flag (cleared on read); bits4-6 = open bus
				v : u8 [ (mdr & 0x70) | ((nmi_occurred) ? 0x80 : 0x00) | 0x02 ]
				nmi_occurred = false
				return v
			if [ addr == 0x4211 ]            # TIMEUP: bit7 = IRQ flag (cleared on read); bits0-6 = open bus
				v : u8 [ (mdr & 0x7F) | ((irq_occurred) ? 0x80 : 0x00) ]
				irq_occurred = false
				return v
			if [ addr == 0x4212 ]            # HVBJOY: bit7=vblank, bit6=hblank, bit0=joy-busy; bits1-5 = open bus
				vb : u8 [ (in_vblank) ? 0x80 : 0 ]
				line_pos : i32 [ frame_cycle % 228 ]
				hb : u8 [ (line_pos >= 180) ? 0x40 : 0 ]
				return (mdr & 0x3E) | vb | hb
			if [ addr == 0x4214 ] return u8[rddiv & 0xFF]         # RDDIVL
			if [ addr == 0x4215 ] return u8[(rddiv >> 8) & 0xFF]  # RDDIVH
			if [ addr == 0x4216 ] return u8[rdmpy & 0xFF]         # RDMPYL
			if [ addr == 0x4217 ] return u8[(rdmpy >> 8) & 0xFF]  # RDMPYH
			if [ addr == 0x4016 ]            # JOYSER0: serial controller-1 read
				if [ joy_strobe & 1 ] return u8[(pad1 >> 15) & 1]
				if [ joy_index >= 16 ] return 0x01
				rb : u8 [ u8[(pad1 >> (15 - joy_index)) & 1] ]
				joy_index += 1
				return rb
			if [ addr == 0x4017 ] return 0x00
			if [ addr == 0x4218 ] return u8[pad1 & 0xFF]        # JOY1L (auto-joypad)
			if [ addr == 0x4219 ] return u8[(pad1 >> 8) & 0xFF]  # JOY1H
			if [ addr >= 0x421A && addr <= 0x421F ] return 0x00  # controllers 2-4
			return 0x00
		el [ addr >= 0x0000 && addr <= 0x1FFF ]
			return cpu.memory[0x7E0000 + (addr & 0x1FFF)]
		el [ addr >= 0x6000 && addr <= 0x7FFF ]
			return cpu.memory[addr]
		return cpu.memory[addr]

	func cpu_w [ addr: u16, val: u8 ]
		cpu_tick[ 0, addr ]
		if [ addr >= 0x2140 && addr <= 0x2143 ]
			spc.ports[addr - 0x2140] = val
			if [ dbg_frames >= 125 && val != 0x00 && dbg_ev2 < 160 ]
				printf[ "f%u CPUw port%d=%02X src=%06X dbr=%02X cpupc=%04X\n", dbg_frames, addr - 0x2140, val, last_rd, cpu.dbr, cpu.pc ]
				dbg_ev2 += 1
		el [ addr >= 0x2100 && addr <= 0x213F ]
			ppu_w[ addr, val ]
		el [ addr == 0x2180 ]                          # WMDATA: write WRAM via WMADD, auto-inc
			cpu.memory[ 0x7E0000 + (wram_addr & 0x1FFFF) ] = val
			wram_addr = (wram_addr + 1) & 0x1FFFF
		el [ addr == 0x2181 ] wram_addr = (wram_addr & 0x1FF00) | u32[val]            # WMADDL
		el [ addr == 0x2182 ] wram_addr = (wram_addr & 0x100FF) | (u32[val] << 8)     # WMADDM
		el [ addr == 0x2183 ] wram_addr = (wram_addr & 0x0FFFF) | ((u32[val] & 1) << 16) # WMADDH
		el [ addr >= 0x4000 && addr <= 0x43FF ]
			if [ addr == 0x4016 ]                  # JOYSER0 strobe: latch/reset serial
				joy_strobe = val
				if [ val & 1 ] joy_index = 0
			el [ addr == 0x4202 ] mpya = val       # WRMPYA
			el [ addr == 0x4203 ]                  # WRMPYB (write triggers 8x8 multiply)
				mpyb = val
				rdmpy = u16[ (u32[mpya] * u32[mpyb]) & 0xFFFF ]
			el [ addr == 0x4204 ] wrdiv = (wrdiv & 0xFF00) | u16[val]          # WRDIVL
			el [ addr == 0x4205 ] wrdiv = (wrdiv & 0x00FF) | (u16[val] << 8)   # WRDIVH
			el [ addr == 0x4206 ]                  # WRDIVB (write triggers 16/8 divide)
				if [ val == 0 ]
					rddiv = 0xFFFF
					rdmpy = wrdiv
				el
					rddiv = wrdiv / u16[val]
					rdmpy = wrdiv % u16[val]
			el [ addr == 0x4200 ]                  # NMITIMEN: bit7=NMI, bit5=V-IRQ, bit4=H-IRQ
				if [ getenv['ASNES_IRQ_LOG'] && dbg_frames < 200 && val != nmitimen ]
					printf[ "NMITIMEN<-%02X f%u pc=%02X:%04X vtime=%d htime=%d\n", val, dbg_frames, cpu.pbr, cpu.pc, i32[vtime], i32[htime] ]
				nmitimen = val
			el [ addr == 0x4207 ] htime = (htime & 0x100) | u16[val]              # HTIMEL
			el [ addr == 0x4208 ] htime = (htime & 0x0FF) | ((u16[val] & 1) << 8) # HTIMEH
			el [ addr == 0x4209 ] vtime = (vtime & 0x100) | u16[val]              # VTIMEL
			el [ addr == 0x420A ] vtime = (vtime & 0x0FF) | ((u16[val] & 1) << 8) # VTIMEH
			el [ addr == 0x420B ] do_dma[ val ]    # MDMAEN: trigger general DMA
			el [ addr == 0x420C ] cpu.memory[addr] = val   # HDMAEN: per-scanline DMA enable mask
			el [ addr == 0x420D ] cpu_fastrom = (val & 1) != 0   # MEMSEL: banks $80-FF fast (6 master) when set
			el [ addr >= 0x4300 && addr <= 0x437F ] cpu.memory[addr] = val   # DMA channel regs
		el [ addr >= 0x0000 && addr <= 0x1FFF ]
			wo : u16 [ addr & 0x1FFF ]
			ww : u32 [ 0x7E0000 + wo ]
			if [ env_logzp && (wo == 0x0041 || wo == 0x0046 || wo == 0x0051 || wo == 0x005D || wo == 0x0060 || wo == 0x0062 || wo == 0x00F0) ]
				printf[ "W[%04X]=%02X pc=%02X:%04X\n", wo, val, cpu.pbr, cpu.pc ]
			if [ env_trace && wo == 0x0060 && val == 1 && dbg_t < 1 ]
				printf[ "==== 32 instrs before $0060<-01 (demo-entry) f%u ====\n", dbg_frames ]
				for [ kk: i32 0, kk < 32, kk += 1 ]
					st : i32 [ (tr_i + kk) % 32 ]
					printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[st] >> 16, tr_addr[st] & 0xFFFF, tr_b0[st], tr_b1[st], tr_b2[st], tr_b3[st], tr_p[st], tr_a[st], tr_x[st], tr_y[st] ]
				dbg_t += 1
			if [ env_pal && wo >= 0x0520 && wo <= 0x0530 && dbg_w < 80 ]
				printf[ "PALw[%04X]=%02X pc=%02X:%04X dbr=%02X f%u (cpuw)\n", wo, val, cpu.pbr, cpu.pc, cpu.dbr, dbg_frames ]
				dbg_w += 1
			if [ wo >= 0x012C && wo <= 0x012F && val != 0 && dbg_frames >= 820 && dbg_w < 160 ]
				printf[ "SNDQ[%04X]=%02X sub=%02X pc=%02X:%04X f%u\n", wo, val, cpu.memory[0x7E0011], cpu.pbr, cpu.pc, dbg_frames ]
				dbg_w += 1
			cpu.memory[ww] = val
		el [ addr >= 0x6000 && addr <= 0x7FFF ]
			cpu.memory[addr] = val
		el
			cpu.memory[addr] = val

	# bank-aware instruction/operand fetch: uses the program bank (pbr).
	# low addresses ($0000-$1FFF) mirror WRAM; everything else is the flat map.
	func cpu_fetch_at [ fa: u16 ] -> u8
		bank : u32 [ cpu.pbr ]
		if [ fa < 0x2000 && bank != 0x7E && bank != 0x7F ]
			waddr : u32 [ 0x7E0000 + u32[fa] ]
			return cpu.memory[waddr]
		faddr : u32 [ (bank << 16) | u32[fa] ]
		return cpu.memory[faddr]

	# SNES bus access speed in MASTER clocks, by region (mirrors bsnes cpu/memory.cpp):
	#   6 = FastROM ($80-FF when $420D.0) + fast I/O ($2100-21FF,$2140-217F,$2180-83,$44xx-5FFF)
	#   8 = SlowROM (all $00-7F ROM, $80-FF when slow), WRAM $7E-7F, low mirror $0000-1FFF, SRAM $6000-7FFF
	#  12 = $4000-43FF (joypad/DMA/CPU regs, xslow)
	func cpu_speed [ bank: u32, addr: u16 ] -> i32
		a : u32 [ (bank << 16) | u32[addr] ]
		if [ (a & 0x408000) != 0 ]
			if [ (a & 0x800000) != 0 && cpu_fastrom ] return 6
			return 8
		if [ ((a + 0x6000) & 0x4000) != 0 ] return 8
		if [ ((a - 0x4000) & 0x7E00) != 0 ] return 6
		return 12

	# charge one CPU memory access (gated so DMA/HDMA/snapshot reads don't double-count)
	func cpu_tick [ bank: u32, addr: u16 ]
		if [ !count_cpu ] return
		op_master   += cpu_speed[ bank, addr ]
		op_accesses += 1

	# flat 24-bit data access for long-addressing opcodes: tick + raw map access
	func cpu_long_r [ la: u32 ] -> u8
		cpu_tick[ la >> 16, u16[ la & 0xFFFF ] ]
		return cpu.memory[ la ]

	func cpu_long_w [ la: u32, val: u8 ]
		cpu_tick[ la >> 16, u16[ la & 0xFFFF ] ]
		cpu.memory[ la ] = val

	func cpu_rb [] -> u8
		v : u8 [ cpu_fetch_at[ cpu.pc ] ]
		cpu_tick[ cpu.pbr, cpu.pc ]
		cpu.pc += 1
		mdr = v                                   # open-bus latch (last bus value)
		return v

	func cpu_rw [] -> u16
		lo : u8 [ cpu_fetch_at[ cpu.pc ] ]
		cpu_tick[ cpu.pbr, cpu.pc ]
		cpu.pc += 1
		hi : u8 [ cpu_fetch_at[ cpu.pc ] ]
		cpu_tick[ cpu.pbr, cpu.pc ]
		cpu.pc += 1
		mdr = hi                                  # open-bus latch (last bus value)
		return lo | (hi << 8)

	# --- CPU register width helpers ---

	func cpu_get_A [] -> u16
		if [ cpu.p & 0x20 ]
			return cpu.a
		return cpu.a | (cpu.b << 8)

	func cpu_set_A [ v: u16 ]
		cpu.a = v & 0xFF
		if [ !(cpu.p & 0x20) ]
			cpu.b = v >> 8

	func cpu_get_X [] -> u16
		if [ cpu.p & 0x10 ]
			return cpu.x
		return cpu.x | (cpu.xh << 8)

	func cpu_set_X [ v: u16 ]
		cpu.x = v & 0xFF
		if [ cpu.p & 0x10 ]
			cpu.xh = 0                  # 8-bit index: high byte forced to 0
		el
			cpu.xh = v >> 8

	func cpu_get_Y [] -> u16
		if [ cpu.p & 0x10 ]
			return cpu.y
		return cpu.y | (cpu.yh << 8)

	func cpu_set_Y [ v: u16 ]
		cpu.y = v & 0xFF
		if [ cpu.p & 0x10 ]
			cpu.yh = 0                  # 8-bit index: high byte forced to 0
		el
			cpu.yh = v >> 8

	# width-aware immediate fetch: #imm is 1 byte in 8-bit mode, 2 in 16-bit.
	# getting this wrong desyncs the PC, so all A/X/Y immediate ops use these.
	func cpu_imm_a [] -> u16
		if [ cpu.p & 0x20 ] return cpu_rb[]
		return cpu_rw[]

	func cpu_imm_x [] -> u16
		if [ cpu.p & 0x10 ] return cpu_rb[]
		return cpu_rw[]

	# width-aware N/Z flag set for A-width / X-width results
	func cpu_nz_a [ v: u16 ]
		if [ cpu.p & 0x20 ]
			cpu.p = (cpu.p & ~0x82) | (((v & 0xFF) == 0) ? 0x02 : 0) | (v & 0x80)
		el
			cpu.p = (cpu.p & ~0x82) | ((v == 0) ? 0x02 : 0) | (((v & 0x8000) != 0) ? 0x80 : 0)

	func cpu_nz_x [ v: u16 ]
		if [ cpu.p & 0x10 ]
			cpu.p = (cpu.p & ~0x82) | (((v & 0xFF) == 0) ? 0x02 : 0) | (v & 0x80)
		el
			cpu.p = (cpu.p & ~0x82) | ((v == 0) ? 0x02 : 0) | (((v & 0x8000) != 0) ? 0x80 : 0)

	# data-bank-relative byte read: low system area (WRAM/registers) is bank-agnostic;
	# the ROM/data region uses the data bank register (DBR). dp modes pass low
	# addresses so DBR never affects them; absolute modes pass the real address.
	# bank-explicit byte read/write applying the LoROM map: low system area
	# (WRAM mirror / hardware registers) is bank-agnostic for system banks,
	# the rest reads the flat 24-bit map. Used by DBR-relative reads and MVN/MVP.
	func cpu_bank_r [ bank: u32, addr: u16 ] -> u8
		a32  : u32 [ u32[addr] ]
		if [ bank != 0x7E && bank != 0x7F ]
			if [ addr < 0x2000 ]
				cpu_tick[ bank, addr ]                        # WRAM-mirror leaf access
				wa : u32 [ 0x7E0000 + a32 ]                   # WRAM mirror
				if [ dbg_frames >= 140 && dbg_frames <= 175 && addr == 0x0011 && dbg_ev < 80 ]
					printf[ "R[0011]=%02X pc=%02X:%04X f%u\n", cpu.memory[wa], cpu.pbr, cpu.pc, dbg_frames ]
					dbg_ev += 1
				return cpu.memory[ wa ]
			if [ addr >= 0x2000 && addr <= 0x43FF ]
				return cpu_r[ addr ]                          # hardware registers (cpu_r ticks)
		cpu_tick[ bank, addr ]                                # flat 24-bit leaf access
		fa : u32 [ (bank << 16) | a32 ]
		return cpu.memory[ fa ]

	func cpu_bank_w [ bank: u32, addr: u16, val: u8 ]
		a32  : u32 [ u32[addr] ]
		if [ bank != 0x7E && bank != 0x7F ]
			if [ addr < 0x2000 ]
				cpu_tick[ bank, addr ]                        # WRAM-mirror leaf access
				wa : u32 [ 0x7E0000 + a32 ]                   # WRAM mirror
				if [ env_logzp && (addr == 0x0041 || addr == 0x0046 || addr == 0x0051 || addr == 0x005D || addr == 0x0060 || addr == 0x0062 || addr == 0x00F0) ]
					printf[ "W[%04X]=%02X pc=%02X:%04X (m)\n", addr, val, cpu.pbr, cpu.pc ]
				if [ env_pal && addr >= 0x0520 && addr <= 0x0530 && dbg_w < 80 ]
					printf[ "PALw[%04X]=%02X pc=%02X:%04X dbr=%02X f%u (mirror b=%02X)\n", addr, val, cpu.pbr, cpu.pc, cpu.dbr, dbg_frames, bank ]
					dbg_w += 1
				if [ addr >= 0x012C && addr <= 0x012F && val != 0 && dbg_w < 200 ]
					printf[ "SNDQ[%04X]=%02X sub=%02X pc=%02X:%04X f%u\n", addr, val, cpu.memory[0x7E0011], cpu.pbr, cpu.pc, dbg_frames ]
					dbg_w += 1
				cpu.memory[ wa ] = val
				return
			if [ addr >= 0x2000 && addr <= 0x43FF ]
				cpu_w[ addr, val ]                            # hardware registers (cpu_w ticks)
				return
		cpu_tick[ bank, addr ]                                # flat 24-bit leaf access
		fa : u32 [ (bank << 16) | a32 ]
		if [ env_pal && fa >= 0x7E0520 && fa <= 0x7E0530 && dbg_w < 80 ]
			printf[ "PALw[%04X]=%02X pc=%02X:%04X dbr=%02X f%u (direct b=%02X)\n", a32, val, cpu.pbr, cpu.pc, cpu.dbr, dbg_frames, bank ]
			dbg_w += 1
		if [ env_map && fa >= 0x7F4A00 && fa <= 0x7F4A07 && dbg_w2 < 120 ]
			printf[ "MAPw[%06X]=%02X pc=%02X:%04X f%u\n", fa, val, cpu.pbr, cpu.pc, dbg_frames ]
			dbg_w2 += 1
		if [ dbg_frames >= 205 && fa >= 0x7E1F00 && fa <= 0x7E1F0B && dbg_w < 60 ]
			printf[ "WRAM[%04X]=%02X bank_w-DIRECT bank=%02X pc=%02X:%04X f%u\n", a32, val, bank, cpu.pbr, cpu.pc, dbg_frames ]
			dbg_w += 1
		cpu.memory[ fa ] = val

	func cpu_db_r [ addr: u16 ] -> u8
		last_rd = (u32[cpu.dbr] << 16) | u32[addr]
		return cpu_bank_r[ cpu.dbr, addr ]

	func cpu_db_w [ addr: u16, val: u8 ]
		cpu_bank_w[ cpu.dbr, addr, val ]

	func cpu_read_mem [ addr: u32 ] -> u16
		if [ cpu.p & 0x20 ]
			return cpu_db_r[ u16[addr] ]
		lo : u16 [ cpu_db_r[ u16[addr] ] ]
		hi : u16 [ cpu_db_r[ u16[addr + 1] ] ]
		if [ u16[addr] == 0x1F0A && dbg_frames >= 219 && dbg_w < 70 ]
			m0 : u32 [ 0x7E1F0A ]
			m1 : u32 [ 0x7E1F0B ]
			printf[ "RD1F0A lo=%02X hi=%02X dbr=%02X mem=%02X %02X pc=%02X:%04X f%u\n", lo, hi, cpu.dbr, cpu.memory[m0], cpu.memory[m1], cpu.pbr, cpu.pc, dbg_frames ]
			dbg_w += 1
		return lo | (hi << 8)

	func cpu_write_mem [ addr: u32, v: u16 ]
		if [ cpu.p & 0x20 ]
			cpu_db_w[ u16[addr], u8[v & 0xFF] ]
		el
			cpu_db_w[ u16[addr],     u8[v & 0xFF] ]
			cpu_db_w[ u16[addr + 1], u8[v >> 8]   ]

	# Direct-page accesses are ALWAYS bank 0 (never DBR). Use cpu_r/cpu_w (bank-0
	# semantics) so dp reads/writes agree with the (dp) pointer fetches, which also
	# use bank 0. (Bug: routing dp through DBR broke when DBR=$7F, e.g. fzero's
	# Mode 7 track decompressor doing STA $0C / LDA ($0C),Y.)
	func cpu_read_dp [ addr: u16 ] -> u16
		if [ cpu.p & 0x20 ]
			return cpu_r[ addr ]
		return cpu_r[ addr ] | (cpu_r[ (addr + 1) & 0xFFFF ] << 8)

	func cpu_write_dp [ addr: u16, v: u16 ]
		cpu_w[ addr, u8[v & 0xFF] ]
		if [ !(cpu.p & 0x20) ]
			cpu_w[ (addr + 1) & 0xFFFF, u8[v >> 8] ]

	# index-width-aware bank-0 dp read (for LDX/LDY/CPX/CPY dp)
	func cpu_read_dp_x [ addr: u16 ] -> u16
		if [ cpu.p & 0x10 ]
			return cpu_r[ addr ]
		return cpu_r[ addr ] | (cpu_r[ (addr + 1) & 0xFFFF ] << 8)

	# vblank NMI: push PCH,PCL,P (matches RTI pull order), jump to NMI vector.
	func cpu_nmi []
		nmi_frames += 1                            # NMI-fired frame count (same unit as bsnes g_frame)
		if [ nmi_frames <= 3 ] printf[ "asnes NMI#%u at cpu_cycles=%ld boot_port_reads=%ld\n", nmi_frames, cpu_cycles, dbg_pr ]
		op_master   = 0                            # count the interrupt sequence's access cycles
		op_accesses = 0
		count_cpu   = true
		if [ dbg_frames >= 60 ]
			printf[ "NMIENTRY f%u savedpc=%02X:%04X sp=%04X p=%03X\n", dbg_frames, cpu.pbr, cpu.pc, cpu.sp, cpu.p ]
			if [ dbg_frames >= 72 && dbg_bad < 1 ]
				printf[ "  ---- 32 instrs before this NMI (savedpc=%04X) ----\n", cpu.pc ]
				for [ k: i32 0, k < 32, k += 1 ]
					s : i32 [ (tr_i + k) % 32 ]
					printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[s] >> 16, tr_addr[s] & 0xFFFF, tr_b0[s], tr_b1[s], tr_b2[s], tr_b3[s], tr_p[s], tr_a[s], tr_x[s], tr_y[s] ]
				dbg_bad += 1
		if [ !cpu.e ]                              # native mode: interrupt pushes PBR
			cpu_w[ cpu.sp, cpu.pbr ]
			cpu.sp -= 1
		cpu_w[ cpu.sp, u8[cpu.pc >> 8] ]
		cpu.sp -= 1
		cpu_w[ cpu.sp, u8[cpu.pc & 0xFF] ]
		cpu.sp -= 1
		cpu_w[ cpu.sp, cpu.p ]
		cpu.sp -= 1
		cpu.p  |= 0x04
		cpu.p  &= ~0x08
		vec    : u16 [ (cpu.e) ? 0xFFFA : 0xFFEA ]
		lo     : u8  [ cpu_r[ vec ] ]
		hi     : u8  [ cpu_r[ vec + 1 ] ]
		cpu.pc  = lo | (hi << 8)
		cpu.pbr = 0
		nmi_occurred = true
		count_cpu = false
		steal_master += op_master + 12             # interrupt: stack pushes/vector reads + 2 internal cycles
		op_master = 0
		if [ dbg_cpu < 6 ]
			printf[ "NMI fired: e=%d vec=%04X -> handler %04X (nmitimen=%02X)\n",
				cpu.e, vec, cpu.pc, nmitimen ]
			dbg_cpu += 1

	# Maskable H/V scanline IRQ. Mirrors cpu_nmi's push sequence; vector $FFFE
	# (emu) / $FFEE (native). Caller checks the I-flag before invoking.
	func cpu_irq []
		op_master   = 0                            # count the interrupt sequence's access cycles
		op_accesses = 0
		count_cpu   = true
		if [ !cpu.e ]                              # native mode: push PBR
			cpu_w[ cpu.sp, cpu.pbr ]
			cpu.sp -= 1
		cpu_w[ cpu.sp, u8[cpu.pc >> 8] ]
		cpu.sp -= 1
		cpu_w[ cpu.sp, u8[cpu.pc & 0xFF] ]
		cpu.sp -= 1
		cpu_w[ cpu.sp, cpu.p ]
		cpu.sp -= 1
		cpu.p  |= 0x04
		cpu.p  &= ~0x08
		vec    : u16 [ (cpu.e) ? 0xFFFE : 0xFFEE ]
		lo     : u8  [ cpu_r[ vec ] ]
		hi     : u8  [ cpu_r[ vec + 1 ] ]
		cpu.pc  = lo | (hi << 8)
		cpu.pbr = 0
		irq_occurred = true
		count_cpu = false
		steal_master += op_master + 12             # interrupt: stack pushes/vector reads + 2 internal cycles
		op_master = 0
		if [ getenv['ASNES_IRQ_LOG'] && dbg_frames < 200 ]
			printf[ "IRQ f%u line=%d vtime=%d htime=%d nmitimen=%02X $0041=%02X%02X\n", dbg_frames, frame_cycle / 228, i32[vtime], i32[htime], nmitimen, cpu.memory[0x7E0042], cpu.memory[0x7E0041] ]

	# --- Gaussian interpolation for BRR samples ---

	func gaussian_interpolate [ frac: i32, ch: u16 ] -> i16
		fr : frac & 0xFF
		s0 : i16 [ spc.channels[ch].samples[0] ]
		s1 : i16 [ spc.channels[ch].samples[1] ]
		s2 : i16 [ spc.channels[ch].samples[2] ]
		s3 : i16 [ spc.channels[ch].samples[3] ]
		# authentic S-DSP 4-tap gaussian: s0=newest .. s3=oldest
		result : i32 [
			gauss[255 - fr] * i32[s3] +
			gauss[511 - fr] * i32[s2] +
			gauss[256 + fr] * i32[s1] +
			gauss[  0 + fr] * i32[s0]
		]
		result >>= 11
		if [ result >  32767 ] result = 32767
		if [ result < -32768 ] result = -32768
		return i16[result]

	# --- Echo processing ---

	func echo_add [ left: f32, right: f32 ]
		echo_delay  : u8  [ dsp_r[0x7D] & 0x0F ]
		echo_length : u16 [ echo_delay * 0x800 ]
		if [ echo_length == 0 ] return
		# FLG bit5 (ECEN, 0x20) DISABLES echo-buffer writes to RAM. real HW honors
		# this; writing anyway corrupts whatever the driver stores in that region.
		echo_writes : bool [ (dsp_r[0x6C] & 0x20) == 0 ]

		echo_enable   : u8 [ dsp_r[0x4D ] ]
		echo_volume_l : u8 [ dsp_r[0x2C ] ]
		echo_volume_r : u8 [ dsp_r[0x3C ] ]
		echo_feedback : u8 [ dsp_r[0x0D ] ]
		echo_start    : u16 [ dsp_r[0x6D ] << 8 ]

		echo_input_l : f32 [ 0.0 ]
		echo_input_r : f32 [ 0.0 ]
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ echo_enable & (1 << ch) ]
				echo_input_l += spc.channels[ch].output_l
				echo_input_r += spc.channels[ch].output_r

		nsamples    : u16 [ echo_length / 4 ]
		echo_addr_l : u16 [ echo_start + (spc.echo_pos * 4)     ]
		echo_addr_r : u16 [ echo_start + (spc.echo_pos * 4) + 2 ]

		# read the delayed sample from the ring buffer and push it into the 8-tap
		# FIR delay line (8 *consecutive* reads, NOT spread across the buffer —
		# spreading produces a per-buffer-length repeat that masks the music).
		spc.fir_idx = (spc.fir_idx + 1) & 7
		spc.fir_hist_l[spc.fir_idx] = i16[spc_r16[echo_addr_l]] / 32768.0
		spc.fir_hist_r[spc.fir_idx] = i16[spc_r16[echo_addr_r]] / 32768.0

		fir_l : f32 [ 0.0 ]
		fir_r : f32 [ 0.0 ]
		for [ tap: i32 0, tap < 8, tap += 1 ]
			coeff : f32 [ i8[dsp_r[0x0F + (tap * 0x10)]] / 128.0 ]
			h     : i32 [ (spc.fir_idx - 7 + tap) & 7 ]   # tap 7 = newest
			fir_l += spc.fir_hist_l[h] * coeff
			fir_r += spc.fir_hist_r[h] * coeff

		efb : f32 [ i8[echo_feedback] / 128.0 ]
		# write back: this sample's dry echo input + FIR output * feedback
		new_l : f32 [ clamp[ echo_input_l + fir_l * efb, -1.0, 1.0 ] ]
		new_r : f32 [ clamp[ echo_input_r + fir_r * efb, -1.0, 1.0 ] ]
		if [ echo_writes ]
			nel : i16 [ new_l * 32767 ]
			ner : i16 [ new_r * 32767 ]
			spc_w[ echo_addr_l,     u8[nel & 0xFF] ]
			spc_w[ echo_addr_l + 1, u8[nel >> 8]   ]
			spc_w[ echo_addr_r,     u8[ner & 0xFF] ]
			spc_w[ echo_addr_r + 1, u8[ner >> 8]   ]

		spc.echo_pos = (spc.echo_pos + 1) % nsamples

		echo_out_l = fir_l * (i8[echo_volume_l] / 128.0)
		echo_out_r = fir_r * (i8[echo_volume_r] / 128.0)

	# --- Direct DSP audio test (no CPU, no upload) ---
	# Loads a tiny looping BRR square wave into SPC RAM, points voice 0 at it,
	# and keys it on by writing the DSP registers directly. Proves the
	# SPC-DSP -> generate_audio -> ALSA path in isolation from the cartridge.
	func audio_test []
		reset_spc[]
		# two BRR blocks of a square wave. block0 ($0200) is plain data; block1
		# ($0209) carries end+loop so the decoder loops back to $0200 -> a
		# continuous ~1kHz square. shift=12, filter=0.
		spc.ram[0x0200] = 0xC0              # block0 header: shift=C, no flags
		spc.ram[0x0209] = 0xC3              # block1 header: shift=C, end+loop
		for [ n: i32 0, n < 4, n += 1 ]
			spc.ram[0x0201 + n] = 0x77      # block0: two +7 nibbles
			spc.ram[0x0205 + n] = 0x88      # block0: two -8 nibbles
			spc.ram[0x020A + n] = 0x77      # block1: two +7 nibbles
			spc.ram[0x020E + n] = 0x88      # block1: two -8 nibbles
		# sample directory at $0100, entry 0: start=$0200, loop=$0200
		spc.ram[0x0100] = 0x00
		spc.ram[0x0101] = 0x02
		spc.ram[0x0102] = 0x00
		spc.ram[0x0103] = 0x02
		# DSP voice 0 + master volume, gain mode (no ADSR ramp), key on
		spc.dsp[0x5D] = 0x01                # sample directory page = $0100
		spc.dsp[0x00] = 0x7F                # voice 0 vol L
		spc.dsp[0x01] = 0x7F                # voice 0 vol R
		spc.dsp[0x02] = 0x00                # pitch lo
		spc.dsp[0x03] = 0x10                # pitch hi -> 0x1000 = 1.0x (32kHz)
		spc.dsp[0x04] = 0x00                # source number 0
		spc.dsp[0x05] = 0x00                # ADSR1 bit7=0 -> use GAIN
		spc.dsp[0x07] = 0x7F                # GAIN direct, near-max envelope
		spc.dsp[0x0C] = 0x7F                # master vol L
		spc.dsp[0x1C] = 0x7F                # master vol R
		spc.dsp[0x4C] = 0x01                # KON voice 0
		spc_keyon[ 0 ]
		puts[ 'audio_test: voice 0 keyed on (~2kHz square)' ]

	# --- .spc playback (isolates SPC700 + DSP + timers; no CPU/ROM/upload) ---
	# Loads an APU snapshot: 64KB RAM, 128 DSP regs, and the SPC700 registers,
	# then we just run spc_step + generate_audio. Proves the SPC core end-to-end.
	func load_spc []
		reset_spc[]
		f : ref FILE [ fopen[ spcfile, 'rb' ] ]
		expect f, 'could not open spc file: {spcfile}'
		buf : ref u8 [ calloc[ 1, 0x10200 ] ]
		fread[ buf, 1, 0x10200, f ]
		fclose[ f ]
		spc.pc  = u16[buf[0x25]] | (u16[buf[0x26]] << 8)
		spc.a   = buf[0x27]
		spc.x   = buf[0x28]
		spc.y   = buf[0x29]
		spc.psw = buf[0x2A]
		spc.sp  = buf[0x2B]
		memcpy[ spc.ram, buf + 0x100, 0x10000 ]
		memcpy[ spc.dsp, buf + 0x10100, 128 ]
		free[ buf ]
		# seed the APU input ports (CPU->APU latch) from the snapshot. a .spc rip
		# has no main CPU, so these stay frozen at capture — the driver keeps
		# seeing the same "play track" handshake and never fades/stops.
		spc.ports[0] = spc.ram[0xF4]
		spc.ports[1] = spc.ram[0xF5]
		spc.ports[2] = spc.ram[0xF6]
		spc.ports[3] = spc.ram[0xF7]
		# seed timer state from the snapshot's APU registers
		spc.timer_on        = spc.ram[0xF1] & 0x07
		spc.timer_target[0] = spc.ram[0xFA]
		spc.timer_target[1] = spc.ram[0xFB]
		spc.timer_target[2] = spc.ram[0xFC]
		# key on any voices the snapshot left active
		for [ ch: i32 0, ch < 8, ch += 1 ]
			if [ spc.dsp[0x4C] & (1 << ch) ] spc_keyon[ ch ]
		printf[ "loaded spc: pc=%04X a=%02X sp=%02X F1=%02X dividers=%02X %02X %02X\n",
			spc.pc, spc.a, spc.sp, spc.ram[0xF1], spc.ram[0xFA], spc.ram[0xFB], spc.ram[0xFC] ]


	# --- Audio generation ---

	# apply key-off then key-on latched since the last DSP sample (KON wins,
	# matching the S-DSP: a voice keyed this sample sounds)
	func apply_latches []
		if [ spc.koff_latch || spc.kon_latch ]
			for [ kc: i32 0, kc < 8, kc += 1 ]
				if [ spc.koff_latch & (1 << kc) ] spc_keyoff[ kc ]
				if [ spc.kon_latch & (1 << kc) ] spc_keyon[ kc ]
			spc.kon_latch  = 0
			spc.koff_latch = 0

	func audio_slice_size [] -> sz
		to_write : sz [ spc.sample_rate / 60 ]
		if [ to_write > spc.buffer_size ] to_write = spc.buffer_size
		return to_write

	func flush_audio [ to_write: sz ]
		wr : i64 [ snd_pcm_writei[ spc.pcm_handle, spc.audio_buffer, to_write ] ]
		if [ wr == -EPIPE ]
			snd_pcm_recover[ spc.pcm_handle, wr, 0 ]
			snd_pcm_prepare[ spc.pcm_handle ]

	# mix one DSP output sample (8 voices + echo) into audio_buffer[i]
	func mix_one_sample [ i: i32 ]
			apply_latches[]

			left  : f32 [ 0.0 ]
			right : f32 [ 0.0 ]

			for [ ch: u16 0, ch < 8, ch += 1 ]
				# inactive voices must contribute 0 to the echo, not their stale
				# last output — otherwise dead voices keep feeding the echo buffer
				if [ !spc.channels[ch].active ]
					spc.channels[ch].output_l = 0.0
					spc.channels[ch].output_r = 0.0
					continue

				ch_base : u8 [ ch * 0x10 ]
				vol_l   : u8 [ dsp_r[ch_base + 0x00 ] ]
				vol_r   : u8 [ dsp_r[ch_base + 0x01 ] ]
				pitch_l : u8 [ dsp_r[ch_base + 0x02 ] ]
				pitch_h : u8 [ dsp_r[ch_base + 0x03 ] ]
				src_n   : u8 [ dsp_r[ch_base + 0x04 ] ]
				adsr1   : u8 [ dsp_r[ch_base + 0x05 ] ]
				adsr2   : u8 [ dsp_r[ch_base + 0x06 ] ]
				gain    : u8 [ dsp_r[ch_base + 0x07 ] ]

				pitch : u16 [ pitch_l | ((pitch_h & 0x3F) << 8) ]
				if [ pitch == 0 ]
					spc.channels[ch].output_l = 0.0
					spc.channels[ch].output_r = 0.0
					continue

				dir_page     : u8  [ dsp_r[0x5D ] ]
				src_dir      : u16 [ (dir_page << 8) + (src_n * 4) ]
				sample_start : u16 [ spc_r16[src_dir] ]
				sample_loop  : u16 [ spc_r16[src_dir + 2] ]

				spc.channels[ch].frac += pitch
				while [ spc.channels[ch].frac >= 0x1000 ]
					spc.channels[ch].frac -= 0x1000
					spc.channels[ch].pos  += 1

					block_pos : u16 [ sample_start + (spc.channels[ch].pos / 16) * 9 ]
					block_header : u8  [ spc_r[ block_pos ] ]
					sample_idx   : u8  [ spc.channels[ch].pos % 16 ]

					sample_byte : u8  [ spc_r[ block_pos + 1 + (sample_idx / 2) ] ]
					hi_nib      : i8 [ (sample_byte >> 4) & 0xF ]
					lo_nib      : i8 [ sample_byte & 0xF ]
					sample_4bit : i8 [ (sample_idx & 1) ? lo_nib : hi_nib ]
					if [ sample_4bit > 7 ] sample_4bit -= 16

					shift_amt  : u8  [ block_header >> 4 ]
					dec_sample : i32 [ i32[sample_4bit] << shift_amt ]
					if [ shift_amt > 12 ]                  # invalid shift: sign bit only
						dec_sample = (i32[sample_4bit] >> 4) << 11
					# BRR IIR filters use arithmetic shifts (floor), matching the
					# S-DSP exactly — C-style * / truncation buzzes on negatives.
					bfilter    : u8  [ (block_header >> 2) & 0x3 ]
					switch [ bfilter ]
						case 0
							# no filter
						case 1
							s0 : i32 [ spc.channels[ch].samples[0] ]
							dec_sample += s0 + ((0 - s0) >> 4)
						case 2
							s0 : i32 [ spc.channels[ch].samples[0] ]
							s1 : i32 [ spc.channels[ch].samples[1] ]
							dec_sample += (s0 << 1) + ((0 - (s0 * 3)) >> 5) - s1 + (s1 >> 4)
						case 3
							s0 : i32 [ spc.channels[ch].samples[0] ]
							s1 : i32 [ spc.channels[ch].samples[1] ]
							dec_sample += (s0 << 1) + ((0 - (s0 * 13)) >> 6) - s1 + ((s1 * 3) >> 4)

					if [ dec_sample >  32767 ] dec_sample =  32767
					if [ dec_sample < -32768 ] dec_sample = -32768

					spc.channels[ch].samples[3] = spc.channels[ch].samples[2]
					spc.channels[ch].samples[2] = spc.channels[ch].samples[1]
					spc.channels[ch].samples[1] = spc.channels[ch].samples[0]
					spc.channels[ch].samples[0] = i16[dec_sample]

					# end-of-block: after decoding sample 15, honor the END/LOOP flags
					# BRR header bit0 = END, bit1 = LOOP
					if [ sample_idx == 15 && (block_header & 0x01) ]
						spc.dsp[0x7C] = spc.dsp[0x7C] | (1 << ch)   # set ENDX
						if [ block_header & 0x02 ]                  # loop
							spc.channels[ch].pos = (((sample_loop - sample_start) / 9) * 16) - 1
						el
							spc.channels[ch].active   = 0           # one-shot finished
							spc.channels[ch].envelope = 0

				frac_v : u8  [ spc.channels[ch].frac >> 4 ]
				interp : i16 [ gaussian_interpolate[ frac_v, ch ] ]

				# --- envelope update (range 0..0x7FF) ---
				env : i32 [ spc.channels[ch].envelope ]
				if [ spc.channels[ch].env_state == 3 ]
					env -= 8                                   # release: linear fade
					if [ env <= 0 ]
						env = 0
						spc.channels[ch].active = 0
				el [ adsr1 & 0x80 ]
					arate : i32 [ adsr2 & 0x1F ]               # sustain rate default
					if [ spc.channels[ch].env_state == 0 ]
						arate = ((adsr1 & 0x0F) << 1) + 1         # attack
					el [ spc.channels[ch].env_state == 1 ]
						arate = (((adsr1 >> 4) & 0x07) << 1) + 16 # decay
					aper : i32 [ env_rate[ arate ] ]
					if [ aper > 0 ]
						spc.channels[ch].env_count += 1
						if [ spc.channels[ch].env_count >= aper ]
							spc.channels[ch].env_count = 0
							if [ spc.channels[ch].env_state == 0 ]
								env += ((arate == 31) ? 1024 : 32)
								if [ env >= 0x7FF ]
									env = 0x7FF
									spc.channels[ch].env_state = 1
							el
								env -= (((env - 1) >> 8) + 1)
								sl : i32 [ (((adsr2 >> 5) & 0x07) + 1) << 8 ]
								if [ spc.channels[ch].env_state == 1 && env <= sl ]
									spc.channels[ch].env_state = 2
				el
					if [ gain & 0x80 ]
						gmode : u8  [ (gain >> 5) & 0x03 ]
						grate : i32 [ gain & 0x1F ]
						gper  : i32 [ env_rate[ grate ] ]
						if [ gper > 0 ]
							spc.channels[ch].env_count += 1
							if [ spc.channels[ch].env_count >= gper ]
								spc.channels[ch].env_count = 0
								switch [ gmode ]
									case 0
										env -= 32
									case 1
										env -= (((env - 1) >> 8) + 1)
									case 2
										env += 32
									default
										env += ((env < 0x600) ? 32 : 8)
					el
						env = (gain & 0x7F) << 4                  # direct gain
				if [ env > 0x7FF ] env = 0x7FF
				if [ env < 0 ] env = 0
				spc.channels[ch].envelope = i16[ env ]
				spc.dsp[ ch_base + 0x08 ] = u8[ (env >> 4) & 0x7F ]   # ENVX

				final_sample : i32 [ (i32[interp] * env) >> 11 ]
				if [ final_sample >  32767 ] final_sample =  32767
				if [ final_sample < -32768 ] final_sample = -32768
				l : f32 [ (final_sample / 32768.0) * (i8[vol_l] / 128.0) ]
				r : f32 [ (final_sample / 32768.0) * (i8[vol_r] / 128.0) ]
				spc.channels[ch].output_l = l
				spc.channels[ch].output_r = r
				left  += l
				right += r

			mvol_l : u8 [ dsp_r[0x0C ] ]
			mvol_r : u8 [ dsp_r[0x1C ] ]
			left  *= i8 [ mvol_l ] / 128.0
			right *= i8 [ mvol_r ] / 128.0

			echo_add[ left, right ]
			left  = clamp[ left  + echo_out_l, -1.0, 1.0 ]
			right = clamp[ right + echo_out_r, -1.0, 1.0 ]

			spc.audio_buffer[i * 2]     = i16[ left  * 32000 * volume ]
			spc.audio_buffer[i * 2 + 1] = i16[ right * 32000 * volume ]

	# .spc / beep path: SPC + DSP only, no CPU. one real-time slice per call.
	func generate_audio [ sps: i32 ]
		avail : i64 [ snd_pcm_avail[ spc.pcm_handle ] ]
		if [ avail < 0 ]
			if [ avail == -EPIPE ]
				snd_pcm_recover[ spc.pcm_handle, avail, 0 ]
				snd_pcm_prepare[ spc.pcm_handle ]
			return
		to_write : sz [ audio_slice_size[] ]
		if [ to_write <= 0 ] return
		for [ i: i32 0, i < to_write, i += 1 ]
			for [ k: i32 0, k < sps, k += 1 ]
				spc_step[]
			mix_one_sample[ i ]
		flush_audio[ to_write ]

	# ROM path: co-schedule the 65816 + SPC700/DSP for one real-time frame.
	# the SPC advances ONLY at safe points — when the CPU reads an APU port
	# (handshake catch-up) and in a bulk pass after the CPU frame — so the
	# game's multi-port command bursts land atomically and the driver never
	# reads a half-written command. blocking audio paces it to 60fps.
	# legacy pre-refactor scheduling (continuous SPC stepping in the CPU loop,
	# mix the whole slice at the end). diagnostic: this version flowed the
	# 2nd-upload command (music played) but had the steady-state port race.
	# Boot phase (silent): step the SPC continuously so the sound driver reaches
	# its loader and the song uploads (the boot handshake needs continuous SPC).
	# no audio is playing yet, so the port race can't corrupt anything audible.
	func run_rom_frame_boot []
		avail : i64 [ snd_pcm_avail[ spc.pcm_handle ] ]
		if [ avail < 0 ]
			if [ avail == -EPIPE ]
				snd_pcm_recover[ spc.pcm_handle, avail, 0 ]
				snd_pcm_prepare[ spc.pcm_handle ]
			return
		to_write : sz [ audio_slice_size[] ]
		if [ to_write <= 0 ] return
		samples   : i32  [ i32[to_write] ]
		done      : i32  [ 0 ]
		sub       : i32  [ 0 ]
		nmi_cyc   : i32  [ 59667 * 225 / 262 ]
		nmi_fired : bool [ false ]
		fcpu      : i32  [ 0 ]
		cur_line  : i32  [ 0 ]
		irq_line_fired : i32 [ -1 ]
		in_vblank = false
		hdma_setup[]
		while [ fcpu < 59667 ]
			if [ cpu_wai && !nmi_fired ]
				wtar : i32 [ nmi_cyc ]
				wim  : u8  [ nmitimen & 0x30 ]
				if [ wim != 0 && (cpu.p & 0x04) == 0 ]
					witl : i32 [ -1 ]
					if [ wim == 0x10 ] witl = (fcpu / 228) + 1
					el [ irq_line_fired != i32[vtime] ] witl = i32[vtime]
					if [ witl >= 0 ]
						wic : i32 [ witl * 228 ]
						if [ wic > fcpu && wic < wtar ] wtar = wic
				fcpu = wtar
			if [ !nmi_fired && fcpu >= nmi_cyc ]
				in_vblank    = true
				nmi_occurred = true
				cpu_wai      = false
				if [ nmitimen & 0x80 ] cpu_nmi[]
				nmi_fired = true
			cnl : i32 [ fcpu / 228 ]
			im  : u8  [ nmitimen & 0x30 ]
			if [ im != 0 && (cpu.p & 0x04) == 0 && cnl < 224 ]
				do_irq : bool [ false ]
				if [ im == 0x10 ]
					if [ cnl != irq_line_fired ] do_irq = true
				el [ cnl >= i32[vtime] && irq_line_fired != i32[vtime] ]
					do_irq = true
				if [ do_irq ]
					cpu_wai = false
					cpu_irq[]
					if [ im == 0x10 ] irq_line_fired = cnl
					el irq_line_fired = i32[vtime]
			if [ cpu_wai ]
				break
			c : i32 [ cpu_step[] ]
			if [ c < 2 ] c = 2
			fcpu += c
			cpu_cycles += i64[ c ]
			frame_cycle = fcpu
			nl : i32 [ fcpu / 228 ]
			while [ cur_line < nl && cur_line < 224 ]
				steal_master += 40                   # DRAM refresh: ~40 master per scanline
				hdma_run_line[]
				ppu_snapshot_line[ cur_line ]
				cur_line += 1
			spc.cycle_accum += c * 2048
			while [ spc.cycle_accum >= 7159 ]
				scy : i32 [ spc_step[] ]
				spc.cycle_accum -= scy * 7159        # real SMP cycles: ~3.5 CPU cyc per SMP cyc
				sub += scy
				if [ sub >= 32 ]                     # DSP emits a sample every 32 SMP cycles
					sub -= 32
					if [ done < samples ]
						mix_one_sample[ done ]
						done += 1
		while [ cur_line < 224 ]
			hdma_run_line[]
			ppu_snapshot_line[ cur_line ]
			cur_line += 1
		steal_master += 38 * 40              # DRAM refresh on the 38 vblank scanlines (224-261)
		if [ !nmi_fired ]
			in_vblank    = true
			nmi_occurred = true
			if [ nmitimen & 0x80 ] cpu_nmi[]
		while [ done < samples ]
			scy : i32 [ spc_step[] ]
			sub += scy
			if [ sub >= 32 ]
				sub -= 32
				mix_one_sample[ done ]
				done += 1
		spc.cycle_accum = 0
		in_vblank = false
		flush_audio[ to_write ]

	# Co-scheduler (clean ding): SPC advances only at safe points — when the CPU
	# reads an APU port (handshake catch-up) and in a bulk pass after the CPU
	# frame — so command write-bursts are atomic to the SPC. blocking audio paces 60fps.
	func run_rom_frame []
		avail : i64 [ snd_pcm_avail[ spc.pcm_handle ] ]
		if [ avail < 0 ]
			if [ avail == -EPIPE ]
				snd_pcm_recover[ spc.pcm_handle, avail, 0 ]
				snd_pcm_prepare[ spc.pcm_handle ]
			return
		to_write : sz [ audio_slice_size[] ]
		if [ to_write <= 0 ] return
		samples   : i32  [ i32[to_write] ]
		done      : i32  [ 0 ]
		sub       : i32  [ 0 ]
		nmi_cyc   : i32  [ 59667 * 225 / 262 ]
		nmi_fired : bool [ false ]
		fcpu      : i32  [ 0 ]
		cur_line  : i32  [ 0 ]
		irq_line_fired : i32 [ -1 ]
		in_vblank = false
		hdma_setup[]
		while [ fcpu < 59667 ]
			if [ cpu_wai && !nmi_fired ]
				wtar : i32 [ nmi_cyc ]
				wim  : u8  [ nmitimen & 0x30 ]
				if [ wim != 0 && (cpu.p & 0x04) == 0 ]
					witl : i32 [ -1 ]
					if [ wim == 0x10 ] witl = (fcpu / 228) + 1
					el [ irq_line_fired != i32[vtime] ] witl = i32[vtime]
					if [ witl >= 0 ]
						wic : i32 [ witl * 228 ]
						if [ wic > fcpu && wic < wtar ] wtar = wic
				fcpu = wtar
			if [ !nmi_fired && fcpu >= nmi_cyc ]
				in_vblank    = true
				nmi_occurred = true
				cpu_wai      = false
				if [ nmitimen & 0x80 ] cpu_nmi[]
				nmi_fired = true
			cnl : i32 [ fcpu / 228 ]
			im  : u8  [ nmitimen & 0x30 ]
			if [ im != 0 && (cpu.p & 0x04) == 0 && cnl < 224 ]
				do_irq : bool [ false ]
				if [ im == 0x10 ]
					if [ cnl != irq_line_fired ] do_irq = true
				el [ cnl >= i32[vtime] && irq_line_fired != i32[vtime] ]
					do_irq = true
				if [ do_irq ]
					cpu_wai = false
					cpu_irq[]
					if [ im == 0x10 ] irq_line_fired = cnl
					el irq_line_fired = i32[vtime]
			if [ cpu_wai ]
				break
			port_read = false
			c : i32 [ cpu_step[] ]
			if [ c < 1 ] c = 1
			fcpu += c
			cpu_cycles += i64[ c ]
			frame_cycle = fcpu
			nl : i32 [ fcpu / 228 ]
			while [ cur_line < nl && cur_line < 224 ]
				steal_master += 40                   # DRAM refresh: ~40 master per scanline
				hdma_run_line[]
				ppu_snapshot_line[ cur_line ]
				cur_line += 1
			spc.cycle_accum += c * 2048
			if [ port_read ]
				while [ spc.cycle_accum >= 7159 ]
					scy : i32 [ spc_step[] ]
					spc.cycle_accum -= scy * 7159        # real SMP cycles: ~3.5 CPU cyc per SMP cyc
					sub += scy
					if [ sub >= 32 ]                     # DSP emits a sample every 32 SMP cycles
						sub -= 32
						if [ done < samples ]
							mix_one_sample[ done ]
							done += 1
		while [ cur_line < 224 ]
			hdma_run_line[]
			ppu_snapshot_line[ cur_line ]
			cur_line += 1
		steal_master += 38 * 40              # DRAM refresh on the 38 vblank scanlines (224-261)
		if [ !nmi_fired ]
			in_vblank    = true
			nmi_occurred = true
			if [ nmitimen & 0x80 ] cpu_nmi[]
		while [ done < samples ]
			scy : i32 [ spc_step[] ]
			sub += scy
			if [ sub >= 32 ]
				sub -= 32
				mix_one_sample[ done ]
				done += 1
		spc.cycle_accum = 0
		in_vblank = false
		flush_audio[ to_write ]

	# --- Load ROM ---

	func reset_spc [] -> bool
		if [ !spc_rom_loaded ]
			if [ !spc_boot_rom ]
				spc_boot_rom = calloc[ 1, 64 ]
			# default the SPC700 IPL to bios.rom in the launch cwd unless --spc_rom given
			if [ !spc_rom ] spc_rom = path '{path.path_startup[]}/bios.rom'
			f    : ref FILE [ fopen[ spc_rom, 'rb' ] ]
			size : sz [ 0 ]
			expect f, 'could not open spc-rom file: {spc_rom}'
			fseek [ f, 0, SEEK_END ]
			size = ftell[ f ]
			rewind[ f ]
			expect size == 64, 'bad spc rom size'
			nrd : i64 [ fread[spc_boot_rom, size, 1, f] ]
			expect nrd == 1, "spc rom read failed"
			fclose[ f ]
			spc_rom_loaded = true

		spc = spc_state []
		memcpy[ spc.ram + 0xFFC0, spc_boot_rom, 64 ]
		spc.pc          = 0xFFC0
		spc.sp          = 0xFF
		spc.psw         = 0x02
		spc.sample_rate = 32000
		spc.buffer_size = 1024
		spc.audio_buffer = calloc[ 1, spc.buffer_size * 2 * 2 ]

		pb  : i32 [ SND_PCM_STREAM_PLAYBACK ]
		err : i32 [ snd_pcm_open[ref spc.pcm_handle, 'pulse', pb, 0] ]

		if [ err < 0 ] return false

		psz    : snd_pcm_hw_params_sizeof[ ]
		params : ref snd_pcm_hw_params_t [ calloc[ 1, psz ] ]
		snd_pcm_hw_params_any         [ spc.pcm_handle, params ]
		rw  : i32 [ SND_PCM_ACCESS_RW_INTERLEAVED ]
		fmt : i32 [ SND_PCM_FORMAT_S16_LE ]

		snd_pcm_hw_params_set_access  [spc.pcm_handle, params, rw]
		snd_pcm_hw_params_set_format  [spc.pcm_handle, params, fmt]
		snd_pcm_hw_params_set_channels[spc.pcm_handle, params, 2]
		snd_pcm_hw_params_set_rate[spc.pcm_handle, params, spc.sample_rate, 0]
		# keep the ring buffer small so snd_pcm_avail paces the SPC to real-time
		# (otherwise PulseAudio reports a ~32s buffer and the engine races ahead).
		bufsz : sz [ 4096 ]
		persz : sz [ 1024 ]
		snd_pcm_hw_params_set_buffer_size_near[ spc.pcm_handle, params, ref bufsz ]
		snd_pcm_hw_params_set_period_size_near[ spc.pcm_handle, params, ref persz, null ]

		spc.ports[0] = 0xAA
		spc.ports[1] = 0xBB

		success : bool [ snd_pcm_hw_params[ spc.pcm_handle, params ] >= 0 ]
		if [ success ]
			perr : i32 [ snd_pcm_prepare[ spc.pcm_handle ] ]
			if [ perr < 0 ]
				puts[ 'ALSA prepare failed: {snd_strerror[perr]}' ]
				success = false
		
		return success

	func load [] -> bool
		f : ref FILE [ fopen[ rom, 'rb' ] ]
		expect f, 'could not open ROM file'
		fseek[ f, 0, SEEK_END ]
		size : sz [ ftell[ f ] ]
		rewind[ f ]
		# .smc copier header: 512 bytes present when size mod 0x8000 == 512.
		# skip it so the reset vector / banks aren't shifted by 512.
		header : sz [ ((size % 0x8000) == 512) ? 512 : 0 ]
		if [ header ]
			fseek[ f, header, SEEK_SET ]
			size -= header
		expect size < 0x1000000, 'ROM too large'

		cpu = cpu_state []
		ppu = ppu_state []
		cpu.memory = calloc[ 1, 0x1000000 ]
		nbanks : i32 [ size / 0x8000 ]
		if [ nbanks < 1 ] nbanks = 1
		rombuf : ref u8 [ calloc[ 1, (nbanks + 1) * 0x8000 ] ]
		fread[ rombuf, 1, size, f ]
		fclose[ f ]
		# build a flat 24-bit LoROM map: each bank's $8000-$FFFF window
		# mirrors a 32KB ROM slice. banks $7E/$7F stay WRAM (left zeroed).
		for [ b: i32 0, b < 0x100, b += 1 ]
			if [ b == 0x7E ] continue
			if [ b == 0x7F ] continue
			chunk : i32 [ (b & 0x7F) % nbanks ]
			dst   : i64 [ (b * 0x10000) + 0x8000 ]
			src   : i64 [ chunk * 0x8000 ]
			memcpy[ cpu.memory + dst, rombuf + src, 0x8000 ]
		free[ rombuf ]

		puts[ 'loaded rom: {rom} ({size} bytes)' ]
		reset_vector : u16 [ cpu.memory[0xFFFC] | (cpu.memory[0xFFFD] << 8) ]
		printf[ "reset vector: 0x%04X\n", reset_vector ]
		printf[ "first op: 0x%02X\n", cpu.memory[reset_vector] ]
		irq_hi : u8 [ cpu.memory[0xFFFF] ]
		irq_lo : u8 [ cpu.memory[0xFFFE] ]
		printf[ "IRQ vector: 0x%02X%02X\n", irq_hi, irq_lo ]

		cpu.pc = reset_vector
		cpu.sp = 0x01FF
		cpu.p  = 0x34

		reset_spc[]
		return true

	# --- Trinity ---

	# --- SPC700 opcode self-test (deterministic, no ROM/.spc needed) ---
	func t_chk [ name: symbol, got: i32, want: i32 ]
		if [ got != want ]
			printf[ "FAIL %-12s got=%02X want=%02X\n", name, got, want ]
			dbg_h += 1
		el
			printf[ "ok   %s\n", name ]

	# run one instruction placed at $0300 with the given operand bytes
	func t_run [ op: u8, o1: u8, o2: u8 ]
		spc.ram[0x0300] = op
		spc.ram[0x0301] = o1
		spc.ram[0x0302] = o2
		spc.pc = 0x0300
		spc_step[]

	func spc_test []
		spc = spc_state []
		dbg_h = 0

		# ADC A,#imm : 0x50 + 0x50 = 0xA0, N|V set, C|Z|H clear
		spc.a = 0x50  spc.psw = 0x00
		t_run[ 0x88, 0x50, 0x00 ]
		t_chk[ 'ADC.res', spc.a, 0xA0 ]
		t_chk[ 'ADC.NVZC', spc.psw & 0xC3, 0xC0 ]
		# ADC carry-out + half-carry: 0xFF + 0x01 = 0x00, C|Z|H set
		spc.a = 0xFF  spc.psw = 0x00
		t_run[ 0x88, 0x01, 0x00 ]
		t_chk[ 'ADC2.res', spc.a, 0x00 ]
		t_chk[ 'ADC2.HZC', spc.psw & 0x0B, 0x0B ]

		# SBC A,#imm : 0x50 - 0x30 (C=1) = 0x20, C set, N|V|Z clear
		spc.a = 0x50  spc.psw = 0x01
		t_run[ 0xA8, 0x30, 0x00 ]
		t_chk[ 'SBC.res', spc.a, 0x20 ]
		t_chk[ 'SBC.C', spc.psw & 0x01, 0x01 ]

		# CMP A,#imm equal : Z|C set, N clear
		spc.a = 0x42  spc.psw = 0x00
		t_run[ 0x68, 0x42, 0x00 ]
		t_chk[ 'CMP.ZC', spc.psw & 0x83, 0x03 ]
		# CMP A < imm : C clear, N set
		spc.a = 0x10  spc.psw = 0x00
		t_run[ 0x68, 0x20, 0x00 ]
		t_chk[ 'CMP2.NC', spc.psw & 0x83, 0x80 ]

		# AND/OR/EOR A,#imm  (N,Z)
		spc.a = 0xF0  spc.psw = 0x00
		t_run[ 0x28, 0x0F, 0x00 ]
		t_chk[ 'AND.res', spc.a, 0x00 ]
		t_chk[ 'AND.Z', spc.psw & 0x82, 0x02 ]
		spc.a = 0x0F  spc.psw = 0x00
		t_run[ 0x08, 0x80, 0x00 ]
		t_chk[ 'OR.res', spc.a, 0x8F ]
		t_chk[ 'OR.N', spc.psw & 0x82, 0x80 ]

		# shifts/rotates on A
		spc.a = 0x81  spc.psw = 0x00
		t_run[ 0x1C, 0x00, 0x00 ]          # ASL A
		t_chk[ 'ASL.res', spc.a, 0x02 ]
		t_chk[ 'ASL.C', spc.psw & 0x01, 0x01 ]
		spc.a = 0x01  spc.psw = 0x00
		t_run[ 0x5C, 0x00, 0x00 ]          # LSR A
		t_chk[ 'LSR.res', spc.a, 0x00 ]
		t_chk[ 'LSR.ZC', spc.psw & 0x03, 0x03 ]
		spc.a = 0x80  spc.psw = 0x01
		t_run[ 0x3C, 0x00, 0x00 ]          # ROL A (carry in)
		t_chk[ 'ROL.res', spc.a, 0x01 ]
		t_chk[ 'ROL.C', spc.psw & 0x01, 0x01 ]
		spc.a = 0x01  spc.psw = 0x01
		t_run[ 0x7C, 0x00, 0x00 ]          # ROR A (carry in)
		t_chk[ 'ROR.res', spc.a, 0x80 ]
		t_chk[ 'ROR.NC', spc.psw & 0x81, 0x81 ]

		# INC/DEC A
		spc.a = 0xFF  spc.psw = 0x00
		t_run[ 0xBC, 0x00, 0x00 ]
		t_chk[ 'INC.ZA', spc.a, 0x00 ]
		t_chk[ 'INC.Z', spc.psw & 0x82, 0x02 ]
		spc.a = 0x00  spc.psw = 0x00
		t_run[ 0x9C, 0x00, 0x00 ]
		t_chk[ 'DEC.A', spc.a, 0xFF ]
		t_chk[ 'DEC.N', spc.psw & 0x82, 0x80 ]

		# word ops: INCW / ADDW / SUBW on dp $20
		spc.ram[0x20] = 0xFF  spc.ram[0x21] = 0x00
		t_run[ 0x3A, 0x20, 0x00 ]          # INCW $20 -> 0x0100
		t_chk[ 'INCW.lo', spc.ram[0x20], 0x00 ]
		t_chk[ 'INCW.hi', spc.ram[0x21], 0x01 ]
		spc.a = 0x34  spc.y = 0x12  spc.ram[0x20] = 0xCD  spc.ram[0x21] = 0xAB
		t_run[ 0x7A, 0x20, 0x00 ]          # ADDW YA,$20 : 0x1234+0xABCD=0xBE01
		t_chk[ 'ADDW.lo', spc.a, 0x01 ]
		t_chk[ 'ADDW.hi', spc.y, 0xBE ]

		# branches: BNE taken when Z clear, not taken when Z set
		spc.psw = 0x00
		t_run[ 0xD0, 0x10, 0x00 ]          # BNE +0x10 from $0302 -> $0312
		t_chk[ 'BNE.taken', spc.pc, 0x0312 ]
		spc.psw = 0x02
		t_run[ 0xD0, 0x10, 0x00 ]          # Z set -> fall through to $0302
		t_chk[ 'BNE.fall', spc.pc, 0x0302 ]
		# BCS taken when C set
		spc.psw = 0x01
		t_run[ 0xB0, 0x20, 0x00 ]          # BCS +0x20 -> $0322
		t_chk[ 'BCS.taken', spc.pc, 0x0322 ]

		if [ dbg_h == 0 ]
			puts[ 'SPC700 self-test: ALL PASS' ]
		el
			printf[ "SPC700 self-test: %d FAILURES\n", dbg_h ]

	func init []
		width      = 512
		height     = 448
		background = 'Background'
		if [ volume == 0.0 ] volume = 0.22         # default playback volume (keep prop-pair override)

	# display-pipeline test: fill a 256x224 CPU array with an animated pattern,
	# upload it to a Texture, and blit it to the screen scaled to the window.
	# keyboard -> SNES controller 1. WASD = D-pad, ;'./ = X Y A B, Enter/Shift =
	# Start/Select, Q/E = L/R. Pad bit layout: B Y Sel St Up Dn L R A X L R (bit15..4).
	public func on_key [ ev: Event ]
		code : i32  [ ev.key.unicode ]
		down : bool [ ev.key.state ]
		bit  : i32  [ -1 ]
		if   [ code == 87 ]  bit = 11                   # W  Up
		el [ code == 83 ]  bit = 10                   # S  Down
		el [ code == 65 ]  bit = 9                    # A  Left
		el [ code == 68 ]  bit = 8                    # D  Right
		el [ code == 47 ]  bit = 15                   # /  B
		el [ code == 39 ]  bit = 14                   # '  Y
		el [ code == 46 ]  bit = 7                    # .  A
		el [ code == 59 ]  bit = 6                    # ;  X
		el [ code == 257 ] bit = 12                   # Enter  Start
		el [ code == 340 || code == 344 ] bit = 13    # Shift  Select
		el [ code == 81 ]  bit = 5                    # Q  L
		el [ code == 69 ]  bit = 4                    # E  R
		if [ bit >= 0 ]
			m : u16 [ u16[1 << bit] ]
			if [ down ] pad1 = pad1 | m
			el pad1 = pad1 & (~m)
		# volume: '-' quieter, '=' / '+' louder (0.02 steps, clamped 0..1)
		if [ down ]
			if   [ code == 45 ] volume = clamp[ volume - 0.02, 0.0, 1.0 ]
			el [ code == 61 || code == 43 ] volume = clamp[ volume + 0.02, 0.0, 1.0 ]
			if [ code == 45 || code == 61 || code == 43 ] puts 'asnes volume {volume}'
			if [ code == 80 ] save_req = true              # 'P' -> save savestate
			if [ code == 76 ] load_req = true              # 'L' -> load savestate

	public func on_canvas [ cv: Canvas ]
		if [ putest ]
			if [ !screen_tex ]
				screen_tex = Texture [ vk: cv.vk, w: cv.w, width: 256, height: 224, linear: true ]
			for [ y: i32 0, y < 224, y += 1 ]
				for [ x: i32 0, x < 256, x += 1 ]
					rr : u32 [ u32[x] & 0xFF ]
					gg : u32 [ u32[y] & 0xFF ]
					bb : u32 [ u32[(x + y + test_t) & 0xFF] ]
					test_buf[ y * 256 + x ] = 0xFF000000 | (bb << 16) | (gg << 8) | rr
			test_t += 1
			screen_tex.upload[ test_buf, 256 * 224 * 4 ]
			dst : rect [ x: 0.0, y: 0.0, w: 512.0, h: 448.0 ]
			cv.draw_image[ screen_tex, dst ]
			return
		if [ !cpu ]
			super.on_canvas[ cv ]
			return
		ppu_render[]
		if [ !screen_tex ]
			screen_tex = Texture [ vk: cv.vk, w: cv.w, width: 256, height: 224, linear: true ]
		screen_tex.upload[ ppu.framebuf, 256 * 224 * 4 ]
		out : rect [ x: 0.0, y: 0.0, w: 512.0, h: 448.0 ]
		cv.draw_image[ screen_tex, out ]

	# write a full PPU/CPU snapshot (WRAM+VRAM+CGRAM+OAM+regs+per-line arrays) to a file.
	# shared by the ASNES_DUMP_FILE env path and the 'P' snapshot key (snap_req).
	# complete PPU register + OAM state, as labeled text for cross-emulator diffing
	func dump_pstate [ fn: symbol ]
		f : ref FILE [ fopen[ fn, 'wb' ] ]
		if [ !f ] return
		fprintf[ f, "INIDISP %02X\n", u32[ppu.inidisp] ]
		fprintf[ f, "OBSEL %02X\n", u32[ppu.obsel] ]
		fprintf[ f, "BGMODE %02X\n", u32[ppu.bgmode] ]
		fprintf[ f, "MOSAIC %02X\n", u32[ppu.mosaic] ]
		for [ k: i32 0, k < 4, k += 1 ]
			fprintf[ f, "BG%dSC %02X\n", k + 1, u32[ppu.bg_sc[k]] ]
		fprintf[ f, "BG12NBA %02X\n", u32[ppu.bg_nba[0]] ]
		fprintf[ f, "BG34NBA %02X\n", u32[ppu.bg_nba[1]] ]
		for [ k: i32 0, k < 4, k += 1 ]
			fprintf[ f, "BG%dHOFS %04X\n", k + 1, u32[ppu.bg_hofs[k]] ]
			fprintf[ f, "BG%dVOFS %04X\n", k + 1, u32[ppu.bg_vofs[k]] ]
		fprintf[ f, "TM %02X\n", u32[ppu.tm] ]
		fprintf[ f, "TS %02X\n", u32[ppu.ts] ]
		fprintf[ f, "TMW %02X\n", u32[ppu.tmw] ]
		fprintf[ f, "TSW %02X\n", u32[ppu.tsw] ]
		fprintf[ f, "W12SEL %02X\n", u32[ppu.w12sel] ]
		fprintf[ f, "W34SEL %02X\n", u32[ppu.w34sel] ]
		fprintf[ f, "WOBJSEL %02X\n", u32[ppu.wobjsel] ]
		fprintf[ f, "WBGLOG %02X\n", u32[ppu.wbglog] ]
		fprintf[ f, "WOBJLOG %02X\n", u32[ppu.wobjlog] ]
		fprintf[ f, "WH0 %02X\n", u32[ppu.wh0] ]
		fprintf[ f, "WH1 %02X\n", u32[ppu.wh1] ]
		fprintf[ f, "WH2 %02X\n", u32[ppu.wh2] ]
		fprintf[ f, "WH3 %02X\n", u32[ppu.wh3] ]
		fprintf[ f, "CGWSEL %02X\n", u32[ppu.cgwsel] ]
		fprintf[ f, "CGADSUB %02X\n", u32[ppu.cgadsub] ]
		fprintf[ f, "COLDATA %04X\n", u32[ppu.coldata] ]
		fprintf[ f, "SETINI %02X\n", u32[ppu.setini] ]
		fprintf[ f, "M7SEL %02X\n", u32[ppu.m7sel] ]
		fprintf[ f, "M7A %04X\n", u32[u16[ppu.m7a]] ]
		fprintf[ f, "M7B %04X\n", u32[u16[ppu.m7b]] ]
		fprintf[ f, "M7C %04X\n", u32[u16[ppu.m7c]] ]
		fprintf[ f, "M7D %04X\n", u32[u16[ppu.m7d]] ]
		fprintf[ f, "M7X %04X\n", u32[u16[ppu.m7x]] ]
		fprintf[ f, "M7Y %04X\n", u32[u16[ppu.m7y]] ]
		for [ k: i32 0, k < 0x220, k += 1 ]
			fprintf[ f, "OAM%03X %02X\n", k, u32[ppu.oam[k]] ]
		fclose[ f ]

	func write_snapshot [ fn: symbol ]
		wf : ref FILE [ fopen[ fn, 'wb' ] ]
		if [ !wf ] return
		fwrite[ cpu.memory + 0x7E0000, 1, 0x20000, wf ]
		fwrite[ ppu.vram,  1, 0x10000, wf ]
		fwrite[ ppu.cgram, 1, 0x200,   wf ]
		fwrite[ ppu.oam,   1, 0x220,   wf ]
		rg : new u8 [ 64 ]
		rg[0]  = ppu.inidisp
		rg[1]  = ppu.bgmode
		rg[2]  = ppu.mosaic
		rg[3]  = ppu.obsel
		rg[4]  = ppu.tm
		rg[5]  = ppu.ts
		rg[6]  = ppu.vmain
		rg[7]  = ppu.bg_sc[0]
		rg[8]  = ppu.bg_sc[1]
		rg[9]  = ppu.bg_sc[2]
		rg[10] = ppu.bg_sc[3]
		rg[11] = ppu.bg_nba[0]
		rg[12] = ppu.bg_nba[1]
		for [ k: i32 0, k < 4, k += 1 ]
			rg[13 + k * 2] = u8[ ppu.bg_hofs[k] & 0xFF ]
			rg[14 + k * 2] = u8[ ppu.bg_hofs[k] >> 8 ]
			rg[21 + k * 2] = u8[ ppu.bg_vofs[k] & 0xFF ]
			rg[22 + k * 2] = u8[ ppu.bg_vofs[k] >> 8 ]
		rg[29] = cpu.memory[0x420C]
		for [ ch: i32 0, ch < 8, ch += 1 ]
			rg[30 + ch] = cpu.memory[0x4300 + (ch << 4)]
			rg[38 + ch] = cpu.memory[0x4301 + (ch << 4)]
		rg[46] = ppu.m7sel
		rg[47] = u8[ u16[ppu.m7x] & 0xFF ]
		rg[48] = u8[ (u16[ppu.m7x] >> 8) & 0xFF ]
		rg[49] = u8[ u16[ppu.m7y] & 0xFF ]
		rg[50] = u8[ (u16[ppu.m7y] >> 8) & 0xFF ]
		rg[51] = u8[ u16[ppu.m7hofs] & 0xFF ]
		rg[52] = u8[ (u16[ppu.m7hofs] >> 8) & 0xFF ]
		rg[53] = u8[ u16[ppu.m7vofs] & 0xFF ]
		rg[54] = u8[ (u16[ppu.m7vofs] >> 8) & 0xFF ]
		rg[55] = ppu.cgwsel
		rg[56] = ppu.tmw
		rg[57] = ppu.tsw
		rg[58] = ppu.w12sel
		rg[59] = ppu.wh0
		rg[60] = ppu.wh1
		fwrite[ rg, 1, 64, wf ]
		fwrite[ line_mode, 1, 224, wf ]
		fwrite[ line_m7a, 2, 224, wf ]
		fwrite[ line_m7b, 2, 224, wf ]
		fwrite[ line_m7c, 2, 224, wf ]
		fwrite[ line_m7d, 2, 224, wf ]
		fwrite[ line_coldata, 2, 224, wf ]
		fwrite[ line_cgadsub, 1, 224, wf ]
		fwrite[ line_cgwsel, 1, 224, wf ]
		fwrite[ line_wobjsel, 1, 224, wf ]
		fwrite[ line_wobjlog, 1, 224, wf ]
		fwrite[ line_wh0, 1, 224, wf ]
		fwrite[ line_wh1, 1, 224, wf ]
		fwrite[ line_wh2, 1, 224, wf ]
		fwrite[ line_wh3, 1, 224, wf ]
		ppu_render[]                                   # ensure framebuf reflects current state
		fwrite[ ppu.framebuf, 4, 256 * 224, wf ]       # actual rendered output (ground truth)
		fclose[ wf ]
		puts 'asnes snapshot written'

	# Save the current rendered frame as a PNG (the app's own output). Uses the img
	# module's Image (RGBA8) + libpng. ppu.framebuf is RGBA8, 256x224.
	func ppu_screenshot [ fn: symbol ]
		ppu_render[]
		shot : Image [ width: 256, height: 224, format: Pixel.rgba8 ]
		memcpy[ shot.vdata[], ppu.framebuf, 256 * 224 * 4 ]
		shot.png[ path fn ]
		bd : u16 [ u16[ppu.cgram[0]] | (u16[ppu.cgram[1]] << 8) ]
		printf[ "asnes bgmode=%02X tm=%02X ts=%02X backdrop=%04X obsel=%02X\n", u32[ppu.bgmode], u32[ppu.tm], u32[ppu.ts], u32[bd], u32[ppu.obsel] ]
		printf[ "  cpu_cycles=%ld dbg_frames=%u | steal(DMA+HDMA+refresh) master=%ld (%ld cpu-cyc, %ld frames-worth)\n", cpu_cycles, dbg_frames, dbg_dma_total, dbg_dma_total / 6, dbg_dma_total / 358002 ]
		printf[ "  cmath y100: cgadsub=%02X cgwsel=%02X ts=%02X coldata=%04X | y150: cgadsub=%02X cgwsel=%02X ts=%02X\n", u32[line_cgadsub[100]], u32[line_cgwsel[100]], u32[line_ts[100]], u32[line_coldata[100]], u32[line_cgadsub[150]], u32[line_cgwsel[150]], u32[line_ts[150]] ]
		for [ yy: i32 0, yy < 224, yy += 32 ]
			printf[ "  win y%d: wobjsel=%02X wobjlog=%02X wh0=%d wh1=%d wh2=%d wh3=%d fen=%d\n", yy, u32[line_wobjsel[yy]], u32[line_wobjlog[yy]], i32[line_wh0[yy]], i32[line_wh1[yy]], i32[line_wh2[yy]], i32[line_wh3[yy]], i32[bool[fog_enabled[128,yy]]] ]
		nopen : i32 [ 0 ]
		for [ yy: i32 0, yy < 224, yy += 1 ]
			if [ line_wh0[yy] < line_wh1[yy] ] nopen += 1
		printf[ "  rendered scanlines with an OPEN window (wh0<wh1): %d / 224\n", nopen ]
		for [ g: i32 0, g < 4, g += 1 ]
			sc : u8  [ ppu.bg_sc[g] ]
			nb : u8  [ ppu.bg_nba[g >> 1] ]
			nib: u32 [ u32[nb] & 0x0F ]
			if [ g & 1 ] nib = (u32[nb] >> 4) & 0x0F
			printf[ "  BG%d scr=%04X char=%04X hofs=%d vofs=%d on=%d\n", g + 1, ((u32[sc] >> 2) & 0x3F) * 0x400, nib * 0x1000, i32[ppu.bg_hofs[g]], i32[ppu.bg_vofs[g]], (ppu.tm >> g) & 1 ]
		puts 'asnes screenshot {fn}'

	# render ONE background layer (both priorities) over the backdrop, save as PNG.
	func ppu_shot_bg [ fn: symbol, bg: i32, bpp: i32 ]
		bg0 : u16 [ ppu_cgram_color[ 0 ] ]
		px  : u32 [ ppu_color[ bg0, 15 ] ]
		for [ i: i32 0, i < 256 * 224, i += 1 ]
			ppu.framebuf[i] = px
		for [ y: i32 0, y < 224, y += 1 ]
			ppu_bg_line[ bg, bpp, y, 15, 0 ]
			ppu_bg_line[ bg, bpp, y, 15, 1 ]
		shot : Image [ width: 256, height: 224, format: Pixel.rgba8 ]
		memcpy[ shot.vdata[], ppu.framebuf, 256 * 224 * 4 ]
		shot.png[ path fn ]
		puts 'asnes bg{bg} -> {fn}'

	# render the 4bpp char data at a word base as a 32x28 tile atlas (896 tiles),
	# grayscale by pixel index, so missing/garbled tiles are visible.
	func ppu_atlas [ fn: symbol, cbase: u32 ]
		for [ i: i32 0, i < 256 * 224, i += 1 ]
			ppu.framebuf[i] = 0xFF000000
		for [ t: i32 0, t < 896, t += 1 ]
			tx : i32 [ (t % 32) * 8 ]
			ty : i32 [ (t / 32) * 8 ]
			tb : u32 [ cbase + u32[t] * 16 ]
			for [ row: i32 0, row < 8, row += 1 ]
				w01 : u32 [ ppu_vw[ tb + u32[row] ] ]
				w23 : u32 [ ppu_vw[ tb + 8 + u32[row] ] ]
				for [ col: i32 0, col < 8, col += 1 ]
					bit : u32 [ u32[7 - col] ]
					idx : u32 [ ((w01 >> bit) & 1) | (((w01 >> (bit + 8)) & 1) << 1) | (((w23 >> bit) & 1) << 2) | (((w23 >> (bit + 8)) & 1) << 3) ]
					g   : u32 [ idx * 17 ]
					ppu.framebuf[ (ty + row) * 256 + (tx + col) ] = 0xFF000000 | (g << 16) | (g << 8) | g
		shot : Image [ width: 256, height: 224, format: Pixel.rgba8 ]
		memcpy[ shot.vdata[], ppu.framebuf, 256 * 224 * 4 ]
		shot.png[ path fn ]
		puts 'asnes atlas {cbase} -> {fn}'

	# --- savestate: full resumable machine state (P=save, L=load, --state=boot-load) ---
	# Order MUST match between save_state and load_state. Float audio tails (echo/fir/lp)
	# are intentionally skipped; they self-heal within a few samples on resume.
	func save_state [ fn: symbol ]
		if [ !cpu || !spc ] return
		wf : ref FILE [ fopen[ fn, 'wb' ] ]
		if [ !wf ] return
		fwrite[ cpu.memory, 1, 0x1000000, wf ]
		fwrite[ ppu.vram,  1, 0x10000, wf ]
		fwrite[ ppu.cgram, 1, 0x200,   wf ]
		fwrite[ ppu.oam,   1, 0x220,   wf ]
		fwrite[ spc.ram,   1, 0x10000, wf ]
		fwrite[ spc.dsp,   1, 128,     wf ]
		b : new u8 [ 4096 ]
		o : i32 [ 0 ]
		o = st_w16[ b, o, cpu.pc ]
		o = st_w8[ b, o, cpu.a ]
		o = st_w8[ b, o, cpu.x ]
		o = st_w8[ b, o, cpu.y ]
		o = st_w16[ b, o, cpu.sp ]
		o = st_w8[ b, o, cpu.p ]
		o = st_w16[ b, o, cpu.dp ]
		o = st_w8[ b, o, cpu.dbr ]
		o = st_w8[ b, o, cpu.pbr ]
		o = st_w8[ b, o, (cpu.e) ? u8[1] : u8[0] ]
		o = st_w8[ b, o, cpu.b ]
		o = st_w8[ b, o, cpu.xh ]
		o = st_w8[ b, o, cpu.yh ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, cpu.ports[k] ]
		o = st_w8[ b, o, ppu.inidisp ]
		o = st_w8[ b, o, ppu.obsel ]
		o = st_w8[ b, o, ppu.bgmode ]
		o = st_w8[ b, o, ppu.mosaic ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, ppu.bg_sc[k] ]
		o = st_w8[ b, o, ppu.bg_nba[0] ]
		o = st_w8[ b, o, ppu.bg_nba[1] ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w16[ b, o, ppu.bg_hofs[k] ]
			o = st_w16[ b, o, ppu.bg_vofs[k] ]
		o = st_w8[ b, o, ppu.ofs_latch ]
		for [ k: i32 0, k < 8, k += 1 ]
			o = st_w8[ b, o, ppu.ofs_hl[k] ]
		o = st_w8[ b, o, ppu.vmain ]
		o = st_w16[ b, o, ppu.vram_addr ]
		o = st_w16[ b, o, ppu.vram_pre ]
		o = st_w8[ b, o, ppu.cgadd ]
		o = st_w8[ b, o, ppu.cg_latch ]
		o = st_w8[ b, o, (ppu.cg_toggle) ? u8[1] : u8[0] ]
		o = st_w16[ b, o, ppu.oamadd ]
		o = st_w16[ b, o, ppu.oamadd_reload ]
		o = st_w8[ b, o, ppu.oam_latch ]
		o = st_w8[ b, o, (ppu.oam_toggle) ? u8[1] : u8[0] ]
		o = st_w8[ b, o, ppu.tm ]
		o = st_w8[ b, o, ppu.ts ]
		o = st_w8[ b, o, ppu.w12sel ]
		o = st_w8[ b, o, ppu.w34sel ]
		o = st_w8[ b, o, ppu.wobjsel ]
		o = st_w8[ b, o, ppu.wh0 ]
		o = st_w8[ b, o, ppu.wh1 ]
		o = st_w8[ b, o, ppu.wh2 ]
		o = st_w8[ b, o, ppu.wh3 ]
		o = st_w8[ b, o, ppu.wbglog ]
		o = st_w8[ b, o, ppu.wobjlog ]
		o = st_w8[ b, o, ppu.tmw ]
		o = st_w8[ b, o, ppu.tsw ]
		o = st_w8[ b, o, ppu.cgwsel ]
		o = st_w8[ b, o, ppu.cgadsub ]
		o = st_w16[ b, o, ppu.coldata ]
		o = st_w8[ b, o, ppu.setini ]
		o = st_w16[ b, o, u16[ppu.m7a] ]
		o = st_w16[ b, o, u16[ppu.m7b] ]
		o = st_w16[ b, o, u16[ppu.m7c] ]
		o = st_w16[ b, o, u16[ppu.m7d] ]
		o = st_w16[ b, o, u16[ppu.m7x] ]
		o = st_w16[ b, o, u16[ppu.m7y] ]
		o = st_w16[ b, o, u16[ppu.m7hofs] ]
		o = st_w16[ b, o, u16[ppu.m7vofs] ]
		o = st_w8[ b, o, ppu.m7sel ]
		o = st_w8[ b, o, ppu.m7_latch ]
		o = st_w16[ b, o, spc.pc ]
		o = st_w8[ b, o, spc.a ]
		o = st_w8[ b, o, spc.x ]
		o = st_w8[ b, o, spc.y ]
		o = st_w8[ b, o, spc.sp ]
		o = st_w8[ b, o, spc.psw ]
		o = st_w8[ b, o, spc.direct_page ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, spc.ports[k] ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, spc.in_stage[k] ]
		for [ k: i32 0, k < 4, k += 1 ]
			o = st_w8[ b, o, spc.oports[k] ]
		o = st_w16[ b, o, spc.echo_pos ]
		o = st_w32[ b, o, u32[spc.fir_idx] ]
		o = st_w8[ b, o, spc.timer_on ]
		for [ k: i32 0, k < 3, k += 1 ]
			o = st_w8[ b, o, spc.timer_target[k] ]
		for [ k: i32 0, k < 3, k += 1 ]
			o = st_w8[ b, o, spc.timer_count[k] ]
		for [ k: i32 0, k < 3, k += 1 ]
			o = st_w32[ b, o, u32[spc.timer_stage[k]] ]
		o = st_w32[ b, o, u32[spc.tcyc] ]
		o = st_w8[ b, o, spc.kon_latch ]
		o = st_w8[ b, o, spc.koff_latch ]
		o = st_w32[ b, o, u32[spc.cycle_accum] ]
		for [ c: i32 0, c < 8, c += 1 ]
			o = st_w16[ b, o, spc.channels[c].pos ]
			o = st_w16[ b, o, spc.channels[c].frac ]
			for [ s: i32 0, s < 4, s += 1 ]
				o = st_w16[ b, o, u16[spc.channels[c].samples[s]] ]
			o = st_w16[ b, o, u16[spc.channels[c].envelope] ]
			o = st_w8[ b, o, spc.channels[c].env_state ]
			o = st_w32[ b, o, u32[spc.channels[c].env_count] ]
			o = st_w8[ b, o, spc.channels[c].active ]
		o = st_w8[ b, o, nmitimen ]
		o = st_w8[ b, o, (nmi_occurred) ? u8[1] : u8[0] ]
		o = st_w32[ b, o, wram_addr ]
		o = st_w8[ b, o, mpya ]
		o = st_w8[ b, o, mpyb ]
		o = st_w16[ b, o, wrdiv ]
		o = st_w16[ b, o, rddiv ]
		o = st_w16[ b, o, rdmpy ]
		o = st_w16[ b, o, pad1 ]
		o = st_w8[ b, o, joy_strobe ]
		o = st_w32[ b, o, u32[joy_index] ]
		o = st_w16[ b, o, htime ]
		o = st_w16[ b, o, vtime ]
		o = st_w8[ b, o, (irq_occurred) ? u8[1] : u8[0] ]
		o = st_w32[ b, o, u32[frame_cycle] ]
		o = st_w8[ b, o, (in_vblank) ? u8[1] : u8[0] ]
		o = st_w8[ b, o, (cpu_wai) ? u8[1] : u8[0] ]
		o = st_w32[ b, o, dbg_frames ]
		o = st_w8[ b, o, (spc_rom_loaded) ? u8[1] : u8[0] ]
		for [ k: i32 0, k < 8, k += 1 ]
			o = st_w16[ b, o, hdma_addr[k] ]
			o = st_w8[ b, o, hdma_line[k] ]
			o = st_w16[ b, o, hdma_ind[k] ]
			o = st_w8[ b, o, hdma_do[k] ]
			o = st_w8[ b, o, hdma_done[k] ]
		fwrite[ b, 1, 4096, wf ]
		fclose[ wf ]
		puts 'asnes state saved'

	func load_state [ fn: symbol ]
		if [ !cpu || !spc ] return
		rf : ref FILE [ fopen[ fn, 'rb' ] ]
		if [ !rf ] return
		fread[ cpu.memory, 1, 0x1000000, rf ]
		fread[ ppu.vram,  1, 0x10000, rf ]
		fread[ ppu.cgram, 1, 0x200,   rf ]
		fread[ ppu.oam,   1, 0x220,   rf ]
		fread[ spc.ram,   1, 0x10000, rf ]
		fread[ spc.dsp,   1, 128,     rf ]
		b : new u8 [ 4096 ]
		fread[ b, 1, 4096, rf ]
		fclose[ rf ]
		o : i32 [ 0 ]
		cpu.pc = st_r16[ b, o ]
		o += 2
		cpu.a = b[o]
		o += 1
		cpu.x = b[o]
		o += 1
		cpu.y = b[o]
		o += 1
		cpu.sp = st_r16[ b, o ]
		o += 2
		cpu.p = b[o]
		o += 1
		cpu.dp = st_r16[ b, o ]
		o += 2
		cpu.dbr = b[o]
		o += 1
		cpu.pbr = b[o]
		o += 1
		cpu.e = b[o] != 0
		o += 1
		cpu.b = b[o]
		o += 1
		cpu.xh = b[o]
		o += 1
		cpu.yh = b[o]
		o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			cpu.ports[k] = b[o]
			o += 1
		ppu.inidisp = b[o]
		o += 1
		ppu.obsel = b[o]
		o += 1
		ppu.bgmode = b[o]
		o += 1
		ppu.mosaic = b[o]
		o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			ppu.bg_sc[k] = b[o]
			o += 1
		ppu.bg_nba[0] = b[o]
		o += 1
		ppu.bg_nba[1] = b[o]
		o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			ppu.bg_hofs[k] = st_r16[ b, o ]
			o += 2
			ppu.bg_vofs[k] = st_r16[ b, o ]
			o += 2
		ppu.ofs_latch = b[o]
		o += 1
		for [ k: i32 0, k < 8, k += 1 ]
			ppu.ofs_hl[k] = b[o]
			o += 1
		ppu.vmain = b[o]
		o += 1
		ppu.vram_addr = st_r16[ b, o ]
		o += 2
		ppu.vram_pre = st_r16[ b, o ]
		o += 2
		ppu.cgadd = b[o]
		o += 1
		ppu.cg_latch = b[o]
		o += 1
		ppu.cg_toggle = b[o] != 0
		o += 1
		ppu.oamadd = st_r16[ b, o ]
		o += 2
		ppu.oamadd_reload = st_r16[ b, o ]
		o += 2
		ppu.oam_latch = b[o]
		o += 1
		ppu.oam_toggle = b[o] != 0
		o += 1
		ppu.tm = b[o]
		o += 1
		ppu.ts = b[o]
		o += 1
		ppu.w12sel = b[o]
		o += 1
		ppu.w34sel = b[o]
		o += 1
		ppu.wobjsel = b[o]
		o += 1
		ppu.wh0 = b[o]
		o += 1
		ppu.wh1 = b[o]
		o += 1
		ppu.wh2 = b[o]
		o += 1
		ppu.wh3 = b[o]
		o += 1
		ppu.wbglog = b[o]
		o += 1
		ppu.wobjlog = b[o]
		o += 1
		ppu.tmw = b[o]
		o += 1
		ppu.tsw = b[o]
		o += 1
		ppu.cgwsel = b[o]
		o += 1
		ppu.cgadsub = b[o]
		o += 1
		ppu.coldata = st_r16[ b, o ]
		o += 2
		ppu.setini = b[o]
		o += 1
		ppu.m7a = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7b = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7c = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7d = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7x = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7y = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7hofs = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7vofs = i16[st_r16[ b, o ]]
		o += 2
		ppu.m7sel = b[o]
		o += 1
		ppu.m7_latch = b[o]
		o += 1
		spc.pc = st_r16[ b, o ]
		o += 2
		spc.a = b[o]
		o += 1
		spc.x = b[o]
		o += 1
		spc.y = b[o]
		o += 1
		spc.sp = b[o]
		o += 1
		spc.psw = b[o]
		o += 1
		spc.direct_page = b[o]
		o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			spc.ports[k] = b[o]
			o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			spc.in_stage[k] = b[o]
			o += 1
		for [ k: i32 0, k < 4, k += 1 ]
			spc.oports[k] = b[o]
			o += 1
		spc.echo_pos = st_r16[ b, o ]
		o += 2
		spc.fir_idx = i32[st_r32[ b, o ]]
		o += 4
		spc.timer_on = b[o]
		o += 1
		for [ k: i32 0, k < 3, k += 1 ]
			spc.timer_target[k] = b[o]
			o += 1
		for [ k: i32 0, k < 3, k += 1 ]
			spc.timer_count[k] = b[o]
			o += 1
		for [ k: i32 0, k < 3, k += 1 ]
			spc.timer_stage[k] = i32[st_r32[ b, o ]]
			o += 4
		spc.tcyc = i32[st_r32[ b, o ]]
		o += 4
		spc.kon_latch = b[o]
		o += 1
		spc.koff_latch = b[o]
		o += 1
		spc.cycle_accum = i32[st_r32[ b, o ]]
		o += 4
		for [ c: i32 0, c < 8, c += 1 ]
			spc.channels[c].pos = st_r16[ b, o ]
			o += 2
			spc.channels[c].frac = st_r16[ b, o ]
			o += 2
			for [ s: i32 0, s < 4, s += 1 ]
				spc.channels[c].samples[s] = i16[st_r16[ b, o ]]
				o += 2
			spc.channels[c].envelope = i16[st_r16[ b, o ]]
			o += 2
			spc.channels[c].env_state = b[o]
			o += 1
			spc.channels[c].env_count = i32[st_r32[ b, o ]]
			o += 4
			spc.channels[c].active = b[o]
			o += 1
		nmitimen = b[o]
		o += 1
		nmi_occurred = b[o] != 0
		o += 1
		wram_addr = st_r32[ b, o ]
		o += 4
		mpya = b[o]
		o += 1
		mpyb = b[o]
		o += 1
		wrdiv = st_r16[ b, o ]
		o += 2
		rddiv = st_r16[ b, o ]
		o += 2
		rdmpy = st_r16[ b, o ]
		o += 2
		pad1 = st_r16[ b, o ]
		o += 2
		joy_strobe = b[o]
		o += 1
		joy_index = i32[st_r32[ b, o ]]
		o += 4
		htime = st_r16[ b, o ]
		o += 2
		vtime = st_r16[ b, o ]
		o += 2
		irq_occurred = b[o] != 0
		o += 1
		frame_cycle = i32[st_r32[ b, o ]]
		o += 4
		in_vblank = b[o] != 0
		o += 1
		cpu_wai = b[o] != 0
		o += 1
		dbg_frames = st_r32[ b, o ]
		o += 4
		spc_rom_loaded = b[o] != 0
		o += 1
		for [ k: i32 0, k < 8, k += 1 ]
			hdma_addr[k] = st_r16[ b, o ]
			o += 2
			hdma_line[k] = b[o]
			o += 1
			hdma_ind[k] = st_r16[ b, o ]
			o += 2
			hdma_do[k] = b[o]
			o += 1
			hdma_done[k] = b[o]
			o += 1
		puts 'asnes state loaded'

	# little-endian pack/unpack helpers for savestate scalar block
	func st_w8 [ b: ref u8, o: i32, v: u8 ] -> i32
		b[o] = v
		return o + 1

	func st_w16 [ b: ref u8, o: i32, v: u16 ] -> i32
		b[o] = u8[v & 0xFF]
		b[o + 1] = u8[(v >> 8) & 0xFF]
		return o + 2

	func st_w32 [ b: ref u8, o: i32, v: u32 ] -> i32
		b[o] = u8[v & 0xFF]
		b[o + 1] = u8[(v >> 8) & 0xFF]
		b[o + 2] = u8[(v >> 16) & 0xFF]
		b[o + 3] = u8[(v >> 24) & 0xFF]
		return o + 4

	func st_r16 [ b: ref u8, o: i32 ] -> u16
		return u16[b[o]] | (u16[b[o + 1]] << 8)

	func st_r32 [ b: ref u8, o: i32 ] -> u32
		return u32[b[o]] | (u32[b[o + 1]] << 8) | (u32[b[o + 2]] << 16) | (u32[b[o + 3]] << 24)

	func on_render [ w: Window ] -> Elements
		if [ putest ]
			return null
		if [ spctest ]
			if [ !spc ] spc_test[]
			return null
		# --beep: bypass the CPU/upload entirely, key on one DSP voice directly.
		if [ beep ]
			if [ !spc ] audio_test[]
			generate_audio[ 0 ]
			return null
		# --spcfile: play a real APU snapshot. generate_audio runs 16 SPC steps
		# per output sample (~32 cycles), interleaving the engine with the DSP.
		if [ spcfile ]
			if [ !spc ] load_spc[]
			generate_audio[ 16 ]
			return null
		# --rom <path> maps onto the public `rom` member, but args are applied
		# after init[], so load lazily on the first frame once rom is set.
		if [ rom && !cpu ] load[]
		if [ !cpu ] return null
		df : symbol [ getenv[ 'ASNES_DUMP_FRAME' ] ]
		if [ df && dbg_frames == atoi[ df ] ]
			fn : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
			if [ fn ]
				ppu_screenshot[ fn ]
				ppu_shot_bg[ '/tmp/asnes_bg1.png', 0, 4 ]
				ppu_shot_bg[ '/tmp/asnes_bg3.png', 2, 2 ]
				ppu_atlas[ '/tmp/asnes_atlas0.png', 0x0000 ]
				write_snapshot[ '/tmp/asnes_blob.bin' ]
			exit[ 0 ]
		# cycle-index trigger (shared baseline): capture at first frame boundary where
		# total CPU cycles reach the target. ASNES_DUMP_CYCLE=N ASNES_DUMP_FILE=x.png
		dcy : symbol [ getenv[ 'ASNES_DUMP_CYCLE' ] ]
		if [ dcy && cpu_cycles >= i64[ atoi[ dcy ] ] ]
			printf[ "asnes capture at cpu_cycles=%ld dbg_frames=%u\n", cpu_cycles, dbg_frames ]
			fnc : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
			if [ fnc ]
				ppu_screenshot[ fnc ]
				ppu_shot_bg[ '/tmp/asnes_bg1.png', 0, 4 ]
				ppu_shot_bg[ '/tmp/asnes_bg3.png', 2, 2 ]
				ppu_atlas[ '/tmp/asnes_atlas0.png', 0x0000 ]
				write_snapshot[ '/tmp/asnes_blob.bin' ]
			exit[ 0 ]
		# --state <file>: load savestate once on the first frame after boot
		if [ state && !state_loaded ]
			state_loaded = true
			load_state[ state.chars ]
			write_snapshot[ '/tmp/asnes_snap.bin' ]      # also drop a diagnostic snapshot for analysis
		# loaded a state via --state: run one frame to populate the renderer, then capture + exit
		if [ state_loaded && state ]
			post_load += 1
			inj : symbol [ getenv[ 'ASNES_INJECT_START' ] ]
			if [ inj ]
				# run frames so the decompressor uploads the car tiles; capture at the env frame.
				# optional ASNES_PRESS_START: hold Start frames 5-16 to advance a menu first.
				if [ getenv['ASNES_PRESS_START'] && post_load >= 5 && post_load <= 16 ] pad1 = pad1 | 0x1000
				el [ getenv['ASNES_PRESS_START'] ] pad1 = pad1 & (~0x1000)
				if [ post_load == atoi[ inj ] ]
					fni : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
					if [ fni ]
						ppu_screenshot[ fni ]
						write_snapshot[ '/tmp/asnes_blob.bin' ]
					exit[ 0 ]
			el [ post_load == 2 ]
				fns : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
				if [ fns ]
					ppu_screenshot[ fns ]
					write_snapshot[ '/tmp/asnes_blob.bin' ]
				exit[ 0 ]
		# boot-mode auto-drive: press Start ("Enter") at ~2s and ~3.3s to reach car-select,
		# then capture at the env frame. ASNES_AUTO_START=<capture-frame>.
		ab : symbol [ getenv[ 'ASNES_AUTO_START' ] ]
		if [ ab && cpu ]
			if [ dbg_frames >= 120 && dbg_frames <= 131 ] pad1 = pad1 | 0x1000
			el [ dbg_frames >= 200 && dbg_frames <= 211 ] pad1 = pad1 | 0x1000
			el [ dbg_frames >= 300 && dbg_frames <= 311 ] pad1 = pad1 | 0x1000
			el [ dbg_frames >= 400 && dbg_frames <= 411 ] pad1 = pad1 | 0x1000
			el pad1 = pad1 & (~0x1000)
			if [ dbg_frames == atoi[ ab ] ]
				fna : symbol [ getenv[ 'ASNES_DUMP_FILE' ] ]
				if [ fna ]
					ppu_screenshot[ fna ]
					write_snapshot[ '/tmp/asnes_blob.bin' ]
				dump_pstate[ '/tmp/asnes_pstate.txt' ]
				exit[ 0 ]
		# 'P' = save savestate, 'L' = load savestate (also writes a diagnostic snapshot)
		if [ save_req ]
			save_req = false
			save_state[ '/tmp/asnes.state' ]
			write_snapshot[ '/tmp/asnes_snap.bin' ]
		if [ load_req ]
			load_req = false
			load_state[ '/tmp/asnes.state' ]
		# silent boot uses continuous SPC (load the song); playback uses the atomic
		# co-scheduler (clean ding + music, no port race). switch after the upload.
		if [ dbg_frames < 28 ]
			run_rom_frame_boot[]
		el
			run_rom_frame[]
		dbg_frames += 1
		if [ spc.pc < 0x8000 && dbg_h < 1 ]
			printf[ "ENGINE@%04X wait0873: %02X %02X %02X %02X %02X %02X  dspENvol7D=%02X ECEN4D=%02X\n",
				spc.pc, spc.ram[0x0873], spc.ram[0x0874], spc.ram[0x0875],
				spc.ram[0x0876], spc.ram[0x0877], spc.ram[0x0878], spc.dsp[0x7D], spc.dsp[0x4D] ]
			dbg_h += 1
		if [ (dbg_frames % 30) == 0 ]
			nzdsp : i32 [ 0 ]
			for [ r: i32 0, r < 128, r += 1 ]
				if [ spc.dsp[r] != 0 ] nzdsp += 1
			printf[ "frame %u cpu=%02X:%04X dbr=%02X spc=%04X nmien=%02X nmifires=%d kon=%d koff=%d c2a=%02X %02X %02X %02X a2c=%02X %02X %02X %02X\n",
				dbg_frames, cpu.pbr, cpu.pc, cpu.dbr, spc.pc, nmitimen, dbg_spc, dbg_kon, dbg_cpu,
				spc.ports[0], spc.ports[1], spc.ports[2], spc.ports[3],
				spc.oports[0], spc.oports[1], spc.oports[2], spc.oports[3] ]
		return null

	func dealloc []
		# cpu/spc are Au class objects (cpu_state[] / spc_state[]) — released by the
		# framework's drop_members, NOT free() (free() on an Au object = invalid pointer).
		# Only the raw calloc'd buffers below are freed manually.
		if [ cpu ]
			free[ cpu.memory ]
		if [ spc ]
			if [ spc.audio_buffer ] free[ spc.audio_buffer ]
		if [ spc_boot_rom ] free[ spc_boot_rom ]

	# --- SPC700 step ---

	# advance the three SPC700 timers by `cyc` SPC cycles. timer0/1 prescale at
	# 128 cycles (8kHz), timer2 at 16 cycles (64kHz); each output is a 4-bit
	# counter the engine polls at $FD-$FF to sequence music.
	func spc_tick_timers [ cyc: i32 ]
		spc.tcyc += cyc
		while [ spc.tcyc >= 128 ]
			spc.tcyc -= 128
			if [ spc.timer_on & 0x01 ]
				spc.timer_stage[0] += 1
				t0 : i32 [ (spc.timer_target[0] == 0) ? 256 : spc.timer_target[0] ]
				if [ spc.timer_stage[0] >= t0 ]
					spc.timer_stage[0] = 0
					spc.timer_count[0] = (spc.timer_count[0] + 1) & 0x0F
			if [ spc.timer_on & 0x02 ]
				spc.timer_stage[1] += 1
				t1 : i32 [ (spc.timer_target[1] == 0) ? 256 : spc.timer_target[1] ]
				if [ spc.timer_stage[1] >= t1 ]
					spc.timer_stage[1] = 0
					spc.timer_count[1] = (spc.timer_count[1] + 1) & 0x0F
			if [ spc.timer_on & 0x04 ]
				spc.timer_stage[2] += 8
				t2 : i32 [ (spc.timer_target[2] == 0) ? 256 : spc.timer_target[2] ]
				while [ spc.timer_stage[2] >= t2 ]
					spc.timer_stage[2] -= t2
					spc.timer_count[2] = (spc.timer_count[2] + 1) & 0x0F

	# taken conditional branch: apply the relative offset and add the +2 cycle penalty
	func spc_take [ off: i32 ]
		spc.pc = u16[ i32[spc.pc] + off ]
		spc.op_cyc += 2

	func spc_step [] -> i32
		opcode : u8 [ spc_rb[] ]
		spc.op_cyc = i32[ spc_cyc[ opcode ] ]      # base SMP cycles; branch handlers add +2 when taken
		spc_tick_timers[ spc.op_cyc ]
		switch [ opcode ]
			case 0x8F  # MOV dp, #imm  (encoding: 8F imm dp — immediate byte first)
				imm : u8 [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, imm ]

			case 0xCD  # MOV X, #imm
				spc.x   = spc_rb[]
				spc_nz[ spc.x ]

			case 0xBD  # MOV SP, X
				spc.sp = spc.x

			case 0x9D  # MOV X, SP
				spc.x   = spc.sp
				spc_nz[ spc.x ]

			case 0x7D  # MOV A, X
				spc.a   = spc.x
				spc_nz[ spc.a ]

			case 0x5D  # MOV X, A
				spc.x   = spc.a
				spc_nz[ spc.x ]

			case 0xDD  # MOV A, Y
				spc.a   = spc.y
				spc_nz[ spc.a ]

			case 0xFD  # MOV Y, A
				spc.y   = spc.a
				spc_nz[ spc.y ]

			case 0xE4  # MOV A, dp
				dp : u16 [ spc_dp[] ]
				spc.a   = spc_r[dp]
				spc_nz[ spc.a ]

			case 0xF4  # MOV A, dp+X
				dp : u16 [ spc_dp[] ]
				spc.a   = spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				spc_nz[ spc.a ]

			case 0xE5  # MOV A, abs
				addr    : u16 [ spc_rw[] ]
				spc.a   = spc_r[addr]
				spc_nz[ spc.a ]

			case 0xF5  # MOV A, abs+X
				addr    : u16 [ spc_rw[] ]
				spc.a   = spc_r[ (addr + spc.x) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0xF6  # MOV A, abs+Y
				addr    : u16 [ spc_rw[] ]
				spc.a   = spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0xE6  # MOV A, (X)
				spc.a   = spc_r[spc.x]
				spc_nz[ spc.a ]

			case 0xBF  # MOV A, (X)+
				spc.a   = spc_r[spc.x]
				spc.x  += 1
				spc_nz[ spc.a ]

			case 0xE7  # MOV A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr     : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr    : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				spc.a   = spc_r[addr]
				spc_nz[ spc.a ]

			case 0xF7  # MOV A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr    : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				spc.a   = spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0xE8  # MOV A, #imm
				spc.a   = spc_rb[]
				spc_nz[ spc.a ]

			case 0xF8  # MOV X, dp
				dp : u16 [ spc_dp[] ]
				spc.x   = spc_r[dp]
				spc_nz[ spc.x ]

			case 0xF9  # MOV X, dp+Y
				dp : u16 [ spc_dp[] ]
				spc.x   = spc_r[ ((dp & 0xFF00) | ((dp + spc.y) & 0xFF)) ]
				spc_nz[ spc.x ]

			case 0xE9  # MOV X, abs
				addr    : u16 [ spc_rw[] ]
				spc.x   = spc_r[addr]
				spc_nz[ spc.x ]

			case 0x8D  # MOV Y, #imm
				spc.y   = spc_rb[]
				spc_nz[ spc.y ]

			case 0xEB  # MOV Y, dp
				dp : u16 [ spc_dp[] ]
				spc.y   = spc_r[dp]
				spc_nz[ spc.y ]

			case 0xFB  # MOV Y, dp+X
				dp : u16 [ spc_dp[] ]
				spc.y   = spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				spc_nz[ spc.y ]

			case 0xEC  # MOV Y, abs
				addr    : u16 [ spc_rw[] ]
				spc.y   = spc_r[addr]
				spc_nz[ spc.y ]

			case 0xC4  # MOV dp, A
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc.a ]

			case 0xD4  # MOV dp+X, A
				dp : u16 [ spc_dp[] ]
				spc_w[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)), spc.a ]

			case 0xC5  # MOV abs, A
				addr : u16 [ spc_rw[] ]
				spc_w[ addr, spc.a ]

			case 0xD5  # MOV abs+X, A
				addr : u16 [ spc_rw[] ]
				spc_w[ (addr + spc.x) & 0xFFFF, spc.a ]

			case 0xD6  # MOV abs+Y, A
				addr : u16 [ spc_rw[] ]
				spc_w[ (addr + spc.y) & 0xFFFF, spc.a ]

			case 0xC6  # MOV (X), A
				spc_w[ spc.x, spc.a ]

			case 0xAF  # MOV (X)+, A
				spc_w[ spc.x, spc.a ]
				spc.x += 1

			case 0xC7  # MOV [dp+X], A
				dp : u16 [ spc_dp[] ]
				ptr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				spc_w[ addr, spc.a ]

			case 0xD7  # MOV [dp]+Y, A
				dp : u16 [ spc_dp[] ]
				addr : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				spc_w[ (addr + spc.y) & 0xFFFF, spc.a ]

			case 0xC9  # MOV abs, X
				addr : u16 [ spc_rw[] ]
				spc_w[ addr, spc.x ]

			case 0xD9  # MOV dp+Y, X
				dp : u16 [ spc_dp[] ]
				spc_w[ ((dp & 0xFF00) | ((dp + spc.y) & 0xFF)), spc.x ]

			case 0xDB  # MOV dp+X, Y
				dp : u16 [ spc_dp[] ]
				spc_w[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)), spc.y ]

			case 0xCB  # MOV dp, Y
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc.y ]

			case 0xD8  # MOV dp, X
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc.x ]

			case 0xCC  # MOV abs, Y
				addr : u16 [ spc_rw[] ]
				spc_w[ addr, spc.y ]

			case 0xFA  # MOV dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				spc_w[ dst, spc_r[src] ]

			case 0x84  # ADC A, dp
				dp : u16 [ spc_dp[] ]
				value  : u8  [ spc_r[dp] ]
				result : u16 [ u16[spc.a] + u16[value] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0x94  # ADC A, dp+X
				dp : u16 [ spc_dp[] ]
				value  : u8  [ spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ] ]
				result : u16 [ u16[spc.a] + u16[value] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0x85  # ADC A, abs
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] + u16[value] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0x95  # ADC A, abs+X
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[ (addr + spc.x) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] + u16[value] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0x96  # ADC A, abs+Y
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] + u16[value] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0x86  # ADC A, (X)
				value  : u8  [ spc_r[spc.x] ]
				result : u16 [ u16[spc.a] + u16[value] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0x97  # ADC A, [dp]+Y   (indirect, post-indexed by Y)
				dp : u16 [ spc_dp[] ]
				addr   : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				value  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] + u16[value] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0x87  # ADC A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr    : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr   : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				value  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] + u16[value] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0x88  # ADC A, #imm
				value  : u8  [ spc_rb[] ]
				result : u16 [ u16[spc.a] + u16[value] + (spc.psw & 0x01) ]
				spc_adc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0x99  # ADC (X), (Y)
				x_val  : u8  [ spc_r[spc.x] ]
				y_val  : u8  [ spc_r[spc.y] ]
				result : u16 [ u16[x_val] + u16[y_val] + (spc.psw & 0x01) ]
				spc_adc[ x_val, y_val, result ]
				spc_w[ spc.x, result & 0xFF ]

			case 0x89  # ADC dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				src_val : u8  [ spc_r[src] ]
				dst_val : u8  [ spc_r[dst] ]
				result  : u16 [ u16[dst_val] + u16[src_val] + (spc.psw & 0x01) ]
				spc_adc[ dst_val, src_val, result ]
				spc_w[ dst, result & 0xFF ]

			case 0x98  # ADC dp, #imm  (imm first)
				imm     : u8  [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				dp_val  : u8  [ spc_r[dp] ]
				result  : u16 [ u16[dp_val] + u16[imm] + (spc.psw & 0x01) ]
				spc_adc[ dp_val, imm, result ]
				spc_w[ dp, result & 0xFF ]

			case 0xA4  # SBC A, dp
				dp : u16 [ spc_dp[] ]
				value  : u8  [ spc_r[dp] ]
				result : u16 [ u16[spc.a] - u16[value] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0xB4  # SBC A, dp+X
				dp : u16 [ spc_dp[] ]
				value  : u8  [ spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ] ]
				result : u16 [ u16[spc.a] - u16[value] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0xA5  # SBC A, abs
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] - u16[value] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0xB5  # SBC A, abs+X
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[ (addr + spc.x) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[value] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0xB6  # SBC A, abs+Y
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[value] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0xA6  # SBC A, (X)
				value  : u8  [ spc_r[spc.x] ]
				result : u16 [ u16[spc.a] - u16[value] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0xB7  # SBC A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr   : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				value  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[value] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0xA7  # SBC A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr    : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr   : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				value  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] - u16[value] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0xA8  # SBC A, #imm
				value  : u8  [ spc_rb[] ]
				result : u16 [ u16[spc.a] - u16[value] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ spc.a, value, result ]
				spc.a   = result & 0xFF

			case 0xB9  # SBC (X), (Y)
				x_val  : u8  [ spc_r[spc.x] ]
				y_val  : u8  [ spc_r[spc.y] ]
				result : u16 [ u16[x_val] - u16[y_val] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ x_val, y_val, result ]
				spc_w[ spc.x, result & 0xFF ]

			case 0xA9  # SBC dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				src_val : u8  [ spc_r[src] ]
				dst_val : u8  [ spc_r[dst] ]
				result  : u16 [ u16[dst_val] - u16[src_val] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ dst_val, src_val, result ]
				spc_w[ dst, result & 0xFF ]

			case 0xB8  # SBC dp, #imm  (imm first)
				imm     : u8  [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				dp_val  : u8  [ spc_r[dp] ]
				result  : u16 [ u16[dp_val] - u16[imm] - (1 - (spc.psw & 0x01)) ]
				spc_sbc[ dp_val, imm, result ]
				spc_w[ dp, result & 0xFF ]

			case 0x64  # CMP A, dp
				dp : u16 [ spc_dp[] ]
				value  : u8  [ spc_r[dp] ]
				result : u16 [ u16[spc.a] - u16[value] ]
				spc_cmp[ result ]

			case 0x74  # CMP A, dp+X
				dp : u16 [ spc_dp[] ]
				value  : u8  [ spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ] ]
				result : u16 [ u16[spc.a] - u16[value] ]
				spc_cmp[ result ]

			case 0x65  # CMP A, abs
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] - u16[value] ]
				spc_cmp[ result ]

			case 0x75  # CMP A, abs+X
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[ (addr + spc.x) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[value] ]
				spc_cmp[ result ]

			case 0x76  # CMP A, abs+Y
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[value] ]
				spc_cmp[ result ]

			case 0x66  # CMP A, (X)
				value  : u8  [ spc_r[spc.x] ]
				result : u16 [ u16[spc.a] - u16[value] ]
				spc_cmp[ result ]

			case 0x77  # CMP A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr   : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				value  : u8  [ spc_r[ (addr + spc.y) & 0xFFFF ] ]
				result : u16 [ u16[spc.a] - u16[value] ]
				spc_cmp[ result ]

			case 0x67  # CMP A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr    : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr   : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				value  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.a] - u16[value] ]
				spc_cmp[ result ]

			case 0x68  # CMP A, #imm
				value  : u8  [ spc_rb[] ]
				result : u16 [ u16[spc.a] - u16[value] ]
				spc_cmp[ result ]

			case 0x79  # CMP (X), (Y)
				x_val  : u8  [ spc_r[spc.x] ]
				y_val  : u8  [ spc_r[spc.y] ]
				result : u16 [ u16[x_val] - u16[y_val] ]
				spc_cmp[ result ]

			case 0x69  # CMP dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				src_val : u8  [ spc_r[src] ]
				dst_val : u8  [ spc_r[dst] ]
				result  : u16 [ u16[dst_val] - u16[src_val] ]
				spc_cmp[ result ]

			case 0x78  # CMP dp, #imm  (imm first)
				imm     : u8  [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				dp_val  : u8  [ spc_r[dp] ]
				result  : u16 [ u16[dp_val] - u16[imm] ]
				spc_cmp[ result ]

			case 0xC8  # CMP X, #imm
				value  : u8  [ spc_rb[] ]
				result : u16 [ u16[spc.x] - u16[value] ]
				spc_cmp[ result ]

			case 0x3E  # CMP X, dp
				dp : u16 [ spc_dp[] ]
				value  : u8  [ spc_r[dp] ]
				result : u16 [ u16[spc.x] - u16[value] ]
				spc_cmp[ result ]

			case 0x1E  # CMP X, abs
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.x] - u16[value] ]
				spc_cmp[ result ]

			case 0xAD  # CMP Y, #imm
				value  : u8  [ spc_rb[] ]
				result : u16 [ u16[spc.y] - u16[value] ]
				spc_cmp[ result ]

			case 0x7E  # CMP Y, dp
				dp : u16 [ spc_dp[] ]
				value  : u8  [ spc_r[dp] ]
				result : u16 [ u16[spc.y] - u16[value] ]
				spc_cmp[ result ]

			case 0x5E  # CMP Y, abs
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[addr] ]
				result : u16 [ u16[spc.y] - u16[value] ]
				spc_cmp[ result ]

			case 0x24  # AND A, dp
				dp : u16 [ spc_dp[] ]
				spc.a &= spc_r[dp]
				spc_nz[ spc.a ]

			case 0x34  # AND A, dp+X
				dp : u16 [ spc_dp[] ]
				spc.a &= spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				spc_nz[ spc.a ]

			case 0x25  # AND A, abs
				addr  : u16 [ spc_rw[] ]
				spc.a &= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x35  # AND A, abs+X
				addr  : u16 [ spc_rw[] ]
				spc.a &= spc_r[ (addr + spc.x) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x36  # AND A, abs+Y
				addr  : u16 [ spc_rw[] ]
				spc.a &= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x26  # AND A, (X)
				spc.a &= spc_r[spc.x]
				spc_nz[ spc.a ]

			case 0x37  # AND A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				spc.a &= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x27  # AND A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr   : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr  : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				spc.a &= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x28  # AND A, #imm
				spc.a &= spc_rb[]
				spc_nz[ spc.a ]

			case 0x39  # AND (X), (Y)
				result : u8 [ spc_r[spc.x] & spc_r[spc.y] ]
				spc_w[ spc.x, result ]
				spc_nz[ result ]

			case 0x29  # AND dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dst] & spc_r[src] ]
				spc_w[ dst, result ]
				spc_nz[ result ]

			case 0x38  # AND dp, #imm  (imm first)
				imm    : u8 [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dp] & imm ]
				spc_w[ dp, result ]
				spc_nz[ result ]

			case 0x04  # OR A, dp
				dp : u16 [ spc_dp[] ]
				spc.a |= spc_r[dp]
				spc_nz[ spc.a ]

			case 0x14  # OR A, dp+X
				dp : u16 [ spc_dp[] ]
				spc.a |= spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				spc_nz[ spc.a ]

			case 0x05  # OR A, abs
				addr  : u16 [ spc_rw[] ]
				spc.a |= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x15  # OR A, abs+X
				addr  : u16 [ spc_rw[] ]
				spc.a |= spc_r[ (addr + spc.x) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x16  # OR A, abs+Y
				addr  : u16 [ spc_rw[] ]
				spc.a |= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x06  # OR A, (X)
				spc.a |= spc_r[spc.x]
				spc_nz[ spc.a ]

			case 0x17  # OR A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				spc.a |= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x07  # OR A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr   : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr  : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				spc.a |= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x08  # OR A, #imm
				spc.a |= spc_rb[]
				spc_nz[ spc.a ]

			case 0x19  # OR (X), (Y)
				result : u8 [ spc_r[spc.x] | spc_r[spc.y] ]
				spc_w[ spc.x, result ]
				spc_nz[ result ]

			case 0x09  # OR dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dst] | spc_r[src] ]
				spc_w[ dst, result ]
				spc_nz[ result ]

			case 0x18  # OR dp, #imm  (imm first)
				imm    : u8 [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dp] | imm ]
				spc_w[ dp, result ]
				spc_nz[ result ]

			case 0x44  # EOR A, dp
				dp : u16 [ spc_dp[] ]
				spc.a ^= spc_r[dp]
				spc_nz[ spc.a ]

			case 0x54  # EOR A, dp+X
				dp : u16 [ spc_dp[] ]
				spc.a ^= spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				spc_nz[ spc.a ]

			case 0x45  # EOR A, abs
				addr  : u16 [ spc_rw[] ]
				spc.a ^= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x55  # EOR A, abs+X
				addr  : u16 [ spc_rw[] ]
				spc.a ^= spc_r[ (addr + spc.x) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x56  # EOR A, abs+Y
				addr  : u16 [ spc_rw[] ]
				spc.a ^= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x46  # EOR A, (X)
				spc.a ^= spc_r[spc.x]
				spc_nz[ spc.a ]

			case 0x57  # EOR A, [dp]+Y
				dp : u16 [ spc_dp[] ]
				addr  : u16 [ spc_r[dp] | (spc_r[dp + 1] << 8) ]
				spc.a ^= spc_r[ (addr + spc.y) & 0xFFFF ]
				spc_nz[ spc.a ]

			case 0x47  # EOR A, [dp+X]
				dp : u16 [ spc_dp[] ]
				ptr   : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				addr  : u16 [ spc_r[ptr] | (spc_r[ptr + 1] << 8) ]
				spc.a ^= spc_r[addr]
				spc_nz[ spc.a ]

			case 0x48  # EOR A, #imm
				spc.a ^= spc_rb[]
				spc_nz[ spc.a ]

			case 0x59  # EOR (X), (Y)
				result : u8 [ spc_r[spc.x] ^ spc_r[spc.y] ]
				spc_w[ spc.x, result ]
				spc_nz[ result ]

			case 0x49  # EOR dp, dp
				src : u16 [ spc_dp[] ]
				dst : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dst] ^ spc_r[src] ]
				spc_w[ dst, result ]
				spc_nz[ result ]

			case 0x58  # EOR dp, #imm  (imm first)
				imm    : u8 [ spc_rb[] ]
				dp : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dp] ^ imm ]
				spc_w[ dp, result ]
				spc_nz[ result ]

			case 0xBC  # INC A
				spc.a  += 1
				spc_nz[ spc.a ]

			case 0x3D  # INC X
				spc.x  += 1
				spc_nz[ spc.x ]

			case 0xFC  # INC Y
				spc.y  += 1
				spc_nz[ spc.y ]

			case 0xAB  # INC dp
				dp : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dp] + 1 ]
				spc_w[ dp, result ]
				spc_nz[ result ]

			case 0xBB  # INC dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				result : u8 [ spc_r[xaddr] + 1 ]
				spc_w[ xaddr, result ]
				spc_nz[ result ]

			case 0xAC  # INC abs
				addr   : u16 [ spc_rw[] ]
				result : u8  [ spc_r[addr] + 1 ]
				spc_w[ addr, result ]
				spc_nz[ result ]

			case 0x9C  # DEC A
				spc.a  -= 1
				spc_nz[ spc.a ]

			case 0x1D  # DEC X
				spc.x  -= 1
				spc_nz[ spc.x ]

			case 0xDC  # DEC Y
				spc.y  -= 1
				spc_nz[ spc.y ]

			case 0x8B  # DEC dp
				dp : u16 [ spc_dp[] ]
				result : u8 [ spc_r[dp] - 1 ]
				spc_w[ dp, result ]
				spc_nz[ result ]

			case 0x9B  # DEC dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				result : u8 [ spc_r[xaddr] - 1 ]
				spc_w[ xaddr, result ]
				spc_nz[ result ]

			case 0x8C  # DEC abs
				addr   : u16 [ spc_rw[] ]
				result : u8  [ spc_r[addr] - 1 ]
				spc_w[ addr, result ]
				spc_nz[ result ]

			case 0x1C  # ASL A
				carry  : u8 [ (spc.a & 0x80) ? 0x01 : 0 ]
				spc.a <<= 1
				spc_nzc[ spc.a, carry ]

			case 0x0B  # ASL dp
				dp : u16 [ spc_dp[] ]
				value  : u8 [ spc_r[dp] ]
				carry  : u8 [ (value & 0x80) ? 0x01 : 0 ]
				value <<= 1
				spc_w[ dp, value ]
				spc_nzc[ value, carry ]

			case 0x1B  # ASL dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				value  : u8 [ spc_r[xaddr] ]
				carry  : u8 [ (value & 0x80) ? 0x01 : 0 ]
				value <<= 1
				spc_w[ xaddr, value ]
				spc_nzc[ value, carry ]

			case 0x0C  # ASL abs
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[addr] ]
				carry  : u8  [ (value & 0x80) ? 0x01 : 0 ]
				value <<= 1
				spc_w[ addr, value ]
				spc_nzc[ value, carry ]

			case 0x5C  # LSR A
				carry  : u8 [ spc.a & 0x01 ]
				spc.a >>= 1
				spc.psw = (spc.psw & ~0x83) | carry | ((spc.a == 0) ? 0x02 : 0)

			case 0x4B  # LSR dp
				dp : u16 [ spc_dp[] ]
				value  : u8 [ spc_r[dp] ]
				carry  : u8 [ value & 0x01 ]
				value >>= 1
				spc_w[ dp, value ]
				spc.psw = (spc.psw & ~0x83) | carry | ((value == 0) ? 0x02 : 0)

			case 0x5B  # LSR dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				value  : u8 [ spc_r[xaddr] ]
				carry  : u8 [ value & 0x01 ]
				value >>= 1
				spc_w[ xaddr, value ]
				spc.psw = (spc.psw & ~0x83) | carry | ((value == 0) ? 0x02 : 0)

			case 0x4C  # LSR abs
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[addr] ]
				carry  : u8  [ value & 0x01 ]
				value >>= 1
				spc_w[ addr, value ]
				spc.psw = (spc.psw & ~0x83) | carry | ((value == 0) ? 0x02 : 0)

			case 0x3C  # ROL A
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ (spc.a & 0x80) ? 0x01 : 0 ]
				spc.a   = (spc.a << 1) | old_c
				spc_nzc[ spc.a, new_c ]

			case 0x2B  # ROL dp
				dp : u16 [ spc_dp[] ]
				value  : u8 [ spc_r[dp] ]
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ (value & 0x80) ? 0x01 : 0 ]
				value   = (value << 1) | old_c
				spc_w[ dp, value ]
				spc_nzc[ value, new_c ]

			case 0x3B  # ROL dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				value  : u8 [ spc_r[xaddr] ]
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ (value & 0x80) ? 0x01 : 0 ]
				value   = (value << 1) | old_c
				spc_w[ xaddr, value ]
				spc_nzc[ value, new_c ]

			case 0x2C  # ROL abs
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[addr] ]
				old_c  : u8  [ spc.psw & 0x01 ]
				new_c  : u8  [ (value & 0x80) ? 0x01 : 0 ]
				value   = (value << 1) | old_c
				spc_w[ addr, value ]
				spc_nzc[ value, new_c ]

			case 0x7C  # ROR A
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ spc.a & 0x01 ]
				spc.a   = (spc.a >> 1) | (old_c << 7)
				spc_nzc[ spc.a, new_c ]

			case 0x6B  # ROR dp
				dp : u16 [ spc_dp[] ]
				value  : u8 [ spc_r[dp] ]
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ value & 0x01 ]
				value   = (value >> 1) | (old_c << 7)
				spc_w[ dp, value ]
				spc_nzc[ value, new_c ]

			case 0x7B  # ROR dp+X
				dp : u16 [ spc_dp[] ]
				xaddr  : u16 [ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ]
				value  : u8 [ spc_r[xaddr] ]
				old_c  : u8 [ spc.psw & 0x01 ]
				new_c  : u8 [ value & 0x01 ]
				value   = (value >> 1) | (old_c << 7)
				spc_w[ xaddr, value ]
				spc_nzc[ value, new_c ]

			case 0x6C  # ROR abs
				addr   : u16 [ spc_rw[] ]
				value  : u8  [ spc_r[addr] ]
				old_c  : u8  [ spc.psw & 0x01 ]
				new_c  : u8  [ value & 0x01 ]
				value   = (value >> 1) | (old_c << 7)
				spc_w[ addr, value ]
				spc_nzc[ value, new_c ]

			case 0x10  # BPL rel
				off : i8 [ spc_rb[] ]
				if [ !(spc.psw & 0x80) ] spc_take[ i32[off] ]

			case 0x30  # BMI rel
				off : i8 [ spc_rb[] ]
				if [ spc.psw & 0x80 ] spc_take[ i32[off] ]

			case 0x50  # BVC rel
				off : i8 [ spc_rb[] ]
				if [ !(spc.psw & 0x40) ] spc_take[ i32[off] ]

			case 0x70  # BVS rel
				off : i8 [ spc_rb[] ]
				if [ spc.psw & 0x40 ] spc_take[ i32[off] ]

			case 0x90  # BCC rel
				off : i8 [ spc_rb[] ]
				if [ !(spc.psw & 0x01) ] spc_take[ i32[off] ]

			case 0xB0  # BCS rel
				off : i8 [ spc_rb[] ]
				if [ spc.psw & 0x01 ] spc_take[ i32[off] ]

			case 0xD0  # BNE rel
				off : i8 [ spc_rb[] ]
				if [ !(spc.psw & 0x02) ] spc_take[ i32[off] ]

			case 0xF0  # BEQ rel
				off : i8 [ spc_rb[] ]
				if [ spc.psw & 0x02 ] spc_take[ i32[off] ]

			case 0xFE  # DBNZ Y, rel
				off : i8 [ spc_rb[] ]
				spc.y -= 1
				if [ spc.y != 0 ] spc_take[ i32[off] ]

			case 0x6E  # DBNZ dp, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				v   : u8 [ spc_r[dp] - 1 ]
				spc_w[ dp, v ]
				if [ v != 0 ] spc_take[ i32[off] ]

			case 0xDE  # CBNE dp+X, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				v   : u8 [ spc_r[ ((dp & 0xFF00) | ((dp + spc.x) & 0xFF)) ] ]
				if [ spc.a != v ] spc_take[ i32[off] ]

			case 0x2E  # CBNE dp, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				v   : u8 [ spc_r[dp] ]
				if [ spc.a != v ] spc_take[ i32[off] ]

			case 0x0E  # TSET1 abs
				addr : u16 [ spc_rw[] ]
				data : u8  [ spc_r[addr] ]
				diff : u8  [ (u16[spc.a] - u16[data]) & 0xFF ]
				spc.psw = (spc.psw & ~0x82) | ((diff == 0) ? 0x02 : 0) | (diff & 0x80)
				spc_w[ addr, data | spc.a ]

			case 0x4E  # TCLR1 abs
				addr : u16 [ spc_rw[] ]
				data : u8  [ spc_r[addr] ]
				diff : u8  [ (u16[spc.a] - u16[data]) & 0xFF ]
				spc.psw = (spc.psw & ~0x82) | ((diff == 0) ? 0x02 : 0) | (diff & 0x80)
				spc_w[ addr, data & ~spc.a ]

			case 0x2F  # BRA rel
				off    : i8 [ spc_rb[] ]
				spc.pc  = u16[i32[spc.pc] + i32[off]]

			case 0x0A  # OR1 C, mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ spc_r[maddr] & (1 << bit) ] spc.psw |= 0x01

			case 0x2A  # OR1 C, /mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ !(spc_r[maddr] & (1 << bit)) ] spc.psw |= 0x01

			case 0x4A  # AND1 C, mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ !(spc_r[maddr] & (1 << bit)) ] spc.psw &= ~0x01

			case 0x6A  # AND1 C, /mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ spc_r[maddr] & (1 << bit) ] spc.psw &= ~0x01

			case 0x8A  # EOR1 C, mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ spc_r[maddr] & (1 << bit) ] spc.psw ^= 0x01

			case 0xAA  # MOV1 C, mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				if [ spc_r[maddr] & (1 << bit) ]
					spc.psw |= 0x01
				el
					spc.psw &= ~0x01

			case 0xCA  # MOV1 mem.bit, C
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				r      : u8  [ spc_r[maddr] ]
				if [ spc.psw & 0x01 ]
					spc_w[ maddr, r | u8[1 << bit] ]
				el
					spc_w[ maddr, r & ~u8[1 << bit] ]

			case 0xEA  # NOT1 mem.bit
				raw    : u16 [ spc_rw[] ]
				bit    : u8  [ u8[(raw >> 13) & 7] ]
				maddr  : u16 [ raw & 0x1FFF ]
				r      : u8  [ spc_r[maddr] ]
				spc_w[ maddr, r ^ u8[1 << bit] ]

			case 0x02  # SET1 dp.0
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x01 ]

			case 0x22  # SET1 dp.1
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x02 ]

			case 0x42  # SET1 dp.2
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x04 ]

			case 0x62  # SET1 dp.3
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x08 ]

			case 0x82  # SET1 dp.4
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x10 ]

			case 0xA2  # SET1 dp.5
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x20 ]

			case 0xC2  # SET1 dp.6
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x40 ]

			case 0xE2  # SET1 dp.7
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] | 0x80 ]

			case 0x12  # CLR1 dp.0
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x01 ]

			case 0x32  # CLR1 dp.1
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x02 ]

			case 0x52  # CLR1 dp.2
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x04 ]

			case 0x72  # CLR1 dp.3
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x08 ]

			case 0x92  # CLR1 dp.4
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x10 ]

			case 0xB2  # CLR1 dp.5
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x20 ]

			case 0xD2  # CLR1 dp.6
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x40 ]

			case 0xF2  # CLR1 dp.7
				dp : u16 [ spc_dp[] ]
				spc_w[ dp, spc_r[dp] & ~0x80 ]

			case 0x03  # BBS dp.0, rel
				dp : u16 [ spc_dp[] ]
