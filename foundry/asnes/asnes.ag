				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_ora_a[ cpu_read_long_dp_y[dp] ]
				cycles = 7
			case 0x37  # AND [dp],Y
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_and_a[ cpu_read_long_dp_y[dp] ]
				cycles = 7
			case 0x57  # EOR [dp],Y
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_eor_a[ cpu_read_long_dp_y[dp] ]
				cycles = 7
			case 0xD7  # CMP [dp],Y
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_cmp_a[ cpu_read_long_dp_y[dp] ]
				cycles = 7
