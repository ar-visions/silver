			case 0xDF  # DAA A
				if [ (spc.a & 0x0F) > 9 || (spc.psw & 0x08) ]
					spc.a += 6
				if [ (spc.a & 0xF0) > 0x90 || (spc.psw & 0x01) ]
					spc.a   += 0x60
					spc.psw |= 0x01
				el
					spc.psw &= ~0x01
				spc_nz[ spc.a ]

