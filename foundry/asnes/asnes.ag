				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x20 ] spc.pc = u16[i32[spc.pc] + i32[off]]

			case 0xC3  # BBS dp.6, rel
				dp : u16 [ spc_dp[] ]
				off : i8 [ spc_rb[] ]
				if [ spc_r[dp] & 0x40 ] spc.pc = u16[i32[spc.pc] + i32[off]]

