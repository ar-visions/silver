			case 0xF6  # INC dp,X
				addr   : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				cpu_write_dp[ addr, cpu_inc_v[ cpu_read_dp[addr] ] ]
				cycles = 6
			case 0xFE  # INC abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_inc_v[ cpu_read_mem[addr] ] ]
				cycles = 7

			# --- ALU (dp,X): ptr at (dp+X) in direct page ---
			case 0x21  # AND (dp,X)
				dpx : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				px  : u16 [ (dpx + cpu.x) & 0xFFFF ]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_and_a[ cpu_read_mem[ax] ]
				cycles = 6
			case 0x41  # EOR (dp,X)
				dpx : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				px  : u16 [ (dpx + cpu.x) & 0xFFFF ]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_eor_a[ cpu_read_mem[ax] ]
				cycles = 6
			case 0x61  # ADC (dp,X)
				dpx : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				px  : u16 [ (dpx + cpu.x) & 0xFFFF ]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_adc_a[ cpu_read_mem[ax] ]
				cycles = 6
			case 0xC1  # CMP (dp,X)
				dpx : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				px  : u16 [ (dpx + cpu.x) & 0xFFFF ]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_cmp_a[ cpu_read_mem[ax] ]
				cycles = 6
			case 0xE1  # SBC (dp,X)
				dpx : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				px  : u16 [ (dpx + cpu.x) & 0xFFFF ]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_sbc_a[ cpu_read_mem[ax] ]
				cycles = 6

			# --- ALU (dp),Y: ptr at dp, + Y ---
			case 0x11  # ORA (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_ora_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5
			case 0x31  # AND (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_and_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5
			case 0x51  # EOR (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_eor_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5
			case 0x71  # ADC (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_adc_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5
			case 0xD1  # CMP (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_cmp_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5
			case 0xF1  # SBC (dp),Y
				dpy : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_sbc_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5

			# --- ALU (dp): ptr at dp ---
			case 0x12  # ORA (dp)
				dpz : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_ora_a[ cpu_read_mem[az] ]
				cycles = 5
			case 0x32  # AND (dp)
				dpz : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_and_a[ cpu_read_mem[az] ]
				cycles = 5
			case 0x52  # EOR (dp)
				dpz : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_eor_a[ cpu_read_mem[az] ]
				cycles = 5
			case 0xD2  # CMP (dp)
				dpz : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_cmp_a[ cpu_read_mem[az] ]
				cycles = 5
			case 0xF2  # SBC (dp)
				dpz : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				az  : u16 [ cpu_r[dpz] | (cpu_r[dpz + 1] << 8) ]
				cpu_sbc_a[ cpu_read_mem[az] ]
				cycles = 5

			# --- ALU abs,X ---
			case 0x1D  # ORA abs,X
				cpu_ora_a[ cpu_read_mem[ cpu_rw[] + cpu_get_X[] ] ]
				cycles = 4
			case 0x3D  # AND abs,X
				cpu_and_a[ cpu_read_mem[ cpu_rw[] + cpu_get_X[] ] ]
				cycles = 4
			case 0x5D  # EOR abs,X
				cpu_eor_a[ cpu_read_mem[ cpu_rw[] + cpu_get_X[] ] ]
				cycles = 4
			case 0x7D  # ADC abs,X
				cpu_adc_a[ cpu_read_mem[ cpu_rw[] + cpu_get_X[] ] ]
				cycles = 4
			case 0xDD  # CMP abs,X
				cpu_cmp_a[ cpu_read_mem[ cpu_rw[] + cpu_get_X[] ] ]
				cycles = 4
			case 0xFD  # SBC abs,X
				cpu_sbc_a[ cpu_read_mem[ cpu_rw[] + cpu_get_X[] ] ]
				cycles = 4

			# --- ALU abs,Y ---
			case 0x19  # ORA abs,Y
				cpu_ora_a[ cpu_read_mem[ cpu_rw[] + cpu_get_Y[] ] ]
				cycles = 4
			case 0x39  # AND abs,Y
				cpu_and_a[ cpu_read_mem[ cpu_rw[] + cpu_get_Y[] ] ]
				cycles = 4
			case 0x59  # EOR abs,Y
				cpu_eor_a[ cpu_read_mem[ cpu_rw[] + cpu_get_Y[] ] ]
				cycles = 4
			case 0x79  # ADC abs,Y
				cpu_adc_a[ cpu_read_mem[ cpu_rw[] + cpu_get_Y[] ] ]
				cycles = 4
			case 0xD9  # CMP abs,Y
				cpu_cmp_a[ cpu_read_mem[ cpu_rw[] + cpu_get_Y[] ] ]
				cycles = 4
			case 0xF9  # SBC abs,Y
				cpu_sbc_a[ cpu_read_mem[ cpu_rw[] + cpu_get_Y[] ] ]
				cycles = 4

			# --- ALU dp,X ---
			case 0x15  # ORA dp,X
				cpu_ora_a[ cpu_read_dp[ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ] ]
				cycles = 4
			case 0x35  # AND dp,X
				cpu_and_a[ cpu_read_dp[ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ] ]
				cycles = 4
			case 0x55  # EOR dp,X
				cpu_eor_a[ cpu_read_dp[ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ] ]
				cycles = 4
			case 0xD5  # CMP dp,X
				cpu_cmp_a[ cpu_read_dp[ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ] ]
				cycles = 4
			case 0xF5  # SBC dp,X
				cpu_sbc_a[ cpu_read_dp[ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ] ]
				cycles = 4

			# --- ALU absolute long ---
			case 0x0F  # ORA long
				cpu_ora_a[ cpu_read_long[] ]
				cycles = 5
			case 0x2F  # AND long
				cpu_and_a[ cpu_read_long[] ]
				cycles = 5
			case 0x4F  # EOR long
				cpu_eor_a[ cpu_read_long[] ]
				cycles = 5
			case 0x6F  # ADC long
				cpu_adc_a[ cpu_read_long[] ]
				cycles = 5
			case 0xCF  # CMP long
				cpu_cmp_a[ cpu_read_long[] ]
				cycles = 5
			case 0xEF  # SBC long
				cpu_sbc_a[ cpu_read_long[] ]
				cycles = 5

			# --- ALU absolute long,X ---
			case 0x3F  # AND long,X
				cpu_and_a[ cpu_read_long_x[] ]
				cycles = 5
			case 0x5F  # EOR long,X
				cpu_eor_a[ cpu_read_long_x[] ]
				cycles = 5
			case 0x7F  # ADC long,X
				cpu_adc_a[ cpu_read_long_x[] ]
				cycles = 5
			case 0xDF  # CMP long,X
				cpu_cmp_a[ cpu_read_long_x[] ]
				cycles = 5

			# --- ALU stack-relative (d,s) ---
			case 0x03  # ORA d,s
				cpu_ora_a[ cpu_read_sr[] ]
				cycles = 4
			case 0x23  # AND d,s
				cpu_and_a[ cpu_read_sr[] ]
				cycles = 4
			case 0x43  # EOR d,s
				cpu_eor_a[ cpu_read_sr[] ]
				cycles = 4
			case 0x63  # ADC d,s
				cpu_adc_a[ cpu_read_sr[] ]
				cycles = 4
			case 0xC3  # CMP d,s
				cpu_cmp_a[ cpu_read_sr[] ]
				cycles = 4
			case 0xE3  # SBC d,s
				cpu_sbc_a[ cpu_read_sr[] ]
				cycles = 4

			# --- ALU (d,s),Y ---
			case 0x13  # ORA (d,s),Y
				cpu_ora_a[ cpu_read_sr_y[] ]
				cycles = 7
			case 0x33  # AND (d,s),Y
				cpu_and_a[ cpu_read_sr_y[] ]
				cycles = 7
			case 0x53  # EOR (d,s),Y
				cpu_eor_a[ cpu_read_sr_y[] ]
				cycles = 7
			case 0xD3  # CMP (d,s),Y
				cpu_cmp_a[ cpu_read_sr_y[] ]
				cycles = 7
			case 0xF3  # SBC (d,s),Y
				cpu_sbc_a[ cpu_read_sr_y[] ]
				cycles = 7

			# --- loads ---
			case 0xA3  # LDA d,s
				cpu_set_A[ cpu_read_sr[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 4
			case 0xA7  # LDA [dp]
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_set_A[ cpu_read_long_dp[dp] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 6
			case 0xB5  # LDA dp,X
				cpu_set_A[ cpu_read_dp[ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 4
			case 0xBF  # LDA long,X
				cpu_set_A[ cpu_read_long_x[] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 5
			case 0xB4  # LDY dp,X
				cpu_set_Y[ cpu_read_dp_x[ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ] ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 4
			case 0xBC  # LDY abs,X
				cpu_set_Y[ cpu_read_mem_x[ cpu_rw[] + cpu_get_X[] ] ]
				cpu_nz_x[ cpu_get_Y[] ]
				cycles = 4

			# --- stores ---
			case 0x83  # STA d,s
				sr : u8 [ cpu_rb[] ]
				sa : u16 [ (cpu.sp + sr) & 0xFFFF ]
				cpu_write_mem[ sa, cpu_get_A[] ]
				cycles = 4
			case 0x87  # STA [dp]
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				lo : u32 [ cpu_r[dp] ]
				mid : u32 [ cpu_r[dp + 1] ]
				bank : u32 [ cpu_r[dp + 2] ]
				la : u32 [ lo | (mid << 8) | (bank << 16) ]
				av : u16 [ cpu_get_A[] ]
				cpu_long_w[ la, u8[ av & 0xFF ] ]
				if [ !(cpu.p & 0x20) ] cpu_long_w[ la + 1, u8[ av >> 8 ] ]
				cycles = 6
			case 0x97  # STA [dp],Y
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				lo : u32 [ cpu_r[dp] ]
				mid : u32 [ cpu_r[dp + 1] ]
				bank : u32 [ cpu_r[dp + 2] ]
				la : u32 [ (lo | (mid << 8) | (bank << 16)) + cpu_get_Y[] ]
				av : u16 [ cpu_get_A[] ]
				cpu_long_w[ la, u8[ av & 0xFF ] ]
				if [ !(cpu.p & 0x20) ] cpu_long_w[ la + 1, u8[ av >> 8 ] ]
				cycles = 7
			case 0x9F  # STA long,X
				lo : u32 [ cpu_rb[] ]
				mid : u32 [ cpu_rb[] ]
				bank : u32 [ cpu_rb[] ]
				la : u32 [ (lo | (mid << 8) | (bank << 16)) + cpu_get_X[] ]
				av : u16 [ cpu_get_A[] ]
				cpu_long_w[ la, u8[ av & 0xFF ] ]
				if [ !(cpu.p & 0x20) ] cpu_long_w[ la + 1, u8[ av >> 8 ] ]
				cycles = 5
			case 0x93  # STA (d,s),Y
				sr : u8 [ cpu_rb[] ]
				sa : u16 [ (cpu.sp + sr) & 0xFFFF ]
				base : u16 [ cpu_r[sa] | (cpu_r[sa + 1] << 8) ]
				cpu_write_mem[ base + cpu_get_Y[], cpu_get_A[] ]
				cycles = 7
			case 0x94  # STY dp,X
				addr : u16 [ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ]
				cpu_w[ addr, cpu.y ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.yh ]
				cycles = 4
			case 0x96  # STX dp,Y
				addr : u16 [ (cpu.dp + cpu_rb[] + cpu_get_Y[]) & 0xFFFF ]
				cpu_w[ addr, cpu.x ]
				if [ !(cpu.p & 0x10) ] cpu_w[ addr + 1, cpu.xh ]
				cycles = 4

			# --- compares (X-width) ---
			case 0xC4  # CPY dp
				cpu_cmp_x[ cpu_get_Y[], cpu_read_dp_x[ cpu_rb[] ] ]
				cycles = 3
			case 0xCC  # CPY abs
				cpu_cmp_x[ cpu_get_Y[], cpu_read_mem_x[ cpu_rw[] ] ]
				cycles = 4
			case 0xE4  # CPX dp
				cpu_cmp_x[ cpu_get_X[], cpu_read_dp_x[ cpu_rb[] ] ]
				cycles = 3
			case 0xEC  # CPX abs
				cpu_cmp_x[ cpu_get_X[], cpu_read_mem_x[ cpu_rw[] ] ]
				cycles = 4

			# --- BIT ---
			case 0x89  # BIT #imm (only affects Z)
				value : u16 [ cpu_imm_a[] ]
				z : u8 [ ((cpu_get_A[] & value) == 0) ? 0x02 : 0 ]
				cpu.p = (cpu.p & ~0x02) | z
				cycles = 2
			case 0x34  # BIT dp,X
				cpu_bit_a[ cpu_read_dp[ (cpu.dp + cpu_rb[] + cpu_get_X[]) & 0xFFFF ] ]
				cycles = 4
			case 0x3C  # BIT abs,X
				cpu_bit_a[ cpu_read_mem[ cpu_rw[] + cpu_get_X[] ] ]
				cycles = 4

			# --- control flow ---
			case 0x7C  # JMP (abs,X)
				ptr : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu.pc = cpu_fetch_at[ptr] | (cpu_fetch_at[ptr + 1] << 8)
				cycles = 6
			case 0xFC  # JSR (abs,X)
				ptr : u16 [ cpu_rw[] ]
				ret : u16 [ cpu.pc - 1 ]
				cpu_push16[ ret ]
				addr : u16 [ (ptr + cpu_get_X[]) & 0xFFFF ]
				cpu.pc = cpu_fetch_at[addr] | (cpu_fetch_at[addr + 1] << 8)
				cycles = 8
			case 0x82  # BRL (branch long)
				rel : u16 [ cpu_rw[] ]
				cpu.pc = cpu.pc + rel
				cycles = 4
			case 0x62  # PER
				rel : u16 [ cpu_rw[] ]
				cpu_push16[ cpu.pc + rel ]
				cycles = 6
			case 0xD4  # PEI
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_push16[ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cycles = 6
			case 0xF4  # PEA
				cpu_push16[ cpu_rw[] ]
				cycles = 5

			# --- misc / system ---
			case 0x42  # WDM (2-byte no-op)
				cpu_rb[]
				cycles = 2
			case 0x02  # COP (consume signature, treat as no-op)
				cpu_rb[]
				cycles = 7
			case 0xCB  # WAI: halt CPU until the next interrupt; frame loop fast-forwards to NMI
				cpu_wai = true
				cycles  = 3
			case 0xDB  # STP (no-op)
				cycles = 3
			case 0x54  # MVN (block move, ascending)
				dstb : u32 [ cpu_rb[] ]
				srcb : u32 [ cpu_rb[] ]
				cpu.dbr = dstb
				if [ env_pal ]
					dyy : u16 [ cpu.y | (cpu.yh << 8) ]
					if [ dyy >= 0x0500 && dyy <= 0x0540 ]
						sxx : u16 [ cpu.x | (cpu.xh << 8) ]
						printf[ "MVN->%04X src=%02X:%04X n=%04X firstbyte=%02X f%u pc=%04X\n",
							dyy, srcb, sxx, cpu.a | (cpu.b << 8), cpu_bank_r[ srcb, sxx ], dbg_frames, cpu.pc ]
						if [ dyy == 0x0520 && dbg_bad < 1 ]
							printf[ "  ---- 32 instrs before MVN->0520 ----\n" ]
							for [ k: i32 0, k < 32, k += 1 ]
								s2 : i32 [ (tr_i + k) % 32 ]
								printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[s2] >> 16, tr_addr[s2] & 0xFFFF, tr_b0[s2], tr_b1[s2], tr_b2[s2], tr_b3[s2], tr_p[s2], tr_a[s2], tr_x[s2], tr_y[s2] ]
							dbg_bad += 1
				if [ dbg_ev3 < 60 ]
					printf[ "f%u MVN src=%02X:%04X -> dst=%02X:%04X n=%04X\n", dbg_frames, srcb, cpu.x | (cpu.xh << 8), dstb, cpu.y | (cpu.yh << 8), cpu.a | (cpu.b << 8) ]
					dbg_ev3 += 1
				if [ dbg_frames >= 200 && dbg_bad < 2 ]
					printf[ "  ---- 32 instrs before this MVN (f%u) ----\n", dbg_frames ]
					for [ k: i32 0, k < 32, k += 1 ]
						s2 : i32 [ (tr_i + k) % 32 ]
						printf[ "  %02X:%04X  %02X %02X %02X %02X   P=%03X A=%04X X=%04X Y=%04X\n", tr_addr[s2] >> 16, tr_addr[s2] & 0xFFFF, tr_b0[s2], tr_b1[s2], tr_b2[s2], tr_b3[s2], tr_p[s2], tr_a[s2], tr_x[s2], tr_y[s2] ]
					dbg_bad += 1
				nbytes : i32 [ i32[ cpu.a | (cpu.b << 8) ] + 1 ]   # MVN moves A+1 bytes, 7 cycles each
				cont : bool [ true ]
				while [ cont ]
					sx : u16 [ cpu.x | (cpu.xh << 8) ]
					dy : u16 [ cpu.y | (cpu.yh << 8) ]
					cpu_bank_w[ dstb, dy, cpu_bank_r[ srcb, sx ] ]
					nx : u16 [ (sx + 1) & 0xFFFF ]
					ny : u16 [ (dy + 1) & 0xFFFF ]
					cpu.x = nx & 0xFF
					cpu.xh = nx >> 8
					cpu.y = ny & 0xFF
					cpu.yh = ny >> 8
					cnt : u16 [ cpu.a | (cpu.b << 8) ]
					nc : u16 [ (cnt - 1) & 0xFFFF ]
					cpu.a = nc & 0xFF
					cpu.b = nc >> 8
					if [ cnt == 0 ] cont = false
				op_master += nbytes * 36 - 24      # per byte: +3 opcode re-fetches +2 idle beyond the 2 ticked data accesses
				cycles = 7
			case 0x44  # MVP (block move, descending)
				dstb : u32 [ cpu_rb[] ]
				srcb : u32 [ cpu_rb[] ]
				cpu.dbr = dstb
				nbytes : i32 [ i32[ cpu.a | (cpu.b << 8) ] + 1 ]   # MVP moves A+1 bytes, 7 cycles each
				cont : bool [ true ]
				while [ cont ]
					sx : u16 [ cpu.x | (cpu.xh << 8) ]
					dy : u16 [ cpu.y | (cpu.yh << 8) ]
					cpu_bank_w[ dstb, dy, cpu_bank_r[ srcb, sx ] ]
					nx : u16 [ (sx - 1) & 0xFFFF ]
					ny : u16 [ (dy - 1) & 0xFFFF ]
					cpu.x = nx & 0xFF
					cpu.xh = nx >> 8
					cpu.y = ny & 0xFF
					cpu.yh = ny >> 8
					cnt : u16 [ cpu.a | (cpu.b << 8) ]
					nc : u16 [ (cnt - 1) & 0xFFFF ]
					cpu.a = nc & 0xFF
					cpu.b = nc >> 8
					if [ cnt == 0 ] cont = false
				op_master += nbytes * 36 - 24      # per byte: +3 opcode re-fetches +2 idle beyond the 2 ticked data accesses
				cycles = 7

			case 0x67  # ADC [dp] (long indirect, width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				blo    : u32 [ cpu_r[dp] ]
				bmid   : u32 [ cpu_r[dp + 1] ]
				bbank  : u32 [ cpu_r[dp + 2] ]
				la     : u32 [ blo | (bmid << 8) | (bbank << 16) ]
				if [ cpu.p & 0x20 ]
					cpu_adc_a[ cpu_long_r[la] ]
				el
					cpu_adc_a[ cpu_long_r[la] | (cpu_long_r[la + 1] << 8) ]
				cycles = 7

			case 0x77  # ADC [dp],Y (long indirect indexed, width-aware)
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				ylo    : u32 [ cpu_r[dp] ]
				ymid   : u32 [ cpu_r[dp + 1] ]
				ybank  : u32 [ cpu_r[dp + 2] ]
				yla    : u32 [ (ylo | (ymid << 8) | (ybank << 16)) + cpu_get_Y[] ]
				if [ cpu.p & 0x20 ]
					cpu_adc_a[ cpu_long_r[yla] ]
				el
					cpu_adc_a[ cpu_long_r[yla] | (cpu_long_r[yla + 1] << 8) ]
				cycles = 7

			case 0xB3  # LDA (d,S),Y (stack-relative indirect indexed, width-aware)
				sr     : u8  [ cpu_rb[] ]
				sa     : u16 [ (cpu.sp + sr) & 0xFFFF ]
				ptr    : u16 [ cpu_r[sa] | (cpu_r[sa + 1] << 8) ]
				addr   : u16 [ ptr + cpu_get_Y[] ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 7

			case 0x1F  # ORA long,X (width-aware)
				lo     : u32 [ cpu_rb[] ]
				hi     : u32 [ cpu_rb[] ]
				bank   : u32 [ cpu_rb[] ]
				laddr  : u32 [ (lo | (hi << 8) | (bank << 16)) + cpu_get_X[] ]
				if [ cpu.p & 0x20 ]
					cpu_set_A[ cpu_get_A[] | cpu_long_r[laddr] ]
				el
					m : u16 [ cpu_long_r[laddr] | (cpu_long_r[laddr + 1] << 8) ]
					cpu_set_A[ cpu_get_A[] | m ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 6

			default
				printf[ "unhandled cpu opcode %02X at %04X\n", opcode, cpu.pc - 1 ]
				fault 'unhandled cpu opcode — implement it then re-run (one at a time)'

		count_cpu = false
		# real master cycles = sum of access speeds + internal/idle cycles (6 master each).
		# idle = standard opcode count minus the memory accesses we actually performed.
		idle : i32 [ cycles - op_accesses ]
		if [ idle < 0 ] idle = 0
		tm : i32 [ op_master + idle * 6 + steal_master + cpu_master_rem ]
		steal_master   = 0
		rc : i32 [ tm / 6 ]
		cpu_master_rem = tm - rc * 6        # carry sub-cpu-cycle remainder so accounting stays exact
		return rc
