					cpu.p |= 0x10                 # emulation forces 8-bit index (X flag)
					cpu.xh = 0
					cpu.yh = 0
				cycles = 2

			case 0xC2  # REP #imm
				mask   : u8 [ cpu_rb[] ]
				cpu.p &= ~mask
				cycles = 3

			case 0xE2  # SEP #imm
				mask   : u8 [ cpu_rb[] ]
				cpu.p |= mask
				if [ mask & 0x10 ]              # entering 8-bit index: force XH/YH to 0
					cpu.xh = 0
					cpu.yh = 0
				cycles = 3

			case 0x14  # TRB dp
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				value  : u16 [ cpu_read_dp[dp] ]
				a16    : u16 [ cpu_get_A[] ]
				result : u16 [ a16 & value ]
				cpu_write_dp[ dp, value & ~a16 ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0x1C  # TRB abs
				addr   : u16 [ cpu_rw[] ]
				value  : u16 [ cpu_read_mem[addr] ]
				a16    : u16 [ cpu_get_A[] ]
				result : u16 [ a16 & value ]
				cpu_write_mem[ addr, value & ~a16 ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 6

			case 0x04  # TSB dp
				dp     : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				value  : u16 [ cpu_read_dp[dp] ]
				a16    : u16 [ cpu_get_A[] ]
				result : u16 [ a16 & value ]
				cpu_write_dp[ dp, value | a16 ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0x0C  # TSB abs
				addr   : u16 [ cpu_rw[] ]
				value  : u16 [ cpu_read_mem[addr] ]
				a16    : u16 [ cpu_get_A[] ]
				result : u16 [ a16 & value ]
				cpu_write_mem[ addr, value | a16 ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 6

			case 0x64  # STZ dp
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_write_dp[ dp, 0 ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0x74  # STZ dp,X
				dp : u16 [ (cpu.dp + cpu_rb[]) & 0xFFFF ]
				cpu_write_dp[ (dp + cpu.x) & 0xFFFF, 0 ]
				cycles = 4 + ((ualign) ? 1 : 0)

			case 0x9C  # STZ abs
				addr : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, 0 ]
				cycles = 4

			case 0x9E  # STZ abs,X
				addr : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, 0 ]
				cycles = 5

			case 0xFF  # SBC long,X
				cpu_sbc_a[ cpu_read_long_x[] ]
