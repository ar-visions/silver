			case 0x5C  # JML long (jump long, absolute)
				clo    : u32 [ cpu_rb[] ]
				chi    : u32 [ cpu_rb[] ]
				cbank  : u8  [ cpu_rb[] ]
				cpu.pc  = clo | (chi << 8)
				cpu.pbr = cbank
