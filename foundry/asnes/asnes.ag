					cpu.x   = cpu_r[ 0x0100 + cpu.sp ]
					cpu.p   = (cpu.p & ~0x82) | ((cpu.x == 0) ? 0x02 : 0) | (cpu.x & 0x80)
				el
					cpu.sp += 1
					xl     : u16 [ cpu_r[ 0x0100 + cpu.sp ] ]
					cpu.sp += 1
					xh     : u16 [ cpu_r[ 0x0100 + cpu.sp ] ]
					cpu.x   = xl
					cpu.xh  = xh
					xv     : u16 [ xl | (xh << 8) ]
					cpu.p   = (cpu.p & ~0x82) | ((xv == 0) ? 0x02 : 0) | ((xv & 0x8000) ? 0x80 : 0)
				cycles = 4

			case 0x7A  # PLY
				if [ cpu.p & 0x10 ]
					cpu.sp += 1
					cpu.y   = cpu_r[ 0x0100 + cpu.sp ]
					cpu.p   = (cpu.p & ~0x82) | ((cpu.y == 0) ? 0x02 : 0) | (cpu.y & 0x80)
				el
					cpu.sp += 1
					yl     : u16 [ cpu_r[ 0x0100 + cpu.sp ] ]
					cpu.sp += 1
					yh     : u16 [ cpu_r[ 0x0100 + cpu.sp ] ]
					cpu.y   = yl
					cpu.yh  = yh
					yv     : u16 [ yl | (yh << 8) ]
					cpu.p   = (cpu.p & ~0x82) | ((yv == 0) ? 0x02 : 0) | ((yv & 0x8000) ? 0x80 : 0)
				cycles = 4

			case 0x8B  # PHB
				cpu_w[ 0x0100 + cpu.sp, cpu.dbr ]
				cpu.sp -= 1
				cycles  = 3

			case 0xAB  # PLB
				cpu.sp += 1
				cpu.dbr = cpu_r[ 0x0100 + cpu.sp ]
				cpu.p   = (cpu.p & ~0x82) | ((cpu.dbr == 0) ? 0x02 : 0) | (cpu.dbr & 0x80)
				cycles  = 4

			case 0x4B  # PHK
				cpu_w[ 0x0100 + cpu.sp, cpu.pbr ]
				cpu.sp -= 1
				cycles  = 3

			case 0x0B  # PHD
				cpu_w[ 0x0100 + cpu.sp, u8[cpu.dp >> 8] ]
				cpu.sp -= 1
				cpu_w[ 0x0100 + cpu.sp, u8[cpu.dp & 0xFF] ]
				cpu.sp -= 1
				cycles  = 4

			case 0x2B  # PLD
				cpu.sp += 1
				dl     : u16 [ cpu_r[ 0x0100 + cpu.sp ] ]
				cpu.sp += 1
				dh     : u16 [ cpu_r[ 0x0100 + cpu.sp ] ]
				cpu.dp  = dl | (dh << 8)
				cpu.p   = (cpu.p & ~0x82) | ((cpu.dp == 0) ? 0x02 : 0) | ((cpu.dp & 0x8000) ? 0x80 : 0)
				cycles  = 5

			case 0xEB  # XBA
				tmp    : u8 [ cpu.a ]
				cpu.a   = cpu.b
				cpu.b   = tmp
				cpu.p   = (cpu.p & ~0x82) | ((cpu.a == 0) ? 0x02 : 0) | (cpu.a & 0x80)
				cycles  = 3

			case 0x1B  # TCS (C -> S), no flags
				cpu.sp  = cpu.a
				cycles  = 2

			case 0x3B  # TSC (S -> C), 16-bit N/Z
				sv     : u16 [ 0x0100 | cpu.sp ]
				cpu.a   = sv & 0xFF
				cpu.b   = sv >> 8
				cpu.p   = (cpu.p & ~0x82) | ((sv == 0) ? 0x02 : 0) | ((sv & 0x8000) ? 0x80 : 0)
				cycles  = 2

			case 0x5B  # TCD (C -> D), 16-bit N/Z
				cv     : u16 [ cpu.a | (cpu.b << 8) ]
				cpu.dp  = cv
				cpu.p   = (cpu.p & ~0x82) | ((cv == 0) ? 0x02 : 0) | ((cv & 0x8000) ? 0x80 : 0)
				cycles  = 2

			case 0x7B  # TDC (D -> C), 16-bit N/Z
				cpu.a   = cpu.dp & 0xFF
				cpu.b   = cpu.dp >> 8
				cpu.p   = (cpu.p & ~0x82) | ((cpu.dp == 0) ? 0x02 : 0) | ((cpu.dp & 0x8000) ? 0x80 : 0)
				cycles  = 2

			case 0x40  # RTI
				cpu.sp += 1
				cpu.p   = cpu_r[0x0100 + cpu.sp]
				cpu.sp += 1
				lo     : u16 [ cpu_r[0x0100 + cpu.sp] ]
				cpu.sp += 1
				hi     : u16 [ cpu_r[0x0100 + cpu.sp] ]
				cpu.pc  = lo | (hi << 8)
				cycles  = 6

			case 0x00  # BRK
				cpu.pc += 1
				cpu_w[ 0x0100 + cpu.sp, u8[cpu.pc >> 8] ]
				cpu.sp -= 1
				cpu_w[ 0x0100 + cpu.sp, u8[cpu.pc & 0xFF] ]
				cpu.sp -= 1
				cpu_w[ 0x0100 + cpu.sp, cpu.p | 0x10 ]
				cpu.sp -= 1
				cpu.p  |= 0x04
				lo     : u16 [ cpu_r[0xFFFE] ]
				hi     : u16 [ cpu_r[0xFFFF] ]
				cpu.pc  = lo | (hi << 8)
				cycles  = 7

			case 0xFB  # XCE
				old_carry : u8 [ cpu.p & 0x01 ]
				if [ cpu.p & 0x100 ]
					cpu.p &= ~0x100
					cpu.p |= old_carry
				el
					cpu.p |= 0x100
					cpu.p  = (cpu.p & ~0x01) | old_carry
				cycles = 2

			case 0xC2  # REP #imm
				mask   : u8 [ cpu_rb[] ]
				cpu.p &= ~mask
				cycles = 3

			case 0xE2  # SEP #imm
				mask   : u8 [ cpu_rb[] ]
				cpu.p |= mask
				cycles = 3

			case 0x14  # TRB dp
				dp     : u8 [ cpu_rb[] ]
				value  : u8 [ cpu_r[dp] ]
				result : u8 [ cpu.a & value ]
				cpu_w[ dp, value & ~cpu.a ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0x1C  # TRB abs
				addr   : u16 [ cpu_rw[] ]
				value  : u8  [ cpu_r[addr] ]
				result : u8  [ cpu.a & value ]
				cpu_w[ addr, value & ~cpu.a ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 6

			case 0x04  # TSB dp
				dp     : u8 [ cpu_rb[] ]
				value  : u8 [ cpu_r[dp] ]
				result : u8 [ cpu.a & value ]
				cpu_w[ dp, value | cpu.a ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 5 + ((ualign) ? 1 : 0)

			case 0x0C  # TSB abs
				addr   : u16 [ cpu_rw[] ]
				value  : u8  [ cpu_r[addr] ]
				result : u8  [ cpu.a & value ]
				cpu_w[ addr, value | cpu.a ]
				cpu.p  = (cpu.p & ~0x02) | ((result == 0) ? 0x02 : 0)
				cycles = 6

			case 0x64  # STZ dp
				dp : u8 [ cpu_rb[] ]
				cpu_w[ dp, 0 ]
				cycles = 3 + ((ualign) ? 1 : 0)

			case 0x74  # STZ dp,X
				dp : u8 [ cpu_rb[] ]
				cpu_w[ (dp + cpu.x) & 0xFF, 0 ]
				cycles = 4 + ((ualign) ? 1 : 0)

			case 0x9C  # STZ abs
				addr : u16 [ cpu_rw[] ]
				cpu_w[ addr, 0 ]
				cycles = 4

			case 0x9E  # STZ abs,X
				addr : u16 [ cpu_rw[] + cpu.x ]
				cpu_w[ addr, 0 ]
				cycles = 5

			case 0xFF  # SBC long,X
				lo     : u8  [ cpu_rb[] ]
				hi     : u8  [ cpu_rb[] ]
				bank   : u8  [ cpu_rb[] ]
				addr   : u32 [ lo | u32[hi << 8] | u32[bank << 16] ]
				value  : u8  [ cpu_r[ u16[(addr + cpu.x) & 0xFFFFFF] ] ]
				result : u16 [ cpu.a - value - (1 - (cpu.p & 0x01)) ]
				cpu_sbc[ cpu.a, value, result ]
				cpu.a   = result & 0xFF

			case 0x22  # JSL (jump subroutine long)
				lo     : u32 [ cpu_rb[] ]
				hi     : u32 [ cpu_rb[] ]
				nbank  : u8  [ cpu_rb[] ]
				ret    : u16 [ cpu.pc - 1 ]
				cpu_w[ 0x0100 + cpu.sp, cpu.pbr ]
				cpu.sp -= 1
				cpu_w[ 0x0100 + cpu.sp, u8[ret >> 8] ]
				cpu.sp -= 1
				cpu_w[ 0x0100 + cpu.sp, u8[ret & 0xFF] ]
				cpu.sp -= 1
				cpu.pbr = nbank
				cpu.pc  = lo | (hi << 8)
				cycles  = 8

			case 0x6B  # RTL (return subroutine long)
				cpu.sp += 1
				rlo    : u16 [ cpu_r[0x0100 + cpu.sp] ]
				cpu.sp += 1
				rhi    : u16 [ cpu_r[0x0100 + cpu.sp] ]
				cpu.sp += 1
				cpu.pbr = cpu_r[0x0100 + cpu.sp]
				cpu.pc  = (rlo | (rhi << 8)) + 1
				cycles  = 6

			case 0xDC  # JML [abs] (jump long, absolute indirect)
				jptr   : u16 [ cpu_rw[] ]
				jlo    : u16 [ cpu_r[jptr] ]
				jhi    : u16 [ cpu_r[jptr + 1] ]
				jbank  : u8  [ cpu_r[jptr + 2] ]
				cpu.pc  = jlo | (jhi << 8)
				cpu.pbr = jbank
				cycles  = 6

			case 0x5C  # JML long (jump long, absolute)
				clo    : u32 [ cpu_rb[] ]
				chi    : u32 [ cpu_rb[] ]
				cbank  : u8  [ cpu_rb[] ]
				cpu.pc  = clo | (chi << 8)
				cpu.pbr = cbank
				cycles  = 4

			case 0xB2  # LDA (dp) (width-aware)
				dp     : u8  [ cpu_rb[] ]
				addr   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cpu_set_A[ cpu_read_mem[addr] ]
				cpu_nz_a[ cpu_get_A[] ]
				cycles = 5

			case 0x92  # STA (dp) (width-aware)
				dp     : u8  [ cpu_rb[] ]
				addr   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cpu_write_mem[ addr, cpu_get_A[] ]
				cycles = 5

			case 0x75  # ADC dp,X (width-aware)
				addr   : u8  [ (cpu_rb[] + cpu.x) & 0xFF ]
				cpu_adc_a[ cpu_read_mem[addr] ]
				cycles = 4

			case 0x73  # ADC (d,S),Y (stack-relative indirect indexed, width-aware)
				sr2    : u8  [ cpu_rb[] ]
				sa2    : u16 [ 0x0100 + ((cpu.sp + sr2) & 0xFF) ]
				p2     : u16 [ cpu_r[sa2] | (cpu_r[sa2 + 1] << 8) ]
				a2     : u16 [ p2 + cpu_get_Y[] ]
				cpu_adc_a[ cpu_read_mem[a2] ]
				cycles = 7

			case 0x72  # ADC (dp) (width-aware)
				dp     : u8  [ cpu_rb[] ]
				addr   : u16 [ cpu_r[dp] | (cpu_r[dp + 1] << 8) ]
				cpu_adc_a[ cpu_read_mem[addr] ]
				cycles = 5

			case 0x76  # ROR dp,X (width-aware RMW)
				addr   : u8 [ (cpu_rb[] + cpu.x) & 0xFF ]
				cpu_write_mem[ addr, cpu_ror_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x16  # ASL dp,X
				addr   : u8 [ (cpu_rb[] + cpu.x) & 0xFF ]
				cpu_write_mem[ addr, cpu_asl_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x1E  # ASL abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_asl_v[ cpu_read_mem[addr] ] ]
				cycles = 7

			case 0x56  # LSR dp,X
				addr   : u8 [ (cpu_rb[] + cpu.x) & 0xFF ]
				cpu_write_mem[ addr, cpu_lsr_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x5E  # LSR abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_lsr_v[ cpu_read_mem[addr] ] ]
				cycles = 7

			case 0x36  # ROL dp,X
				addr   : u8 [ (cpu_rb[] + cpu.x) & 0xFF ]
				cpu_write_mem[ addr, cpu_rol_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x3E  # ROL abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_rol_v[ cpu_read_mem[addr] ] ]
				cycles = 7

			case 0x7E  # ROR abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_ror_v[ cpu_read_mem[addr] ] ]
				cycles = 7

			case 0x0E  # ASL abs
				addr   : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_asl_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x2E  # ROL abs
				addr   : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_rol_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x4E  # LSR abs
				addr   : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_lsr_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x6E  # ROR abs
				addr   : u16 [ cpu_rw[] ]
				cpu_write_mem[ addr, cpu_ror_v[ cpu_read_mem[addr] ] ]
				cycles = 6

			case 0x07  # ORA [dp]
				dp : u8 [ cpu_rb[] ]
				cpu_ora_a[ cpu_read_long_dp[dp] ]
				cycles = 7
			case 0x27  # AND [dp]
				dp : u8 [ cpu_rb[] ]
				cpu_and_a[ cpu_read_long_dp[dp] ]
				cycles = 7
			case 0x47  # EOR [dp]
				dp : u8 [ cpu_rb[] ]
				cpu_eor_a[ cpu_read_long_dp[dp] ]
				cycles = 7
			case 0xC7  # CMP [dp]
				dp : u8 [ cpu_rb[] ]
				cpu_cmp_a[ cpu_read_long_dp[dp] ]
				cycles = 7
			case 0xE7  # SBC [dp]
				dp : u8 [ cpu_rb[] ]
				cpu_sbc_a[ cpu_read_long_dp[dp] ]
				cycles = 7
			case 0x17  # ORA [dp],Y
				dp : u8 [ cpu_rb[] ]
				cpu_ora_a[ cpu_read_long_dp_y[dp] ]
				cycles = 7
			case 0x37  # AND [dp],Y
				dp : u8 [ cpu_rb[] ]
				cpu_and_a[ cpu_read_long_dp_y[dp] ]
				cycles = 7
			case 0x57  # EOR [dp],Y
				dp : u8 [ cpu_rb[] ]
				cpu_eor_a[ cpu_read_long_dp_y[dp] ]
				cycles = 7
			case 0xD7  # CMP [dp],Y
				dp : u8 [ cpu_rb[] ]
				cpu_cmp_a[ cpu_read_long_dp_y[dp] ]
				cycles = 7
			case 0xF7  # SBC [dp],Y
				dp : u8 [ cpu_rb[] ]
				cpu_sbc_a[ cpu_read_long_dp_y[dp] ]
				cycles = 7

			case 0xD6  # DEC dp,X
				addr   : u8 [ (cpu_rb[] + cpu.x) & 0xFF ]
				cpu_write_mem[ addr, cpu_dec_v[ cpu_read_mem[addr] ] ]
				cycles = 6
			case 0xDE  # DEC abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_dec_v[ cpu_read_mem[addr] ] ]
				cycles = 7
			case 0xF6  # INC dp,X
				addr   : u8 [ (cpu_rb[] + cpu.x) & 0xFF ]
				cpu_write_mem[ addr, cpu_inc_v[ cpu_read_mem[addr] ] ]
				cycles = 6
			case 0xFE  # INC abs,X
				addr   : u16 [ cpu_rw[] + cpu_get_X[] ]
				cpu_write_mem[ addr, cpu_inc_v[ cpu_read_mem[addr] ] ]
				cycles = 7

			# --- ALU (dp,X): ptr at (dp+X) in direct page ---
			case 0x21  # AND (dp,X)
				dpx : u8  [ cpu_rb[] ]
				px  : u16 [ (dpx + cpu.x) & 0xFF ]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_and_a[ cpu_read_mem[ax] ]
				cycles = 6
			case 0x41  # EOR (dp,X)
				dpx : u8  [ cpu_rb[] ]
				px  : u16 [ (dpx + cpu.x) & 0xFF ]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_eor_a[ cpu_read_mem[ax] ]
				cycles = 6
			case 0x61  # ADC (dp,X)
				dpx : u8  [ cpu_rb[] ]
				px  : u16 [ (dpx + cpu.x) & 0xFF ]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_adc_a[ cpu_read_mem[ax] ]
				cycles = 6
			case 0xC1  # CMP (dp,X)
				dpx : u8  [ cpu_rb[] ]
				px  : u16 [ (dpx + cpu.x) & 0xFF ]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_cmp_a[ cpu_read_mem[ax] ]
				cycles = 6
			case 0xE1  # SBC (dp,X)
				dpx : u8  [ cpu_rb[] ]
				px  : u16 [ (dpx + cpu.x) & 0xFF ]
				ax  : u16 [ cpu_r[px] | (cpu_r[px + 1] << 8) ]
				cpu_sbc_a[ cpu_read_mem[ax] ]
				cycles = 6

			# --- ALU (dp),Y: ptr at dp, + Y ---
			case 0x11  # ORA (dp),Y
				dpy : u8  [ cpu_rb[] ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_ora_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5
			case 0x31  # AND (dp),Y
				dpy : u8  [ cpu_rb[] ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_and_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5
			case 0x51  # EOR (dp),Y
				dpy : u8  [ cpu_rb[] ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_eor_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5
			case 0x71  # ADC (dp),Y
				dpy : u8  [ cpu_rb[] ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_adc_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5
			case 0xD1  # CMP (dp),Y
				dpy : u8  [ cpu_rb[] ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_cmp_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
				cycles = 5
			case 0xF1  # SBC (dp),Y
				dpy : u8  [ cpu_rb[] ]
				by  : u16 [ cpu_r[dpy] | (cpu_r[dpy + 1] << 8) ]
				cpu_sbc_a[ cpu_read_mem[ by + cpu_get_Y[] ] ]
