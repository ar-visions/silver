import spectra
import img
import <stdio.h>

# decode a .caf/.m4a and render its spectrograph:
# spectro --file <audio> [--out png] [--w N] [--h N]
app spectro
    public file : string
    public out  : string [ '/tmp/spectrograph.png' ]
    public w    : i32 [ 1024 ]
    public h    : i32 [ 512 ]

    func init []
        if [ !file ]
            puts 'usage: spectro --file <caf/m4a> [--out <png>] [--w N] [--h N]'
            return
        c : caf_load[ path file ]
        if [ !c ] return
        if [ spectrograph[ c, path out, w, h ] ]
            puts 'spectrograph: {out}'
