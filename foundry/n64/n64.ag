	mutable lle          : bool              # N64_LLE: boot from 0xBFC00000 (real IPL) vs HLE
	mutable pif_state    : i32               # PIF boot state: 0 Init 1 Lockout 2 GetChk 3 ChkChk 4 TermBoot 5 Run
	mutable rom_data     : ref u8
	mutable rom_size     : i64
	# MI
	mutable mi_intr      : u32              # pending: SP DP? bit0=SP 1=SI 2=AI 3=VI 4=PI 5=DP
	mutable mi_mask      : u32
	mutable mi_mode      : u32
	# VI
	mutable vi_ctrl      : u32
	mutable vi_origin    : u32
	mutable vi_width     : u32
	mutable vi_intr_line : u32 [ 0x3FF ]
	mutable vi_current   : u32
	mutable vi_hstart    : u32
	mutable vi_vstart    : u32
	mutable vi_xscale    : u32
	mutable vi_yscale    : u32
	# cycle-accurate VI line clock (ares VI::main port): vcounter advances one line
	# per (quarterLineDuration+1) video-clocks, converted to CPU Thread-clocks.
	# V_CURRENT = vcounter<<1 | field, synced to the live cycle on every read.
	mutable vi_hlpf      : u32 [ 525 ]       # VI_V_TOTAL halfLinesPerField (NTSC default)
	mutable vi_qld       : u32 [ 3092 ]      # VI_H_TOTAL quarterLineDuration (NTSC default)
	mutable vi_leappat   : u32 [ 0 ]
	mutable vi_hleap0    : u32 [ 3093 ]
	mutable vi_hleap1    : u32 [ 3093 ]
	mutable vi_vcounter  : u32
	mutable vi_field     : u32
	mutable vi_leapcnt   : u32
	mutable vi_line_clk  : i64               # sys_clk at which the next line ticks
	mutable vi_clkfrac   : i64               # VI->CPU clock remainder (ares clockFraction)
	mutable vi_refreshed : bool
	mutable sys_clk      : i64               # free-running CPU Thread-clocks (2/instr), never reset
	# AI: 2-deep DMA fifo, drained one buffer per video frame into ALSA
	mutable ai_dram      : u32
	mutable ai_len       : u32
	mutable ai_ctrl      : u32
	mutable ai_dacrate   : u32
	mutable ai_fifo_dram : new u32 [ 2 ]
	mutable ai_fifo_len  : new u32 [ 2 ]
	mutable ai_fifo_n    : i32            # dmaCount: CPU-facing DMA queue depth
	mutable ai_period    : i64 [ 4251 ]   # sys_clk per sample (ares default 187500000/44100)
	mutable ai_clk       : i64            # free-running sample clock (ares ai.clock)
	mutable ai_out_dram  : new u32 [ 16 ] # decoupled ALSA playback ring: addr
	mutable ai_out_len   : new u32 [ 16 ] # decoupled ALSA playback ring: len
	mutable ai_out_n     : i32            # ALSA ring depth
	mutable audio        : n64_audio_out
	mutable audio_fail   : bool
	# audio HLE: ABI1 alist state (ref: mupen64plus-rsp-hle alist_audio.c).
	# abuf mirrors the ucode sample workspace (big-endian words); command
	# dmem offsets are relative to DMEM_BASE 0x5C0.
	mutable abuf         : new u8  [ 0x1000 ]
	mutable aseg         : new u32 [ 16 ]
	mutable a_in         : u32
	mutable a_out        : u32
	mutable a_count      : u32
	mutable a_dryr       : u32
	mutable a_wetl       : u32
	mutable a_wetr       : u32
	mutable a_dry        : i32
	mutable a_wet        : i32
	mutable a_vol0       : i32
	mutable a_vol1       : i32
	mutable a_tgt0       : i32
	mutable a_tgt1       : i32
	mutable a_rate0      : i64
	mutable a_rate1      : i64
	mutable a_loop       : u32
	mutable a_table      : new i32 [ 128 ]
	mutable ad_last      : new i32 [ 16 ]
	mutable ad_frame     : new i32 [ 16 ]
	# RSP resampler 4-tap kernel, 64 phases (mupen64plus-rsp-hle audio.c)
	intern  res_lut      : new i16 [256] [
