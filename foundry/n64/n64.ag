export 0.8.8

# N64 emulator — foundation pass: VR4300 CPU (integer + COP0 + FPU), memory
# map, HLE CIC-6102 boot, PI/SI DMA, MI/VI interrupts, 60Hz frame loop.
# Target: Super Mario 64. RSP (Fast3D HLE) + RDP shader pipeline follow.
# References: foundry/n64/reference/ (n64brew wiki, SGI docs, ares core).

import vec
import img
import trinity
import <alsa/asoundlib.h>
	-lasound
import <stdio.h>
import <stdlib.h>
import <string.h>
import <math.h>
import <fenv.h>
import <pthread.h>
import <unistd.h>

# in-loop ares oracle: the vendored ares N64 core, no-LTO, merged into one
# clang-linkable archive (see reference/ares/build-cosim.sh). arescore_* is the
# extern-C ABI in reference/ares/ares_cosim.cpp.
import <reference/ares/ares_cosim.h>
	-l/src/silver/foundry/n64/reference/ares/libares_cosim.a
	-ldl

class cpu_vr4300
	r         : new i64 [ 32 ]      # GPRs (64-bit)
	fpr       : new u64 [ 32 ]      # FPU raw bits
	hi        : i64
	lo        : i64
	pc        : u32
	npc       : u32
	fcr31     : u32
	# COP0
	c_index   : u32
	c_count   : u32
	c_compare : u32
	c_status  : u32
	c_cause   : u32
	c_epc     : u32
	c_config  : u32
	c_wired   : u32
	c_entrylo0 : u32
	c_entrylo1 : u32
	c_entryhi  : u32
	c_pagemask : u32
	tlb_hi    : new u32 [ 32 ]      # raw EntryHi per TLB entry
	tlb_pm    : new u32 [ 32 ]
	tlb_lo0   : new u32 [ 32 ]
	tlb_lo1   : new u32 [ 32 ]
	tlb_used  : bool                # any tlbwi yet (fast-path gate)
	ll_bit    : bool

class n64_audio_out
	pcm_handle     : ref snd_pcm_t
	buffer         : ref i16
	buffer_size    : sz
	sample_rate    : i32
	channels       : i32

	func open [ rate: i32 ] -> bool
		sample_rate = rate
		channels    = 2
		buffer_size = 2048
		buffer      = calloc[ 1, buffer_size * channels * 2 ]
		pb  : i32 [ SND_PCM_STREAM_PLAYBACK ]
		err : i32 [ snd_pcm_open[ ref pcm_handle, 'pulse', pb, 0 ] ]
		if [ err < 0 ] return false
		psz    : snd_pcm_hw_params_sizeof[]
		params : ref snd_pcm_hw_params_t [ calloc[ 1, psz ] ]
		snd_pcm_hw_params_any[ pcm_handle, params ]
		rw  : i32 [ SND_PCM_ACCESS_RW_INTERLEAVED ]
		fmt : i32 [ SND_PCM_FORMAT_S16_LE ]
		snd_pcm_hw_params_set_access  [ pcm_handle, params, rw ]
		snd_pcm_hw_params_set_format  [ pcm_handle, params, fmt ]
		snd_pcm_hw_params_set_channels[ pcm_handle, params, channels ]
		snd_pcm_hw_params_set_rate    [ pcm_handle, params, sample_rate, 0 ]
		bufsz : sz [ 3072 ]
		persz : sz [ 512 ]
		snd_pcm_hw_params_set_buffer_size_near[ pcm_handle, params, ref bufsz ]
		snd_pcm_hw_params_set_period_size_near[ pcm_handle, params, ref persz, null ]
		ok : bool [ snd_pcm_hw_params[ pcm_handle, params ] >= 0 ]
		if [ ok ]
			perr : i32 [ snd_pcm_prepare[ pcm_handle ] ]
			if [ perr < 0 ]
				puts 'n64 audio: prepare failed {snd_strerror[ perr ]}'
				ok = false
		return ok

	func write [ frames: i32 ] -> none
		if [ ! pcm_handle ] return
		wr : i64 [ snd_pcm_writei[ pcm_handle, buffer, frames ] ]
		if [ wr < 0 ]
			snd_pcm_recover[ pcm_handle, wr, 0 ]
			snd_pcm_writei[ pcm_handle, buffer, frames ]

	func close []
		if [ pcm_handle ]
			snd_pcm_close[ pcm_handle ]
			pcm_handle = null


enum N64Surface
	atlas : 0
	state : 1

# N64 ubershader: raw Fast3D vertices in, transform + vertex lighting in the
# vertex stage (matrix/light/material palettes live in the `state` rgbaf
# texture, row 0 = matrices, row 1 = light sets, row 2 = materials), combiner
# + wrapped atlas sampling in the fragment stage.
ModelViewProject N64GX
	attrib atlas : LayoutBinding [ type:typeid[ N64Surface ], id:N64Surface.atlas, count:1, format: typeid[ rgba8 ] ]
	attrib state : LayoutBinding [ type:typeid[ N64Surface ], id:N64Surface.state, count:1, format: typeid[ rgbaf ] ]

	attrib a_pos : VertexInput [ type:typeid[ vec3f ] ]
	attrib a_col : VertexInput [ type:typeid[ vec4f ] ]
	attrib a_uv  : VertexInput [ type:typeid[ vec2f ] ]
	attrib a_aux : VertexInput [ type:typeid[ vec4f ] ]

	attrib v_col  : VertexOutput [ type:typeid[ vec4f ] ]
	attrib v_uv   : VertexOutput [ type:typeid[ vec2f ] ]
	attrib v_aux  : VertexOutput [ type:typeid[ vec4f ] ]
	attrib v_prim : VertexOutput [ type:typeid[ vec4f ] ]
	attrib v_env  : VertexOutput [ type:typeid[ vec4f ] ]
	attrib v_rect : VertexOutput [ type:typeid[ vec4f ] ]
	attrib v_wrap : VertexOutput [ type:typeid[ vec4f ] ]

	attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

	func init [ ]
		model = mat4f.identity[]
		view  = mat4f.identity[]
		proj  = mat4f.identity[]

	func vertex [] -> GLSL none {
		int mi = int(a_aux.x + 0.5) * 4;
		vec4 r0 = texelFetch(state, ivec2(mi + 0, 0), 0);
		vec4 r1 = texelFetch(state, ivec2(mi + 1, 0), 0);
		vec4 r2 = texelFetch(state, ivec2(mi + 2, 0), 0);
		vec4 r3 = texelFetch(state, ivec2(mi + 3, 0), 0);
		mat4 M  = mat4(r0, r1, r2, r3);          // rows as columns => M = rowmajor^T, so M*v == v*rows
		vec4 clip = M * vec4(a_pos, 1.0);
		int flags = int(a_aux.y + 0.5);
		int ms = int(a_aux.w + 0.5) * 4;
		v_rect = texelFetch(state, ivec2(ms + 0, 2), 0);
		v_wrap = texelFetch(state, ivec2(ms + 1, 2), 0);
		v_prim = texelFetch(state, ivec2(ms + 2, 2), 0);
		v_env  = texelFetch(state, ivec2(ms + 3, 2), 0);
		vec4 col = a_col;
		vec2 uv  = a_uv;
		if ((flags & 1) != 0) {                  // lit: a_col.xyz = normal
			vec3 n  = a_col.xyz;
			int  ls = int(a_aux.z + 0.5) * 8;
			vec4 amb = texelFetch(state, ivec2(ls, 1), 0);
			vec3 c   = amb.rgb;
			int  nl  = int(amb.a + 0.5);
			for (int i = 0; i < 3; i++) {
				if (i >= nl) break;
				vec3 lc = texelFetch(state, ivec2(ls + 1 + i * 2, 1), 0).rgb;
				vec3 ld = texelFetch(state, ivec2(ls + 2 + i * 2, 1), 0).rgb;
				float d = max(dot(normalize(n), normalize(ld)), 0.0);   // N64 light dirs (e.g. 0x28,0x28,0x28) are not unit — normalize
				c += lc * d;
			}
			col = vec4(min(c, vec3(1.0)), a_col.w);
			if ((flags & 2) != 0)                // texgen: uv from normal
				uv = vec2(n.x * 0.5 + 0.5, 0.5 - n.y * 0.5) * v_rect.zw;
		}
		v_col = col;
		v_uv  = uv;
		float vtot = texelFetch(state, ivec2(2047, 0), 0).r;
		float vsplit = texelFetch(state, ivec2(2046, 0), 0).r;
		float vidx = float(gl_VertexIndex);
		float vord = (vidx < vsplit) ? -1.0 : (vidx / max(vtot, 1.0));   // -1 = backdrop (before first z-enabled 3D), else draw-order
		v_aux = vec4(vord, a_aux.y, a_aux.z, a_aux.w);   // x repurposed: z-disabled depth key
		gl_Position = vec4(clip.x, clip.y, (clip.z + clip.w) * 0.5, clip.w);
	}

	func wrapc [ t: float, msk: float, cm: float, lim: float ] -> GLSL float {
		int icm = int(cm + 0.5);
		float clim = float(icm >> 2);          // clamp at TILESIZE (packed), not mask
		if (clim < 0.5) clim = lim;
		if ((icm & 2) != 0 || msk < 0.5) t = clamp(t, 0.0, clim - 1.0);
		if (msk > 0.5) {
			if ((icm & 1) != 0) {
				float m2 = msk * 2.0;
				t = mod(t, m2);
				if (t >= msk) t = m2 - 1.0 - t;
			} else {
				t = mod(t, msk);
			}
		}
		return t;
	}

	func fragment [] -> GLSL none {
		int flags = int(v_aux.y + 0.5);
		if ((flags & 1024) != 0 && gl_FrontFacing) discard;
		if ((flags & 2048) != 0 && !gl_FrontFacing) discard;
		vec4 col = v_col;
		if ((flags & 4) != 0) {
			float tsx = wrapc(v_uv.x, v_wrap.x, v_wrap.z, v_rect.z);
			float tsy = wrapc(v_uv.y, v_wrap.y, v_wrap.w, v_rect.w);
			vec4 tex = texelFetch(atlas, ivec2(v_rect.xy + vec2(tsx, tsy)), 0);
			int cc = (flags >> 4) & 7;
			if (cc == 1)      col.rgb = mix(col.rgb, v_prim.rgb, tex.rgb);
			else if (cc == 2) col.rgb = min(col.rgb + tex.rgb, vec3(1.0));
			else if (cc == 3) col = tex;
			else { col.rgb *= tex.rgb; col.a *= tex.a; }
			if ((flags & 8) != 0) col.rgb *= v_prim.rgb;
			if ((flags & 128) != 0 && col.a < 0.5) discard;
		} else {
			if ((flags & 128) != 0 && col.a < 0.02) discard;
		}
		if ((flags & 512) != 0) col.a = max(col.r, max(col.g, col.b));
		else if ((flags & 256) == 0) col.a = 1.0;
		if ((flags & 8192) != 0) gl_FragDepth = 0.9999;                                // clear/fill: far background
		else if ((flags & 4096) != 0) {                                                // z-disabled:
			if (v_aux.x < 0.0) gl_FragDepth = 0.9999;                                  //   backdrop (before first 3D): far, behind everything
			else gl_FragDepth = clamp(1.0 - v_aux.x, 0.0001, 0.9999);                  //   overlay (after 3D): near, painter order
		}
		else gl_FragDepth = gl_FragCoord.z;
		fragColor = col;
	}


class ares
	func load [ rom: cstr ] -> i32
		return arescore_load[ rom ]
	func step [] -> none
		arescore_step[]
	func snapshot [ s: ref ares_cpu_state ] -> none
		arescore_state[ s ]
	func rd8 [ addr: u32 ] -> u8
		return arescore_rdram8[ addr ]
	func rpc [] -> u32
		return arescore_pc[]
	func reg [ i: i32 ] -> u64
		return arescore_reg[ i ]
	func rhi [] -> u64
		return arescore_hi[]
	func rlo [] -> u64
		return arescore_lo[]
	func si_status [] -> u32
		return arescore_si_status[]
	func amiintr [] -> u32
		return arescore_mi_intr[]
	func adctag [ idx: i32 ] -> u32
		return arescore_dcache_tag[ idx ]
	func aspstat [] -> u32
		return arescore_sp_status[]
	func acount [] -> u64
		return arescore_count[]
	func acause [] -> u64
		return arescore_cause[]
	func astatus [] -> u64
		return arescore_status[]
	func aepc [] -> u64
		return arescore_epc[]
	func avcount [] -> u32
		return arescore_vi_counter[]
	func avintr [] -> u32
		return arescore_vi_intr[]
	func avclock [] -> i64
		return arescore_vi_clock[]
	func avclockfrac [] -> u32
		return arescore_vi_clockfrac[]
	func acpuclk [] -> i64
		return i64[ arescore_cpuclock[] ]
	func aselftest [ n: i32 ] -> u64
		return arescore_selftest[ n ]
	func save_ckpt [ fn: cstr ] -> i32
		return arescore_save_file[ fn ]
	func load_ckpt [ fn: cstr ] -> i32
		return arescore_load_file[ fn ]

element n64 : trinity
	public  width        : i32    [ 960 ]
	public  height       : i32    [ 720 ]
	public  title        : string [ 'n64' ]
	public  background   : string [ 'Background' ]
	public  rom          : path
	public  volume       : f32 [ 0.1 ]
	mutable cpu          : cpu_vr4300
	mutable oracle       : ares          # in-loop ares reference (co-sim)
	mutable cosim        : bool [ false ] # lockstep against ares, halt on divergence
	mutable cosim_seq    : i64
	mutable cosim_ppc    : u32            # pc of the last instruction we executed (culprit on diverge)
	mutable cosim_pop    : u32            # opcode of that instruction
	mutable cosim_pbase  : u32            # base register value before exec (loads clobber rt==rs)
	mutable cosim_ff     : i64            # fast-forward budget: run ours alone this many steps on resume
	mutable cosim_next   : i64            # next seq at which to write the validated checkpoint
	mutable cosim_iv     : i64 [ 1 ]      # checkpoint EVERY validated instruction (frontier); N64_COSIM_IV overrides
	mutable c_cmp_prev   : u32            # Count at last step_cycle; timer fires when Compare is crossed
	mutable c_sysbase    : u32            # Count at last step_cycle; sys_clk advances 2*(count delta)
	mutable c_istart     : u32            # Count at instruction start (MTC0 Count preserves accrued cost)
	mutable cosim_pre_ours : u32          # our count before the pending instruction
	mutable cosim_pre_ares : i64          # ares count before the pending instruction
	mutable cosim_cnt_rep  : i32          # count-mismatch reports emitted (cap the spam)
	mutable dbg_clkdelta   : i64 [ 0x7FFFFFFFFFFFFFFF ]  # last sys_clk - ares cpuclock
	mutable dbg_psys       : i64          # prev sys_clk for per-step cost
	mutable dbg_pares      : i64          # prev ares cpuclock for per-step cost
	mutable dbg_dch        : i64          # dcache hits
	mutable dbg_dcm        : i64          # dcache misses
	mutable dbg_icm        : i64          # icache misses
	mutable dbg_rcc        : i64          # io_rcost nonzero charges
	mutable cosim_cdef     : i64          # running net count deficit (ares - ours)
	mutable dbg_dch2       : u32          # prev our dc_tag[194] (dcache co-sim probe)
	mutable dbg_dcm2       : u32          # prev ares dc_tag[194] (dcache co-sim probe)
	mutable rdram        : new u8 [ 0x800000 ]
	mutable dmem         : new u8 [ 0x1000 ]
	mutable imem         : new u8 [ 0x1000 ]
	mutable pif_ram      : new u8 [ 64 ]
	mutable pif_rom      : new u8 [ 1984 ] [
