	# PI
	mutable pi_dram      : u32
	mutable pi_cart      : u32
	mutable pi_status    : u32
	mutable pi_dma_p     : bool              # a PI DMA is in flight (dmaBusy); completion deferred
	mutable pi_dma_at    : u32               # cpu.c_count at which PI DMA completes + raises interrupt
	mutable pi_d1_lat    : u32               # PI_BSD_DOM1 latency/pulseWidth/pageSize/release
	mutable pi_d1_pwd    : u32
	mutable pi_d1_pgs    : u32
	mutable pi_d1_rls    : u32
	mutable pi_d2_lat    : u32               # PI_BSD_DOM2
	mutable pi_d2_pwd    : u32
	mutable pi_d2_pgs    : u32
	mutable pi_d2_rls    : u32
	# SI
	mutable si_dram      : u32
	mutable si_status    : u32
	mutable si_dma_p     : bool              # an SI DMA is in flight; its completion interrupt is deferred
	mutable si_dma_at    : u32               # cpu.c_count at which the deferred SI interrupt fires
	mutable si_buslatch  : u32               # last SI bus-write word (returned by a read that force-finishes)
	mutable si_lat       : u32 [ 4000 ]      # SI DMA latency in c_count units (N64_SIDELAY overrides)
	# SP (RSP stubs until the RSP pass)
	mutable sp_status    : u32 [ 1 ]        # halted
	mutable sp_dram      : u32
	mutable sp_mem       : u32
	mutable sp_pc        : u32
	mutable sp_semaphore : u32
	# DPC
	mutable dpc_status   : u32
	# input
	mutable pad_st       : u32              # A B Z Start DU DD DL DR ... C buttons L R
	mutable stick_x      : i32
	mutable stick_y      : i32
	# frame/thread
	mutable frames       : u32
	mutable trace        : bool
	mutable booted       : bool
	mutable emu_started  : bool
	mutable emu_stop     : bool
	mutable emu_running  : bool
	mutable paused       : bool
	mutable context_req  : bool
	mutable context_out  : string
	mutable context_seq  : i32
	mutable pub_lock     : mutex
	mutable pub_framebuf : new u32 [ 1280 * 960 ]
	mutable pub_w        : i32 [ 320 ]
	mutable pub_h        : i32 [ 240 ]
	mutable pub_valid    : bool
	mutable screen_tex   : Texture
	mutable tex_w        : i32
	# ---- gfx HLE: Fast3D state ----
	mutable gx_seg       : new u32 [ 16 ]
	mutable gx_mats      : new f32 [ 256 ]   # 16 mtx slots: 0=proj 1..11=mv stack 12=tmpA 13=tmpB 14=mvp
	mutable gx_mvi       : i32
	mutable gx_mvp_ok    : bool
	mutable gx_vt        : new f32 [ 160 ]   # 16 slots x 10: cx cy cz cw u v r g b a
	mutable gx_clip      : new f32 [ 80 ]    # near-clip scratch (up to 8 verts)
	mutable gx_scr       : new f32 [ 80 ]    # screen-space: sx sy sz invw u_ow v_ow r g b a
	# PN-triangle smoothing (option): tessellate lit tris with curved corners.
	public  smooth       : i32 [ 6 ]         # tess level (0=off, 2/3 typical)
	mutable gx_smooth_cos: f32 [ 0.5 ]       # hard-edge gate: min normal dot to smooth (cos 60deg)
	mutable pn_P         : new f32 [ 9 ]     # 3 corner positions (obj)
	mutable pn_N         : new f32 [ 9 ]     # 3 corner normals (normalized)
	mutable pn_cp        : new f32 [ 30 ]    # 10 Bezier control points (b300..b111) xyz
	mutable pn_at        : new f32 [ 15 ]    # 3 corners x (u v alpha vmtx vls)
	mutable gx_geom      : u32
	mutable gx_texon     : bool
	mutable gx_texs      : f32
	mutable gx_text      : f32
	mutable gx_tile      : i32
	mutable gx_prim      : u32
	mutable gx_env       : u32
	mutable gx_fill      : u32
	mutable gx_cimg      : u32
	mutable gx_zimg      : u32
	mutable gx_ciw       : i32 [ 320 ]
	mutable rtt_addr     : new u32 [ 16 ]         # recent offscreen color-image targets
	mutable rtt_w        : new i32 [ 16 ]
	mutable rtt_h        : new i32 [ 16 ]
	mutable rtt_n        : i32
	mutable gx_timg      : u32
	mutable gx_tfmt      : u32
	mutable gx_tsiz      : u32
	mutable gx_tw        : i32
	mutable tmem         : new u8 [ 4096 ]
	mutable gx_tlut      : new u32 [ 256 ]
	mutable tl_fmt       : new u32 [ 8 ]
	mutable tl_siz       : new u32 [ 8 ]
	mutable tl_line      : new u32 [ 8 ]
	mutable tl_tmem      : new u32 [ 8 ]
	mutable tl_block     : new u32 [ 8 ]
	mutable yw_done      : bool
	mutable spk_done     : bool
	mutable src_done     : bool
	mutable dbg_seq      : i32
	mutable dumped_gt    : i32
	mutable fparm        : bool
	mutable wrhash       : u64
	mutable wrseq        : i32
	mutable dn_seq       : i32
	mutable fp_hash      : u64
	mutable fp_seq       : i32
	mutable dc_tag       : new u32 [ 512 ]    # VR4300 D-cache timing model: 8KB direct-mapped, 16B lines. per line: tag|0xFFF-masked, bit0=valid, bit1=dirty
	mutable ic_tag       : new u32 [ 512 ]    # I-cache timing model: 16KB, 32B lines. tag = paddr&~0xFFF, bit0=valid
	mutable dc_on        : bool               # D-cache timing enable (isolation switch)
	mutable velargs      : new u32 [ 8 ]
	mutable tl_pal       : new u32 [ 8 ]
	mutable tl_cms       : new u32 [ 8 ]
	mutable tl_cmt       : new u32 [ 8 ]
	mutable tl_masks     : new u32 [ 8 ]
	mutable tl_maskt     : new u32 [ 8 ]
	mutable tl_uls       : new u32 [ 8 ]
	mutable tl_ult       : new u32 [ 8 ]
	mutable tl_lrs       : new u32 [ 8 ]
	mutable tl_lrt       : new u32 [ 8 ]
	mutable zbuf         : new f32 [ 1280 * 960 ]
	mutable ss_buf       : new u32 [ 1280 * 960 ]
	mutable gx_ss        : i32 [ 1 ]             # supersample factor (N64_SS=1/2/4; CPU raster, 4x = 16x cost)
	mutable ss_used      : bool
	mutable gx_lights    : new f32 [ 48 ]    # 8 x: r g b dx dy dz
	mutable gx_nl        : i32
	mutable gx_oth_h     : u32
	mutable gx_oth_l     : u32
	mutable gx_sx0       : i32
	mutable gx_sy0       : i32
	mutable gx_sx1       : i32 [ 320 ]
	mutable gx_sy1       : i32 [ 240 ]
	mutable gx_half1     : u32
	mutable gx_vp        : new f32 [ 6 ]     # scale x y z, trans x y z
	mutable gx_dls       : new u32 [ 20 ]
	mutable gx_dsp       : i32
	mutable gx_unk       : new u32 [ 256 ]
	# ---- GPU renderer (Vulkan; N64_GPU=0 falls back to CPU raster) ----
	mutable gpu_on       : bool [ true ]
	mutable gx_vraw      : new f32 [ 192 ]       # per-slot raw: x y z u v r g b a lit mtx ls (VTX-time state)
	mutable gxv          : new f32 [ 1703936 ]   # 131072 verts x 13 floats
	mutable gxv_n        : i32
	mutable st_tex       : new f32 [ 24576 ]     # 2048x3 rgba32f staging
	mutable st_mtx_n     : i32
	mutable st_ls_n      : i32
	mutable st_mat_n     : i32
	mutable gx_mslot     : i32 [ -1 ]            # cached slots (-1 = dirty)
	mutable gx_lsslot    : i32 [ -1 ]
	mutable gx_matslot   : i32 [ -1 ]
	mutable at_stage     : new u32 [ 1048576 ]   # 1024x1024 atlas staging
	mutable at_dirty     : bool
	mutable at_dbg       : i32
	mutable uv_dbg       : i32
	mutable mr_dbg       : i32
	mutable txr_dbg      : i32
	mutable at_x         : i32
	mutable at_y         : i32
	mutable at_rowh      : i32
	mutable atk_key      : new i64 [ 256 ]
	mutable atk_rect     : new i32 [ 1024 ]
	mutable atk_n        : i32
	mutable pub_gxv      : new f32 [ 1703936 ]
	mutable pub_gxv_n    : i32
	mutable pub_st       : new f32 [ 24576 ]
	mutable pub_at_dirty : bool
	mutable r_shader     : N64GX
	mutable r_atlas      : Texture
	mutable r_state      : Texture
	mutable r_render     : Render
	mutable r_pipeline   : Pipeline
	mutable r_model      : Model
	mutable r_vbo        : Gpu
	mutable gx_dbgc      : i32
	mutable gx_vsrc      : new u32 [ 16 ]
	mutable gx_ti0       : i32
	mutable gx_ti1       : i32
	mutable gx_ti2       : i32
	mutable gx_dbgl      : i32
	mutable gx_cc_tex    : bool [ true ]
	mutable gx_cc_shade  : bool [ true ]
	mutable gx_cc_add    : bool
	mutable gx_cc_prim   : bool
	mutable gx_cc_lerp   : bool
	mutable gx_bl_add    : bool
	mutable gx_bl_xlu    : bool
	mutable gx_ccw1      : u32
	mutable gx_ccw2      : u32
	# runaway-PC diagnostic: ring of the last 32 (pc, op) pairs; one-shot
	# dump the first time the PC maps outside RDRAM/DMEM/IMEM/ROM
	mutable dbg_ring     : new u32 [ 64 ]
	mutable dbg_ri       : i32
	mutable dbg_esc      : i32
	mutable dbg_jring    : new u32 [ 64 ]
	mutable dbg_ji       : i32
	mutable dbg_z        : i32
	mutable dbg_ic       : i32
	mutable dbg_wv       : i32
	mutable dbg_on       : bool             # N64_DBG: per-step runaway diagnostics
	mutable hash_on      : bool             # N64_HASH: per-instruction state hash to stderr
	mutable hash_seq     : u64
	mutable hold_f       : i32              # N64_HOLD: pause emu at this frame (debug capture)
	mutable gx_pc        : u32              # current display-list command address (source trace)
	mutable trc_n        : i32              # source-trace line budget
	mutable gx_zsplit    : i32              # vertex index of first z-enabled draw this frame (z-disabled before = backdrop)
	mutable gx_zset      : bool             # whether gx_zsplit has been captured this frame
	mutable pub_zsplit   : i32              # published gx_zsplit for the paint thread

	func init []
		animated  = true
		focusable = true
		if [ volume == 0.0 ] volume = 0.1
		if [ getenv[ 'N64_DBG' ] ] dbg_on = true
		if [ getenv[ 'N64_HASH' ] ] hash_on = true
		if [ getenv[ 'N64_LLE' ] ] lle = true
		sde : symbol [ getenv[ 'N64_SIDELAY' ] ]
		if [ sde ] si_lat = u32[ atoi[ sde ] ]
		gpe : symbol [ getenv[ 'N64_GPU' ] ]
		if [ gpe ]
			if [ atoi[ gpe ] == 0 ] gpu_on = false
		he9 : symbol [ getenv[ 'N64_HOLD' ] ]
		if [ he9 ] hold_f = atoi[ he9 ]
		sse : symbol [ getenv[ 'N64_SS' ] ]
		if [ sse ]
			sv9 : i32 [ atoi[ sse ] ]
			if [ sv9 >= 3 ] gx_ss = 4
			el [ sv9 == 2 ] gx_ss = 2
			el gx_ss = 1
		el gx_ss = 1
		re9 : symbol [ getenv[ 'N64_ROM' ] ]
		if [ re9 ] rom = path[ re9 ]
		if [ ! rom ] rom = path[ '/src/silver/mario64.z64' ]
		ive : symbol [ getenv[ 'N64_COSIM_IV' ] ]
		if [ ive ] cosim_iv = i64[ atoi[ ive ] ]
		if [ getenv[ 'N64_COSIM' ] ] cosim = true
		if [ getenv[ 'N64_COSIM_RESTART' ] ] cosim = true
		if [ getenv[ 'N64_COSIM_OFF' ] ] cosim = false

	# ---------------- ROM + HLE boot ----------------
	func load_rom [] -> bool
		f : ref FILE [ fopen[ rom.chars, 'rb' ] ]
		if [ !f ]
			puts 'n64: cannot open rom {rom}'
			return false
		fseek[ f, 0, SEEK_END ]
		rom_size = ftell[ f ]
		rewind[ f ]
		buf : new u8 [ rom_size ]
		fread[ buf, 1, rom_size, f ]
		fclose[ f ]
		rom_data = buf
		hold[ (buf to Au) ]
		# byte order from magic: z64 80371240 (native BE) / v64 37804012
		# (16-bit swapped) / n64 40123780 (LE words)
		m0 : u32 [ u32[ buf[0] ] ]
		if [ m0 == 0x37 ]
			for [ i: i64 0, i < rom_size, i += 2 ]
				t : u8 [ buf[i] ]
				buf[i] = buf[i + 1]
				buf[i + 1] = t
		el [ m0 == 0x40 ]
			for [ i: i64 0, i < rom_size, i += 4 ]
				t0 : u8 [ buf[i] ]
				t1 : u8 [ buf[i + 1] ]
				buf[i]     = buf[i + 3]
				buf[i + 1] = buf[i + 2]
				buf[i + 2] = t1
				buf[i + 3] = t0
		return true

	func rom32 [ off: i64 ] -> u32
		if [ off + 3 >= rom_size ] return 0
		return (u32[rom_data[off]] << 24) | (u32[rom_data[off+1]] << 16) | (u32[rom_data[off+2]] << 8) | u32[rom_data[off+3]]

	# HLE the PIF + IPL3 (CIC-6102): game code to RDRAM, registers to the
	# ---- functional PIF/CIC boot handshake (CIC-6102) ----
	# ares runs the PIF main state machine (hle.cpp) interleaved with the CPU while
	# IPL2 drives it through the command byte at PIF RAM 0x3F. We reproduce the same
	# RAM-visible results functionally: seed the CIC-6102 secrets at Init, then advance
	# the state machine each time IPL2 writes the command byte. Checksum verification is
	# skipped (ares' inaccurate path), which does not affect post-boot RDRAM state.
	func pif_init_secrets []
		# memSwapSecrets result for CIC-6102 cold boot: osInfo[0]=0xB4 (ver bit + hi
		# nibble 0xB), osInfo[1]=osInfo[2]=0x3F (the 6102 seed byte, hi=lo=0x3F)
		pif_ram[ 0x25 ] = 0xB4
		pif_ram[ 0x26 ] = 0x3F
		pif_ram[ 0x27 ] = 0x3F
		pif_ram[ 0x3F ] = 0x00
		pif_state = 1                                    # WaitLockout

	func pif_tick []
		cmd : u32 [ u32[ pif_ram[ 0x3F ] ] ]
		if [ pif_state == 1 && (cmd & 0x10) ]
			pif_state = 2                                # -> WaitGetChecksum
			return
		if [ pif_state == 2 && (cmd & 0x20) ]
			pif_ram[ 0x25 ] = 0                          # memSwapSecrets: hide seeds
			pif_ram[ 0x26 ] = 0
			pif_ram[ 0x27 ] = 0
			pif_ram[ 0x3F ] = u8[ cmd | 0x80 ]           # ack bit for IPL2
			pif_state = 3                                # -> WaitCheckChecksum
			return
		if [ pif_state == 3 && (cmd & 0x40) ]
			pif_state = 4                                # -> WaitTerminateBoot (checksum skipped)
			return
		if [ pif_state == 4 && (cmd & 0x08) ]
			pif_ram[ 0x3F ] = 0x00
			pif_state = 5                                # -> Run
			return

	# documented post-IPL state, PC = header entry point
	func boot []
		cpu = cpu_vr4300 []
		entry : u32 [ rom32[ 8 ] ]
		if [ cosim ] lle = true                          # co-sim needs the same LLE boot ares does
		if [ lle ]
			# real boot: CPU runs IPL1/IPL2 from the embedded PIF ROM at 0xBFC00000,
			# which reads the CIC secrets we seed into PIF RAM, copies IPL3 from the
			# cart, and IPL3 copies the game into RDRAM. No faked globals or register
			# state — the ROM sets Status/config/etc. itself.
			pif_init_secrets []
			cpu.r[ 29 ] = i64[ i32[ 0xA4001FF0 ] ]        # sp (only reset reg ares sets)
			cpu.pc  = 0xBFC00000
			cpu.npc = 0xBFC00004
			booted  = true
			puts 'n64: LLE boot from 0xBFC00000 (real PIF ROM IPL), entry={entry}'
			if [ cosim ]
				oracle = ares []
				lr : i32 [ oracle.load[ rom.chars ] ]
				if [ getenv[ 'N64_ARES_SELFTEST' ] && lr == 0 ]
					h1 : u64 [ oracle.aselftest[ 500000 ] ]
					h2 : u64 [ oracle.aselftest[ 500000 ] ]
					h3 : u64 [ oracle.aselftest[ 500000 ] ]
					printf[ "n64 ARES SELFTEST h1=%016llx h2=%016llx h3=%016llx det=%d\n", h1, h2, h3, i32[ h1 == h2 && h2 == h3 ] ]
					fflush[ null ]
					exit[ 9 ]
				if [ lr != 0 ]
					puts 'n64 cosim: ares load failed ({lr}) — lockstep off'
					cosim = false
				el
					cosim_next = cosim_iv
					sseq : i64 [ ckpt_read_seq[] ]
					if [ sseq > 0 && ! reset_requested[] ]
						lr2 : i32 [ oracle.load_ckpt[ '/src/silver/foundry/n64/cosim.ares' ] ]
						lo2 : i32 [ load_ours[ '/src/silver/foundry/n64/cosim.ours' ] ]
						if [ lr2 == 0 && lo2 == 0 ]
							cosim_seq  = sseq                # both sides loaded AT the frontier — no replay
							cosim_next = sseq + cosim_iv
							puts 'n64 cosim: RESUME at validated seq={sseq} — ours+ares loaded directly, no replay'
							printf[ "n64 cosim: at resume count ours=%u ares=%llu ; VI vcount ours=%u ares=%u\n", cpu.c_count, oracle.acount[], vi_vcounter, oracle.avcount[] ]
						el
							puts 'n64 cosim: checkpoint load failed (ares={lr2} ours={lo2}) — fresh lockstep'
					el
						puts 'n64 cosim: fresh lockstep from 0xBFC00000 (--reset or no checkpoint)'
			return
		# IPL3 copies 1MB of game code from ROM 0x1000 to the entry address
		sz : i64 [ 0x100000 ]
		if [ rom_size - 0x1000 < sz ] sz = rom_size - 0x1000
		dst : i64 [ i64[ entry & 0x1FFFFFFF ] ]
		for [ i: i64 0, i < sz, i += 1 ]
			rdram[ dst + i ] = rom_data[ 0x1000 + i ]
		# IPL boot globals: osTvType/osRomBase/osMemSize (osRomBase feeds
		# osPiStartDma's cart address — without it PI DMA sources from 0)
		wr_phys32[ 0x300, 1 ]                # osTvType: NTSC
		wr_phys32[ 0x308, 0xB0000000 ]       # osRomBase: cart domain 1
		wr_phys32[ 0x318, 0x800000 ]         # osMemSize for 6102
		cpu.r[ 11 ] = i64[ i32[ 0xFFFFFFFF ] ] & 0 | i64[ entry ]        # t3
		cpu.r[ 20 ] = 1                                                  # s4: tv type NTSC
		cpu.r[ 22 ] = 0x3F                                               # s6: CIC 6102 seed
		cpu.r[ 29 ] = i64[ i32[ 0xA4001FF0 ] ]                           # sp
		cpu.c_status = 0x34000000
		cpu.c_config = 0x0006E463
		cpu.pc  = entry
		cpu.npc = entry + 4
		booted  = true
		puts 'n64: booted entry={entry} rom {rom_size} bytes'

	# ---------------- physical memory ----------------
	func rd_phys8 [ pa: u32 ] -> u32
		if [ pa < 0x800000 ] return u32[ rdram[ pa ] ]
		if [ pa >= 0x04000000 && pa < 0x04001000 ] return u32[ dmem[ pa & 0xFFF ] ]
		if [ pa >= 0x04001000 && pa < 0x04002000 ] return u32[ imem[ pa & 0xFFF ] ]
		if [ pa >= 0x10000000 && pa < 0x10000000 + u32[ rom_size ] ] return u32[ rom_data[ pa - 0x10000000 ] ]
		if [ pa >= 0x1FC00000 && pa < 0x1FC007C0 ] return u32[ pif_rom[ pa - 0x1FC00000 ] ]
		if [ pa >= 0x1FC007C0 && pa < 0x1FC00800 ] return u32[ pif_ram[ pa - 0x1FC007C0 ] ]
		if [ pa >= 0x04300000 && pa < 0x04900000 ] return (io_read[ pa & 0xFFFFFFFC ] >> ((3 - (pa & 3)) * 8)) & 0xFF
		return 0

	func wr_phys8 [ pa: u32, v: u32 ]
		if [ pa < 0x800000 ]
			if [ dbg_on && pa >= 0x888F0 && pa < 0x88910 && dbg_wv < 40 && frames >= 300 ]
				dbg_wv += 1
				printf[ "n64 VWRITE pa=%06X v=%02X pc=%08X ra=%08X f%u\n", pa, v & 0xFF, cpu.pc, u32[ cpu.r[31] ], frames ]
			rdram[ pa ] = u8[ v ]
			return
		if [ pa >= 0x04000000 && pa < 0x04001000 ]
			dmem[ pa & 0xFFF ] = u8[ v ]
			return
		if [ pa >= 0x04001000 && pa < 0x04002000 ]
			imem[ pa & 0xFFF ] = u8[ v ]
			return
		if [ pa >= 0x1FC007C0 && pa < 0x1FC00800 ]
			pif_ram[ pa - 0x1FC007C0 ] = u8[ v ]
			if [ pif_state < 5 ] pif_tick []

	func rd_phys32 [ pa: u32 ] -> u32
		if [ pa < 0x800000 ]
			return (u32[rdram[pa]] << 24) | (u32[rdram[pa+1]] << 16) | (u32[rdram[pa+2]] << 8) | u32[rdram[pa+3]]
		if [ pa >= 0x04000000 && pa < 0x04002000 ]
			b : u32 [ pa & 0x1FFF ]
			m : ref u8 [ (b < 0x1000) ? dmem : imem ]
			o : u32 [ b & 0xFFF ]
			return (u32[m[o]] << 24) | (u32[m[o+1]] << 16) | (u32[m[o+2]] << 8) | u32[m[o+3]]
		if [ pa >= 0x10000000 && pa < 0x10000000 + u32[ rom_size ] ]
			return rom32[ i64[ pa - 0x10000000 ] ]
		if [ pa >= 0x1FC00000 && pa < 0x1FC00800 ]
			if [ si_status & 0x2 ]                                # ioBusy: a bus write is in flight
				si_status = si_status & (~u32[0x2])              # read force-finishes it (ares writeForceFinish)
				si_dma_p  = false                                # cancelled: never completes, no interrupt
				return si_buslatch                               # returns the latched bus-write word, not PIF
			if [ pa < 0x1FC007C0 ]
				o3 : u32 [ pa - 0x1FC00000 ]
				return (u32[pif_rom[o3]] << 24) | (u32[pif_rom[o3+1]] << 16) | (u32[pif_rom[o3+2]] << 8) | u32[pif_rom[o3+3]]
			o2 : u32 [ pa - 0x1FC007C0 ]
			return (u32[pif_ram[o2]] << 24) | (u32[pif_ram[o2+1]] << 16) | (u32[pif_ram[o2+2]] << 8) | u32[pif_ram[o2+3]]
		return io_read[ pa ]

	func wr_phys32 [ pa: u32, v: u32 ]
		if [ pa < 0x800000 ]

			if [ dbg_on && pa == 0x1BA05C && frames > 260 && frames < 280 && dbg_ic < 3000 ]
				printf[ "n64 INVW v=%08X pc=%08X ra=%08X f%u\n", v, cpu.pc, u32[ cpu.r[31] ], frames ]
			if [ dbg_on && pa == 0xC9478 ]
				printf[ "n64 RESTW v=%08X ra=%08X f%u invmtx:\n", v, u32[ cpu.r[31] ], frames ]
				for [ jr: i32 0, jr < 4, jr += 1 ]
					jb9 : u32 [ 0x1BA038 + u32[ jr * 16 ] ]
					printf[ "  %08X %08X %08X %08X\n", dr_r32[ jb9 ], dr_r32[ jb9 + 4 ], dr_r32[ jb9 + 8 ], dr_r32[ jb9 + 12 ] ]
				vt9 : u32 [ dr_r32[ 0x1BA030 ] ]
				printf[ "  weightnode=%08X\n", vt9 ]
			rdram[pa]   = u8[ v >> 24 ]
			rdram[pa+1] = u8[ v >> 16 ]
			rdram[pa+2] = u8[ v >> 8 ]
			rdram[pa+3] = u8[ v ]
			return
		if [ pa >= 0x04000000 && pa < 0x04002000 ]
			b : u32 [ pa & 0x1FFF ]
			m : ref u8 [ (b < 0x1000) ? dmem : imem ]
			o : u32 [ b & 0xFFF ]
			m[o]   = u8[ v >> 24 ]
			m[o+1] = u8[ v >> 16 ]
			m[o+2] = u8[ v >> 8 ]
			m[o+3] = u8[ v ]
			return
		if [ pa >= 0x1FC007C0 && pa < 0x1FC00800 ]
			if [ si_status & 0x2 ] return                    # ioBusy: prior bus write in flight, ignore (ares)
			o2 : u32 [ pa - 0x1FC007C0 ]
			pif_ram[o2]   = u8[ v >> 24 ]
			pif_ram[o2+1] = u8[ v >> 16 ]
			pif_ram[o2+2] = u8[ v >> 8 ]
			pif_ram[o2+3] = u8[ v ]
			if [ pif_state < 5 ] pif_tick []
			pif_joybus[]
			# a single-word CPU write to PIF RAM is an SI bus transaction: it
			# completes ~3225 Count cycles later and raises the SI interrupt (ares
			# SI_BUS_Write, 2150*3 Thread-clocks). IPL3 uses this during boot.
			si_buslatch = v                                  # latched word: a read force-finishes to this
			si_status = (si_status & 0x1000) | 0x09B3        # ioBusy|dmaBusy|pch=b|dmaState=9
			si_dma_p  = true
			si_dma_at = c_istart + 3225                      # ares schedules from pre-instr clock
			return
		io_write[ pa, v ]

	# ---------------- I/O registers ----------------
	func io_read [ pa: u32 ] -> u32
		rcp_poll[]                                           # DMA may complete mid-instruction (ares)
		if [ dbg_on && frames >= 224 && frames < 232 ]
			printf[ "n64 IOR %08X (pc=%08X)\n", pa, cpu.pc ]
		if [ pa == 0x04040010 ]
			if [ cosim ] return oracle.aspstat[]             # HLE RSP: status from ares
			return sp_status
		if [ pa == 0x04040018 ] return 0                    # SP DMA busy
		if [ pa == 0x0404001C ]
			s : u32 [ sp_semaphore ]
			sp_semaphore = 1
			return s
		if [ pa == 0x04080000 ] return sp_pc
		if [ pa == 0x0410000C ] return dpc_status | 0x80    # bit7 ready: HLE RDP always idle (ares reset)
		if [ pa == 0x04300008 ] return mi_intr
		if [ pa == 0x0430000C ] return mi_mask
		if [ pa == 0x04300004 ] return 0x02020102           # MI version
		if [ pa == 0x04400010 ]
			vi_sync[]
			return vi_current
		if [ pa == 0x04600010 ] return pi_status
		if [ pa == 0x04800018 ] return si_status
		if [ pa == 0x04500004 ] return ai_len
		if [ pa == 0x0450000C ]                              # AI status (ares AI_STATUS bits)
			st : u32 [ 0x01100000 ]                          # bit20 + bit24 always set
			if [ ai_fifo_n > 1 ] st = st | 0x80000001        # bit31 + bit0: fifo full
			if [ ai_fifo_n > 0 ] st = st | 0x40000000        # bit30: busy
			if [ ai_ctrl & 1 ]  st = st | 0x02000000         # bit25: dmaEnable
			return st
		if [ pa >= 0x04700000 && pa < 0x04800000 ]             # RI regs: PIF-ROM RDRAM self-test result
			ra : u32 [ (pa & 0x1F) >> 2 ]
			if [ ra == 0 ] return 0x0E                        # RI_MODE
			if [ ra == 1 ] return 0x40                        # RI_CONFIG
			if [ ra == 3 ]                                    # RI_SELECT: IPL3 RDRAM-init-skip probe
				cpu.c_count += 17641000                       # ares step(17.641M*2), count += clocks>>1
				return 0x14
			if [ ra == 4 ] return 0x00063634                  # RI_REFRESH
			return 0                                           # CURRENT_LOAD/LATENCY/RERROR/WERROR
		if [ pa >= 0x03F00000 && pa < 0x04000000 ] return 0
		return 0

	# SP DMA: length reg = { skip[31:20], count[19:12], length[11:0] };
	# sp_mem bit 12 selects IMEM, rows advance dram by length+skip
	func sp_dma [ v: u32, to_sp: bool ]
		ln : u32 [ ((v & 0xFFF) | 7) + 1 ]
		cnt : u32 [ ((v >> 12) & 0xFF) + 1 ]
		skip : u32 [ (v >> 20) & 0xFFF ]
		ma : u32 [ sp_mem & 0x1FF8 ]
		da : u32 [ sp_dram & 0xFFFFF8 ]
		for [ c: u32 0, c < cnt, c += 1 ]
			for [ i: u32 0, i < ln, i += 1 ]
				mo : u32 [ (ma + i) & 0x1FFF ]
				dd : u32 [ da + i ]
				if [ dd < 0x800000 ]
					if [ to_sp ]
						if [ mo < 0x1000 ] dmem[ mo ] = rdram[ dd ]
						el imem[ mo & 0xFFF ] = rdram[ dd ]
					el
						if [ mo < 0x1000 ] rdram[ dd ] = dmem[ mo ]
						el rdram[ dd ] = imem[ mo & 0xFFF ]
			ma += ln
			da += ln + skip

	# PI cartridge-DMA duration (ares PI::dmaDuration). returns thread-clocks
	# (cycles*3); the caller halves it into our count units. lraw = PI_*_LEN reg.
	func pi_dma_dur [ lraw: u32, pbus: u32 ] -> u32
		len : u32 [ (lraw | 1) + 1 ]
		dsel : u32 [ (pbus >> 24) & 0xFF ]
		d2 : bool [ dsel == 0x05 || (dsel >= 0x08 && dsel <= 0x0F) ]
		lat : u32 [ (d2) ? pi_d2_lat : pi_d1_lat ]
		pwd : u32 [ (d2) ? pi_d2_pwd : pi_d1_pwd ]
		pgs : u32 [ (d2) ? pi_d2_pgs : pi_d1_pgs ]
		rls : u32 [ (d2) ? pi_d2_rls : pi_d1_rls ]
		pshift : u32 [ pgs + 2 ]
		psize : u32 [ u32[ 1 ] << pshift ]
		pmask : u32 [ psize - 1 ]
		pfirst : u32 [ pbus ]
		plast : u32 [ pbus + len - 2 ]
		pfpage : u32 [ pfirst >> pshift ]
		plpage : u32 [ plast >> pshift ]
		ppages : u32 [ plpage - pfpage + 1 ]
		nbuf : u32 [ 0 ]
		pbytes : u32 [ 0 ]
		if [ pfpage == plpage ]
			if [ len == 128 ] nbuf = 1
			el pbytes = len
		el
			if [ (pfirst & pmask) == 0 ] nbuf += 1
			el pbytes += psize - (pfirst & pmask)
			if [ ((plast + 2) & pmask) == 0 ] nbuf += 1
			el pbytes += (plast & pmask) + 2
			if [ pfpage + 1 < plpage ] nbuf += (ppages - 2) * psize / 128
		cyc : u32 [ 0 ]
		cyc += (14 + lat + 1) * ppages
		cyc += (pwd + 1 + rls + 1) * len / 2
		cyc += nbuf * 28
		cyc += pbytes
		return cyc * 3

	func io_write [ pa: u32, v: u32 ]
		if [ dbg_on && frames >= 224 && frames < 232 ]
			printf[ "n64 IOW %08X = %08X (pc=%08X)\n", pa, v, cpu.pc ]
		if [ hash_on && pa >= 0x04800000 && pa < 0x04800020 ] printf[ "SIW %08X=%08X seq=%llu\n", pa, v, hash_seq ]
		if [ pa == 0x04040010 ]                              # SP_STATUS write: set/clear pairs (ares RSP::Status)
			if [ (v & 0x4) != 0 ] sp_status = sp_status & (~u32[0x2])                       # clear broke
			if [ (v & 0x8) != 0 && (v & 0x10) == 0 ] mi_intr = mi_intr & (~u32[0x1])        # clear SP int
			if [ (v & 0x10) != 0 && (v & 0x8) == 0 ] mi_intr = mi_intr | 0x1                # set SP int
			if [ (v & 0x20) != 0 && (v & 0x40) == 0 ] sp_status = sp_status & (~u32[0x20])  # clear single-step
			if [ (v & 0x40) != 0 && (v & 0x20) == 0 ] sp_status = sp_status | 0x20          # set single-step
			if [ (v & 0x80) != 0 && (v & 0x100) == 0 ] sp_status = sp_status & (~u32[0x40]) # clear intr-on-break
			if [ (v & 0x100) != 0 && (v & 0x80) == 0 ] sp_status = sp_status | 0x40         # set intr-on-break
			for [ si9: i32 0, si9 < 8, si9 += 1 ]                                           # signals 0-7 (read 7-14)
				clrb : u32 [ u32[1] << u32[ 9 + si9 * 2 ] ]
				setb : u32 [ u32[1] << u32[ 10 + si9 * 2 ] ]
				rdb  : u32 [ u32[1] << u32[ 7 + si9 ] ]
				if [ (v & clrb) != 0 && (v & setb) == 0 ] sp_status = sp_status & (~rdb)
				if [ (v & setb) != 0 && (v & clrb) == 0 ] sp_status = sp_status | rdb
			if [ (v & 0x2) != 0 && (v & 0x1) == 0 ] sp_status = sp_status | 0x1             # set halt
			if [ (v & 0x1) != 0 && (v & 0x2) == 0 && (v & 0x40) == 0 && (sp_status & 0x20) == 0 ]  # clear halt (not single-step): START -> HLE the task
				# OSTask header sits at DMEM 0xFC0; type: 1=gfx 2=audio.
				# audio runs the ABI1 alist interpreter; gfx still fake-
				# completes (halt + SIG2, SP int, + DP int) so the scheduler
				# flows until the Fast3D pass.
				tt : u32 [ (u32[dmem[0xFC0]] << 24) | (u32[dmem[0xFC1]] << 16) | (u32[dmem[0xFC2]] << 8) | u32[dmem[0xFC3]] ]
				if [ tt == 2 ] audio_task[]
				if [ tt == 1 ] gfx_task[]
				if [ !cosim ]                                    # cosim: SP_STATUS + SP/DP int come from ares
					sp_status = (sp_status & 0x7FC0) | 0x1 | 0x200   # halt + SIG2, preserve intr-on-break/signals
					mi_intr = mi_intr | 0x1
					if [ tt == 1 ] mi_intr = mi_intr | 0x20
				if [ trace && tt != 2 ] printf[ "n64 SP task type=%u f%u (fake-complete)\n", tt, frames ]
				if [ dbg_on && dbg_ic < 3000 ] printf[ "n64 task t=%u f%u\n", tt, frames ]
			mi_check[]
			return
		if [ pa == 0x0404001C ]
			sp_semaphore = 0
			return
		if [ pa == 0x04040000 ]
			sp_mem = v
			return
		if [ pa == 0x04040004 ]
			sp_dram = v
			return
		if [ pa == 0x04040008 ]                              # SP read length: RDRAM -> SP mem
			sp_dma[ v, true ]
			return
		if [ pa == 0x0404000C ]                              # SP write length: SP mem -> RDRAM
			sp_dma[ v, false ]
			return
		if [ pa == 0x04300000 ]
			mi_mode = v
			if [ v & 0x800 ] mi_intr = mi_intr & (~u32[0x20])
			mi_check[]
			return
		if [ pa == 0x0430000C ]                              # MI mask set/clear pairs
			for [ b: i32 0, b < 6, b += 1 ]
				if [ (v >> (b * 2)) & 1 ] mi_mask = mi_mask & (~(u32[1] << b))
				if [ (v >> (b * 2)) & 2 ] mi_mask = mi_mask | (u32[1] << b)
			mi_check[]
			return
		if [ pa == 0x04400000 ]
			if [ dbg_on && vi_ctrl != v ] printf[ "n64 VI_CTRL=%08X gamma=%d dither=%d divot=%d aa=%d f%u\n", v, (v >> 3) & 1, (v >> 2) & 1, (v >> 4) & 1, (v >> 8) & 3, frames ]
			vi_ctrl = v                                      # ares carries VI phase across blank; no reset
			return
		if [ pa == 0x04400004 ]
			vi_origin = v & 0xFFFFFF
			return
		if [ pa == 0x04400008 ]
			vi_width = v & 0xFFF
			return
		if [ pa == 0x0440000C ]
			vi_intr_line = v & 0x3FF
			return
		if [ pa == 0x04400010 ]                              # VI current write = clear VI int
			mi_intr = mi_intr & (~u32[0x8])
			mi_check[]
			return
		if [ pa == 0x04400018 ]                              # VI_V_TOTAL: halfLinesPerField
			vi_hlpf = v & 0x3FF
			return
		if [ pa == 0x0440001C ]                              # VI_H_TOTAL: quarterLineDuration + leapPattern
			vi_qld     = v & 0xFFF
			vi_leappat = (v >> 16) & 0x1F
			return
		if [ pa == 0x04400020 ]                              # VI_H_SYNC_LEAP
			vi_hleap0 = v & 0xFFF
			vi_hleap1 = (v >> 16) & 0xFFF
			return
		if [ pa == 0x04400028 ]                              # VI_V_VIDEO: vstart
			vi_vstart = (v >> 16) & 0x3FF
			return
		if [ pa == 0x04400030 ]
			vi_xscale = v
			return
		if [ pa == 0x04400034 ]
			vi_yscale = v
			return
		if [ pa == 0x04500000 ]                              # AI_DRAM: addr into slot dmaCount
			ai_dram = v
			if [ ai_fifo_n < 2 ] ai_fifo_dram[ ai_fifo_n ] = v & 0xFFFFF8
			return
		if [ pa == 0x04500004 ]                              # AI_LENGTH: queue DMA (ares-exact)
			ln : u32 [ v & 0x3FFF8 ]
			ai_len = ln
			if [ ai_fifo_n < 2 ]
				if [ ai_fifo_n == 0 ]                        # ares: raise AI on queue-into-empty
					mi_intr = mi_intr | 0x4
					mi_check[]
				ai_fifo_len[ ai_fifo_n ] = ln
				if [ ai_out_n < 16 ]                        # decoupled ALSA output ring
					ai_out_dram[ ai_out_n ] = ai_fifo_dram[ ai_fifo_n ] & 0x7FFFF8
					ai_out_len[ ai_out_n ]  = ln
					ai_out_n = ai_out_n + 1
				ai_fifo_n = ai_fifo_n + 1
			return
		if [ pa == 0x04500008 ]
			ai_ctrl = v
			return
		if [ pa == 0x0450000C ]                              # AI status write = clear AI int
			mi_intr = mi_intr & (~u32[0x4])
			mi_check[]
			return
		if [ pa == 0x04500010 ]                              # AI_DACRATE: sys_clk per sample
			ai_dacrate = v
			dr : u32 [ v & 0x3FFF ]
			dfreq : i64 [ i64[ 48681818 ] / (i64[ dr ] + 1) ]
			if [ dfreq < 1 ] dfreq = 1
			ai_period = i64[ 187500000 ] / dfreq
			return
		if [ pa == 0x04600000 ]
			pi_dram = v & 0xFFFFFF
			return
		if [ pa == 0x04600004 ]
			pi_cart = v
			return
		if [ pa == 0x0460000C ]                              # PI write length: cart -> RDRAM
			ln : u32 [ (v & 0xFFFFFF) + 1 ]
			src : i64 [ i64[ pi_cart & 0x1FFFFFFF ] - 0x10000000 ]
			if [ trace ]
				printf[ "n64 PIDMA cart=%08X dram=%06X len=%u f%u\n", pi_cart, pi_dram, ln, frames ]
			for [ i: u32 0, i < ln, i += 1 ]
				bv : u32 [ (src + i64[i] < rom_size && src + i64[i] >= 0) ? u32[ rom_data[ src + i64[i] ] ] : 0 ]
				if [ pi_dram + i < 0x800000 ] rdram[ pi_dram + i ] = u8[ bv ]
			pi_status = pi_status | 0x1                       # dmaBusy; interrupt deferred (ares)
			pi_dma_p  = true
			pi_dma_at = c_istart + (pi_dma_dur[ v & 0xFFFFFF, pi_cart ] + 1) / 2
			return
		if [ pa == 0x04600008 ]                              # PI read length: RDRAM -> cart
			pi_status = pi_status | 0x1                       # dmaBusy; RDRAM->cart write ignored (ROM)
			pi_dma_p  = true
			pi_dma_at = c_istart + (pi_dma_dur[ v & 0xFFFFFF, pi_cart ] + 1) / 2
			return
		if [ pa == 0x04600014 ]
			pi_d1_lat = v & 0xFF
			return
		if [ pa == 0x04600018 ]
			pi_d1_pwd = v & 0xFF
			return
		if [ pa == 0x0460001C ]
			pi_d1_pgs = v & 0xF
			return
		if [ pa == 0x04600020 ]
			pi_d1_rls = v & 0x3
			return
		if [ pa == 0x04600024 ]
			pi_d2_lat = v & 0xFF
			return
		if [ pa == 0x04600028 ]
			pi_d2_pwd = v & 0xFF
			return
		if [ pa == 0x0460002C ]
			pi_d2_pgs = v & 0xF
			return
		if [ pa == 0x04600030 ]
			pi_d2_rls = v & 0x3
			return
		if [ pa == 0x04600010 ]                              # PI_STATUS write
			if [ v & 0x1 ]                                    # reset controller: clear dmaBusy + cancel
				pi_status = pi_status & (~u32[0x1])
				pi_dma_p  = false
			if [ v & 0x2 ]                                    # clear PI interrupt
				pi_status = pi_status & (~u32[0x8])
				mi_intr = mi_intr & (~u32[0x10])
				mi_check[]
			return
		if [ pa == 0x04800000 ]
			si_dram = v & 0xFFFFFF
			return
		if [ pa == 0x04800004 ]                              # SI read64: PIF -> RDRAM
			pif_joybus[]
			for [ i: u32 0, i < 64, i += 1 ]
				rdram[ si_dram + i ] = pif_ram[ i ]
			si_status = (si_status & 0x1000) | 0x0141        # dmaBusy|pch=4|dmaState=1
			si_dma_p  = true                                 # defer completion interrupt (real HW: ~ms later)
			si_dma_at = c_istart + si_lat
			if [ hash_on ] printf[ "SIKICK rd seq=%llu count=%u at=%u\n", hash_seq, cpu.c_count, si_dma_at ]
			return
		if [ pa == 0x04800010 ]                              # SI write64: RDRAM -> PIF
			for [ i: u32 0, i < 64, i += 1 ]
				pif_ram[ i ] = rdram[ si_dram + i ]
			if [ pif_state < 5 ] pif_tick []
			pif_joybus[]
			si_status = (si_status & 0x1000) | 0x0411        # dmaBusy|pch=1|dmaState=4
			si_dma_p  = true
			si_dma_at = c_istart + si_lat
			if [ hash_on ] printf[ "SIKICK wr seq=%llu count=%u at=%u\n", hash_seq, cpu.c_count, si_dma_at ]
			return
		if [ pa == 0x04800018 ]
			si_status = si_status & (~u32[0x1000])            # ack clears SI_STATUS interrupt bit12
			mi_intr = mi_intr & (~u32[0x2])
			mi_check[]
			return

	# controller reads: interpret joybus commands in PIF RAM
	# ---------------- audio HLE: ABI1 alist interpreter ----------------
	# Faithful port of mupen64plus-rsp-hle alist_audio.c/alist.c (vendored in
	# reference/). abuf holds big-endian 16-bit samples; all dmem offsets are
	# pre-biased by DMEM_BASE 0x5C0 at command decode.

	func ab_r8 [ off: u32 ] -> u32
		return u32[ abuf[ off & 0xFFF ] ]

	func ab_w8 [ off: u32, v: u32 ]
		abuf[ off & 0xFFF ] = u8[ v & 0xFF ]

	func ab_r16 [ off: u32 ] -> i32
		oo : u32 [ off & 0xFFF ]
		o2 : u32 [ (off + 1) & 0xFFF ]
		vv : i32 [ (i32[ abuf[oo] ] << 8) | i32[ abuf[o2] ] ]
		if [ vv >= 0x8000 ] vv -= 0x10000
		return vv

	func ab_w16 [ off: u32, v: i32 ]
		oo : u32 [ off & 0xFFF ]
		o2 : u32 [ (off + 1) & 0xFFF ]
		abuf[ oo ] = u8[ (v >> 8) & 0xFF ]
		abuf[ o2 ] = u8[ v & 0xFF ]

	func dr_r16 [ ad: u32 ] -> i32
		oo : u32 [ ad & 0x7FFFFE ]
		vv : i32 [ (i32[ rdram[oo] ] << 8) | i32[ rdram[oo + 1] ] ]
		if [ vv >= 0x8000 ] vv -= 0x10000
		return vv

	func dr_ru16 [ ad: u32 ] -> u32
		oo : u32 [ ad & 0x7FFFFE ]
		return (u32[ rdram[oo] ] << 8) | u32[ rdram[oo + 1] ]

	func dr_w16 [ ad: u32, v: i32 ]
		oo : u32 [ ad & 0x7FFFFE ]
		rdram[ oo ]     = u8[ (v >> 8) & 0xFF ]
		rdram[ oo + 1 ] = u8[ v & 0xFF ]

	func dr_r32 [ ad: u32 ] -> u32
		oo : u32 [ ad & 0x7FFFFC ]
		return (u32[rdram[oo]] << 24) | (u32[rdram[oo + 1]] << 16) | (u32[rdram[oo + 2]] << 8) | u32[rdram[oo + 3]]

	func dr_w32 [ ad: u32, v: u32 ]
		oo : u32 [ ad & 0x7FFFFC ]
		rdram[ oo ]     = u8[ (v >> 24) & 0xFF ]
		rdram[ oo + 1 ] = u8[ (v >> 16) & 0xFF ]
		rdram[ oo + 2 ] = u8[ (v >> 8) & 0xFF ]
		rdram[ oo + 3 ] = u8[ v & 0xFF ]

	func fnv_u64 [ h: u64, v: u64 ] -> u64
		r : u64 [ h ]
		for [ i: i32 7, i >= 0, i -= 1 ]
			r = (r ^ ((v >> u64[ i * 8 ]) & 0xFF)) * 0x100000001b3
		return r

	func wrsig [ pa: u32, v: u32 ]
		if [ dbg_on && fparm && (cpu.pc >= 0x80170000) && (cpu.pc < 0x801A0000) ]
			wrhash = fnv_u64[ wrhash, u64[ pa ] ]
			wrhash = fnv_u64[ wrhash, u64[ v ] ]
			printf[ "OWH %d %016llx %08X %08X pc=%08X\n", wrseq, wrhash, pa, v, cpu.pc ]
			wrseq = wrseq + 1

	func fnv_mem [ lo: u32, hi: u32 ] -> u64
		h : u64 [ 0xcbf29ce484222325 ]
		a : u32 [ lo ]
		while [ a < hi ]
			w : u32 [ dr_r32[ a ] ]
			h = (h ^ u64[ (w >> 24) & 0xFF ]) * 0x100000001b3
			h = (h ^ u64[ (w >> 16) & 0xFF ]) * 0x100000001b3
			h = (h ^ u64[ (w >> 8) & 0xFF ]) * 0x100000001b3
			h = (h ^ u64[ w & 0xFF ]) * 0x100000001b3
			a += 4
		return h

	# whole-system-state hash: entire 4MB RDRAM + all 32 GPRs + all 32 FPRs + HI + LO (full data state)
	func sys_hash [] -> u64
		h : u64 [ 0xcbf29ce484222325 ]
		a : u32 [ 0 ]
		while [ a < 0x400000 ]
			w : u32 [ dr_r32[ a ] ]
			h = (h ^ u64[ (w >> 24) & 0xFF ]) * 0x100000001b3
			h = (h ^ u64[ (w >> 16) & 0xFF ]) * 0x100000001b3
			h = (h ^ u64[ (w >> 8) & 0xFF ]) * 0x100000001b3
			h = (h ^ u64[ w & 0xFF ]) * 0x100000001b3
			a += 4
		for [ i: i32 0, i < 32, i += 1 ]
			h = fnv_u64[ h, u64[ cpu.r[ i ] ] ]
		for [ i: i32 0, i < 32, i += 1 ]
			h = fnv_u64[ h, cpu.fpr[ i ] ]
		h = fnv_u64[ h, u64[ cpu.hi ] ]
		h = fnv_u64[ h, u64[ cpu.lo ] ]
		return h

	func dr_s32 [ ad: u32 ] -> i64
		return wrs32[ i64[ dr_r32[ ad ] ] ]

	func cs16 [ v: i32 ] -> i32
		if [ v > 32767 ] return 32767
		if [ v < -32768 ] return -32768
		return v

	func sx16u [ v: u32 ] -> i32
		rv : i32 [ i32[ v & 0xFFFF ] ]
		if [ rv >= 0x8000 ] rv -= 0x10000
		return rv

	func wrs32 [ v: i64 ] -> i64
		ww : i64 [ v & 0xFFFFFFFF ]
		if [ ww >= 0x80000000 ] ww -= 0x100000000
		return ww

	func a_addr [ so: u32 ] -> u32
		sg : u32 [ (so >> 24) & 0x3F ]
		of : u32 [ so & 0xFFFFFF ]
		if [ sg >= 16 ] return of
		sb : u32 [ aseg[ sg ] ]
		return sb + of

	func a_clear [ dm: u32, count: u32 ]
		for [ i: u32 0, i < count, i += 1 ]
			ab_w8[ dm + i, 0 ]

	func a_loadbuf [ ad: u32, dm: u32, count: u32 ]
		dd : u32 [ dm & (~u32[3]) ]
		ss : u32 [ ad & (~u32[7]) ]
		cc : u32 [ (count + 7) & (~u32[7]) ]
		for [ i: u32 0, i < cc, i += 1 ]
			ab_w8[ dd + i, u32[ rdram[ (ss + i) & 0x7FFFFF ] ] ]

	func a_savebuf [ ad: u32, dm: u32, count: u32 ]
		dd : u32 [ dm & (~u32[3]) ]
		ss : u32 [ ad & (~u32[7]) ]
		cc : u32 [ (count + 7) & (~u32[7]) ]
		for [ i: u32 0, i < cc, i += 1 ]
			rdram[ (ss + i) & 0x7FFFFF ] = u8[ ab_r8[ dd + i ] ]

	func a_move [ dmo: u32, dmi: u32, count: u32 ]
		for [ i: u32 0, i < count, i += 1 ]
			ab_w8[ dmo + i, ab_r8[ dmi + i ] ]

	# adpcm_compute_residuals: dst/src are ad_last/ad_frame at base, cb indexes
	# a_table (book1 = cb, book2 = cb+8), l1/l2 = ad_last[lofs], ad_last[lofs+1]
	func a_resid [ base: i32, cb: i32, lofs: i32 ]
		l1 : i32 [ ad_last[ lofs ] ]
		l2 : i32 [ ad_last[ lofs + 1 ] ]
		for [ i: i32 0, i < 8, i += 1 ]
			acc : i32 [ ad_frame[ base + i ] << 11 ]
			acc += a_table[ cb + i ] * l1
			acc += a_table[ cb + 8 + i ] * l2
			for [ k: i32 0, k < i, k += 1 ]
				acc += a_table[ cb + 8 + k ] * ad_frame[ base + i - 1 - k ]
			ad_last[ base + i ] = cs16[ acc >> 11 ]

	func a_adpcm [ init: bool, lp: bool, addr: u32 ]
		dmo : u32 [ a_out ]
		dmi : u32 [ a_in ]
		count : u32 [ (a_count + 31) & (~u32[31]) ]
		if [ init ]
			for [ i: i32 0, i < 16, i += 1 ]
				ad_last[ i ] = 0
		el
			sa : u32 [ (lp) ? a_loop : addr ]
			for [ i: i32 0, i < 16, i += 1 ]
				ad_last[ i ] = dr_r16[ sa + u32[ i * 2 ] ]
		for [ i: i32 0, i < 16, i += 1 ]
			ab_w16[ dmo, ad_last[ i ] ]
			dmo += 2
		while [ count > 0 ]
			code : u32 [ ab_r8[ dmi ] ]
			dmi += 1
			scale : i32 [ i32[ (code >> 4) & 0xF ] ]
			cb : i32 [ i32[ code & 0xF ] << 4 ]
			rsh : i32 [ (scale < 12) ? (12 - scale) : 0 ]
			for [ i: i32 0, i < 8, i += 1 ]
				bt : u32 [ ab_r8[ dmi ] ]
				dmi += 1
				hn : i32 [ i32[ (bt >> 4) & 0xF ] << 12 ]
				ln : i32 [ i32[ bt & 0xF ] << 12 ]
				if [ hn >= 0x8000 ] hn -= 0x10000
				if [ ln >= 0x8000 ] ln -= 0x10000
				ad_frame[ i * 2 ]     = hn >> rsh
				ad_frame[ i * 2 + 1 ] = ln >> rsh
			a_resid[ 0, cb, 14 ]
			a_resid[ 8, cb, 6 ]
			for [ i: i32 0, i < 16, i += 1 ]
				ab_w16[ dmo, ad_last[ i ] ]
				dmo += 2
			count -= 32
		for [ i: i32 0, i < 16, i += 1 ]
			dr_w16[ addr + u32[ i * 2 ], ad_last[ i ] ]

	# alist_envmix_exp: exponential envelope ramps, state saved in DRAM at addr
	# (layout internal to the HLE: 10 big-endian i32 fields, 40 bytes)
	func a_envmix [ init: bool, aux: bool, addr: u32 ]
		dry : i32 [ a_dry ]
		wet : i32 [ a_wet ]
		v0 : i64 [ 0 ]
		v1 : i64 [ 0 ]
		t0 : i64 [ 0 ]
		t1 : i64 [ 0 ]
		er0 : i64 [ 0 ]
		er1 : i64 [ 0 ]
		es0 : i64 [ 0 ]
		es1 : i64 [ 0 ]
		if [ init ]
			v0 = i64[ a_vol0 ] << 16
			v1 = i64[ a_vol1 ] << 16
			t0 = i64[ a_tgt0 ] << 16
			t1 = i64[ a_tgt1 ] << 16
			er0 = a_rate0
			er1 = a_rate1
			es0 = wrs32[ i64[ a_vol0 ] * a_rate0 ]
			es1 = wrs32[ i64[ a_vol1 ] * a_rate1 ]
		el
			wet = i32[ dr_s32[ addr ] ]
			dry = i32[ dr_s32[ addr + 4 ] ]
			t0  = dr_s32[ addr + 8 ]
			t1  = dr_s32[ addr + 12 ]
			er0 = dr_s32[ addr + 16 ]
			er1 = dr_s32[ addr + 20 ]
			es0 = dr_s32[ addr + 24 ]
			es1 = dr_s32[ addr + 28 ]
			v0  = dr_s32[ addr + 32 ]
			v1  = dr_s32[ addr + 36 ]
		step0 : i64 [ t0 - v0 ]
		step1 : i64 [ t1 - v1 ]
		bi : u32 [ a_in ]
		bo : u32 [ a_out ]
		bdr : u32 [ a_dryr ]
		bwl : u32 [ a_wetl ]
		bwr : u32 [ a_wetr ]
		cnt : i32 [ i32[ a_count ] ]
		ptr : u32 [ 0 ]
		for [ y: i32 0, y < cnt, y += 16 ]
			if [ step0 != 0 ]
				es0 = wrs32[ (es0 * er0) >> 16 ]
				step0 = (es0 - v0) >> 3
			if [ step1 != 0 ]
				es1 = wrs32[ (es1 * er1) >> 16 ]
				step1 = (es1 - v1) >> 3
			for [ x: i32 0, x < 8, x += 1 ]
				v0 += step0
				hit0 : bool [ (step0 <= 0) ? (v0 <= t0) : (v0 >= t0) ]
				if [ hit0 ]
					v0 = t0
					step0 = 0
				v1 += step1
				hit1 : bool [ (step1 <= 0) ? (v1 <= t1) : (v1 >= t1) ]
				if [ hit1 ]
					v1 = t1
					step1 = 0
				lv : i32 [ i32[ v0 >> 16 ] ]
				rv : i32 [ i32[ v1 >> 16 ] ]
				g0 : i32 [ cs16[ (lv * dry + 0x4000) >> 15 ] ]
				g1 : i32 [ cs16[ (rv * dry + 0x4000) >> 15 ] ]
				g2 : i32 [ cs16[ (lv * wet + 0x4000) >> 15 ] ]
				g3 : i32 [ cs16[ (rv * wet + 0x4000) >> 15 ] ]
				smp : i32 [ ab_r16[ bi + ptr * 2 ] ]
				oo : u32 [ ptr * 2 ]
				d0 : i32 [ ab_r16[ bo + oo ] ]
				ab_w16[ bo + oo, cs16[ d0 + ((smp * g0) >> 15) ] ]
				d1 : i32 [ ab_r16[ bdr + oo ] ]
				ab_w16[ bdr + oo, cs16[ d1 + ((smp * g1) >> 15) ] ]
				if [ aux ]
					d2 : i32 [ ab_r16[ bwl + oo ] ]
					ab_w16[ bwl + oo, cs16[ d2 + ((smp * g2) >> 15) ] ]
					d3 : i32 [ ab_r16[ bwr + oo ] ]
					ab_w16[ bwr + oo, cs16[ d3 + ((smp * g3) >> 15) ] ]
				ptr += 1
		dr_w32[ addr,      u32[ wet ] ]
		dr_w32[ addr + 4,  u32[ dry ] ]
		dr_w32[ addr + 8,  u32[ t0 & 0xFFFFFFFF ] ]
		dr_w32[ addr + 12, u32[ t1 & 0xFFFFFFFF ] ]
		dr_w32[ addr + 16, u32[ er0 & 0xFFFFFFFF ] ]
		dr_w32[ addr + 20, u32[ er1 & 0xFFFFFFFF ] ]
		dr_w32[ addr + 24, u32[ es0 & 0xFFFFFFFF ] ]
		dr_w32[ addr + 28, u32[ es1 & 0xFFFFFFFF ] ]
		dr_w32[ addr + 32, u32[ v0 & 0xFFFFFFFF ] ]
		dr_w32[ addr + 36, u32[ v1 & 0xFFFFFFFF ] ]

	func a_resample [ init: bool, pitch: u32, addr: u32 ]
		ip : u32 [ (a_in >> 1) - 4 ]
		op : u32 [ a_out >> 1 ]
		cnt : u32 [ ((a_count + 15) & (~u32[15])) >> 1 ]
		accu : u32 [ 0 ]
		if [ init ]
			for [ k: u32 0, k < 4, k += 1 ]
				ab_w16[ (ip + k) * 2, 0 ]
		el
			for [ k: u32 0, k < 4, k += 1 ]
				ab_w16[ (ip + k) * 2, dr_r16[ addr + k * 2 ] ]
			accu = dr_ru16[ addr + 8 ]
		while [ cnt > 0 ]
			li : i32 [ i32[ (accu >> 10) & 0x3F ] * 4 ]
			s0 : i32 [ ab_r16[ ip * 2 ] ]
			s1 : i32 [ ab_r16[ (ip + 1) * 2 ] ]
			s2 : i32 [ ab_r16[ (ip + 2) * 2 ] ]
			s3 : i32 [ ab_r16[ (ip + 3) * 2 ] ]
			sum : i32 [ s0 * i32[ res_lut[ li ] ] + s1 * i32[ res_lut[ li + 1 ] ] + s2 * i32[ res_lut[ li + 2 ] ] + s3 * i32[ res_lut[ li + 3 ] ] ]
			ab_w16[ op * 2, cs16[ sum >> 15 ] ]
			op += 1
			accu += pitch
			ip += accu >> 16
			accu = accu & 0xFFFF
			cnt -= 1
		for [ k: u32 0, k < 4, k += 1 ]
			dr_w16[ addr + k * 2, ab_r16[ (ip + k) * 2 ] ]
		dr_w16[ addr + 8, i32[ accu ] ]

	func a_mix [ dmo: u32, dmi: u32, count: u32, gain: i32 ]
		cc : u32 [ count >> 1 ]
		for [ i: u32 0, i < cc, i += 1 ]
			ss : i32 [ ab_r16[ dmi + i * 2 ] ]
			dd : i32 [ ab_r16[ dmo + i * 2 ] ]
			ab_w16[ dmo + i * 2, cs16[ dd + ((ss * gain) >> 15) ] ]

	func a_interleave [ lft: u32, rgt: u32 ]
		cnt : u32 [ ((a_count + 15) & (~u32[15])) >> 2 ]
		oo : u32 [ a_out ]
		ll : u32 [ lft ]
		rr : u32 [ rgt ]
		while [ cnt > 0 ]
			l1 : i32 [ ab_r16[ ll ] ]
			l2 : i32 [ ab_r16[ ll + 2 ] ]
			r1 : i32 [ ab_r16[ rr ] ]
			r2 : i32 [ ab_r16[ rr + 2 ] ]
			ab_w16[ oo,     l1 ]
			ab_w16[ oo + 2, r1 ]
			ab_w16[ oo + 4, l2 ]
			ab_w16[ oo + 6, r2 ]
			ll += 4
			rr += 4
			oo += 8
			cnt -= 1

	func audio_task []
		dp : u32 [ (u32[dmem[0xFF0]] << 24) | (u32[dmem[0xFF1]] << 16) | (u32[dmem[0xFF2]] << 8) | u32[dmem[0xFF3]] ]
		ds : u32 [ (u32[dmem[0xFF4]] << 24) | (u32[dmem[0xFF5]] << 16) | (u32[dmem[0xFF6]] << 8) | u32[dmem[0xFF7]] ]
		for [ i: i32 0, i < 16, i += 1 ]
			aseg[ i ] = 0
		ap : u32 [ dp & 0x7FFFFF ]
		ae : u32 [ ap + (ds & (~u32[7])) ]
		gcnt : i32 [ 0 ]
		while [ ap + 8 <= ae && gcnt < 4096 ]
			gcnt += 1
			w1 : u32 [ dr_r32[ ap ] ]
			w2 : u32 [ dr_r32[ ap + 4 ] ]
			ap += 8
			cmd : u32 [ (w1 >> 24) & 0x7F ]
			cflg : u32 [ (w1 >> 16) & 0xFF ]
			if [ cmd == 1 ]                                   # ADPCM
				a_adpcm[ (cflg & 1) != 0, (cflg & 2) != 0, a_addr[ w2 ] ]
			el [ cmd == 2 ]                                   # CLEARBUFF
				cnt : u32 [ w2 & 0xFFF ]
				if [ cnt > 0 ] a_clear[ (w1 & 0xFFFF) + 0x5C0, (cnt + 15) & (~u32[15]) ]
			el [ cmd == 3 ]                                   # ENVMIXER
				a_envmix[ (cflg & 1) != 0, (cflg & 8) != 0, a_addr[ w2 ] ]
			el [ cmd == 4 ]                                   # LOADBUFF
				if [ a_count > 0 ] a_loadbuf[ a_addr[ w2 ], a_in, a_count ]
			el [ cmd == 5 ]                                   # RESAMPLE
				a_resample[ (cflg & 1) != 0, (w1 & 0xFFFF) << 1, a_addr[ w2 ] ]
			el [ cmd == 6 ]                                   # SAVEBUFF
				if [ a_count > 0 ] a_savebuf[ a_addr[ w2 ], a_out, a_count ]
			el [ cmd == 7 ]                                   # SEGMENT
				sg : u32 [ (w2 >> 24) & 0x3F ]
				if [ sg < 16 ] aseg[ sg ] = w2 & 0xFFFFFF
			el [ cmd == 8 ]                                   # SETBUFF
				if [ cflg & 8 ]
					a_dryr = (w1 & 0xFFFF) + 0x5C0
					a_wetl = ((w2 >> 16) & 0xFFFF) + 0x5C0
					a_wetr = (w2 & 0xFFFF) + 0x5C0
				el
					a_in    = (w1 & 0xFFFF) + 0x5C0
					a_out   = ((w2 >> 16) & 0xFFFF) + 0x5C0
					a_count = w2 & 0xFFFF
			el [ cmd == 9 ]                                   # SETVOL
				vv : i32 [ sx16u[ w1 & 0xFFFF ] ]
				if [ cflg & 8 ]
					a_dry = vv
					a_wet = sx16u[ w2 & 0xFFFF ]
				el
					if [ cflg & 4 ]
						if [ cflg & 2 ] a_vol0 = vv
						el a_vol1 = vv
					el
						if [ cflg & 2 ]
							a_tgt0 = vv
							a_rate0 = wrs32[ i64[ w2 ] ]
						el
							a_tgt1 = vv
							a_rate1 = wrs32[ i64[ w2 ] ]
			el [ cmd == 10 ]                                  # DMEMMOVE
				cnt : u32 [ w2 & 0xFFFF ]
				if [ cnt > 0 ] a_move[ ((w2 >> 16) & 0xFFFF) + 0x5C0, (w1 & 0xFFFF) + 0x5C0, (cnt + 15) & (~u32[15]) ]
			el [ cmd == 11 ]                                  # LOADADPCM
				cnt : u32 [ ((w1 & 0xFFFF) + 7) & (~u32[7]) ]
				ad : u32 [ a_addr[ w2 ] ]
				nw : u32 [ cnt >> 1 ]
				if [ nw > 128 ] nw = 128
				for [ i: u32 0, i < nw, i += 1 ]
					a_table[ i ] = dr_r16[ ad + i * 2 ]
			el [ cmd == 12 ]                                  # MIXER
				if [ a_count > 0 ] a_mix[ (w2 & 0xFFFF) + 0x5C0, ((w2 >> 16) & 0xFFFF) + 0x5C0, (a_count + 31) & (~u32[31]), sx16u[ w1 & 0xFFFF ] ]
			el [ cmd == 13 ]                                  # INTERLEAVE
				if [ a_count > 0 ] a_interleave[ ((w2 >> 16) & 0xFFFF) + 0x5C0, (w2 & 0xFFFF) + 0x5C0 ]
			el [ cmd == 15 ]                                  # SETLOOP
				a_loop = a_addr[ w2 ]

	# retire ALL queued AI buffers each video frame: convert the big-endian
	# stereo s16 blocks from RDRAM, blocking-write to ALSA (this paces the
	# emu thread to real time), raising an AI interrupt per retired buffer
	func ai_drain []
		if [ ai_out_n == 0 ] return
		if [ !audio && !audio_fail ]
			freq : i32 [ 32000 ]
			if [ ai_dacrate > 0 ] freq = i32[ 48681812 / (ai_dacrate + 1) ]
			ao : n64_audio_out [ ]
			if [ ao.open[ freq ] ]
				ao.hold[]
				audio = ao
				if [ trace ] printf[ "n64 audio: %d Hz\n", freq ]
			el
				puts 'n64: audio device unavailable — continuing muted'
				audio_fail = true
		oi : i32 [ 0 ]
		while [ oi < ai_out_n ]                              # decoupled from CPU-facing fifo/interrupt
			dram0 : u32 [ ai_out_dram[ oi ] ]
			len0 : u32 [ ai_out_len[ oi ] ]
			oi += 1
			if [ audio ]
				nf : i32 [ i32[ len0 >> 2 ] ]
				vol : i32 [ i32[ volume * 256.0 ] ]
				done : i32 [ 0 ]
				while [ done < nf ]
					chunk : i32 [ nf - done ]
					cap : i32 [ i32[ audio.buffer_size ] ]
					if [ chunk > cap ] chunk = cap
					for [ i: i32 0, i < chunk, i += 1 ]
						off : u32 [ dram0 + u32[ (done + i) * 4 ] ]
						lv : i32 [ dr_r16[ off ] ]
						rv : i32 [ dr_r16[ off + 2 ] ]
						audio.buffer[ i * 2 ]     = i16[ (lv * vol) >> 8 ]
						audio.buffer[ i * 2 + 1 ] = i16[ (rv * vol) >> 8 ]
					audio.write[ chunk ]
					done += chunk
		ai_out_n = 0

	# cycle-accurate AI DMA playback (ares AI::sample). Consumes the head
	# buffer one sample per ai_period sys_clk; raises the AI interrupt when a
	# buffer drains and another is queued. CPU-facing timing, no audio output.
	func ai_sync []
		if [ ai_period <= 0 ] return
		while [ sys_clk > ai_clk ]                            # free-runs like ares sample()
			if [ ai_fifo_n > 0 ]
				if [ (ai_ctrl & 1) && ai_fifo_len[ 0 ] > 0 ]
					ai_fifo_len[ 0 ] = ai_fifo_len[ 0 ] - 4
				if [ ai_fifo_len[ 0 ] == 0 ]
					ai_fifo_n = ai_fifo_n - 1
					if [ ai_fifo_n > 0 ]
						ai_fifo_dram[ 0 ] = ai_fifo_dram[ 1 ]
						ai_fifo_len[ 0 ]  = ai_fifo_len[ 1 ]
						mi_intr = mi_intr | 0x4
						mi_check[]
			ai_clk = ai_clk + ai_period

	# ---------------- gfx HLE: Fast3D -> software raster ----------------
	# Interprets SM64's F3D display lists on SP gfx tasks and rasterizes
	# straight into the RDRAM color image (16bpp 5551) that the game's RDP
	# commands target; the VI scanout publishes it unchanged. Perspective-
	# correct nearest-texel sampling, vertex lighting, 1-bit alpha cutout.

	func dr_r8 [ ad: u32 ] -> u32
		return u32[ rdram[ ad & 0x7FFFFF ] ]

	func dr_s8 [ ad: u32 ] -> i32
		vv : i32 [ i32[ u32[ rdram[ ad & 0x7FFFFF ] ] ] ]
		if [ vv >= 0x80 ] vv -= 0x100
		return vv

	func gx_addr [ so: u32 ] -> u32
		sg : u32 [ (so >> 24) & 0x0F ]
		sb : u32 [ gx_seg[ sg ] ]
		return (sb + (so & 0xFFFFFF)) & 0x7FFFFF

	# read a 16.16 fixed N64 matrix at ad into mats slot 12 (tmpA)
	func gx_mtx_read [ ad: u32 ]
		for [ i: i32 0, i < 16, i += 1 ]
			ih : i32 [ dr_r16[ ad + u32[ i * 2 ] ] ]
			fl : u32 [ dr_ru16[ ad + 32 + u32[ i * 2 ] ] ]
			gx_mats[ 192 + i ] = f32[ ih ] + f32[ fl ] / 65536.0

	# mats[ob] = mats[ab] * mats[bb] (row-vector convention), via tmpB
	func gx_mmul [ ab: i32, bb: i32, ob: i32 ]
		for [ rr: i32 0, rr < 4, rr += 1 ]
			for [ cc: i32 0, cc < 4, cc += 1 ]
				acc : f32 [ 0.0 ]
				for [ kk: i32 0, kk < 4, kk += 1 ]
					acc += gx_mats[ ab + rr * 4 + kk ] * gx_mats[ bb + kk * 4 + cc ]
				gx_mats[ 208 + rr * 4 + cc ] = acc
		for [ i: i32 0, i < 16, i += 1 ]
			gx_mats[ ob + i ] = gx_mats[ 208 + i ]

	func gx_mcopy [ ab: i32, ob: i32 ]
		for [ i: i32 0, i < 16, i += 1 ]
			gx_mats[ ob + i ] = gx_mats[ ab + i ]

	func gx_mtx_cmd [ par: u32, ad: u32 ]
		gx_mtx_read[ ad ]
		if [ par & 1 ]                                       # projection
			if [ par & 2 ] gx_mcopy[ 192, 0 ]
			el gx_mmul[ 192, 0, 0 ]
		el
			if [ (par & 4) && gx_mvi < 10 ]                  # push
				ob : i32 [ (1 + gx_mvi) * 16 ]
				gx_mcopy[ ob, ob + 16 ]
				gx_mvi += 1
			mb : i32 [ (1 + gx_mvi) * 16 ]
			if [ par & 2 ] gx_mcopy[ 192, mb ]
			el gx_mmul[ 192, mb, mb ]
		gx_mvp_ok = false
		gx_mslot = -1

	func gx_vtx_cmd [ w1: u32, w2: u32 ]
		nn : i32 [ i32[ (w1 >> 20) & 0xF ] + 1 ]
		v0 : i32 [ i32[ (w1 >> 16) & 0xF ] ]
		ad : u32 [ gx_addr[ w2 ] ]
		if [ dbg_on && frames == 377 && (ad & 0x1FFFFFFF) >= 0x88000 && (ad & 0x1FFFFFFF) < 0x89000 ]
			printf[ "n64 GVTX w1=%08X w2=%08X nn=%d v0=%d ad=%08X endad=%08X f%u\n", w1, w2, nn, v0, ad, ad + u32[ nn * 16 ], frames ]
		if [ !gx_mvp_ok ]
			gx_mmul[ (1 + gx_mvi) * 16, 0, 224 ]
			gx_mvp_ok = true
		m00 : f32 [ gx_mats[224] ]
		m01 : f32 [ gx_mats[225] ]
		m02 : f32 [ gx_mats[226] ]
		m03 : f32 [ gx_mats[227] ]
		m10 : f32 [ gx_mats[228] ]
		m11 : f32 [ gx_mats[229] ]
		m12 : f32 [ gx_mats[230] ]
		m13 : f32 [ gx_mats[231] ]
		m20 : f32 [ gx_mats[232] ]
		m21 : f32 [ gx_mats[233] ]
		m22 : f32 [ gx_mats[234] ]
		m23 : f32 [ gx_mats[235] ]
		m30 : f32 [ gx_mats[236] ]
		m31 : f32 [ gx_mats[237] ]
		m32 : f32 [ gx_mats[238] ]
		m33 : f32 [ gx_mats[239] ]
		lit : bool [ (gx_geom & 0x20000) != 0 ]
		na : i32 [ gx_nl * 6 ]
		if [ gpu_on ]
			vms : i32 [ st_mtx_ensure[] ]
			vls : i32 [ 0 ]
			if [ lit ] vls = st_ls_ensure[]
			for [ i: i32 0, i < nn, i += 1 ]
				sl : i32 [ v0 + i ]
				if [ sl > 15 ] sl = 15
				va : u32 [ ad + u32[ i * 16 ] ]
				gx_vsrc[ sl ] = va
				rb : i32 [ sl * 12 ]
				gx_vraw[ rb ]     = f32[ dr_r16[ va ] ]
				gx_vraw[ rb + 1 ] = f32[ dr_r16[ va + 2 ] ]
				gx_vraw[ rb + 2 ] = f32[ dr_r16[ va + 4 ] ]
				gx_vraw[ rb + 3 ] = f32[ dr_r16[ va + 8 ] ] * gx_texs / 32.0
				gx_vraw[ rb + 4 ] = f32[ dr_r16[ va + 10 ] ] * gx_text / 32.0
				if [ lit ]
					gx_vraw[ rb + 5 ] = f32[ dr_s8[ va + 12 ] ] / 128.0
					gx_vraw[ rb + 6 ] = f32[ dr_s8[ va + 13 ] ] / 128.0
					gx_vraw[ rb + 7 ] = f32[ dr_s8[ va + 14 ] ] / 128.0
					gx_vraw[ rb + 9 ] = 1.0
				el
					gx_vraw[ rb + 5 ] = f32[ dr_r8[ va + 12 ] ] / 255.0
					gx_vraw[ rb + 6 ] = f32[ dr_r8[ va + 13 ] ] / 255.0
					gx_vraw[ rb + 7 ] = f32[ dr_r8[ va + 14 ] ] / 255.0
					gx_vraw[ rb + 9 ] = 0.0
				gx_vraw[ rb + 8 ]  = f32[ dr_r8[ va + 15 ] ] / 255.0
				gx_vraw[ rb + 10 ] = f32[ vms ]
				gx_vraw[ rb + 11 ] = f32[ vls ]
				if [ dbg_on && frames == 377 && (va & 0x1FFFFFFF) >= 0x88000 && (va & 0x1FFFFFFF) < 0x89000 ]
					vy5 : i32 [ dr_r16[ va + 2 ] ]
					vz5 : i32 [ dr_r16[ va + 4 ] ]
					if [ true ]
						printf[ "n64 FARV sl=%d va=%08X xyz=(%d,%d,%d) uv=(%d,%d) f%u\n", sl, va, dr_r16[ va ], vy5, vz5, dr_r16[ va + 8 ], dr_r16[ va + 10 ], frames ]
			return
		for [ i: i32 0, i < nn, i += 1 ]
			sl : i32 [ v0 + i ]
			if [ sl > 15 ] sl = 15
			va : u32 [ ad + u32[ i * 16 ] ]
			gx_vsrc[ sl ] = va
			vx : f32 [ f32[ dr_r16[ va ] ] ]
			vy : f32 [ f32[ dr_r16[ va + 2 ] ] ]
			vz : f32 [ f32[ dr_r16[ va + 4 ] ] ]
			ob : i32 [ sl * 10 ]
			gx_vt[ ob ]     = vx * m00 + vy * m10 + vz * m20 + m30
			gx_vt[ ob + 1 ] = vx * m01 + vy * m11 + vz * m21 + m31
			gx_vt[ ob + 2 ] = vx * m02 + vy * m12 + vz * m22 + m32
			gx_vt[ ob + 3 ] = vx * m03 + vy * m13 + vz * m23 + m33
			gx_vt[ ob + 4 ] = f32[ dr_r16[ va + 8 ] ] * gx_texs / 32.0
			gx_vt[ ob + 5 ] = f32[ dr_r16[ va + 10 ] ] * gx_text / 32.0
			aa : f32 [ f32[ dr_r8[ va + 15 ] ] / 255.0 ]
			if [ lit ]
				nx : f32 [ f32[ dr_s8[ va + 12 ] ] / 128.0 ]
				ny : f32 [ f32[ dr_s8[ va + 13 ] ] / 128.0 ]
				nz : f32 [ f32[ dr_s8[ va + 14 ] ] / 128.0 ]
				cr : f32 [ gx_lights[ na ] ]
				cg : f32 [ gx_lights[ na + 1 ] ]
				cb : f32 [ gx_lights[ na + 2 ] ]
				nm : f32 [ sqrt[ nx * nx + ny * ny + nz * nz ] ]
				for [ li: i32 0, li < gx_nl, li += 1 ]
					lb : i32 [ li * 6 ]
					ldx : f32 [ gx_lights[ lb + 3 ] ]
					ldy : f32 [ gx_lights[ lb + 4 ] ]
					ldz : f32 [ gx_lights[ lb + 5 ] ]
					lm : f32 [ sqrt[ ldx * ldx + ldy * ldy + ldz * ldz ] ]   # N64 light dirs not unit — normalize
					dp : f32 [ 0.0 ]
					if [ lm > 0.0 && nm > 0.0 ] dp = (nx * ldx + ny * ldy + nz * ldz) / (lm * nm)
					if [ dp > 0.0 ]
						cr += dp * gx_lights[ lb ]
						cg += dp * gx_lights[ lb + 1 ]
						cb += dp * gx_lights[ lb + 2 ]
				if [ dbg_on && gx_dbgl > 0 && i == 0 ]
					printf[ "n64 litvtx n=(%f,%f,%f) amb=(%f,%f,%f) out=(%f,%f,%f) nl=%d\n", f64[nx], f64[ny], f64[nz], f64[ gx_lights[na] ], f64[ gx_lights[na+1] ], f64[ gx_lights[na+2] ], f64[cr], f64[cg], f64[cb], gx_nl ]
				if [ cr > 1.0 ] cr = 1.0
				if [ cg > 1.0 ] cg = 1.0
				if [ cb > 1.0 ] cb = 1.0
				gx_vt[ ob + 6 ] = cr
				gx_vt[ ob + 7 ] = cg
				gx_vt[ ob + 8 ] = cb
				if [ gx_geom & 0x40000 ]                     # texture gen: uv from normal
					tn8 : i32 [ gx_tile ]
					tws : f32 [ f32[ i32[ (tl_lrs[ tn8 ] - tl_uls[ tn8 ]) >> 2 ] ] ]
					tht : f32 [ f32[ i32[ (tl_lrt[ tn8 ] - tl_ult[ tn8 ]) >> 2 ] ] ]
					gx_vt[ ob + 4 ] = (nx * 0.5 + 0.5) * tws
					gx_vt[ ob + 5 ] = (0.5 - ny * 0.5) * tht
			el
				if [ dbg_on && gx_dbgl > 0 && i == 0 ]
					gx_dbgl -= 1
					printf[ "n64 vtxcol ad=%08X xyz=(%d,%d,%d) f=%04X col=%02X%02X%02X%02X f%u\n", va, dr_r16[va], dr_r16[va+2], dr_r16[va+4], dr_ru16[va+6], dr_r8[va+12], dr_r8[va+13], dr_r8[va+14], dr_r8[va+15], frames ]
				gx_vt[ ob + 6 ] = f32[ dr_r8[ va + 12 ] ] / 255.0
				gx_vt[ ob + 7 ] = f32[ dr_r8[ va + 13 ] ] / 255.0
				gx_vt[ ob + 8 ] = f32[ dr_r8[ va + 14 ] ] / 255.0
			gx_vt[ ob + 9 ] = aa

	# nearest-texel sample from the render tile; returns r<<24|g<<16|b<<8|a
	func gx_texel [ su: i32, tv: i32 ] -> u32
		tn : i32 [ gx_tile ]
		ss : i32 [ su - i32[ tl_uls[ tn ] >> 2 ] ]
		tt : i32 [ tv - i32[ tl_ult[ tn ] >> 2 ] ]
		msk : u32 [ tl_masks[ tn ] ]
		if [ msk > 0 ]
			mm : i32 [ (1 << i32[ msk ]) - 1 ]
			if [ (tl_cms[ tn ] & 1) && ((ss >> i32[msk]) & 1) ] ss = mm - (ss & mm)
			el ss = ss & mm
		el
			lim : i32 [ i32[ (tl_lrs[ tn ] - tl_uls[ tn ]) >> 2 ] ]
			if [ ss < 0 ] ss = 0
			if [ ss > lim ] ss = lim
		if [ tl_cms[ tn ] & 2 ]
			lim2 : i32 [ i32[ (tl_lrs[ tn ] - tl_uls[ tn ]) >> 2 ] ]
			if [ ss > lim2 ] ss = lim2
			if [ ss < 0 ] ss = 0
		mkt : u32 [ tl_maskt[ tn ] ]
		if [ mkt > 0 ]
			mm2 : i32 [ (1 << i32[ mkt ]) - 1 ]
			if [ (tl_cmt[ tn ] & 1) && ((tt >> i32[mkt]) & 1) ] tt = mm2 - (tt & mm2)
			el tt = tt & mm2
		el
			limt : i32 [ i32[ (tl_lrt[ tn ] - tl_ult[ tn ]) >> 2 ] ]
			if [ tt < 0 ] tt = 0
			if [ tt > limt ] tt = limt
		if [ tl_cmt[ tn ] & 2 ]
			limt2 : i32 [ i32[ (tl_lrt[ tn ] - tl_ult[ tn ]) >> 2 ] ]
			if [ tt > limt2 ] tt = limt2
			if [ tt < 0 ] tt = 0
		lin : i32 [ i32[ tl_line[ tn ] ] * 8 ]
		tb : i32 [ i32[ tl_tmem[ tn ] ] * 8 + tt * lin ]
		fmt : u32 [ tl_fmt[ tn ] ]
		siz : u32 [ tl_siz[ tn ] ]
		swp : i32 [ (tl_block[ tn ] && (tt & 1)) ? 4 : 0 ]   # LoadBlock odd-row 32-bit word swap
		if [ fmt == 0 && siz == 2 ]                          # RGBA16
			toff : i32 [ tb + ss * 2 ]
			px : u32 [ (u32[ tmem[ (toff ^ swp) & 0xFFF ] ] << 8) | u32[ tmem[ ((toff + 1) ^ swp) & 0xFFF ] ] ]
			r5 : u32 [ (px >> 11) & 31 ]
			g5 : u32 [ (px >> 6) & 31 ]
			b5 : u32 [ (px >> 1) & 31 ]
			return ((r5 << 3 | r5 >> 2) << 24) | ((g5 << 3 | g5 >> 2) << 16) | ((b5 << 3 | b5 >> 2) << 8) | ((px & 1) * 255)
		if [ fmt == 3 && siz == 2 ]                          # IA16
			toff2 : i32 [ tb + ss * 2 ]
			iv : u32 [ u32[ tmem[ (toff2 ^ swp) & 0xFFF ] ] ]
			av : u32 [ u32[ tmem[ ((toff2 + 1) ^ swp) & 0xFFF ] ] ]
			return (iv << 24) | (iv << 16) | (iv << 8) | av
		if [ fmt == 3 && siz == 1 ]                          # IA8: 4/4
			bv : u32 [ u32[ tmem[ ((tb + ss) ^ swp) & 0xFFF ] ] ]
			i4 : u32 [ (bv >> 4) & 0xF ]
			a4 : u32 [ bv & 0xF ]
			iv2 : u32 [ (i4 << 4) | i4 ]
			av2 : u32 [ (a4 << 4) | a4 ]
			return (iv2 << 24) | (iv2 << 16) | (iv2 << 8) | av2
		if [ fmt == 3 && siz == 0 ]                          # IA4: 3/1
			bv2 : u32 [ u32[ tmem[ ((tb + (ss >> 1)) ^ swp) & 0xFFF ] ] ]
			nib : u32 [ ((ss & 1) == 0) ? ((bv2 >> 4) & 0xF) : (bv2 & 0xF) ]
			i3 : u32 [ (nib >> 1) & 7 ]
			iv3 : u32 [ (i3 << 5) | (i3 << 2) | (i3 >> 1) ]
			return (iv3 << 24) | (iv3 << 16) | (iv3 << 8) | ((nib & 1) * 255)
		if [ fmt == 4 && siz == 1 ]                          # I8
			iv4 : u32 [ u32[ tmem[ ((tb + ss) ^ swp) & 0xFFF ] ] ]
			return (iv4 << 24) | (iv4 << 16) | (iv4 << 8) | iv4
		if [ fmt == 4 && siz == 0 ]                          # I4
			bv3 : u32 [ u32[ tmem[ ((tb + (ss >> 1)) ^ swp) & 0xFFF ] ] ]
			n2 : u32 [ ((ss & 1) == 0) ? ((bv3 >> 4) & 0xF) : (bv3 & 0xF) ]
			iv5 : u32 [ (n2 << 4) | n2 ]
			return (iv5 << 24) | (iv5 << 16) | (iv5 << 8) | iv5
		if [ fmt == 2 && siz == 1 ]                          # CI8
			ci : u32 [ u32[ tmem[ ((tb + ss) ^ swp) & 0xFFF ] ] ]
			return gx_tlut[ ci ]
		if [ fmt == 2 && siz == 0 ]                          # CI4
			bv4 : u32 [ u32[ tmem[ ((tb + (ss >> 1)) ^ swp) & 0xFFF ] ] ]
			n3 : u32 [ ((ss & 1) == 0) ? ((bv4 >> 4) & 0xF) : (bv4 & 0xF) ]
			return gx_tlut[ (tl_pal[ gx_tile ] << 4) | n3 ]
		return 0xFFFFFFFF

	# px/py in SUPERSAMPLED coords (native * gx_ss). Writes the RGBA ss_buf
	# (publish path) and, on the top-left subsample, the game-visible RDRAM
	# 5551 color image.
	func gx_putpix [ px: i32, py: i32, rr: u32, gg: u32, bb: u32, aa8: u32 ]
		if [ px < 0 || py < 0 || px >= 1280 || py >= 960 ] return
		idx : i32 [ py * 1280 + px ]
		rr2 : u32 [ rr ]
		gg2 : u32 [ gg ]
		bb2 : u32 [ bb ]
		if [ gx_bl_add || gx_bl_xlu ]
			dv : u32 [ ss_buf[ idx ] ]
			dr : u32 [ dv & 0xFF ]
			dg : u32 [ (dv >> 8) & 0xFF ]
			db : u32 [ (dv >> 16) & 0xFF ]
			if [ gx_bl_add ]                                 # blender ADD: dst + src
				rr2 = rr + dr
				gg2 = gg + dg
				bb2 = bb + db
				if [ rr2 > 255 ] rr2 = 255
				if [ gg2 > 255 ] gg2 = 255
				if [ bb2 > 255 ] bb2 = 255
			el                                               # XLU: src*a + dst*(1-a)
				rr2 = (rr * aa8 + dr * (255 - aa8)) / 255
				gg2 = (gg * aa8 + dg * (255 - aa8)) / 255
				bb2 = (bb * aa8 + db * (255 - aa8)) / 255
		ss_buf[ idx ] = 0xFF000000 | (bb2 << 16) | (gg2 << 8) | rr2
		ss_used = true
		msk9 : i32 [ gx_ss - 1 ]
		if [ ((px | py) & msk9) == 0 ]
			lpx : i32 [ px / gx_ss ]
			lpy : i32 [ py / gx_ss ]
			off : u32 [ (gx_cimg + u32[ (lpy * gx_ciw + lpx) * 2 ]) & 0x7FFFFE ]
			v16 : u32 [ ((rr2 >> 3) << 11) | ((gg2 >> 3) << 6) | ((bb2 >> 3) << 1) | 1 ]
			rdram[ off ]     = u8[ (v16 >> 8) & 0xFF ]
			rdram[ off + 1 ] = u8[ v16 & 0xFF ]

	# rasterize one screen-space triangle from gx_scr at slot offsets
	func gx_raster [ o0: i32, o1: i32, o2: i32 ]
		x0 : f32 [ gx_scr[ o0 ] ]
		y0 : f32 [ gx_scr[ o0 + 1 ] ]
		x1 : f32 [ gx_scr[ o1 ] ]
		y1 : f32 [ gx_scr[ o1 + 1 ] ]
		x2 : f32 [ gx_scr[ o2 ] ]
		y2 : f32 [ gx_scr[ o2 + 1 ] ]
		if [ dbg_on && gx_dbgc > 0 && gx_scr[ o0 + 3 ] < 0.01 && gx_cc_shade && gx_cc_tex ]
			gx_dbgc -= 1
			smp0 : u32 [ gx_texel[ i32[ gx_scr[o0+4] / gx_scr[o0+3] ], i32[ gx_scr[o0+5] / gx_scr[o0+3] ] ] ]
			printf[ "n64 htri cc=%06X.%08X othl=%08X shade=(%.2f,%.2f,%.2f) tex=%08X f%u\n", gx_ccw1 & 0xFFFFFF, gx_ccw2, gx_oth_l, f64[ gx_scr[o0+6] ], f64[ gx_scr[o0+7] ], f64[ gx_scr[o0+8] ], smp0, frames ]
		tarea : f32 [ (x1 - x0) * (y2 - y0) - (y1 - y0) * (x2 - x0) ]
		if [ (gx_geom & 0x2000) && tarea >= 0.0 ] return     # cull back
		if [ (gx_geom & 0x1000) && tarea <= 0.0 ] return     # cull front
		if [ tarea == 0.0 ] return
		inv : f32 [ 1.0 / tarea ]
		bx0 : i32 [ i32[ (x0 < x1) ? ((x0 < x2) ? x0 : x2) : ((x1 < x2) ? x1 : x2) ] ]
		bx1 : i32 [ i32[ (x0 > x1) ? ((x0 > x2) ? x0 : x2) : ((x1 > x2) ? x1 : x2) ] + 1 ]
		by0 : i32 [ i32[ (y0 < y1) ? ((y0 < y2) ? y0 : y2) : ((y1 < y2) ? y1 : y2) ] ]
		by1 : i32 [ i32[ (y0 > y1) ? ((y0 > y2) ? y0 : y2) : ((y1 > y2) ? y1 : y2) ] + 1 ]
		if [ bx0 < gx_sx0 * gx_ss ] bx0 = gx_sx0 * gx_ss
		if [ by0 < gx_sy0 * gx_ss ] by0 = gx_sy0 * gx_ss
		if [ bx1 > gx_sx1 * gx_ss ] bx1 = gx_sx1 * gx_ss
		if [ by1 > gx_sy1 * gx_ss ] by1 = gx_sy1 * gx_ss
		if [ bx1 > gx_ciw * gx_ss ] bx1 = gx_ciw * gx_ss
		if [ by1 > 240 * gx_ss ] by1 = 240 * gx_ss
		if [ bx0 >= bx1 || by0 >= by1 ] return
		if [ dbg_on && dbg_esc < 24 && by0 < 6 && by1 > 60 ]
			dbg_esc += 1
			va0 : u32 [ gx_vsrc[ gx_ti0 ] ]
			va1 : u32 [ gx_vsrc[ gx_ti1 ] ]
			va2 : u32 [ gx_vsrc[ gx_ti2 ] ]
			tnA : i32 [ gx_tile ]
			printf[ "n64 TALLTRI slots(%d,%d,%d) geom=%08X uv0=(%.1f,%.1f) uv1=(%.1f,%.1f) tile fmt=%d siz=%d tsz=(%d,%d) texel=%08X f%u\n", gx_ti0, gx_ti1, gx_ti2, gx_geom, f64[ gx_scr[o0+4] / gx_scr[o0+3] ], f64[ gx_scr[o0+5] / gx_scr[o0+3] ], f64[ gx_scr[o1+4] / gx_scr[o1+3] ], f64[ gx_scr[o1+5] / gx_scr[o1+3] ], tl_fmt[tnA], tl_siz[tnA], i32[ (tl_lrs[tnA] - tl_uls[tnA]) >> 2 ], i32[ (tl_lrt[tnA] - tl_ult[tnA]) >> 2 ], gx_texel[ i32[ gx_scr[o1+4] / gx_scr[o1+3] ], i32[ gx_scr[o1+5] / gx_scr[o1+3] ] ], frames ]
			printf[ "  v0 @%08X raw=(%d,%d,%d) scr=(%.1f,%.1f)\n", va0, dr_r16[va0], dr_r16[va0+2], dr_r16[va0+4], f64[x0], f64[y0] ]
			printf[ "  v1 @%08X raw=(%d,%d,%d) scr=(%.1f,%.1f)\n", va1, dr_r16[va1], dr_r16[va1+2], dr_r16[va1+4], f64[x1], f64[y1] ]
			printf[ "  v2 @%08X raw=(%d,%d,%d) scr=(%.1f,%.1f)\n", va2, dr_r16[va2], dr_r16[va2+2], dr_r16[va2+4], f64[x2], f64[y2] ]
		z0 : f32 [ gx_scr[ o0 + 2 ] ]
		z1 : f32 [ gx_scr[ o1 + 2 ] ]
		z2 : f32 [ gx_scr[ o2 + 2 ] ]
		w0v : f32 [ gx_scr[ o0 + 3 ] ]
		w1v : f32 [ gx_scr[ o1 + 3 ] ]
		w2v : f32 [ gx_scr[ o2 + 3 ] ]
		u0 : f32 [ gx_scr[ o0 + 4 ] ]
		u1 : f32 [ gx_scr[ o1 + 4 ] ]
		u2 : f32 [ gx_scr[ o2 + 4 ] ]
		t0 : f32 [ gx_scr[ o0 + 5 ] ]
		t1 : f32 [ gx_scr[ o1 + 5 ] ]
		t2 : f32 [ gx_scr[ o2 + 5 ] ]
		r0 : f32 [ gx_scr[ o0 + 6 ] ]
		r1 : f32 [ gx_scr[ o1 + 6 ] ]
		r2 : f32 [ gx_scr[ o2 + 6 ] ]
		g0 : f32 [ gx_scr[ o0 + 7 ] ]
		g1 : f32 [ gx_scr[ o1 + 7 ] ]
		g2 : f32 [ gx_scr[ o2 + 7 ] ]
		b0 : f32 [ gx_scr[ o0 + 8 ] ]
		b1 : f32 [ gx_scr[ o1 + 8 ] ]
		b2 : f32 [ gx_scr[ o2 + 8 ] ]
		a0 : f32 [ gx_scr[ o0 + 9 ] ]
		a1 : f32 [ gx_scr[ o1 + 9 ] ]
		a2 : f32 [ gx_scr[ o2 + 9 ] ]
		zon : bool [ (gx_geom & 1) != 0 ]
		zdec : bool [ ((gx_oth_l >> 10) & 3) == 3 ]          # decal: z must match surface
		ton : bool [ gx_texon && gx_cc_tex ]
		son : bool [ gx_cc_shade ]
		gx_bl_add = (((gx_oth_l >> 22) & 3) == 1) && (((gx_oth_l >> 18) & 3) == 2)
		gx_bl_xlu = (((gx_oth_l >> 22) & 3) == 1) && (((gx_oth_l >> 18) & 3) == 0)
		for [ py: i32 by0, py < by1, py += 1 ]
			fy : f32 [ f32[ py ] + 0.5 ]
			for [ px: i32 bx0, px < bx1, px += 1 ]
				fx : f32 [ f32[ px ] + 0.5 ]
				e0 : f32 [ (x1 - x0) * (fy - y0) - (y1 - y0) * (fx - x0) ]
				e1 : f32 [ (x2 - x1) * (fy - y1) - (y2 - y1) * (fx - x1) ]
				e2 : f32 [ (x0 - x2) * (fy - y2) - (y0 - y2) * (fx - x2) ]
				inside : bool [ (tarea > 0.0) ? (e0 >= 0.0 && e1 >= 0.0 && e2 >= 0.0) : (e0 <= 0.0 && e1 <= 0.0 && e2 <= 0.0) ]
				if [ inside ]
					l0 : f32 [ e1 * inv ]
					l1 : f32 [ e2 * inv ]
					l2 : f32 [ e0 * inv ]
					zv : f32 [ l0 * z0 + l1 * z1 + l2 * z2 ]
					zi : i32 [ py * 1280 + px ]
					zok : bool [ true ]
					if [ zon ]
						if [ zdec ]
							dz9 : f32 [ zv - zbuf[ zi ] ]
							if [ dz9 > 0.0015 || dz9 < -0.0015 ] zok = false
						el
							if [ zv > zbuf[ zi ] ] zok = false
					if [ zok ]
						cr : f32 [ 1.0 ]
						cg : f32 [ 1.0 ]
						cb : f32 [ 1.0 ]
						ca : f32 [ 1.0 ]
						if [ son ]
							cr = l0 * r0 + l1 * r1 + l2 * r2
							cg = l0 * g0 + l1 * g1 + l2 * g2
							cb = l0 * b0 + l1 * b1 + l2 * b2
							ca = l0 * a0 + l1 * a1 + l2 * a2
						skip : bool [ false ]
						pxa : u32 [ 255 ]
						if [ ton ]
							iw : f32 [ l0 * w0v + l1 * w1v + l2 * w2v ]
							uu : f32 [ (l0 * u0 + l1 * u1 + l2 * u2) / iw ]
							vv : f32 [ (l0 * t0 + l1 * t1 + l2 * t2) / iw ]
							tx : u32 [ gx_texel[ i32[ uu ], i32[ vv ] ] ]
							ta : u32 [ tx & 0xFF ]
							if [ gx_cc_lerp ]                # (PRIM-SHADE)*T0+SHADE
								pr9 : f32 [ f32[ (gx_prim >> 24) & 0xFF ] / 255.0 ]
								pg9 : f32 [ f32[ (gx_prim >> 16) & 0xFF ] / 255.0 ]
								pb9 : f32 [ f32[ (gx_prim >> 8) & 0xFF ] / 255.0 ]
								txr : f32 [ f32[ (tx >> 24) & 0xFF ] / 255.0 ]
								txg : f32 [ f32[ (tx >> 16) & 0xFF ] / 255.0 ]
								txb : f32 [ f32[ (tx >> 8) & 0xFF ] / 255.0 ]
								cr = cr + (pr9 - cr) * txr
								cg = cg + (pg9 - cg) * txg
								cb = cb + (pb9 - cb) * txb
							el [ gx_cc_add ]                 # highlight: shade + texel
								cr += f32[ (tx >> 24) & 0xFF ] / 255.0
								cg += f32[ (tx >> 16) & 0xFF ] / 255.0
								cb += f32[ (tx >> 8) & 0xFF ] / 255.0
								if [ cr > 1.0 ] cr = 1.0
								if [ cg > 1.0 ] cg = 1.0
								if [ cb > 1.0 ] cb = 1.0
							el
								if [ gx_bl_xlu ]
									if [ ta == 0 ] skip = true
									pxa = u32[ f32[ ta ] * ca ]
								el
									if [ ta < 128 && (ca < 0.99 || ta == 0) ] skip = true
								cr = cr * f32[ (tx >> 24) & 0xFF ] / 255.0
								cg = cg * f32[ (tx >> 16) & 0xFF ] / 255.0
								cb = cb * f32[ (tx >> 8) & 0xFF ] / 255.0
						el
							if [ ca < 0.02 ] skip = true
							pxa = u32[ ca * 255.0 ]
						if [ gx_cc_prim && !gx_cc_lerp && !skip ]
							cr = cr * f32[ (gx_prim >> 24) & 0xFF ] / 255.0
							cg = cg * f32[ (gx_prim >> 16) & 0xFF ] / 255.0
							cb = cb * f32[ (gx_prim >> 8) & 0xFF ] / 255.0
						if [ !skip ]
							if [ zon && !zdec ] zbuf[ zi ] = zv
							gx_putpix[ px, py, u32[ cr * 255.0 ], u32[ cg * 255.0 ], u32[ cb * 255.0 ], pxa ]

	func gx_raster_done []
		gx_bl_add = false
		gx_bl_xlu = false

	# near-clip the triangle in gx_clip (n verts), project, fan-rasterize
	func gx_tri_out [ nin: i32 ]
		# clip against cw > eps
		no : i32 [ 0 ]
		for [ i: i32 0, i < nin, i += 1 ]
			j : i32 [ (i + 1 < nin) ? (i + 1) : 0 ]
			ib : i32 [ i * 10 ]
			jb : i32 [ j * 10 ]
			wi : f32 [ gx_clip[ ib + 3 ] ]
			wj : f32 [ gx_clip[ jb + 3 ] ]
			ini : bool [ wi > 0.05 ]
			inj : bool [ wj > 0.05 ]
			if [ ini && no < 8 ]
				oo : i32 [ no * 10 ]
				for [ k: i32 0, k < 10, k += 1 ]
					gx_scr[ oo + k ] = gx_clip[ ib + k ]
				no += 1
			if [ ((ini && !inj) || (!ini && inj)) && no < 8 ]
				tt : f32 [ (0.05 - wi) / (wj - wi) ]
				oo2 : i32 [ no * 10 ]
				for [ k: i32 0, k < 10, k += 1 ]
					gx_scr[ oo2 + k ] = gx_clip[ ib + k ] + (gx_clip[ jb + k ] - gx_clip[ ib + k ]) * tt
				no += 1
		if [ no < 3 ] return
		# project all verts in place: sx sy sz invw u/w v/w r g b a
		vsx : f32 [ gx_vp[ 0 ] ]
		vsy : f32 [ gx_vp[ 1 ] ]
		vtx0 : f32 [ gx_vp[ 3 ] ]
		vty0 : f32 [ gx_vp[ 4 ] ]
		ssf : f32 [ f32[ gx_ss ] ]
		for [ i: i32 0, i < no, i += 1 ]
			ob : i32 [ i * 10 ]
			cw : f32 [ gx_scr[ ob + 3 ] ]
			iw : f32 [ 1.0 / cw ]
			ndx : f32 [ gx_scr[ ob ] * iw ]
			ndy : f32 [ gx_scr[ ob + 1 ] * iw ]
			ndz : f32 [ gx_scr[ ob + 2 ] * iw ]
			gx_scr[ ob ]     = (vtx0 + ndx * vsx) * ssf
			gx_scr[ ob + 1 ] = (vty0 + ndy * vsy) * ssf
			gx_scr[ ob + 2 ] = (ndz + 1.0) * 0.5
			gx_scr[ ob + 3 ] = iw
			gx_scr[ ob + 4 ] = gx_scr[ ob + 4 ] * iw
			gx_scr[ ob + 5 ] = gx_scr[ ob + 5 ] * iw
		for [ i: i32 2, i < no, i += 1 ]
			gx_raster[ 0, (i - 1) * 10, i * 10 ]
		gx_raster_done[]

	# ---------------- GPU batching: palettes + atlas + vertex emit ----------------
	func st_put [ x: i32, y: i32, c0: f32, c1: f32, c2: f32, c3: f32 ]
		bi : i32 [ (y * 2048 + x) * 4 ]
		st_tex[ bi ]     = c0
		st_tex[ bi + 1 ] = c1
		st_tex[ bi + 2 ] = c2
		st_tex[ bi + 3 ] = c3

	# ensure the current MVP (with the game's viewport folded in, matching the
	# CPU raster: screen = vtrans + ndc*vscale, then mapped to NDC) is in the
	# matrix palette (row 0, 4 texels/slot)
	func st_mtx_ensure [] -> i32
		if [ gx_mslot >= 0 ] return gx_mslot
		if [ st_mtx_n >= 511 ]
			if [ dbg_on ] printf[ "n64 OVERFLOW mtx palette f%u\n", frames ]
			return 510
		gx_mmul[ (1 + gx_mvi) * 16, 0, 224 ]
		for [ i: i32 0, i < 16, i += 1 ]
			gx_mats[ 192 + i ] = 0.0
		gx_mats[ 192 ]      = gx_vp[ 0 ] / 160.0
		gx_mats[ 192 + 5 ]  = gx_vp[ 1 ] / 120.0
		gx_mats[ 192 + 10 ] = 1.0
		gx_mats[ 192 + 12 ] = gx_vp[ 3 ] / 160.0 - 1.0
		gx_mats[ 192 + 13 ] = gx_vp[ 4 ] / 120.0 - 1.0
		gx_mats[ 192 + 15 ] = 1.0
		gx_mmul[ 224, 192, 224 ]
		sl : i32 [ st_mtx_n ]
		st_mtx_n += 1
		for [ rr: i32 0, rr < 4, rr += 1 ]
			st_put[ sl * 4 + rr, 0, gx_mats[ 224 + rr * 4 ], gx_mats[ 224 + rr * 4 + 1 ], gx_mats[ 224 + rr * 4 + 2 ], gx_mats[ 224 + rr * 4 + 3 ] ]
		gx_mslot = sl
		return sl

	# ensure current light state is in the light palette (row 1, 8 texels/set)
	func st_ls_ensure [] -> i32
		if [ gx_lsslot >= 0 ] return gx_lsslot
		if [ st_ls_n >= 255 ]
			if [ dbg_on ] printf[ "n64 OVERFLOW light palette f%u\n", frames ]
			return 254
		sl : i32 [ st_ls_n ]
		st_ls_n += 1
		na2 : i32 [ gx_nl * 6 ]
		nl2 : i32 [ (gx_nl > 3) ? 3 : gx_nl ]
		st_put[ sl * 8, 1, gx_lights[ na2 ], gx_lights[ na2 + 1 ], gx_lights[ na2 + 2 ], f32[ nl2 ] ]
		for [ li: i32 0, li < nl2, li += 1 ]
			lb4 : i32 [ li * 6 ]
			st_put[ sl * 8 + 1 + li * 2, 1, gx_lights[ lb4 ], gx_lights[ lb4 + 1 ], gx_lights[ lb4 + 2 ], 0.0 ]
			st_put[ sl * 8 + 2 + li * 2, 1, gx_lights[ lb4 + 3 ], gx_lights[ lb4 + 4 ], gx_lights[ lb4 + 5 ], 0.0 ]
		if [ dbg_on && frames == 449 ]
			printf[ "n64 LIGHTSET slot=%d nl=%d amb=(%.2f,%.2f,%.2f) L0col=(%.2f,%.2f,%.2f) f%u\n", sl, gx_nl, f64[ gx_lights[ na2 ] ], f64[ gx_lights[ na2 + 1 ] ], f64[ gx_lights[ na2 + 2 ] ], f64[ gx_lights[ 0 ] ], f64[ gx_lights[ 1 ] ], f64[ gx_lights[ 2 ] ], frames ]
		gx_lsslot = sl
		return sl

	# decode the render tile into the atlas (cached by content hash); returns
	# the packed rect via atk_rect index
	func at_ensure [] -> i32
		tn : i32 [ gx_tile ]
		tw : i32 [ i32[ (tl_lrs[ tn ] - tl_uls[ tn ]) >> 2 ] + 1 ]
		th : i32 [ i32[ (tl_lrt[ tn ] - tl_ult[ tn ]) >> 2 ] + 1 ]
		# degenerate tilesize (fonts/sprites relying on wrap): mask defines extent
		if [ tw <= 1 && tl_masks[ tn ] > 0 ] tw = 1 << i32[ tl_masks[ tn ] ]
		if [ th <= 1 && tl_maskt[ tn ] > 0 ] th = 1 << i32[ tl_maskt[ tn ] ]
		if [ tw < 1 ] tw = 1
		if [ th < 1 ] th = 1
		if [ tw > 256 ] tw = 256
		if [ th > 256 ] th = 256
		# content hash: tile bytes + descriptor
		lnb : i32 [ i32[ tl_line[ tn ] ] * 8 ]
		tb : i32 [ i32[ tl_tmem[ tn ] ] * 8 ]
		nb : i32 [ lnb * th ]
		if [ nb > 4096 ] nb = 4096
		hh : i64 [ 1469598103934665603 ]
		for [ i: i32 0, i < nb, i += 1 ]
			hh = (hh ^ i64[ u32[ tmem[ (tb + i) & 0xFFF ] ] ]) * 1099511628211
		hh = (hh ^ i64[ tl_fmt[ tn ] ]) * 1099511628211
		hh = (hh ^ i64[ tl_siz[ tn ] ]) * 1099511628211
		hh = (hh ^ i64[ u32[ tw ] ]) * 1099511628211
		hh = (hh ^ i64[ u32[ th ] ]) * 1099511628211
		hh = (hh ^ i64[ tl_pal[ tn ] ]) * 1099511628211
		if [ tl_fmt[ tn ] == 2 ]                             # CI: palette contents matter
			for [ i: i32 0, i < 256, i += 1 ]
				hh = (hh ^ i64[ gx_tlut[ i ] ]) * 1099511628211
		for [ i: i32 0, i < atk_n, i += 1 ]
			if [ atk_key[ i ] == hh ] return i
		# pack: shelf allocator
		if [ atk_n >= 255 || at_y + th > 1024 ]
			atk_n = 0
			at_x = 0
			at_y = 0
			at_rowh = 0
		if [ at_x + tw > 1024 ]
			at_x = 0
			at_y += at_rowh
			at_rowh = 0
			if [ at_y + th > 1024 ]
				atk_n = 0
				at_y = 0
		if [ th > at_rowh ] at_rowh = th
		rx : i32 [ at_x ]
		ry : i32 [ at_y ]
		at_x += tw
		us4 : i32 [ i32[ tl_uls[ tn ] >> 2 ] ]
		ut4 : i32 [ i32[ tl_ult[ tn ] >> 2 ] ]
		for [ ty: i32 0, ty < th, ty += 1 ]
			for [ txx: i32 0, txx < tw, txx += 1 ]
				pxv : u32 [ gx_texel[ txx + us4, ty + ut4 ] ]
				at_stage[ (ry + ty) * 1024 + rx + txx ] = 0xFF000000 & ((pxv & 0xFF) * 0x1000000) | (((pxv >> 8) & 0xFF) << 16) | (((pxv >> 16) & 0xFF) << 8) | ((pxv >> 24) & 0xFF)
		at_dirty = true
		if [ dbg_on ]
			printf[ "n64 ATLAS fmt=%u siz=%u line=%u tmem=%u ts=%ux%u uls=%u ult=%u mask=%u,%u cm=%u,%u -> %dx%d f%u\n", tl_fmt[tn], tl_siz[tn], tl_line[tn], tl_tmem[tn], (tl_lrs[tn] - tl_uls[tn]) / 4 + 1, (tl_lrt[tn] - tl_ult[tn]) / 4 + 1, tl_uls[tn] >> 2, tl_ult[tn] >> 2, tl_masks[tn], tl_maskt[tn], tl_cms[tn], tl_cmt[tn], tw, th, frames ]
		if [ dbg_on && tl_fmt[tn] == 0 && tl_siz[tn] == 2 && tw == 32 && frames >= 448 && frames < 452 && at_dbg < 3 ]
			at_dbg += 1
			tbz : i32 [ i32[ tl_tmem[ tn ] ] * 8 ]
			printf[ "n64 ATBAKE src[0..7]=%02X %02X %02X %02X %02X %02X %02X %02X px0=%08X px1=%08X gx_tile=%d f%u\n", u32[ tmem[ (tbz+0)&0xFFF ] ], u32[ tmem[ (tbz+1)&0xFFF ] ], u32[ tmem[ (tbz+2)&0xFFF ] ], u32[ tmem[ (tbz+3)&0xFFF ] ], u32[ tmem[ (tbz+4)&0xFFF ] ], u32[ tmem[ (tbz+5)&0xFFF ] ], u32[ tmem[ (tbz+6)&0xFFF ] ], u32[ tmem[ (tbz+7)&0xFFF ] ], gx_texel[ us4, ut4 ], gx_texel[ us4+1, ut4 ], gx_tile, frames ]
		sl : i32 [ atk_n ]
		atk_key[ sl ] = hh
		atk_rect[ sl * 4 ]     = rx
		atk_rect[ sl * 4 + 1 ] = ry
		atk_rect[ sl * 4 + 2 ] = tw
		atk_rect[ sl * 4 + 3 ] = th
		atk_n += 1
		return sl

	# ensure current material (atlas rect + wrap + prim/env) in row 2
	func st_mat_ensure [] -> i32
		if [ gx_matslot >= 0 ] return gx_matslot
		if [ st_mat_n >= 511 ]
			if [ dbg_on ] printf[ "n64 OVERFLOW material palette f%u\n", frames ]
			return 510
		sl : i32 [ st_mat_n ]
		st_mat_n += 1
		tn : i32 [ gx_tile ]
		asl : i32 [ 0 ]
		if [ gx_texon && gx_cc_tex ] asl = at_ensure[]
		rb : i32 [ asl * 4 ]
		st_put[ sl * 4, 2, f32[ atk_rect[ rb ] ], f32[ atk_rect[ rb + 1 ] ], f32[ atk_rect[ rb + 2 ] ], f32[ atk_rect[ rb + 3 ] ] ]
		wms : f32 [ 0.0 ]
		wmt : f32 [ 0.0 ]
		if [ tl_masks[ tn ] > 0 ] wms = f32[ 1 << i32[ tl_masks[ tn ] ] ]
		if [ tl_maskt[ tn ] > 0 ] wmt = f32[ 1 << i32[ tl_maskt[ tn ] ] ]
		clS : i32 [ i32[ (tl_lrs[ tn ] - tl_uls[ tn ]) >> 2 ] + 1 ]
		clT : i32 [ i32[ (tl_lrt[ tn ] - tl_ult[ tn ]) >> 2 ] + 1 ]
		if [ clS < 1 ] clS = 1
		if [ clT < 1 ] clT = 1
		st_put[ sl * 4 + 1, 2, wms, wmt, f32[ tl_cms[ tn ] + u32[ clS ] * 4 ], f32[ tl_cmt[ tn ] + u32[ clT ] * 4 ] ]
		st_put[ sl * 4 + 2, 2, f32[ (gx_prim >> 24) & 0xFF ] / 255.0, f32[ (gx_prim >> 16) & 0xFF ] / 255.0, f32[ (gx_prim >> 8) & 0xFF ] / 255.0, f32[ gx_prim & 0xFF ] / 255.0 ]
		st_put[ sl * 4 + 3, 2, f32[ (gx_env >> 24) & 0xFF ] / 255.0, f32[ (gx_env >> 16) & 0xFF ] / 255.0, f32[ (gx_env >> 8) & 0xFF ] / 255.0, f32[ gx_env & 0xFF ] / 255.0 ]
		if [ dbg_on && gx_texon && gx_cc_tex && frames >= 448 && frames < 452 && mr_dbg < 6 ]
			mr_dbg += 1
			printf[ "n64 MATRECT mat=%d asl=%d rect=(%d,%d,%d,%d) wms=%.0f cm=%u,%u fmt=%u siz=%u f%u\n", sl, asl, atk_rect[ rb ], atk_rect[ rb + 1 ], atk_rect[ rb + 2 ], atk_rect[ rb + 3 ], f64[ wms ], tl_cms[ tn ], tl_cmt[ tn ], tl_fmt[ tn ], tl_siz[ tn ], frames ]
		gx_matslot = sl
		return sl

	# combiner/blend flags word for the current state (+lit/texgen per-vertex)
	func gx_flags [ lit: bool ] -> u32
		fl : u32 [ 0 ]
		if [ lit ] fl = fl | 1
		ton : bool [ gx_texon && gx_cc_tex ]
		if [ ton ] fl = fl | 4
		if [ gx_cc_prim && !gx_cc_lerp ] fl = fl | 8
		cc : u32 [ 0 ]
		if [ gx_cc_lerp ] cc = 1
		el [ gx_cc_add ] cc = 2
		el [ ton && !gx_cc_shade ] cc = 3
		fl = fl | (cc << 4)
		if [ gx_geom & 0x2000 ] fl = fl | 1024
		if [ gx_geom & 0x1000 ] fl = fl | 2048
		if [ (gx_geom & 1) == 0 ] fl = fl | 4096
		xl : bool [ (((gx_oth_l >> 22) & 3) == 1) && (((gx_oth_l >> 18) & 3) == 0) ]
		ad : bool [ (((gx_oth_l >> 22) & 3) == 1) && (((gx_oth_l >> 18) & 3) == 2) ]
		if [ ad ] fl = fl | 512
		el [ xl ] fl = fl | 256
		el fl = fl | 128
		if [ ((gx_oth_h >> 20) & 3) >= 2 ] fl = fl | 8192   # FILL/COPY cycle = screen clear/blit: force to far background
		if [ dbg_on && ton && frames >= 448 && frames < 452 && mr_dbg < 12 ]
			printf[ "n64 FLAGS fl=%X geom=%08X oth_l=%08X lerp=%d add=%d shade=%d prim=%d tex=%d texon=%d xl=%d ad=%d f%u\n", fl, gx_geom, gx_oth_l, gx_cc_lerp, gx_cc_add, gx_cc_shade, gx_cc_prim, gx_cc_tex, gx_texon, xl, ad, frames ]
		return fl

	# emit one vertex (13 floats) from a raw slot; matrix/light state was
	# captured per slot at VTX time (RSP transforms at load, not at TRI)
	func gxe_vert [ sl: i32, fl: u32, mat: i32 ]
		if [ gxv_n >= 131064 ]
			if [ dbg_on && (gxv_n & 1023) == 0 ] printf[ "n64 OVERFLOW vertex buffer f%u\n", frames ]
			return
		rb : i32 [ sl * 12 ]
		flv : u32 [ fl ]
		if [ gx_vraw[ rb + 9 ] > 0.5 ]
			flv = flv | 1
			if [ gx_geom & 0x40000 ] flv = flv | 2
		if [ !gx_zset && (flv & 4096) == 0 && (flv & 8192) == 0 ]   # first z-enabled (non-clear) vertex → backdrop split
			gx_zsplit = gxv_n
			gx_zset = true
		ob : i32 [ gxv_n * 13 ]
		gxv[ ob ]      = gx_vraw[ rb ]
		gxv[ ob + 1 ]  = gx_vraw[ rb + 1 ]
		gxv[ ob + 2 ]  = gx_vraw[ rb + 2 ]
		gxv[ ob + 3 ]  = gx_vraw[ rb + 5 ]
		gxv[ ob + 4 ]  = gx_vraw[ rb + 6 ]
		gxv[ ob + 5 ]  = gx_vraw[ rb + 7 ]
		gxv[ ob + 6 ]  = gx_vraw[ rb + 8 ]
		gxv[ ob + 7 ]  = gx_vraw[ rb + 3 ]
		gxv[ ob + 8 ]  = gx_vraw[ rb + 4 ]
		gxv[ ob + 9 ]  = gx_vraw[ rb + 10 ]
		gxv[ ob + 10 ] = f32[ flv ]
		gxv[ ob + 11 ] = gx_vraw[ rb + 11 ]
		gxv[ ob + 12 ] = f32[ mat ]
		if [ dbg_on && frames == 449 && uv_dbg < 16 ]
			uv_dbg += 1
			printf[ "n64 VTXUV flv=%X lit=%d col/n=(%.2f,%.2f,%.2f) vls=%.0f pos=(%.1f,%.1f) f%u\n", flv, flv & 1, f64[ gx_vraw[ rb + 5 ] ], f64[ gx_vraw[ rb + 6 ] ], f64[ gx_vraw[ rb + 7 ] ], f64[ gx_vraw[ rb + 11 ] ], f64[ gx_vraw[ rb ] ], f64[ gx_vraw[ rb + 1 ] ], frames ]
		gxv_n += 1

	# PN-triangle (curved point-normal) smoothing for low-poly lit meshes.
	# object-space tessellation; corners/UVs preserved. every lit tri is
	# tessellated — crack avoidance is per-edge (see gx_pn_edge) so smoothed
	# and hard-edge neighbors always share identical edge points.
	func gx_pn_gate [ i0: i32, i1: i32, i2: i32 ] -> bool
		r0 : i32 [ i0 * 12 ]
		r1 : i32 [ i1 * 12 ]
		r2 : i32 [ i2 * 12 ]
		if [ gx_vraw[ r0 + 9 ] < 0.5 ] return false
		if [ gx_vraw[ r1 + 9 ] < 0.5 ] return false
		if [ gx_vraw[ r2 + 9 ] < 0.5 ] return false
		return true

	# gather corner c (0..2) from raw slot sl into pn_P/pn_N/pn_at
	func gx_pn_gather [ c: i32, sl: i32 ]
		rb : i32 [ sl * 12 ]
		pb : i32 [ c * 3 ]
		pn_P[ pb ]     = gx_vraw[ rb ]
		pn_P[ pb + 1 ] = gx_vraw[ rb + 1 ]
		pn_P[ pb + 2 ] = gx_vraw[ rb + 2 ]
		nx : f32 [ gx_vraw[ rb + 5 ] ]
		ny : f32 [ gx_vraw[ rb + 6 ] ]
		nz : f32 [ gx_vraw[ rb + 7 ] ]
		nl : f32 [ sqrt[ nx * nx + ny * ny + nz * nz ] ]
		if [ nl < 0.0001 ] nl = 1.0
		pn_N[ pb ]     = nx / nl
		pn_N[ pb + 1 ] = ny / nl
		pn_N[ pb + 2 ] = nz / nl
		ab : i32 [ c * 5 ]
		pn_at[ ab ]     = gx_vraw[ rb + 3 ]
		pn_at[ ab + 1 ] = gx_vraw[ rb + 4 ]
		pn_at[ ab + 2 ] = gx_vraw[ rb + 8 ]
		pn_at[ ab + 3 ] = gx_vraw[ rb + 10 ]
		pn_at[ ab + 4 ] = gx_vraw[ rb + 11 ]

	# edge control point b_ij = (2Pi + Pj - w*Ni)/3, w = dot(Pj-Pi, Ni).
	# depends only on the two shared endpoints so neighbors match (watertight).
	# hard edge (endpoint normals disagree) collapses to the straight 1/3 point.
	func gx_pn_edge [ i: i32, j: i32, ci: i32 ]
		bi : i32 [ i * 3 ]
		bj : i32 [ j * 3 ]
		co : i32 [ ci * 3 ]
		nd : f32 [ pn_N[ bi ] * pn_N[ bj ] + pn_N[ bi + 1 ] * pn_N[ bj + 1 ] + pn_N[ bi + 2 ] * pn_N[ bj + 2 ] ]
		if [ nd < gx_smooth_cos ]
			pn_cp[ co ]     = (2.0 * pn_P[ bi ]     + pn_P[ bj ]) / 3.0
			pn_cp[ co + 1 ] = (2.0 * pn_P[ bi + 1 ] + pn_P[ bj + 1 ]) / 3.0
			pn_cp[ co + 2 ] = (2.0 * pn_P[ bi + 2 ] + pn_P[ bj + 2 ]) / 3.0
			return
		dx : f32 [ pn_P[ bj ]     - pn_P[ bi ] ]
		dy : f32 [ pn_P[ bj + 1 ] - pn_P[ bi + 1 ] ]
		dz : f32 [ pn_P[ bj + 2 ] - pn_P[ bi + 2 ] ]
		w : f32 [ dx * pn_N[ bi ] + dy * pn_N[ bi + 1 ] + dz * pn_N[ bi + 2 ] ]
		pn_cp[ co ]     = (2.0 * pn_P[ bi ]     + pn_P[ bj ]     - w * pn_N[ bi ]) / 3.0
		pn_cp[ co + 1 ] = (2.0 * pn_P[ bi + 1 ] + pn_P[ bj + 1 ] - w * pn_N[ bi + 1 ]) / 3.0
		pn_cp[ co + 2 ] = (2.0 * pn_P[ bi + 2 ] + pn_P[ bj + 2 ] - w * pn_N[ bi + 2 ]) / 3.0

	# evaluate cubic Bezier triangle at barycentric (l0,l1,l2); emit one vertex
	func gxe_pn [ l0: f32, l1: f32, l2: f32, fl: u32, mat: i32 ]
		if [ gxv_n >= 131064 ] return
		flv : u32 [ fl | 1 ]
		if [ gx_geom & 0x40000 ] flv = flv | 2
		if [ !gx_zset && (flv & 4096) == 0 && (flv & 8192) == 0 ]
			gx_zsplit = gxv_n
			gx_zset = true
		bez : local f32 [ 10 ]
		bez[ 0 ] = l0 * l0 * l0
		bez[ 1 ] = l1 * l1 * l1
		bez[ 2 ] = l2 * l2 * l2
		bez[ 3 ] = 3.0 * l0 * l0 * l1
		bez[ 4 ] = 3.0 * l0 * l1 * l1
		bez[ 5 ] = 3.0 * l1 * l1 * l2
		bez[ 6 ] = 3.0 * l1 * l2 * l2
		bez[ 7 ] = 3.0 * l0 * l2 * l2
		bez[ 8 ] = 3.0 * l0 * l0 * l2
		bez[ 9 ] = 6.0 * l0 * l1 * l2
		px : f32 [ 0.0 ]
		py : f32 [ 0.0 ]
		pz : f32 [ 0.0 ]
		for [ k: i32 0, k < 10, k += 1 ]
			cb : i32 [ k * 3 ]
			px += bez[ k ] * pn_cp[ cb ]
			py += bez[ k ] * pn_cp[ cb + 1 ]
			pz += bez[ k ] * pn_cp[ cb + 2 ]
		nx : f32 [ l0 * pn_N[ 0 ] + l1 * pn_N[ 3 ] + l2 * pn_N[ 6 ] ]
		ny : f32 [ l0 * pn_N[ 1 ] + l1 * pn_N[ 4 ] + l2 * pn_N[ 7 ] ]
		nz : f32 [ l0 * pn_N[ 2 ] + l1 * pn_N[ 5 ] + l2 * pn_N[ 8 ] ]
		nl : f32 [ sqrt[ nx * nx + ny * ny + nz * nz ] ]
		if [ nl < 0.0001 ] nl = 1.0
		au : f32 [ l0 * pn_at[ 0 ] + l1 * pn_at[ 5 ]  + l2 * pn_at[ 10 ] ]
		av : f32 [ l0 * pn_at[ 1 ] + l1 * pn_at[ 6 ]  + l2 * pn_at[ 11 ] ]
		aa : f32 [ l0 * pn_at[ 2 ] + l1 * pn_at[ 7 ]  + l2 * pn_at[ 12 ] ]
		vls : f32 [ l0 * pn_at[ 4 ] + l1 * pn_at[ 9 ] + l2 * pn_at[ 14 ] ]
		ob : i32 [ gxv_n * 13 ]
		gxv[ ob ]      = px
		gxv[ ob + 1 ]  = py
		gxv[ ob + 2 ]  = pz
		gxv[ ob + 3 ]  = nx / nl
		gxv[ ob + 4 ]  = ny / nl
		gxv[ ob + 5 ]  = nz / nl
		gxv[ ob + 6 ]  = aa
		gxv[ ob + 7 ]  = au
		gxv[ ob + 8 ]  = av
		gxv[ ob + 9 ]  = pn_at[ 3 ]
		gxv[ ob + 10 ] = f32[ flv ]
		gxv[ ob + 11 ] = vls
		gxv[ ob + 12 ] = f32[ mat ]
		gxv_n += 1

	# emit one tessellated vertex at grid coords (a,b) of an L-subdivided tri
	func gx_pn_v [ ga: i32, gb: i32, L: i32, fl: u32, mat: i32 ]
		fL : f32 [ f32[ L ] ]
		l1 : f32 [ f32[ ga ] / fL ]
		l2 : f32 [ f32[ gb ] / fL ]
		l0 : f32 [ 1.0 - l1 - l2 ]
		gxe_pn[ l0, l1, l2, fl, mat ]

	# build the 10 control points then tessellate into L^2 sub-triangles
	func gx_pn_tri [ i0: i32, i1: i32, i2: i32, fl: u32, mat: i32 ]
		gx_pn_gather[ 0, i0 ]
		gx_pn_gather[ 1, i1 ]
		gx_pn_gather[ 2, i2 ]
		for [ d: i32 0, d < 3, d += 1 ]
			pn_cp[ d ]     = pn_P[ d ]
			pn_cp[ 3 + d ] = pn_P[ 3 + d ]
			pn_cp[ 6 + d ] = pn_P[ 6 + d ]
		gx_pn_edge[ 0, 1, 3 ]
		gx_pn_edge[ 1, 0, 4 ]
		gx_pn_edge[ 1, 2, 5 ]
		gx_pn_edge[ 2, 1, 6 ]
		gx_pn_edge[ 2, 0, 7 ]
		gx_pn_edge[ 0, 2, 8 ]
		for [ d: i32 0, d < 3, d += 1 ]
			ee : f32 [ (pn_cp[ 9 + d ] + pn_cp[ 12 + d ] + pn_cp[ 15 + d ] + pn_cp[ 18 + d ] + pn_cp[ 21 + d ] + pn_cp[ 24 + d ]) / 6.0 ]
			vv : f32 [ (pn_P[ d ] + pn_P[ 3 + d ] + pn_P[ 6 + d ]) / 3.0 ]
			pn_cp[ 27 + d ] = ee + (ee - vv) * 0.5
		L : i32 [ smooth ]
		if [ L < 1 ] L = 1
		for [ ga: i32 0, ga < L, ga += 1 ]
			for [ gb: i32 0, gb < L - ga, gb += 1 ]
				gx_pn_v[ ga, gb, L, fl, mat ]
				gx_pn_v[ ga + 1, gb, L, fl, mat ]
				gx_pn_v[ ga, gb + 1, L, fl, mat ]
				if [ gb < L - 1 - ga ]
					gx_pn_v[ ga + 1, gb, L, fl, mat ]
					gx_pn_v[ ga + 1, gb + 1, L, fl, mat ]
					gx_pn_v[ ga, gb + 1, L, fl, mat ]

	# emit a screen-space quad (ortho matrix slot 0): pixel coords + z + uv + color
	func gxe_quad [ qx0: f32, qy0: f32, qx1: f32, qy1: f32, zz: f32, u0: f32, v0: f32, u1: f32, v1: f32, cr: f32, cg: f32, cb: f32, fl: u32, mat: i32 ]
		if [ gxv_n >= 131058 ] return
		for [ k: i32 0, k < 6, k += 1 ]
			cx : f32 [ ((k == 1 || k == 2 || k == 4)) ? qx1 : qx0 ]
			cy : f32 [ ((k == 2 || k == 4 || k == 5)) ? qy1 : qy0 ]
			cu : f32 [ ((k == 1 || k == 2 || k == 4)) ? u1 : u0 ]
			cv : f32 [ ((k == 2 || k == 4 || k == 5)) ? v1 : v0 ]
			ob : i32 [ gxv_n * 13 ]
			gxv[ ob ]      = cx
			gxv[ ob + 1 ]  = cy
			gxv[ ob + 2 ]  = zz
			gxv[ ob + 3 ]  = cr
			gxv[ ob + 4 ]  = cg
			gxv[ ob + 5 ]  = cb
			gxv[ ob + 6 ]  = 1.0
			gxv[ ob + 7 ]  = cu
			gxv[ ob + 8 ]  = cv
			gxv[ ob + 9 ]  = 0.0
			gxv[ ob + 10 ] = f32[ fl ]
			gxv[ ob + 11 ] = 0.0
			gxv[ ob + 12 ] = f32[ mat ]
			gxv_n += 1

	func gx_tri_cmd [ i0: i32, i1: i32, i2: i32 ]
		gx_ti0 = i0
		gx_ti1 = i1
		gx_ti2 = i2
		if [ gpu_on ]
			mat : i32 [ st_mat_ensure[] ]
			fl : u32 [ gx_flags[ false ] ]
			if [ dbg_on && frames == 377 ]
				ya0 : i32 [ dr_r16[ gx_vsrc[ i0 ] + 2 ] ]
				ya1 : i32 [ dr_r16[ gx_vsrc[ i1 ] + 2 ] ]
				ya2 : i32 [ dr_r16[ gx_vsrc[ i2 ] + 2 ] ]
				if [ ya0 > 850 || ya1 > 850 || ya2 > 850 ]
					printf[ "n64 STRAND tri va=(%06X,%06X,%06X) Y=(%d,%d,%d) geom=%05X texon=%d cctex=%d prim=%08X env=%08X othl=%08X f%u\n", gx_vsrc[i0], gx_vsrc[i1], gx_vsrc[i2], ya0, ya1, ya2, gx_geom, gx_texon, gx_cc_tex, gx_prim, gx_env, gx_oth_l, frames ]
			if [ smooth > 0 && gx_pn_gate[ i0, i1, i2 ] ]
				gx_pn_tri[ i0, i1, i2, fl, mat ]
				return
			gxe_vert[ i0, fl, mat ]
			gxe_vert[ i1, fl, mat ]
			gxe_vert[ i2, fl, mat ]
			return
		s0 : i32 [ i0 * 10 ]
		s1 : i32 [ i1 * 10 ]
		s2 : i32 [ i2 * 10 ]
		if [ dbg_on && frames >= 374 && frames <= 380 && gx_vt[ s0 + 3 ] > 0.05 && gx_vt[ s1 + 3 ] > 0.05 && gx_vt[ s2 + 3 ] > 0.05 ]
			ny0 : f32 [ gx_vt[ s0 + 1 ] / gx_vt[ s0 + 3 ] ]
			ny1 : f32 [ gx_vt[ s1 + 1 ] / gx_vt[ s1 + 3 ] ]
			ny2 : f32 [ gx_vt[ s2 + 1 ] / gx_vt[ s2 + 3 ] ]
			nmax : f32 [ (ny0 > ny1) ? ((ny0 > ny2) ? ny0 : ny2) : ((ny1 > ny2) ? ny1 : ny2) ]
			nmin : f32 [ (ny0 < ny1) ? ((ny0 < ny2) ? ny0 : ny2) : ((ny1 < ny2) ? ny1 : ny2) ]
			if [ nmax > 1.05 && nmin > -0.9 && nmin < 0.9 ]
				dbg_esc += 1
				printf[ "n64 STRAND va=(%06X,%06X,%06X) objY=(%d,%d,%d) objZ=(%d,%d,%d) ndcY=(%.2f,%.2f,%.2f) w=(%.2f,%.2f,%.2f) f%u\n", gx_vsrc[i0], gx_vsrc[i1], gx_vsrc[i2], dr_r16[gx_vsrc[i0]+2], dr_r16[gx_vsrc[i1]+2], dr_r16[gx_vsrc[i2]+2], dr_r16[gx_vsrc[i0]+4], dr_r16[gx_vsrc[i1]+4], dr_r16[gx_vsrc[i2]+4], f64[ny0], f64[ny1], f64[ny2], f64[ gx_vt[s0+3] ], f64[ gx_vt[s1+3] ], f64[ gx_vt[s2+3] ], frames ]
		for [ k: i32 0, k < 10, k += 1 ]
			gx_clip[ k ]      = gx_vt[ s0 + k ]
			gx_clip[ 10 + k ] = gx_vt[ s1 + k ]
			gx_clip[ 20 + k ] = gx_vt[ s2 + k ]
		gx_tri_out[ 3 ]

	func gx_texrect [ w1: u32, w2: u32, wst: u32, wdxy: u32 ]
		xl : i32 [ i32[ (w1 >> 12) & 0xFFF ] >> 2 ]
		yl : i32 [ i32[ w1 & 0xFFF ] >> 2 ]
		tn : i32 [ i32[ (w2 >> 24) & 7 ] ]
		xh : i32 [ i32[ (w2 >> 12) & 0xFFF ] >> 2 ]
		yh : i32 [ i32[ w2 & 0xFFF ] >> 2 ]
		s0 : i32 [ i32[ (wst >> 16) & 0xFFFF ] ]
		t0 : i32 [ i32[ wst & 0xFFFF ] ]
		if [ s0 >= 0x8000 ] s0 -= 0x10000
		if [ t0 >= 0x8000 ] t0 -= 0x10000
		dsdx : i32 [ i32[ (wdxy >> 16) & 0xFFFF ] ]
		dtdy : i32 [ i32[ wdxy & 0xFFFF ] ]
		if [ dsdx >= 0x8000 ] dsdx -= 0x10000
		if [ dtdy >= 0x8000 ] dtdy -= 0x10000
		cyc : u32 [ (gx_oth_h >> 20) & 3 ]
		fdx : f32 [ f32[ dsdx ] / 1024.0 ]
		if [ cyc == 2 ] fdx = fdx / 4.0                       # copy mode packs 4x
		fdy : f32 [ f32[ dtdy ] / 1024.0 ]
		fs0 : f32 [ f32[ s0 ] / 32.0 ]
		ft0 : f32 [ f32[ t0 ] / 32.0 ]
		ot : i32 [ gx_tile ]
		gx_tile = tn
		if [ gpu_on ]
			gx_matslot = -1
			ton0 : bool [ gx_texon ]                         # texrect always textures (G_TEXTURE state is for RSP tris only)
			gx_texon = true
			mat : i32 [ st_mat_ensure[] ]
			gx_texon = ton0
			gx_matslot = -1
			du : f32 [ f32[ xl - xh ] * fdx ]
			dv : f32 [ f32[ yl - yh ] * fdy ]
			gxe_quad[ f32[ xh ], f32[ yh ], f32[ xl ], f32[ yl ], 0.02, fs0, ft0, fs0 + du, ft0 + dv, 1.0, 1.0, 1.0, 4 | (3 << 4) | 128, mat ]
			gx_tile = ot
			return
		x0c : i32 [ ((xh < gx_sx0) ? gx_sx0 : xh) * gx_ss ]
		y0c : i32 [ ((yh < gx_sy0) ? gx_sy0 : yh) * gx_ss ]
		x1c : i32 [ ((xl > gx_sx1) ? gx_sx1 : xl) * gx_ss ]
		y1c : i32 [ ((yl > gx_sy1) ? gx_sy1 : yl) * gx_ss ]
		if [ x1c > gx_ciw * gx_ss ] x1c = gx_ciw * gx_ss
		if [ y1c > 240 * gx_ss ] y1c = 240 * gx_ss
		ssf2 : f32 [ f32[ gx_ss ] ]
		for [ py: i32 y0c, py < y1c, py += 1 ]
			tv : i32 [ i32[ ft0 + (f32[ py ] / ssf2 - f32[ yh ]) * fdy ] ]
			for [ px: i32 x0c, px < x1c, px += 1 ]
				su : i32 [ i32[ fs0 + (f32[ px ] / ssf2 - f32[ xh ]) * fdx ] ]
				tx : u32 [ gx_texel[ su, tv ] ]
				if [ (tx & 0xFF) >= 128 ]
					gx_putpix[ px, py, (tx >> 24) & 0xFF, (tx >> 16) & 0xFF, (tx >> 8) & 0xFF, 255 ]
		gx_tile = ot

	func gx_fillrect [ w1: u32, w2: u32 ]
		xl : i32 [ i32[ (w1 >> 12) & 0xFFF ] >> 2 ]
		yl : i32 [ i32[ w1 & 0xFFF ] >> 2 ]
		xh : i32 [ i32[ (w2 >> 12) & 0xFFF ] >> 2 ]
		yh : i32 [ i32[ w2 & 0xFFF ] >> 2 ]
		if [ gx_cimg == gx_zimg && gx_zimg != 0 ]
			if [ !gpu_on ]
				for [ i: i32 0, i < 1280 * 960, i += 1 ]
					zbuf[ i ] = 1000000.0
			return
		if [ gpu_on ]
			pf16 : u32 [ (gx_fill >> 16) & 0xFFFF ]
			fr9 : u32 [ (pf16 >> 11) & 31 ]
			fg9 : u32 [ (pf16 >> 6) & 31 ]
			fb9 : u32 [ (pf16 >> 1) & 31 ]
			gxe_quad[ f32[ xh ], f32[ yh ], f32[ xl + 1 ], f32[ yl + 1 ], 0.998, 0.0, 0.0, 0.0, 0.0, f32[ (fr9 << 3) | (fr9 >> 2) ] / 255.0, f32[ (fg9 << 3) | (fg9 >> 2) ] / 255.0, f32[ (fb9 << 3) | (fb9 >> 2) ] / 255.0, 128 | 8192, 0 ]
			return
		px16 : u32 [ (gx_fill >> 16) & 0xFFFF ]
		fr5 : u32 [ (px16 >> 11) & 31 ]
		fg5 : u32 [ (px16 >> 6) & 31 ]
		fb5 : u32 [ (px16 >> 1) & 31 ]
		fargb : u32 [ 0xFF000000 | (((fb5 << 3) | (fb5 >> 2)) << 16) | (((fg5 << 3) | (fg5 >> 2)) << 8) | ((fr5 << 3) | (fr5 >> 2)) ]
		for [ py: i32 yh, py <= yl, py += 1 ]
			if [ py >= 0 && py < 240 ]
				for [ px: i32 xh, px <= xl, px += 1 ]
					if [ px >= 0 && px < gx_ciw ]
						off : u32 [ (gx_cimg + u32[ (py * gx_ciw + px) * 2 ]) & 0x7FFFFE ]
						rdram[ off ]     = u8[ (px16 >> 8) & 0xFF ]
						rdram[ off + 1 ] = u8[ px16 & 0xFF ]
		sy9 : i32 [ yh * gx_ss ]
		ey9 : i32 [ (yl + 1) * gx_ss ]
		sx9 : i32 [ xh * gx_ss ]
		ex9 : i32 [ (xl + 1) * gx_ss ]
		if [ sy9 < 0 ] sy9 = 0
		if [ sx9 < 0 ] sx9 = 0
		if [ ey9 > 960 ] ey9 = 960
		if [ ex9 > 1280 ] ex9 = 1280
		for [ py: i32 sy9, py < ey9, py += 1 ]
			rb9 : i32 [ py * 1280 ]
			for [ px: i32 sx9, px < ex9, px += 1 ]
				ss_buf[ rb9 + px ] = fargb
		ss_used = true

	func gfx_task []
		dp : u32 [ (u32[dmem[0xFF0]] << 24) | (u32[dmem[0xFF1]] << 16) | (u32[dmem[0xFF2]] << 8) | u32[dmem[0xFF3]] ]
		for [ i: i32 0, i < 16, i += 1 ]
			gx_seg[ i ] = 0
		gx_mvi = 0
		gx_dsp = 0
		gx_mvp_ok = false
		if [ gx_vp[ 0 ] == 0.0 ]
			gx_vp[ 0 ] = 160.0
			gx_vp[ 1 ] = -120.0
			gx_vp[ 3 ] = 160.0
			gx_vp[ 4 ] = 120.0
		gx_sx0 = 0
		gx_sy0 = 0
		gx_sx1 = 320
		gx_sy1 = 240
		if [ dbg_on && (frames & 63) == 0 ]
			gx_dbgc = 8
			gx_dbgl = 30
		if [ gpu_on ]
			gxv_n = 0
			gx_zsplit = 0
			gx_zset = false
			st_mtx_n = 1
			st_ls_n = 0
			st_mat_n = 0
			gx_mslot = -1
			gx_lsslot = -1
			gx_matslot = -1
			# matrix slot 0 = screen-space ortho (pixel coords -> vulkan NDC)
			st_put[ 0, 0, 2.0 / 320.0, 0.0, 0.0, 0.0 ]
			st_put[ 1, 0, 0.0, 2.0 / 240.0, 0.0, 0.0 ]
			st_put[ 2, 0, 0.0, 0.0, 2.0, 0.0 ]
			st_put[ 3, 0, -1.0, -1.0, -1.0, 1.0 ]
		pc : u32 [ dp & 0x7FFFFF ]
		if [ dbg_on && frames == 300 ]
			printf[ "n64 gfx DL dp=%08X:\n", dp ]
			for [ i: i32 0, i < 16, i += 1 ]
				printf[ "  %08X %08X\n", dr_r32[ pc + u32[ i * 8 ] ], dr_r32[ pc + u32[ i * 8 + 4 ] ] ]
		gcmd : i32 [ 0 ]
		n_tri : i32 [ 0 ]
		n_vtx : i32 [ 0 ]
		n_txr : i32 [ 0 ]
		n_fil : i32 [ 0 ]
		n_mtx : i32 [ 0 ]
		running : bool [ true ]
		while [ running && gcmd < 300000 ]
			gcmd += 1
			gx_pc = pc
			w1 : u32 [ dr_r32[ pc ] ]
			w2 : u32 [ dr_r32[ pc + 4 ] ]
			pc += 8
			cmd : u32 [ w1 >> 24 ]
			trc : bool [ dbg_on && hold_f > 0 && frames >= hold_f - 1 && frames <= hold_f && trc_n < 400 ]
			if [ trc && (cmd == 0x06 || cmd == 0xE4 || cmd == 0xFD || cmd == 0xFF || cmd == 0xF6 || cmd == 0xFC) ]
				trc_n += 1
				tgt : u32 [ (cmd == 0x06) ? gx_addr[ w2 ] : gx_timg ]
				printf[ "n64 TRC pc=%06X cmd=%02X w2=%08X ->%06X cyc=%u geom=%05X f%u\n", gx_pc, cmd, w2, tgt, (gx_oth_h >> 20) & 3, gx_geom & 0xFFFFF, frames ]
			if [ cmd == 0x01 ]                               # G_MTX
				n_mtx += 1
				gx_mtx_cmd[ (w1 >> 16) & 0xFF, gx_addr[ w2 ] ]
			el [ cmd == 0x03 ]                               # G_MOVEMEM
				mi2 : u32 [ (w1 >> 16) & 0xFF ]
				ma : u32 [ gx_addr[ w2 ] ]
				if [ dbg_on && gx_dbgl > 0 && mi2 != 0x80 ]
					printf[ "n64 movemem idx=%02X ad=%08X f%u\n", mi2, ma, frames ]
				if [ mi2 == 0x80 ]                           # viewport
					gx_mslot = -1
					gx_vp[ 0 ] = f32[ dr_r16[ ma ] ] / 4.0
					gx_vp[ 1 ] = 0.0 - f32[ dr_r16[ ma + 2 ] ] / 4.0
					gx_vp[ 2 ] = f32[ dr_r16[ ma + 4 ] ] / 4.0
					gx_vp[ 3 ] = f32[ dr_r16[ ma + 8 ] ] / 4.0
					gx_vp[ 4 ] = f32[ dr_r16[ ma + 10 ] ] / 4.0
					gx_vp[ 5 ] = f32[ dr_r16[ ma + 12 ] ] / 4.0
				el [ mi2 >= 0x86 ]                           # lights: L0.. then ambient
					ln2 : i32 [ i32[ (mi2 - 0x86) >> 1 ] ]
					if [ dbg_on && gx_dbgl > 0 ]
						printf[ "n64 light%d col=%02X%02X%02X dir=%d,%d,%d nl=%d\n", ln2, dr_r8[ma], dr_r8[ma+1], dr_r8[ma+2], dr_s8[ma+8], dr_s8[ma+9], dr_s8[ma+10], gx_nl ]
					gx_lsslot = -1
					if [ ln2 < 8 ]
						lb2 : i32 [ ln2 * 6 ]
						gx_lights[ lb2 ]     = f32[ dr_r8[ ma ] ] / 255.0
						gx_lights[ lb2 + 1 ] = f32[ dr_r8[ ma + 1 ] ] / 255.0
						gx_lights[ lb2 + 2 ] = f32[ dr_r8[ ma + 2 ] ] / 255.0
						gx_lights[ lb2 + 3 ] = f32[ dr_s8[ ma + 8 ] ] / 128.0
						gx_lights[ lb2 + 4 ] = f32[ dr_s8[ ma + 9 ] ] / 128.0
						gx_lights[ lb2 + 5 ] = f32[ dr_s8[ ma + 10 ] ] / 128.0
			el [ cmd == 0x04 ]                               # G_VTX
				n_vtx += 1
				gx_vtx_cmd[ w1, w2 ]
			el [ cmd == 0x06 ]                               # G_DL
				if [ ((w1 >> 16) & 0xFF) == 0 && gx_dsp < 18 ]
					gx_dls[ gx_dsp ] = pc
					gx_dsp += 1
				pc = gx_addr[ w2 ]
			el [ cmd == 0xB8 ]                               # G_ENDDL
				if [ gx_dsp > 0 ]
					gx_dsp -= 1
					pc = gx_dls[ gx_dsp ]
				el running = false
			el [ cmd == 0xB7 ]                               # G_SETGEOMETRYMODE
				gx_geom = gx_geom | w2
			el [ cmd == 0xB6 ]                               # G_CLEARGEOMETRYMODE
				gx_geom = gx_geom & (~w2)
			el [ cmd == 0xBB ]                               # G_TEXTURE
				gx_matslot = -1
				gx_texon = (w1 & 0xFF) != 0
				gx_tile = i32[ (w1 >> 8) & 7 ]
				gx_texs = f32[ (w2 >> 16) & 0xFFFF ] / 65536.0
				gx_text = f32[ w2 & 0xFFFF ] / 65536.0
			el [ cmd == 0xBD ]                               # G_POPMTX
				if [ gx_mvi > 0 ] gx_mvi -= 1
				gx_mvp_ok = false
				gx_mslot = -1
			el [ cmd == 0xBF ]                               # G_TRI1
				n_tri += 1
				gx_tri_cmd[ i32[ ((w2 >> 16) & 0xFF) / 10 ], i32[ ((w2 >> 8) & 0xFF) / 10 ], i32[ (w2 & 0xFF) / 10 ] ]
			el [ cmd == 0xBC ]                               # G_MOVEWORD: index in low byte
				mwi : u32 [ w1 & 0xFF ]
				if [ dbg_on && gx_dbgl > 0 ]
					printf[ "n64 mw idx=%02X off=%04X w2=%08X f%u\n", mwi, (w1 >> 8) & 0xFFFF, w2, frames ]
				if [ mwi == 6 ]                              # segment
					sg2 : u32 [ ((w1 >> 8) & 0xFFFF) >> 2 ]
					if [ sg2 < 16 ] gx_seg[ sg2 ] = w2 & 0xFFFFFF
				el [ mwi == 0x0A ]                           # light color (goddard per-frame)
					gx_lsslot = -1
					lof : u32 [ (w1 >> 8) & 0xFFFF ]
					li2 : i32 [ i32[ lof >> 5 ] ]
					if [ ((lof & 0x1F) == 0) && li2 < 8 ]
						lb3 : i32 [ li2 * 6 ]
						gx_lights[ lb3 ]     = f32[ (w2 >> 24) & 0xFF ] / 255.0
						gx_lights[ lb3 + 1 ] = f32[ (w2 >> 16) & 0xFF ] / 255.0
						gx_lights[ lb3 + 2 ] = f32[ (w2 >> 8) & 0xFF ] / 255.0
				el [ mwi == 2 ]                              # numlights
					gx_lsslot = -1
					if [ dbg_on && gx_dbgc > 0 ] printf[ "n64 numlight w2=%08X\n", w2 ]
					gx_nl = i32[ ((w2 - 0x80000000) / 32) - 1 ]
					if [ gx_nl < 0 ] gx_nl = 0
					if [ gx_nl > 7 ] gx_nl = 7
			el [ cmd == 0xB4 ]                               # G_RDPHALF_1
				gx_half1 = w2
			el [ cmd == 0xBA ]                               # G_SETOTHERMODE_H
				sft : u32 [ (w1 >> 8) & 0xFF ]
				num : u32 [ w1 & 0xFF ]
				msk3 : u32 [ ((u32[1] << num) - 1) << sft ]
				gx_oth_h = (gx_oth_h & (~msk3)) | (w2 & msk3)
			el [ cmd == 0xB9 ]                               # G_SETOTHERMODE_L
				gx_matslot = -1
				sft2 : u32 [ (w1 >> 8) & 0xFF ]
				num2 : u32 [ w1 & 0xFF ]
				msk4 : u32 [ ((u32[1] << num2) - 1) << sft2 ]
				gx_oth_l = (gx_oth_l & (~msk4)) | (w2 & msk4)
			el [ cmd == 0xEF ]                               # G_RDPSETOTHERMODE
				gx_oth_h = w1 & 0xFFFFFF
				gx_oth_l = w2
			el [ cmd == 0xE4 ]                               # G_TEXRECT (2 extra words)
				ws : u32 [ dr_r32[ pc + 4 ] ]
				wd : u32 [ dr_r32[ pc + 12 ] ]
				pc += 16
				n_txr += 1
				gx_texrect[ w1, w2, ws, wd ]
			el [ cmd == 0xED ]                               # G_SETSCISSOR
				gx_sx0 = i32[ (w1 >> 12) & 0xFFF ] >> 2
				gx_sy0 = i32[ w1 & 0xFFF ] >> 2
				gx_sx1 = i32[ (w2 >> 12) & 0xFFF ] >> 2
				gx_sy1 = i32[ w2 & 0xFFF ] >> 2
			el [ cmd == 0xF0 ]                               # G_LOADTLUT
				gx_matslot = -1
				cnt2 : i32 [ i32[ ((w2 >> 14) & 0x3FF) ] + 1 ]
				if [ cnt2 > 256 ] cnt2 = 256
				for [ i: i32 0, i < cnt2, i += 1 ]
					pv2 : u32 [ dr_ru16[ gx_timg + u32[ i * 2 ] ] ]
					r5 : u32 [ (pv2 >> 11) & 31 ]
					g5 : u32 [ (pv2 >> 6) & 31 ]
					b5 : u32 [ (pv2 >> 1) & 31 ]
					gx_tlut[ i ] = ((r5 << 3 | r5 >> 2) << 24) | ((g5 << 3 | g5 >> 2) << 16) | ((b5 << 3 | b5 >> 2) << 8) | ((pv2 & 1) * 255)
			el [ cmd == 0xF2 ]                               # G_SETTILESIZE
				gx_matslot = -1
				tn2 : i32 [ i32[ (w2 >> 24) & 7 ] ]
				tl_uls[ tn2 ] = (w1 >> 12) & 0xFFF
				tl_ult[ tn2 ] = w1 & 0xFFF
				tl_lrs[ tn2 ] = (w2 >> 12) & 0xFFF
				tl_lrt[ tn2 ] = w2 & 0xFFF
			el [ cmd == 0xF3 ]                               # G_LOADBLOCK
				gx_matslot = -1
				tn3 : i32 [ i32[ (w2 >> 24) & 7 ] ]
				txl : u32 [ (w2 >> 12) & 0xFFF ]
				nby : u32 [ ((txl + 1) << gx_tsiz) >> 1 ]
				if [ nby > 4096 ] nby = 4096
				tb2 : u32 [ tl_tmem[ tn3 ] * 8 ]
				tl_block[ tn3 ] = 1
				for [ i: u32 0, i < nby, i += 1 ]
					tmem[ (tb2 + i) & 0xFFF ] = u8[ dr_r8[ gx_timg + i ] ]
			el [ cmd == 0xF4 ]                               # G_LOADTILE
				gx_matslot = -1
				tn4 : i32 [ i32[ (w2 >> 24) & 7 ] ]
				tl_block[ tn4 ] = 0
				ul4s : u32 [ ((w1 >> 12) & 0xFFF) >> 2 ]
				ul4t : u32 [ (w1 & 0xFFF) >> 2 ]
				lr4s : u32 [ ((w2 >> 12) & 0xFFF) >> 2 ]
				lr4t : u32 [ (w2 & 0xFFF) >> 2 ]
				wds : u32 [ lr4s - ul4s + 1 ]
				bpr : u32 [ (wds << gx_tsiz) >> 1 ]
				spr : u32 [ (u32[ gx_tw ] << gx_tsiz) >> 1 ]
				tb3 : u32 [ tl_tmem[ tn4 ] * 8 ]
				lnb : u32 [ tl_line[ tn4 ] * 8 ]
				for [ tr: u32 ul4t, tr <= lr4t, tr += 1 ]
					sa2 : u32 [ gx_timg + tr * spr + ((ul4s << gx_tsiz) >> 1) ]
					da2 : u32 [ tb3 + (tr - ul4t) * lnb ]
					for [ i: u32 0, i < bpr, i += 1 ]
						tmem[ (da2 + i) & 0xFFF ] = u8[ dr_r8[ sa2 + i ] ]
			el [ cmd == 0xF5 ]                               # G_SETTILE
				gx_matslot = -1
				tn5 : i32 [ i32[ (w2 >> 24) & 7 ] ]
				tl_fmt[ tn5 ]   = (w1 >> 21) & 7
				tl_siz[ tn5 ]   = (w1 >> 19) & 3
				tl_line[ tn5 ]  = (w1 >> 9) & 0x1FF
				tl_tmem[ tn5 ]  = w1 & 0x1FF
				tl_pal[ tn5 ]   = (w2 >> 20) & 0xF
				tl_cmt[ tn5 ]   = (w2 >> 18) & 3
				tl_maskt[ tn5 ] = (w2 >> 14) & 0xF
				tl_cms[ tn5 ]   = (w2 >> 8) & 3
				tl_masks[ tn5 ] = (w2 >> 4) & 0xF
			el [ cmd == 0xF6 ]                               # G_FILLRECT
				n_fil += 1
				gx_fillrect[ w1, w2 ]
			el [ cmd == 0xF7 ]                               # G_SETFILLCOLOR
				gx_fill = w2
			el [ cmd == 0xFC ]                               # G_SETCOMBINE
				gx_matslot = -1
				gx_ccw1 = w1
				gx_ccw2 = w2
				ca0 : u32 [ (w1 >> 20) & 0xF ]
				cc0 : u32 [ (w1 >> 15) & 0x1F ]
				ca1 : u32 [ (w1 >> 5) & 0xF ]
				cc1 : u32 [ w1 & 0x1F ]
				cb0 : u32 [ (w2 >> 28) & 0xF ]
				cb1 : u32 [ (w2 >> 24) & 0xF ]
				cd0 : u32 [ (w2 >> 15) & 7 ]
				cd1 : u32 [ (w2 >> 6) & 7 ]
				gx_cc_tex = (ca0 == 1 || ca0 == 2 || cb0 == 1 || cb0 == 2 || cc0 == 1 || cc0 == 2 || cd0 == 1 || cd0 == 2 || ca1 == 1 || ca1 == 2 || cb1 == 1 || cb1 == 2 || cc1 == 1 || cc1 == 2 || cd1 == 1 || cd1 == 2)
				gx_cc_shade = (ca0 == 4 || cb0 == 4 || cc0 == 4 || cd0 == 4 || ca1 == 4 || cb1 == 4 || cc1 == 4 || cd1 == 4)
				gx_cc_add = (cd0 == 4) && (ca0 == 1 || ca0 == 2)
				gx_cc_prim = (cc0 == 3)
				gx_cc_lerp = (ca0 == 3) && (cb0 == 4) && (cc0 == 1) && (cd0 == 4)
			el [ cmd == 0xFA ]                               # G_SETPRIMCOLOR
				gx_matslot = -1
				gx_prim = w2
			el [ cmd == 0xFB ]                               # G_SETENVCOLOR
				gx_matslot = -1
				gx_env = w2
			el [ cmd == 0xFD ]                               # G_SETTIMG
				gx_tfmt = (w1 >> 21) & 7
				gx_tsiz = (w1 >> 19) & 3
				gx_tw   = i32[ (w1 & 0xFFF) ] + 1
				gx_timg = gx_addr[ w2 ]
				if [ dbg_on && frames >= 440 && frames < 620 ]
					printf[ "n64 TIMG timg=%06X fmt=%u siz=%u w=%d f%u\n", gx_timg, gx_tfmt, gx_tsiz, gx_tw, frames ]
					nchk : i32 [ (rtt_n < 16) ? rtt_n : 16 ]
					for [ ri: i32 0, ri < nchk, ri += 1 ]
						reg : u32 [ rtt_addr[ ri ] ]
						rsz : u32 [ u32[ rtt_w[ ri ] * rtt_h[ ri ] * 2 ] ]
						if [ gx_timg >= reg && gx_timg < reg + rsz ]
							printf[ "n64 RTT-SAMPLE timg=%06X hits cimg=%06X (w=%d) fmt=%u siz=%u f%u\n", gx_timg, reg, rtt_w[ ri ], gx_tfmt, gx_tsiz, frames ]
			el [ cmd == 0xFE ]                               # G_SETZIMG
				gx_zimg = gx_addr[ w2 ]
			el [ cmd == 0xFF ]                               # G_SETCIMG
				gx_cimg = gx_addr[ w2 ]
				gx_ciw  = i32[ (w1 & 0xFFF) ] + 1
				if [ gx_cimg != vi_origin ]
					slot : i32 [ rtt_n & 15 ]
					rtt_addr[ slot ] = gx_cimg
					rtt_w[ slot ]    = gx_ciw
					rtt_h[ slot ]    = 240
					rtt_n += 1
					if [ dbg_on && frames >= 440 && frames < 620 ]
						printf[ "n64 RTT-CIMG addr=%06X w=%d f%u\n", gx_cimg, gx_ciw, frames ]
			el [ cmd == 0x00 || cmd == 0xB5 || cmd == 0xB2 || cmd == 0xE6 || cmd == 0xE7 || cmd == 0xE8 || cmd == 0xE9 || cmd == 0xB3 ]
				cmd = cmd                                    # known no-ops / handled elsewhere
			el
				gx_unk[ cmd ] = gx_unk[ cmd ] + 1
		if [ gpu_on && gxv_n > 0 ]
			pub_lock.lock[]
			nf9 : i32 [ gxv_n * 13 ]
			for [ i: i32 0, i < nf9, i += 1 ]
				pub_gxv[ i ] = gxv[ i ]
			pub_gxv_n = gxv_n
			pub_zsplit = (gx_zset) ? gx_zsplit : 0
			for [ i: i32 0, i < 24576, i += 1 ]
				pub_st[ i ] = st_tex[ i ]
			if [ at_dirty ]
				pub_at_dirty = true
				at_dirty = false
			pub_lock.unlock[]
		if [ dbg_on && (frames & 255) == 0 ]
			for [ k: i32 0, k < 256, k += 1 ]
				ucnt : u32 [ gx_unk[ k ] ]
				if [ ucnt > 0 ]
					printf[ "n64 gfx UNKCMD %02X x%u f%u\n", k, ucnt, frames ]
					gx_unk[ k ] = 0
		if [ dbg_on && ((frames >= 300 && frames < 304) || (frames >= 448 && frames < 451)) ]
			printf[ "n64 gfx f%u cmds=%d mtx=%d vtx=%d tri=%d txr=%d fil=%d cimg=%06X vp=%d\n", frames, gcmd, n_mtx, n_vtx, n_tri, n_txr, n_fil, gx_cimg, i32[ gx_vp[0] ] ]


	func pif_joybus []
		i : i32 [ 0 ]
		ch : i32 [ 0 ]
		while [ i < 63 ]
			t : i32 [ i32[ pif_ram[ i ] ] ]
			if [ t == 0 ]
				ch += 1
				i += 1
				continue
			if [ t == 0xFE ] return
			if [ t == 0xFF ]
				i += 1
				continue
			rx : i32 [ i32[ pif_ram[ i + 1 ] ] & 0x3F ]
			cmd : i32 [ i32[ pif_ram[ i + 2 ] ] ]
			if [ ch == 0 && (cmd == 0 || cmd == 0xFF) && i + 4 < 64 ]      # info
				pif_ram[ i + 3 ] = 0x05
				pif_ram[ i + 4 ] = 0x00
				pif_ram[ i + 5 ] = 0x02                                    # no pak
			el [ ch == 0 && cmd == 1 && i + 6 < 64 ]                       # read state
				pif_ram[ i + 3 ] = u8[ pad_st >> 8 ]
				pif_ram[ i + 4 ] = u8[ pad_st ]
				pif_ram[ i + 5 ] = u8[ stick_x ]
				pif_ram[ i + 6 ] = u8[ stick_y ]
			el [ ch > 0 && i + 1 < 64 ]                                    # absent channels
				pif_ram[ i + 1 ] = u8[ u32[ rx ] | 0x80 ]
			i += 3 + (t & 0x3F) + rx
			ch += 1

	# ---------------- interrupts ----------------
	func mi_check []
		if [ mi_intr & mi_mask ] cpu.c_cause = cpu.c_cause | 0x400
		el cpu.c_cause = cpu.c_cause & (~u32[0x400])

	# advance the VI line counter to the current cycle (ares VI::main). CPU clock =
	# 187.5MHz (2/instr), NTSC video clock = 48.681818MHz. Each line consumes
	# (quarterLineDuration+1) video-clocks (leap line at vcounter==1). VI interrupt
	# raised at the coincidence line. Called on every V_CURRENT read and each step.
	func vi_sync []
		if [ (vi_ctrl & 3) == 0 ]                            # VI blanked (colorDepth 0)
			while [ sys_clk > vi_line_clk ]                  # ares stops at clock==0, so strict
				vi_vcounter = 0
				bscaled : i64 [ i64[ 0x800 ] * 187500000 + vi_clkfrac ]
				vi_line_clk = vi_line_clk + (bscaled / 48681818)
				vi_clkfrac  = bscaled % 48681818
			return
		while [ sys_clk > vi_line_clk ]
			vi_vcounter += 1
			hl : u32 [ (vi_vcounter << 1) | vi_field ]
			if [ hl >= vi_hlpf + 1 ]
				vi_vcounter = 0
				if [ (vi_hlpf & 1) == 0 ] vi_field = vi_field ^ 1
				vi_leapcnt += 1
				if [ vi_leapcnt == 5 ] vi_leapcnt = 0
			if [ vi_vcounter == (vi_vstart >> 1) ] vi_refreshed = true
			ci : u32 [ vi_intr_line ]
			if [ vi_hlpf & 1 ]
				if [ vi_vcounter == (ci >> 1) ]
					mi_intr = mi_intr | 0x8
					mi_check[]
			el [ ci & 1 ]
				if [ vi_vcounter == (ci >> 1) ]
					mi_intr = mi_intr | 0x8
					mi_check[]
			el
				hl2 : u32 [ (vi_vcounter << 1) | vi_field ]
				if [ (vi_field == 0 && hl2 == ci) || (vi_field != 0 && hl2 + 1 == ci) || (vi_field == 0 && hl2 == vi_hlpf && ci == 0) ]
					mi_intr = mi_intr | 0x8
					mi_check[]
			ld : u32 [ vi_qld + 1 ]
			if [ vi_vcounter == 1 ]
				lp : u32 [ (vi_leappat >> vi_leapcnt) & 1 ]
				if [ lp ] ld = vi_hleap1
				el ld = vi_hleap0
			scaled : i64 [ i64[ ld ] * 187500000 + vi_clkfrac ]
			vi_line_clk = vi_line_clk + (scaled / 48681818)
			vi_clkfrac  = scaled % 48681818
		vi_current = (vi_vcounter << 1) | vi_field

	func take_int []
		dbg_ic += 1
		cpu.c_cause = cpu.c_cause & (~u32[0x3000007C])      # ExcCode 0 + CE 0 (ares sets coproc=0)
		if [ cpu.npc != cpu.pc + 4 ]                         # in a branch delay slot:
			cpu.c_epc = cpu.pc - 4                           # EPC = the branch, BD set,
			cpu.c_cause = cpu.c_cause | 0x80000000           # so ERET re-runs branch+slot
		el
			cpu.c_epc = cpu.pc
			cpu.c_cause = cpu.c_cause & (~u32[0x80000000])
		if [ dbg_esc < 40 && (cpu.pc < 0x80000000 || cpu.pc >= 0x80400000) ]
			dbg_esc += 1
			printf[ "n64 INT from bogus pc=%08X ra=%08X f%u\n", cpu.pc, u32[ cpu.r[31] ], frames ]
		cpu.c_status = cpu.c_status | 0x2                    # EXL
		cpu.pc  = 0x80000180
		cpu.npc = 0x80000184

	# raise a synchronous exception from inside exec (EPC = the faulting
	# instruction, which re-executes if the OS returns)
	func take_exc [ code: u32, cur: u32 ]
		if [ dbg_esc < 40 ]
			dbg_esc += 1
			printf[ "n64 FAULT exc=%u pc=%08X op=%08X f%u\n", code, cur, rd32v[ cur ], frames ]
		cpu.c_cause = (cpu.c_cause & (~u32[0x3000007C])) | ((code & 0x1F) << 2)   # CE 0
		cpu.c_epc = cur
		cpu.c_status = cpu.c_status | 0x2                    # EXL
		cpu.pc  = 0x80000180
		cpu.npc = 0x80000184

	# Coprocessor Unusable (ExcCode 11): raised when a COP1/FPU instruction runs
	# with Status.CU1 (bit 29) clear. libultra's handler sets CU1 and marks the
	# thread an FPU user, enabling lazy FP context save/restore. Sets Cause.CE=1.
	func take_cpu [ cur: u32 ]
		cpu.c_cause = (cpu.c_cause & (~u32[0x7C])) | (11 << 2)
		cpu.c_cause = (cpu.c_cause & (~u32[0x30000000])) | 0x10000000
		cpu.c_epc = cur
		cpu.c_status = cpu.c_status | 0x2                    # EXL
		cpu.pc  = 0x80000180
		cpu.npc = 0x80000184

	# ---------------- virtual memory (KSEG0/1 direct + TLB) ----------------
	# KUSEG/KSSEG go through the TLB (goddard maps its dynlist segment at
	# 0x04000000 via osMapTLB); anything unmapped falls back to the physical
	# mask so the pre-TLB boot path keeps working.
	func vmap [ va: u32 ] -> u32
		if [ va >= 0x80000000 && va < 0xC0000000 ] return va & 0x1FFFFFFF
		if [ cpu.tlb_used ]
			for [ i: i32 0, i < 32, i += 1 ]
				pm : u32 [ cpu.tlb_pm[ i ] ]
				vmask : u32 [ ~(pm | 0x1FFF) ]
				if [ (va & vmask) == (cpu.tlb_hi[ i ] & vmask) ]
					g : bool [ ((cpu.tlb_lo0[ i ] & 1) != 0) && ((cpu.tlb_lo1[ i ] & 1) != 0) ]
					if [ (!g) && ((cpu.tlb_hi[ i ] & 0xFF) != (cpu.c_entryhi & 0xFF)) ] continue   # ASID mismatch (non-global)
					hpg : u32 [ (pm + 0x2000) >> 1 ]
					lo : u32 [ (va & hpg) ? cpu.tlb_lo1[ i ] : cpu.tlb_lo0[ i ] ]
					if [ lo & 2 ] return (((lo >> 6) & 0xFFFFFF) << 12) | (va & (hpg - 1))
		return va & 0x1FFFFFFF

	# VR4300 D-cache timing (ref: ares dcache.cpp). 8KB direct-mapped, 16B lines, index = va[12:4].
	# hit +1, line fill +40, dirty-line eviction writeback +40. Only cached KSEG0 (0x80-0x9F).
	# ares charges DefaultReadCycles*2=40 count (20 our half-units) for each
	# uncached RCP-register read; boot runs from IMEM uncached so every fetch
	# and MMIO load pays it. cached reads go through dcache; writes cost 0.
	func io_rcost [ va: u32, pa: u32 ] -> i32
		if [ (va & 0xE0000000) == 0x80000000 ] return 0                     # KSEG0 cached: dcache charged it
		if [ pa >= 0x04000000 && pa < 0x04900000 ] return 20               # RSP/RDP/MI/VI/AI/PI/RI/SI regs
		if [ pa >= 0x1FC00000 && pa < 0x1FD00000 ] return 20               # PIF ROM/RAM via SI
		if [ pa >= 0x05000000 && pa <= 0x1FBFFFFF ] return 270             # PI cart domain: RCP 20 + PI 250
		if [ pa >= 0x1FD00000 && pa <= 0x7FFFFFFF ] return 270             # PI cart domain 2
		return 0

	# I-cache timing: cached (KSEG0) fetch miss fills at ares step(48*2)/2.
	func icache [ va: u32, pa: u32 ]
		if [ (va & 0xE0000000) != 0x80000000 ] return                       # KSEG1 uncached: io_rcost charged it
		idx : i32 [ i32[ (va >> 5) & 0x1FF ] ]
		tag : u32 [ pa & 0x1FFFF000 ]
		cur : u32 [ ic_tag[ idx ] ]
		if [ (cur & 1) != 0 && (cur & 0x1FFFF000) == tag ] return           # hit: base +1 already paid
		cpu.c_count += 48                                                    # miss fill: ares step(48*2)/2
		dbg_icm += 1
		ic_tag[ idx ] = tag | 1

	# CACHE instruction: mirror ares cost + cache-state change (interpreter-ipu CACHE).
	# writebacks step(40*2)/2=40, icache fill step(48*2)/2=48; state kept so future
	# dcache/icache hit/miss timing stays in lockstep with ares.
	func cache_op [ cop: u32, va: u32 ]
		if [ cop == 0x14 ]                                   # icache fill
			ii : i32 [ i32[ (va >> 5) & 0x1FF ] ]
			cpu.c_count += 48
			ic_tag[ ii ] = (va & 0x1FFFF000) | 1
			return
		if [ cop == 0x00 || cop == 0x10 ]                    # icache invalidate
			ii2 : i32 [ i32[ (va >> 5) & 0x1FF ] ]
			ic_tag[ ii2 ] = ic_tag[ ii2 ] & (~u32[1])
			return
		di  : i32 [ i32[ (va >> 4) & 0x1FF ] ]
		dtg : u32 [ va & 0x1FFFF000 ]
		cur : u32 [ dc_tag[ di ] ]
		hit : bool [ (cur & 1) != 0 && (cur & 0x1FFFF000) == dtg ]
		drt : bool [ (cur & 2) != 0 ]
		if [ cop == 0x01 ]                                   # dcache index writeback invalidate
			if [ (cur & 1) != 0 && drt ] cpu.c_count += 40
			dc_tag[ di ] = 0
		el [ cop == 0x15 ]                                   # dcache hit writeback invalidate
			if [ hit ]
				if [ drt ] cpu.c_count += 40
				dc_tag[ di ] = 0
		el [ cop == 0x19 ]                                   # dcache hit writeback (line stays valid)
			if [ hit && drt ]
				cpu.c_count += 40
				dc_tag[ di ] = cur & (~u32[2])
		el [ cop == 0x11 ]                                   # dcache hit invalidate
			if [ hit ] dc_tag[ di ] = 0
		el [ cop == 0x0D ]                                   # dcache create dirty exclusive
			if [ (!hit) && drt ] cpu.c_count += 40
			dc_tag[ di ] = dtg | 3

	func dcache [ va: u32, w: bool ]
		if [ (va & 0xE0000000) != 0x80000000 ] return                       # KSEG1/uncached & mapped: no dcache
		idx : i32 [ i32[ (va >> 4) & 0x1FF ] ]
		tag : u32 [ va & 0x1FFFF000 ]                                        # paddr line tag (paddr & ~0xFFF)
		cur : u32 [ dc_tag[ idx ] ]
		if [ (cur & 1) != 0 && (cur & 0x1FFFF000) == tag ]                   # hit
			cpu.c_count += 1
			dbg_dch += 1
			if [ w ] dc_tag[ idx ] = cur | 2
		el                                                                  # miss
			if [ (cur & 1) != 0 && (cur & 2) != 0 ] cpu.c_count += 40   # evict dirty: ares step(40*2)/2
			cpu.c_count += 40                                               # fill: ares step(40*2)/2
			dbg_dcm += 1
			dc_tag[ idx ] = (w) ? (tag | 3) : (tag | 1)

	func rd8  [ va: u32 ] -> u32
		dcache[ va, false ]
		p : u32 [ vmap[ va ] ]
		cpu.c_count += i64[ io_rcost[ va, p ] ]
		return rd_phys8[ p ]
	func rd16 [ va: u32 ] -> u32
		dcache[ va, false ]
		p : u32 [ vmap[ va ] ]
		cpu.c_count += i64[ io_rcost[ va, p ] ]
		return (rd_phys8[ p ] << 8) | rd_phys8[ p + 1 ]
	func rd32v [ va: u32 ] -> u32
		dcache[ va, false ]
		p : u32 [ vmap[ va ] ]
		cpu.c_count += i64[ io_rcost[ va, p ] ]
		return rd_phys32[ p ]
	func rd64 [ va: u32 ] -> i64
		dcache[ va, false ]
		p : u32 [ vmap[ va ] ]
		cpu.c_count += i64[ io_rcost[ va, p ] ]
		h : u32 [ rd_phys32[ p ] ]
		l : u32 [ rd_phys32[ p + 4 ] ]
		return (i64[ h ] << 32) | i64[ l ]
	func wr8v  [ va: u32, v: u32 ]
		dcache[ va, true ]
		wrsig[ va & 0x1FFFFFFF, v & 0xFF ]
		wr_phys8[ vmap[ va ], v ]
	func wr16v [ va: u32, v: u32 ]
		dcache[ va, true ]
		wrsig[ va & 0x1FFFFFFF, v & 0xFFFF ]
		if [ dbg_on && frames == 377 && (va & 0x1FFFFFFF) >= 0x88000 && (va & 0x1FFFFFFF) < 0x88200 && (va & 6) == 2 ]
			printf[ "n64 HW16 pc=%08X va=%08X v=%04X\n", cpu.pc, va & 0x1FFFFFFF, v & 0xFFFF ]
		if [ dbg_on && frames == 377 && (va & 0x1FFFFFFF) >= 0x88830 && (va & 0x1FFFFFFF) < 0x88840 ]
			printf[ "n64 SPK16 pc=%08X va=%08X v=%04X f%u\n", cpu.pc, va & 0x1FFFFFFF, v & 0xFFFF, frames ]
			if [ (va & 0x1FFFFFFF) == 0x88832 && !spk_done ]
				spk_done = true
				t2 : u32 [ u32[ cpu.r[10] ] ]
				src : u32 [ t2 + 0x24 ]
				printf[ "n64 SPKSRC t2=%08X srcaddr=%08X floatbits=%08X f8bits=%08X\n", t2, src & 0x1FFFFFFF, rd32v[ src ], fget32[ 8 ] ]
		p : u32 [ vmap[ va ] ]
		wr_phys8[ p, (v >> 8) & 0xFF ]
		wr_phys8[ p + 1, v & 0xFF ]
	func wr32v [ va: u32, v: u32 ]
		dcache[ va, true ]
		wrsig[ va & 0x1FFFFFFF, v ]
		if [ dbg_on && frames == 377 && (va & 0x1FFFFFFF) >= 0x88830 && (va & 0x1FFFFFFF) < 0x88840 ]
			printf[ "n64 SPK32 pc=%08X va=%08X v=%08X f%u\n", cpu.pc, va & 0x1FFFFFFF, v, frames ]
		if [ dbg_on && frames >= 300 && frames <= 400 && (va & 0x1FFFFFFF) == 0x000B45AC && cpu.pc == 0x80181AC0 ]
			printf[ "n64 NYRANGE f%u newY=%08X\n", frames, v ]
		if [ dbg_on && frames >= 1 && frames <= 378 && (va & 0x1FFFFFFC) >= 0x0C94C4 && (va & 0x1FFFFFFC) <= 0x0C94D4 ]
			printf[ "n64 VELY pc=%08X ra=%08X va=%08X v=%08X r16=%08X r17=%08X r18=%08X f%u\n", cpu.pc, u32[ cpu.r[31] ], va, v, u32[cpu.r[16]], u32[cpu.r[17]], u32[cpu.r[18]], frames ]
			if [ cpu.pc == 0x80181BD4 && !yw_done ]
				yw_done = true
				dpc : u32 [ 0x80181B70 ]
				for [ di: i32 0, di < 32, di += 1 ]
					printf[ "n64 DIS %08X: %08X\n", dpc + u32[ di * 4 ], rd32v[ dpc + u32[ di * 4 ] ] ]
		if [ dbg_on && (va & 0x1FFFFFFC) >= 0x0C9210 && (va & 0x1FFFFFFC) <= 0x0C9218 ]
			mgt : u32 [ dr_r32[ 0x32D5D4 ] ]
			if [ mgt >= 95 && mgt <= 100 ]
				printf[ "n64 MTXW gt=%u pc=%08X ra=%08X va=%08X v=%08X\n", mgt, cpu.pc, u32[ cpu.r[31] ], va & 0x1FFFFFFF, v ]
			if [ dbg_on && fparm && (va & 0x1FFFFFFC) == 0x00206B0C ]
				printf[ "n64 STK pc=%08X v=%08X\n", cpu.pc, v ]
		wr_phys32[ vmap[ va ], v ]
	func wr64 [ va: u32, v: i64 ]
		dcache[ va, true ]
		wr_phys32[ vmap[ va ], u32[ v >> 32 ] ]
		wr_phys32[ vmap[ va ] + 4, u32[ v ] ]

	# ---------------- FPU register file (FR=0 pairing) ----------------
	func fget32 [ n: i32 ] -> u32
		if [ cpu.c_status & 0x04000000 ] return u32[ cpu.fpr[ n ] ]
		e : i32 [ n - (n & 1) ]
		fv : u64 [ cpu.fpr[ e ] ]
		if [ n & 1 ] return u32[ fv >> 32 ]
		return u32[ fv ]
	func fset32 [ n: i32, v: u32 ]
		if [ cpu.c_status & 0x04000000 ]
			fz : u64 [ cpu.fpr[ n ] ]
			cpu.fpr[ n ] = (fz & 0xFFFFFFFF00000000) | u64[ v ]
			return
		e : i32 [ n - (n & 1) ]
		fw : u64 [ cpu.fpr[ e ] ]
		if [ n & 1 ] cpu.fpr[ e ] = (fw & 0x00000000FFFFFFFF) | (u64[ v ] << 32)
		el cpu.fpr[ e ] = (fw & 0xFFFFFFFF00000000) | u64[ v ]
	func fget64 [ n: i32 ] -> u64
		if [ cpu.c_status & 0x04000000 ] return cpu.fpr[ n ]
		return cpu.fpr[ n - (n & 1) ]
	func fset64 [ n: i32, v: u64 ]
		if [ cpu.c_status & 0x04000000 ]
			cpu.fpr[ n ] = v
			return
		cpu.fpr[ n - (n & 1) ] = v
	func fgs [ n: i32 ] -> f32
		bb : local u32 [ 1 ] [ fget32[ n ] ]
		fp : ref f32 [ ((ref bb[0]) to ref f32) ]
		return fp[ 0 ]
	func fss [ n: i32, v: f32 ]
		bb : local f32 [ 1 ] [ v ]
		up : ref u32 [ ((ref bb[0]) to ref u32) ]
		fset32[ n, up[ 0 ] ]
	func fgd [ n: i32 ] -> f64
		bb : local u64 [ 1 ] [ fget64[ n ] ]
		fp : ref f64 [ ((ref bb[0]) to ref f64) ]
		return fp[ 0 ]
	func fsd [ n: i32, v: f64 ]
		bb : local f64 [ 1 ] [ v ]
		up : ref u64 [ ((ref bb[0]) to ref u64) ]
		fset64[ n, up[ 0 ] ]

	# map host IEEE exceptions to FCR31 cause (12-16) + sticky flags (2-6),
	# honoring the enable bits (7-11). matches ares checkFPUExceptions.
	func fpu_flags []
		exc : i32 [ fetestexcept[ 0x3D ] ]
		cpu.fcr31 = cpu.fcr31 & (~u32[ 0x3F000 ])            # clear cause field per op
		en : u32 [ (cpu.fcr31 >> 7) & 0x1F ]
		if [ (exc & 0x20) != 0 ]                             # inexact
			cpu.fcr31 = cpu.fcr31 | 0x1000
			if [ (en & 0x01) == 0 ] cpu.fcr31 = cpu.fcr31 | 0x4
		if [ (exc & 0x10) != 0 ]                             # underflow
			cpu.fcr31 = cpu.fcr31 | 0x2000
			if [ (en & 0x02) == 0 ] cpu.fcr31 = cpu.fcr31 | 0x8
		if [ (exc & 0x08) != 0 ]                             # overflow
			cpu.fcr31 = cpu.fcr31 | 0x4000
			if [ (en & 0x04) == 0 ] cpu.fcr31 = cpu.fcr31 | 0x10
		if [ (exc & 0x04) != 0 ]                             # divide by zero
			cpu.fcr31 = cpu.fcr31 | 0x8000
			if [ (en & 0x08) == 0 ] cpu.fcr31 = cpu.fcr31 | 0x20
		if [ (exc & 0x01) != 0 ]                             # invalid
			cpu.fcr31 = cpu.fcr31 | 0x10000
			if [ (en & 0x10) == 0 ] cpu.fcr31 = cpu.fcr31 | 0x40

	# round to nearest, ties to even (VR4300 RN mode + round.w/round.l)
	func rne [ x: f64 ] -> f64
		f : f64 [ floor[ x ] ]
		d : f64 [ x - f ]
		if [ d < 0.5 ] return f
		if [ d > 0.5 ] return f + 1.0
		h : f64 [ f * 0.5 ]
		if [ (h - floor[ h ]) == 0.0 ] return f
		return f + 1.0

	# convert to integer honoring FCR31 rounding mode (cvt.w / cvt.l)
	func fcvt_rm [ x: f64 ] -> f64
		rm : u32 [ cpu.fcr31 & 3 ]
		if [ rm == 0 ] return rne[ x ]
		if [ rm == 2 ] return ceil[ x ]
		if [ rm == 3 ] return floor[ x ]
		if [ x < 0.0 ] return ceil[ x ]                                     # rm == 1: toward zero
		return floor[ x ]

	# ---------------- interpreter ----------------
	func sx32 [ v: u32 ] -> i64
		return i64[ i32[ v ] ]

	func sx16 [ v: u32 ] -> i64
		ww : u32 [ v & 0xFFFF ]
		if [ ww >= 0x8000 ] ww = ww | 0xFFFF0000
		return i64[ i32[ ww ] ]

	func cosim_check []
		apc : u32 [ oracle.rpc[] ]
		bad : bool [ false ]
		if [ apc != cpu.pc ] bad = true
		for [ i: i32 0, i < 32, i += 1 ]
			if [ oracle.reg[ i ] != u64[ cpu.r[ i ] ] ] bad = true
		if [ u64[ cpu.hi ] != oracle.rhi[] ] bad = true
		if [ u64[ cpu.lo ] != oracle.rlo[] ] bad = true
		if [ (cpu.c_cause & 0x8000007C) != (u32[ oracle.acause[] ] & 0x8000007C) ] bad = true   # BD + ExcCode
		cdelta : i64 [ sys_clk - oracle.acpuclk[] ]
		if [ cosim_seq >= 719950 && cosim_seq <= 719978 ]
			printf[ "n64 STEP seq=%lld pc=%08X ppc=%08X pop=%08X sys_step=%lld ares_step=%lld delta=%lld\n", cosim_seq, cpu.pc, cosim_ppc, cosim_pop, sys_clk - dbg_psys, oracle.acpuclk[] - dbg_pares, cdelta ]
		if [ cdelta != dbg_clkdelta && cosim_seq > 23200000 && cosim_cnt_rep < 120 ]
			cosim_cnt_rep += 1
			dea : u32 [ cosim_pbase + u32[ sx16[ cosim_pop ] ] ]
			ddi : i32 [ i32[ (dea >> 4) & 0x1FF ] ]
			printf[ "n64 DRIFT seq=%lld pc=%08X op=%08X ea=%08X dcidx=%d dctag=%08X cdelta %lld->%lld (ours=%lld ares=%lld)\n", cosim_seq, cosim_ppc, cosim_pop, dea, ddi, dc_tag[ ddi ], dbg_clkdelta, cdelta, sys_clk - dbg_psys, oracle.acpuclk[] - dbg_pares ]
		if [ cosim_seq >= 23283000 && cosim_seq <= 23286735 ]
			o194 : u32 [ dc_tag[ 194 ] ]
			a194 : u32 [ oracle.adctag[ 194 ] ]
			if [ (o194 != dbg_dch2) || (a194 != dbg_dcm2) ]
				printf[ "n64 DC194 seq=%lld ppc=%08X pop=%08X our=%08X->%08X ares=%08X->%08X\n", cosim_seq, cosim_ppc, cosim_pop, dbg_dch2, o194, dbg_dcm2, a194 ]
				dbg_dch2 = o194
				dbg_dcm2 = a194
		dbg_clkdelta = cdelta
		dbg_psys  = sys_clk
		dbg_pares = oracle.acpuclk[]
		if [ bad ]
			printf[ "n64 COSIM DIVERGE seq=%lld ours pc=%08X ares pc=%08X\n", cosim_seq, cpu.pc, apc ]
			printf[ "  count ours=%u ares=%llu (ares/2=%llu)\n", cpu.c_count, oracle.acount[], oracle.acount[] / 2 ]
			printf[ "  cause ours=%08X ares=%08llX ; status ours=%08X ares=%08llX ; mi_intr=%X mi_mask=%X\n", cpu.c_cause, oracle.acause[], cpu.c_status, oracle.astatus[], mi_intr, mi_mask ]
			printf[ "  VI vcount ours=%u ares=%u ; intr_line ours=%u ares=%u ; vi_field=%u vi_hlpf=%u\n", vi_vcounter, oracle.avcount[], vi_intr_line, oracle.avintr[], vi_field, vi_hlpf ]
			printf[ "  sys_clk=%lld vi_line_clk=%lld (clk-line=%lld) vi_clkfrac=%lld\n", sys_clk, vi_line_clk, vi_line_clk - sys_clk, vi_clkfrac ]
			printf[ "  ares vi.clock=%lld clkfrac=%u ; leapcnt=%u\n", oracle.avclock[], oracle.avclockfrac[], vi_leapcnt ]
			printf[ "  culprit: last exec pc=%08X op=%08X\n", cosim_ppc, cosim_pop ]
			crs : i32 [ i32[ (cosim_pop >> 21) & 31 ] ]
			cad : u32 [ cosim_pbase + u32[ sx16[ cosim_pop ] ] ]
			printf[ "  load base r%d=%08X + %04X -> addr=%08X (phys=%08X) ; ours mem=%08X\n", crs, cosim_pbase, cosim_pop & 0xFFFF, cad, cad & 0x1FFFFFFF, rd_phys32[ vmap[ cad ] ] ]
			for [ i: i32 0, i < 32, i += 1 ]
				ov : u64 [ u64[ cpu.r[ i ] ] ]
				av : u64 [ oracle.reg[ i ] ]
				if [ ov != av ] printf[ "  r%-2d ours=%016llx ares=%016llx\n", i, ov, av ]
			if [ u64[ cpu.hi ] != oracle.rhi[] ] printf[ "  hi ours=%016llx ares=%016llx\n", u64[ cpu.hi ], oracle.rhi[] ]
			if [ u64[ cpu.lo ] != oracle.rlo[] ] printf[ "  lo ours=%016llx ares=%016llx\n", u64[ cpu.lo ], oracle.rlo[] ]
			fflush[ null ]                                   # flush before halting the process
			exit[ 3 ]                                        # STOP on divergence — never continue
		# agreed at pre-instruction cosim_seq: advance the validated checkpoint
		if [ cosim_seq >= cosim_next ]
			r9 : i32 [ ckpt_write[] ]
			if [ (cosim_seq & 511) == 0 ] printf[ "n64 cosim: agree seq=%lld ckpt=%d\n", cosim_seq, r9 ]
			cosim_next = cosim_seq + cosim_iv
		cosim_pre_ours = cpu.c_count                     # audit: count before this instruction
		cosim_pre_ares = i64[ oracle.acount[] ]
		oracle.step[]
		cosim_seq += 1

	# validated-state checkpoint: cosim.seq (our cycle id) + cosim.ares (ares savestate).
	# written only at agreed points, never on divergence — so a resume never re-runs
	# already-validated states.
	func ckpt_read_seq [] -> i64
		f : ref FILE [ fopen[ '/src/silver/foundry/n64/cosim.seq', 'rb' ] ]
		if [ ! f ] return i64[ -1 ]
		v : i64 [ 0 ]
		fread[ ref v, 8, 1, f ]
		fclose[ f ]
		return v

	# fresh boot instead of resume: --reset on the command line (or N64_COSIM_RESTART).
	func reset_requested [] -> bool
		if [ getenv[ 'N64_COSIM_RESTART' ] ] return true
		f : ref FILE [ fopen[ '/proc/self/cmdline', 'rb' ] ]
		if [ ! f ] return false
		buf : local u8 [ 512 ]
		n : i64 [ fread[ buf, 1, 511, f ] ]
		fclose[ f ]
		for [ i: i64 0, i + 5 <= n, i += 1 ]
			if [ buf[i]==114 && buf[i+1]==101 && buf[i+2]==115 && buf[i+3]==101 && buf[i+4]==116 ]
				return true                          # 'reset' present in argv
		return false

	func ckpt_write [] -> i32
		r : i32 [ oracle.save_ckpt[ '/src/silver/foundry/n64/cosim.ares' ] ]
		if [ r != 0 ] return r
		if [ save_ours[ '/src/silver/foundry/n64/cosim.ours' ] != 0 ] return 4
		f : ref FILE [ fopen[ '/src/silver/foundry/n64/cosim.seq', 'wb' ] ]
		if [ f ]
			v : i64 [ cosim_seq ]
			fwrite[ ref v, 8, 1, f ]
			fclose[ f ]
		return 0

	# our full machine state: CPU + memory + timing/interrupt regs. render (gx_*/
	# tmem) and audio-DSP (a_*) state omitted — they don't feed the CPU lockstep.
	func save_ours [ fn: cstr ] -> i32
		f : ref FILE [ fopen[ fn, 'wb' ] ]
		if [ ! f ] return 1
		fwrite[ rdram, 1, 0x800000, f ]
		fwrite[ dmem, 1, 0x1000, f ]
		fwrite[ imem, 1, 0x1000, f ]
		fwrite[ pif_ram, 1, 64, f ]
		fwrite[ cpu.r, 8, 32, f ]
		fwrite[ cpu.fpr, 8, 32, f ]
		fwrite[ cpu.tlb_hi, 4, 32, f ]
		fwrite[ cpu.tlb_pm, 4, 32, f ]
		fwrite[ cpu.tlb_lo0, 4, 32, f ]
		fwrite[ cpu.tlb_lo1, 4, 32, f ]
		fwrite[ ai_fifo_dram, 4, 2, f ]
		fwrite[ ai_fifo_len, 4, 2, f ]
		fwrite[ dc_tag, 4, 512, f ]
		fwrite[ ic_tag, 4, 512, f ]
		sc : local u64 [ 80 ]
		sc[ 0 ]=u64[cpu.hi]  sc[ 1 ]=u64[cpu.lo]  sc[ 2 ]=u64[cpu.pc]  sc[ 3 ]=u64[cpu.npc]  sc[ 4 ]=u64[cpu.fcr31]
		sc[ 5 ]=u64[cpu.c_index]  sc[ 6 ]=u64[cpu.c_count]  sc[ 7 ]=u64[cpu.c_compare]  sc[ 8 ]=u64[cpu.c_status]
		sc[ 9 ]=u64[cpu.c_cause]  sc[ 10]=u64[cpu.c_epc]  sc[ 11]=u64[cpu.c_config]  sc[ 12]=u64[cpu.c_wired]
		sc[ 13]=u64[cpu.c_entrylo0]  sc[ 14]=u64[cpu.c_entrylo1]  sc[ 15]=u64[cpu.c_entryhi]  sc[ 16]=u64[cpu.c_pagemask]
		sc[ 17]=u64[cpu.tlb_used]  sc[ 18]=u64[cpu.ll_bit]
		sc[ 19]=u64[sys_clk]  sc[ 20]=u64[mi_intr]  sc[ 21]=u64[mi_mask]  sc[ 22]=u64[mi_mode]
		sc[ 23]=u64[vi_ctrl]  sc[ 24]=u64[vi_origin]  sc[ 25]=u64[vi_width]  sc[ 26]=u64[vi_intr_line]  sc[ 27]=u64[vi_current]
		sc[ 28]=u64[vi_hstart]  sc[ 29]=u64[vi_vstart]  sc[ 30]=u64[vi_xscale]  sc[ 31]=u64[vi_yscale]
		sc[ 32]=u64[vi_vcounter]  sc[ 33]=u64[vi_field]  sc[ 34]=u64[vi_leapcnt]  sc[ 35]=u64[vi_line_clk]  sc[ 36]=u64[vi_clkfrac]
		sc[ 37]=u64[vi_refreshed]  sc[ 38]=u64[si_dram]  sc[ 39]=u64[si_status]  sc[ 40]=u64[si_dma_p]  sc[ 41]=u64[si_dma_at]
		sc[ 42]=u64[pi_dram]  sc[ 43]=u64[pi_cart]  sc[ 44]=u64[pi_status]
		sc[ 45]=u64[sp_dram]  sc[ 46]=u64[sp_mem]  sc[ 47]=u64[sp_pc]  sc[ 48]=u64[sp_semaphore]  sc[ 49]=u64[dpc_status]
		sc[ 50]=u64[ai_dram]  sc[ 51]=u64[ai_len]  sc[ 52]=u64[ai_ctrl]  sc[ 53]=u64[ai_dacrate]  sc[ 54]=u64[ai_fifo_n]
		sc[ 55]=u64[pif_state]  sc[ 56]=u64[lle]  sc[ 57]=u64[frames]  sc[ 58]=u64[pad_st]  sc[ 59]=u64[stick_x]  sc[ 60]=u64[stick_y]
		sc[ 61]=u64[cosim_seq]
		sc[ 62]=u64[vi_hlpf]  sc[ 63]=u64[vi_qld]  sc[ 64]=u64[vi_leappat]  sc[ 65]=u64[vi_hleap0]  sc[ 66]=u64[vi_hleap1]
		sc[ 67]=u64[si_lat]  sc[ 68]=u64[sp_status]
		fwrite[ sc, 8, 80, f ]
		fclose[ f ]
		return 0

	func load_ours [ fn: cstr ] -> i32
		f : ref FILE [ fopen[ fn, 'rb' ] ]
		if [ ! f ] return 1
		fread[ rdram, 1, 0x800000, f ]
		fread[ dmem, 1, 0x1000, f ]
		fread[ imem, 1, 0x1000, f ]
		fread[ pif_ram, 1, 64, f ]
		fread[ cpu.r, 8, 32, f ]
		fread[ cpu.fpr, 8, 32, f ]
		fread[ cpu.tlb_hi, 4, 32, f ]
		fread[ cpu.tlb_pm, 4, 32, f ]
		fread[ cpu.tlb_lo0, 4, 32, f ]
		fread[ cpu.tlb_lo1, 4, 32, f ]
		fread[ ai_fifo_dram, 4, 2, f ]
		fread[ ai_fifo_len, 4, 2, f ]
		fread[ dc_tag, 4, 512, f ]
		fread[ ic_tag, 4, 512, f ]
		sc : local u64 [ 80 ]
		fread[ sc, 8, 80, f ]
		fclose[ f ]
		cpu.hi=i64[sc[ 0 ]]  cpu.lo=i64[sc[ 1 ]]  cpu.pc=u32[sc[ 2 ]]  cpu.npc=u32[sc[ 3 ]]  cpu.fcr31=u32[sc[ 4 ]]
		cpu.c_index=u32[sc[ 5 ]]  cpu.c_count=u32[sc[ 6 ]]  cpu.c_compare=u32[sc[ 7 ]]  cpu.c_status=u32[sc[ 8 ]]
		cpu.c_cause=u32[sc[ 9 ]]  cpu.c_epc=u32[sc[ 10]]  cpu.c_config=u32[sc[ 11]]  cpu.c_wired=u32[sc[ 12]]
		cpu.c_entrylo0=u32[sc[ 13]]  cpu.c_entrylo1=u32[sc[ 14]]  cpu.c_entryhi=u32[sc[ 15]]  cpu.c_pagemask=u32[sc[ 16]]
		cpu.tlb_used=sc[ 17]!=0  cpu.ll_bit=sc[ 18]!=0
		sys_clk=i64[sc[ 19]]  mi_intr=u32[sc[ 20]]  mi_mask=u32[sc[ 21]]  mi_mode=u32[sc[ 22]]
		vi_ctrl=u32[sc[ 23]]  vi_origin=u32[sc[ 24]]  vi_width=u32[sc[ 25]]  vi_intr_line=u32[sc[ 26]]  vi_current=u32[sc[ 27]]
		vi_hstart=u32[sc[ 28]]  vi_vstart=u32[sc[ 29]]  vi_xscale=u32[sc[ 30]]  vi_yscale=u32[sc[ 31]]
		vi_vcounter=u32[sc[ 32]]  vi_field=u32[sc[ 33]]  vi_leapcnt=u32[sc[ 34]]  vi_line_clk=i64[sc[ 35]]  vi_clkfrac=i64[sc[ 36]]
		vi_refreshed=sc[ 37]!=0  si_dram=u32[sc[ 38]]  si_status=u32[sc[ 39]]  si_dma_p=sc[ 40]!=0  si_dma_at=u32[sc[ 41]]
		pi_dram=u32[sc[ 42]]  pi_cart=u32[sc[ 43]]  pi_status=u32[sc[ 44]]
		sp_dram=u32[sc[ 45]]  sp_mem=u32[sc[ 46]]  sp_pc=u32[sc[ 47]]  sp_semaphore=u32[sc[ 48]]  dpc_status=u32[sc[ 49]]
		ai_dram=u32[sc[ 50]]  ai_len=u32[sc[ 51]]  ai_ctrl=u32[sc[ 52]]  ai_dacrate=u32[sc[ 53]]  ai_fifo_n=i32[sc[ 54]]
		pif_state=i32[sc[ 55]]  lle=sc[ 56]!=0  frames=u32[sc[ 57]]  pad_st=u32[sc[ 58]]  stick_x=i32[sc[ 59]]  stick_y=i32[sc[ 60]]
		cosim_seq=i64[sc[ 61]]
		vi_hlpf=u32[sc[ 62]]  vi_qld=u32[sc[ 63]]  vi_leappat=u32[sc[ 64]]  vi_hleap0=u32[sc[ 65]]  vi_hleap1=u32[sc[ 66]]
		si_lat=u32[sc[ 67]]  sp_status=u32[sc[ 68]]
		c_cmp_prev = cpu.c_count                    # crossing window restarts at resume
		c_sysbase  = cpu.c_count                    # sys_clk continues from checkpoint value
		return 0

	func step []
		if [ cosim ]
			if [ cosim_ff > 0 ]
				cosim_ff  = cosim_ff - 1               # replaying ours to the validated cycle
				cosim_seq = cosim_seq + 1
			el
				mi_intr = (mi_intr & (~u32[0x21])) | (oracle.amiintr[] & 0x21)   # HLE RSP/RDP: SP+DP int timing from ares
				mi_check[]
				cosim_check[]
		# pending interrupt (IE, not EXL/ERL, enabled + pending lines)
		st : u32 [ cpu.c_status ]
		if [ (st & 1) && !(st & 6) && (cpu.c_cause & st & 0xFF00) ]
			take_int[]                                # ares: interrupt-taken is its OWN step —
			cpu.c_count += 1                          # the interrupt step (ares step(1*2)/2)
			step_cycle[ 0 ]                           # redirect to vector, 1 count cycle, retire nothing
			return
		fpa : u32 [ vmap[ cpu.pc ] ]
		op  : u32 [ rd_phys32[ fpa ] ]                # fetch: icache path, not dcache
		c_istart = cpu.c_count                        # instruction-start count (MTC0 Count preserves this instr's cost)
		cpu.c_count += 1                              # fetch base (ares step(1*2)/2), BEFORE the data read
		cpu.c_count += i64[ io_rcost[ cpu.pc, fpa ] ] # uncached fetch (IMEM/KSEG1) pays RCP read cost
		icache[ cpu.pc, fpa ]                         # cached fetch: charge I-cache miss fill
		cur : u32 [ cpu.pc ]
		if [ hash_on ]
			rh : u64 [ 0xcbf29ce484222325 ]
			rh = fnv_u64[ rh, u64[ cur ] ]
			for [ ri: i32 0, ri < 32, ri += 1 ]
				rh = fnv_u64[ rh, u64[ cpu.r[ ri ] ] ]
			for [ ri: i32 0, ri < 32, ri += 1 ]
				rh = fnv_u64[ rh, cpu.fpr[ ri ] ]
			rh = fnv_u64[ rh, u64[ cpu.hi ] ]
			rh = fnv_u64[ rh, u64[ cpu.lo ] ]
			printf[ "%llu %08X %08X fcr=%08X %016llx\n", hash_seq, cur, op, cpu.fcr31, rh ]
			hash_seq = hash_seq + 1
		if [ dbg_on ]
			slot : i32 [ dbg_ri & 31 ]
			dbg_ring[ slot * 2 ]     = cur
			dbg_ring[ slot * 2 + 1 ] = op
			dbg_ri += 1
			pv : u32 [ dbg_ring[ ((dbg_ri + 30) & 31) * 2 ] ]
			if [ cur != pv + 4 ]
				js : i32 [ dbg_ji & 31 ]
				dbg_jring[ js * 2 ]     = pv
				dbg_jring[ js * 2 + 1 ] = cur
				dbg_ji += 1
			if [ op == 0 ]
				dbg_z += 1
				if [ dbg_z == 64 && dbg_esc == 0 ]
					dbg_esc = 1
					printf[ "n64 NOPSLED start=%08X ra=%08X sp=%08X f%u — last jumps:\n", cur - 252, u32[ cpu.r[31] ], u32[ cpu.r[29] ], frames ]
					for [ k: i32 0, k < 32, k += 1 ]
						qq : i32 [ (dbg_ji + k) & 31 ]
						printf[ "  J %08X -> %08X\n", dbg_jring[ qq * 2 ], dbg_jring[ qq * 2 + 1 ] ]
			el
				dbg_z = 0
		if [ dbg_on && cur == 0x80193508 && (u32[ cpu.r[6] ] & 0x7FFFFF) == 0x88900 && dbg_wv < 0 ]
			dbg_wv += 1
			nd9 : u32 [ u32[ cpu.r[10] ] ]
			printf[ "n64 GDV node=%08X fx=%08X fy=%08X fz=%08X f%u\n", nd9, dr_r32[ nd9 + 0x20 ], dr_r32[ nd9 + 0x24 ], dr_r32[ nd9 + 0x28 ], frames ]
		if [ dbg_on && cur == 0x80183B20 ]
			dlp : u32 [ u32[ cpu.r[4] ] ]
			dlo : u32 [ dlp & 0x7FFFFF ]
			printf[ "n64 proc_dynlist a0=%08X ra=%08X w0=%08X w1=%08X w2=%08X f%u\n", dlp, u32[ cpu.r[31] ], dr_r32[ dlo ], dr_r32[ dlo + 4 ], dr_r32[ dlo + 8 ], frames ]
		if [ dbg_on && cur == 0x8018D298 ]
			fp : u32 [ u32[ cpu.r[4] ] & 0x7FFFFF ]
			fs : local u8 [ 64 ]
			for [ k: i32 0, k < 60, k += 1 ]
				fchr : u32 [ u32[ rdram[ fp + u32[k] ] ] ]
				if [ fchr >= 32 && fchr < 127 ] fs[ k ] = u8[ fchr ]
				el fs[ k ] = 46
			fs[ 60 ] = 0
			printf[ "n64 gd_printf ra=%08X a1=%08X a2=%08X f%u: %s\n", u32[ cpu.r[31] ], u32[ cpu.r[5] ], u32[ cpu.r[6] ], frames, fs ]
		cpu.pc  = cpu.npc
		cpu.npc = cpu.pc + 4
		c0 : u32 [ cpu.c_count ]                              # exec adds multicycle stall cycles (mul/div/...)
		cosim_pbase = u32[ cpu.r[ (op >> 21) & 31 ] ]        # base reg before exec (culprit report)
		exec[ op, cur ]
		cosim_ppc = cur                                       # remember for co-sim culprit report
		cosim_pop = op
		cpu.r[ 0 ] = 0
		dcyc : u32 [ cpu.c_count - c0 ]
		if [ dcyc > 200 ] dcyc = 0                            # guard: mtc0 COUNT write, not a cycle cost
		step_cycle[ dcyc ]

	# advance one Count cycle: clock, VI, timer-compare, deferred SI DMA.
	# shared by the normal instruction path and the interrupt-taken step.
	func step_cycle [ dcyc: u32 ]
		sc : u32 [ cpu.c_count - c_sysbase ]                  # counts elapsed since last tick (wrap-safe)
		c_sysbase = cpu.c_count
		sys_clk = sys_clk + 2 * i64[ sc ]                    # ares vi.clock == 2*count (full step clocks)
		vi_sync[]                                             # advance VI line counter to this cycle
		ai_sync[]                                             # cycle-accurate AI DMA + interrupt
		d   : u32 [ cpu.c_count - c_cmp_prev ]                # counts advanced this step (mod 2^32)
		off : u32 [ cpu.c_compare - c_cmp_prev - 1 ]          # prev..Compare distance
		if [ off < d ]                                        # Compare crossed, even on a multi-count jump
			cpu.c_cause = cpu.c_cause | 0x8000
		c_cmp_prev = cpu.c_count
		rcp_poll[]

	# fire any SI/PI DMA whose deferred completion time has arrived. called at
	# instruction end AND before a status read, so a poll samples the same
	# completion instant ares does (it fires mid-instruction during a step()).
	func rcp_poll []
		if [ si_dma_p && cpu.c_count >= si_dma_at ]           # deferred SI DMA completion
			si_dma_p  = false
			si_status = 0x1000                               # busy/pch/dmaState clear; interrupt held to ack
			mi_intr   = mi_intr | 0x2
			mi_check[]
		if [ pi_dma_p && cpu.c_count >= pi_dma_at ]           # deferred PI DMA completion
			pi_dma_p  = false
			pi_status = (pi_status & (~u32[0x1])) | 0x8       # dmaBusy clear, interrupt set
			mi_intr   = mi_intr | 0x10
			mi_check[]

	func branch [ cond: bool, cur: u32, op: u32, likely: bool ]
		if [ cond ]
			cpu.npc = cur + 4 + (u32[ sx16[ op ] ] << 2)
		el [ likely ]
			cpu.pc  = cpu.npc
			cpu.npc = cpu.pc + 4

	func exec [ op: u32, cur: u32 ]
		o  : u32 [ op >> 26 ]
		rs : i32 [ i32[ (op >> 21) & 31 ] ]
		rt : i32 [ i32[ (op >> 16) & 31 ] ]
		rd : i32 [ i32[ (op >> 11) & 31 ] ]
		sa : i32 [ i32[ (op >> 6) & 31 ] ]
		im : i64 [ sx16[ op ] ]
		zi : u32 [ op & 0xFFFF ]
		if [ (o == 0x11 || o == 0x31 || o == 0x35 || o == 0x39 || o == 0x3D) && (cpu.c_status & 0x20000000) == 0 ]
			take_cpu[ cur ]
			return
		switch [ o ]
		case 0x00
			exec_special[ op, rs, rt, rd, sa, cur ]
		case 0x01
			rti : i32 [ rt ]
			c : bool [ false ]
			if [ rti == 0 ] c = cpu.r[ rs ] < 0                # BLTZ
			el [ rti == 1 ] c = cpu.r[ rs ] >= 0               # BGEZ
			el [ rti == 2 ]                                    # BLTZL
				branch[ cpu.r[ rs ] < 0, cur, op, true ]
				return
			el [ rti == 3 ]                                    # BGEZL
				branch[ cpu.r[ rs ] >= 0, cur, op, true ]
				return
			el [ rti == 16 || rti == 17 ]                      # BLTZAL/BGEZAL
				c = (rti == 16) ? (cpu.r[ rs ] < 0) : (cpu.r[ rs ] >= 0)
				cpu.r[ 31 ] = sx32[ cur + 8 ]
			branch[ c, cur, op, false ]
		case 0x02                                              # J
			cpu.npc = ((cur + 4) & 0xF0000000) | ((op & 0x3FFFFFF) << 2)
		case 0x03                                              # JAL
			cpu.r[ 31 ] = sx32[ cur + 8 ]
			cpu.npc = ((cur + 4) & 0xF0000000) | ((op & 0x3FFFFFF) << 2)
		case 0x04
			branch[ cpu.r[ rs ] == cpu.r[ rt ], cur, op, false ]
		case 0x05
			branch[ cpu.r[ rs ] != cpu.r[ rt ], cur, op, false ]
		case 0x06
			branch[ cpu.r[ rs ] <= 0, cur, op, false ]
		case 0x07
			branch[ cpu.r[ rs ] > 0, cur, op, false ]
		case 0x08, 0x09                                        # ADDI/ADDIU
			cpu.r[ rt ] = sx32[ u32[ cpu.r[ rs ] ] + u32[ im ] ]
		case 0x0A
			cpu.r[ rt ] = (cpu.r[ rs ] < im) ? 1 : 0
		case 0x0B
			cpu.r[ rt ] = (u64[ cpu.r[ rs ] ] < u64[ im ]) ? 1 : 0
		case 0x0C
			cpu.r[ rt ] = cpu.r[ rs ] & i64[ zi ]
		case 0x0D
			cpu.r[ rt ] = cpu.r[ rs ] | i64[ zi ]
		case 0x0E
			cpu.r[ rt ] = cpu.r[ rs ] ^ i64[ zi ]
		case 0x0F
			cpu.r[ rt ] = sx32[ zi << 16 ]
		case 0x10
			exec_cop0[ op, rs, rt, rd ]
		case 0x11
			exec_cop1[ op, cur ]
		case 0x14
			branch[ cpu.r[ rs ] == cpu.r[ rt ], cur, op, true ]
		case 0x15
			branch[ cpu.r[ rs ] != cpu.r[ rt ], cur, op, true ]
		case 0x16
			branch[ cpu.r[ rs ] <= 0, cur, op, true ]
		case 0x17
			branch[ cpu.r[ rs ] > 0, cur, op, true ]
		case 0x18, 0x19                                        # DADDI/U
			cpu.r[ rt ] = cpu.r[ rs ] + im
		case 0x1A                                              # LDL
			cpu.r[ rt ] = rd64[ u32[ cpu.r[ rs ] + im ] & (~u32[7]) ]
		case 0x1B
			cpu.r[ rt ] = rd64[ u32[ cpu.r[ rs ] + im ] & (~u32[7]) ]
		case 0x20
			cpu.r[ rt ] = i64[ i32[ i8[ rd8[ u32[ cpu.r[ rs ] + im ] ] ] ] ]
		case 0x21
			cpu.r[ rt ] = i64[ i32[ i16[ rd16[ u32[ cpu.r[ rs ] + im ] ] ] ] ]
		case 0x22                                              # LWL
			a2 : u32 [ u32[ cpu.r[ rs ] + im ] ]
			sh : u32 [ (a2 & 3) * 8 ]
			w  : u32 [ rd32v[ a2 & (~u32[3]) ] ]
			ov1 : u32 [ u32[ cpu.r[ rt ] ] ]
			mkv : u32 [ (sh == 0) ? w : ((ov1 & ((u32[1] << sh) - 1)) | (w << sh)) ]
			cpu.r[ rt ] = sx32[ mkv ]
		case 0x23
			cpu.r[ rt ] = sx32[ rd32v[ u32[ cpu.r[ rs ] + im ] ] ]
		case 0x24
			cpu.r[ rt ] = i64[ rd8[ u32[ cpu.r[ rs ] + im ] ] ]
		case 0x25
			cpu.r[ rt ] = i64[ rd16[ u32[ cpu.r[ rs ] + im ] ] ]
		case 0x26                                              # LWR
			a3 : u32 [ u32[ cpu.r[ rs ] + im ] ]
			sh2 : u32 [ (3 - (a3 & 3)) * 8 ]
			w2 : u32 [ rd32v[ a3 & (~u32[3]) ] ]
			ov2 : u32 [ u32[ cpu.r[ rt ] ] ]
			mk2 : u32 [ (sh2 == 0) ? w2 : ((ov2 & (~(u32[0xFFFFFFFF] >> sh2))) | (w2 >> sh2)) ]
			cpu.r[ rt ] = sx32[ mk2 ]
		case 0x27
			cpu.r[ rt ] = i64[ rd32v[ u32[ cpu.r[ rs ] + im ] ] ]
		case 0x28
			wr8v[ u32[ cpu.r[ rs ] + im ], u32[ cpu.r[ rt ] ] ]
		case 0x29
			wr16v[ u32[ cpu.r[ rs ] + im ], u32[ cpu.r[ rt ] ] ]
		case 0x2A                                              # SWL
			a4 : u32 [ u32[ cpu.r[ rs ] + im ] ]
			sh3 : u32 [ (a4 & 3) * 8 ]
			w3 : u32 [ rd32v[ a4 & (~u32[3]) ] ]
			ov3 : u32 [ u32[ cpu.r[ rt ] ] ]
			nv : u32 [ (sh3 == 0) ? ov3 : ((w3 & (~(u32[0xFFFFFFFF] >> sh3))) | (ov3 >> sh3)) ]
			wr32v[ a4 & (~u32[3]), nv ]
		case 0x2B
			wr32v[ u32[ cpu.r[ rs ] + im ], u32[ cpu.r[ rt ] ] ]
		case 0x2E                                              # SWR
			a5 : u32 [ u32[ cpu.r[ rs ] + im ] ]
			sh4 : u32 [ (3 - (a5 & 3)) * 8 ]
			w4 : u32 [ rd32v[ a5 & (~u32[3]) ] ]
			ov4 : u32 [ u32[ cpu.r[ rt ] ] ]
			nv2 : u32 [ (sh4 == 0) ? ov4 : ((w4 & (~(u32[0xFFFFFFFF] << sh4))) | (ov4 << sh4)) ]
			wr32v[ a5 & (~u32[3]), nv2 ]
		case 0x2F                                              # CACHE
			cache_op[ u32[ rt ], u32[ cpu.r[ rs ] + im ] ]
			return
		case 0x30                                              # LL
			cpu.r[ rt ] = sx32[ rd32v[ u32[ cpu.r[ rs ] + im ] ] ]
			cpu.ll_bit = true
		case 0x31
			fset32[ rt, rd32v[ u32[ cpu.r[ rs ] + im ] ] ]
		case 0x35
			fset64[ rt, u64[ rd64[ u32[ cpu.r[ rs ] + im ] ] ] ]
		case 0x37
			cpu.r[ rt ] = rd64[ u32[ cpu.r[ rs ] + im ] ]
		case 0x38                                              # SC
			if [ cpu.ll_bit ] wr32v[ u32[ cpu.r[ rs ] + im ], u32[ cpu.r[ rt ] ] ]
			cpu.r[ rt ] = (cpu.ll_bit) ? 1 : 0
			cpu.ll_bit = false
		case 0x39
			wr32v[ u32[ cpu.r[ rs ] + im ], fget32[ rt ] ]
		case 0x3D
			wr64[ u32[ cpu.r[ rs ] + im ], i64[ fget64[ rt ] ] ]
		case 0x3F
			wr64[ u32[ cpu.r[ rs ] + im ], cpu.r[ rt ] ]
		default
			take_exc[ 10, cur ]                                # Reserved Instruction
			return

	func exec_special [ op: u32, rs: i32, rt: i32, rd: i32, sa: i32, cur: u32 ]
		f : u32 [ op & 0x3F ]
		switch [ f ]
		case 0x00
			cpu.r[ rd ] = sx32[ u32[ cpu.r[ rt ] ] << u32[ sa ] ]
		case 0x02
			cpu.r[ rd ] = sx32[ u32[ cpu.r[ rt ] ] >> u32[ sa ] ]
		case 0x03
			cpu.r[ rd ] = sx32[ u32[ i32[ cpu.r[ rt ] ] >> sa ] ]
		case 0x04
			cpu.r[ rd ] = sx32[ u32[ cpu.r[ rt ] ] << (u32[ cpu.r[ rs ] ] & 31) ]
		case 0x06
			cpu.r[ rd ] = sx32[ u32[ cpu.r[ rt ] ] >> (u32[ cpu.r[ rs ] ] & 31) ]
		case 0x07
			cpu.r[ rd ] = sx32[ u32[ i32[ cpu.r[ rt ] ] >> i32[ cpu.r[ rs ] & 31 ] ] ]
		case 0x08                                              # JR
			cpu.npc = u32[ cpu.r[ rs ] ]
		case 0x09
			cpu.r[ rd ] = sx32[ cpu.pc + 4 ]
			cpu.npc = u32[ cpu.r[ rs ] ]
		case 0x0F                                              # SYNC
			return
		case 0x10
			cpu.r[ rd ] = cpu.hi
		case 0x11
			cpu.hi = cpu.r[ rs ]
		case 0x12
			cpu.r[ rd ] = cpu.lo
		case 0x13
			cpu.lo = cpu.r[ rs ]
		case 0x14
			dv1 : i64 [ cpu.r[ rt ] ]
			cpu.r[ rd ] = dv1 << (u32[ cpu.r[ rs ] ] & 63)
		case 0x16
			dv2 : u64 [ u64[ cpu.r[ rt ] ] ]
			cpu.r[ rd ] = i64[ dv2 >> (u32[ cpu.r[ rs ] ] & 63) ]
		case 0x17
			dv3 : i64 [ cpu.r[ rt ] ]
			cpu.r[ rd ] = dv3 >> (u32[ cpu.r[ rs ] ] & 63)
		case 0x18                                              # MULT
			p1 : i64 [ i64[ i32[ cpu.r[ rs ] ] ] * i64[ i32[ cpu.r[ rt ] ] ] ]
			cpu.lo = sx32[ u32[ p1 ] ]
			cpu.hi = sx32[ u32[ p1 >> 32 ] ]
			cpu.c_count += 4                                   # VR4300 mult = 5 cycles
		case 0x19                                              # MULTU
			p2 : u64 [ u64[ u32[ cpu.r[ rs ] ] ] * u64[ u32[ cpu.r[ rt ] ] ] ]
			cpu.lo = sx32[ u32[ p2 ] ]
			cpu.hi = sx32[ u32[ p2 >> 32 ] ]
			cpu.c_count += 4
		case 0x1A                                              # DIV
			dvs : i64 [ cpu.r[ rt ] ]                          # s64 divisor (avoids INT_MIN/-1 host trap)
			if [ dvs != 0 ]
				num : i64 [ i64[ i32[ cpu.r[ rs ] ] ] ]
				cpu.lo = sx32[ u32[ i32[ num / dvs ] ] ]
				cpu.hi = sx32[ u32[ i32[ num % dvs ] ] ]
			el
				cpu.lo = (i32[ cpu.r[ rs ] ] < 0) ? 1 : -1
				cpu.hi = sx32[ u32[ cpu.r[ rs ] ] ]
			cpu.c_count += 36                                  # VR4300 div = 37 cycles
		case 0x1B                                              # DIVU
			d2 : u32 [ u32[ cpu.r[ rt ] ] ]
			if [ d2 != 0 ]
				cpu.lo = sx32[ u32[ cpu.r[ rs ] ] / d2 ]
				cpu.hi = sx32[ u32[ cpu.r[ rs ] ] % d2 ]
			el
				cpu.lo = -1
				cpu.hi = sx32[ u32[ cpu.r[ rs ] ] ]
			cpu.c_count += 36
		case 0x1C                                              # DMULT (low-precision fallback)
			dq1 : i64 [ cpu.r[ rs ] ]
			dq2 : i64 [ cpu.r[ rt ] ]
			cpu.lo = dq1 * dq2
			cpu.hi = (cpu.lo < 0) ? -1 : 0
			cpu.c_count += 7                                   # VR4300 dmult = 8 cycles
		case 0x1D
			dm1 : u64 [ u64[ cpu.r[ rs ] ] ]
			dm2 : u64 [ u64[ cpu.r[ rt ] ] ]
			cpu.lo = i64[ dm1 * dm2 ]
			cpu.hi = 0
			cpu.c_count += 7
		case 0x1E                                              # DDIV
			ds1 : i64 [ cpu.r[ rs ] ]
			dt1 : i64 [ cpu.r[ rt ] ]
			if [ dt1 != 0 ]
				if [ u64[ ds1 ] == 0x8000000000000000 && dt1 == -1 ]   # INT64_MIN / -1 overflow
					cpu.lo = ds1
					cpu.hi = 0
				el
					cpu.lo = ds1 / dt1
					cpu.hi = ds1 % dt1
			el
				cpu.lo = (ds1 < 0) ? 1 : -1
				cpu.hi = ds1
			cpu.c_count += 68                                  # VR4300 ddiv = 69 cycles (ref: ares DDIV)
		case 0x1F                                              # DDIVU
			ds2 : u64 [ u64[ cpu.r[ rs ] ] ]
			dt2 : u64 [ u64[ cpu.r[ rt ] ] ]
			if [ dt2 != 0 ]
				cpu.lo = i64[ ds2 / dt2 ]
				cpu.hi = i64[ ds2 % dt2 ]
			el
				cpu.lo = -1
				cpu.hi = i64[ ds2 ]
			cpu.c_count += 68                                  # ref: ares DDIVU
		case 0x20, 0x21
			cpu.r[ rd ] = sx32[ u32[ cpu.r[ rs ] ] + u32[ cpu.r[ rt ] ] ]
		case 0x22, 0x23
			cpu.r[ rd ] = sx32[ u32[ cpu.r[ rs ] ] - u32[ cpu.r[ rt ] ] ]
		case 0x24
			cpu.r[ rd ] = cpu.r[ rs ] & cpu.r[ rt ]
		case 0x25
			cpu.r[ rd ] = cpu.r[ rs ] | cpu.r[ rt ]
		case 0x26
			cpu.r[ rd ] = cpu.r[ rs ] ^ cpu.r[ rt ]
		case 0x27
			cpu.r[ rd ] = ~(cpu.r[ rs ] | cpu.r[ rt ])
		case 0x2A
			cpu.r[ rd ] = (cpu.r[ rs ] < cpu.r[ rt ]) ? 1 : 0
		case 0x2B
			cpu.r[ rd ] = (u64[ cpu.r[ rs ] ] < u64[ cpu.r[ rt ] ]) ? 1 : 0
		case 0x2C, 0x2D
			cpu.r[ rd ] = cpu.r[ rs ] + cpu.r[ rt ]
		case 0x2E, 0x2F
			cpu.r[ rd ] = cpu.r[ rs ] - cpu.r[ rt ]
		case 0x38
			dv4 : i64 [ cpu.r[ rt ] ]
			cpu.r[ rd ] = dv4 << u32[ sa ]
		case 0x3A
			dv5 : u64 [ u64[ cpu.r[ rt ] ] ]
			cpu.r[ rd ] = i64[ dv5 >> u32[ sa ] ]
		case 0x3B
			dv6 : i64 [ cpu.r[ rt ] ]
			cpu.r[ rd ] = dv6 >> u32[ sa ]
		case 0x3C
			dv7 : i64 [ cpu.r[ rt ] ]
			cpu.r[ rd ] = dv7 << u32[ sa + 32 ]
		case 0x3E
			dv8 : u64 [ u64[ cpu.r[ rt ] ] ]
			cpu.r[ rd ] = i64[ dv8 >> u32[ sa + 32 ] ]
		case 0x3F
			dv9 : i64 [ cpu.r[ rt ] ]
			cpu.r[ rd ] = dv9 >> u32[ sa + 32 ]
		default
			take_exc[ 10, cur ]                                # Reserved Instruction
			return

	func exec_cop0 [ op: u32, rs: i32, rt: i32, rd: i32 ]
		if [ rs == 0 ]                                         # MFC0
			v : u32 [ 0 ]
			if [ rd == 0 ]  v = cpu.c_index
			el [ rd == 2 ]  v = cpu.c_entrylo0
			el [ rd == 3 ]  v = cpu.c_entrylo1
			el [ rd == 5 ]  v = cpu.c_pagemask
			el [ rd == 9 ]  v = c_istart >> 1                 # ares reads count BEFORE this instr's clocks
			el [ rd == 10 ] v = cpu.c_entryhi
			el [ rd == 11 ] v = cpu.c_compare >> 1            # ares Compare = scc.compare >> 1
			el [ rd == 12 ] v = cpu.c_status
			el [ rd == 13 ] v = cpu.c_cause
			el [ rd == 14 ] v = cpu.c_epc
			el [ rd == 16 ] v = cpu.c_config
			cpu.r[ rt ] = sx32[ v ]
			return
		if [ rs == 4 ]                                         # MTC0
			v2 : u32 [ u32[ cpu.r[ rt ] ] ]
			if [ rd == 0 ]  cpu.c_index = v2
			el [ rd == 2 ]  cpu.c_entrylo0 = v2
			el [ rd == 3 ]  cpu.c_entrylo1 = v2
			el [ rd == 5 ]  cpu.c_pagemask = v2
			el [ rd == 9 ]
				accr : u32 [ cpu.c_count - c_istart ]   # ares adds this instr's clocks AFTER the write
				cpu.c_count = (v2 << 1) + accr          # ares scc.count = value<<1, then += clocks
				c_cmp_prev  = cpu.c_count
				c_sysbase   = c_sysbase + (v2 << 1) - c_istart   # shift base by rewrite delta: sys_clk keeps this instr's clocks (ares VI keeps them)
			el [ rd == 10 ] cpu.c_entryhi = v2
			el [ rd == 11 ]
				cpu.c_compare = v2 << 1            # ares scc.compare = MTC0 value << 1
				c_cmp_prev    = cpu.c_count
				cpu.c_cause = cpu.c_cause & (~u32[0x8000])
			el [ rd == 12 ] cpu.c_status = v2
			el [ rd == 13 ] cpu.c_cause = (cpu.c_cause & (~u32[0x300])) | (v2 & 0x300)
			el [ rd == 14 ] cpu.c_epc = v2
			return
		if [ (op & 0x3F) == 0x02 ]                             # TLBWI
			ti : i32 [ i32[ cpu.c_index & 31 ] ]
			cpu.tlb_hi[ ti ]  = cpu.c_entryhi
			cpu.tlb_pm[ ti ]  = cpu.c_pagemask
			cpu.tlb_lo0[ ti ] = cpu.c_entrylo0
			cpu.tlb_lo1[ ti ] = cpu.c_entrylo1
			cpu.tlb_used = true
			return
		if [ (op & 0x3F) == 0x08 ]                             # TLBP (ares CPU::TLBP)
			cpu.c_index = 0x80000000                           # probeFailure=1
			for [ i: i32 0, i < 32, i += 1 ]
				pm : u32 [ cpu.tlb_pm[ i ] ]
				vmask : u32 [ ~(pm | 0x1FFF) ]                 # pagemask-aware VPN mask
				if [ (cpu.c_entryhi & vmask) != (cpu.tlb_hi[ i ] & vmask) ] continue
				g : bool [ ((cpu.tlb_lo0[ i ] & 1) != 0) && ((cpu.tlb_lo1[ i ] & 1) != 0) ]
				if [ (!g) && ((cpu.tlb_hi[ i ] & 0xFF) != (cpu.c_entryhi & 0xFF)) ] continue
				cpu.c_index = u32[ i ]                         # first match wins
				break
			return
		if [ (op & 0x3F) == 0x01 ]                             # TLBR
			ri : i32 [ i32[ cpu.c_index & 31 ] ]
			cpu.c_entryhi  = cpu.tlb_hi[ ri ]
			cpu.c_pagemask = cpu.tlb_pm[ ri ]
			cpu.c_entrylo0 = cpu.tlb_lo0[ ri ]
			cpu.c_entrylo1 = cpu.tlb_lo1[ ri ]
			return
		if [ (op & 0x3F) == 0x18 ]                             # ERET
			if [ dbg_esc < 40 && (cpu.c_epc < 0x80000000 || cpu.c_epc >= 0x80400000) ]
				dbg_esc += 1
				printf[ "n64 ERET to bogus epc=%08X f%u\n", cpu.c_epc, frames ]
			if [ dbg_on && frames >= 200 && frames < 280 ]
				printf[ "n64 ERET %08X ra=%08X f%u\n", cpu.c_epc, u32[ cpu.r[31] ], frames ]
			cpu.pc  = cpu.c_epc
			cpu.npc = cpu.pc + 4
			cpu.c_status = cpu.c_status & (~u32[0x2])
			cpu.ll_bit = false

	func exec_cop1 [ op: u32, cur: u32 ]
		rs : i32 [ i32[ (op >> 21) & 31 ] ]
		rt : i32 [ i32[ (op >> 16) & 31 ] ]
		fs : i32 [ i32[ (op >> 11) & 31 ] ]
		fd : i32 [ i32[ (op >> 6) & 31 ] ]
		fn : u32 [ op & 0x3F ]
		if [ rs == 0 ]
			cpu.r[ rt ] = sx32[ fget32[ fs ] ]
			return
		if [ rs == 1 ]
			cpu.r[ rt ] = i64[ fget64[ fs ] ]
			return
		if [ rs == 2 ]
			cpu.r[ rt ] = sx32[ (fs == 31) ? cpu.fcr31 : 0xA00 ]
			return
		if [ rs == 4 ]
			fset32[ fs, u32[ cpu.r[ rt ] ] ]
			return
		if [ rs == 5 ]
			fset64[ fs, u64[ cpu.r[ rt ] ] ]
			return
		if [ rs == 6 ]
			if [ fs == 31 ] cpu.fcr31 = u32[ cpu.r[ rt ] ]
			return
		if [ rs == 8 ]                                         # BC1
			cnd : bool [ (cpu.fcr31 & 0x800000) != 0 ]
			tf  : bool [ (rt & 1) != 0 ]
			branch[ cnd == tf, cur, op, (rt & 2) != 0 ]
			return
		if [ rs == 16 ]                                        # fmt S
			v1 : f32 [ fgs[ fs ] ]
			v2 : f32 [ fgs[ i32[ (op >> 16) & 31 ] ] ]
			ab_a : u32 [ fget32[ fs ] ]
			ab_b : u32 [ fget32[ i32[ (op >> 16) & 31 ] ] ]
			fpe : bool [ fn <= 4 ]
			if [ fn >= 8 && fn <= 37 ] fpe = true
			if [ fpe ] feclearexcept[ 0x3D ]
			if [ fn == 0 ] fss[ fd, v1 + v2 ]
			el [ fn == 1 ] fss[ fd, v1 - v2 ]
			el [ fn == 2 ] fss[ fd, v1 * v2 ]
			el [ fn == 3 ] fss[ fd, v1 / v2 ]
			el [ fn == 4 ] fss[ fd, sqrt[ v1 ] ]
			el [ fn == 5 ] fss[ fd, (v1 < 0.0) ? (0.0 - v1) : v1 ]
			el [ fn == 6 ] fss[ fd, v1 ]
			el [ fn == 7 ] fss[ fd, 0.0 - v1 ]
			el [ fn == 13 ] fset32[ fd, u32[ i32[ v1 ] ] ]                        # trunc.w.s
			el [ fn == 12 ] fset32[ fd, u32[ i32[ rne[ f64[ v1 ] ] ] ] ]          # round.w.s (ties even)
			el [ fn == 14 ] fset32[ fd, u32[ i32[ ceil[ v1 ] ] ] ]                # ceil.w.s
			el [ fn == 15 ] fset32[ fd, u32[ i32[ floor[ v1 ] ] ] ]               # floor.w.s
			el [ fn == 9 ]  fset64[ fd, u64[ i64[ v1 ] ] ]                        # trunc.l.s
			el [ fn == 8 ]  fset64[ fd, u64[ i64[ rne[ f64[ v1 ] ] ] ] ]          # round.l.s
			el [ fn == 10 ] fset64[ fd, u64[ i64[ ceil[ v1 ] ] ] ]                # ceil.l.s
			el [ fn == 11 ] fset64[ fd, u64[ i64[ floor[ v1 ] ] ] ]               # floor.l.s
			el [ fn == 33 ] fsd[ fd, f64[ v1 ] ]                                   # cvt.d.s
			el [ fn == 36 ] fset32[ fd, u32[ i32[ fcvt_rm[ f64[ v1 ] ] ] ] ]       # cvt.w.s: honor FCR31 RM
			el [ fn == 37 ] fset64[ fd, u64[ i64[ fcvt_rm[ f64[ v1 ] ] ] ] ]       # cvt.l.s: honor FCR31 RM
			el [ fn >= 48 ] fcmp[ f64[ v1 ], f64[ v2 ], fn ]
			if [ fn >= 8 && fn <= 37 ]                        # sw float->int conv: inexact if non-integer
				if [ fn != 33 ]
					dv9 : f64 [ f64[ v1 ] ]
					if [ floor[ dv9 ] != dv9 ] feraiseexcept[ 0x20 ]
			if [ fpe ] fpu_flags[]
			# COP1 fmt.S (rs=16) VR4300 cycle cost. base +1 charged in step[]; extra = latency-1.
			# ref: ares interpreter-fpu.cpp step((lat-1)*2), Count = clocks>>1 (cpu.cpp:144)
			#   fn0  add.s    lat3  +2   | fn8  round.l.s lat5 +4 | fn12 round.w.s lat5 +4
			#   fn1  sub.s    lat3  +2   | fn9  trunc.l.s lat5 +4 | fn13 trunc.w.s lat5 +4
			#   fn2  mul.s    lat5  +4   | fn10 ceil.l.s  lat5 +4 | fn14 ceil.w.s  lat5 +4
			#   fn3  div.s    lat29 +28  | fn11 floor.l.s lat5 +4 | fn15 floor.w.s lat5 +4
			#   fn4  sqrt.s   lat29 +28  | fn36 cvt.w.s   lat5 +4 | fn37 cvt.l.s   lat5 +4
			#   fn5 abs.s / fn6 mov.s / fn7 neg.s / fn33 cvt.d.s / fn48-63 c.cond.s : lat1 +0
			if [ fn == 3 || fn == 4 ] cpu.c_count += 28
			el [ fn == 2 ] cpu.c_count += 4
			el [ fn == 0 || fn == 1 ] cpu.c_count += 2
			el [ fn >= 8 && fn <= 15 ] cpu.c_count += 4
			el [ fn == 36 || fn == 37 ] cpu.c_count += 4
			if [ dbg_on && fparm && fn <= 37 && ((cur >= 0x80170000 && cur < 0x801A0000) || (cur >= 0x80320000 && cur < 0x80330000)) ]
				if [ fp_seq == 0 ] fp_hash = 0xcbf29ce484222325
				fp_hash = fnv_u64[ fp_hash, u64[ fn ] ]
				fp_hash = fnv_u64[ fp_hash, u64[ ab_a ] ]
				fp_hash = fnv_u64[ fp_hash, u64[ ab_b ] ]
				printf[ "OFPH %d %016llx pc=%08X fn=%u a=%08X b=%08X d=%08X\n", fp_seq, fp_hash, cur, fn, ab_a, ab_b, fget32[ fd ] ]
				fp_seq = fp_seq + 1
			if [ dbg_on && fparm && fn <= 4 && cur >= 0x80170000 && cur < 0x801A0000 && dn_seq < 40 ]
				ua : u32 [ fget32[ fs ] & 0x7FFFFFFF ]
				ub : u32 [ fget32[ i32[ (op >> 16) & 31 ] ] & 0x7FFFFFFF ]
				ud : u32 [ fget32[ fd ] & 0x7FFFFFFF ]
				sa : bool [ (ua != 0) && (ua < 0x00800000) ]
				sb : bool [ (ub != 0) && (ub < 0x00800000) ]
				sd : bool [ (ud != 0) && (ud < 0x00800000) ]
				if [ sa || sb || sd || (cpu.fcr31 & 3) != 0 ]
					printf[ "ODEN pc=%08X fn=%u fcr31=%08X a=%08X b=%08X d=%08X sub a%d b%d d%d\n", cur, fn, cpu.fcr31, fget32[ fs ], fget32[ i32[ (op >> 16) & 31 ] ], fget32[ fd ], i32[ sa ], i32[ sb ], i32[ sd ] ]
					dn_seq = dn_seq + 1
			if [ dbg_on && fparm && fn <= 3 && cur >= 0x80195000 && cur < 0x80198000 ]
				printf[ "OFP pc=%08X fn=%u a=%08X b=%08X\n", cur, fn, fget32[ fs ], fget32[ i32[ (op >> 16) & 31 ] ] ]
			if [ dbg_on && fparm && cur == 0x80196854 && dbg_seq < 5000 ]
				sp2 : u32 [ u32[ cpu.r[29] ] ]
				printf[ "OMB #%d sp=%08X srcA=%08X srcB=%08X t4=%08X t5=%08X f8=%08X f4=%08X acc1C=%08X\n", dbg_seq, sp2, dr_r32[ sp2 + 0x58 ], dr_r32[ sp2 + 0x5C ], u32[ cpu.r[12] ], u32[ cpu.r[13] ], fget32[ 8 ], fget32[ 4 ], dr_r32[ sp2 + 0x1C ] ]
				dbg_seq = dbg_seq + 1
			return
		if [ rs == 17 ]                                        # fmt D
			ad : f64 [ fgd[ fs ] ]
			bd : f64 [ fgd[ i32[ (op >> 16) & 31 ] ] ]
			dd_a : u64 [ fget64[ fs ] ]
			dd_b : u64 [ fget64[ i32[ (op >> 16) & 31 ] ] ]
			fpe : bool [ fn <= 4 ]
			if [ fn >= 8 && fn <= 37 ] fpe = true
			if [ fpe ] feclearexcept[ 0x3D ]
			if [ fn == 0 ] fsd[ fd, ad + bd ]
			el [ fn == 1 ] fsd[ fd, ad - bd ]
			el [ fn == 2 ] fsd[ fd, ad * bd ]
			el [ fn == 3 ] fsd[ fd, ad / bd ]
			el [ fn == 4 ] fsd[ fd, sqrt[ ad ] ]
			el [ fn == 5 ] fsd[ fd, (ad < 0.0) ? (0.0 - ad) : ad ]
			el [ fn == 6 ] fsd[ fd, ad ]
			el [ fn == 7 ] fsd[ fd, 0.0 - ad ]
			el [ fn == 13 ] fset32[ fd, u32[ i32[ ad ] ] ]                        # trunc.w.d
			el [ fn == 12 ] fset32[ fd, u32[ i32[ rne[ ad ] ] ] ]                 # round.w.d
			el [ fn == 14 ] fset32[ fd, u32[ i32[ ceil[ ad ] ] ] ]                # ceil.w.d
			el [ fn == 15 ] fset32[ fd, u32[ i32[ floor[ ad ] ] ] ]               # floor.w.d
			el [ fn == 9 ]  fset64[ fd, u64[ i64[ ad ] ] ]                        # trunc.l.d
			el [ fn == 8 ]  fset64[ fd, u64[ i64[ rne[ ad ] ] ] ]                 # round.l.d
			el [ fn == 10 ] fset64[ fd, u64[ i64[ ceil[ ad ] ] ] ]                # ceil.l.d
			el [ fn == 11 ] fset64[ fd, u64[ i64[ floor[ ad ] ] ] ]               # floor.l.d
			el [ fn == 32 ] fss[ fd, f32[ ad ] ]                                  # cvt.s.d
			el [ fn == 36 ] fset32[ fd, u32[ i32[ fcvt_rm[ ad ] ] ] ]             # cvt.w.d: honor FCR31 RM
			el [ fn == 37 ] fset64[ fd, u64[ i64[ fcvt_rm[ ad ] ] ] ]             # cvt.l.d: honor FCR31 RM
			el [ fn >= 48 ] fcmp[ ad, bd, fn ]
			if [ fn >= 8 && fn <= 37 ]                        # sw float->int conv: inexact if non-integer
				if [ fn != 32 ]
					if [ floor[ ad ] != ad ] feraiseexcept[ 0x20 ]
			if [ fpe ] fpu_flags[]
			# COP1 fmt.D (rs=17) VR4300 cycle cost. base +1 in step[]; extra = latency-1.
			# ref: ares interpreter-fpu.cpp
			#   fn0  add.d  lat3  +2  | fn2  mul.d   lat8  +7  | fn3  div.d  lat58 +57
			#   fn1  sub.d  lat3  +2  | fn32 cvt.s.d lat2  +1  | fn4  sqrt.d lat58 +57
			#   fn8-15 round/trunc/ceil/floor .l/.w lat5 +4    | fn36 cvt.w.d lat5 +4 | fn37 cvt.l.d lat5 +4
			#   fn5 abs.d / fn6 mov.d / fn7 neg.d / fn48-63 c.cond.d : lat1 +0
			if [ fn == 3 || fn == 4 ] cpu.c_count += 57
			el [ fn == 2 ] cpu.c_count += 7
			el [ fn == 0 || fn == 1 ] cpu.c_count += 2
			el [ fn >= 8 && fn <= 15 ] cpu.c_count += 4
			el [ fn == 32 ] cpu.c_count += 1
			el [ fn == 36 || fn == 37 ] cpu.c_count += 4
			if [ dbg_on && fparm && fn <= 7 && ((cur >= 0x80170000 && cur < 0x801A0000) || (cur >= 0x80320000 && cur < 0x80330000)) ]
				printf[ "DFPH pc=%08X fn=%u a=%016llx b=%016llx d=%016llx\n", cur, fn, dd_a, dd_b, fget64[ fd ] ]
			return
		if [ rs == 20 ]                                        # fmt W
			iw : i32 [ i32[ fget32[ fs ] ] ]
			feclearexcept[ 0x3D ]
			if [ fn == 32 ] fss[ fd, f32[ iw ] ]                                  # cvt.s.w
			el [ fn == 33 ] fsd[ fd, f64[ iw ] ]                                  # cvt.d.w
			fpu_flags[]
			cpu.c_count += 4                                   # cvt.s.w/cvt.d.w lat5 (ref: ares FCVT_S_W/FCVT_D_W)
			return
		if [ rs == 21 ]                                        # fmt L
			il : i64 [ i64[ fget64[ fs ] ] ]
			feclearexcept[ 0x3D ]
			if [ fn == 32 ] fss[ fd, f32[ il ] ]                                  # cvt.s.l
			el [ fn == 33 ] fsd[ fd, f64[ il ] ]                                  # cvt.d.l
			fpu_flags[]
			cpu.c_count += 4                                   # cvt.s.l/cvt.d.l lat5 (ref: ares FCVT_S_L/FCVT_D_L)

	func fcmp [ fa: f64, fb: f64, fn: u32 ]
		lt : bool [ fa < fb ]
		eq : bool [ fa == fb ]
		c : bool [ false ]
		if [ fn & 2 ] c = c || eq
		if [ fn & 4 ] c = c || lt
		if [ c ] cpu.fcr31 = cpu.fcr31 | 0x800000
		el cpu.fcr31 = cpu.fcr31 & (~u32[0x800000])

	# ---------------- frame loop ----------------
	func run_frame []
		# 93.75MHz / 60 / 2 PClocks-per-instruction ≈ 781250 steps; Count
		# increments 1 per step, matching the hardware Count rate exactly
		# run one VI field: step until the cycle-accurate VI signals refresh (ares
		# frames on vcounter==vstart>>1). Guard caps a pathological frame.
		vi_refreshed = false
		fstep : i32 [ 0 ]
		while [ !vi_refreshed && fstep < 4000000 ]
			step[]
			fstep += 1
		if [ dbg_on && getenv[ 'N64_AUTO' ] ]
			if [ frames == 400 ] pad_st = pad_st | 0x1000
			if [ frames == 410 ] pad_st = pad_st & (~u32[0x1000])
			if [ frames == 470 && getenv[ 'N64_AUTO2' ] ] pad_st = pad_st | 0x8000
			if [ frames == 480 ] pad_st = pad_st & (~u32[0x8000])
		if [ !getenv[ 'N64_NO_AIDRAIN' ] ] ai_drain[]
		if [ dbg_on && frames == 600 ]
			printf[ "n64 f600 pc=%08X ra=%08X sp=%08X a0=%08X op=%08X\n", cpu.pc, u32[ cpu.r[31] ], u32[ cpu.r[29] ], u32[ cpu.r[4] ], rd32v[ cpu.pc ] ]
			printf[ "n64 regs a1=%08X a2=%08X a3=%08X v0=%08X v1=%08X s0=%08X s1=%08X s2=%08X s3=%08X t0=%08X\n", u32[ cpu.r[5] ], u32[ cpu.r[6] ], u32[ cpu.r[7] ], u32[ cpu.r[2] ], u32[ cpu.r[3] ], u32[ cpu.r[16] ], u32[ cpu.r[17] ], u32[ cpu.r[18] ], u32[ cpu.r[19] ], u32[ cpu.r[8] ] ]
			a0p : u32 [ u32[ cpu.r[4] ] & 0x7FFFFF ]
			sb : local u8 [ 100 ]
			for [ k: i32 0, k < 96, k += 1 ]
				ch : u32 [ u32[ rdram[ a0p + u32[k] ] ] ]
				if [ ch >= 32 && ch < 127 ] sb[ k ] = u8[ ch ]
				el sb[ k ] = 46
			sb[ 96 ] = 0
			printf[ "n64 a0 str: %s\n", sb ]
			gdf : ref FILE [ fopen[ '/tmp/n64_gd.bin', 'wb' ] ]
			if [ gdf ]
				fwrite[ rdram, 1, 0x800000, gdf ]
				fclose[ gdf ]
				puts 'n64 dumped rdram to /tmp/n64_gd.bin'
			# stack back-scan: plausible return addresses on thread5's stack
			spb : u32 [ u32[ cpu.r[29] ] & 0x7FFFFF ]
			for [ k: i32 0, k < 64, k += 1 ]
				sv : u32 [ dr_r32[ spb + u32[ k * 4 ] ] ]
				if [ sv >= 0x80100000 && sv < 0x80400000 ] printf[ "n64 stackra +%d = %08X\n", k * 4, sv ]
		if [ dbg_on ]
			agt : u32 [ dr_r32[ 0x32D5D4 ] ]
			fparm = (agt >= 95) && (agt <= 97)
		frames += 1
		if [ trace && (frames % 60) == 0 ]
			printf[ "n64 f%u pc=%08X sp_stat=%X mi=%X/%X vi_org=%06X\n", frames, cpu.pc, sp_status, mi_intr, mi_mask, vi_origin ]

	# publish the VI framebuffer (16bpp 5551 or 32bpp) for the render thread
	func publish []
		pub_lock.lock[]
		if [ ss_used ]
			wss : i32 [ 320 * gx_ss ]
			hss : i32 [ 240 * gx_ss ]
			pub_w = wss
			pub_h = hss
			for [ y9: i32 0, y9 < hss, y9 += 1 ]
				sb9 : i32 [ y9 * 1280 ]
				db9 : i32 [ y9 * wss ]
				for [ x9: i32 0, x9 < wss, x9 += 1 ]
					pub_framebuf[ db9 + x9 ] = ss_buf[ sb9 + x9 ]
			pub_valid = true
			pub_lock.unlock[]
			return
		w2 : i32 [ (vi_width > 0 && vi_width <= 640) ? i32[ vi_width ] : 320 ]
		h2 : i32 [ (w2 > 400) ? 480 : 240 ]
		pub_w = w2
		pub_h = h2
		fmt : u32 [ vi_ctrl & 3 ]
		org : u32 [ vi_origin & 0x7FFFFF ]
		if [ fmt == 3 ]
			for [ i: i32 0, i < w2 * h2, i += 1 ]
				p : u32 [ (u32[rdram[org + u32[i*4]]] << 24) | (u32[rdram[org + u32[i*4] + 1]] << 16) | (u32[rdram[org + u32[i*4] + 2]] << 8) | u32[rdram[org + u32[i*4] + 3]] ]
				pub_framebuf[ i ] = 0xFF000000 | ((p >> 8) & 0xFF0000) | ((p >> 8) & 0xFF00) | ((p >> 8) & 0xFF) | 0
				pub_framebuf[ i ] = 0xFF000000 | (((p >> 8) & 0xFF) << 16) | (((p >> 16) & 0xFF) << 8) | ((p >> 24) & 0xFF)
		el [ fmt == 2 ]
			for [ i: i32 0, i < w2 * h2, i += 1 ]
				px : u32 [ (u32[rdram[org + u32[i*2]]] << 8) | u32[rdram[org + u32[i*2] + 1]] ]
				r5 : u32 [ (px >> 11) & 31 ]
				g5 : u32 [ (px >> 6) & 31 ]
				b5 : u32 [ (px >> 1) & 31 ]
				pub_framebuf[ i ] = 0xFF000000 | ((b5 << 3 | b5 >> 2) << 16) | ((g5 << 3 | g5 >> 2) << 8) | (r5 << 3 | r5 >> 2)
		pub_valid = true
		pub_lock.unlock[]

	func emu_tick []
		run_frame[]
		if [ !getenv[ 'N64_NO_PUBLISH' ] ] publish[]
		if [ hold_f > 0 && frames >= hold_f ] paused = true

	func emu_entry [] -> none
		emu_running = true
		if [ !booted ]
			if [ !load_rom[] ]
				emu_running = false
				return
			boot[]
		if [ getenv[ 'N64_RUNFRAME_TEST' ] ]
			for [ k8: i32 0, k8 < 8, k8 += 1 ]
				emu_tick[]
			hh8 : u64 [ 0xcbf29ce484222325 ]
			hh8 = fnv_u64[ hh8, u64[ cpu.pc ] ]
			for [ r8: i32 0, r8 < 32, r8 += 1 ]
				hh8 = fnv_u64[ hh8, u64[ cpu.r[ r8 ] ] ]
			printf[ "n64 RUNFRAME TEST pc=%08X cnt=%u sys_clk=%lld frames=%u h=%016llx\n", cpu.pc, cpu.c_count, sys_clk, frames, hh8 ]
			fflush[ null ]
			exit[ 12 ]
		if [ getenv[ 'N64_OURS_SELFTEST' ] ]
			for [ k9: i32 0, k9 < 2500000, k9 += 1 ]
				step[]
			printf[ "n64 OURS SELFTEST cnt=%u sys_clk=%lld dch=%lld dcm=%lld icm=%lld ic=%d\n", cpu.c_count, sys_clk, dbg_dch, dbg_dcm, dbg_icm, dbg_ic ]
			fflush[ null ]
			exit[ 11 ]
		while [ !emu_stop ]
			if [ context_req ]
				context_req = false
				ctx : string context_text[]
				ctx.hold[]
				context_out = ctx
				context_seq += 1
			if [ paused ] usleep[ 15000 ]
			el
				emu_tick[]
				usleep[ 1000 ]
		emu_running = false

	func hx8 [ v: u32 ] -> string
		hx : string [ '0123456789ABCDEF' ]
		s : string [ '' ]
		for [ i: i32 7, i >= 0, i -= 1 ]
			s = s + hx.mid[ i32[ (v >> u32[ i * 4 ]) & 15 ], 1 ]
		return s

	func context_text [] -> string
		if [ !booted ] return 'n64 paused: not booted'
		s : string 'N64 emulator paused ({rom}) — machine context\n'
		s = s + 'frame {frames}\n'
		s = s + 'VR4300: PC=${hx8[ cpu.pc ]} COUNT=${hx8[ cpu.c_count ]} STATUS=${hx8[ cpu.c_status ]} CAUSE=${hx8[ cpu.c_cause ]}\n'
		s = s + 'MI intr=${hx8[ mi_intr ]} mask=${hx8[ mi_mask ]}  VI origin=${hx8[ vi_origin ]} ctrl=${hx8[ vi_ctrl ]}\n'
		return s

	# ---------------- input (mirrors the other emulators) ----------------
	public func on_key [ ev: Event ]
		code : i32  [ ev.key.unicode ]
		down : bool [ ev.key.state ]
		bit : i32 [ -1 ]
		if   [ code == 47 ]  bit = 15    # /  A
		el [ code == 46 ]  bit = 14    # .  B
		el [ code == 90 ]  bit = 13    # Z
		el [ code == 257 ] bit = 12    # Enter  Start
		el [ code == 265 ] bit = 11    # d-pad up
		el [ code == 264 ] bit = 10
		el [ code == 263 ] bit = 9
		el [ code == 262 ] bit = 8
		el [ code == 81 ]  bit = 5     # Q  L
		el [ code == 69 ]  bit = 4     # E  R
		el [ code == 73 ]  bit = 3     # IJKL = C buttons
		el [ code == 75 ]  bit = 2
		el [ code == 74 ]  bit = 1
		el [ code == 76 ]  bit = 0
		if [ bit >= 0 ]
			m : u32 [ u32[ 1 ] << bit ]
			if [ down ] pad_st = pad_st | m
			el pad_st = pad_st & (~m)
		# WASD = analog stick
		if [ code == 87 ] stick_y = (down) ? 80 : 0
		if [ code == 83 ] stick_y = (down) ? -80 : 0
		if [ code == 65 ] stick_x = (down) ? -80 : 0
		if [ code == 68 ] stick_x = (down) ? 80 : 0
		if [ down && code == 32 ] paused = !paused

	# ---------------- paint ----------------
	public func draw [ w: Window ]
		if [ w.draw_stage != CanvasType.screen ] return
		ux.will_animate = true
		paint[ w.screen, rect [ x: 0.0, y: 0.0, w: bounds.w, h: bounds.h ] ]

	# ---------------- GPU renderer: pipeline setup + per-frame draw ----------------
	func gxr_setup [ cv: Canvas ]
		if [ r_render ] return
		if [ bounds.w <= 0.0 || bounds.h <= 0.0 ] return
		r_shader = N64GX [ vk: cv.vk, name: 'n64gx' ]
		r_atlas = Texture [ vk: cv.vk, w: cv.w, width: 1024, height: 1024, linear: false ]
		r_state = Texture [ vk: cv.vk, w: cv.w, width: 2048, height: 3, linear: false, pixel_format: Pixel.rgbaf32 ]
		vm : new vertex_member_t [ 4 ]
		vm[0].src    = typeid[ vec3f ]
		vm[0].size   = 12
		vm[0].offset = 0
		vm[1].src    = typeid[ vec4f ]
		vm[1].size   = 16
		vm[1].offset = 12
		vm[2].src    = typeid[ vec2f ]
		vm[2].size   = 8
		vm[2].offset = 28
		vm[3].src    = typeid[ vec4f ]
		vm[3].size   = 16
		vm[3].offset = 36
		vsz : i32 [ 52 ]
		vct : i32 [ 131072 ]
		vmc : i32 [ 4 ]
		r_vbo = Gpu [ vk: cv.vk, name: 'n64v', members: vm, member_count: vmc, vertex_size: vsz, vertex_count: vct ]
		r_vbo.sync[ cv.w ]
		gw : i32 [ i32[ bounds.w ] * 4 ]
		gh : i32 [ i32[ bounds.h ] * 4 ]
		if [ gw > 4096 ] gw = 4096
		if [ gh > 4096 ] gh = 4096
		r_render = Render [ vk: cv.vk, w: cv.w, width: gw, height: gh, use_depth: true, reduce: true, clear_color: vec4f [ 0.0, 0.0, 0.0, 1.0 ] ]
		r_pipeline = Pipeline [ vk: cv.vk, w: cv.w, name: string 'n64gx', r: r_render, s: r_shader, vbo: r_vbo, samplers: map Au[string] [ 'atlas': r_atlas, 'state': r_state ], straight_alpha: true, cull_none: true ]
		r_model = Model [ vk: cv.vk, w: cv.w, s: r_shader, samplers: map Au[string] [ 'atlas': r_atlas, 'state': r_state ] ]
		r_model.pipelines = array Pipeline [ alloc: 1 ]
		r_model.pipelines.push[ r_pipeline ]
		r_model.r = r_render
		r_render.models = array Model [ r_model ]
		r_vbo.vertex_count = 0
		puts 'n64 gpu: render target {gw}x{gh} (4x reduce)'

	public func paint [ cv: Canvas, vp: rect ]
		bounds = vp
		if [ !emu_started ]
			emu_started = true
			trace = getenv[ 'N64_TRACE' ] != null
			pub_lock = mutex [ cond: false ]
			if [ cosim ]
				emu_entry[]                              # cosim: run inline, single-threaded (no render race)
			el
				tid : local u64 [ 1 ]
				pthread_create[ tid, null, ref emu_entry, a ]
		if [ gpu_on && pub_gxv_n > 0 ]
			gxr_setup[ cv ]
			if [ !r_render ] return
			pub_lock.lock[]
			if [ pub_at_dirty ]
				r_atlas.upload[ at_stage, 1024 * 1024 * 4 ]
				pub_at_dirty = false
			pub_st[ 2047 * 4 ] = f32[ pub_gxv_n ]     # total drawn vertices → shader draw-order normalizer (texel 2047,0)
			pub_st[ 2046 * 4 ] = f32[ pub_zsplit ]    # first z-enabled vertex index → z-disabled backdrop/overlay split (texel 2046,0)
			r_state.upload[ pub_st, 2048 * 3 * 16 ]
			vd9 : ref f32 [ r_vbo.vertex_data ]
			nf9 : i32 [ pub_gxv_n * 13 ]
			for [ i: i32 0, i < nf9, i += 1 ]
				vd9[ i ] = pub_gxv[ i ]
			vlim : i32 [ pub_gxv_n ]
			vpe : symbol [ getenv[ 'N64_VLIM' ] ]
			if [ vpe ]
				vp9 : i32 [ atoi[ vpe ] ]
				if [ vp9 > 0 && vp9 < 100 ] vlim = pub_gxv_n * vp9 / 100
			r_vbo.vertex_count = vlim
			pub_lock.unlock[]
			r_vbo.upload_verts[]
			r_render.update[]
			r_render.draw[]
			r_render.sync_fence[]
			rt9 : Texture [ (r_render.reduce && r_render.reduction) ? r_render.reduction : r_render.color ]
			cv.draw_image[ rt9, rect [ x: vp.x, y: vp.y, w: vp.w, h: vp.h ] ]
			return
		if [ !pub_valid ] return
		pub_lock.lock[]
		if [ !screen_tex || tex_w != pub_w ]
			screen_tex = Texture [ vk: cv.vk, w: cv.w, width: pub_w, height: pub_h, linear: true ]
			tex_w = pub_w
		screen_tex.upload[ pub_framebuf, pub_w * pub_h * 4 ]
		pub_lock.unlock[]
		cv.draw_image[ screen_tex, rect [ x: vp.x, y: vp.y, w: vp.w, h: vp.h ] ]

	# reload/exit teardown: stop the emulation thread DETERMINISTICALLY (before
	# the module's code unloads — dealloc order can't be relied on for threads).
	public func on_unload []
		if [ emu_started ]
			emu_stop = true
			while [ emu_running ]
				usleep[ 2000 ]
		if [ audio ]
			audio.close[]

	func dealloc []
		if [ emu_started ]
			emu_stop = true
			while [ emu_running ]
				usleep[ 2000 ]
		if [ audio ]
			audio.close[]
