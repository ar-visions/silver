import textmate
import <stdio.h>

app textmate-test
    func init []
        p : path [ '/src/vscode-textmate/benchmark/c.tmLanguage.json' ]
        g : TmGrammar [ p.load[ typeid[TmGrammar], null ] ]
        if [ !g ]
            printf[ "failed to load grammar\n" ]
            return
        printf[ "loaded: %s\n", g.name ]
        printf[ "scopeName: %s\n", g.scopeName ]
        if [ g.patterns ]
            printf[ "top-level patterns: %d\n", g.patterns.count ]
        el
            printf[ "top-level patterns: null\n" ]
        if [ g.repository ]
            printf[ "repository entries: %d\n", g.repository.count ]
        el
            printf[ "repository entries: null\n" ]

        t : TmTokenizer [ grammar: g ]
        lines : array string []
        lines.push[ '#include <stdio.h>' ]
        lines.push[ '' ]
        lines.push[ 'int add(int a, int b) {{' ]
        lines.push[ '    return a + b;' ]
        lines.push[ '}}' ]
        lines.push[ '' ]
        lines.push[ '/* block comment */' ]
        lines.push[ 'float x = 3.14f; // inline comment' ]

        state : TmState [ null ]
        for [ li: i32 0, li < lines.count, li += 1 ]
            line   : string [ lines[li] ]
            result : TmLineResult [ t.tokenize_line[ line, state ] ]
            state  = result.state
            printf[ "line %d: %s\n", li, line ]
            toks : array TmToken [ result.tokens ]
            for [ ti: i32 0, ti < toks.count, ti += 1 ]
                tok  : TmToken [ toks[ti] ]
                text : string [ line.mid[ tok.start, tok.end - tok.start ] ]
                printf[ "  [%d-%d] '%s'\n", tok.start, tok.end, text ]
                for [ si: i32 0, si < tok.scopes.count, si += 1 ]
                    printf[ "    %s\n", tok.scopes[si] ]
