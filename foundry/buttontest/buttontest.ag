import vec
import img
import trinity
import <stdio.h>

element buttontest : trinity
    intern clicks     : i32    0
    public width      : i32    [ 480 ]
    public height     : i32    [ 320 ]
    public background : string [ 'Background' ]
    public title      : string [ 'buttontest' ]

    public func on_click [ ev: Event ]
        e : (ev.target to element)
        if [ !e ] return
        if [ e.id == 'hello' ]
            clicks += 1
            puts 'button clicked! count={clicks}'
        ev.stop_propagation[]

    public func render [] -> Elements
        return Elements [
            "hello": Button [ label: 'click me' ]
        ]
