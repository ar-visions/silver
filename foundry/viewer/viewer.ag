import vec
import img
import gltf
import trinity
import <stdio.h>
import <stdlib.h>
import <math.h>

# basic glTF model viewer: `viewer --model path/to/model.gltf`
# drag orbits the camera, wheel zooms, R resets the view.

ModelViewProject ViewerLit
    attrib color : LayoutBinding [ type:typeid[ Surface ], id:Surface.color, count:1, format: typeid[ rgba8 ] ]

    attrib a_pos     : VertexInput    [ type:typeid[ vec3f ] ]
    attrib a_normal  : VertexInput    [ type:typeid[ vec3f ] ]
    attrib a_uv      : VertexInput    [ type:typeid[ vec2f ] ]

    attrib v_normal  : VertexOutput   [ type:typeid[ vec3f ] ]
    attrib v_uv      : VertexOutput   [ type:typeid[ vec2f ] ]
    attrib fragColor : FragmentOutput [ type:typeid[ vec4f ] ]

    func init [ ]
        model = mat4f.identity[]
        view  = mat4f.identity[]
        proj  = mat4f.identity[]

    func vertex [] -> GLSL none {
        v_normal    = mat3(ubo.model) * a_normal;
        v_uv        = a_uv;
        gl_Position = ubo.proj * ubo.view * ubo.model * vec4(a_pos, 1.0);
    }

    # two directional lights + ambient over the material color — enough to read
    # form on any model without needing a full PBR/environment setup
    func fragment [] -> GLSL none {
        vec4  c  = texture(color, v_uv);
        vec3  n  = normalize(v_normal);
        float l  = max(dot(n, normalize(vec3( 0.35, 0.75,  0.55))), 0.0) * 0.75
                 + max(dot(n, normalize(vec3(-0.50, 0.20, -0.60))), 0.0) * 0.25 + 0.22;
        fragColor = vec4(c.rgb * l, c.a);
    }

element ModelView
    # required at construction — the caller must provide it (null is a valid
    # explicit provision; the draw guard then reports the missing file)
    expect  model_path : path
    mutable vshader    : HumanPBR
    mutable vmodel     : Model
    mutable vrender    : Render
    mutable yaw        : f32
    mutable pitch      : f32 [ 0.05 ]
    mutable dist       : f32 [ 3.5 ]
    mutable look_x     : f32
    mutable look_y     : f32 [ 1.0 ]
    mutable look_z     : f32
    mutable dragging   : bool
    mutable lastx      : f32
    mutable lasty      : f32
    mutable frame_n    : i32

    func init []
        animated  = true
        focusable = true

    public func on_press [ ev: Event ]
        dragging = true
        lastx = ev.mouse.pos.x
        lasty = ev.mouse.pos.y
        set_capture[]

    public func on_release [ ev: Event ]
        dragging = false
        release_capture[]

    public func on_move [ ev: Event ]
        if [ !dragging ] return
        dx : f32 [ ev.mouse.pos.x - lastx ]
        dy : f32 [ ev.mouse.pos.y - lasty ]
        lastx = ev.mouse.pos.x
        lasty = ev.mouse.pos.y
        if [ ev.key.shift ]
            # shift-drag PANS: translate the look target along the camera's
            # right and screen-up axes, scaled so the content tracks the cursor
            sc : f32 [ dist * 0.0016 ]
            syw : f32 [ sin[ yaw ] ]
            cyw : f32 [ cos[ yaw ] ]
            spt : f32 [ sin[ pitch ] ]
            cpt : f32 [ cos[ pitch ] ]
            look_x += (cyw * dx + syw * spt * dy) * sc
            look_y += cpt * dy * sc
            look_z += ((0.0 - syw) * dx + cyw * spt * dy) * sc
        el
            yaw   += dx * 0.01
            pitch += dy * 0.01
            if [ pitch >  1.5 ] pitch =  1.5
            if [ pitch < -1.5 ] pitch = -1.5

    public func on_wheel [ ev: Event ]
        dist *= 1.0 - f32[ ev.mouse.wheel_delta.y ] * 0.1
        if [ dist < 0.2 ]  dist = 0.2
        if [ dist > 50.0 ] dist = 50.0

    public func on_key [ ev: Event ]
        if [ !ev.key.state ] return
        if [ ev.key.unicode == 82 ]        # R: reset view
            yaw   = 0.0
            pitch = 0.05

    public func draw [ w: Window ]
        if [ w.draw_stage != CanvasType.screen ] return
        ux.will_animate = true
        if [ bounds.w <= 0.0 || bounds.h <= 0.0 ] return
        cv : Canvas [ w.screen ]
        if [ !vrender ]
            expect model_path && model_path.exists[], 'model does not exist: {model_path}'
            vshader   = HumanPBR [ vk: cv.vk, name: 'humanpbr' ]
            vmodel    = Model [ vk: cv.vk, w: w, s: vshader ]
            # buffer uris in the .gltf are relative to the model's own directory
            GltfBuffer.set_base[ model_path.parent_dir[] ]
            # member sets outside init do NOT retain: without the hold the
            # loaded model drops before Render init and Model.finish silently
            # falls back to the default quad
            gm : GltfModel [ model_path.load[ typeid[ GltfModel ], null ] ]
            gm.hold[]
            vmodel.id = gm
            # auto-frame: union of POSITION bounds in WORLD space — each mesh
            # node's composed scene-graph transform applied to its box corners
            # (the axis-fix/scale live in parent chains; accessor-space bounds
            # framed her feet)
            gm.compute_worlds[]
            mnx : f32 [  1e9 ]
            mny : f32 [  1e9 ]
            mnz : f32 [  1e9 ]
            mxx : f32 [ -1e9 ]
            mxy : f32 [ -1e9 ]
            mxz : f32 [ -1e9 ]
            for [ nd: Node ] in gm.nodes
                if [ !nd.AF_query_name[ 'mesh' ] ] continue
                me : gm.meshes[ nd.mesh ]
                if [ !me ] continue
                wmat : mat4f [ nd.world ]
                for [ pr: Primitive ] in me.primitives
                    for [ av: ref i64, an: string ] in pr.attributes
                        if [ an == 'POSITION' ]
                            ac : gm.accessors[ av[0] ]
                            for [ cn: i32 0, cn < 8, cn += 1 ]
                                cxv : f32 [ ((cn & 1) != 0) ? ac.max.x : ac.min.x ]
                                cyv : f32 [ ((cn & 2) != 0) ? ac.max.y : ac.min.y ]
                                czv : f32 [ ((cn & 4) != 0) ? ac.max.z : ac.min.z ]
                                # column-major transform, scalar math (a C
                                # vec4f-by-value return crosses the aether/clang
                                # struct-return ABI wrong — see mul_v4 note)
                                wcx : f32 [ wmat.m[0] * cxv + wmat.m[4] * cyv + wmat.m[8]  * czv + wmat.m[12] ]
                                wcy : f32 [ wmat.m[1] * cxv + wmat.m[5] * cyv + wmat.m[9]  * czv + wmat.m[13] ]
                                wcz : f32 [ wmat.m[2] * cxv + wmat.m[6] * cyv + wmat.m[10] * czv + wmat.m[14] ]
                                if [ wcx < mnx ] mnx = wcx
                                if [ wcy < mny ] mny = wcy
                                if [ wcz < mnz ] mnz = wcz
                                if [ wcx > mxx ] mxx = wcx
                                if [ wcy > mxy ] mxy = wcy
                                if [ wcz > mxz ] mxz = wcz
            if [ mxx > mnx ]
                sx : f32 [ mxx - mnx ]
                sy : f32 [ mxy - mny ]
                sz : f32 [ mxz - mnz ]
                r  : f32 [ sx ]
                if [ sy > r ] r = sy
                if [ sz > r ] r = sz
                look_x = (mnx + mxx) * 0.5
                look_y = (mny + mxy) * 0.5
                look_z = (mnz + mxz) * 0.5
                dist   = r * 2.8
                if [ dist < 0.2 ] dist = 0.2
                puts 'viewer: model bounds {sx}x{sy}x{sz} center=({look_x},{look_y},{look_z}) -> dist={dist}'
            # per-map UV sets from the first material (texCoord indices — the
            # athlete uses color:0 mr:1 normal:2; single-UV models read 0,0,0)
            if [ gm.materials && gm.materials.count > 0 ]
                mt : gm.materials[ 0 ]
                uvm : vec4f [ 0.0, 0.0, 0.0, 0.0 ]
                pm2 : mt.pbrMetallicRoughness
                if [ pm2 ]
                    if [ pm2.baseColorTexture ]         uvm.x = f32[ pm2.baseColorTexture.texCoord ]
                    if [ pm2.metallicRoughnessTexture ] uvm.y = f32[ pm2.metallicRoughnessTexture.texCoord ]
                if [ mt.normalTexture ] uvm.z = f32[ mt.normalTexture.texCoord ]
                vshader.uv_map = uvm
            vrender   = Render [ vk: cv.vk, w: w, wscale: 1.0, use_depth: true, clear_color: vec4f [ 0.10, 0.12, 0.18, 1.0 ], models: array Model [ vmodel ] ]
            puts 'viewer: bounds={bounds.w}x{bounds.h} window={w.width}x{w.height} scale={w.scale}'
        # orbit camera: spherical eye around the look point (matches the Avatar
        # camera conventions — up is -Y, fov is horizontal)
        tgt : vec3f [ look_x, look_y, look_z ]
        eye : vec3f [
            tgt.x + dist * cos[ pitch ] * sin[ yaw ],
            tgt.y + dist * sin[ pitch ],
            tgt.z + dist * cos[ pitch ] * cos[ yaw ] ]
        up  : vec3f [ 0.0f, -1.0f, 0.0f ]
        asp : f32 [ bounds.w / bounds.h ]
        fy  : f32 [ 2.0f * atan[ tan[ radians[ 40.0f ] * 0.5f ] / asp ] ]
        vshader.model = mat4f.identity[]
        vshader.view  = mat4f.look_at[ eye, tgt, up ]
        vshader.proj  = mat4f.perspective[ fy, asp, 0.05f, 200.0f ]
        vshader.eye   = vec4f [ eye.x, eye.y, eye.z, 1.0 ]
        vshader.time  = w.time
        vrender.update[]
        vrender.draw[]
        vrender.flush_submit[]
        vrender.sync_fence[]
        # VIEWER_DUMP=1: write the render target to /tmp/viewer_target.png once
        # (~frame 60) — discriminates render corruption from present corruption
        frame_n += 1
        if [ frame_n == 60 && getenv[ 'VIEWER_DUMP' ] ]
            tex : Texture vrender.color
            dsz : i32 [ tex.width * tex.height * 4 ]
            db : Buffer [ vk: tex.vk, size: dsz,
                u_dst: true, m_host_visible: true, m_host_coherent: true ]
            db.transfer[ tex ]
            dshot : Image [ width: tex.width, height: tex.height, format: Pixel.rgba8 ]
            memcpy[ dshot.vdata[], db.mmap[], dsz ]
            db.unmap[]
            dshot.png[ path '/tmp/viewer_target.png' ]
            puts 'viewer: dumped {tex.width}x{tex.height} target'
        cv.draw_image[ vrender.color, rect [ x: 0.0, y: 0.0, w: bounds.w, h: bounds.h ] ]

element viewer : trinity
    public model      : path
    public width      : i32    [ 1280 ]
    public height     : i32    [ 960 ]
    public title      : string [ 'viewer' ]
    # solid-color background: the swapchain blit presents the LAST render's
    # color — the background chain's r_view (targeting the screen canvas) is
    # that render, so an app without one has nothing to present
    public background : string [ 'Background' ]

    public func render [] -> Elements
        e : Elements [ ]
        e['view'] = ModelView [ model_path: model ]
        return e
