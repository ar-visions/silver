
export 0.8.8

import <stdio.h>
import <string.h>
import <math.h>
import ai
import random


alias astrings: array string

app ai-test
    func init [] 
        rng_seed 42
        puts 'ai-test: dual-input average color predictor'
        puts 'network: two conv branches -> concatenate -> pool -> dense(64) -> dense(1)'

        # --- input tensors for each layer position ---
        t_inA:    tensor [tensor_shape: 32x32x1]
        t_inB:    tensor [tensor_shape: 32x32x1]
        t_convA:  tensor [tensor_shape: 32x32x1]
        t_convB:  tensor [tensor_shape: 32x32x1]
        t_cat:    tensor [tensor_shape: 32x32x8]
        t_pool:   tensor [tensor_shape: 32x32x8]
        t_flat:   tensor [tensor_shape: 16x16x8]
        t_dense1: tensor [tensor_shape: 1x2048]
        t_dense2: tensor [tensor_shape: 1x64]
        t_out:    tensor [tensor_shape: 1x1]

        # --- weight and bias tensors ---
        w_convA:  tensor [tensor_shape: 36x1,     initializer: glorot_uniform]
        b_convA:  tensor [tensor_shape: 4x1,      initializer: zeros]
        w_convB:  tensor [tensor_shape: 36x1,     initializer: glorot_uniform]
        b_convB:  tensor [tensor_shape: 4x1,      initializer: zeros]
        w_dense1: tensor [tensor_shape: 2048x64,  initializer: glorot_uniform]
        b_dense1: tensor [tensor_shape: 1x64,     initializer: zeros]
        w_dense2: tensor [tensor_shape: 64x1,     initializer: glorot_uniform]
        b_dense2: tensor [tensor_shape: 1x1,      initializer: zeros]

        # --- construct ops ---
        op_inA:  input_op [input: t_inA,    name: 'inputA', lr_scale: 1.0f]
        op_inB:  input_op [input: t_inB,    name: 'inputB', lr_scale: 1.0f]

        op_cA:   conv     [input: t_convA,  name: 'convA',
                           padding: Padding.same, kernel_size: 3x3, stride_shape: 1x1,
                           out_channels: 4, activation: Activation.relu,
                           weights: w_convA, bias: b_convA, lr_scale: 1.0f]

        op_cB:   conv     [input: t_convB,  name: 'convB',
                           padding: Padding.same, kernel_size: 3x3, stride_shape: 1x1,
                           out_channels: 4, activation: Activation.relu,
                           weights: w_convB, bias: b_convB, lr_scale: 1.0f]

        op_cat:  concatenate [input: t_cat, name: 'concat', axis: 2, lr_scale: 1.0f]

        op_p:    pool     [input: t_pool,   name: 'pool',
                           pool_size: 2x2, pool_type: Pooling.max,
                           stride_shape: 2x2, lr_scale: 1.0f]
        op_f:    flatten  [input: t_flat,   name: 'flatten', lr_scale: 1.0f]
        op_d1:   dense    [input: t_dense1, name: 'dense1',
                           units: 64, in_dim: 2048, out_dim: 64,
                           activation: Activation.relu,
                           weights: w_dense1, bias: b_dense1, lr_scale: 1.0f]
        op_d2:   dense    [input: t_dense2, name: 'dense2',
                           units: 1, in_dim: 64, out_dim: 1,
                           weights: w_dense2, bias: b_dense2, lr_scale: 1.0f]
        op_out:  output_op[input: t_out,    name: 'output', lr_scale: 1.0f]

        # --- wire upstream dependencies ---
        op_inA.inputs = astrings []
        op_inB.inputs = astrings []
        op_cA.inputs  = array string [ 'inputA' ]
        op_cB.inputs  = array string [ 'inputB' ]
        op_cat.inputs = array string [ 'convA', 'convB' ]
        op_p.inputs   = array string [ 'concat' ]
        op_f.inputs   = array string [ 'pool' ]
        op_d1.inputs  = array string [ 'flatten' ]
        op_d2.inputs  = array string [ 'dense1' ]
        op_out.inputs = array string [ 'dense2' ]

        # --- create keras model ---
        all_ops: array op [ op_inA, op_inB, op_cA, op_cB, op_cat, op_p, op_f, op_d1, op_d2, op_out ]

        model: keras [ident: 'ai-test', ops: all_ops]

        # --- generate training data ---
        # two random grayscale 32x32 images, label = average of both averages
        num_samples: i32 [20]
        samples: map tensor[tensor] []
        pixels:  i32 [1024]

        puts 'generating {num_samples} dual-input training samples...'
        for [ s: i32 0, s < num_samples, s += 1 ]
            imgA: tensor [tensor_shape: 32x32x1]
            imgB: tensor [tensor_shape: 32x32x1]
            avgA: f32 [0.0]
            avgB: f32 [0.0]
            for [ i: i32 0, i < pixels, i += 1 ]
                v: randf
                imgA.floats[i] = v
                avgA += v
            for [ i: i32 0, i < pixels, i += 1 ]
                v: randf
                imgB.floats[i] = v
                avgB += v
            avgA /= 1024.0
            avgB /= 1024.0
            target: tensor [tensor_shape: 1x1]
            target.floats[0] = (avgA + avgB) / 2.0

            # set inputB source for this sample
            op_inB.source = imgB

            samples[imgA] = target

        # --- train ---
        puts 'training...'
        model.train 100, samples, 0.001f, adam

        # --- quantize and eval ---
        model.quantize_model
        model.eval_q8 samples
        puts 'ai-test complete'
