import <time.h>
import <stdio.h>
import <stdlib.h>
import <math.h>
	-lm
import <alsa/asoundlib.h>
	-lasound

class spectra
    public size:        i32
    public sample_rate: i32
    public channels:    i32
    public device:      cstr
    public pcm:         ref snd_pcm_t
    public re:          ref f32
    public im:          ref f32
    public buf:         ref i16
    public bins:        ref f32

    func init [] 
        channels = 1
        re   = new f32 [ size ]
        im   = new f32 [ size ]
        buf  = new i16 [ size ]
        bins = new f32 [ size / 2 ]

    func open [] -> bool
        rc: snd_pcm_open [ ref pcm, device, SND_PCM_STREAM_CAPTURE, 0 ]
        if [ rc < 0 ]
            printf [ "cannot open: %s\n", snd_strerror [ rc ] ]
            return false
        params2: ref snd_pcm_hw_params_t
        snd_pcm_hw_params_malloc       [ ref params2 ]
        snd_pcm_hw_params_any          [ pcm, params2 ]
        snd_pcm_hw_params_set_access   [ pcm, params2, SND_PCM_ACCESS_RW_INTERLEAVED ]
        snd_pcm_hw_params_set_format   [ pcm, params2, SND_PCM_FORMAT_S16_LE ]
        snd_pcm_hw_params_set_channels [ pcm, params2, channels ]

        rate:           u32 [ sample_rate ]
        dir2:           i32 [ 0 ]
        snd_pcm_hw_params_set_rate_near        [ pcm, params2, ref rate, ref dir2 ]
        
        period_size:    i32 size
        dir_period:     i32 0
        snd_pcm_hw_params_set_period_size_near [ pcm, params2, ref period_size, ref dir_period ]
        rc = snd_pcm_hw_params [ pcm, params2 ]
        snd_pcm_hw_params_free [ params2 ]
        if [ rc < 0 ]
            printf [ "hw params failed: %s\n", snd_strerror [ rc ] ]
            return false
        return true

    func capture [] -> bool
        frames: i32 [ snd_pcm_readi [ pcm, buf, size ] ]
        
        if [ frames < 0 ]
            snd_pcm_prepare [ pcm ]
            return false
        
        for [ i: i32 0, i < size, i += 1 ]
            re[i] = buf[i] / 32768.0
            im[i] = 0.0
        
        fft [ re, im, size ]
        half2: i32 [ size / 2 ]
        for [ i: i32 0, i < half2, i += 1 ]
            bins[i] = sqrt [ re[i] * re[i] + im[i] * im[i] ]
        return true

    func close [] 
        snd_pcm_close [ pcm ]



# generic ALSA PCM output — shared by the emulators (knes/rgen/asnes/n64).
# construct with prop pairs (sample_rate/channels/buffer_size/device), then
# open[]; fill `buffer` (interleaved S16) and write[ frames ] — the blocking
# writei paces an emulation thread to real time.
class AudioOut
    public sample_rate : i32 [ 48000 ]
    public channels    : i32 [ 2 ]
    public buffer_size : sz  [ 1024 ]
    public device      : string
    public pcm_handle  : ref snd_pcm_t
    public buffer      : ref i16

    func open [] -> bool
        buffer = calloc[ 1, buffer_size * channels * 2 ]
        pb  : i32 [ SND_PCM_STREAM_PLAYBACK ]
        dev : symbol [ (device && device.count) ? device.chars : 'pulse' ]
        err : i32 [ snd_pcm_open[ ref pcm_handle, dev, pb, 0 ] ]
        if [ err < 0 ] return false
        psz    : snd_pcm_hw_params_sizeof[]
        params : ref snd_pcm_hw_params_t [ calloc[ 1, psz ] ]
        snd_pcm_hw_params_any[ pcm_handle, params ]
        rw  : i32 [ SND_PCM_ACCESS_RW_INTERLEAVED ]
        fmt : i32 [ SND_PCM_FORMAT_S16_LE ]
        snd_pcm_hw_params_set_access  [ pcm_handle, params, rw ]
        snd_pcm_hw_params_set_format  [ pcm_handle, params, fmt ]
        snd_pcm_hw_params_set_channels[ pcm_handle, params, channels ]
        snd_pcm_hw_params_set_rate    [ pcm_handle, params, sample_rate, 0 ]
        bufsz : sz [ buffer_size * 2 ]
        persz : sz [ buffer_size / 4 ]
        snd_pcm_hw_params_set_buffer_size_near[ pcm_handle, params, ref bufsz ]
        snd_pcm_hw_params_set_period_size_near[ pcm_handle, params, ref persz, null ]
        ok : bool [ snd_pcm_hw_params[ pcm_handle, params ] >= 0 ]
        free[ params ]
        if [ ok ]
            perr : i32 [ snd_pcm_prepare[ pcm_handle ] ]
            if [ perr < 0 ]
                puts 'AudioOut: prepare failed {snd_strerror[ perr ]}'
                ok = false
        return ok

    func write [ frames: i32 ] -> none
        if [ ! pcm_handle ] return
        wr : i64 [ snd_pcm_writei[ pcm_handle, buffer, frames ] ]
        if [ wr < 0 ]
            snd_pcm_recover[ pcm_handle, wr, 0 ]
            snd_pcm_writei[ pcm_handle, buffer, frames ]

    func close []
        if [ pcm_handle ]
            snd_pcm_drain[ pcm_handle ]
            snd_pcm_close[ pcm_handle ]
        pcm_handle = null

func fft [ re: ref f32, im: ref f32, n: i32 ] 
    if [ n <= 1 ]
        return
    
    half2: i32 [ n / 2 ]
    re_even: new f32 [ half2 ]
    im_even: new f32 [ half2 ]
    re_odd:  new f32 [ half2 ]
    im_odd:  new f32 [ half2 ]

    for [ i: i32 0, i < half2, i += 1 ]
        re_even[i] = re[i * 2]
        im_even[i] = im[i * 2]
        re_odd[i]  = re[i * 2 + 1]
        im_odd[i]  = im[i * 2 + 1]
    
    fft [ re_even, im_even, half2 ]
    fft [ re_odd,  im_odd,  half2 ]

    for [ i: i32 0, i < half2, i += 1 ]
        angle: f32 [ -6.28318530718 * i / n ]
        wr: f32 [ cos [ angle ] ]
        wi: f32 [ sin [ angle ] ]
        tr: f32 [ wr * re_odd[i] - wi * im_odd[i] ]
        ti: f32 [ wi * re_odd[i] + wr * im_odd[i] ]
        re[i]        = re_even[i] + tr
        im[i]        = im_even[i] + ti
        re[i + half2] = re_even[i] - tr
        im[i + half2] = im_even[i] - ti
    
    free [ re_even ]
    free [ im_even ]
    free [ re_odd ]
    free [ im_odd ]

# coverage is an abstract class;
coverage test
     i:i32
     func run[] -> Au
        i = 2
        puts 'ive done it all'
        return true


