import <time.h>
import <stdio.h>
import <stdlib.h>
import <string.h>
import <unistd.h>
import <math.h>
    -lm

# platform audio backend: CoreAudio (AudioQueue) on mac, ALSA elsewhere.
# AudioOut is the shared surface — construct with prop pairs
# (sample_rate/channels/buffer_size/device), open[], fill `buffer`
# (interleaved S16), write[ frames ]. the blocking write paces an
# emulation thread to real time. `active` is true after a good open.
ifdef [ apple ]
    import <AudioToolbox/AudioToolbox.h>
        -framework AudioToolbox

    # completion callback: user data points at the freed-buffer counter
    func aq_output_done [ user: handle, q: AudioQueueRef, b: AudioQueueBufferRef ] -> none
        c : ref u64 [ user ]
        c[0] += 1

    class AudioOut
        public sample_rate : i32 [ 48000 ]
        public channels    : i32 [ 2 ]
        public buffer_size : sz  [ 1024 ]
        public device      : string
        public active      : bool
        public buffer      : ref i16
        intern queue       : AudioQueueRef
        intern aq_bufs     : ref AudioQueueBufferRef
        intern freed       : ref u64           # callback-owned counter
        intern used        : u64               # write-side counter
        intern next        : i32               # round-robin buffer index

        func open [] -> bool
            bytes  : i32 [ buffer_size * channels * 2 ]
            buffer = calloc[ 1, bytes ]
            freed  = calloc[ 1, 8 ]
            aq_bufs = calloc[ 4, 8 ]
            fmt : AudioStreamBasicDescription
            memset[ ref fmt, 0, sizeof[ AudioStreamBasicDescription ] ]
            fmt.mSampleRate       = sample_rate
            fmt.mFormatID         = kAudioFormatLinearPCM
            fmt.mFormatFlags      = kLinearPCMFormatFlagIsSignedInteger | kLinearPCMFormatFlagIsPacked
            fmt.mBytesPerPacket   = channels * 2
            fmt.mFramesPerPacket  = 1
            fmt.mBytesPerFrame    = channels * 2
            fmt.mChannelsPerFrame = channels
            fmt.mBitsPerChannel   = 16
            err : i32 [ AudioQueueNewOutput[ ref fmt, ref aq_output_done, freed, null, null, 0, ref queue ] ]
            if [ err != 0 ] return false
            # prime all buffers with silence so playback paces immediately
            for [ i: i32 0, i < 4, i += 1 ]
                b : AudioQueueBufferRef
                AudioQueueAllocateBuffer[ queue, bytes, ref b ]
                memset[ b.mAudioData, 0, bytes ]
                b.mAudioDataByteSize = bytes
                AudioQueueEnqueueBuffer[ queue, b, 0, null ]
                aq_bufs[ i ] = b
            used = 4
            serr : i32 [ AudioQueueStart[ queue, null ] ]
            if [ serr != 0 ] return false
            active = true
            return true

        func write [ frames: i32 ] -> none
            if [ ! active ] return
            # block while the hardware ring is full — this paces the caller
            for [ used - freed[0] >= 4 ]
                usleep[ 500 ]
            b     : AudioQueueBufferRef [ aq_bufs[ next ] ]
            bytes : i32 [ frames * channels * 2 ]
            memcpy[ b.mAudioData, buffer, bytes ]
            b.mAudioDataByteSize = bytes
            AudioQueueEnqueueBuffer[ queue, b, 0, null ]
            used += 1
            next  = ( next + 1 ) % 4

        func close []
            if [ ! active ] return
            AudioQueueStop   [ queue, 1 ]
            AudioQueueDispose[ queue, 1 ]
            active = false
el
    import <alsa/asoundlib.h>
        -lasound

    class spectra
        public size:        i32
        public sample_rate: i32
        public channels:    i32
        public device:      cstr
        public pcm:         ref snd_pcm_t
        public re:          ref f32
        public im:          ref f32
        public buf:         ref i16
        public bins:        ref f32

        func init []
            channels = 1
            re   = new f32 [ size ]
            im   = new f32 [ size ]
            buf  = new i16 [ size ]
            bins = new f32 [ size / 2 ]

        func open [] -> bool
            rc: snd_pcm_open [ ref pcm, device, SND_PCM_STREAM_CAPTURE, 0 ]
            if [ rc < 0 ]
                printf [ "cannot open: %s\n", snd_strerror [ rc ] ]
                return false
            params2: ref snd_pcm_hw_params_t
            snd_pcm_hw_params_malloc       [ ref params2 ]
            snd_pcm_hw_params_any          [ pcm, params2 ]
            snd_pcm_hw_params_set_access   [ pcm, params2, SND_PCM_ACCESS_RW_INTERLEAVED ]
            snd_pcm_hw_params_set_format   [ pcm, params2, SND_PCM_FORMAT_S16_LE ]
            snd_pcm_hw_params_set_channels [ pcm, params2, channels ]

            rate:           u32 [ sample_rate ]
            dir2:           i32 [ 0 ]
            snd_pcm_hw_params_set_rate_near        [ pcm, params2, ref rate, ref dir2 ]

            period_size:    i32 size
            dir_period:     i32 0
            snd_pcm_hw_params_set_period_size_near [ pcm, params2, ref period_size, ref dir_period ]
            rc = snd_pcm_hw_params [ pcm, params2 ]
            snd_pcm_hw_params_free [ params2 ]
            if [ rc < 0 ]
                printf [ "hw params failed: %s\n", snd_strerror [ rc ] ]
                return false
            return true

        func capture [] -> bool
            frames: i32 [ snd_pcm_readi [ pcm, buf, size ] ]

            if [ frames < 0 ]
                snd_pcm_prepare [ pcm ]
                return false

            for [ i: i32 0, i < size, i += 1 ]
                re[i] = buf[i] / 32768.0
                im[i] = 0.0

            fft [ re, im, size ]
            half2: i32 [ size / 2 ]
            for [ i: i32 0, i < half2, i += 1 ]
                bins[i] = sqrt [ re[i] * re[i] + im[i] * im[i] ]
            return true

        func close []
            snd_pcm_close [ pcm ]

    class AudioOut
        public sample_rate : i32 [ 48000 ]
        public channels    : i32 [ 2 ]
        public buffer_size : sz  [ 1024 ]
        public device      : string
        public active      : bool
        public buffer      : ref i16
        public pcm_handle  : ref snd_pcm_t

        func open [] -> bool
            buffer = calloc[ 1, buffer_size * channels * 2 ]
            pb  : i32 [ SND_PCM_STREAM_PLAYBACK ]
            dev : symbol [ (device && device.count) ? device.chars : 'pulse' ]
            err : i32 [ snd_pcm_open[ ref pcm_handle, dev, pb, 0 ] ]
            if [ err < 0 ] return false
            psz    : snd_pcm_hw_params_sizeof[]
            params : ref snd_pcm_hw_params_t [ calloc[ 1, psz ] ]
            snd_pcm_hw_params_any[ pcm_handle, params ]
            rw  : i32 [ SND_PCM_ACCESS_RW_INTERLEAVED ]
            fmt : i32 [ SND_PCM_FORMAT_S16_LE ]
            snd_pcm_hw_params_set_access  [ pcm_handle, params, rw ]
            snd_pcm_hw_params_set_format  [ pcm_handle, params, fmt ]
            snd_pcm_hw_params_set_channels[ pcm_handle, params, channels ]
            snd_pcm_hw_params_set_rate    [ pcm_handle, params, sample_rate, 0 ]
            bufsz : sz [ buffer_size * 2 ]
            persz : sz [ buffer_size / 4 ]
            snd_pcm_hw_params_set_buffer_size_near[ pcm_handle, params, ref bufsz ]
            snd_pcm_hw_params_set_period_size_near[ pcm_handle, params, ref persz, null ]
            ok : bool [ snd_pcm_hw_params[ pcm_handle, params ] >= 0 ]
            free[ params ]
            if [ ok ]
                perr : i32 [ snd_pcm_prepare[ pcm_handle ] ]
                if [ perr < 0 ]
                    puts 'AudioOut: prepare failed {snd_strerror[ perr ]}'
                    ok = false
            active = ok
            return ok

        func write [ frames: i32 ] -> none
            if [ ! pcm_handle ] return
            wr : i64 [ snd_pcm_writei[ pcm_handle, buffer, frames ] ]
            if [ wr < 0 ]
                snd_pcm_recover[ pcm_handle, wr, 0 ]
                snd_pcm_writei[ pcm_handle, buffer, frames ]

        func close []
            if [ pcm_handle ]
                snd_pcm_drain[ pcm_handle ]
                snd_pcm_close[ pcm_handle ]
            pcm_handle = null
            active = false

func fft [ re: ref f32, im: ref f32, n: i32 ]
    if [ n <= 1 ]
        return

    half2: i32 [ n / 2 ]
    re_even: new f32 [ half2 ]
    im_even: new f32 [ half2 ]
    re_odd:  new f32 [ half2 ]
    im_odd:  new f32 [ half2 ]

    for [ i: i32 0, i < half2, i += 1 ]
        re_even[i] = re[i * 2]
        im_even[i] = im[i * 2]
        re_odd[i]  = re[i * 2 + 1]
        im_odd[i]  = im[i * 2 + 1]

    fft [ re_even, im_even, half2 ]
    fft [ re_odd,  im_odd,  half2 ]

    for [ i: i32 0, i < half2, i += 1 ]
        angle: f32 [ -6.28318530718 * i / n ]
        wr: f32 [ cos [ angle ] ]
        wi: f32 [ sin [ angle ] ]
        tr: f32 [ wr * re_odd[i] - wi * im_odd[i] ]
        ti: f32 [ wi * re_odd[i] + wr * im_odd[i] ]
        re[i]        = re_even[i] + tr
        im[i]        = im_even[i] + ti
        re[i + half2] = re_even[i] - tr
        im[i + half2] = im_even[i] - ti

    free [ re_even ]
    free [ im_even ]
    free [ re_odd ]
    free [ im_odd ]

# coverage: AudioOut opens, plays ~1s of 440 Hz, closes.
# 48 chunks > 4-buffer ring, so the blocking pace path is exercised.
coverage test
    func run[] -> Au
        out : AudioOut [ sample_rate: 48000, channels: 2, buffer_size: 1024 ]
        if [ ! out.open[] ]
            puts 'spectra test: audio device unavailable'
            return false
        if [ ! out.active ]
            puts 'spectra test: open ok but active not set'
            return false
        phase : f64 [ 0.0 ]
        step  : f64 [ 440.0 * 6.28318530718 / 48000.0 ]
        for [ chunk: i32 0, chunk < 48, chunk += 1 ]
            for [ i: i32 0, i < 1024, i += 1 ]
                s : i16 [ i16[ sin[ phase ] * 6000.0 ] ]
                out.buffer[ i * 2 ]     = s
                out.buffer[ i * 2 + 1 ] = s
                phase += step
            out.write[ 1024 ]
        out.close
        puts 'spectra test: AudioOut ok'
        return true


