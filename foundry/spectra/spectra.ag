# audio formats spectra claims. a module emits its extensions at build time
# into {SILVER}/install/export/spectra.agi; orbiter reads that and hands us
# the file — it has no per-format code of its own.
export extensions ['.mp3']

import net
import ai
import trinity
import vec

# platform audio backend: CoreAudio (AudioQueue) on mac, ALSA elsewhere.
# AudioOut is the shared surface — construct with prop pairs
# (sample_rate/channels/buffer_size/device), open[], fill `buffer`
# (interleaved S16), write[ frames ]. the blocking write paces an
# emulation thread to real time. `active` is true after a good open.
ifdef [ apple ]
    import <AudioToolbox/AudioToolbox.h>
        -framework AudioToolbox

    # completion callback: user data points at the freed-buffer counter
    func aq_output_done [ user: handle, q: AudioQueueRef, b: AudioQueueBufferRef ] -> none
        c : @u64 [ user ]
        c[0] += 1

    class AudioOut
        public sample_rate : i32 [ 48000 ]
        public channels    : i32 [ 2 ]
        public buffer_size : sz  [ 1024 ]
        public device      : string
        public active      : bool
        public buffer      : @i16
        intern queue       : AudioQueueRef
        intern aq_bufs     : @AudioQueueBufferRef
        intern freed       : @u64           # callback-owned counter
        intern used        : u64               # write-side counter
        intern next        : i32               # round-robin buffer index

        func open [] -> bool
            bytes  : i32 [ buffer_size * channels * 2 ]
            buffer = calloc[ 1, bytes ]
            freed  = calloc[ 1, 8 ]
            aq_bufs = calloc[ 4, 8 ]
            fmt : AudioStreamBasicDescription
            memset[ @fmt, 0, sizeof[ AudioStreamBasicDescription ] ]
            fmt.mSampleRate       = sample_rate
            fmt.mFormatID         = kAudioFormatLinearPCM
            fmt.mFormatFlags      = kLinearPCMFormatFlagIsSignedInteger | kLinearPCMFormatFlagIsPacked
            fmt.mBytesPerPacket   = channels * 2
            fmt.mFramesPerPacket  = 1
            fmt.mBytesPerFrame    = channels * 2
            fmt.mChannelsPerFrame = channels
            fmt.mBitsPerChannel   = 16
            err : i32 [ AudioQueueNewOutput[ @fmt, @aq_output_done, freed, null, null, 0, @queue ] ]
            if [ err != 0 ] return false
            # prime all buffers with silence so playback paces immediately
            for [ i: i32 0, i < 4, i += 1 ]
                b : AudioQueueBufferRef
                AudioQueueAllocateBuffer[ queue, bytes, @b ]
                memset[ b.mAudioData, 0, bytes ]
                b.mAudioDataByteSize = bytes
                AudioQueueEnqueueBuffer[ queue, b, 0, null ]
                aq_bufs[ i ] = b
            used = 4
            serr : i32 [ AudioQueueStart[ queue, null ] ]
            if [ serr != 0 ] return false
            active = true
            return true

        func write [ frames: i32 ] -> none
            if [ ! active ] return
            # block while the hardware ring is full — this paces the caller
            for [ used - freed[0] >= 4 ]
                usleep[ 500 ]
            b     : AudioQueueBufferRef [ aq_bufs[ next ] ]
            bytes : i32 [ frames * channels * 2 ]
            memcpy[ b.mAudioData, buffer, bytes ]
            b.mAudioDataByteSize = bytes
            AudioQueueEnqueueBuffer[ queue, b, 0, null ]
            used += 1
            next  = ( next + 1 ) % 4

        func close []
            if [ ! active ] return
            AudioQueueStop   [ queue, 1 ]
            AudioQueueDispose[ queue, 1 ]
            active = false
el
    import <alsa/asoundlib.h>
        -lasound

    class spectra
        public size:        i32
        public sample_rate: i32
        public channels:    i32
        public device:      cstr
        public pcm:         @snd_pcm_t
        public re:          @f32
        public im:          @f32
        public buf:         @i16
        public bins:        @f32

        func init []
            channels = 1
            re   = new f32 [ size ]
            im   = new f32 [ size ]
            buf  = new i16 [ size ]
            bins = new f32 [ size / 2 ]

        func open [] -> bool
            rc: snd_pcm_open [ @pcm, device, SND_PCM_STREAM_CAPTURE, 0 ]
            if [ rc < 0 ]
                printf [ "cannot open: %s\n", snd_strerror [ rc ] ]
                return false
            params2: @snd_pcm_hw_params_t
            snd_pcm_hw_params_malloc       [ @params2 ]
            snd_pcm_hw_params_any          [ pcm, params2 ]
            snd_pcm_hw_params_set_access   [ pcm, params2, SND_PCM_ACCESS_RW_INTERLEAVED ]
            snd_pcm_hw_params_set_format   [ pcm, params2, SND_PCM_FORMAT_S16_LE ]
            snd_pcm_hw_params_set_channels [ pcm, params2, channels ]

            rate:           u32 [ sample_rate ]
            dir2:           i32 [ 0 ]
            snd_pcm_hw_params_set_rate_near        [ pcm, params2, @rate, @dir2 ]

            period_size:    i32 size
            dir_period:     i32 0
            snd_pcm_hw_params_set_period_size_near [ pcm, params2, @period_size, @dir_period ]
            rc = snd_pcm_hw_params [ pcm, params2 ]
            snd_pcm_hw_params_free [ params2 ]
            if [ rc < 0 ]
                printf [ "hw params failed: %s\n", snd_strerror [ rc ] ]
                return false
            return true

        func capture [] -> bool
            frames: i32 [ snd_pcm_readi [ pcm, buf, size ] ]

            if [ frames < 0 ]
                snd_pcm_prepare [ pcm ]
                return false

            for [ i: i32 0, i < size, i += 1 ]
                re[i] = buf[i] / 32768.0
                im[i] = 0.0

            fft [ re, im, size ]
            half2: i32 [ size / 2 ]
            for [ i: i32 0, i < half2, i += 1 ]
                bins[i] = sqrt [ re[i] * re[i] + im[i] * im[i] ]
            return true

        # discard any audio ALSA queued while we weren't reading (between
        # takes the device stays open and accumulates — draining here means a
        # new take captures FRESH audio, not the stale backlog)
        func drain []
            if [ !pcm ] return
            snd_pcm_drop    [ pcm ]
            snd_pcm_prepare [ pcm ]
            snd_pcm_start   [ pcm ]

        func close []
            # pcm is null when open[] failed (no capture device) — closing then
            # segfaults inside alsa. null it after, so a second close is safe too.
            if [ !pcm ] return
            snd_pcm_close [ pcm ]
            pcm = null

    class AudioOut
        public sample_rate : i32 [ 48000 ]
        public channels    : i32 [ 2 ]
        public buffer_size : sz  [ 1024 ]
        public device      : string
        public active      : bool
        public buffer      : @i16
        public pcm_handle  : @snd_pcm_t

        func open [] -> bool
            buffer = calloc[ 1, buffer_size * channels * 2 ]
            pb  : i32 [ SND_PCM_STREAM_PLAYBACK ]
            dev : symbol [ (device && device.count) ? device.chars : 'pulse' ]
            err : i32 [ snd_pcm_open[ @pcm_handle, dev, pb, 0 ] ]
            if [ err < 0 ] return false
            psz    : snd_pcm_hw_params_sizeof[]
            params : @snd_pcm_hw_params_t [ calloc[ 1, psz ] ]
            snd_pcm_hw_params_any[ pcm_handle, params ]
            rw  : i32 [ SND_PCM_ACCESS_RW_INTERLEAVED ]
            fmt : i32 [ SND_PCM_FORMAT_S16_LE ]
            snd_pcm_hw_params_set_access  [ pcm_handle, params, rw ]
            snd_pcm_hw_params_set_format  [ pcm_handle, params, fmt ]
            snd_pcm_hw_params_set_channels[ pcm_handle, params, channels ]
            snd_pcm_hw_params_set_rate    [ pcm_handle, params, sample_rate, 0 ]
            bufsz : sz [ buffer_size * 2 ]
            persz : sz [ buffer_size / 4 ]
            snd_pcm_hw_params_set_buffer_size_near[ pcm_handle, params, @bufsz ]
            snd_pcm_hw_params_set_period_size_near[ pcm_handle, params, @persz, null ]
            ok : bool [ snd_pcm_hw_params[ pcm_handle, params ] >= 0 ]
            free[ params ]
            if [ ok ]
                perr : i32 [ snd_pcm_prepare[ pcm_handle ] ]
                if [ perr < 0 ]
                    puts 'AudioOut: prepare failed {snd_strerror[ perr ]}'
                    ok = false
            active = ok
            return ok

        func write [ frames: i32 ] -> none
            if [ ! pcm_handle ] return
            wr : i64 [ snd_pcm_writei[ pcm_handle, buffer, frames ] ]
            if [ wr < 0 ]
                snd_pcm_recover[ pcm_handle, wr, 0 ]
                snd_pcm_writei[ pcm_handle, buffer, frames ]

        func close []
            if [ pcm_handle ]
                snd_pcm_drain[ pcm_handle ]
                snd_pcm_close[ pcm_handle ]
            pcm_handle = null
            active = false

# decoded PCM, interleaved S16
class AudioClip
    public rate     : i32
    public channels : i32
    public frames   : i64
    public pcm      : @i16

func be32 [ b: @u8, o: i32 ] -> i64
    return i64[ b[o] ] * 16777216 + i64[ b[o+1] ] * 65536 + i64[ b[o+2] ] * 256 + i64[ b[o+3] ]

func le32 [ b: @u8, o: i32 ] -> i64
    return i64[ b[o] ] + i64[ b[o+1] ] * 256 + i64[ b[o+2] ] * 65536 + i64[ b[o+3] ] * 16777216

func le16 [ b: @u8, o: i32 ] -> i32
    return i32[ b[o] ] + i32[ b[o+1] ] * 256

func be64 [ b: @u8, o: i32 ] -> i64
    hi : i64 [ be32[ b, o ] ]
    lo : i64 [ be32[ b, o + 4 ] ]
    return hi * 4294967296 + lo

# parsed AAC packet stream, container-agnostic
class AacStream
    public asc_o   : i32
    public asc_n   : i32
    public npkts   : i64
    public sizes   : @i32
    public offs    : @i32
    public priming : i32
    public nvalid  : i64

func box_find [ b: @u8, s: i32, e: i32, cc: i64 ] -> i32
    o : i32 [ s ]
    while [ o + 8 <= e ]
        bs : i64 [ be32[ b, o ] ]
        bt : i64 [ be32[ b, o + 4 ] ]
        if [ bt == cc ] return o
        if [ bs < 8 ] return -1
        adv : i32 [ i32[ bs ] ]
        o += adv
    return -1

# esds descriptor chain: tag 5 payload is the raw ASC.
# returns offset * 65536 + length, or -1
func esds_asc [ b: @u8, s: i32, e: i32 ] -> i64
    q : i32 [ s ]
    while [ q < e ]
        tag : i32 [ i32[ b[ q ] ] ]
        q += 1
        ln : i32 [ 0 ]
        while [ true ]
            b9 : i32 [ i32[ b[ q ] ] ]
            q += 1
            ln = ln * 128 + (b9 & 127)
            if [ (b9 & 128) == 0 ] break
        if [ tag == 5 ]
            return i64[ q ] * 65536 + i64[ ln ]
        el [ tag == 3 ]
            q += 3
        el [ tag == 4 ]
            q += 13
        el
            q += ln
    return -1

# CAF: desc/kuki/pakt/data big-endian chunks
func caf_parse [ buf: @u8, fsz: i32 ] -> AacStream
    o      : i32 [ 8 ]
    kuki_o : i32 [ -1 ]
    kuki_n : i32 [ 0 ]
    pakt_o : i32 [ -1 ]
    data_o : i32 [ -1 ]
    while [ o + 12 <= fsz ]
        ct : i64 [ be32[ buf, o ] ]
        cs : i64 [ be64[ buf, o + 4 ] ]
        o += 12
        if [ ct == 1802659689 ]
            kuki_o = o
            kuki_n = i32[ cs ]
        el [ ct == 1885432180 ]
            pakt_o = o
        el [ ct == 1684108385 ]
            data_o = o + 4
        if [ cs < 0 ] break
        adv : i32 [ i32[ cs ] ]
        o += adv
    if [ kuki_o < 0 || pakt_o < 0 || data_o < 0 ] return null
    st : AacStream [ asc_o: kuki_o, asc_n: kuki_n ]
    if [ i32[ buf[ kuki_o ] ] == 3 ]
        pk : i64 [ esds_asc[ buf, kuki_o, kuki_o + kuki_n ] ]
        if [ pk < 0 ] return null
        st.asc_o = i32[ pk / 65536 ]
        st.asc_n = i32[ pk % 65536 ]
    st.npkts   = be64[ buf, pakt_o ]
    st.nvalid  = be64[ buf, pakt_o + 8 ]
    st.priming = i32[ be32[ buf, pakt_o + 16 ] ]
    np : i32 [ i32[ st.npkts ] ]
    st.sizes = new i32 [ np ]
    st.offs  = new i32 [ np ]
    po : i32 [ pakt_o + 24 ]
    doff : i32 [ data_o ]
    for [ k: i32 0, k < np, k += 1 ]
        psz : i32 [ 0 ]
        while [ true ]
            b9 : i32 [ i32[ buf[ po ] ] ]
            po += 1
            psz = psz * 128 + (b9 & 127)
            if [ (b9 & 128) == 0 ] break
        st.sizes[ k ] = psz
        st.offs[ k ]  = doff
        doff += psz
    return st

# M4A/MP4: moov.trak.mdia.minf.stbl — esds config, stsz sizes,
# stsc/stco chunk layout. Apple shipped these with a .caf name.
func m4a_parse [ buf: @u8, fsz: i32 ] -> AacStream
    moov : i32 [ box_find[ buf, 0, fsz, 1836019574 ] ]
    if [ moov < 0 ] return null
    me   : i32 [ moov + i32[ be32[ buf, moov ] ] ]
    trak : i32 [ box_find[ buf, moov + 8, me, 1953653099 ] ]
    if [ trak < 0 ] return null
    te   : i32 [ trak + i32[ be32[ buf, trak ] ] ]
    # elst media_time = encoder priming in media samples
    priming : i32 [ 2112 ]
    edts : i32 [ box_find[ buf, trak + 8, te, 1701082227 ] ]
    if [ edts >= 0 ]
        ee   : i32 [ edts + i32[ be32[ buf, edts ] ] ]
        elst : i32 [ box_find[ buf, edts + 8, ee, 1701606260 ] ]
        if [ elst >= 0 ]
            nent : i32 [ i32[ be32[ buf, elst + 12 ] ] ]
            if [ nent > 0 ]
                mt : i32 [ i32[ be32[ buf, elst + 20 ] ] ]
                if [ mt > 0 ] priming = mt
    mdia : i32 [ box_find[ buf, trak + 8, te, 1835297121 ] ]
    if [ mdia < 0 ] return null
    de   : i32 [ mdia + i32[ be32[ buf, mdia ] ] ]
    minf : i32 [ box_find[ buf, mdia + 8, de, 1835626086 ] ]
    if [ minf < 0 ] return null
    fe   : i32 [ minf + i32[ be32[ buf, minf ] ] ]
    stbl : i32 [ box_find[ buf, minf + 8, fe, 1937007212 ] ]
    if [ stbl < 0 ] return null
    se   : i32 [ stbl + i32[ be32[ buf, stbl ] ] ]
    stsd : i32 [ box_find[ buf, stbl + 8, se, 1937011556 ] ]
    stsz : i32 [ box_find[ buf, stbl + 8, se, 1937011578 ] ]
    stsc : i32 [ box_find[ buf, stbl + 8, se, 1937011555 ] ]
    stco : i32 [ box_find[ buf, stbl + 8, se, 1937007471 ] ]
    if [ stsd < 0 || stsz < 0 || stsc < 0 || stco < 0 ] return null
    # stsd first entry is the mp4a sample entry; esds is its child
    entry : i32 [ stsd + 16 ]
    entry_e : i32 [ entry + i32[ be32[ buf, entry ] ] ]
    esds : i32 [ box_find[ buf, entry + 36, entry_e, 1702061171 ] ]
    if [ esds < 0 ] return null
    ese : i32 [ esds + i32[ be32[ buf, esds ] ] ]
    pk : i64 [ esds_asc[ buf, esds + 12, ese ] ]
    if [ pk < 0 ] return null
    st : AacStream [ asc_o: i32[ pk / 65536 ], asc_n: i32[ pk % 65536 ], priming: priming ]
    np : i32 [ i32[ be32[ buf, stsz + 16 ] ] ]
    fixed : i32 [ i32[ be32[ buf, stsz + 12 ] ] ]
    st.npkts = np
    st.sizes = new i32 [ np ]
    st.offs  = new i32 [ np ]
    for [ k: i32 0, k < np, k += 1 ]
        st.sizes[ k ] = (fixed > 0) ? fixed : i32[ be32[ buf, stsz + 20 + k * 4 ] ]
    nchunk : i32 [ i32[ be32[ buf, stco + 12 ] ] ]
    nsc    : i32 [ i32[ be32[ buf, stsc + 12 ] ] ]
    k2 : i32 [ 0 ]
    sci : i32 [ 0 ]
    for [ ci: i32 0, ci < nchunk, ci += 1 ]
        # advance the stsc run whose first_chunk covers this chunk
        while [ sci + 1 < nsc ]
            nfc : i32 [ i32[ be32[ buf, stsc + 16 + (sci + 1) * 12 ] ] ]
            if [ ci + 1 >= nfc ]
                sci += 1
            el
                break
        spc : i32 [ i32[ be32[ buf, stsc + 16 + sci * 12 + 4 ] ] ]
        coff : i32 [ i32[ be32[ buf, stco + 16 + ci * 4 ] ] ]
        for [ j: i32 0, j < spc, j += 1 ]
            if [ k2 >= np ] break
            st.offs[ k2 ] = coff
            coff += st.sizes[ k2 ]
            k2 += 1
    st.nvalid = 0
    return st

# .wav (RIFF PCM S16) -> PCM. hand-parsed: fmt + data chunks only
func wav_load [ p: path ] -> AudioClip
    fp : @FILE [ fopen[ '{p}', 'rb' ] ]
    if [ !fp ]
        puts 'wav: cannot open {p}'
        return null
    fseek[ fp, 0, SEEK_END ]
    fsz : i32 [ i32[ ftell[ fp ] ] ]
    fseek[ fp, 0, SEEK_SET ]
    buf : new u8 [ fsz ]
    fread[ buf, 1, fsz, fp ]
    fclose[ fp ]
    if [ fsz < 44 || be32[ buf, 0 ] != 1380533830 || be32[ buf, 8 ] != 1463899717 ]
        puts 'wav: not RIFF/WAVE: {p}'
        return null
    rate : i32 [ 0 ]
    ch : i32 [ 0 ]
    bits : i32 [ 0 ]
    doff : i32 [ 0 ]
    dsz : i32 [ 0 ]
    o : i32 [ 12 ]
    for [ o + 8 <= fsz ]
        cid : i64 [ be32[ buf, o ] ]
        csz : i32 [ i32[ le32[ buf, o + 4 ] ] ]
        if [ cid == 1718449184 ]
            ch   = le16[ buf, o + 10 ]
            rate = i32[ le32[ buf, o + 12 ] ]
            bits = le16[ buf, o + 22 ]
        if [ cid == 1684108385 ]
            doff = o + 8
            dsz = csz
        o += 8 + csz + (csz % 2)
    if [ rate < 1 || ch < 1 || bits != 16 || dsz < 2 ]
        puts 'wav: unsupported format in {p} (need PCM S16)'
        return null
    nfr : i64 [ i64[ dsz ] / i64[ ch * 2 ] ]
    cnt : i32 [ i32[ nfr ] * ch ]
    pcm : new i16 [ cnt ]
    memcpy[ pcm, @buf[ doff ], i64[ cnt ] * 2 ]
    clip : AudioClip [ rate: rate, channels: ch, frames: nfr ]
    clip.pcm = pcm
    return clip

# .mp3 -> PCM via system libmpg123 (vendored decls: mpg123min.h)
func mp3_load [ p: path ] -> AudioClip
    mpg123_init[]
    err9 : i32 [ 0 ]
    mh : @mpg123_handle [ mpg123_new[ null, @err9 ] ]
    if [ !mh ]
        puts 'mp3: mpg123_new failed ({err9})'
        return null
    if [ mpg123_open[ mh, '{p}' ] != 0 ]
        puts 'mp3: cannot open {p}'
        mpg123_delete[ mh ]
        return null
    mpg123_scan[ mh ]
    rate9 : i64 [ 0 ]
    ch9   : i32 [ 0 ]
    enc9  : i32 [ 0 ]
    mpg123_getformat[ mh, @rate9, @ch9, @enc9 ]
    if [ rate9 < 1 || ch9 < 1 ]
        puts 'mp3: no stream format in {p}'
        mpg123_close[ mh ]
        mpg123_delete[ mh ]
        return null
    mpg123_format_none[ mh ]
    mpg123_format[ mh, rate9, ch9, MPG123_ENC_SIGNED_16 ]
    nfr : i64 [ mpg123_length[ mh ] ]
    if [ nfr < 1 ] nfr = rate9 * 600
    cap : i64 [ (nfr + 8192) * i64[ ch9 ] ]
    pcm : new i16 [ cap ]
    wr : i64 [ 0 ]
    for [ true ]
        room : i64 [ (cap - wr) * 2 ]
        if [ room < 9216 ] break
        done9 : u64 [ 0 ]
        r9 : i32 [ mpg123_read[ mh, @pcm[ wr ], room, @done9 ] ]
        wr += i64[ done9 ] / 2
        if [ r9 != MPG123_OK ] break
    mpg123_close[ mh ]
    mpg123_delete[ mh ]
    clip : AudioClip [ rate: i32[ rate9 ], channels: ch9, frames: wr / i64[ ch9 ] ]
    clip.pcm = pcm
    puts 'mp3: {p} rate={clip.rate} ch={clip.channels} frames={clip.frames}'
    return clip

# .caf or .m4a (Apple shipped m4a bytes under .caf names) -> PCM
func caf_load [ p: path ] -> AudioClip
    fp : @FILE [ fopen[ '{p}', 'rb' ] ]
    if [ !fp ]
        puts 'caf: cannot open {p}'
        return null
    fseek[ fp, 0, SEEK_END ]
    fsz : i32 [ i32[ ftell[ fp ] ] ]
    fseek[ fp, 0, SEEK_SET ]
    buf : new u8 [ fsz ]
    fread[ buf, 1, fsz, fp ]
    fclose[ fp ]
    st : AacStream [ null ]
    if [ be32[ buf, 0 ] == 1667327590 ]
        st = caf_parse[ buf, fsz ]
    el [ be32[ buf, 4 ] == 1718909296 ]
        st = m4a_parse[ buf, fsz ]
    if [ !st ]
        # ID3 tag or bare MPEG sync = mp3, decode via libmpg123
        if [ (buf[0] == 73 && buf[1] == 68 && buf[2] == 51) || buf[0] == 255 ]
            return mp3_load[ p ]
        # RIFF = wav
        if [ be32[ buf, 0 ] == 1380533830 ]
            return wav_load[ p ]
        puts 'caf: unsupported container: {p}'
        return null
    h : NeAACDecOpen[]
    conf : NeAACDecGetCurrentConfiguration[ h ]
    conf.outputFormat = FAAD_FMT_16BIT
    NeAACDecSetConfiguration[ h, conf ]
    sr9 : u64 [ 0 ]
    ch9 : u8 [ 0 ]
    ir : i64 [ NeAACDecInit2[ h, @buf[ st.asc_o ], u64[ st.asc_n ], @sr9, @ch9 ] ]
    if [ ir != 0 ]
        puts 'caf: faad init failed on {p}'
        NeAACDecClose[ h ]
        return null
    ch : i32 [ i32[ ch9 ] ]
    rate : i32 [ i32[ sr9 ] ]
    cap : i64 [ (st.npkts + 2) * 2048 * ch ]
    pcm : new i16 [ cap ]
    wr : i64 [ 0 ]
    np : i32 [ i32[ st.npkts ] ]
    for [ k: i32 0, k < np, k += 1 ]
        info : NeAACDecFrameInfo
        doff : i32 [ st.offs[ k ] ]
        psz  : i32 [ st.sizes[ k ] ]
        smp : @i16 [ NeAACDecDecode[ h, @info, @buf[ doff ], psz ] ]
        if [ info.error != 0 || !smp ] continue
        if [ i32[ info.channels ] > 0 ] ch = i32[ info.channels ]
        ns : i64 [ i64[ info.samples ] ]
        if [ wr + ns > cap ] break
        nb : i64 [ ns * 2 ]
        memcpy[ @pcm[ wr ], smp, nb ]
        wr += ns
    NeAACDecClose[ h ]
    # drop encoder priming; trim to the container's frame count if known
    start : i64 [ i64[ st.priming ] * ch ]
    total : i64 [ wr - start ]
    if [ st.nvalid > 0 ]
        nv : i64 [ st.nvalid * ch ]
        if [ nv < total ] total = nv
    if [ total < 0 ] total = 0
    if [ start > 0 && total > 0 ]
        tb : i64 [ total * 2 ]
        memmove[ pcm, @pcm[ start ], tb ]
    clip : AudioClip [ rate: rate, channels: ch, frames: total / ch ]
    clip.pcm = pcm
    puts 'caf: {p} rate={rate} ch={ch} frames={clip.frames}'
    return clip

class Voice
    public clip   : AudioClip
    public pos    : f64
    public gain   : f32
    public pitch  : f32 [ 1.0 ]
    public loop   : bool
    public active : bool

# tiny software mixer on its own thread; AudioOut's blocking
# write paces it. play[] is safe from the UI thread.
class AudioMixer
    public sample_rate : i32 [ 44100 ]
    public out    : AudioOut
    intern voices : array Voice
    intern acc    : @i32
    intern stop   : bool

    func start [] -> bool
        out = AudioOut [ sample_rate: sample_rate, channels: 2, buffer_size: 1024 ]
        if [ !out.open[] ]
            puts 'mixer: audio device unavailable'
            return false
        voices = array Voice [ ]
        voices.hold[]
        nacc : i32 [ out.buffer_size * 2 ]
        acc = new i32 [ nacc ]
        tid : local u64 [ 1 ]
        pthread_create[ tid, null, @mix_entry, a ]
        return true

    # pitch: OpenAL AL_PITCH semantics — playback rate multiplier
    func play_p [ c: AudioClip, loop2: bool, gain2: f32, pitch2: f32 ]
        if [ !c || !out || !out.active ] return
        for [ v: Voice ] in voices
            if [ !v.active ]
                v.clip = c
                v.pos = 0.0
                v.gain = gain2
                v.pitch = pitch2
                v.loop = loop2
                v.active = true
                return
        nv : Voice [ clip: c, pos: 0.0, gain: gain2, pitch: pitch2, loop: loop2 ]
        voices += nv
        nv.active = true

    func play [ c: AudioClip, loop2: bool, gain2: f32 ]
        play_p[ c, loop2, gain2, 1.0 ]

    func mix_entry [] -> none
        n : i32 [ out.buffer_size ]
        n2 : i32 [ n * 2 ]
        while [ !stop ]
            for [ i: i32 0, i < n2, i += 1 ] acc[ i ] = 0
            for [ v: Voice ] in voices
                if [ !v.active ] continue
                c : v.clip
                step : f64 [ f64[ c.rate ] / f64[ sample_rate ] * f64[ v.pitch ] ]
                ch : i32 [ c.channels ]
                for [ i: i32 0, i < n, i += 1 ]
                    lim : f64 [ f64[ c.frames - 1 ] ]
                    if [ v.pos >= lim ]
                        if [ v.loop ]
                            v.pos = 0.0
                        el
                            v.active = false
                            break
                    i0 : i64 [ i64[ v.pos ] ]
                    fr : f32 [ f32[ v.pos - f64[ i0 ] ] ]
                    b0 : i64 [ i0 * ch ]
                    b1 : i64 [ (i0 + 1) * ch ]
                    l0 : f32 [ f32[ c.pcm[ b0 ] ] ]
                    l1 : f32 [ f32[ c.pcm[ b1 ] ] ]
                    ls : f32 [ (l0 + (l1 - l0) * fr) * v.gain ]
                    rs : f32 [ ls ]
                    if [ ch > 1 ]
                        r0 : f32 [ f32[ c.pcm[ b0 + 1 ] ] ]
                        r1 : f32 [ f32[ c.pcm[ b1 + 1 ] ] ]
                        rs = (r0 + (r1 - r0) * fr) * v.gain
                    li : i32 [ i32[ ls ] ]
                    ri : i32 [ i32[ rs ] ]
                    acc[ i * 2 ] += li
                    acc[ i * 2 + 1 ] += ri
                    v.pos += step
            for [ i: i32 0, i < n2, i += 1 ]
                s5 : i32 [ acc[ i ] ]
                if [ s5 > 32767 ] s5 = 32767
                if [ s5 < -32768 ] s5 = -32768
                out.buffer[ i ] = i16[ s5 ]
            out.write[ n ]
        out.close[]

# iterative in-place radix-2, e^-i2pik/n forward — the same transform
# the old recursive form computed, with ZERO allocations (that version
# heap-allocated four buffers per level per call)
func fft [ re: @f32, im: @f32, n: i32 ]
    if [ n <= 1 ]
        return
    j : i32 [ 0 ]
    for [ i: i32 1, i < n, i += 1 ]
        m2 : i32 [ n / 2 ]
        for [ m2 >= 1 && j >= m2 ]
            j -= m2
            m2 = m2 / 2
        j += m2
        if [ i < j ]
            tr0 : f32 [ re[ i ] ]
            re[ i ] = re[ j ]
            re[ j ] = tr0
            ti0 : f32 [ im[ i ] ]
            im[ i ] = im[ j ]
            im[ j ] = ti0
    ln : i32 [ 2 ]
    for [ ln <= n ]
        ha : i32 [ ln / 2 ]
        ang0 : f32 [ -6.28318530718 / f32[ ln ] ]
        wr0 : f32 [ cos[ ang0 ] ]
        wi0 : f32 [ sin[ ang0 ] ]
        for [ s: i32 0, s < n, s += ln ]
            wr : f32 [ 1.0 ]
            wi : f32 [ 0.0 ]
            for [ k: i32 0, k < ha, k += 1 ]
                i0 : i32 [ s + k ]
                i1 : i32 [ s + k + ha ]
                tr : f32 [ wr * re[ i1 ] - wi * im[ i1 ] ]
                ti : f32 [ wi * re[ i1 ] + wr * im[ i1 ] ]
                re[ i1 ] = re[ i0 ] - tr
                im[ i1 ] = im[ i0 ] - ti
                re[ i0 ] = re[ i0 ] + tr
                im[ i0 ] = im[ i0 ] + ti
                wn : f32 [ wr * wr0 - wi * wi0 ]
                wi = wr * wi0 + wi * wr0
                wr = wn
        ln = ln * 2

# heat colormap: black -> deep blue -> purple -> orange -> white
# returns r*65536 + g*256 + b
func heat [ t0: f32 ] -> i32
    t : f32 [ t0 ]
    if [ t < 0.0 ] t = 0.0
    if [ t > 1.0 ] t = 1.0
    r0 : f32 [ 0.0 ]
    g0 : f32 [ 0.0 ]
    b0 : f32 [ 0.0 ]
    r1 : f32 [ 0.0 ]
    g1 : f32 [ 0.0 ]
    b1 : f32 [ 0.0 ]
    f : f32 [ 0.0 ]
    if [ t < 0.25 ]
        r1 = 22.0
        g1 = 24.0
        b1 = 96.0
        f = t * 4.0
    el [ t < 0.5 ]
        r0 = 22.0
        g0 = 24.0
        b0 = 96.0
        r1 = 128.0
        g1 = 32.0
        b1 = 142.0
        f = (t - 0.25) * 4.0
    el [ t < 0.75 ]
        r0 = 128.0
        g0 = 32.0
        b0 = 142.0
        r1 = 244.0
        g1 = 124.0
        b1 = 44.0
        f = (t - 0.5) * 4.0
    el
        r0 = 244.0
        g0 = 124.0
        b0 = 44.0
        r1 = 255.0
        g1 = 244.0
        b1 = 210.0
        f = (t - 0.75) * 4.0
    r : i32 [ i32[ r0 + (r1 - r0) * f ] ]
    g : i32 [ i32[ g0 + (g1 - g0) * f ] ]
    b : i32 [ i32[ b0 + (b1 - b0) * f ] ]
    return r * 65536 + g * 256 + b

# per-channel spectrograph, log-frequency 20Hz..10kHz, dB heat map.
# channels stack top to bottom (L then R); time runs right.
# gray: single-channel magnitude image (the MODEL input); false =
# heat colormap rgba for human eyes. act (nullable): filled with the
# per-column mean magnitude — the annotator's energy trace
func spectrograph [ c: AudioClip, out2: path, w2: i32, h2: i32, fmin: f32, fmax: f32, gray: bool, act: @f32 ] -> bool
    if [ !c || c.frames < 4096 ] return false
    n : i32 [ 2048 ]
    # the analysis window matches the LIVE stream's 42.7ms slice at
    # ANY clip rate: wn samples of real signal, zero-padded into the
    # 2048 fft, magnitudes scaled by the fill ratio. without this a
    # 16k clip would get 128ms windows — 3x the temporal smear of
    # what the mic stream produces, a real domain gap
    wn : i32 [ i32[ i64[ c.rate ] * 2048 / 48000 ] ]
    if [ wn > n ] wn = n
    if [ wn < 64 ] wn = 64
    mscale : f32 [ f32[ n ] / f32[ wn ] ]
    re : new f32 [ n ]
    im : new f32 [ n ]
    win : new f32 [ n ]
    for [ i: i32 0, i < wn, i += 1 ]
        ang : f32 [ 6.28318530718 * f32[ i ] / f32[ wn ] ]
        win[ i ] = 0.5 - 0.5 * cos[ ang ]
    nch5 : i32 [ (gray) ? 1 : 4 ]
    pfmt : Pixel [ (gray) ? Pixel.u8 : Pixel.rgba8 ]
    img2 : Image [ width: w2, height: h2, format: pfmt, channels: nch5 ]
    pd : @u8 [ img2.vdata[] ]
    ch : i32 [ c.channels ]
    gap : i32 [ (ch > 1) ? 2 : 0 ]
    band : i32 [ (h2 - gap * (ch - 1)) / ch ]
    span : i64 [ c.frames - i64[ n ] ]
    hop : i64 [ span / i64[ w2 ] ]
    if [ hop < 1 ] hop = 1
    nyq : f32 [ f32[ c.rate ] * 0.5 ]
    fx2 : f32 [ (fmax > nyq) ? nyq : fmax ]
    lr : f32 [ log[ fx2 / fmin ] ]
    # divider rows between channel bands
    for [ y: i32 0, y < h2, y += 1 ]
        for [ x: i32 0, x < w2, x += 1 ]
            if [ gray ]
                dg0 : i64 [ i64[ y ] * w2 + x ]
                pd[ dg0 ] = 0
            el
                di : i64 [ (i64[ y ] * w2 + x) * 4 ]
                pd[ di ]     = 0
                pd[ di + 1 ] = 0
                pd[ di + 2 ] = 0
                pd[ di + 3 ] = 255
    for [ x: i32 0, x < w2, x += 1 ]
        s0 : i64 [ i64[ x ] * hop ]
        for [ c2: i32 0, c2 < ch, c2 += 1 ]
            for [ i: i32 0, i < wn, i += 1 ]
                b9 : i64 [ (s0 + i64[ i ]) * ch + c2 ]
                re[ i ] = f32[ c.pcm[ b9 ] ] / 32768.0 * win[ i ]
                im[ i ] = 0.0
            for [ i: i32 wn, i < n, i += 1 ]
                re[ i ] = 0.0
                im[ i ] = 0.0
            fft[ re, im, n ]
            ytop : i32 [ c2 * (band + gap) ]
            for [ y: i32 0, y < band, y += 1 ]
                # log frequency: band bottom = 20Hz, top = 10kHz
                t : f32 [ f32[ band - 1 - y ] / f32[ band - 1 ] ]
                fq : f32 [ fmin * exp[ t * lr ] ]
                fb : f32 [ fq * f32[ n ] / f32[ c.rate ] ]
                bi : i32 [ i32[ fb ] ]
                fr : f32 [ fb - f32[ bi ] ]
                m0 : f32 [ sqrt[ re[ bi ] * re[ bi ] + im[ bi ] * im[ bi ] ] ]
                m1 : f32 [ sqrt[ re[ bi + 1 ] * re[ bi + 1 ] + im[ bi + 1 ] * im[ bi + 1 ] ] ]
                mag : f32 [ m0 + (m1 - m0) * fr ]
                amp : f32 [ mag * mscale / 512.0 ]
                db : f32 [ 8.6858896 * log[ amp + 0.0000000001 ] ]
                tv : f32 [ (db + 80.0) / 80.0 ]
                if [ tv < 0.0 ] tv = 0.0
                if [ tv > 1.0 ] tv = 1.0
                if [ act && c2 == 0 ]
                    act[ x ] += tv / f32[ band ]
                if [ gray ]
                    dg1 : i64 [ i64[ ytop + y ] * w2 + x ]
                    pd[ dg1 ] = u8[ tv * 255.0 ]
                el
                    rgb : i32 [ heat[ tv ] ]
                    di : i64 [ (i64[ ytop + y ] * w2 + x) * 4 ]
                    pd[ di ]     = u8[ rgb / 65536 ]
                    pd[ di + 1 ] = u8[ (rgb / 256) % 256 ]
                    pd[ di + 2 ] = u8[ rgb % 256 ]
                    pd[ di + 3 ] = 255
    img2.png[ out2 ]
    return true

# ---- whisper frontend -----------------------------------------------------
# mono 16kHz, exactly 30s (480000 samples), f32 -1..1 (truncate / zero-pad)
func whisper_pcm [ c: AudioClip ] -> @f32
    out9 : new f32 [ 480000 ]
    ch : i32 [ c.channels ]
    ratio : f64 [ f64[ c.rate ] / 16000.0 ]
    n16 : i64 [ i64[ f64[ c.frames ] / ratio ] ]
    if [ n16 > 480000 ] n16 = 480000
    den : f32 [ f32[ ch ] * 32768.0f ]
    for [ i: i64 0, i < n16, i += 1 ]
        sp : f64 [ f64[ i ] * ratio ]
        i0 : i64 [ i64[ sp ] ]
        fr : f32 [ f32[ sp - f64[ i0 ] ] ]
        i1 : i64 [ i0 + 1 ]
        if [ i1 >= c.frames ] i1 = c.frames - 1
        a9 : f32 [ 0.0 ]
        b9 : f32 [ 0.0 ]
        for [ c2: i32 0, c2 < ch, c2 += 1 ]
            a9 += f32[ c.pcm[ i0 * ch + c2 ] ]
            b9 += f32[ c.pcm[ i1 * ch + c2 ] ]
        va : f32 [ a9 / den ]
        vb : f32 [ b9 / den ]
        out9[i] = va + (vb - va) * fr
    return out9

# slaney hz->mel / mel->hz (librosa htk=false)
func hz_mel [ f: f64 ] -> f64
    if [ f < 1000.0 ] return f * 3.0 / 200.0
    return 15.0 + log[ f / 1000.0 ] * 27.0 / 1.8562979903656263
func mel_hz [ m: f64 ] -> f64
    if [ m < 15.0 ] return 200.0 * m / 3.0
    return 1000.0 * exp[ 1.8562979903656263 / 27.0 * (m - 15.0) ]

# whisper log-mel: n_fft 400 hop 160 periodic hann, center reflect pad,
# 80 slaney mels 0..8kHz, log10, clamp to max-8, then (x+4)/4.
# 400-pt DFT done directly (not radix-2) with mod-400 angle tables so
# bin frequencies match whisper exactly. returns 3000 x 80 tensor.
func whisper_mel [ c: AudioClip ] -> tensor
    pcm9 : whisper_pcm[ c ]
    nfft : i32 [ 400 ]
    nb   : i32 [ 201 ]
    hop9 : i32 [ 160 ]
    # trim to the real audio + 0.5s tail (whisper pads to 30s, but the
    # encoder handles shorter windows — 5x less work on a 6s clip)
    ratio9 : f64 [ f64[ c.rate ] / 16000.0 ]
    n16r : i64 [ i64[ f64[ c.frames ] / ratio9 ] ]
    if [ n16r > 480000 ] n16r = 480000
    tt : i32 [ i32[ n16r / 160 ] + 50 ]
    tt = ((tt + 1) / 2) * 2
    if [ tt > 3000 ] tt = 3000
    if [ tt < 100 ] tt = 100
    win9 : new f32 [ 400 ]
    for [ i: i32 0, i < nfft, i += 1 ]
        win9[i] = f32[ 0.5 - 0.5 * cos[ 6.28318530717958648 * f64[ i ] / 400.0 ] ]
    # angle = 2π/400 * ((b*i) mod 400) — exact for all b,i. expanded to
    # contiguous per-bin rows so the dot products run 8-wide
    cs9 : new f32 [ 400 ]
    sn9 : new f32 [ 400 ]
    for [ i: i32 0, i < nfft, i += 1 ]
        ang : f64 [ 6.28318530717958648 * f64[ i ] / 400.0 ]
        cs9[i] = f32[ cos[ ang ] ]
        sn9[i] = f32[ sin[ ang ] ]
    tabn : i32 [ 80400 ]
    csf : new f32 [ tabn ]
    snf : new f32 [ tabn ]
    for [ b: i32 0, b < nb, b += 1 ]
        for [ i: i32 0, i < nfft, i += 1 ]
            mi : i32 [ (b * i) % 400 ]
            csf[b * 400 + i] = cs9[mi]
            snf[b * 400 + i] = sn9[mi]
    # slaney filterbank: 82 mel points 0..8kHz, triangles over bins b*40Hz
    mhi : f64 [ hz_mel[ 8000.0 ] ]
    pts : new f64 [ 82 ]
    for [ k: i32 0, k < 82, k += 1 ]
        pts[k] = mel_hz[ mhi * f64[ k ] / 81.0 ]
    mw : new f32 [ 16080 ]
    for [ m: i32 0, m < 80, m += 1 ]
        f0 : f64 [ pts[m] ]
        f1 : f64 [ pts[m + 1] ]
        f2 : f64 [ pts[m + 2] ]
        norm : f64 [ 2.0 / (f2 - f0) ]
        for [ b: i32 0, b < nb, b += 1 ]
            fb : f64 [ f64[ b ] * 40.0 ]
            lo : f64 [ (fb - f0) / (f1 - f0) ]
            hi : f64 [ (f2 - fb) / (f2 - f1) ]
            w9 : f64 [ (lo < hi) ? lo : hi ]
            if [ w9 < 0.0 ] w9 = 0.0
            mw[m * nb + b] = f32[ w9 * norm ]
    mdv : new i64 [ 2 ]
    mdv[0] = tt
    mdv[1] = 80
    msh : shape.shape_from[ 2, mdv ]
    mel_t : tensor [ tensor_shape: msh ]
    fr9 : new f32 [ 400 ]
    pw  : new f32 [ 201 ]
    acc8r : new f32 [ 8 ]
    acc8i : new f32 [ 8 ]
    mmax : f32 [ -1.0e30f ]
    for [ t: i32 0, t < tt, t += 1 ]
        base : i32 [ t * hop9 - 200 ]
        for [ i: i32 0, i < nfft, i += 1 ]
            j : i32 [ base + i ]
            if [ j < 0 ] j = 0 - j
            if [ j >= 480000 ] j = 959998 - j
            fr9[i] = pcm9[j] * win9[i]
        for [ b: i32 0, b < nb, b += 1 ]
            brow : i32 [ b * 400 ]
            # self-contained blocks: accumulate via memory (ymm regs do
            # not survive between asm blocks under -O2)
            for [ z2: i32 0, z2 < 8, z2 += 1 ]
                acc8r[z2] = 0.0f
                acc8i[z2] = 0.0f
            for [ c8: i32 0, c8 < 400, c8 += 8 ]
                f_off : i64 [ c8 * 4 ]
                t_off : i64 [ (brow + c8) * 4 ]
                asm x86_64
                    vmovups ymm0, ymmword ptr [acc8r]
                    vmovups ymm5, ymmword ptr [acc8i]
                    vmovups ymm1, ymmword ptr [fr9 + f_off]
                    vmovups ymm2, ymmword ptr [csf + t_off]
                    vfmadd231ps ymm0, ymm1, ymm2
                    vmovups ymm3, ymmword ptr [snf + t_off]
                    vfmadd231ps ymm5, ymm1, ymm3
                    vmovups ymmword ptr [acc8r], ymm0
                    vmovups ymmword ptr [acc8i], ymm5
            re9 : f32 [ acc8r[0] + acc8r[1] + acc8r[2] + acc8r[3] + acc8r[4] + acc8r[5] + acc8r[6] + acc8r[7] ]
            im9 : f32 [ 0.0f - (acc8i[0] + acc8i[1] + acc8i[2] + acc8i[3] + acc8i[4] + acc8i[5] + acc8i[6] + acc8i[7]) ]
            pw[b] = re9 * re9 + im9 * im9
        for [ m: i32 0, m < 80, m += 1 ]
            e9 : f32 [ 0.0 ]
            for [ b: i32 0, b < nb, b += 1 ]
                e9 += mw[m * nb + b] * pw[b]
            if [ e9 < 1.0e-10f ] e9 = 1.0e-10f
            l9 : f32 [ f32[ log[ f64[ e9 ] ] / 2.30258509299404568 ] ]
            mel_t.floats[t * 80 + m] = l9
            if [ l9 > mmax ] mmax = l9
    floor9 : f32 [ mmax - 8.0f ]
    ntot9 : i64 [ i64[ tt ] * 80 ]
    for [ i: i64 0, i < ntot9, i += 1 ]
        v9 : f32 [ mel_t.floats[i] ]
        if [ v9 < floor9 ] v9 = floor9
        mel_t.floats[i] = (v9 + 4.0f) / 4.0f
    return mel_t

# render the 3000x80 mel as a heat map png: time right, low mel at
# bottom, each mel row 3px tall (3000 x 240)
func mel_png [ m: tensor, out2: path ] -> bool
    w2 : i32 [ i32[ m.tensor_shape[0] ] ]
    h2 : i32 [ 240 ]
    img3 : Image [ width: w2, height: h2, format: Pixel.rgba8, channels: 4 ]
    pd : @u8 [ img3.vdata[] ]
    for [ y: i32 0, y < h2, y += 1 ]
        mrow : i32 [ 79 - (y / 3) ]
        for [ x: i32 0, x < w2, x += 1 ]
            tv : f32 [ m.floats[x * 80 + mrow] ]
            if [ tv < 0.0 ] tv = 0.0
            if [ tv > 1.0 ] tv = 1.0
            rgb : i32 [ heat[ tv ] ]
            di : i64 [ (i64[ y ] * w2 + x) * 4 ]
            pd[ di ]     = u8[ rgb / 65536 ]
            pd[ di + 1 ] = u8[ (rgb / 256) % 256 ]
            pd[ di + 2 ] = u8[ rgb % 256 ]
            pd[ di + 3 ] = 255
    img3.png[ out2 ]
    return true

# LibriSpeech + MFA alignments -> our spectral set, BORN ANNOTATED:
# reads {root}/{subset}-align.txt (one line per utterance: the
# alignment file path, utt id, "comma,words", "comma,end,times" —
# "" entries are silences), decodes the wav beside the alignment
# file, writes {split}_{i}.png + .agi carrying wspans (start end per
# word, in columns) — full word boundaries, no clicking, no CTC-only
func libri_translate [ root: path, subset: string, outdir: path, limit: i32 ] -> i32
    Au.auto_free[ true ]
    root.hold[]
    subset.hold[]
    outdir.hold[]
    idxp : path '{root}/{subset}-align.txt'
    s : (idxp.load[ typeid[ string ], null ] to string)
    if [ !s ]
        puts 'libri_translate: cannot read {idxp} (run the extract step)'
        return 0
    mkdir[ '{outdir}', 493 ]
    lines : array string [ s.split[ '\n' ] ]
    lines.hold[]
    n9 : i32 [ 0 ]
    for [ li: i32 0, li < lines.count, li += 1 ]
        ln : lines[ li ]
        if [ !ln || ln.count < 8 ] continue
        # fields: alignpath uttid "words" "times"
        q1 : num [ ln.index_of[ '"' ] ]
        if [ q1 < 0 ] continue
        head9 : ln.mid[ 0, i32[ q1 ] ]
        parts : array string [ head9.split[ ' ' ] ]
        if [ parts.count < 2 ] continue
        apath : parts[ 0 ]
        uttid : parts[ 1 ]
        rest9 : ln.mid[ i32[ q1 ] + 1, ln.count - i32[ q1 ] - 1 ]
        q2 : num [ rest9.index_of[ '"' ] ]
        if [ q2 < 0 ] continue
        wstr : rest9.mid[ 0, i32[ q2 ] ]
        rest8 : rest9.mid[ i32[ q2 ] + 1, rest9.count - i32[ q2 ] - 1 ]
        q3 : num [ rest8.index_of[ '"' ] ]
        if [ q3 < 0 ] continue
        rest7 : rest8.mid[ i32[ q3 ] + 1, rest8.count - i32[ q3 ] - 1 ]
        q4 : num [ rest7.index_of[ '"' ] ]
        if [ q4 < 0 ] continue
        tstr : rest7.mid[ 0, i32[ q4 ] ]
        # wav lives beside the alignment file
        sl9 : num [ apath.rindex_of[ '/' ] ]
        if [ sl9 < 0 ] continue
        adir : apath.mid[ 0, i32[ sl9 ] ]
        wp : path '{root}/{adir}/{uttid}.wav'
        c : caf_load[ wp ]
        if [ !c ] continue
        if [ c.frames < 4096 ] continue
        hop9 : i64 [ i64[ c.rate ] * 2048 / 48000 ]
        if [ hop9 < 1 ] hop9 = 1
        w9 : i32 [ i32[ (c.frames - 2048) / hop9 ] ]
        if [ w9 < 16 ] continue
        if [ w9 > 4096 ]
            Au.auto_free[ false ]
            continue
        op : path '{outdir}/{subset}_{n9}.png'
        act9 : new f32 [ w9 ]
        if [ !spectrograph[ c, op, w9, 64, 150.0, 8000.0, true, act9 ] ]
            Au.auto_free[ false ]
            continue
        # words + end times -> per-word column spans; "" = silence
        wlist : array string [ wstr.split[ ',' ] ]
        tlist : array string [ tstr.split[ ',' ] ]
        sent : string ''
        wsp : string ''
        t0 : f32 [ 0.0 ]
        nw9 : i32 [ 0 ]
        for [ wi9: i32 0, wi9 < wlist.count, wi9 += 1 ]
            if [ wi9 >= tlist.count ] break
            te : tlist[ wi9 ]
            t1 : f32 [ te.real_value[] ]
            wd : wlist[ wi9 ]
            if [ wd && wd.count > 0 ]
                c0 : i32 [ i32[ t0 * 23.4375 ] ]
                c1 : i32 [ i32[ t1 * 23.4375 ] ]
                if [ c1 > w9 ] c1 = w9
                sent = '{sent}{wd} '
                wsp = '{wsp}{c0} {c1} '
                nw9 += 1
            t0 = t1
        if [ nw9 < 1 ]
            Au.auto_free[ false ]
            continue
        dur : f32 [ f32[ c.frames ] / f32[ c.rate ] ]
        body : string 'image: {subset}_{n9}.png\nsentence: {sent}\nspeaker: {uttid}\nrate: {c.rate}\nframes: {c.frames}\nduration: {dur}\nsource: {wp}\nwspans: {wsp}\n'
        ag : path '{outdir}/{subset}_{n9}.agi'
        ag.save[ body, null ]
        n9 += 1
        if [ (n9 % 100) == 0 ] puts 'libri_translate: {n9} translated'
        Au.auto_free[ false ]
        if [ limit > 0 && n9 >= limit ] break
    puts 'libri_translate: {root} ({subset}) -> {outdir}: {n9} clips'
    return n9

# schema-translate a Common Voice dir into our own spectral set:
# {split}.tsv + en_{split}_0/*.mp3 -> {outdir}/{split}_{i}.png
# (GRAY model input: 64 rows 150Hz..8kHz, one column per live-stream
# window) + {split}_{i}.agi (sentence, speaker, age/gender/accents,
# rate/frames/duration)
func cv_translate [ dataset: path, split: string, outdir: path, limit: i32 ] -> i32
    # adopt everything alive now (the half-initialized app, args,
    # rows) so the per-clip sweep below only frees loop garbage —
    # the same true-then-false pattern trinity's run loop uses
    Au.auto_free[ true ]
    dataset.hold[]
    split.hold[]
    outdir.hold[]
    tsvp : path '{dataset}/{split}.tsv'
    s : (tsvp.load[ typeid[ string ], null ] to string)
    if [ !s ]
        puts 'cv_translate: cannot read {tsvp}'
        return 0
    mkdir[ '{outdir}', 493 ]
    lines : array string [ s.split[ '\n' ] ]
    lines.hold[]
    n9 : i32 [ 0 ]
    for [ li: i32 1, li < lines.count, li += 1 ]
        ln : lines[ li ]
        if [ !ln || ln.count < 8 ] continue
        colsx : array string [ ln.split[ '\t' ] ]
        if [ colsx.count < 12 ] continue
        fname : colsx[ 1 ]
        sent  : colsx[ 3 ]
        spk0  : colsx[ 0 ]
        age9  : colsx[ 7 ]
        gen9  : colsx[ 8 ]
        acc9  : colsx[ 9 ]
        mp : path '{dataset}/en_{split}_0/{fname}'
        c : caf_load[ mp ]
        if [ !c ] continue
        if [ c.frames < 4096 ] continue
        # the LIVE cadence: one 2048 window per column at the 48k
        # clock — training inputs generate exactly like the stream
        hop9 : i64 [ i64[ c.rate ] * 2048 / 48000 ]
        if [ hop9 < 1 ] hop9 = 1
        w9 : i32 [ i32[ (c.frames - 2048) / hop9 ] ]
        if [ w9 < 16 ] continue
        if [ w9 > 4096 ] w9 = 4096
        op : path '{outdir}/{split}_{n9}.png'
        act9 : new f32 [ w9 ]
        if [ !spectrograph[ c, op, w9, 64, 150.0, 8000.0, true, act9 ] ] continue
        # spectra AS ANNOTATOR: the live tracker's envelope (fast
        # attack, slow release) segments sustained-energy sections —
        # when section count matches word count, the trainer gets
        # full word boundaries; otherwise it falls back to CTC.
        # threshold ADAPTS per clip: recording levels vary 2x, so it
        # sits 35% up this clip's own floor-to-peak envelope range
        emt9 : new f32 [ w9 ]
        ema9 : f32 [ 0.0 ]
        elo9 : f32 [ 1.0 ]
        ehi9 : f32 [ 0.0 ]
        for [ x8: i32 0, x8 < w9, x8 += 1 ]
            e8 : f32 [ act9[ x8 ] ]
            if [ e8 > ema9 ]
                ema9 = ema9 * 0.6 + e8 * 0.4
            el
                ema9 = ema9 * 0.88 + e8 * 0.12
            emt9[ x8 ] = ema9
            if [ ema9 < elo9 ] elo9 = ema9
            if [ ema9 > ehi9 ] ehi9 = ema9
        thr9 : f32 [ elo9 + (ehi9 - elo9) * 0.35 ]
        sect9 : string [ '' ]
        nsec9 : i32 [ 0 ]
        sx9 : i32 [ -1 ]
        for [ x8: i32 0, x8 < w9, x8 += 1 ]
            on8 : bool [ emt9[ x8 ] > thr9 ]
            if [ on8 && sx9 < 0 ] sx9 = x8
            if [ !on8 && sx9 >= 0 ]
                sect9 = '{sect9}{sx9} {x8} '
                nsec9 += 1
                sx9 = -1
        if [ sx9 >= 0 ]
            sect9 = '{sect9}{sx9} {w9} '
            nsec9 += 1
        dur : f32 [ f32[ c.frames ] / f32[ c.rate ] ]
        spk : spk0.mid[ 0, 16 ]
        body : string 'image: {split}_{n9}.png\nsentence: {sent}\nspeaker: {spk}\nage: {age9}\ngender: {gen9}\naccents: {acc9}\nrate: {c.rate}\nframes: {c.frames}\nduration: {dur}\nsource: {mp}\nsections: {sect9}\n'
        ag : path '{outdir}/{split}_{n9}.agi'
        ag.save[ body, null ]
        n9 += 1
        if [ (n9 % 100) == 0 ] puts 'cv_translate: {n9} translated'
        # per-clip sweep: pcm, file buffers and images free here — a
        # CLI loop never reaches trinity's per-frame auto_free
        Au.auto_free[ false ]
        if [ limit > 0 && n9 >= limit ] break
    puts 'cv_translate: {dataset} ({split}) -> {outdir}: {n9} clips'
    return n9

# coverage: AudioOut plays Ode to Joy (Beethoven, public domain).
# sustained writes far exceed the 4-buffer ring, so the blocking
# pace path is exercised throughout.
coverage test
    intern out   : AudioOut
    intern phase : f64

    # one note: sine + 2 harmonics, 10ms attack / 40ms release
    func tone [ freq: f64, msec: i32 ] -> none
        step  : f64 [ freq * 6.28318530718 / 48000.0 ]
        total : i32 [ 48 * msec ]
        done  : i32 [ 0 ]
        for [ done < total ]
            c : i32 [ ((total - done) > 1024) ? 1024 : (total - done) ]
            for [ i: i32 0, i < c, i += 1 ]
                t   : i32 [ done + i ]
                env : f64 [ 1.0 ]
                if [ t < 480 ] env = f64[ t ] / 480.0
                rem : i32 [ total - t ]
                if [ rem < 1920 ] env = env * f64[ rem ] / 1920.0
                s : f64 [ sin[ phase ] + 0.35 * sin[ phase * 2.0 ] + 0.15 * sin[ phase * 3.0 ] ]
                v : i16 [ i16[ s * env * 5200.0 ] ]
                out.buffer[ i * 2 ]     = v
                out.buffer[ i * 2 + 1 ] = v
                phase += step
            out.write[ c ]
            done += c

    func run[] -> Au
        out = AudioOut [ sample_rate: 48000, channels: 2, buffer_size: 1024 ]
        if [ ! out.open[] ]
            puts 'spectra test: audio device unavailable'
            return false
        if [ ! out.active ]
            puts 'spectra test: open ok but active not set'
            return false
        # melody as semitones from C4; time in half-beats (250ms, 120 bpm)
        st : array i32 [ 4,4,5,7, 7,5,4,2, 0,0,2,4, 4,2,2,  4,4,5,7, 7,5,4,2, 0,0,2,4, 2,0,0 ]
        bt : array i32 [ 2,2,2,2, 2,2,2,2, 2,2,2,2, 3,1,4,  2,2,2,2, 2,2,2,2, 2,2,2,2, 3,1,4 ]
        for [ n: i32 0, n < 30, n += 1 ]
            f : f64 [ 261.63 * pow[ 2.0, f64[ st[n] ] / 12.0 ] ]
            tone[ f, bt[n] * 250 ]
        out.close
        puts 'spectra test: AudioOut ok'
        return true


# a word read out of the stream: a column span + its text, drawn in
# the label lane under the waterfall with its span highlighted above
class SpectWord
    public x0   : i32
    public x1   : i32
    public text : string

# time-stretch WITHOUT pitch change (youtube 0.5x): SOLA — grains
# overlap-added at a slower hop, each aligned to the output tail by
# a short cross-correlation search. mono only; stereo returns as-is
func stretch_clip [ c: AudioClip, factor: f32 ] -> AudioClip
    if [ !c || c.channels != 1 ] return c
    n : i32 [ c.rate * 30 / 1000 ]
    ov : i32 [ n / 2 ]
    hopo : i32 [ n - ov ]
    hopi : f32 [ f32[ hopo ] / factor ]
    srch : i32 [ c.rate * 8 / 1000 ]
    ocap : i32 [ i32[ f32[ c.frames ] * factor ] + n * 2 ]
    outp : new i16 [ ocap ]
    for [ i: i32 0, i < n, i += 1 ]
        outp[ i ] = c.pcm[ i ]
    wpos : i32 [ hopo ]
    ipos : f32 [ 0.0 ]
    for [ true ]
        ipos += hopi
        base : i32 [ i32[ ipos ] ]
        if [ i64[ base + n + srch + 1 ] >= c.frames ] break
        if [ wpos + n >= ocap ] break
        if [ base - srch < 0 ] continue
        # best alignment of the grain against the written tail
        best : i32 [ base ]
        bsc : f32 [ -1e30 ]
        for [ off: i32 0 - srch, off <= srch, off += 2 ]
            sc : f32 [ 0.0 ]
            for [ k: i32 0, k < ov, k += 4 ]
                sc += f32[ outp[ wpos + k ] ] * f32[ c.pcm[ base + off + k ] ]
            if [ sc > bsc ]
                bsc = sc
                best = base + off
        # crossfade the overlap, copy the fresh half
        for [ k2: i32 0, k2 < ov, k2 += 1 ]
            t2 : f32 [ f32[ k2 ] / f32[ ov ] ]
            v2 : f32 [ f32[ outp[ wpos + k2 ] ] * (1.0 - t2) + f32[ c.pcm[ best + k2 ] ] * t2 ]
            outp[ wpos + k2 ] = i16[ v2 ]
        for [ k3: i32 ov, k3 < n, k3 += 1 ]
            outp[ wpos + k3 ] = c.pcm[ best + k3 ]
        wpos += hopo
    s2 : AudioClip [ rate: c.rate, channels: 1, frames: i64[ wpos + ov ] ]
    s2.pcm = outp
    return s2

# run the module by itself and it presents itself; importers still
# dlopen the .so. CLI modes do their work and exit; a bare run opens
# the ai whisper model class, aliased clear of the --whisper flag prop
alias WhisperNet: whisper

# one live transcription: raw mono 48k utterance in, text out. runs on
# its own pthread so the render loop never blocks; the app polls done.
class WhisperJob
    public model : WhisperNet
    public pcm  : @i16
    public n    : i64
    public done : bool
    public text : string
    # the utterance's sweep-column span (st_abs units) for placement
    public c0   : i64
    public c1   : i64
    # gpu path with a compute queue: the worker encodes AND decodes; the
    # render thread only spawns. enc pre-set = legacy render-thread encode
    public enc  : tensor
    public gpu  : whisper_vk

func spectra_whisper_thread [ arg: handle ] -> handle
    j : (arg to WhisperJob)
    enc : j.enc
    if [ !enc ]
        c : AudioClip [ rate: 48000, channels: 1, frames: j.n, pcm: j.pcm ]
        m : whisper_mel[ c ]
        mel_png[ m, path '/tmp/live-mel.png' ]
        if [ j.gpu ]
            enc = j.gpu.encode[ m ]
        el
            enc = j.model.encode[ m ]
    ids : j.model.transcribe[ enc, 96 ]
    j.text = j.model.text_for[ ids ]
    j.done = true
    return null

# a window with a live mic spectrum when a capture device is present
# ---- dictation: a flat C-callable surface -----------------------------------
# the capture loop used to live inside spectra's own app draw[], so it only ever
# worked when spectra WAS the app. these are plain module functions: no trinity,
# no element, no render loop — so the mic can be owned by whatever process
# should outlive the app being dictated into (silver-host, not the app).
struct DictState
    cap : spectra
    ok  : bool
    lvl : f32
    txt : string
    # the same live-whisper machine the spectra app runs: 32s ring,
    # level-gated utterance segmentation, worker-thread transcribe
    net    : WhisperNet
    gpu    : whisper_vk
    gpu_no : bool
    # worker-thread gpu encode verified; false = encode on the caller
    gpu_thr : bool
    raw    : @i16
    wr    : i64
    state : i32
    start : i64
    act   : i64
    quiet : i32
    job   : WhisperJob
    tid   : u64
    polls : i32
    # cancel: discard everything this take produced (incl. a late job)
    drop    : bool
    # this take's audio has already been sent to whisper (once, on stop)
    flushed : bool
    # rolling index for the per-utterance .wav dumps
    wavn    : i32

intern dict : DictState

# 0 = capturing, non-zero = no device. the record click loads EVERYTHING:
# capture opens and whisper-small comes up right here, first time.
# the device stays OPEN across takes — closing then reopening 'default'
# fails intermittently (the second take never went live), so stop ends the
# take, not the stream; a start just re-arms the segmenter.
func dictation_start [] -> i32
    if [ !dict.cap ]
        dict.cap = spectra [ size: 2048, sample_rate: 48000, device: 'default' ]
        dict.cap.hold[]
    if [ !dict.ok ]
        dict.ok = dict.cap.open[]
    if [ !dict.ok ]
        puts 'dictation: no capture device'
        return 1
    if [ !dict.net ]
        d9 : path.path_storage[ 'spectra' ]
        wm : path '{d9}/whisper-small.safetensors'
        if [ wm.exists[] ]
            puts 'dictation: loading whisper-small…'
            n8 : WhisperNet [ src: wm ]
            if [ n8.valid ]
                n8.hold[]
                dict.net = n8
                dict.raw = new i16 [ 1536000 ]
                r9 : (dict.raw to Au)
                r9.hold[]
                puts 'dictation: whisper ready — speak; a pause transcribes'
            el
                puts 'dictation: whisper load failed — capture only'
        el
            puts 'dictation: no whisper weights — capture only'
    # HARD reset — every enable is a clean slate. a stale job pointer or a
    # stuck quiet counter from the previous take blocked segmentation (poll
    # gates on !dict.job), which is why the mic went dead after take one.
    # drop ALSA's queued backlog so this take starts from live audio
    dict.cap.drain[]
    dict.job     = null
    dict.wr      = 0
    dict.state   = 0
    dict.quiet   = 0
    dict.drop    = false
    dict.flushed = false
    dict.txt     = ''
    puts 'dictation: capturing (fresh, backlog dropped)'
    return 0

# end the TAKE — the device stays open (see dictation_start). the flush path
# reads dict.ok to force the final utterance, so it is cleared by the caller
# after the flush, not here.
func dictation_stop [] -> none
    # leave dict.state alone — dictation_flush forces the in-progress
    # utterance (state==1) into the final job
    dict.lvl = 0.0
    puts 'dictation: take ended'

# real teardown — close the mic (app exit / cancel keeps device for reuse,
# so only call when the recorder is truly done)
func dictation_release [] -> none
    if [ !dict.ok ] return
    dict.cap.close[]
    dict.ok = false
    puts 'dictation: released'

# pull one buffer off the device. true when a frame was read — the caller may be
# a render loop or a plain thread; nothing here needs a window.
func dictation_poll [] -> bool
    if [ !dict.ok ] return false
    if [ !dict.cap.capture[] ] return false
    # band energy — the spectra app's PROVEN detector: log-spaced bands
    # 150Hz..8k summed, /24 per band, fast attack / slow release EMA
    fmin : f32 [ 150.0 ]
    fmax : f32 [ 8000.0 ]
    nyq  : f32 [ f32[ dict.cap.sample_rate ] * 0.5 ]
    if [ fmax > nyq ] fmax = nyq
    lr9   : f32 [ log[ fmax / fmin ] ]
    half2 : i32 [ dict.cap.size / 2 ]
    nb9   : i32 [ 96 ]
    en9   : f32 [ 0.0 ]
    for [ b: i32 0, b < nb9, b += 1 ]
        t9 : f32 [ f32[ nb9 - 1 - b ] / f32[ nb9 - 1 ] ]
        fq : f32 [ fmin * exp[ t9 * lr9 ] ]
        fb : f32 [ fq * f32[ dict.cap.size ] / f32[ dict.cap.sample_rate ] ]
        bi : i32 [ i32[ fb ] ]
        if [ bi > half2 - 2 ] bi = half2 - 2
        fr : f32 [ fb - f32[ bi ] ]
        m0 : f32 [ dict.cap.bins[ bi ] ]
        m1 : f32 [ dict.cap.bins[ bi + 1 ] ]
        en9 += m0 + (m1 - m0) * fr
    en9 = en9 / (f32[ nb9 ] * 24.0)
    if [ en9 > 1.0 ] en9 = 1.0
    if [ en9 > dict.lvl ]
        dict.lvl = dict.lvl * 0.6 + en9 * 0.4
    el
        dict.lvl = dict.lvl * 0.88 + en9 * 0.12
    # TAKE model: while the mic is on, only BUFFER audio — no per-pause
    # transcription. the whole take transcribes ONCE on stop (dictation_flush),
    # so nothing overlaps/doubles and nothing trails behind. cap 30s @ 48k.
    if [ dict.net && dict.raw ]
        ns5 : i64 [ dict.cap.size ]
        for [ i5: i64 0, i5 < ns5, i5 += 1 ]
            w2 : i64 [ dict.wr + i5 ]
            if [ w2 < 1440000 ] dict.raw[ w2 ] = dict.cap.buf[i5]
        dict.wr += ns5
        if [ dict.wr > 1440000 ] dict.wr = 1440000
    return true

# spawn a whisper job over raw[a..b], on the GPU worker exactly like the demo
func dict_spawn [ a: i64, b: i64 ]
    e5 : i64 [ b ]
    if [ e5 > dict.wr ] e5 = dict.wr
    n5 : i64 [ e5 - a ]
    if [ n5 <= 24000 ] return
    # 1s of trailing SILENCE (whisper needs speech-then-silence to emit
    # end-of-text; a take that ends mid-word otherwise loops the last phrase)
    pad5 : i64 [ 48000 ]
    tot5 : i64 [ n5 + pad5 ]
    buf5 : new i16 [ tot5 ]
    b9 : (buf5 to Au)
    b9.hold[]
    for [ i6: i64 0, i6 < n5, i6 += 1 ]
        buf5[i6] = dict.raw[(a + i6) % 1536000]
    for [ i7: i64 n5, i7 < tot5, i7 += 1 ]
        buf5[i7] = 0
    # dump the padded clip to a .wav so the input can be verified
    dict_write_wav[ buf5, tot5 ]
    j5 : WhisperJob [ model: dict.net, pcm: buf5, n: tot5 ]
    j5.hold[]
    if [ dict.gpu && dict.gpu.threaded[] ] j5.gpu = dict.gpu
    dict.job = j5
    puts 'dictation: transcribing {n5 / 48000}s speech + 1s pad…'
    pthread_create[ @dict.tid, null, @spectra_whisper_thread, (j5 to handle) ]
    pthread_detach[ dict.tid ]

# dump a mono 48k i16 utterance to /tmp/dict-<n>.wav for validation
func dict_write_wav [ pcm: @i16, n: i64 ]
    p : string '/tmp/dict-{dict.wavn}.wav'
    dict.wavn += 1
    fp : @FILE [ fopen[ p.chars, 'wb' ] ]
    if [ !fp ] return
    rate  : i32 [ 48000 ]
    bytes : i32 [ i32[ n ] * 2 ]
    hdr   : local i32 [ 11 ]
    hdr[0] = 1179011410           # 'RIFF'
    hdr[1] = 36 + bytes
    hdr[2] = 1163280727           # 'WAVE'
    hdr[3] = 544501094            # 'fmt '
    hdr[4] = 16
    hdr[5] = 65537                # PCM(1) | channels(1)<<16
    hdr[6] = rate
    hdr[7] = rate * 2             # byte rate (mono, 2 bytes/sample)
    hdr[8] = 131074              # blockalign(2) | bits(16)<<16
    hdr[9] = 1635017060           # 'data'
    hdr[10] = bytes
    fwrite[ @hdr[0], 1, 44, fp ]
    fwrite[ pcm, 1, bytes, fp ]
    fclose[ fp ]
    puts 'dictation: wrote {p} ({n} samples)'

# remove whisper's (music)/[BLANK_AUDIO] annotation spans from anywhere
func strip_annotations [ s: string ] -> string
    if [ !s ] return s
    out : string ''
    depth : i32 [ 0 ]
    for [ i: i32 0, i < i32[ s.count ], i += 1 ]
        c : i8 [ s.chars[ i ] ]
        if [ c == '(' || c == '[' ]
            depth += 1
        el [ c == ')' || c == ']' ]
            if [ depth > 0 ] depth -= 1
        el [ depth == 0 ]
            ch : s.mid[ i, 1 ]
            out = '{out}{ch}'
    return out.trim[]

# collect a finished utterance, APPEND its text to the take
# collect the finished transcription — the take is exactly what whisper
# returned (one pass over the whole recording), annotations stripped.
func dictation_harvest []
    if [ !dict.job || !dict.job.done ] return
    t8 : string dict.job.text
    puts 'dictation harvest: raw "{t8}" drop={dict.drop}'
    if [ t8 && t8.count > 0 && !dict.drop ]
        clean : string strip_annotations[ t8 ]
        if [ clean && clean.count > 0 ]
            puts 'dictation:{clean}'
            dict.txt = clean
            dict.txt.hold[]
    dict.job = null

# mic OFF: transcribe the WHOLE take in ONE pass, then wait for it.
# true once the transcript is ready. flushed guards against re-spawning.
func dictation_flush [] -> bool
    if [ dict.job ]
        dictation_harvest[]
        return (dict.job == null)
    if [ dict.flushed ] return true
    dict.flushed = true
    dict_spawn[ 0, dict.wr ]
    return (dict.job == null)

# esc: throw the whole take away — no transcription, no send
func dictation_cancel []
    dict.drop    = true
    dict.txt     = ''
    dict.wr      = 0
    dict.flushed = true
    dictation_stop[]
    puts 'dictation: cancelled'

func dictation_level [] -> f32
    return dict.lvl

# what was heard so far — the host shows this for sign-off before it is sent
func dictation_text [] -> string
    return dict.txt

# build the gpu encoder EXACTLY as the spectra app does: whisper_vk from the
# screen Canvas's vk, use it if valid. no parity gate, no fallback games.
func dictation_gpu [ cv: Canvas ] -> bool
    if [ !dict.net || !cv ] return false
    if [ dict.gpu ] return true
    if [ dict.gpu_no ] return false
    puts 'dictation: building gpu pipelines…'
    g0 : whisper_vk [ model: dict.net, vk: cv.vk, win: cv.w ]
    if [ !g0.valid ]
        puts 'dictation: gpu unavailable — cpu encoder'
        dict.gpu_no = true
        return false
    g0.hold[]
    dict.gpu = g0
    dict.gpu_thr = g0.threaded[]
    puts 'dictation: gpu encoder ready (threaded {dict.gpu_thr})'
    return true

# claim the transcript: returns the accumulated text and clears it, so the
# caller (orbiter) types each utterance into the agent exactly once
func dictation_take [] -> string
    t : dict.txt
    if [ !t || t.count == 0 ] return null
    dict.txt = ''
    return t

# ---- tts: a flat C-callable surface (sherpa-onnx, kokoro voices) ------------
# same single-owner shape as dictation_*: plain module functions, no element,
# so whatever process should speak (orbiter) owns the engine and the device.
struct TtsState
    eng : @SherpaOnnxOfflineTts
    mix : AudioMixer
    ok  : bool

intern tts : TtsState

# dir holds model.onnx, voices.bin, tokens.txt, espeak-ng-data.
# 0 = ready; 1 = no model at dir; 2 = engine failed
func tts_init [ dir: cstr ] -> i32
    if [ tts.ok ] return 0
    mdl : string '{dir}/model.onnx'
    vcs : string '{dir}/voices.bin'
    tks : string '{dir}/tokens.txt'
    dd  : string '{dir}/espeak-ng-data'
    mp  : path '{mdl}'
    if [ !mp.exists[] ]
        puts 'tts: no model at {mdl}'
        return 1
    prov : string 'cpu'
    cfg : SherpaOnnxOfflineTtsConfig [
        model: SherpaOnnxOfflineTtsModelConfig [
            kokoro: SherpaOnnxOfflineTtsKokoroModelConfig [
                model: mdl.chars, voices: vcs.chars, tokens: tks.chars,
                data_dir: dd.chars, length_scale: 1.0 ],
            num_threads: 4, provider: prov.chars ],
        max_num_sentences: 1 ]
    tts.eng = SherpaOnnxCreateOfflineTts[ @cfg ]
    if [ !tts.eng ]
        puts 'tts: engine failed'
        return 2
    puts 'tts: ready ({dir})'
    tts.ok = true
    return 0

func tts_ready [] -> bool
    return tts.ok

# synthesize and play. generation blocks the caller (kokoro runs faster than
# realtime on cpu); playback rides the mixer thread.
func tts_say [ text: cstr, sid: i32, speed: f32 ] -> i32
    if [ !tts.ok ] return 1
    gc : SherpaOnnxGenerationConfig [ silence_scale: 0.2, speed: speed, sid: sid ]
    au2 : SherpaOnnxOfflineTtsGenerateWithConfig[ tts.eng, text, @gc, null, null ]
    if [ !au2 ] return 2
    n : i32 [ au2.n ]
    if [ n <= 0 ]
        SherpaOnnxDestroyOfflineTtsGeneratedAudio[ au2 ]
        return 2
    c : AudioClip [ rate: au2.sample_rate, channels: 1, frames: i64[ n ] ]
    c.pcm = new i16 [ n ]
    for [ i: i32 0, i < n, i += 1 ]
        s5 : f32 [ au2.samples[ i ] * 32767.0 ]
        if [ s5 >  32767.0 ] s5 =  32767.0
        if [ s5 < -32768.0 ] s5 = -32768.0
        c.pcm[ i ] = i16[ s5 ]
    SherpaOnnxDestroyOfflineTtsGeneratedAudio[ au2 ]
    if [ !tts.mix ]
        tts.mix = AudioMixer [ sample_rate: 48000 ]
        tts.mix.hold[]
        if [ !tts.mix.start[] ]
            tts.mix = null
            return 3
    # the mixer voice borrows the clip; hold so it survives this call
    c.hold[]
    tts.mix.play[ c, false, 1.0 ]
    return 0

# the element form, for a host that just wants to drop one in. it owns nothing:
# the flat functions above hold the device, so there is a single owner.
element Dictation
    # flip to start/stop the stream; the host owns the button
    public  active   : bool
    # what was heard so far — the host shows this for sign-off
    public  text     : string
    # speech-band energy of the last frame (0..1), for a level readout
    public  level    : f32
    intern  was_on   : bool

    func render [] -> Elements
        if [ active != was_on ]
            was_on = active
            if [ active ]
                dictation_start[]
            el
                dictation_stop[]
        if [ !active ] return null
        # keep frames coming; a stalled window would stall the pump
        if [ ux ] ux.will_animate = true
        dictation_poll[]
        level = dictation_level[]
        text  = dictation_text[]
        return null

    public func on_unload [ ]
        dictation_stop[]

# spectra --file <caf/m4a/mp3> [--out png] [--img_w N] [--img_h N]
# spectra --dataset <cv dir> --split dev --outdir <dir> [--limit N]
element main : trinity
    # the swapchain presents the LAST render's color; the Background
    # chain provides it — an app without one has nothing to present
    public background : string [ 'Background' ]
    # a host (orbiter) sizes an attached app with these — the standard set an
    # app declares to be launchable in a pane.
    public width      : i32 [ 1280 ]
    public height     : i32 [ 720 ]
    # the document — spectra's default (positional) argument, so orbiter hands
    # us a claimed .mp3 with no flag at all. a `path` so with_cstrs normalizes
    # a relative arg to absolute against the launch dir (cwd is the bundle).
    default file   : path
    # --out makes --file a ONE-SHOT spectrograph render; without it, --file
    # opens the player: the spectrograph is the scrub track and it plays.
    public out     : string
    # player state: the decoded clip, its mixer voice, and the spectrograph
    # drawn as the scrub track (playhead rides it; a click seeks).
    intern pclip   : AudioClip
    intern pmix    : AudioMixer
    intern pvoice  : Voice
    intern ptex    : Texture
    intern ptrack  : Image
    public img_w   : i32 [ 1024 ]
    public img_h   : i32 [ 512 ]
    public dataset : string
    public libri   : string                # LibriSpeech root (extracted)
    public split   : string [ 'dev' ]
    public outdir  : string
    public limit   : i32 [ 0 ]
    # --whisper <size>: fetch the real openai weights (safetensors)
    # into models/whisper-<size>.safetensors, then exit
    public whisper : string
    # --check: run the whisper self-test (reader/encode/decode) and exit
    public check   : bool
    intern cap     : spectra
    intern cap_ok  : bool
    intern st_x    : i32
    intern st_buf  : @u8                # 1024 x 64 rgba sweep image
    intern st_tex  : Texture
    intern st_act  : @f32               # per-column speech-band energy
    intern st_ema  : f32                   # ~100ms running avg of energy
    intern st_words : array SpectWord      # read results land here
    # live whisper: rolling mic ring + utterance state + worker job
    intern w_net   : WhisperNet
    intern w_raw   : @i16                  # 32s mono 48k ring
    intern w_wr    : i64                   # absolute samples written
    intern w_state : i32
    intern w_start : i64
    intern w_act   : i64                   # last sample where speech energy held
    intern w_quiet : i32
    intern w_tid   : u64
    intern w_job   : WhisperJob
    intern w_text  : string
    intern w_gpu   : whisper_vk
    intern w_gtry  : bool
    # the reader: read1.ptc on interval over the trailing window
    intern rd_hnd  : ARef                  # torchscript handle
    intern st_mag  : @f32               # gray magnitudes, 64 x 1024 ring
    intern st_abs  : i64                   # absolute column counter
    intern rd_next : i64                   # next read at this abs column
    intern rd_in   : @f32               # contiguous window, 64 x W
    intern rd_out  : @f32               # per-column token/prob/sect
    intern voc_tok : @i32               # vocab: token ids
    intern voc_w   : array string          # vocab: words (same order)
    intern voc_n   : i32
    intern rd_q    : string                # the unnamed-word glyph
    # --teach: read prompted sentences; the model force-aligns each
    # take (the sentence is KNOWN) and writes self_{i} training clips
    public teach   : bool
    intern th_sent : string
    intern th_words : array string
    intern th_toks : @i32
    intern th_ntk  : i32
    intern th_state : i32                  # 0 wait, 1 speaking
    intern th_quiet : i32
    intern th_start : i64
    intern th_i    : i32
    intern th_spans : @i32
    intern th_last : string                # last save announcement
    # --annotate: play random translated clips, click word boundaries
    public annotate : bool
    intern ann_n    : i32                  # clips in outdir
    intern ann_id   : i32                  # current clip id
    intern ann_img  : Image
    intern ann_tex  : Texture
    intern ann_clip : AudioClip
    intern ann_out  : AudioOut
    intern ann_pos  : i64                  # playback cursor, frames
    intern ann_marks : @f32             # boundary columns, sorted
    intern ann_nm   : i32
    intern ann_words : array string
    intern ann_sent : string
    intern ann_rx   : f32                  # spectro rect, set in draw
    intern ann_rw   : f32
    intern ann_seed : i64

    # one line of a translated .agi by key
    func ann_field [ text: string, key: string ] -> string
        lines2 : array string [ text.split[ '\n' ] ]
        pre : string '{key}: '
        for [ li2: i32 0, li2 < lines2.count, li2 += 1 ]
            ln2 : lines2[ li2 ]
            if [ ln2.count <= pre.count ] continue
            hd2 : ln2.mid[ 0, pre.count ]
            if [ hd2 == pre ]
                return ln2.mid[ pre.count, ln2.count - pre.count ]
        return string ''

    func ann_pick []
        ann_seed = ann_seed * 6364136223846793005 + 1442695040888963407
        ann_id = i32[ (ann_seed % i64[ ann_n ] + i64[ ann_n ]) % i64[ ann_n ] ]
        ap : path '{outdir}/{split}_{ann_id}.agi'
        text : (ap.load[ typeid[ string ], null ] to string)
        if [ !text ] return
        img5 : ann_field[ text, 'image' ]
        src5 : ann_field[ text, 'source' ]
        ann_sent = ann_field[ text, 'sentence' ]
        ann_sent.hold[]
        ann_words = ann_sent.split[ ' ' ]
        ann_words.hold[]
        ann_img = Image [ uri: path '{outdir}/{img5}' ]
        ann_img.hold[]
        ann_tex = null
        # half speed, same pitch (youtube 0.5x): the clip itself is
        # SOLA-stretched 2x and plays at its normal rate
        ann_clip = stretch_clip[ caf_load[ path src5 ], 2.0 ]
        if [ ann_clip ] ann_clip.hold[]
        ann_pos = 0
        ann_nm = 0
        if [ ann_clip && (!ann_out || !ann_out.active) ]
            ann_out = AudioOut [ sample_rate: ann_clip.rate, channels: ann_clip.channels, buffer_size: 512 ]
            ann_out.hold[]
            ann_out.open[]

    # marks in column order (placed order preserved in ann_marks)
    func ann_sorted [ dst: @f32 ]
        for [ i7: i32 0, i7 < ann_nm, i7 += 1 ]
            v7 : f32 [ ann_marks[ i7 ] ]
            j7 : i32 [ i7 ]
            for [ j7 > 0 && dst[ j7 - 1 ] > v7 ]
                dst[ j7 ] = dst[ j7 - 1 ]
                j7 -= 1
            dst[ j7 ] = v7

    # rewrite this clip's .agi with the clicked marks line
    func ann_save []
        ap : path '{outdir}/{split}_{ann_id}.agi'
        text : (ap.load[ typeid[ string ], null ] to string)
        if [ !text ] return
        lines3 : array string [ text.split[ '\n' ] ]
        body3 : string ''
        for [ li3: i32 0, li3 < lines3.count, li3 += 1 ]
            ln3 : lines3[ li3 ]
            if [ ln3.count < 1 ] continue
            hd3 : string ''
            if [ ln3.count > 7 ] hd3 = ln3.mid[ 0, 7 ]
            if [ hd3 == 'marks: ' ] continue
            body3 = '{body3}{ln3}\n'
        srt3 : local f32 [ 256 ]
        ann_sorted[ srt3 ]
        mk3 : string ''
        for [ mi3: i32 0, mi3 < ann_nm, mi3 += 1 ]
            v3 : i32 [ i32[ srt3[ mi3 ] ] ]
            mk3 = '{mk3}{v3} '
        body3 = '{body3}marks: {mk3}\n'
        ap.save[ body3, null ]
        puts 'annotate: {split}_{ann_id} marks: {mk3}'

    # app-private storage (path.path_storage): downloaded models + the
    # last-used model name. share stays static build resources.
    func whisper_weights [ nm: string ] -> path
        d : path.path_storage[ 'spectra' ]
        return path '{d}/whisper-{nm}.safetensors'

    func whisper_vocab [] -> path
        d : path.path_storage[ 'spectra' ]
        return path '{d}/whisper-vocab.json'

    # the whisper model name last used, persisted across launches
    func saved_model [] -> string
        d : path.path_storage[ 'spectra' ]
        if [ !d ] return null
        mp : path '{d}/whisper.txt'
        if [ !mp.exists[] ] return null
        txt : string [ mp.load[ typeid[string], null ] ]
        if [ !txt ] return null
        return txt.trim[]

    func save_model [ nm: string ]
        d : path.path_storage[ 'spectra' ]
        if [ !d ] return
        mp2 : path '{d}/whisper.txt'
        mp2.save[ nm, null ]

    func init []
        if [ file && whisper && whisper.count > 0 ]
            c8 : caf_load[ file ]
            if [ !c8 ] exit[ 1 ]
            mel8 : whisper_mel[ c8 ]
            if [ mel_png[ mel8, path out ] ]
                puts 'whisper mel: {out}'
            dst8 : whisper_weights[ whisper ]
            if [ dst8.exists[] ]
                wsp8 : WhisperNet [ src: dst8 ]
                if [ wsp8.valid ]
                    puts 'whisper: encoding…'
                    enc8 : wsp8.encode[ mel8 ]
                    puts 'whisper: decoding…'
                    ids8 : wsp8.transcribe[ enc8, 64 ]
                    txt8 : wsp8.text_for[ ids8 ]
                    if [ txt8 ]
                        puts 'whisper:{txt8}'
                    el
                        line8 : string [ '' ]
                        for [ k8: i32 0, k8 < ids8.count, k8 += 1 ]
                            line8 = '{line8} {ids8[k8]}'
                        puts 'whisper tokens:{line8}'
            exit[ 0 ]
        if [ whisper && whisper.count > 0 ]
            dst : whisper_weights[ whisper ]
            vjs : whisper_vocab[]
            if [ !vjs.exists[] ]
                nv0 : i64 [ Http.download[ 'https://huggingface.co/openai/whisper-{whisper}/resolve/main/vocab.json', vjs ] ]
                if [ nv0 > 0 ]
                    puts 'spectra: fetched vocab ({nv0} bytes)'
            if [ !dst.exists[] ]
                puts 'spectra: fetching whisper-{whisper} weights…'
                n9 : i64 [ Http.download[ 'https://huggingface.co/openai/whisper-{whisper}/resolve/main/model.safetensors', dst ] ]
                if [ n9 <= 0 ]
                    puts 'spectra: download failed'
                    exit[ 1 ]
                mb9 : i64 [ n9 / 1048576 ]
                puts 'spectra: wrote {dst} ({mb9} MB)'
            if [ check ]
                # verify the reader end-to-end (header + one tensor)
                st9 : safetensors [ src: dst ]
                t9 : st9.tensor_named[ 'model.decoder.embed_positions.weight' ]
                if [ !t9 ]
                    puts 'spectra: {dst} present but reader failed'
                    exit[ 1 ]
                n9c : i64 [ t9.tensor_shape.total[] ]
                sum9 : f64 [ 0.0 ]
                for [ i9: i64 0, i9 < n9c, i9 += 1 ]
                    sum9 += f64[ t9.floats[i9] ]
                mean9 : f64 [ sum9 / f64[ n9c ] ]
                puts 'spectra: whisper-{whisper} ok — {n9c} floats, mean {mean9}'
                # encoder smoke: deterministic 8x80 mel through all 12 blocks
                wsp : WhisperNet [ src: dst ]
                if [ !wsp.valid ]
                    puts 'spectra: whisper model load failed'
                    exit[ 1 ]
                mel9 : tensor [ tensor_shape: 8x80 ]
                for [ tt: i32 0, tt < 8, tt += 1 ]
                    for [ cc: i32 0, cc < 80, cc += 1 ]
                        mel9.floats[tt * 80 + cc] = sinf[ f32[tt] * 0.1f + f32[cc] * 0.05f ]
                enc9 : wsp.encode[ mel9 ]
                ne9 : i64 [ enc9.tensor_shape.total[] ]
                se9 : f64 [ 0.0 ]
                for [ i9: i64 0, i9 < ne9, i9 += 1 ]
                    se9 += f64[ enc9.floats[i9] ]
                me9 : f64 [ se9 / f64[ ne9 ] ]
                puts 'spectra: encode ok — {ne9} floats, mean {me9}, first {enc9.floats[0]} {enc9.floats[1]} {enc9.floats[2]}'
                # decoder smoke: one greedy step from the seed prompt
                seed9 : new i32 [ 8 ]
                seed9[0] = 50258
                seed9[1] = 50259
                seed9[2] = 50359
                seed9[3] = 50363
                tk9 : i32 [ wsp.decode_step[ enc9, (seed9 to handle), 4 ] ]
                puts 'spectra: decode ok — first token {tk9}'
                exit[ 0 ]
        if [ libri ]
            if [ !outdir ]
                puts 'spectra: --libri needs --outdir'
                exit[ 1 ]
            libri_translate[ path libri, split, path outdir, limit ]
            exit[ 0 ]
        if [ dataset ]
            if [ !outdir ]
                puts 'spectra: --dataset needs --outdir'
                exit[ 1 ]
            cv_translate[ path dataset, split, path outdir, limit ]
            exit[ 0 ]
        if [ annotate ]
            if [ !outdir ]
                puts 'spectra: --annotate needs --outdir (the translated set)'
                exit[ 1 ]
            n5 : i32 [ 0 ]
            for [ true ]
                p5 : path '{outdir}/{split}_{n5}.agi'
                if [ !p5.exists[] ] break
                n5 += 1
            if [ n5 < 1 ]
                puts 'spectra: no {split}_*.agi under {outdir}'
                exit[ 1 ]
            ann_n = n5
            ann_marks = new f32 [ 256 ]
            ann_seed = epoch_millis[]
            ann_pick[]
            animated = true
            focusable = true
            puts 'annotate: {ann_n} clips — click between words; click a mark again to finish; U undo, N skip, space replay'
            return
        if [ file && out && out.count > 0 ]
            c : caf_load[ file ]
            if [ !c ] exit[ 1 ]
            if [ spectrograph[ c, path out, img_w, img_h, 20.0, 10000.0, false, null ] ]
                puts 'spectrograph: {out}'
            exit[ 0 ]
        # player: decode, render the spectrograph as the scrub track, and play.
        # caf_load sniffs the container (ID3/MPEG sync -> mp3_load), so this is
        # the same path for every audio format spectra claims.
        if [ file ]
            pclip = caf_load[ file ]
            if [ !pclip ]
                puts 'spectra: cannot decode {file}'
                exit[ 1 ]
            pclip.hold[]
            # play FIRST — the spectrograph over a long clip is expensive and
            # must not delay audio (a 30-min file made it 'sit there')
            pmix = AudioMixer [ sample_rate: pclip.rate ]
            pmix.hold[]
            if [ pmix.start[] ]
                pmix.play_p[ pclip, false, 1.0, 1.0 ]
            puts 'spectra: playing {file} ({pclip.frames} frames @ {pclip.rate})'
            # then build the scrub track
            trk : path '/tmp/spectra-track-{getpid[]}.png'
            if [ spectrograph[ pclip, trk, img_w, img_h, 20.0, 10000.0, false, null ] ]
                ptrack = Image [ uri: trk ]
                if [ ptrack ] ptrack.hold[]
        cap = spectra [ size: 2048, sample_rate: 48000, device: 'default' ]
        cap.hold[]
        cap_ok = cap.open[]
        if [ !cap_ok ] puts 'spectra: no capture device — window stays silent'
        # live whisper: always load when the model is on disk (--whisper
        # only picks a size / provisions). the draw loop segments
        # utterances; a worker thread transcribes on each pause.
        if [ cap_ok ]
            wname : string [ whisper ]
            if [ !wname || wname.count == 0 ] wname = saved_model[]
            if [ !wname || wname.count == 0 ] wname = 'small'
            wm : whisper_weights[ wname ]
            if [ wm.exists[] ]
                puts 'spectra: loading whisper-{wname}…'
                w_net = WhisperNet [ src: wm ]
                w_net.hold[]
                if [ w_net.valid ]
                    w_raw = new i16 [ 1536000 ]
                    hold[ (w_raw to Au) ]
                    save_model[ wname ]
                    puts 'spectra: whisper ready — speak; a pause transcribes'
            el [ whisper ]
                puts 'spectra: no {wm}'
        # stream continuously: repaint every frame, never cache-skip
        animated = true
        # the word reader (optional): models/read1.ptc + its vocab
        mp8 : string [ '/src/silver/foundry/spectra' ]
        rp8 : path 'models/read1.ptc'
        if [ !rp8.exists[] ] rp8 = path '{mp8}/models/read1.ptc'
        if [ rp8.exists[] ]
            rs8 : string '{rp8}'
            rd_hnd = ts_load[ rs8.chars ]
        if [ rd_hnd ]
            st_mag = new f32 [ 65536 ]
            rd_in = new f32 [ 12288 ]
            rd_out = new f32 [ 576 ]
            rd_q = string '?'
            rd_q.hold[]
            voc_tok = new i32 [ 4200 ]
            voc_w = array string [ alloc: 4200 ]
            voc_w.hold[]
            vp8 : path '{mp8}/models/read1-vocab.txt'
            vs8 : (vp8.load[ typeid[ string ], null ] to string)
            if [ vs8 ]
                vl8 : array string [ vs8.split[ '\n' ] ]
                for [ vi8: i32 0, vi8 < vl8.count, vi8 += 1 ]
                    lv8 : vl8[ vi8 ]
                    if [ !lv8 || lv8.count < 3 ] continue
                    sp8 : num [ lv8.index_of[ ' ' ] ]
                    if [ sp8 < 1 ] continue
                    tk8 : lv8.mid[ 0, i32[ sp8 ] ]
                    wd8 : lv8.mid[ i32[ sp8 ] + 1, lv8.count - i32[ sp8 ] - 1 ]
                    if [ voc_n >= 4200 ] break
                    voc_tok[ voc_n ] = i32[ tk8.real_value[] ]
                    voc_w += wd8
                    voc_n += 1
            puts 'spectra: reader loaded ({voc_n} words named)'
        el
            puts 'spectra: no models/read1.ptc — stream view only'
        if [ teach ]
            if [ !outdir ]
                puts 'spectra: --teach needs --outdir (the training set dir)'
                exit[ 1 ]
            if [ !rd_hnd ]
                puts 'spectra: --teach needs models/read1.ptc'
                exit[ 1 ]
            th_toks = new i32 [ 64 ]
            th_spans = new i32 [ 128 ]
            ann_seed = epoch_millis[]
            for [ true ]
                pt5 : path '{outdir}/self_{th_i}.agi'
                if [ !pt5.exists[] ] break
                th_i += 1
            th_pick[]
            puts 'teach: read each sentence aloud — silence ends the take (N skips)'

    # live stream: 64 fft bands (150Hz..8kHz, the model's own range) in
    # a 1024x64 sweep image, drawn as a 128px strip off the element
    # bottom. columns advance left to right and wrap, painting over the
    # last pass. the canvas clears every repaint, so history lives in
    # the texture; ticks and word labels paint with the canvas
    # the trainer's tokenizer, reproduced: fnv1a-32 of the lowercase
    # word, % 4096 + 1; words outside the named vocab -> 4097 <other>
    func th_hash [ wd: string ] -> i32
        h : u32 [ 2166136261 ]
        cs : symbol [ wd.chars ]
        for [ i: i32 0, i < wd.count, i += 1 ]
            c : u32 [ u32[ i32[ cs[ i ] ] ] ]
            h = (h ^ c) * 16777619
        t : i32 [ i32[ h % 4096 ] + 1 ]
        for [ v: i32 0, v < voc_n, v += 1 ]
            if [ voc_tok[ v ] == t ] return t
        return 4097

    # next prompt: a random short sentence from the translated set
    func th_pick []
        for [ true ]
            ann_seed = ann_seed * 6364136223846793005 + 1442695040888963407
            k : i32 [ i32[ (ann_seed % 2703 + 2703) % 2703 ] ]
            ap : path '{outdir}/dev-clean_{k}.agi'
            if [ !ap.exists[] ] continue
            text : (ap.load[ typeid[ string ], null ] to string)
            if [ !text ] continue
            sn : ann_field[ text, 'sentence' ]
            ws : array string [ sn.split[ ' ' ] ]
            nw : i32 [ 0 ]
            for [ wi: i32 0, wi < ws.count, wi += 1 ]
                wv : ws[ wi ]
                if [ wv && wv.count > 0 ] nw += 1
            if [ nw < 4 || nw > 9 ] continue
            th_sent = sn
            th_sent.hold[]
            th_words = array string [ ]
            th_words.hold[]
            th_ntk = 0
            for [ wi2: i32 0, wi2 < ws.count, wi2 += 1 ]
                wv2 : ws[ wi2 ]
                if [ !wv2 || wv2.count < 1 ] continue
                th_words += wv2
                th_toks[ th_ntk ] = th_hash[ wv2 ]
                th_ntk += 1
            th_state = 0
            th_quiet = 0
            return

    # one finished take: force-align the known words, save the clip
    func th_save [ a0: i64, a1: i64 ]
        w6 : i32 [ i32[ a1 - a0 ] ]
        if [ w6 < 16 || w6 > 1000 ] return
        for [ y6: i32 0, y6 < 64, y6 += 1 ]
            for [ x6: i32 0, x6 < w6, x6 += 1 ]
                rx6 : i32 [ i32[ (a0 + i64[ x6 ]) % 1024 ] ]
                rd_in[ y6 * w6 + x6 ] = st_mag[ y6 * 1024 + rx6 ]
        n6 : i32 [ ts_align[ rd_hnd, rd_in, 64, w6, th_toks, th_ntk, th_spans ] ]
        if [ n6 < 1 ]
            th_last = string 'alignment failed — take skipped'
            th_last.hold[]
            return
        img6 : Image [ width: w6, height: 64, format: Pixel.u8, channels: 1 ]
        pd6 : @u8 [ img6.vdata[] ]
        for [ y8: i32 0, y8 < 64, y8 += 1 ]
            for [ x8: i32 0, x8 < w6, x8 += 1 ]
                dg8 : i64 [ i64[ y8 ] * w6 + x8 ]
                pd6[ dg8 ] = u8[ rd_in[ y8 * w6 + x8 ] * 255.0 ]
        img6.png[ path '{outdir}/self_{th_i}.png' ]
        wsp6 : string ''
        for [ k6: i32 0, k6 < th_ntk, k6 += 1 ]
            s6 : i32 [ th_spans[ k6 * 2 ] ]
            e6 : i32 [ th_spans[ k6 * 2 + 1 ] ]
            if [ s6 < 0 ] s6 = 0
            if [ e6 <= s6 ] e6 = s6 + 1
            wsp6 = '{wsp6}{s6} {e6} '
        fr6 : i64 [ i64[ w6 ] * 2048 ]
        body6 : string 'image: self_{th_i}.png\nsentence: {th_sent}\nspeaker: self\nrate: 48000\nframes: {fr6}\nduration: {f32[ w6 ] * 0.0427}\nsource: live\nwspans: {wsp6}\n'
        ag6 : path '{outdir}/self_{th_i}.agi'
        ag6.save[ body6, null ]
        th_last = string 'saved self_{th_i} ({th_ntk} words aligned)'
        th_last.hold[]
        puts 'teach: saved self_{th_i}'
        th_i += 1

    # merge one read's word runs into st_words. the key is COLUMN
    # OVERLAP in absolute stream position — an overlapping span is the
    # same word instance re-read (newer wins: more right context);
    # disjoint spans NEVER join, so repeated words stay separate
    func rd_merge [ base9: i32, n9: i32 ]
        i9 : i32 [ 0 ]
        for [ i9 < n9 ]
            tk : i32 [ i32[ rd_out[ i9 * 3 ] ] ]
            if [ tk == 0 ]
                i9 += 1
                continue
            j9 : i32 [ i9 ]
            ps : f32 [ 0.0 ]
            ss : f32 [ 0.0 ]
            for [ j9 < n9 && i32[ rd_out[ j9 * 3 ] ] == tk ]
                ps += rd_out[ j9 * 3 + 1 ]
                ss += rd_out[ j9 * 3 + 2 ]
                j9 += 1
            # a word spans >= 3 columns (~130ms); shorter = toggle noise
            ln9 : i32 [ j9 - i9 ]
            ok9 : bool [ ln9 >= 3 ]
            if [ ok9 && ps / f32[ ln9 ] < 0.30 ] ok9 = false
            if [ ok9 && ss / f32[ ln9 ] < 0.35 ] ok9 = false
            if [ ok9 ]
                a0 : i32 [ base9 + i9 ]
                a1 : i32 [ base9 + j9 ]
                wd : rd_q
                for [ v9: i32 0, v9 < voc_n, v9 += 1 ]
                    if [ voc_tok[ v9 ] == tk ]
                        wd = voc_w[ v9 ]
                        break
                bi9 : i32 [ -1 ]
                bo9 : i32 [ 0 ]
                for [ wi9: i32 0, wi9 < st_words.count, wi9 += 1 ]
                    ew : st_words[ wi9 ]
                    o0 : i32 [ (ew.x0 > a0) ? ew.x0 : a0 ]
                    o1 : i32 [ (ew.x1 < a1) ? ew.x1 : a1 ]
                    if [ o1 - o0 > bo9 ]
                        bo9 = o1 - o0
                        bi9 = wi9
                if [ bi9 >= 0 ]
                    uw : st_words[ bi9 ]
                    uw.x0 = a0
                    uw.x1 = a1
                    uw.text = wd
                el
                    nw : SpectWord [ x0: a0, x1: a1, text: wd ]
                    st_words += nw
            i9 = j9
        # prune once the oldest word falls off the ring
        if [ st_words.count > 0 ]
            h0 : st_words[ 0 ]
            if [ i64[ h0.x1 ] < st_abs - 1024 ]
                keep : array SpectWord [ ]
                for [ ki: i32 0, ki < st_words.count, ki += 1 ]
                    kw : st_words[ ki ]
                    if [ i64[ kw.x1 ] >= st_abs - 1024 ] keep += kw
                keep.hold[]
                st_words = keep

    # annotate view: the clip's spectrogram large, audio looping,
    # marks as green lines; words label their regions once counts fit
    func ann_draw [ w: Window ]
        ux.will_animate = true
        cv : w.screen
        if [ ann_clip && ann_out && ann_out.active ]
            ch5 : i32 [ ann_clip.channels ]
            fr5 : i64 [ 512 ]
            if [ ann_pos + fr5 > ann_clip.frames ]
                ann_pos = 0
            nb5 : i64 [ fr5 * i64[ ch5 ] * 2 ]
            memcpy[ ann_out.buffer, @ann_clip.pcm[ ann_pos * i64[ ch5 ] ], nb5 ]
            ann_out.write[ i32[ fr5 ] ]
            ann_pos += fr5
        if [ ann_img && !ann_tex ]
            ann_tex = Texture [ vk: cv.vk, w: ux, linear: true, mip_levels: 1, sampler: ann_img ]
            ann_tex.hold[]
        if [ !ann_tex ] return
        cols : f32 [ f32[ ann_img.width ] ]
        ann_rx = 40.0
        ann_rw = bounds.w - 80.0
        ry : f32 [ bounds.h * 0.18 ]
        rh : f32 [ bounds.h * 0.5 ]
        cv.draw_image[ ann_tex, rect [ x: ann_rx, y: ry, w: ann_rw, h: rh ] ]
        cv.paint[]
        # playback cursor
        if [ ann_clip && ann_clip.frames > 0 ]
            px5 : f32 [ ann_rx + f32[ ann_pos ] / f32[ ann_clip.frames ] * ann_rw ]
            cv.rounded_rect[ px5, ry, 2.0, rh, 0.0, 0.0, 0.0, 0.0 ]
            cv.fill_color[ rgba [ r: 1.0, g: 1.0, b: 1.0, a: 0.6 ] ]
            cv.paint[]
        # boundary marks
        for [ m5: i32 0, m5 < ann_nm, m5 += 1 ]
            mx5 : f32 [ ann_rx + ann_marks[ m5 ] / cols * ann_rw ]
            cv.rounded_rect[ mx5 - 1.0, ry - 8.0, 3.0, rh + 16.0, 0.0, 0.0, 0.0, 0.0 ]
            cv.fill_color[ rgba [ r: 0.3, g: 1.0, b: 0.55, a: 0.9 ] ]
            cv.paint[]
        # region words once the marks split the clip into word count
        need5 : i32 [ ann_words.count - 1 ]
        cv.sync_fence[]
        if [ ann_nm == need5 ]
            srt5 : local f32 [ 256 ]
            ann_sorted[ srt5 ]
            for [ r5: i32 0, r5 < ann_words.count, r5 += 1 ]
                x05 : f32 [ 0.0 ]
                x15 : f32 [ cols ]
                if [ r5 > 0 ] x05 = srt5[ r5 - 1 ]
                if [ r5 < ann_nm ] x15 = srt5[ r5 ]
                wd5 : ann_words[ r5 ]
                cv.fill_color[ '#8fc' ]
                cv.draw_text[ '{wd5}',
                    rect [ x: ann_rx + x05 / cols * ann_rw, y: ry + rh + 8.0, w: (x15 - x05) / cols * ann_rw, h: 20.0 ],
                    vec2f [ 0.5, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
                cv.paint[]
        el
            cv.fill_color[ '#9ab' ]
            cv.draw_text[ '{ann_sent}',
                rect [ x: ann_rx, y: ry + rh + 8.0, w: ann_rw, h: 20.0 ],
                vec2f [ 0.5, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            cv.paint[]
        cv.fill_color[ '#678' ]
        cv.draw_text[ '{split}_{ann_id}  marks {ann_nm}/{need5}  click between words - click a mark to finish - U undo - N skip - space replay',
            rect [ x: ann_rx, y: bounds.h - 32.0, w: ann_rw, h: 20.0 ],
            vec2f [ 0.5, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
        cv.paint[]

    public func on_click [ ev: Event ]
        if [ !annotate || !ann_img ] return
        if [ ann_rw < 1.0 ] return
        ev.stop_propagation[]
        mx : f32 [ ev.mouse.pos.x - bounds.x ]
        cols : f32 [ f32[ ann_img.width ] ]
        c5 : f32 [ (mx - ann_rx) / ann_rw * cols ]
        if [ c5 < 0.0 || c5 > cols ] return
        # clicking an existing mark again ENDS the clip: save + next
        tol : f32 [ cols * 0.012 ]
        for [ i5: i32 0, i5 < ann_nm, i5 += 1 ]
            d5 : f32 [ ann_marks[ i5 ] - c5 ]
            if [ d5 < 0.0 ] d5 = 0.0 - d5
            if [ d5 < tol ]
                ann_save[]
                ann_pick[]
                return
        if [ ann_nm >= 256 ] return
        # PLACED order: space replays from the last one put down and
        # U undoes it; regions/save sort a copy
        ann_marks[ ann_nm ] = c5
        ann_nm += 1

    public func on_key [ ev: Event ]
        if [ teach ]
            kt : i32 [ ev.key.unicode ]
            if [ kt == 78 ] th_pick[]
            return
        if [ !annotate ] return
        k5 : i32 [ ev.key.unicode ]
        if [ k5 == 32 && ann_img && ann_clip ]
            # replay from the LAST MARK PUT DOWN, 100ms early
            cols6 : f32 [ f32[ ann_img.width ] ]
            pm6 : f32 [ 0.0 ]
            if [ ann_nm > 0 ] pm6 = ann_marks[ ann_nm - 1 ]
            np6 : i64 [ i64[ pm6 / cols6 * f32[ ann_clip.frames ] ] - i64[ ann_clip.rate ] / 10 ]
            if [ np6 < 0 ] np6 = 0
            ann_pos = np6
        if [ k5 == 85 && ann_nm > 0 ] ann_nm -= 1
        if [ k5 == 78 ] ann_pick[]

    public func draw [ w: Window ]
        if [ w.draw_stage != CanvasType.screen ] return
        if [ annotate ]
            ann_draw[ w ]
            return
        if [ !cap_ok ] return
        ux.will_animate = true
        cv : w.screen
        sw9 : i32 [ 1024 ]
        nb : i32 [ 64 ]
        if [ !st_act ]
            st_act = new f32 [ sw9 ]
            st_words = array SpectWord [ ]
            st_words.hold[]
            nby : i32 [ sw9 * nb * 4 ]
            nb2 : new u8 [ nby ]
            for [ z9: i32 0, z9 < nby, z9 += 4 ]
                nb2[ z9 + 3 ] = 255
            st_buf = nb2
        if [ !st_tex ]
            st_tex = Texture [ vk: cv.vk, w: cv.w, width: sw9, height: nb, linear: true ]
            st_tex.hold[]
        strip : f32 [ 128.0 ]
        y0 : f32 [ bounds.h - strip ]
        xs9 : f32 [ bounds.w / f32[ sw9 ] ]
        if [ cap.capture[] ]
            fmin : f32 [ 150.0 ]
            fmax : f32 [ 8000.0 ]
            nyq : f32 [ f32[ cap.sample_rate ] * 0.5 ]
            if [ fmax > nyq ] fmax = nyq
            lr : f32 [ log[ fmax / fmin ] ]
            half2 : i32 [ cap.size / 2 ]
            en9 : f32 [ 0.0 ]
            for [ b: i32 0, b < nb, b += 1 ]
                t : f32 [ f32[ nb - 1 - b ] / f32[ nb - 1 ] ]
                fq : f32 [ fmin * exp[ t * lr ] ]
                fb : f32 [ fq * f32[ cap.size ] / f32[ cap.sample_rate ] ]
                bi : i32 [ i32[ fb ] ]
                if [ bi > half2 - 2 ] bi = half2 - 2
                fr : f32 [ fb - f32[ bi ] ]
                m0 : f32 [ cap.bins[ bi ] ]
                m1 : f32 [ cap.bins[ bi + 1 ] ]
                mag : f32 [ m0 + (m1 - m0) * fr ]
                en9 += mag
                amp : f32 [ mag / 512.0 ]
                db : f32 [ 8.6858896 * log[ amp + 0.0000000001 ] ]
                tv : f32 [ (db + 80.0) / 80.0 ]
                if [ tv < 0.0 ] tv = 0.0
                if [ tv > 1.0 ] tv = 1.0
                rgb : i32 [ heat[ tv ] ]
                di : i32 [ (b * sw9 + st_x) * 4 ]
                st_buf[ di ]     = u8[ rgb / 65536 ]
                st_buf[ di + 1 ] = u8[ (rgb / 256) % 256 ]
                st_buf[ di + 2 ] = u8[ rgb % 256 ]
                st_buf[ di + 3 ] = 255
                if [ st_mag ]
                    st_mag[ b * sw9 + st_x ] = tv
            # tracking state: ~100ms running average of band energy —
            # green only when the sound STAYS continuous, one hot
            # window alone decays before it crosses the threshold
            en9 = en9 / (f32[ nb ] * 24.0)
            if [ en9 > 1.0 ] en9 = 1.0
            # fast attack, slow release: rising sound catches in ~100ms,
            # the tail hangs on ~3x longer before the tick lets go
            if [ en9 > st_ema ]
                st_ema = st_ema * 0.6 + en9 * 0.4
            el
                st_ema = st_ema * 0.88 + en9 * 0.12
            st_act[ st_x ] = st_ema
            # teach take machine: speech starts the take, ~0.9s of
            # quiet ends it — align + save, then the next prompt
            if [ teach && th_ntk > 0 ]
                if [ th_state == 0 ]
                    if [ st_ema > 0.12 ]
                        th_state = 1
                        th_start = st_abs - 5
                        if [ th_start < 0 ] th_start = 0
                        th_quiet = 0
                el
                    if [ st_ema < 0.08 ]
                        th_quiet += 1
                        if [ th_quiet >= 20 ]
                            th_save[ th_start, st_abs - 14 ]
                            th_pick[]
                    el
                        th_quiet = 0
            # gpu engine: built lazily at first frame (pipeline compile is
            # a one-time hitch), verified against the cpu encoder
            if [ w_net && !w_gtry && !teach ]
                w_gtry = true
                puts 'whisper: building gpu pipelines…'
                g0 : whisper_vk [ model: w_net, vk: cv.vk, win: w ]
                if [ g0.valid ]
                    g0.hold[]
                    w_gpu = g0
                    melg : tensor [ tensor_shape: 8x80 ]
                    for [ tg: i32 0, tg < 8, tg += 1 ]
                        for [ cg: i32 0, cg < 80, cg += 1 ]
                            melg.floats[tg * 80 + cg] = sinf[ f32[tg] * 0.1f + f32[cg] * 0.05f ]
                    eg : w_gpu.encode[ melg ]
                    ec : w_net.encode[ melg ]
                    ng : i64 [ eg.tensor_shape.total[] ]
                    sg : f64 [ 0.0 ]
                    sc : f64 [ 0.0 ]
                    for [ ig: i64 0, ig < ng, ig += 1 ]
                        sg += f64[ eg.floats[ig] ]
                        sc += f64[ ec.floats[ig] ]
                    puts 'whisper: gpu encoder ready — parity gpu {sg / f64[ng]} cpu {sc / f64[ng]}'
                el
                    puts 'whisper: gpu unavailable — cpu encoder'
            # live whisper: ring the raw window in, segment utterances the
            # same way the teach take machine does, hand a copy to a thread
            if [ w_net && w_raw && !teach ]
                ns5 : i64 [ cap.size ]
                for [ i5: i64 0, i5 < ns5, i5 += 1 ]
                    w_raw[(w_wr + i5) % 1536000] = cap.buf[i5]
                w_wr += ns5
                if [ !w_job ]
                    if [ w_state == 0 ]
                        if [ st_ema > 0.12 ]
                            w_state = 1
                            w_start = w_wr - 38400
                            if [ w_start < 0 ] w_start = 0
                            w_act   = w_wr
                            w_quiet = 0
                    el
                        # the utterance END is the last column the band-energy
                        # gate held — the same detector that started the take
                        if [ st_ema > 0.10 ] w_act = w_wr
                        if [ st_ema < 0.08 ]
                            w_quiet += 1
                        el
                            w_quiet = 0
                        too_long : bool [ w_wr - w_start > 576000 ]
                        if [ w_quiet >= 20 || too_long ]
                            w_state = 0
                            e5 : i64 [ w_act + 16800 ]
                            if [ e5 > w_wr ] e5 = w_wr
                            n5 : i64 [ e5 - w_start ]
                            if [ n5 > 24000 ]
                                buf5 : new i16 [ n5 ]
                                hold[ (buf5 to Au) ]
                                for [ i5: i64 0, i5 < n5, i5 += 1 ]
                                    buf5[i5] = w_raw[(w_start + i5) % 1536000]
                                j5 : WhisperJob [ model: w_net, pcm: buf5, n: n5, c0: w_start / 2048, c1: e5 / 2048 ]
                                j5.hold[]
                                # gpu path: with a compute queue the WORKER
                                # encodes (low priority, sliced submits) —
                                # graphics never waits. no compute queue →
                                # legacy render-thread encode
                                if [ w_gpu ]
                                    if [ w_gpu.threaded[] ]
                                        j5.gpu = w_gpu
                                    el
                                        c7 : AudioClip [ rate: 48000, channels: 1, frames: n5, pcm: buf5 ]
                                        m7 : whisper_mel[ c7 ]
                                        mel_png[ m7, path '/tmp/live-mel.png' ]
                                        e7 : w_gpu.encode[ m7 ]
                                        e7.hold[]
                                        j5.enc = e7
                                w_job = j5
                                puts 'whisper: transcribing {n5 / 48000}s…'
                                pthread_create[ @w_tid, null, @spectra_whisper_thread, (j5 to handle) ]
                                pthread_detach[ w_tid ]
            if [ w_job && w_job.done ]
                w_text = w_job.text
                if [ w_text && w_text.count > 0 ]
                    puts 'whisper:{w_text}'
                    # anchor the transcript to its own span on the sweep
                    nw5 : SpectWord [ x0: i32[ w_job.c0 ], x1: i32[ w_job.c1 ], text: w_text ]
                    st_words += nw5
                    # prune entries that scrolled out of the ring
                    if [ st_words.count > 48 ]
                        keep5 : array SpectWord [ ]
                        for [ ki5: i32 0, ki5 < st_words.count, ki5 += 1 ]
                            kw5 : st_words[ ki5 ]
                            if [ i64[ kw5.x0 ] >= st_abs - i64[ sw9 ] ] keep5 += kw5
                        st_words = keep5
                        st_words.hold[]
                w_job = null
            # the sweep cursor: a dark gap one column ahead
            nx9 : i32 [ (st_x + 1) % sw9 ]
            for [ y2: i32 0, y2 < nb, y2 += 1 ]
                dg : i32 [ (y2 * sw9 + nx9) * 4 ]
                st_buf[ dg ]     = 15
                st_buf[ dg + 1 ] = 13
                st_buf[ dg + 2 ] = 26
                st_buf[ dg + 3 ] = 255
            st_x = nx9
            st_abs += 1
            st_tex.upload[ st_buf, sw9 * nb * 4 ]
            # interval read: every 12 columns (~0.5s) the reader takes
            # the trailing window in ONE pass; words merge by span
            if [ rd_hnd && !w_net && st_mag && st_abs >= rd_next ]
                rd_next = st_abs + 12
                w7 : i32 [ (st_abs < 192) ? i32[ st_abs ] : 192 ]
                if [ w7 >= 24 ]
                    for [ y7: i32 0, y7 < nb, y7 += 1 ]
                        for [ x7: i32 0, x7 < w7, x7 += 1 ]
                            rx7 : i32 [ i32[ (st_abs - i64[ w7 ] + i64[ x7 ]) % i64[ sw9 ] ] ]
                            rd_in[ y7 * w7 + x7 ] = st_mag[ y7 * sw9 + rx7 ]
                    n7r : i32 [ ts_read_cols[ rd_hnd, rd_in, nb, w7, rd_out, 576 ] ]
                    if [ n7r > 0 ] rd_merge[ i32[ st_abs ] - w7, n7r ]
        cv.draw_image[ st_tex, rect [ x: 0.0, y: y0, w: bounds.w, h: strip ] ]
        # busy hint; transcripts render anchored at their spans (st_words)
        if [ w_job ]
            cv.font_size[ 18 ]
            cv.fill_color[ '#9a9aa8' ]
            cv.draw_text[ 'transcribing…', rect [ x: 16.0, y: y0 - 42.0, w: bounds.w - 32.0, h: 32.0 ],
                vec2f [ 0.0, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            cv.paint[]
        cv.paint[]
        # activity ticks: bright marks over the columns fit to read
        run0 : i32 [ -1 ]
        for [ x3: i32 0, x3 <= sw9, x3 += 1 ]
            on9 : bool [ false ]
            if [ x3 < sw9 ]
                on9 = st_act[ x3 ] > 0.12
            if [ on9 && run0 < 0 ] run0 = x3
            if [ !on9 && run0 >= 0 ]
                cv.rounded_rect[ f32[ run0 ] * xs9, y0 - 4.0, f32[ x3 - run0 ] * xs9, 4.0, 0.0, 0.0, 0.0, 0.0 ]
                cv.fill_color[ rgba [ r: 0.3, g: 1.0, b: 0.55, a: 1.0 ] ]
                cv.paint[]
                run0 = -1
        # teach prompt: the sentence to read, take state underneath
        if [ teach && th_sent ]
            cv.sync_fence[]
            cv.fill_color[ '#fff' ]
            cv.draw_text[ '{th_sent}',
                rect [ x: 20.0, y: bounds.h * 0.3, w: bounds.w - 40.0, h: 30.0 ],
                vec2f [ 0.5, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            cv.paint[]
            st5 : string [ (th_state == 1) ? 'listening...' : 'read it aloud' ]
            cv.fill_color[ '#8fc' ]
            cv.draw_text[ '{st5}   {th_last}',
                rect [ x: 20.0, y: bounds.h * 0.3 + 36.0, w: bounds.w - 40.0, h: 20.0 ],
                vec2f [ 0.5, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            cv.paint[]
        # found words drawn OVER the spectra graph at their spans
        # (abs -> ring columns; seam-crossing spans skip one pass)
        for [ wi: i32 0, wi < st_words.count, wi += 1 ]
            sw2 : st_words[ wi ]
            if [ i64[ sw2.x0 ] < st_abs - i64[ sw9 ] ] continue
            r0w : i32 [ sw2.x0 % sw9 ]
            r1w : i32 [ sw2.x1 % sw9 ]
            if [ r1w <= r0w ] continue
            wx0 : f32 [ f32[ r0w ] * xs9 ]
            wx1 : f32 [ f32[ r1w ] * xs9 ]
            cv.sync_fence[]
            cv.fill_color[ '#dfe' ]
            cv.draw_text[ '{sw2.text}',
                rect [ x: wx0, y: y0 + 6.0, w: wx1 - wx0, h: 18.0 ],
                vec2f [ 0.5, 0.5 ], vec2f [ 0.0, 0.0 ], Overflow.visible, null ]
            cv.paint[]
#        half2: s.size / 2
#        for [ true ]
#            if [ s.capture[] ]
#                for [ i: i32 0, i < half2, i += 1 ]
#                    if [ i % 16 == 0 ]
#                        printf "%5d Hz |", i * s.sample_rate / s.size
#                        bar: i32 [ s.bins[i] * 50.0 ]
#                        if [ bar > 50 ]
#                            bar = 50
#                        for [ j: i32 0, j < bar, j += 1 ]
#                            printf "#"
#                        printf "\n"
#                printf "\033[%dA", half2 / 16
#        s.close
#        return 0
