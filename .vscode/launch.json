        {
            "name":             "hyperspace (compile)",
            "type":             "lldb",
            "request":          "launch",
            "preLaunchTask":    "build-silver-debug",
            "program":          "${workspaceFolder}/install/debug/silver",
            "args":             [ "hyperspace", "--verbose", "--clean" ],
            "cwd":              "${workspaceFolder}/install/share/hyperspace",
            "stopOnEntry":      false,
            "env": {
                "LD_LIBRARY_PATH":  "${workspaceFolder}/install/lib",
                "IMPORT":           "${workspaceFolder}/install",
                "ASAN_OPTIONS":     "detect_leaks=0 quarantine_size_mb=0",
                "VK_LAYER_PATH":    "${workspaceFolder}/install/share/vulkan/explicit_layer.d",
                "AU_SKIP_DROP":     ""
            },
            "initCommands": [
                "settings set target.process.stop-on-exec false"
            ]
        },
