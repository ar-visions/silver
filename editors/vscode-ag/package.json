{
  "name": "silver-ag",
  "displayName": "Silver (.ag)",
  "description": "Syntax highlighting for the Silver language (.ag files)",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.78.0"
  },
  "icon": "icon.png",
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [
      {
        "id": "ag",
        "aliases": ["Silver", "ag"],
        "extensions": [".ag"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icons/ag-light.svg",
          "dark": "./icons/ag-dark.svg"
        }
      }
    ],
    "grammars": [
      {
        "language": "ag",
        "scopeName": "source.ag",
        "path": "./syntaxes/ag.tmLanguage.json"
      }
    ]
  }
}
