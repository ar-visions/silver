{
  "name": "silver-ag",
  "displayName": "silver (.ag)",
  "description": "Silver language support for .ag modules",
  "version": "0.1.0",
  "engines": {
    "vscode": "^1.75.0"
  },
  "icon": "icon.png",
  "categories": ["Programming Languages"],
  "activationEvents": ["onLanguage:ag"],
  "main": "./extension.js",
  "contributes": {
    "languages": [
      {
        "id": "ag",
        "aliases": ["silver", "ag"],
        "extensions": [".ag"],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "icon-small.png",
          "dark": "icon-small.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "ag",
        "scopeName": "source.ag",
        "path": "./syntaxes/ag.tmLanguage.json"
      }
    ],
    "breakpoints": [
      {
        "language": "ag"
      }
    ]
  }
}
